    <JadeMethod name="getExtraInfo" id="52b2442a-5bd2-4819-8417-9d210f4a5002">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2	ChangeRequest 56835:[56836] EUP - VAS Truck Work Order

*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
begin

	inheritMethod(_dataContainer);

	addStr := self.allVehicleVisits.listString(Comma,CM_VehicleVisitRecord::jobNumber.name);
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Vehicle), DC_Label, 1, self.allVehicleVisits.first);
		block.addNewItem(addStr, DC_Data, 1, self.allVehicleVisits.first);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="36b74249-a8cd-4115-9f7c-256340d0b5b9">
        <source>getMyDebtor() : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/

vars
	debtor : CM_Debtor;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	vvr := self.allVehicleVisits.first;
	if vvr = null then
		vvr := self.allVehiclesCompleted.first;
	endif;
	
	if vvr &lt;&gt; null then
		truck := vvr.vehicle;
		if truck.carrier &lt;&gt; null then
			debtor := truck.carrier.myDebtor;
		endif;
	endif;
	
	if debtor = null then
		debtor :=  self.myParent.getMyDebtor();  // ### TFS BUG 58790 23JUN2023 NAVAB1
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
