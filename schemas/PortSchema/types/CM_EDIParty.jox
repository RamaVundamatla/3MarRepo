/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
