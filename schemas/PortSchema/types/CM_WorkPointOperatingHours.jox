    <JadeMethod name="getNetExchangeInterval" id="4e9c7fe7-f351-4d77-85bb-b77cdb811340">
        <source>getNetExchangeInterval():TimeStampInterval;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars
	
	grossInterval : TimeStampInterval;
	delayMinutes : Integer;
	delayInterval : TimeStampInterval;
	netInterval : TimeStampInterval;
	localExchangeEnd : TimeStamp;

begin

	if not self.exchangeStart.Date.isValid then
		return null;
	endif;
	
	localExchangeEnd := self.getExchangeEnd;
	grossInterval := localExchangeEnd - self.exchangeStart;
	
	delayMinutes := self.getDelayedMinutes;
	if delayMinutes &gt; 0 then
		delayInterval.set(0, 60000 * delayMinutes);
		netInterval := grossInterval - delayInterval;
	else
		netInterval := grossInterval;
	endif;
	
	return netInterval;

epilog

end;</source>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getRelativeLabourAshore" id="4745d6b3-16c0-4bf4-818f-523c0c5b8053">
        <source>getRelativeLabourAshore():TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation

*/

vars

	voyAshore : TimeStamp;
	returnTs : TimeStamp;

begin

	returnTs := app.actualTimeServer;
	
	voyAshore := self.myVoyage.labourOnShore;
	if voyAshore.Date.isValid and voyAshore &lt; returnTs then
		returnTs := voyAshore;
	endif;
	
	if labourEnd.Date.isValid and labourEnd &lt; returnTs then
		returnTs := labourEnd;
	endif;
	
	return returnTs;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
