    <JadeMethod name="initialise" id="34d0da10-2127-4363-86bd-26b508e289e7">
        <updating/>
        <source>initialise(	_parent 		: CM_BaseForm;
			_proxyWorkOrder : CM_WorkOrder; 
			_mode 			: Integer;
			_selectedTask 	: CM_WorkOrderDtl;
			_workOrderMode  : Integer;
			_voyage 		: CM_Voyage	)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/08/2009	cnwmd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders - new parameters for method
16/02/2022  navma1	Bug 52884: MTN - Work Order - Should Allow Multiple Tasks to be Added to a Cargo Work Order
*/

vars
	wodtl : CM_WorkOrderDtl;
	term  : CM_Terminal;
begin
	
	term 				:= self.myTerminal;					//16.02.2022 navma1 #52884
	self.isUseYardJobs	:= term.isUseYardJobsForCargoWo;    //16.02.2022 navma1 #52884
	
	
	self.myMainForm := _parent;
	self.setParentForm(_parent);
	
	_proxyWorkOrder.raiseExceptionIfNotTransient(method);
	foreach wodtl in _proxyWorkOrder.allWoDtls do
		wodtl.raiseExceptionIfNotTransient(method);
	endforeach;
	
	self.myProxyWorkOrder := _proxyWorkOrder;
	
	self.myCurrentProxyTask := _selectedTask;
	
	
	
	if self.myProxyWorkOrder.hasBeenApproved() then
		self.isApproved := true;
	else
		self.isApproved := false;		
	endif;
	
	self.mode := _mode;
	self.workOrderMode := _workOrderMode;										// TFS 38560
	if _selectedTask &lt;&gt; null and _selectedTask.getMyVoyageObject &lt;&gt; null then	// TFS 38560
		self.myVoyage := _selectedTask.getMyVoyageObject;						// TFS 38560
	elseif _voyage &lt;&gt; null then													// TFS 38560
		self.myVoyage := _voyage;												// TFS 38560
	endif;																		// TFS 38560
	
	if self.isApproved then
		self.setFormForApproved();
	endif;
epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_selectedTask" type="CM_WorkOrderDtl"/>
        <Parameter name="_workOrderMode" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
