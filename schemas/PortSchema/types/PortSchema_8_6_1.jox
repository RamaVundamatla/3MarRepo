    <JadeMethod name="setNewPermDelUser" id="853be426-39e4-43e5-b6d2-7dffa780f340">
        <source>setNewPermDelUser( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

	securityRoleSys : CM_SecurityRoleSystem;
	pxySecurityRole : CM_SecurityRole;
	permissionAgent	: CM_PermissionAgent;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting New User Delete Permission.", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting New User Delete Permission") ;	
	endif;
	
	foreach securityRoleSys in CM_SecurityRoleSystem.instances do
	
		if securityRoleSys.permissions[PmCmpUserTableMaint] then

			create permissionAgent transient;
			permissionAgent.populatePermissionDict(true, true, 0);
			beginLoad;
				pxySecurityRole := securityRoleSys.pxyCreateUpdateProxy();
			endLoad;
			pxySecurityRole.permissions[PmCmpUserTableDelete] := true;
			
			app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport); 

			delete pxySecurityRole;
			delete permissionAgent;
			
		endif;	
	
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Setting New User Delete Permission complete", LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting New User Delete Permission complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete pxySecurityRole;
	delete permissionAgent;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setNewPmAdmInvoice" id="c4130a56-f901-4060-9cae-f66f5ded82c2">
        <source>setNewPmAdmInvoice(_controller: CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/03/2017 cnwma1  TFS #3661:ADP - Invoice Management Permissions
31/01/2020	jlgzm1	TFS 48378 Differences between Dmast and Wmast. lines relating to 
					PmAdmInvListStatusClose were commented out for TFS 39618, but only in Dmast
					so will have been uncommented in releases

*/

vars
	terminalRole : CM_SecurityRole;
	termRole	: CM_SecurityRoleTerminalRoot;
begin

if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Updating The new Invoices Permissions :
											 Invoice List Re-evaluate Invoices,
											 Invoice List Override Rates,
											 Export invoices,Export invoices to file,
											 Invoice Status to Close,
											 Invoice Lines Re-evaluate Invoice Lines,
											 Invoice Lines Override Rates", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating The new Invoices Permissions :
							 Invoice List Re-evaluate Invoices,
							 Invoice List Override Rates,
							 Export invoices,Export invoices to file,
							 Invoice Status to Close,
							 Invoice Lines Re-evaluate Invoice Lines,
							 Invoice Lines Override Rates") ;	
	endif;
	
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	
	foreach terminalRole in termRole.allChildRoles do	
		terminalRole.updateNewPermission(PmAdmInvListReEvaluate);
		terminalRole.updateNewPermission(PmAdmInvListOverrideRates);
		terminalRole.updateNewPermission(PmAdmInvListExportInv);
		terminalRole.updateNewPermission(PmAdmInvExportToFile);
		terminalRole.updateNewPermission(PmAdmInvListStatusClose);
		terminalRole.updateNewPermission(PmAdmInvLineReEvaluate);
		terminalRole.updateNewPermission(PmAdmInvLineOverrideRate);
	endforeach;
	
app.writeLog(method.qualifiedName &amp; " Updating The new Invoices Permissions :
										 Invoice List Re-evaluate Invoices,
										 Invoice List Override Rates,
										 Export invoices,Export invoices to file,
										 Invoice Status to Close,
										 Invoice Lines Re-evaluate Invoice Lines,
										 Invoice Lines Override Rates-- Complete" , LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating The new Invoices Permissions :
							 Invoice List Re-evaluate Invoices,
							 Invoice List Override Rates,
							 Export invoices,Export invoices to file,
							 Invoice Status to Close,
							 Invoice Lines Re-evaluate Invoice Lines,
							 Invoice Lines Override Rates-- Complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
