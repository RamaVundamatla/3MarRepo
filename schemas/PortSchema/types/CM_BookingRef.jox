    <JadeMethod name="getBookingRolled" id="9c0142f5-f6b5-4b8e-9451-d33e29a2faae">
        <source>getBookingRolled(_to : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2013	cnwmc5	Initial creation	PAR 32671

*/

vars
	evt			: CMEVT_SplitRollBooking;
	
	bookingRef	: String;
	
begin
	foreach evt in self.allSplitRollEventsAsOld reversed do
		if evt.isKindOf(CMEVT_RollBooking) then
			if _to then
				bookingRef := evt.CMEVT_RollBooking.myNewBookingReference.bookingReference;
			else
				bookingRef := evt.CMEVT_RollBooking.myOldBookingReference.bookingReference;
			endif;
			break;
		endif;
	endforeach;
	
	//If bookingRef is null, must be the new booking, so check the 'new' collection..
	if bookingRef = null then
		foreach evt in self.allSplitRollEventsAsNew reversed do
			if evt.isKindOf(CMEVT_RollBooking) then
				if _to then
					bookingRef := evt.CMEVT_RollBooking.myNewBookingReference.bookingReference;
				else
					bookingRef := evt.CMEVT_RollBooking.myOldBookingReference.bookingReference;
				endif;
				break;
			endif;
		endforeach;
	endif;
	
	//If the booking ref is myself, don't dispaly
	if bookingRef = self.bookingReference then
		return null;
	endif;
	return bookingRef;
epilog

end;</source>
        <Parameter name="_to" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
