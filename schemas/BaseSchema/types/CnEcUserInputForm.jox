    <ImplicitInverseRef name="btnCancel" id="72f1840b-95db-4de8-bd0f-0915e5e155fd">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="78484583-69de-46a3-a2a5-67b91c1832e0">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cnEcLine" id="d73d860f-e935-4d79-b51b-b4d4fce11ee3">
        <embedded/>
        <type name="CnEcLine3D"/>
    </ImplicitInverseRef>
    <PrimAttribute name="isEmptyInputAllowed" id="d2d08614-c7db-4363-a3ad-13331bf8f9fc">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="lblInstruction" id="86621dab-1b9e-45e5-a9cb-04c78af654cc">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtInput" id="c40da3a1-04d5-4c20-ad85-a226505d3e92">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="f54d6ff4-bfa7-4c0e-9331-9844676764d3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	self.CNEC_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="2afaef1f-e308-4cbc-9600-235a2a954f40">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
// --------------------------------------------------------------------------------
begin
	if self.isEmptyInputAllowed or txtInput.text.trimBlanks &lt;&gt; null then  		//17.10.2025 navbs1  #34979
		app.mousePointer	:=	Busy;
		modalResult			:=	self.CNEC_MODAL_UPDATE;
		unloadForm();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="18440fde-16bb-4d2b-849a-0338121dd3ae">
        <source>getValue():String;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Purpose:		Returns the value entered by the user.
//
// Parameters:	None
//
// Returns:		The value entered by the user.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return txtInput.text.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="aff0db5e-0b8d-42fc-8abc-0b34d9dcae19">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	centreWindow();
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProperties" id="cd6ed882-ad69-44c0-8b2d-8c4b52f56129">
        <updating/>
        <source>setProperties(pTitle:String; pInstruction:String; pDefaultValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Purpose:		Sets the dialog title, user instruction label caption, and a default
//				value.
//
// Parameters:	pTitle - The dialog title.
//				pInstruction - The user instructions, such as what to enter.
//				pDefaultValue - The default input value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption			:=	pTitle;
	lblInstruction.caption	:=	pInstruction;
	txtInput.text			:=	pDefaultValue;
end;</source>
        <Parameter name="pTitle" type="String"/>
        <Parameter name="pInstruction" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
</GUIClass>
