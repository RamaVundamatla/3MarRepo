    <JadeMethod name="loadForm" id="b47e2af9-a1bf-42f9-be0a-6275cc2337e4">
        <updating/>
        <source>loadForm()updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	wbDefn : WorkbookDefinition;
begin
	lblStep1.fontBold := true;
	lblStep1.left := 10;
	
	wbDefn := myDA.myWorkbookDefinition;
	inheritMethod();
	if myDA.myExcelDataDA.workbookName &lt;&gt; null then
		txtWorkbookName.text := myDA.myExcelDataDA.workbookName;
		txtWorkbookDesc.text := myDA.myExcelDataDA.workbookDescription;
		txtDataWSName.text := myDA.myExcelDataDA.workbookDataWorksheet;
		chkDataWSHide.value	:= myDA.myExcelDataDA.workbookHideDataSheet;
		txtTopWS.text := myDA.myExcelDataDA.workbookTopWorksheet;
	elseif wbDefn &lt;&gt; null then
		txtWorkbookName.text := wbDefn.workbookName;
		txtWorkbookDesc.text := wbDefn.workbookDescription;
		txtDataWSName.text := wbDefn.dataWorksheet;
		chkDataWSHide.value	:= wbDefn.hideDataWorksheet;
		txtTopWS.text := wbDefn.topWorksheet;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProcessingParameters" id="fb40fd6d-c90f-41e1-9f01-15279d1130da">
        <updating/>
        <source>setProcessingParameters() updating;

/*****************************************************
	Written by	:	cnwgrp1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	myDataDA.setValues(txtWorkbookName.text.trimBlanks,
						txtWorkbookDesc.text.trimBlanks,
						txtDataWSName.text.trimBlanks,
						chkDataWSHide.value,
						txtTopWS.text.trimBlanks); 
epilog

end;</source>
    </JadeMethod>
</GUIClass>
