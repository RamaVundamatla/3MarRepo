&lt;version&gt;9&lt;/version&gt;&lt;/hdr&gt;&lt;bdy&gt;&lt;bolXnt class="LOG"&gt;
&lt;supplierlookup&gt;PEN&lt;/supplierlookup&gt;&lt;bolnolookup&gt;123&lt;/bolnolookup&gt;
&lt;grossweight&gt;44.444&lt;/grossweight&gt;&lt;tareweight&gt;55.555&lt;/tareweight&gt;&lt;netweight&gt;66.666&lt;/netweight&gt;&lt;/bolXnt&gt;&lt;/bdy&gt;&lt;/msg&gt;';


	if app.userName().toUpper = "CNWER1" then
