    <JadeMethod name="saveAsXML" id="e07e7957-8333-4cfb-969c-6b5ba68cf9e8">
        <source>saveAsXML() protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpClient	: DEV_LicenseClient;
	tmpConst	: Constant;
	saveStr		: String;

begin

	foreach tmpClient in self.allClients do
		saveStr := saveStr &amp; tmpClient.outputAsXML();
	endforeach;

	tmpConst := self.myConstant;
	
	beginTransaction;
	tmpConst.setText(saveStr);
	commitTransaction;

	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCurrentClient" id="a9cf4b5d-df38-442b-b5a2-95fc9de9c235">
        <updating/>
        <source>setCurrentClient(_client : DEV_LicenseClient) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerm		: DEV_LicenseDtl;
	permObj		: CM_PermissionObject;
	tmpRow,
	permIdx,
	idx,
	numValues	: Integer;
	value		: Boolean;
	masterStr	: String;
	
begin

	self.myCurrentClient	:= _client;
	cmbClient.listObject	:= _client;
	
	if _client = null then
		self.txtName.text			:= null;
		self.txtNumTerminals.text	:= null;
		self.chkSite.value 			:= false;
		return;
	endif;

	self.setHasClientDetailsChanged(false);
	

	self.txtName.text			:= _client.name.trimBlanks;
	self.txtNumTerminals.text	:= _client.numTerminals.String;
	self.chkSite.value 			:= _client.hasSiteLicense;
	self.chkRealClient.value	:= _client.isRealClient;
	self.txtNotes.text			:= _client.notes;
	
	self.initComboLicenseType(_client);
	self.setCurrentLicenseDtl(_client.mySystemLicense, DEV_LicenseEntity.LicenseType_System);

end;</source>
        <access>protected</access>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="setCurrentLicenseDtl" id="8548a096-a005-4867-8afd-6ed7a665be75">
        <updating/>
        <source>setCurrentLicenseDtl(_licenseDtl : DEV_LicenseDtl; _licenseType : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//08 Oct 2019	NLD	TFS 46169
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	tmpText			: String;
begin

	if _licenseDtl &lt;&gt; null and _licenseDtl = self.myCurrentLicenseDtl then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' = current so no change');
		return;
	endif;

	if self.myCurrentLicenseDtl &lt;&gt; null and self.hasLicenseDtlsChanged then
		if app.msgBox('License details have changed.  Save Now?', 'Info', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
			if (not self.doSaveDtl()) then
				// there has been an error so reset back to current
				self.cmbLicenseType.listObject := self.myCurrentLicenseDtl;
				return;
			endif;
		endif;
	endif;

	self.setHasLicenseDtlsChanged(false);

	self.tblLicense.clear;
	self.tblLicense.sortColumn[1] := 1;
	if self.myCurrentClient = null then
		self.tblLicense.rows := self.tblLicense.fixedRows;
		self.myCurrentLicenseDtl := null;
		return;
	endif;
	
	self.myCurrentLicenseDtl := _licenseDtl;
	
	if _licenseDtl = null then // New Client
		self.currentLicenseType := _licenseType;
		self.txtExpiryDate.setDate(null);

		self.btnDeleteDtl.enabled := false;
		self.btnGenerate.enabled := false;
		self.btnSaveDtl.enabled := false;
		
		if self.currentLicenseType = DEV_LicenseEntity.LicenseType_EDI then
			self.cmbLicenseType.text := ProductStr_JMT_EDI;
			
		elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_System then
			self.cmbLicenseType.text := ProductStr_JMT;
		// ### JIRA 33543 12DEC2024 NAVAB1
		elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EWS then
			self.cmbLicenseType.text := ProductStr_EWS;
			
		elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_Subscription then	//17 Jun 2020	NDL	TFS 49569
			self.cmbLicenseType.text := ProductStr_SUBS;

		else
			self.cmbLicenseType.text := null;

		endif;
	else // Existing Client
		self.cmbLicenseType.listObject := _licenseDtl;
		self.currentLicenseType := _licenseDtl.type;
		self.txtExpiryDate.setDate(_licenseDtl.expiryDate);

		self.btnDeleteDtl.enabled := true;
		self.btnGenerate.enabled := true;
		self.btnSaveDtl.enabled := true;
		
	endif;
	
	self.btnSetAll.helpContextId := 0; // ### JIRA 33540 08JAN2025 NAVAB1
	
	if self.currentLicenseType = DEV_LicenseEntity.LicenseType_Subscription then	//17 Jun 2020	NDL	TFS 49569
		self.initTblLicenseForSub(_licenseDtl);
	elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EDI then
		self.initTblLicenseForEDI(_licenseDtl);
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EWS then
		self.initTblLicenseForEWS(_licenseDtl);
	else
		/* ### JIRA 33502 20DEC2024 NAVAB1
		if self.mode = self.Mode_New then
			self.initTblLicenseForSysOrTermSimp(_licenseDtl);
		else
		*/
			self.initTblLicenseForSysOrTerminal(_licenseDtl);
		//endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
        <Parameter name="_licenseType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHasClientDetailsChanged" id="d61977ab-29d4-4456-86da-9e1f3e518261">
