    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="de54b82c-fb25-48d7-b694-b346917e8cb3">
        <source>setupThumbnailDetails();
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	//use the "ETDef_MachineAvailTbl" - no point is creating a new one with the same attributs.
	theForm.setTblDataEntRows(ETDef_DeliveryRelReasonMaint);
//	theForm.zAddColumn('MachineAvailability code', 'code', Table.InputType_None, 30);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Id, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_DeliveryRelReasonMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7d851baa-8ede-4b67-b96c-391068711b64">
        <updating/>
        <source>showThumbnail(pDeliveryRelReason: CM_DeliveryReleaseReason) updating;

vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Id, pDeliveryRelReason.id);
	theForm.tblInput1.setValueByName(ETRow_Description,	pDeliveryRelReason.description);
end;</source>
        <Parameter name="pDeliveryRelReason" type="CM_DeliveryReleaseReason"/>
    </JadeMethod>
</Class>
