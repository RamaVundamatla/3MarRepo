    <JadeMethod name="autoShowWeighBridgeAtGate" id="ddce79ab-eabf-45c8-98cb-6531369a34cf">
        <source>autoShowWeighBridgeAtGate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	gte : CMGTE_Entity;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;

begin

	if self.hasWeighInVVRD &lt;&gt; null and self.hasWeighOutVVRD &lt;&gt; null then
		//already got both, no need to automatically present the form
		return false;
	endif;
	
	//can only be one cargo item in, OR one cargo item out.
	if self.allGateEntities.size &gt; 1 then
		return false;
	endif;
	
	gte := self.allGateEntities.first();
	if gte.isKindOf( CMGTE_Receival ) then
		cargoType := app.myRoot.allCargoTypesById[gte.CMGTE_Receival.cargoType];
		commodity := app.myRoot.allCommodities[gte.CMGTE_Receival.commodity];
		
	elseif gte.isKindOf( CMGTE_Release ) then
		cargoType := app.myRoot.allCargoTypesById[gte.CMGTE_Release.cargoType];
		commodity := app.myRoot.allCommodities[gte.CMGTE_Release.commodity];
		
	else
		return false;
		
	endif;
	
	if cargoType = null and commodity = null then
		return false;
	endif;
	
	if cargoType &lt;&gt; null and not cargoType.requiresWeighing then
		return false;
	endif;
	
	if commodity &lt;&gt; null and not commodity.requiresWeighing then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
