    <JadeMethod name="cmbMaster_click" id="44d9dcd6-745b-48b8-a510-2551e04b0205">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMaster_click(combobox: ComboBox input) updating;
//-----------------------------------------------------------------------
//	Created:	31 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	master	: HMS_Master;
	harbour : HMS_Harbour;
	pilotExempt : HMS_PilotExemptionCertificate;
begin
	master := combobox.listObject.HMS_Master;
	if master &lt;&gt; null then
		self.tbxShipsMaster.text := master.description &amp; ' ('&amp; master.code &amp; ')';
		if self.myCurrentMovement &lt;&gt; null then
			harbour := self.myCurrentMovement.getHarbour;	//30 Apr 2012	NDL	Par 29496
			if master.isValidForVessel (harbour, self.myCurrentMovement.getMyVessel, self.myCurrentMovement.occursOnDTNEW.Date) then
				pilotExempt := master.getPECforVessel( harbour, self.myCurrentMovement.getMyVessel, self.myCurrentMovement.occursOnDTNEW.Date );
				self.lblMasterStatus.caption := "Exempt Status valid" &amp; CrLf &amp; "Exp Date : " &amp;  pilotExempt.expiryDate.format ("dd/MM/yyy");
				/*self.ckbxPilotExempt.value 		:= true;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.ckbxPilotExempt.enabled 	:= false;
				self.cmbPilot.listIndex			:= -1;
				self.cmbPilot.enabled 			:= false;
				self.cmbPilotLaunch.enabled 	:= false;
				self.cbxLaunchPosn.enabled 		:= false;*/
			else
				self.lblMasterStatus.caption := "Exempt Status invalid" &amp; CrLf ;
				/*self.ckbxPilotExempt.value 		:= false;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.ckbxPilotExempt.enabled 	:= true;
				self.cmbPilot.enabled 			:= true;
				self.cmbPilotLaunch.enabled 	:= true;
				self.cbxLaunchPosn.enabled 		:= true;*/
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
