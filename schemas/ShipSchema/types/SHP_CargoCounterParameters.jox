    <JadeMethod name="translateForm" id="7bba3acf-00f9-41ec-9397-431d18e1e362">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 February 2022 15:22:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015253, locale);
	chkContainerCount.translateCaption(Xlat_0024586, locale);
	chkContainerTEU.translateCaption(Xlat_0024587, locale);
	chkQty.translateCaption(Xlat_0024588, locale);
	chkTeu.translateCaption(Xlat_0024589, locale);
	chkVolume.translateCaption(Xlat_0024590, locale);
	chkWeight.translateCaption(Xlat_0024591, locale);
	grpContainer.translateCaption(Xlat_0024592, locale);
	grpGeneralCargo.translateCaption(Xlat_0024593, locale);
	lblFor.translateCaption(Xlat_0015254, locale);
	lblMonths.translateCaption(Xlat_0015255, locale);
	lblStart.translateCaption(Xlat_0015256, locale);
end;</source>
    </JadeMethod>
