    <JadeMethod name="getID" id="1dacacdd-d75e-42f7-86c1-8acdc5f8f126">
        <source>getID(): String;

/*

Purpose:			

Parameters:			None

Return Value:		Returns id of location within terminal area


Date		Who		Reason
11 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	
	//epr par 26495 27/1/2011 
	if self.myGridArea.CM_AreaWithLanes.isBufferZone then
		return self.myGridArea.id;
	endif;


	if self.isDefaultLane() then
		return null;
	endif;

	return self.getLaneNumber.String;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverstowedByTIs" id="e474a121-3a32-44bd-878c-e454434e826b">
        <source>getOverstowedByTIs(moveMode: Integer; tiToGetOverstowedBy: CM_TrackedItem; overstowingTIs: CMIF_RTSortByPosDict input; _includeSelf: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwer1	Initial creation

*/

vars

begin

	if self.myTerminalArea.CM_AreaWithLanes.isBufferZone then
		return;
	else
		inheritMethod(moveMode, tiToGetOverstowedBy, overstowingTIs, _includeSelf);
	endif;
epilog

end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="tiToGetOverstowedBy" type="CM_TrackedItem"/>
        <Parameter name="overstowingTIs" type="CMIF_RTSortByPosDict" usage="input"/>
        <Parameter name="_includeSelf" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDefaultLane" id="eba65b38-fed0-49ec-a782-d77fa336d8f0">
        <source>isDefaultLane(): Boolean;
// ---------------------------------------------------------------------------
// Created:     19 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myGridArea.CM_AreaWithLanes.laneCount = 0;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
