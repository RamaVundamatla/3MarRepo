    <JadeMethod name="getCargoGroupAssignAddXML" id="0e9fdde8-45ae-47d0-a362-5e9214ad90b3">
        <source>getCargoGroupAssignAddXML( _cargoGroupAssignBaseId : String; _cargoGroupBaseId : String; _cargoBaseId : String; _operCode : String; _bsId : String; _remarks : String ):String protected;
/*

Purpose:			

