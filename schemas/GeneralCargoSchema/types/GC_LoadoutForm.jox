    <JadeMethod name="createDetailProxies" id="8bf025e1-37de-469c-a7dd-c63e1539b7d0">
        <updating/>
        <source>createDetailProxies() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifBOLOutLine		: CMIF_BOLOutLine;
	ti					: CM_TrackedItem;
	obj					: Object;
	realBOLOut,
	bolOut				: CM_BOLOut;
	tbl					: CM_DataTable;
	entDef				: EntTableDef;
begin
	bolOut := self.myCurrentMasterPxy.CM_BOLOut;
	if bolOut = null then
		return;
	endif;
	realBOLOut := bolOut.pxyGetRealObject();
	
	if realBOLOut = null then
		return;
	endif;
	
	self.allDetailObjects.clear();
	foreach ti in realBOLOut.allTrackedItems do
		create cmifBOLOutLine transient;
		cmifBOLOutLine.setFromTrackedItem(ti);
		self.allDetailObjects.add(cmifBOLOutLine);
	endforeach;
	
	tbl := self.tblDataDetail;
	tbl.rows := tbl.fixedRows;
	entDef := self.tblDetailEnt.myEntTableDef;
	
	foreach obj in self.allDetailObjects do
		self.addProxyObjectToDetailTable(tbl, obj);
	endforeach;
	
	self.doAssignLineNos();
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="8fc474ee-bc35-4fa8-8269-695b65abe385">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOut			: CM_BOLOut;
	any				: Any;
	tbl				: CM_DataTable;
	numSearched,
	numFound		: Integer;
	breakOut		: Boolean;
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.msgBox('You cannot receive selector results while editing and adding new loadout dockets','Operation not possible', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	tbl := self.tblDataMaster;
	tbl.rows := tbl.fixedRows;
	self.zShowHideSearcher(false);
		
	foreach any in _resultCollection do
		if CM_BOLOut.hasInstance(any.Object) then
			bolOut := any.CM_BOLOut;
			if bolOut.bolType &lt;&gt; BOLType_GeneralDocket then
				continue;
			endif;
			
			self.addObjectToMasterTable(tbl, bolOut, numSearched, numFound, breakOut);
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddDetailLine" id="d6c42316-7af6-4224-9ac3-845ff013e15c">
        <updating/>
        <source>doAddDetailLine() : Object updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutLine		: CMIF_BOLOutLine;
	ti				: CM_TrackedItem;
	tbl				: CM_DataTable;
	numRows,
	row				: Integer;
	existingTI		: CM_TrackedItem;

begin
	tbl := self.tblDataDetail;
	ti := self.cmbItem.listObject.CM_TrackedItem;
	if ti = null then
		app.msgBox('You must select an item to add to the docket first', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	//see if we've already added this TI to the table - note we're not using the edition key to check
	//just oid comparison
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		bolOutLine := tbl.accessRow(row).itemObject.CMIF_BOLOutLine;
		
		if bolOutLine.myTrackedItem = ti then
			app.msgBox('The selected item has already been added to this docket at line number ' &amp; (row - tbl.fixedRows).String, 
					app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
			return null;
		endif;	
	endforeach;
	
	create bolOutLine transient;
	bolOutLine.setFromTrackedItem(ti);
	self.allDetailObjects.add(bolOutLine);
	self.addProxyObjectToDetailTable(self.tblDataDetail, bolOutLine);
	//self.allDetailObjects.add(bolOutLine);
	self.doAssignLineNos();
	
	return bolOutLine;

epilog
	self.tblDetailEnt.setFocus();
	self.tblDetailEnt.goToRowByName(ETRow_Id);	
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="doAssignLineNos" id="8d84faf8-95c5-4f78-a2cc-2726310076b3">
        <source>doAssignLineNos() protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl						: CM_DataTable;
	lineNo,
	lineNoCol,
	productCol,
	numRows,
	row						: Integer;
	prevCode,
	code					: String;
begin
	tbl := self.tblDataDetail;
	
	numRows := tbl.rows;
	productCol := tbl.getColumnByHeading(app.getErrorString(Product));
	lineNoCol := tbl.getColumnByHeading('Line No');
	
	if productCol = 0
	or lineNoCol = 0 then
		return;
	endif;

	foreach row in tbl.fixedRows + 1 to numRows do
		code := tbl.getCellText(row, productCol);
		if code &lt;&gt; prevCode then
			lineNo := 1;
		else
			lineNo := lineNo + 1;
		endif;
		
		tbl.setCellText(row, lineNoCol, lineNo.String);
		prevCode := code;
		
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoAssignItems" id="469771cc-72f7-449d-9685-7d0f3a80b7e5">
        <updating/>
        <source>doAutoAssignItems() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 May 2004	cnwth2
//
// Purpose:     Potential here to auto assign by specified location + conditions various. 
//				Currently, just grabs them from anywhere from the first matching sohLocation.
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	row,
	numRows			: Integer;
	tbl				: CM_DataTable;
	obj				: Object;
	bolOutLine		: CMIF_BOLOutLine;
	sohLocation		: CM_SOHLocation;
	ti				: CM_TrackedItem;
	entDef			: EntTableDef;
	cmb				: CMUI_ComboBox;
	tiSet			: CM_TISet;
begin
	tbl := self.tblDataDetail;
	entDef := tbl.myEntTableDef;
	numRows := tbl.rows;
	
	if numRows &lt;= tbl.fixedRows then
		app.msgBox('There are no loadout lines present', 'No lines to assign...', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	/*
	if app.msgBox("This operation will automatically assign on-site items to each loadout line where no item has yet been specified." &amp; CrLf &amp;
					"Do you wish to continue?", 'Proceed with automatic assignment?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
		return;			
	endif;
	*/
	
	create tiSet transient;
	
	foreach row in tbl.fixedRows to numRows do : rowLoop
		bolOutLine := tbl.accessRow(row).itemObject.CMIF_BOLOutLine;
		if bolOutLine = null then
			continue;
		endif;
		
		if bolOutLine.myTrackedItem &lt;&gt; null or
		   bolOutLine.myProduct = null then
			continue;
		endif;
		
		foreach sohLocation in bolOutLine.myProduct.allSOHLocations do : sohLoop
			foreach ti in sohLocation.allTrackedItems do : tiLoop
				if ti.myParent &lt;&gt; null then
					continue tiLoop;
				endif;
				//check the ti is not already added
//				foreach obj in self.allDetailObjects do
//					if obj.CMIF_BOLOutLine.myTrackedItem = ti then
				if tiSet.includes(ti) then 
					continue tiLoop;
				endif;
//				endforeach;
				tiSet.add(ti);
//				bolOutLine.setFromTrackedItem(ti);
//				tbl.setCellText(row, 1, self.getDataRowForDef(bolOutLine, entDef));
//				tbl.setCellText(row, self.colItem, ti.id);
				tbl.row := row;
				cmb := tbl.accessCell(row, self.colItem).cellControl.CMUI_ComboBox; 
				cmb.listIndex := cmb.findObject(ti);
				cmb.click(cmb);
				continue rowLoop;
			endforeach;
		endforeach;
	endforeach;
	
	self.doAssignLineNos();
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteClick" id="051ff2e9-dc6d-4d16-85a3-0eda4789cc97">
        <updating/>
        <source>doBtnDeleteClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOut			: CM_BOLOut;
begin
	bolOut := self.myCurrentMasterObject.CM_BOLOut;
	if bolOut = null then
		app.msgBox('Please select a docket to delete first', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
	
	if bolOut.myMasterTI &lt;&gt; null and bolOut.myMasterTI.site = TI_SITE_ONSITE then
		self.chkUnpackTxns.enabled 		:= true;
		self.chkUnpackTxns.value		:= true;
		self.chkUnpackCharges.enabled 	:= true;
		self.chkUnpackCharges.value		:= true;
	else
		self.chkUnpackTxns.enabled 		:= false;
		self.chkUnpackTxns.value		:= false;
		self.chkUnpackCharges.enabled 	:= false;
		self.chkUnpackCharges.value		:= false;
	endif;
	
	self.showHideDeleteDocketFrm(true);
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeEntryView" id="73ab40a2-0e6f-4b0c-86b3-aedf57d00335">
        <source>doChangeEntryView() protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb				: CMUI_ComboBox;
	idx,
	processOpt,
	transMode			: Integer;
	
begin
	idx := self.cmbTransportMode.listIndex; 
	if idx &gt; 0 then
		transMode := self.cmbTransportMode.itemData[idx];
	endif;
	
	idx := self.cmbProcessOpt.listIndex;
	if idx &gt; 0 then
		processOpt := self.cmbProcessOpt.itemData[idx];
	endif;

	self.setViewForBOLOut(processOpt, transMode);
	
	if processOpt = Process_Direct_Loadout then
		self.setState(STATE_ENABLED);
	elseif processOpt = Process_Pack then
		self.setState(STATE_DISABLED);
	endif;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbBRBuild" id="6c96c536-b361-4c0b-be95-6ade56f96380">
        <source>doCmbBRBuild(_tmpBR : CM_BulkRelease);
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo : CMUI_ComboBox;
	aBR,tmpBR : CM_BulkRelease;
	iter01 : Iterator;
begin
	combo := self.cmbBR;
	
	combo.clear;
	combo.sorted := true;
	
	iter01 := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator();

	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_PACKING,BR_ACTIVE,null,null,iter01);
	
	while iter01.next(aBR) do
		if aBR.type &lt;&gt; BR_TYPE_PACKING or aBR.status &lt;&gt; BR_ACTIVE then
			break;
		else
			tmpBR := self.myTerminal.getBulkReleaseFromCode(aBR.code);
			if tmpBR &lt;&gt; null then
				if tmpBR = aBR then
					combo.addItemObject(aBR.code,aBR);
				else
					combo.addItemObject(aBR.code &amp; Tab &amp; aBR.dateRequested.date.String,aBR);
				
				endif;
			else
				combo.addItemObject(aBR.code,aBR);
			endif;
		endif;
	endwhile;
	
	combo.sorted := false;
	combo.addItemAt("",1);

	if _tmpBR &lt;&gt; null then
		combo.listObject := _tmpBR;
	else
		combo.listIndex := -1;
	endif;		
	combo.lostFocus(combo);
epilog
	delete iter01;	
	
end;</source>
        <Parameter name="_tmpBR" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeChange" id="f7fe986c-9ac6-410f-b543-2daad3070ddd">
        <updating/>
        <source>doCmbCargoTypeChange(combobox : CMUI_ComboBox) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCargoType	: CM_CargoType;
	tmpCmbId, 
	tmpCmbProd,
	cmbCargoType	: CMUI_ComboBox;
	theRow : Integer;
	tmpCell : JadeTableCell;

begin

	cmbCargoType	:= combobox;
	tbl 			:= self.tblDataDetail;
	tmpCargoType 	:= combobox.listObject.CM_CargoType;
	
	theRow  := tbl.row;
	
//	update Proxy in table
	self.myCurrentDetailObject.CMIF_BOLOutLine.myCargoType := tmpCargoType;	
	
	tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Product));
	tmpCmbProd := tmpCell.cellControl.CMUI_ComboBox;
	self.myAssistant.comboBoxProduct(tmpCmbProd,tmpCargoType,null,tmpCmbProd.listObject.CM_Product);
	
	if 	tmpCmbProd.listObject = null then 
		self.doCmbProductLostFocus(tmpCmbProd);
	else
	 	tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));
		tmpCmbId := tmpCell.cellControl.CMUI_ComboBox;
		self.doCmbItemLostFocus(tmpCmbId);
	endif;

	
	
	
/*
//old code
//	if cmbCargoType.text = tbl.getValueByName(ETRow_CargoType).String then 
	//have already selected the item previously so no need to redo and clear other combos. 
//		return;
//	endif;

	
//	tbl.setValueByControlName(cmbCargoType.name, cmbCargoType.text);
	self.myAssistant.comboBoxProduct(self.cmbProduct, tmpCargoType, null, self.cmbProduct.listObject.CM_Product);
	
	tbl.setValueByName(ETRow_Product, null);
	tbl.setValueByName(ETRow_Id, null);
	tbl.setValueByName(ETRow_Location, null);
		
	//list all the TIs of the selected cargo type - then if a product is selected TIs will be refilled
		//when a TI is selected, the product combo will prefill.	
	if tmpCargoType &lt;&gt; null then
		self.myAssistant.comboBoxTrackedItemID(self.cmbItem, tmpCargoType.id, TI_STATE_NORMAL, self.cmbItem.text); 	
	else
		self.cmbItem.clear();
	endif;
*/
	


end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doCmbCarrierClick" id="2c49c9e0-8b92-44ce-af3e-3640ab8b83d5">
        <updating/>
        <source>doCmbCarrierClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	carrier			: CM_Carrier;
	str				: String;
	vehicle			: CM_Vehicle;
	cmb				: CMUI_ComboBox;
begin



	cmb := self.cmbVehicle;
	cmb.clear();
	
	carrier := self.cmbCarrier.myObject.CM_Carrier;
	if carrier = null then
		return;
	endif;
	
	// DVB changed 06/09/04
	foreach vehicle in carrier.vehicles where not vehicle.isNotAvailableForEntry do
		cmb.itemObject[cmb.addItem(vehicle.regNumber)] := vehicle;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbItemLostFocus" id="9b444755-72ce-454c-86af-e514f12df084">
        <source>doCmbItemLostFocus(combobox : CMUI_ComboBox) protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Correct weight handling
vars
	cmbPro		: CMUI_ComboProduct;
	cmb			: CMUI_ComboBox;
	tmpTI		: CM_TrackedItem;
	tbl			: CM_DataTable;
	theRow 		: Integer;
	tmpCell : JadeTableCell;
begin
	cmb 			:= combobox;
	tbl 			:= self.tblDataDetail;
	tmpTI 			:= cmb.listObject.CM_TrackedItem;
		
	theRow  := tbl.row;

	tbl.accessRow(theRow).itemObject.CMIF_BOLOutLine.setFromTrackedItem(tmpTI);
//	self.myCurrentDetailObject.CMIF_BOLOutLine.myTrackedItem := tmpTI;
	
	if (tmpTI &lt;&gt; null) then
		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Product));
		cmbPro := tmpCell.cellControl.CMUI_ComboProduct;
		// set product if it hasnt been set. 
			if cmbPro.listObject &lt;&gt; tmpTI.myProduct then 
				cmbPro.clear(); 
				cmbPro.setCargoType(tmpTI.myCargoType);
				cmbPro.setObject(tmpTI.myProduct);
			endif;
	// set rest of table data;		
		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Location));
		tmpCell.text := tmpTI.locationId  ;

		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Volume));
		tmpCell.text := tmpTI.getMyTotalVolume.String;
	
		//tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Weight));			//-cnwml2 MSL CCMS 1017
		//tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_TotalWeight));		//+cnwml2 MSL CCMS 1017	// PAR #36909
		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_WeightTotal));		//+cnwml2 MSL CCMS 1017	// PAR #36909
		//tmpCell.text := tmpTI.weight.asStringWeightJMT();									//-cnwml2 MSL CCMS 1017
		tmpCell.text := tmpTI.totalWeight.asStringWeightJMT();								//+cnwml2 MSL CCMS 1017
		
		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_LineNo));
		tmpCell.text := (theRow -1).String;
		self.maintainIDCombos(cmb);
	
	endif;			

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doCmbPackIntoLostFocus" id="f2cd7aba-3199-4f52-a568-84d7aafdc4ac">
        <updating/>
        <source>doCmbPackIntoLostFocus(_combo : ComboBox) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	containerID : String;
begin


	//self.doDisplayContainer; //Moved from click Event
	containerID := self.cmbPackInto.text.toUpper;
	
	if containerID = null then		
//		self.tblMasterEnt.clearValues();
		// can cause error when saving if table not cleared
		return;
	endif;
	if _combo.listObject &lt;&gt; null and _combo.listObject.isKindOf(CM_Container) then
		self.doModalMessageDisplay(_combo.listObject.CM_Container);
	endif;

	self.tblMasterEnt.setValueByControlName(_combo.name, _combo.text);

end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doCmbProductLostFocus" id="b61025b9-64c5-4525-9b29-f2effd8263f5">
        <updating/>
        <source>doCmbProductLostFocus(combo :CMUI_ComboBox) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	tbl				: CM_DataTable;
	tmpCargoType	: CM_CargoType;
	tmpCmbProd : CMUI_ComboBox;
