    <JadeMethod name="setInitialControlValues" id="870d9672-e612-46f0-a8e1-93f743c7813e">
        <updating/>
        <source>setInitialControlValues() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines

*/

vars

	headings : String;
	term 	 : CM_Terminal;
	terms 	 : CM_TerminalByCodeDict;

begin

	self.setNavigatorHeading( self.caption );

	self.frmMain.borderStyle := 0;
	self.frmMain.top := 0;
	self.frmMain.left := 0;
	
	self.frmTables.borderStyle := 0;
	
	self.minimumHeight := 400;
	self.minimumWidth := 700;
		
	create terms transient;
	app.getMyUser.getTerminals(terms);
	foreach term in terms do
		if not term.isCashOnlyEnabled then
			continue;
		endif;
	endforeach;
		
	self.tblCash.rows := 1;
	self.tblCash.fixedRows := 1;
	self.tblCash.columns := 6;
	self.tblCash.fixedColumns := 0; 
	self.tblCash.alignment := Table.Alignment_Left_Top;
	self.tblCash.scrollBars := self.ScrollBar_Vertical;
	
	self.tblCash.accessColumn(4).alignment := Table.Alignment_Left_Bottom;
	self.tblCash.accessColumn(5).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessCell(1,4).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessCell(1,5).alignment := Table.Alignment_Left_Top;
	headings := app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Debtor_GC) &amp; Tab &amp; app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(CM_Type) &amp; Tab &amp; app.getErrorString(Amount) &amp; Tab &amp; app.getErrorString(Tax);
	self.tblCash.setCellText(1,1,headings);
	self.tblCash.accessRow(1).fontBold := true;
	
	self.tblCash.accessColumn(6).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessCell(1, 6).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessColumn(6).width := self.tblCash.accessColumn(5).width;
	self.tblCash.accessColumn(6).visible := self.showServiceTax;
		
	self.tblCash.selectMode := Table.SelectMode_WholeRows; // TFS 7611
	
epilog

	delete terms;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9cc4d516-a886-44a8-8fe1-12ba00d71623">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2018	jlgns1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.showServiceTax := (self.myTerminal.getConfig(CashAllCashTax).String = null) and self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
		
	self.setInitialControlValues();

end;</source>
    </JadeMethod>
    <JadeMethod name="showExtraPayments" id="85ccf042-ac23-4794-9cf8-9092e39926e0">
        <updating/>
        <source>showExtraPayments(_extraLines : ObjectArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2018	jlgns1	Initial creation
28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines
27/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars
	object		: Object;
	payment		: CM_CashPayment;
	invoiceLine : CM_InvoiceLine;
	tax 		: Decimal[23,6]; //[16,4]; // TFS 47529
	col 		: Integer;
	colWidth 	: Integer;
	rowHeight 	: Integer;
	tableCol 	: JadeTableColumn;
	vScrollWidth : Integer;
	ind 		: Integer;
	debtorTerm : CM_DebtorTerminal;
begin
	
	self.show;
		
	//Add lines to the table
	foreach ind  in _extraLines.size to 1 step -1 do
		object := _extraLines[ind];
		if object.isKindOf(CM_CashPayment) then
			payment := object.CM_CashPayment;
			tax :=  payment.taxAmount;	
			debtorTerm :=  payment.myDebtorTerminal;
			
			self.addLineToTable(payment,debtorTerm,tax);
			
		elseif object.isKindOf(CM_InvoiceLine) then
			invoiceLine := object.CM_InvoiceLine;
			debtorTerm := invoiceLine.getDebtor.allDebtorTerminals[self.myTerminal];
			if debtorTerm &lt;&gt; null then
				tax := invoiceLine.getTaxAmountForLine;
				
				self.addLineToTable(invoiceLine,debtorTerm,tax);
			endif;
		endif;
		
		
		
	endforeach;
	
	//Adjust form to eliminate horizonatal scrolling
	//get the width of all visible columns
	foreach col in 1 to tblCash.columns do
		tableCol := tblCash.accessColumn(col);
		if tableCol.visible then
			colWidth := colWidth + tableCol.width;
		endif;		
	endforeach;
	
	//Check for a verticle scrollbar
	rowHeight := tblCash.rows * tblCash.rowHeight[1];
	if rowHeight &gt;= tblCash.height then
		vScrollWidth := 16;
	else
		vScrollWidth := 0;
	endif;
		
	//Adjust form if columns don't all fit	
	if colWidth + vScrollWidth &lt;&gt; tblCash.width then
		self.width := self.width + colWidth + vScrollWidth - tblCash.width;
		self.centreOverParent(0);		
	endif;

	self.resize;
	
epilog

end;</source>
        <Parameter name="_extraLines" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="db300418-2b2d-4db1-a030-f602c3d464dd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 May 2018 09:01:41.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022492, locale);
	btnClose.translateCaption(Xlat_0022493, locale);
end;</source>
    </JadeMethod>
</GUIClass>
