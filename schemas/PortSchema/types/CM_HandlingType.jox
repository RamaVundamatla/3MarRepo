    <JadeMethod name="setProxyForHandlingType" id="9d26bd5e-4f5b-4e52-ac5a-160a2968e947">
        <updating/>
        <source>setProxyForHandlingType(_id : Integer;
					_descr : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.id				 			:= _id;
	self.description	 			:= _descr;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
