    <JadeMethod name="tblInput1_change" id="aa98fc66-a33b-4133-9b3a-fdedcd05f8f3">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput1_change(_tbl: CM_EntryTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwma1	 TFS #3054:PAR38451 C3 - Code Groups - Special Characters
// 16 Jan 2017	cnwrs1	TFS 3221 - have a invaliDcharacter list that allows full stop
*/
vars
	textbox : TextBox;
	cursorPos : Integer;
begin
	if self.mode = self.Mode_Add then
		if _tbl.row = _tbl.getRowByName(ETRow_Code) and _tbl.column = _tbl.ColumnValue then
			textbox := _tbl.accessCell(_tbl.row, _tbl.column).cellControl.TextBox;
			if textbox &lt;&gt; null and textbox.text &lt;&gt; null then
				cursorPos := textbox.selStart;
				if textbox.text.hasInvalidChars2 then
					textbox.text := textbox.text.removeInvalidChars2;
					textbox.selStart := cursorPos-1;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="878b17d7-90f8-4f9a-9721-0395eccbf2fd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:40:23.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007313, locale);
	chkInclNotAvail.translateCaption(Xlat_0023237, locale);
	lblView.translateCaption(Xlat_0000257, locale);
	shtMultiSelect1.translateCaption(Xlat_0000260, locale);
	shtMultiSelect2.translateCaption(Xlat_0000258, locale);
	shtMultiSelect3.translateCaption(Xlat_0000259, locale);
	shtTblInput1.translateCaption(Xlat_0000256, locale);
end;</source>
    </JadeMethod>
