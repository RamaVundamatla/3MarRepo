    <JadeMethod name="getExtraInfo" id="59fb09c3-194a-4c65-9136-99fbe45bd2b0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2012	cnwer1	Initial creation CCMS MES 1035
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti	: CM_TrackedItem;
	str : String;
	block : CM_DataContainerBlock;
	allTis	: CM_TISet;
begin
	inheritMethod(_dataContainer);
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		str := ti.id &amp; ' ' &amp; str;
	endforeach;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Attachments), DC_Label, 1, self);
	block.addNewItem(str, DC_Data, 1, self);
	// May 2011 cnwjre1 27097 CCMS 2043
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CanBeHiLowCube), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.myReserveHeader.canBeHiLoCube), DC_Data, 1, null);
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoRel" id="d748a830-f0bc-4234-8faa-1f566e204572">
        <source>getExtraInfoRel(_dataContainer: CM_DataContainer);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 23 December 2019
TFS#		: 48113
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars	
	block 			: CM_DataContainerBlock;
	caption			: String;
	reserveDetail	: CM_ReserveDetail;
	bulkRelease		: CM_BulkRelease;
begin
	reserveDetail := self;
	bulkRelease	  := reserveDetail.myReserveHeader;
			
	caption := self.setExtraInfoCaption(bulkRelease, reserveDetail);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Release_request), DC_Label, 1, self);
	block.addNewItem(caption, DC_Data, 1, self);
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
