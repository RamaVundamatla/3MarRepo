    <JadeMethod name="showCargoAddFromOnship" id="e9f6cecd-260b-4dea-9b7c-34ffd2646591">
        <source>showCargoAddFromOnship(_parentForm : CM_BaseForm; _isNewItem : Boolean; _columns, _controlWidth : Integer;_bolDetail : CM_BOLDtl; 
	_stowage : CM_Object; _trackedItem : CM_TrackedItem; _prenote : CMIF_PreNote; _voyage : CM_Voyage; _showModal : Boolean; _defaultLocation : CM_LocationsController);
/*
Purpose:			

Parameters:			
_stowage is a place-holder for CM_Stowage (or whatever) in 7.8.2	

Return Value:		

Date		Who		Reason
19/01/2010	cnwjre1	Initial creation
19/12/2024	jlizm1	MTN 33241 Cannot edit attachments when creating cargo from voyage ops live
*/
vars
	form 	: CMUI_ReceiveCargoForm;

begin

	//02 Sep 2019	NDL	TFS 46317
	if not  app.myCurrentUserCan(self.myTerminal, PmShipPrenoteMaint ) then
		app.msgBox(app.getErrorString1( VB_SECSHOW, app.getErrorString(CreateCargo) ), "Security Warning", MsgBox_Stop_Icon);
		return;
	endif;

	if _showModal then
	form := app.loadForm(	CMUI_ReceiveCargoFormModal,
							self.class,
							false,
							false,
							_showModal,
							self.myTerminal, null).CMUI_ReceiveCargoFormModal;
	else
		form := app.loadForm(	CMUI_ReceiveCargoForm,
								self.class,
								false,
								false,
								_showModal,
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	endif;
	
	form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
	form.initFromOnshipForm(_parentForm, _bolDetail, _stowage, _trackedItem, _prenote, _voyage, _defaultLocation);
	form.setIsNewItem(_isNewItem);
	
	if _showModal then
		form.showModal;
	else
		form.show;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_isNewItem" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_stowage" type="CM_Object"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_prenote" type="CMIF_PreNote"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_showModal" type="Boolean"/>
        <Parameter name="_defaultLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="showCargoAddFromOnsite" id="10ce141c-3cc4-43c2-b57c-2a1f92be7e86">
        <source>showCargoAddFromOnsite(_parentForm : CM_BaseForm; _isNewItem : Boolean; _columns, _controlWidth : Integer;_bolDetail : CM_BOLDtl; 
	_stowage : CM_Object; _trackedItem : CM_TrackedItem; _prenote : CMIF_PreNote; _voyage : CM_Voyage; _showModal : Boolean; _defaultLocation : CM_LocationsController);
/*
Purpose:			
Date			Who			Reason
FEB 2017		CNWAB1		Initial creation
19/12/2024		jlizm1		MTN 33241 Cannot edit attachments when creating cargo from voyage ops live
*/

vars
	form 	: CMUI_ReceiveCargoForm;

begin
	if _showModal then
	form := app.loadForm(	CMUI_ReceiveCargoFormModal,
							self.class,
							false,
							false,
							_showModal,
							self.myTerminal, null).CMUI_ReceiveCargoFormModal;
	else
		form := app.loadForm(	CMUI_ReceiveCargoForm,
								self.class,
								false,
								false,
								_showModal,
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	endif;
	
	form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
	form.initFromOnsiteForm(_parentForm, _bolDetail, _stowage, _trackedItem, _prenote, _voyage, _defaultLocation);
	form.setIsNewItem(_isNewItem);
	
	if _showModal then
		form.showModal;
	else
		form.show;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_isNewItem" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_stowage" type="CM_Object"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_prenote" type="CMIF_PreNote"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_showModal" type="Boolean"/>
        <Parameter name="_defaultLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="showCargoAllocSubMap" id="b46497be-5ce3-4038-8cde-9f4eeca7faba">
        <source>showCargoAllocSubMap(_parentMap : CM_QuantityMap; _qrm : CM_QuantityRangeMap; _subqrm : CM_QuantityRangeMap; _isFromCargoAlloc : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/01/2025	navkc1 JIRA Sub-task MTN-19517: MTN | Jade Sub quantity Range Invoice Cargo Allocations

*/

vars
	tmpForm : CMUI_InvoiceFutureSubMaps;
begin
	tmpForm := app.loadForm(CMUI_InvoiceFutureSubMaps, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_InvoiceFutureSubMaps;
	
	if tmpForm = null then
		return;
	endif;
	
	tmpForm.mySubQuantityRange := _subqrm;
	tmpForm.myCurrentQuantityRangeMap := _qrm;
	tmpForm.myParentQuantityMap := _parentMap;
	
	tmpForm.updateMode := _subqrm &lt;&gt; null;
	tmpForm.isFromCargoAllocation := _isFromCargoAlloc;
	
	tmpForm.showModal();
	
epilog

end;</source>
        <Parameter name="_parentMap" type="CM_QuantityMap"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_subqrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_isFromCargoAlloc" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoChecksForm" id="b2c6fe98-2b1a-4000-9bc6-1780b3db75cd">
        <source>showCargoChecksForm(_ti : CM_TrackedItem; _gte : CMGTE_Receival; _vvr : CM_VehicleVisitRecord; _context : Integer; _parentForm : CM_BaseForm);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	form : CMUI_CargoChecksForm;
	
begin

	create form transient;
	
	if form = null then
		return;
	endif;
	
	form.setMyTerminal(self.myTerminal);
	form.setBaseDetails(_ti, _gte, _context);
	form.setMyVehicleVisit(_vvr);
	form.setParentForm(_parentForm);
	
	form.showModal;

epilog
	delete form;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gte" type="CMGTE_Receival"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
