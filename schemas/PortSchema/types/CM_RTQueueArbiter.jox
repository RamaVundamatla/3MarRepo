    <JadeMethod name="addTIToQueue" id="086f9594-7e11-4086-842c-6bc28fe7c604">
        <updating/>
        <source>addTIToQueue() updating;
vars
	now	:	TimeStamp;
begin
	//Set the TI reference
	exclusiveLock(ti);
	ti.addToQueue(self.queue);
end;</source>
    </JadeMethod>
    <JadeMethod name="buildDoorQueueTasks" id="be1e8be8-203d-48dd-9499-9aa09b382006">
        <source>buildDoorQueueTasks() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	taskPickup,
	taskSetdown : CM_RTQueueTask;
begin
	create taskPickup;
	taskPickup.setDetails(	self.sourceLocation,
							self.targetLocation,
							TASK_UNACTIONED,
							TASK_PICKUP,
							self.ti);
	self.entry.addTask(taskPickup);
	
	
	create taskSetdown;
	taskSetdown.setDetails(	self.targetLocation,
							self.sourceLocation,
							TASK_UNACTIONED,
							TASK_SETDOWN,
							self.ti);
							
	self.entry.addTask(taskSetdown);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildQueueEntryMaster" id="83c11003-9421-4a5a-901b-1ce20b344d36">
        <updating/>
        <source>buildQueueEntryMaster() updating;

// Created by cnwdvb1 on 14 August 2006
/*
Date		Who		Reason
16 Feb 2010	consw1	PAR #22383 - Allow for multiple machine moves when actioning a Director Task
16 Feb 2010 cnwer1	CCMS 1100 - changed determining the queue to after the entry and tasks have been created
							  - this then allows the queue to be determined on the indivual entrys source and
							    target if needed.
06 Aug 2010 cnwer1	PAR 25300 - If the move method used more than one machine for director tasks this would create &gt; 1 director q entry
								this caused exceptions when it came to create the pickup &amp; setdown tasks
12 Aug 2010 cnwer1  PAR 25388 - the director tasks has been accepted when ti is assigned make sure we do not change the entries queue
19/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so it will also appear on the logging form
31/01/2023	navhl20	Bug 55413: PNL - Radio Telemetry Queues not working for multi move delivery requests
25 Apr 2023 navma1	Bug 57739: PNL - Radio Telemetry Queues not working for multi move delivery requests (new issues)
14 Jul 2025	navhl20 Bug MTN-34906: POL - Machine Rules Target Destination
28 Aug 2025 jlier1 	JIRA-35826  Target Location is incorrect for Straddle Stack on the RTQ form
*/


vars
	aQueue 					: CM_RadioTelemetryQueue;
	isQueueInternallySet	: Boolean;
	forDirectorTasks		: Boolean;
	rtQueueTask				: CM_RTQueueTask;
	taskTargetLc			: CM_LocationsController;
begin
	//epr par 25300 6/8/2010 
	if self.myPreviousRTQueueEntry &lt;&gt; null and 
		self.myPreviousRTQueueEntry.allTasks.size = 1 and
		self.myPreviousRTQueueEntry.allTasks.first.taskType = TASK_DIRECTOR then
		
		//cnwrd1 par 25681 18.11.2010 multi machine director moves - was just return;
		self.createQueueEntry();		

		//if self.queue = null then	//31.1.2023 navhl20 TFS 55413		//25.04.2023 navma1 #57739
			aQueue := self.getQueue() ;  
			self.queue := aQueue;	
		//endif;					//31.1.2023 navhl20 TFS 55413       //25.04.2023 navma1 #57739
	
		isQueueInternallySet := true;
		
		//-----------------
		//Add us to the Queue
		//-----------------
		self.queue.addQueueEntry(self.entry);
		self.validateQueueEntry();
		return;
	endif;
	//-------------
	//Do the stuff to queue to a location
	//-------------
	forDirectorTasks:=false;
	if self.isForDirectorTask then //refactored into own method
		// Add pickup/setdown tasks for ti to existing queue entry for Director Task
		self.createEntryTasks();
		self.allRTQueueEntries.add(self.entry);
		self.myPreviousRTQueueEntry	:= self.entry;
		forDirectorTasks:=true;
	else
		//epr par 35702 4/3/15 CCMS 2457
		if self.myBulkReleaseMaster &lt;&gt; null then
			self.createQueueEntry();
		else
			//cnwrd1 par 25681 18.11.2010 multi machine director moves
			if self.myPreviousRTQueueEntry &lt;&gt; null and  (self.myPreviousRTQueueEntry.isMultiMachineDirector) then
			// Add pickup/setdown tasks for ti to existing queue entry for Director Task	
				if self.entry.getNextRelatedEntry() &lt;&gt; null then 
					self.entry := self.myPreviousRTQueueEntry.getNextRelatedEntry;
					rtQueueTask := self.entry.allTasks.first;							//14.07.2025 navhl20 #34906
					if rtQueueTask &lt;&gt; null then											//14.07.2025 navhl20 #34906
						taskTargetLc := rtQueueTask.targetLocation;
					endif;
					if self.targetLocation &lt;&gt; taskTargetLc and taskTargetLc &lt;&gt; null then	//28/7/25 jlier1 	JIRA-35826						
						self.targetLocation := taskTargetLc;
					endif;
					self.createEntryTasks();
					self.allRTQueueEntries.add(self.entry);
					self.myPreviousRTQueueEntry	:= self.entry;
					forDirectorTasks:=true;
				endif;
			else	
				self.createQueueEntry();
			endif;
		endif;
	endif;
	
	//epr par 35702 27/2/15
	if self.myBulkReleaseMaster &lt;&gt; null then
		self.queue:=self.myBulkReleaseMaster.myQueue;
	endif;
	
	// Queue can be manually set.
	if self.queue = null then
		self.writeLoggingText("buildQueueEntryMaster: Need to get the queue as not set manually");

		/*epr 25388 12/08/10 - if is a director task the entry has been created and is already in a queue. 
			Make sure it stays in the queue.
		*/
		if forDirectorTasks and self.entry.myQueue &lt;&gt; null then
			self.queue :=self.entry.myQueue;
		else
			aQueue := self.getQueue() ;
			self.queue := aQueue;
		endif;
		isQueueInternallySet := true;
	else
		self.writeLoggingText("buildQueueEntryMaster: Using queue: " &amp; self.queue.id);
		if self.queue.isKindOf(CM_SubQueue) then						// 29/06/2011 cnwmh5 #27179
			self.writeLoggingText(Tab &amp; 'From: ' &amp; self.queue.CM_SubQueue.allMoveFromTAMasters.getAreaAsString);
			self.writeLoggingText(Tab &amp; "To: " &amp; self.queue.CM_SubQueue.allMoveToTAMasters.getAreaAsString);
		endif;
	endif;
		
	// DVB changed 15/08/06
	// Director tasks are coming through here now as well.
	if self.ti &lt;&gt; null then
		self.addTIToQueue();
	endif;
	
	//-----------------
	//Add us to the Queue
	//-----------------
	self.queue.addQueueEntry(self.entry);
	
	if self.entry.isBreakBulkGenericMaster then // cnwrd1 2274
		self.entry.setQuantity(self.wle.quantity);
		
		//epr CCMS 1366 12/3/14
		if wle.myRequest &lt;&gt; null and wle.myRequest.isBulkMulti then
			self.entry.setWeight(wle.weight);
		endif;
	endif;
	
	self.validateQueueEntry();
	
epilog

	// Par 9828
	if self.queue &lt;&gt; null and not app.isRTApp then
		// CCMS 1458
		self.causeAddEntryEvent();
	endif;
	
	if isQueueInternallySet then
		self.queue := null;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="causeAddEntryEvent" id="be6ed935-fbb9-4bee-ae7c-375a63fd0e62">
        <source>causeAddEntryEvent() protected;

// Created by cnwdvb1 on 23 June 2006

vars

begin

	// Only send this event if the queue has one entry. This method
	// should be called just after an entry is added. So if it is the first
	// entry then we want a note. 
	// When this method was written the event was fired once for each queue entry.

	if self.queue &lt;&gt; null and self.queue.allEntries.size = 1 then
		self.queue.causeEvent(EVENT_ENTRY_ADD_QUEUE, false, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkChildHolds" id="0f675483-89ae-44a0-adec-553460d5feff">
        <source>checkChildHolds();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2014	cnwndl1	Initial creation	Par 34665

*/

vars
	rtEntry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
begin

	foreach rtEntry in self.allRTQueueEntries where rtEntry.isChildTiEntry do
		task := rtEntry.allTasks.first;
		if task.status = TASK_UNACTIONED then
			task.setStatus( TASK_SYS_HELD );//22 Apr 2015	NDL	Par 36014
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkLocationForHold" id="f1bf88b0-86e2-473c-82b4-f5806575cca9">
        <source>checkLocationForHold(_location : CM_LocationsController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2012	cnwrd1	Initial creation
//cnwrd1 par 29269 14.3.2012
17 May 2012	cnwer1	par 29525 - changed name &amp; take parameter for location now checks source and target location
*/

vars
	rtEntry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
begin

	if _location = null then
		return;
	endif;
	
	if _location.hasRestrictions(LABOUR_RESTRICTION) then	
		foreach rtEntry in self.allRTQueueEntries do
			task := rtEntry.allTasks.first;
			if task.status = TASK_UNACTIONED then
				task.setStatus( TASK_SYS_HELD );	//22 Apr 2015	NDL	Par 36014
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="compareQueuesToType" id="63494449-4b2d-40fc-81f6-f8b3493876ee">
        <source>compareQueuesToType(_allFoundQueues : CM_RTQueueSet input) protected;

// Created by cnwdvb1 on 15 August 2006

vars

	queue : CM_RadioTelemetryQueue;
	invalidQueue : Boolean;
begin

	// This method screen queues that are not appropriate
	// for certain types of moves. Only sub queues really take any
	// notice.
		
	on Exception do app.handleDeletedObject(exception,queue,invalidQueue);
	invalidQueue:=false;
	
	foreach queue in _allFoundQueues do
		if not queue.compareQueueToType(self.myCurrentMachineTypeGroup) then
			_allFoundQueues.remove(queue);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_allFoundQueues" type="CM_RTQueueSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="955c4364-24b8-4203-9380-2ede81cf1ecd">
        <updating/>
        <source>create() updating;

// Created by cnwdvb1 on 16 August 2006

vars

	terminal : CM_Terminal;

begin

	terminal 				:= app.getMyTerminalDO_NOT_USE();
	
	if terminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal is null', null, null);
		return;
	endif;
	self.preferSource		:= terminal.getConfig(RtQueuePriorityFromOverTo).Boolean;
	self.useMachineRules	:= terminal.getConfig(GateAllowDualGate).Boolean;

end;</source>
    </JadeMethod>
    <JadeMethod name="createBreakBulkMasterTask" id="e9870eee-d953-4500-9c1f-85c3d08f317c">
        <updating/>
        <source>createBreakBulkMasterTask() updating;
/*

Date		Who		Reason
07 May 2013	cnwrd1	Initial creation
06 Sep 2013 cnwer1	PAR 32408 changes to work with release by type
*/

vars
	task : CM_RTQueueTask;
	sourceLC,
	targetLC : CM_LocationsController;
begin
	create task;
	
	if self.wle.myRequest.isBreakBulkReleaseByType() or self.wle.myRequest.isBulkMultiReleaseByType() then
		sourceLC:=self.sourceLocation;
		targetLC:=self.targetLocation;
	else
		sourceLC:=self.ti.myPrimaryActualLocation;
		targetLC:=self.ti.getPrimaryLocation(QUEUE_MODE);	
	endif;
	
	//parent will be set higher up.
	task.setDetails(	sourceLC,
						targetLC,
						TASK_UNACTIONED,
						TASK_BREAKBULK,
						self.ti);
	
	self.entry.addTask(task);
	
	//epr par 32194 7/8/13
	if self.myCurrentMachineTypeGroup &lt;&gt; null then
		self.entry.machineTypeGroup:=self.myCurrentMachineTypeGroup.type;
		self.entry.setMyRTMoveMethodRule(self.myRTMoveMethodRule);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createCOUAlert" id="495dbc0e-12b7-4a3c-8b5c-bae5c41ea8ce">
        <source>createCOUAlert() protected;

vars
	alert	:	CM_SystemAlert;
begin
	create alert;
	alert.details := "Job id " &amp; job.jobId &amp; " requires a COU.";
	alert.setSeverity(SEVERE_INFO);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createEntryTasks" id="8f9a9323-c379-47ec-94e5-b7334c9840c3">
        <updating/>
        <source>createEntryTasks() updating, protected;
//Does the work to get the Tasks. Usually called from createQueueEntry in this
//class, however can be called from wherever required to add tasks to an existing entry.
/*

Date		Who		Reason
06 Aug 2010	cnwer1	PAR#25302 - Director tasks should display the default move method
28 Oct 2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/
vars
	anArbiter : CM_RTQueueArbiter;
	lErrString : String;
	lc : CM_LocationsController;
	targetLC : CM_LocationsController; //cnwrd1
	task	: CM_RTQueueTask;
	forDirector : Boolean;
begin
	if self.job = null or self.wle = null or self.entry = null then
		if self.job = null then
			lErrString := "Job";
		endif;
 		if self.wle = null then
 			if lErrString = null then
				lErrString := "WLE";
			else
				lErrString := lErrString &amp; ", WLE";
			endif;
 		endif;
 		if self.entry = null then
 			if lErrString = null then
				lErrString := "Entry";
			else
				lErrString := lErrString &amp; ", Entry";
			endif;
 		endif;
 		//We need all of this stuff to function.
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NO_ARBITER, ti.id, lErrString ,null, null);
		return;
	endif;
	exclusiveLock(self);
	anArbiter := self;

	forDirector:= self.isForDirectorTask; //epr 21/8/14 CCMS 1391 warehouse vmt and make sure we can pickup break/bulk for director tasks
	if self.ti = null then
			//---------------
			//Is the Job a Road/Rail/Yard internal request of a generic type?
			//---------------
			if not wle.myRequest.isKindOf(CM_DeliveryRequest)
				and not wle.myRequest.isKindOf( CM_YardMoveRequest)
				and not wle.myRequest.isKindOf( CM_RORORequest) //cnwrd1 ccms 1303 30842
				and not wle.myRequest.isKindOf( CM_SlotRequest)
				and not wle.myRequest.isKindOf( CM_HoldRequest) then
				//Nope.
				lErrString := "It is not a Delivery Request or a Yard Move Request";
				//We need all of this stuff to function.
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_NO_ARBITER, null /* self.ti.id */, lErrString ,null, null);
				return;
			endif;
				
			//-----------------
			//Get a Director task.. ie, "goto here, pickup a TI to satisfy..."
			//-----------------
			lc := self.sourceLocation; // DCT STACKDUMP
			// 23099 
			if lc = null and
			   self.wle.myRequest.isKindOf(CM_YardMoveRequest) then
				lc := self.wle.myRequest.CM_YardMoveRequest.mySourceLocation;
				self.sourceLocation := lc;
			endif;	// end 23099
			
				
			
			if lc &lt;&gt; null then
			
				//cnwrd1 par 25681 18.11.2010 multi machine director moves
				targetLC := self.targetLocation;			
				if targetLC &lt;&gt; null and self.myRTMoveMethodRule &lt;&gt; null then 
					//we have source and target location lets go create proper multi move director tasks	
					if (wle.myRequest.isBreakBulkReleaseByType() or wle.myRequest.isBulkMultiReleaseByType())and self.myBulkReleaseMaster = null then
						self.myRTMoveMethodRule.buildQueueTasks(self,self.myCurrentMachineTypeGroup,true);
					else
						self.myRTMoveMethodRule.buildDirectorQueueTask(self,self.myCurrentMachineTypeGroup);
					endif;
				else			
					//epr par 32408 6/9/13
					if (wle.myRequest.isBreakBulkReleaseByType() or wle.myRequest.isBulkMultiReleaseByType())and self.myBulkReleaseMaster = null then
						self.createBreakBulkMasterTask();
						return;
					endif;
				
					lc.getQueueDirectorTasks(anArbiter);
					
					if self.myCurrentMachineTypeGroup &lt;&gt; null then  //cnwrd1	 30/11/2010
						self.entry.machineTypeGroup := self.myCurrentMachineTypeGroup.type;
					endif;
					//epr par 25302 06/08/10
					lc := null;			
				endif;
				
				//epr par 25302 06/08/10
				lc := null;
				if self.myRTMoveMethodRule &lt;&gt; null and self.entry &lt;&gt; null then
					self.entry.setMyRTMoveMethodRule(self.myRTMoveMethodRule);
				endif;
				
			endif;
	else	
		//-------------
		//Get the tasks for each end of the move
		//If the arbiter has been populated with a source and target location
		//it means we are a swapJob, and use thse locations rather than the TI's ones.
		//-------------
		exclusiveLock(ti);
		if self.myCurrentMachineTypeGroup &lt;&gt; null then
			if self.isDoorTurnaround then
				self.buildDoorQueueTasks();
			else	
			//epr ccms 1100  11/2/10
				if self.myRTMoveMethodRule &lt;&gt; null then		
					self.myRTMoveMethodRule.buildQueueTasks(self,self.myCurrentMachineTypeGroup,not forDirector and   ti.canSplitTotalQuantity and self.myBulkReleaseMaster = null);
				else
					self.myCurrentMachineTypeGroup.buildQueueTasks(self);
				endif;
			endif;
		else
			if not forDirector and   ti.canSplitTotalQuantity and self.myBulkReleaseMaster = null then //cnwrd1 2274 break bulk queueing  //epr 21/8/14 CCMS 1391 warehouse vmt if this for a director tasks don't create break bulk master
				self.createBreakBulkMasterTask();
				return;
			endif;
			
			if self.sourceLocation &lt;&gt; null then
				self.sourceLocation.getQueueTasks(anArbiter, true);
			else
				lc := ti.getPrimaryLocation(REAL_MODE); // DCT STACKDUMP
				if lc &lt;&gt; null then
					lc.getQueueTasks(anArbiter, true);
					lc := null;
				endif;
			endif;
	
			if self.targetLocation &lt;&gt; null then
				self.targetLocation.getQueueTasks(anArbiter, false);
			else
				lc := ti.getLastQueuedLocation(); // DCT STACKDUMP
				if lc &lt;&gt; null then
					lc.getQueueTasks(anArbiter, false);
					lc := null;
				else
					if not self.entry.isPlanOnPickupNoTarget then
						create task;
						task.setDetails(self.sourceLocation,null,	TASK_UNACTIONED,	TASK_SETDOWN,ti);
						self.entry.addTask(task);
					endif;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createQueueEntry" id="08fcaf0a-fd2b-4b5c-a9f1-e0a74b3e5594">
        <updating/>
        <source>createQueueEntry() updating, protected;
/*
This method is called when we have determined the correct
queue to assign a TI to.
*/
vars
	qEntry, proxyQEntry	: CM_RTQueueEntry;
	lErrString : String;
	futureMove			: CM_FutureMove;
	qIndex		: Integer;
begin
		
	if self.job = null  or self.wle = null then
		if job = null then
			lErrString := "Job";
		endif;
 		if self.wle = null then
 			if lErrString = null then
				lErrString := "WLE";
			else
				lErrString := lErrString &amp; ", WLE";
			endif;
 		endif;
 		//We need all of this stuff to function.
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NO_ARBITER, ti.id, lErrString ,null, null);
		return;		
	endif;
	
	futureMove := self.wle.myFutureMove;
	if futureMove = null and self.wle.isDRLinkedByFM then	// TFS 42863 jlgzm1 06/08/2019
		futureMove := self.wle.myFutureMoveDR;				// TFS 42863 
	endif;
	
	//epr CCMS 1100 22/2/10
	if self.myRTMoveMethodRule &lt;&gt; null then
		
		//cnwrd1 par 25681 18.11.2010 multi machine director moves
		//if futureMove &lt;&gt; null and not self.wle.allRTQueueEntries.isEmpty then
		if not self.wle.allRTQueueEntries.isEmpty  and self.wle.allRTQueueEntries.first.allTasks.size &gt; 1 then
			qIndex:=self.wle.allRTQueueEntries.indexOf(self.myPreviousRTQueueEntry);
			qIndex:=qIndex+1;
			// this is the new index lets see if a rt queue entry for the future move exists
			if self.wle.allRTQueueEntries.size &gt;= qIndex then
				qEntry:=self.wle.allRTQueueEntries[qIndex];
				if qEntry &lt;&gt; null and self.entry &lt;&gt; null then
					self.entry.setMyPreviousRTQueueEntry(self.myPreviousRTQueueEntry);
					self.allRTQueueEntries.add(self.entry);
					self.myPreviousRTQueueEntry	:= self.entry;
					return;
				endif;
			endif;
		endif;
	
	endif;
	
	
	//-----------------
	//Create the entry
	//-----------------
	
	// cnwrd1 ccms 2014 autoplan on pickup - here we dont want to create a new queue entry as we already have one for the initial pickup task. 22.3.2011
	
	if futureMove.isKindOf(CM_FutureMoveQueuedPOP) and not futureMove.CM_FutureMoveQueuedPOP.allRTQueueEntries.isEmpty and self.myPreviousRTQueueEntry = null  then
		qEntry := futureMove.CM_FutureMoveQueuedPOP.allRTQueueEntries.first;
		self.entry := qEntry;  //set the old qentry
		futureMove.CM_FutureMoveQueued.setRTQueueEntry(self.entry, self.isMultiQueueEntry); //update for multiqueued
	else
		create proxyQEntry transient;
		proxyQEntry.setProxy(self.wle);
		create qEntry persistent;
		qEntry.setForCreate(proxyQEntry);
		qEntry.setIsMachineInitiatedMove(self.isDriverInitiatedMove);
		self.entry := qEntry;
	
		// DVB Added 23 March 04. 
		if futureMove &lt;&gt; null and futureMove.isKindOf(CM_FutureMoveQueued) then //cnwrd1 par 27024 21.2.2011
			self.exclusiveLock(futureMove);
			futureMove.CM_FutureMoveQueued.setRTQueueEntry(self.entry, self.isMultiQueueEntry);
		endif;
	endif;

	//-----------------
	//Now, get the tasks
	//-----------------
 	self.createEntryTasks();
	
	
	
	if self.myBulkReleaseMaster &lt;&gt; null then //cnwrd1 2274 break bulk
		self.entry.setMyBreakBulkMaster(self.myBulkReleaseMaster);
	else
		self.entry.setMyPreviousRTQueueEntry(self.myPreviousRTQueueEntry);
	endif;
		
	self.allRTQueueEntries.add(self.entry);
	self.myPreviousRTQueueEntry	:= self.entry;
	
epilog
	delete proxyQEntry;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createVoyageQueues" id="4b71ccd7-bc69-4307-89de-f98004f51918">
        <updating/>
        <source>createVoyageQueues(_job : CM_Job input; _returnQueue : CM_RadioTelemetryQueue io) protected, updating;
/*

Purpose:	Will create the Voyage Queue then depending on the type of job will create 
				either a Voyage Crane Queue or a Work Point Queue

Parameters:			

Return Value:		


Date			Who		Reason
12 August 2011	cnwer1	Initial creation CCMS MES 1033
31 July 2019	jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk
 // ### JIRA 35862 08SEP2025 NAVAB1 - added 'updating'
*/

vars
	voyageJob : CM_VoyageJob;
	masterQ:         CM_MasterQueue;
	workPointObject  : CM_Object;
	crane	: CM_Crane;
	workPoint : CM_WorkPoint;
begin
	
	if _job = null then
		return;
	endif;
	
	if not _job.isKindOf(CM_VoyageJob) then	
		return;
	endif;
	
	voyageJob := _job.CM_VoyageJob;
	masterQ := self.myTerminal.radioTelemetry.masterQueue;

	// don't accept the master queue, try for crane queue then voyage queue
	// create them if neccessary!
	if _returnQueue = masterQ and not masterQ.hasVoyageQueue(voyageJob.myVoyage) then  // PAR 25683
		self.writeLoggingText("Create voyage queue for: " &amp; voyageJob.myVoyage.code);
		masterQ.createVoyageQueue(voyageJob.myVoyage, _returnQueue);
		
		// If is a Direct Release move 'to' Voyage										
		if _job.isRelease and self.wle &lt;&gt; null and self.wle.isDRLinkedByFM then		// TFS 42863
			// If is the first move of a multi machine move
			if self.allRTQueueEntries.size = 1 										// TFS 42863
			   and self.myRTMoveMethod &lt;&gt; null 										// TFS 42863
			   and self.myRTMoveMethod.allMachineTypeGroups.size &gt; 1 then			// TFS 42863
				_returnQueue := masterQ;											// TFS 42863
			endif;																	// TFS 42863
		endif;
	endif;

	// create the crane or work point queue
	if _returnQueue.isKindOf(CM_VoyageQueue) then
		workPointObject:=voyageJob.getWorkPointObject;
		
	//	crane := voyageJob.getJobCrane;	
		if workPointObject &lt;&gt; null and (not workPointObject.IF_VoyageWorkPoint.getIsNotAvailableForEntry) then
			if workPointObject.IF_VoyageWorkPoint.getWorkPointQueueForVoyage(voyageJob.myVoyage) = null then
				
				if workPointObject.isKindOf(CM_Crane) then
					crane:=workPointObject.CM_Crane;
					_returnQueue.addMachine(crane);
					self.writeLoggingText("Create voyage crane queue for: " &amp; crane.id);
					_returnQueue.CM_VoyageQueue.createCraneQueue(crane, _returnQueue);
				elseif workPointObject.isKindOf(CM_WorkPoint) then
					workPoint:=workPointObject.CM_WorkPoint;
					self.writeLoggingText("Create voyage work point queue for: " &amp; workPoint.code);
					_returnQueue.CM_VoyageQueue.createWorkPointQueue(workPoint,_returnQueue);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_returnQueue" type="CM_RadioTelemetryQueue" usage="io"/>
    </JadeMethod>
    <JadeMethod name="determineMoveMethodRule" id="ca47fed7-d918-4781-82cf-475038ed100c">
        <updating/>
        <source>determineMoveMethodRule() updating;
/*

Date		Who		Reason
17 Mar 2015	cnwer1	Initial creation PAR
30 Jan 2022 jlier1	TFS 55828 - removed protected 

*/

vars
	theTargetLC 			: CM_LocationsController;
begin
	
	if self.myRTMoveMethodRule &lt;&gt; null then
		self.myRTMoveMethod :=self.myRTMoveMethodRule.myRTMoveMethod;
		return;
	endif;
	
	theTargetLC := self.targetLocation; //cnwrd1 par 25681 1.12.2010 multimachine director tasks
	if theTargetLC = null then
		//epr par 34634 3/9/14
		if self.wle &lt;&gt; null and not self.wle.isPlanOnPickup then
			theTargetLC := self.getTargetLocForYardRequest();
		endif;
	endif;
		
	if self.sourceLocation &lt;&gt; null then
		self.writeLoggingText('processMachineMoves: Source: ' &amp; self.sourceLocation.getID);
	endif;
	if theTargetLC &lt;&gt; null then
		self.writeLoggingText('processMachineMoves: Target: ' &amp; theTargetLC.getID);
	endif;
		
	self.myRule:= self.myTerminal.getRTQueueMultiRule(self.sourceLocation, theTargetLC); //cnwrd1 par 25681 1.12.2010 multimachine director tasks
	// Some RTG extra rules about RTG to RTG moves in same lane.
	//if self.myRule &lt;&gt; null then
	if self.myRule &lt;&gt; null and not self.myRule.isDisabled then						// 24/08/2012 cnwmh5
		self.writeLoggingText('processMachineMoves: Found machine rule: ' &amp; self.myRule.getName());

		
		
		if self.myRule.isRuleRTGToRTGSameLane(self.sourceLocation,  theTargetLC) then //cnwrd1 par 25681 1.12.2010 multimachine director tasks
			self.myRTMoveMethod:= app.myRoot.allRTMoveMethods[RTMoveMethod_22];
		else
			//epr par 30507 25/10/12 for director tasks will already have determined move rule
			if self.myRTMoveMethodRule = null or not 
				(self.myRule.allDefaultRTMoveMethodRules.includes(self.myRTMoveMethodRule) or
				self.myRule.allOtherRTMoveMethodRules.includes(self.myRTMoveMethodRule)) then
								
				
				self.myRTMoveMethodRule:=self.myRule.getDefaultRTMoveMethodRule;
				if self.myCurrentMachineTypeGroup &lt;&gt; null then
					if self.myRTMoveMethodRule.myRTMoveMethod.allMachineTypeGroups.first &lt;&gt; self.myCurrentMachineTypeGroup then
						self.myRTMoveMethodRule:=self.myRule.getMoveMethThatStartsWithMach(self.myCurrentMachineTypeGroup);
						if self.myRTMoveMethodRule = null then
							self.myRTMoveMethodRule:=self.myRule.getDefaultRTMoveMethodRule;
						endif;	
					endif;					
				endif;
			endif;
			//epr 8/3/10 par 22686
			if self.myRTMoveMethodRule &lt;&gt; null then
				//jlier1 TFS 54701 tractor move
				if self.myRTMoveMethodRule.myRTMoveMethod.type = RTMoveMethod_39 then
				//if it is a tractor then cargo must be a trailer
					if self.ti = null or not self.ti.isChassis then
						if self.myRule.allOtherRTMoveMethodRules.first &lt;&gt; null then
							self.myRTMoveMethodRule:=self.myRule.allOtherRTMoveMethodRules.first;
						endif;
					endif;
				endif;
				if self.myRTMoveMethodRule.myRTMoveMethod.type = RTMoveMethod_40 then
				//if it is a tractor the fork lift cargo must be on a trailer
					if self.ti = null or not self.ti.isOnTrailer then
						if self.myRule.allOtherRTMoveMethodRules.first &lt;&gt; null then
							self.myRTMoveMethodRule:=self.myRule.allOtherRTMoveMethodRules.first;
						endif;
					endif;
				endif;
				if self.myRTMoveMethodRule.myRTMoveMethod.type = RTMoveMethod_41 then //if the rule is forklift to mafi then doesn't make sense if just queueing a MAFI
					if self.ti = null or  self.ti.isChassis then
						if self.myRule.allOtherRTMoveMethodRules.first &lt;&gt; null then
							self.myRTMoveMethodRule:=self.myRule.allOtherRTMoveMethodRules.first;
						endif;			
					endif;					
				endif;
			
				self.myRTMoveMethod :=self.myRTMoveMethodRule.myRTMoveMethod;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enqueueRequest" id="cfc2cf17-0bce-4c0f-ab1f-878ddb75af83">
        <updating/>
        <source>enqueueRequest(optionalSourceLC : CM_LocationsController io) updating;
//Does the work to Queue a Request for a TYPE of container to a system queue.
//There IS NO TI!!
//The Request here is a delivery request, not a yardmove type, this is deliberate
//as yardMove requests are not queued in this manner, the sourcelocation is known.

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 20/09/2022	navkc1		Bug 54860: PNL - Error 85427 (No next position for container longer than 20')
// 25/04/2023   navma1		Bug 57739: PNL - Radio Telemetry Queues not working for multi move delivery requests (new issues)
// 05/06/2025   navma1 		MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage 
// 17/9/25 		jlier1		MTN-35637 - changes to how best pick gets the ti - now ordered by attributes of Ti - numOverstows &amp;  bestPickDT
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
vars

	targetTa			: CM_TerminalArea;
	targetLocn			: CM_LocationsController;
	theTerminal			: CM_Terminal;
	tStr				: String;
	foundHeight			: Integer;
	req					: CM_Request;
	sourceTa			: CM_TerminalArea;
	sourceLocn			: CM_LocationsController;
	foundTi				: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	ti					: CM_TrackedItem;
	passport			: CM_Passport;
	overrideQueue		: CM_RadioTelemetryQueue;
	wc					: CM_WagonController;
	invalid 			: Boolean;
	ed					: Integer;
	rule				: CM_RTQueueMultiRule;
	yaPlan				: CMIF_YAAutoPlan;
	tempLc				: CM_LocationsController;
	reserveDetail		: CM_ReserveDetail;
	bestPickOnlySource			: Boolean;
begin

	//-------------
	//Do the autoplan, it returns a sourceLocation to pick one of these TI's from.
	//-------------
	if self.job = null then
		return;
	endif;

	//----------------
	//Get the Area where this is terminating (ie, a VTA)
	//----------------
	theTerminal := self.job.getMyTerminal;
	if not theTerminal.isAutoPlanningEnabled() then				// 08/10/2015 cnwma1 PAR# 36984
		return;
	endif;
	

	if self.job.isRoadJob then
		//AJA 6/3/01: Now we queue the items to the truck itself
		targetLocn	:= wle.getRoadReleaseLC(); //epr par 33302 15/1/13
	elseif job.isRail then
		//--------------------
		//If this Request requires a COU STOP NOW!
		//COU's are dealt with MANUALLY. Dont bother queuing/planning.
		//--------------------
		if wle.myRequest.CM_YardRequest.needCOU then
			if wle.myTrackedItem &lt;&gt; null then

				if wle.myTrackedItem.isKindOf(CM_Container) then
					if wle.myTrackedItem.CM_Container.getCou = null then
						//TI, but no COU.
						self.createCOUAlert();
						return;
					endif;
				endif;
				//If it has a COU, then its been attached, let it through.
			else
				//For delivery requests with COUs we deliberately do not go into the autoplan process
				//This is because the TI normally goes from the block stack via a COU area to get a COU
				//attached and we don't do the double queue move. We just create an alert for the operator
				//who satisfies the request manually
				//UNLESS there is an optionalSourceLC passed into us. The users are telling us where
				//to go get the box. DQ 07/06/2001
				if optionalSourceLC = null then
					self.createCOUAlert();
					return;
				endif;
			endif;
		endif;

		targetTa	:= theTerminal.lookupTerminalArea(job.CM_RailJob.railTransAreaId);
		//Ta here is the Rail Track, we have to deref again to get the transfer area
		targetTa := targetTa.CM_Rail.myTransferArea;
		if targetTa = null then	//No RTA yet!
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_TA_ID, job.CM_RailJob.railTransAreaId.trimRight &amp; " has no transfer area", null, null);
			return;			
		endif;

		targetLocn := targetTa.getLocationsController();
		
		//21 Aug 2009	NDL	CCMS 1094
		if wle.isYardReleaseAssigned then
			wc := wle.CM_YardWLE.allLocationControllers.first;
			if wc &lt;&gt; null then
				//This wle has been associated with a wagon controller, so use that instead of teh rail area.
				targetLocn := wc;
			endif;
		endif;

	elseif job.isKindOf(CM_YardInternalJob) then
		//----------------------
		//Specialised type of job, this is like a road release, but a release is to
		//another area within the yard.
		req := job.CM_YardInternalJob.allRequests.first;
		if req.isKindOf(CM_YardDeliveryRequest) then
		
			tStr	:= req.CM_YardDeliveryRequest.targetLocation;
			targetTa		:= req.CM_YardDeliveryRequest.myTargetTA;
			
			invalid := false;
			if targetTa = null then
				invalid := true;
			else
				on Exception do app.handleDeletedObject(exception, targetTa, invalid);
				// Dereference ta to check it is valid
				ed := targetTa.edition();
			endif;
			
			if invalid then
				targetTa	:= theTerminal.lookupTerminalArea(tStr);
			endif;

			if targetTa = null then
				//--------------------
				//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
				//--------------------
				theTerminal.findLocationFromString(tStr, false, targetLocn, foundHeight);
			endif;
			
			if targetLocn = null and targetTa &lt;&gt; null then
				targetLocn := targetTa.getLocationsController();
			endif;
			
		elseif req.isKindOf(CM_WOMoveRequest) then
			tStr	:= req.CM_WOMoveRequest.targetLocation;
			targetTa		:= req.CM_WOMoveRequest.myTargetTA;
			
			invalid := false;
			if targetTa = null then
				invalid := true;
			else
				on Exception do app.handleDeletedObject(exception, targetTa, invalid);
				// Dereference ta to check it is valid
				ed := targetTa.edition();
			endif;
			
			if invalid then
				targetTa	:= theTerminal.lookupTerminalArea(tStr);
			endif;

			if targetTa = null then
				//--------------------
				//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
				//--------------------
				theTerminal.findLocationFromString(tStr, false, targetLocn, foundHeight);
			endif;
	
			if targetLocn = null and targetTa &lt;&gt; null then
				targetLocn := targetTa.getLocationsController();
			endif;
			
		elseif req.isKindOf(CM_YardMoveRequest) then
			//added to handle YardMoveRequests epr par 21210 16/10/09
			targetLocn	:= req.CM_YardMoveRequest.myTargetLocation;
			
		else
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_TA_ID, "Not a yard Delivery Job", null, null);
			return;
		endif;
	
	elseif job.hasBulkReleaseItem then
		// This should be a Voyage bulk release, so the destination is a crane transfer area
		targetLocn := job.CM_VoyageJob.getCraneTransAreaLC();
		//20 Aug 2014	NDL	Par 33700
		if wle &lt;&gt; null then
			tempLc := wle.getLocationForMode(PLANNING_MODE);
			if tempLc &lt;&gt; null then //epr par 35029 4/11/14
				targetLocn := tempLc;
			endif;
		endif;
		//epr par 30393
		reserveDetail := self.wle.myRequest.getBulkReleaseReserveDetail();		//05.06.2025 navma1 #MTN-34114
		if  reserveDetail &lt;&gt; null then 											//epr par 30393 8/1/14
			optionalSourceLC := reserveDetail.getLocationLC();  				// PAR 18617
		endif;
	elseif wle.isVoyageAllocDirector then // we are a voyage allocation load wle
		targetLocn := job.CM_VoyageJob.getCraneTransAreaLC();
		//epr par 35029 4/11/14
		if wle &lt;&gt; null then
			tempLc := wle.getLocationForMode(PLANNING_MODE);
			if tempLc &lt;&gt; null then
				targetLocn := tempLc;
			endif;
		endif;
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_JOB, null, null);
		return;
	endif;
	//added to handle YardMoveRequests epr par 21210 16/10/09
	if not wle.isVoyageAllocDirector then
		if not (wle.myRequest.isKindOf(CM_DeliveryRequest) or 
				 job.hasBulkReleaseItem or	
				 wle.myRequest.isKindOf(CM_YardMoveRequest)) then
			app.setContinueCMExceptions(false);
			app.raiseCMException(VB_REQ_NOT_FOUND, null, null);
			return;
		endif;
	endif;
	
	self.setMyTerminal( theTerminal);
	if optionalSourceLC &lt;&gt; null then
		sourceLocn := optionalSourceLC;
	else
		passport	:= app.myPassport;
		// 05/02/2010 cnwjre1 CCMS 1101 nominated location
		//sourceTa	:= wle.myRequest.getNominatedTA();
		bestPickOnlySource:= self.job.isRoadJob and theTerminal.getConfig(GateBestPickForSource).Boolean; //jlier1 JIRA 65637 15/9/25
		// 23023 do director task if not best-pick; also just scan this area
		// 26671 Refactored code to remove duplication
		if wle.isBestPick or bestPickOnlySource  then		// 23098
		
			//24 May 2011	NDL	Par 27524
		/*	if  wle.isBestPick and ( sourceTa = null and wle.myRequest.isKindOf(CM_DeliveryRequest) and not wle.myRequest.CM_DeliveryRequest.allTerminalAreas.isEmpty) then
				//we have a delivery request with 'Best Pick' set, but also with one or more specific areas nominated.
				// The "getNominatedTa" call has failed to identify any of those area(s) as actually having any suitable cargo
				// therefore we should bail rather than go off and find matching cargo outside of teh nominated area(s), which we would
				// attempt to do if we make the call with sourceTa set to null.
				app.raiseCMWarning(Request_failed_auto_plan, null, null, null);
				return;
			endif;*/
			
			ti := app.sourceTisForRequestBestPick(theTerminal, wle, sourceTa, true,null);
			if ti &lt;&gt; null then
				sourceLocn := ti.allLocations.first;
				self.sourceLocation := sourceLocn; // 23098 - this can be referenced later
				self.myBestPickTI:=ti;
				if not wle.isBestPick and bestPickOnlySource then //jlier1 JIRA 65637 15/9/25
					sourceTa:=ti.myTerminalArea;	
				else
					foundTi := ti;
				endif;
			else
				app.raiseCMWarning(Request_failed_auto_plan, null, null, null);
				return;
			endif;
			// if nothing was found at this location, don't continue
			if not bestPickOnlySource and sourceLocn = null  then
				return;
			endif;
	
		endif;
		
		// If we are best pick we should have a source location or have exited
		if sourceLocn = null then   
			sourceLocn	:= app.sourceTisForRequestYA(theTerminal, wle.myRequest);
			//28 June 2012	NDL	Par 29778 - Check for YA being a best pick
			if app.myYAAgent &lt;&gt; null then
				yaPlan := app.myYAAgent.myCurrentCMIFYAAutoPlan;
				if yaPlan &lt;&gt; null and yaPlan.myFirstUsedYA &lt;&gt; null and yaPlan.myFirstUsedYA.fillOptionOut = YAFillOption_BestPick then // best pick YA
					foundTi := yaPlan.allFoundTis.first;
				endif;
			endif;
		endif;
		
		if sourceLocn = null then
			app.raiseCMWarning(Request_failed_auto_plan, null,null,null);  //cnwrd1 par 24621 13.7.2010
			return;
		endif;
		
		if (sourceLocn.myTerminalArea &lt;&gt; null
			and sourceLocn.myTerminalArea.isKindOf(CM_GridArea)) then
			if foundTi &lt;&gt; null then
				ti := foundTi;
			
				create moveController transient;
				moveController.setMoveMode(QUEUE_MODE);
				moveController.setMyTrackedItem(ti);				
				moveController.setMyToPrimaryLocation(targetLocn);
				moveController.setMyWorkListEntry(wle);
				app.myUtilityUA.utlUpdateWLEUnqueue(wle, passport);			// 23023 equivalent - same as menu unqueue code
				wle.setMyTrackedItem(null);
				// ** 23676 introduced a validation check to prevent source location change to a queued item
				// so the code above may no longer be required.
			
				app.myUtilityUA.utlUpdateWLEAssignTI(moveController, passport);
				
				if passport.noErrors() then
					// Tell the stuff later on that things are ok.
					self.ti := ti;
				endif;
			
				if app.myYAAgent &lt;&gt; null then
					ti.createInfomationTransaction(YardAllocationAutoPlan, app.myYAAgent.getLoggingArray(true), null, passport);
				endif;
			
				return;
			endif;
		endif;
	endif;
		
	/*
	25.04.2023 navma1 #57739
	not Setting the target location will cause issues to assign the RTQ Task to the correct queue 
	*/
	if self.job &lt;&gt; null and self.job.isKindOf(CM_YardInternalJob)then
		if targetLocn = null then
			if targetTa &lt;&gt; null then
				if targetTa.isKindOf(CM_GridArea) then
					targetLocn := targetTa.CM_GridArea.getNextAvailableLocation(targetTa.CM_GridArea.allGridControllersByRowColumn.first);
				endif;
			endif;
		endif;
	endif;
	/*
	25.04.2023 navma1 #57739
	*/
	
	//----------------
	//find a queue
	//----------------
	self.sourceLocation 	:= sourceLocn;
	self.targetLocation 	:= targetLocn;
	self.ignoreExtraChecks	:= true;
	
	// cnwrd1 ccms 1075/ccms 1735 - if request has a selected rt queue use that as overide. 11.8.09 -  moved here as part of CCMS 2014
	if req &lt;&gt; null and req.mySelectedRTQueue &lt;&gt; null then				// 28/03/2011 cnwmh5 - Add req &lt;&gt; null
		overrideQueue := req.mySelectedRTQueue ;
	endif;
	
	// Override queue. This is so we can use queue associated with the current location of a vehicle
	// if the one of source/target locations is a vehicle.  
	//cnwrd1 11.8.09 also setting Override above for internal move jobs with rtqueue selected
	if self.sourceLocation &lt;&gt; null and overrideQueue = null then //cnwrd1 11.8.09
	
		overrideQueue := self.sourceLocation.getOverrideQueue();
		
		if overrideQueue = null and self.targetLocation &lt;&gt; null then	
			overrideQueue := self.targetLocation.getOverrideQueue();	
		endif;
	endif;
	self.queue := overrideQueue;
	
	//epr par 25373 13/08/10 - 
	if self.sourceLocation = null or self.targetLocation = null then
		if sourceTa &lt;&gt; null and targetTa &lt;&gt; null then
			rule := self.myTerminal.allRTQueueMultiRuleTATypes[sourceTa.myType, targetTa.myType];
		endif;
		if rule &lt;&gt; null and not rule.isDisabled then							// 24/08/2012 cnwmh5	
			self.setMyRTMoveMethodRule(rule.getDefaultRTMoveMethodRule);
			self.myRTMoveMethod :=self.myRTMoveMethodRule.myRTMoveMethod;
		endif;
	endif;
	
	self.processMachineMoves();
	
	if self.wle &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.wle, theTerminal.getTerminalEvent(WLE_Update_Event), self.wle);	
	endif;
epilog
	delete moveController;
end;</source>
        <Parameter name="optionalSourceLC" type="CM_LocationsController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enqueueTI" id="bc61a601-741f-4fd9-8149-f8e8614fe136">
        <updating/>
        <source>enqueueTI() updating;
//Does the work to Queue this TI to a system queue.
//By the time we get here, the TI should have a Queued location.
// 29/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so can also write to logging form
// 20/02/2018	jlgsl4	TFS 37057 - Use source location specified in new queued move to Yard location
//									if there's already-queued move to non-Yard location
// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

vars
	tiID 			: String;
	tmpQueuedLocn	: CM_LocationsController;
	theSubQueue		: CM_SubQueue;
	futureMoveQueued: CM_FutureMoveQueued;
	invalidObject : Boolean;
	crnTA : CM_CraneTransferArea;
	crn : CM_Crane;
	subQ : CM_RadioTelemetryQueue;
	voyCrnQ : CM_VoyageCraneQueue;
	theVoyCrnQ : CM_VoyageCraneQueue;
	wp : CM_WorkPoint;
	wpQ : CM_VoyageWorkPointQueue;
	
begin
	on Exception do app.handleDeletedObject(exception, self.sourceLocation, invalidObject);

	tiID := ti.id.trimBlanks;	

	self.writeLoggingText("EnqueueTI: Find a queue for: " &amp; tiID );
	
	//epr par 25285 13/9/10 if there is a wle use the target location from the future move
	// this is more acurate when there are multiple moves 
	if self.wle &lt;&gt; null then
		tmpQueuedLocn := self.wle.getTargetLocation;
	endif;
	if tmpQueuedLocn = null then
		tmpQueuedLocn := ti.getLastQueuedLocation();
	endif;
	
	if tmpQueuedLocn = null and not ti.allQueuedFutureMoves.last.isKindOf(CM_FutureMoveQueuedPOP)  then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		if  not self.isDriverInitiatedMove then //epr CCMS 1391 21/8/14 driver initiated moves don't have to have a target the driver will specify one
	//TI has not been queued moved yet!
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_TI_NO_QUEUELOCN, tiID, null, null);
		return;		
		endif;
	endif;
	
	
	// CCMS 1577 //epr par 31707 11/6/13
	if  ti.queueId &lt;&gt; null and not ti.canMergeBreakBulk then //epr par 35597 30/1/15
		if (self.job = null or not self.job.isYardInternalJob) and not (wle &lt;&gt; null and wle.isChassisToRelease) then //epr par 34107 20/5/14
			if wle &lt;&gt; null and wle.myFutureMoveDR &lt;&gt; null then	//17 Jul 2019	NDL	TFS 42876
				//Its a Direct Release, this is OK.
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException1(Tracked_item_already_queued, tiID,null, null);
			return;	
			endif;
		endif;
	endif;
	//-------------
	//OK, we have a queued target location. Get the Queue!
	//-------------
	
	
	if ti.isMultiQueued() and not self.isDriverInitiatedMove and not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then //epr par 35702 3/3/15
		// epr par 25873 
		if self.wle.myFutureMove &lt;&gt; null then
			//epr par 25285 13/9/10 
			futureMoveQueued := self.ti.getPreviousFutureMoveQueued(self.wle.myFutureMove);
		endif;
		
		if futureMoveQueued &lt;&gt; null and not futureMoveQueued.isKindOf(CM_FutureMoveQueuedPOP)  then
			if futureMoveQueued.allLocationsControllers.first &lt;&gt; null and futureMoveQueued.allLocationsControllers.first.isKindOf(CM_YardController) then // TFS 37057
				self.isMultiQueueEntry := true;
				/*jlier1 JIRA#19371 9/12/24 - the rtQueueEntry has a mapping method which always gets the source location where the cargo currently is. So this is not needed and also means if the cargo is queuedx2 then the source becomes the first
				queued location's target. This means if there is labour it won't put the queue entry on hold if the source is not where the cargo is*/
				//self.sourceLocation := futureMoveQueued.getPrimaryLocation();
			endif; // TFS 37057
		endif;
	endif;
	
	if self.sourceLocation = null then
		self.sourceLocation		:= ti.getPrimaryLocation(REAL_MODE);
	endif;
	
	// Override queue. This is so we can use the dual gate vehicle transfer pre queue.
	if self.sourceLocation &lt;&gt; null then		// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
		theSubQueue:= self.sourceLocation.getOverrideQueue();
	endif;
	
	if theSubQueue = null and tmpQueuedLocn &lt;&gt; null then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		theSubQueue := tmpQueuedLocn.getOverrideQueue();
	endif;
	
	if self.wle.isPlanOnPickup and self.wle.myRequest.mySelectedRTQueue &lt;&gt; null then //cnwrd1 ccms 2014 31.3.2011 //cnwrd1 23.11.11 par 28728 do this only for autoplanonpickup
		self.queue				:=  self.wle.myRequest.mySelectedRTQueue;
		self.writeLoggingText("EnqueueTI: Selected queue from request will be used");
	else
		self.queue				:= theSubQueue;
	endif;
	
	//14 Sep 2017	NDL	TFS 6887
	if self.queue = null and self.job &lt;&gt; null and self.sourceLocation &lt;&gt; null then
		if self.job.isKindOf(CM_VoyageJob) and self.sourceLocation.isCraneLaneController then
			if not self.job.isRelease and self.job.CM_VoyageJob.myVoyage &lt;&gt; null then
				//Its being moved 'in transit' to the crane controller during discharge, use the voyage queue
				self.queue := self.job.CM_VoyageJob.myVoyage.myQueue;
				//20 Sep 2017	NDL	TFS 6887
				if self.queue &lt;&gt; null and sourceLocation.myTerminalArea &lt;&gt; null and sourceLocation.myTerminalArea.isKindOf(CM_CraneTransferArea) then
					crn := sourceLocation.myTerminalArea.CM_CraneTransferArea.crane;
					if crn &lt;&gt; null then
						foreach subQ in self.queue.allSubQueuesById do
							if not subQ.isCraneQueue then
								continue;
							endif;
							voyCrnQ := subQ.CM_VoyageCraneQueue;
							if voyCrnQ.crane = crn then
								theVoyCrnQ := voyCrnQ;
								break;
							endif;
						endforeach;
					endif;
				endif;
				if theVoyCrnQ &lt;&gt; null then
					self.queue := theVoyCrnQ;
				endif;
				
			endif;
		endif;
	endif;
	
	//23 Jun 2021	NDL	TFS 51231 - From Voyage Operations moving cargo to the I/C area for a Barge.
	if self.queue = null and tmpQueuedLocn &lt;&gt; null and ti.isExport and ti.myVoyage &lt;&gt; null and ti.myVoyage.isBarge then
		if tmpQueuedLocn.myTerminalArea &lt;&gt; null and ( tmpQueuedLocn.myTerminalArea.isKindOf(CM_CraneTransferArea) or  tmpQueuedLocn.myTerminalArea.isKindOf(CM_WorkPointInterchangeArea) ) then
			self.queue := ti.myVoyage.myQueue;
			if tmpQueuedLocn.myTerminalArea.isKindOf(CM_CraneTransferArea) then
				crn := tmpQueuedLocn.myTerminalArea.CM_CraneTransferArea.crane;
				if crn &lt;&gt; null then
					foreach subQ in self.queue.allSubQueuesById do
						if not subQ.isCraneQueue then
							continue;
						endif;
						voyCrnQ := subQ.CM_VoyageCraneQueue;
						if voyCrnQ.crane = crn then
							self.queue := voyCrnQ;
							break;
						endif;
					endforeach;
				endif;
				
			elseif tmpQueuedLocn.myTerminalArea.isKindOf(CM_WorkPointInterchangeArea) then
				wp := tmpQueuedLocn.myTerminalArea.CM_WorkPointInterchangeArea.myWorkPoint;
				if wp &lt;&gt; null then
					foreach subQ in self.queue.allSubQueuesById do
						if not subQ.isWorkPointQueue then
							continue;
						endif;
						wpQ := subQ.CM_VoyageWorkPointQueue;
						if wpQ.myWorkPoint = wp then
							self.queue := wpQ;
							break;
						endif;
					endforeach;
				endif;
			
			endif;
		endif;
	endif;
	
	if self.queue &lt;&gt; null then
		self.writeLoggingText("EnqueueTI: Found queue: " &amp; self.queue.id);
	else
		self.writeLoggingText("EnqueueTI: No queue found");
	endif;
	
	self.targetLocation 	:= tmpQueuedLocn;
	self.ignoreExtraChecks	:= false;
	
	self.processMachineMoves();
	self.checkLocationForHold(self.targetLocation); //cnwrd1 par 29269 14.3.2012
	self.checkLocationForHold(self.sourceLocation); //epr par 29525 17/5/12 - check source to
	self.checkChildHolds();	//30 July 2014	NDL	Par 34665
end;</source>
    </JadeMethod>
    <JadeMethod name="getQueue" id="001be470-f06b-4eb9-a719-5d3c24f41fe6">
        <updating/>
        <source>getQueue(): CM_RadioTelemetryQueue  updating;

/*

Date		Who		Reason
26/05/2010 cnwmh5 #25510/25512 - Add queue logging
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
27/06/2011	cnwmh5	#27179 - Change so that uses the queues in the order they are on the RT Queues screen
29/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so can be reported on logging form
30/08/2011	cnwdap1	PAR #25693 CCMS POL 2008 Changes to allow Full Move Queueing for voyage Load jobs
28/09/2011	cnwdap1	PAR #28280 Correction for Full Move Queueing - find first matching queue then stop looking
							   Avoids issues with bi-directional queues with terminal areas defined that can 
							   end up becoming a higher priority than the original queue, and splitting the jobs
27/09/2012	cnwer1	PAR 30376  Source LC to IMV entry for ForkLift or IMV to Target LC entry for ForkLift could get the incorrect queue if leg queuing
								Source LC to IMV should always try find q for source lc &amp; IMV to Target LC entry should try q for target LC area
// ### JIRA 35862 08SEP2025 NAVAB1 add to message window indented
01/10/2025	jlizm1	MTN 35861 RTQueue configuration - cargo attribute criteria
*/
vars
	masterQ:         CM_MasterQueue;
	tmpQueueRef1,
	tmpQueueRef2	: CM_RTQueueSet;
	aQueue:          CM_RadioTelemetryQueue;
	retQueue:        CM_RadioTelemetryQueue;
	machineTypeGrp : CM_MachineTypeGroup;
	currentMatch,
	match:           Integer;
	theTerminal 	: CM_Terminal;
	tmpTargetLocation,
	tmpSourceLocation: CM_LocationsController;
	arbiterRef		: CM_RTQueueArbiter;	
	doCreateVoyageQueues : Boolean;
	invalidQueue : Boolean;
	loggingText	: String;
	allQueues		: CM_RTQueueArray;
	iter 		: Iterator;
	prevEntry	 : CM_RTQueueEntry;
	isFullLegQueuing, isLegQueuing : Boolean;
	cta : CM_CraneTransferArea;
	criteriaQueues		: CM_RTQueueArray;
	criteriaHasPriority	: Boolean;
	dynaDict 			: DynaDictionary;
	criteriaFailReason	: String;
	
begin

	criteriaHasPriority := self.myTerminal.getConfig(RtQPrioritiseCriteria).Boolean;

	self.writeLoggingText("****** Getting Queue to use - Start");
	self.writeLoggingText("Source Priority Config is " &amp; self.preferSource.String);
	self.writeLoggingText("Criteria Priority Config is " &amp; criteriaHasPriority.String);
	
	if self.job &lt;&gt; null then
		self.writeLoggingText("Job: " &amp; self.job.jobId.trimBlanks &amp; " - " &amp; self.job.jobTypeId.trimBlanks &amp; " - " &amp; self.job.getJobNum.String);
	endif;
	
	if self.entry = null then
		return null;
	endif;
	
	if self.entry.myBreakBulkMaster &lt;&gt; null then  //working a break bulk sub task , always place into master task queue ccms 2274 cnwrd1
		if self.entry.myBreakBulkMaster.myQueue &lt;&gt; null then
			return self.entry.myBreakBulkMaster.myQueue;
		endif;
	endif;
	
	tmpSourceLocation := self.getSourceLocation();
	if tmpSourceLocation = null then
		tmpSourceLocation:=self.sourceLocation;
	endif;
	if tmpSourceLocation = null then
		return null;
	endif;

	self.writeLoggingText("Job Source: " &amp; tmpSourceLocation.getFullId());

	tmpTargetLocation:=self.getTargetLocation();
	if tmpTargetLocation = null then
		if self.targetLocation = null then
			if tmpTargetLocation = null  then // and self.isLastEntryForMultiDirector then 
				tmpTargetLocation:=self.getTargetLocForYardRequest;
			endif;
			if tmpTargetLocation = null then
				tmpTargetLocation := tmpSourceLocation;
			endif;
		else
			tmpTargetLocation := self.targetLocation;
		endif;
	endif;
	isFullLegQueuing:=self.myRTMoveMethodRule &lt;&gt; null and self.myRTMoveMethodRule.queuingRule = FullMoveQueuing;
	isLegQueuing:=self.myRTMoveMethodRule &lt;&gt; null and self.myRTMoveMethodRule.queuingRule = LegMoveQueuing;
	//epr par 30376 27/9/2012
	if isLegQueuing then
		prevEntry:=self.entry.getPreviousRelatedEntry();  //epr 17/2/15 par 35702 CCMS 2457
		//source is IMV should always try to go to target location q
		if prevEntry&lt;&gt; null and prevEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			tmpSourceLocation:=tmpTargetLocation;
		endif;
		iter:=self.myRTMoveMethodRule.myRTMoveMethod.allMachineTypeGroups.createIterator;
		iter.startAtIndex(self.currentMachineTypeGrpIndex);
		iter.next(machineTypeGrp);
		if not iter.next(machineTypeGrp) then
			machineTypeGrp:=null;
		endif;
		// target is IMV should always try to go to source location q
		if machineTypeGrp &lt;&gt; null and machineTypeGrp.type = MACHINETYPEGRP_IMV then
			tmpTargetLocation:=tmpSourceLocation;
		endif;
	endif;
	
	
	if tmpTargetLocation &lt;&gt; null then
		self.writeLoggingText("Job Target: " &amp; tmpTargetLocation.getFullId());
	endif;
	
	theTerminal := self.myTerminal;
	if theTerminal = null then
		self.writeLoggingText("No Terminal!");  // ### JIRA 35862 08SEP2025 NAVAB1
		return null;
	endif;
	
	masterQ := theTerminal.radioTelemetry.masterQueue;
		
	// Now using queues on self rather than creating transients every time.
	self.tmpQueues1.clear();
	self.tmpQueues2.clear();
	
	tmpQueueRef1	:= self.tmpQueues1;
	tmpQueueRef2	:= self.tmpQueues2;
		
	doCreateVoyageQueues:= not self.captureLoggingMode;  // ### JIRA 35862 08SEP2025 NAVAB1
	
	// CCMS 1309 DVB Changed 15/02/2005
	// Don't bother looking and voyage queues for rtg
	if	(self.myCurrentMachineTypeGroup &lt;&gt; null and self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_RTG)
	and (tmpSourceLocation.isKindOf(CM_VoyageController)) then
		doCreateVoyageQueues:=false;
	else			
			tmpSourceLocation.getQueues(tmpQueueRef1);
			self.writeLoggingText("Available Queues found for Source");
			foreach aQueue in tmpQueueRef1 do
				self.writeLoggingText(Tab &amp; aQueue.id);
			endforeach;
	endif;

	// Don't bother looking and voyage queues for rtg
	if	(self.myCurrentMachineTypeGroup &lt;&gt; null and self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_RTG)
	and (tmpTargetLocation.isKindOf(CM_VoyageController)) then
		doCreateVoyageQueues:=false;
	else
		
			tmpTargetLocation.getQueues(tmpQueueRef2);
			self.writeLoggingText("Available Queues found for Target");
			foreach aQueue in tmpQueueRef2 do
				self.writeLoggingText(Tab &amp; aQueue.id);
			endforeach;
	endif;
		
	// Compare both sets.
	foreach aQueue in tmpQueueRef1 do
		if not tmpQueueRef2.includes(aQueue) then
			tmpQueueRef2.add(aQueue);
		endif;
	endforeach;

	// Take out queues that aren't appropriate for our machine type.
	self.compareQueuesToType(tmpQueueRef2);
	
	//gets all queues so we get the queue in order that they are seen in the Queue form 
	create allQueues transient;					// 27/06/2011 cnwmh5 #27179
	masterQ.getAllQueues(allQueues);	
	
	create criteriaQueues transient;
	
	arbiterRef := self;

	on Exception do app.handleDeletedObject(exception,aQueue,invalidQueue);
	
	if self.ti &lt;&gt; null then
		foreach aQueue in tmpQueueRef2 do
			if not aQueue.allCriteria.isEmpty then
				criteriaQueues.add(aQueue);
			endif;
		endforeach;
		
		if criteriaHasPriority and not criteriaQueues.isEmpty then
			create dynaDict transient;
			dynaDict.setMembership(CM_RadioTelemetryQueue);
			dynaDict.addExternalKey(Real, 8, true, true);	//sort by priority
			dynaDict.endKeys(true);
			
			self.writeLoggingText("Checking Queue Criteria");
			
			foreach aQueue in criteriaQueues do
				if aQueue.doesTIMatch(self.ti, criteriaFailReason) then
					dynaDict.putAtKey(aQueue.getCriteriaPriority, aQueue);
					//jlier1 14/10/25 JIRA-36155
					self.writeLoggingText(Tab &amp; aQueue.id);
					self.writeLoggingText(Tab &amp; Tab &amp; "Cargo does match criteria with Queue Priority " &amp; aQueue.getCriteriaPriority.String);
				else
					self.writeLoggingText(Tab &amp; aQueue.id);
					self.writeLoggingText(Tab &amp; Tab &amp; "Cargo doesn't match criteria: " &amp; criteriaFailReason);
				endif;
			endforeach;
		endif;
		
		if dynaDict &lt;&gt; null and not dynaDict.isEmpty then
			delete iter;
			iter := dynaDict.createIterator;
			
			while iter.next(aQueue) do
				loggingText := "";
				if aQueue.isKindOf(CM_SubQueue) then
					if aQueue.CM_SubQueue.isUnidirectional then
					   loggingText := "UniDirectional";
					else
					   loggingText := "BiDirectional";
					endif;
				endif;
				self.writeLoggingText(Tab &amp; aQueue.id &amp; " " &amp; loggingText);
				
				if aQueue.isKindOf(CM_SubQueue) then
					self.writeLoggingText(Tab &amp; Tab &amp; "From: " &amp; aQueue.CM_SubQueue.allMoveFromTAMasters.getAreaAsString);
					self.writeLoggingText(Tab &amp; Tab &amp; "To: " &amp; aQueue.CM_SubQueue.allMoveToTAMasters.getAreaAsString);
				endif;
				
				if aQueue.status = QSTATUS_HELD then
					continue;
				endif;
				
				retQueue := aQueue;
				break;

			endwhile;
		endif;
	endif;
	
	
	if retQueue = null then
		// Available queues
		self.writeLoggingText("All RT Queues");
	
		currentMatch := 0;
		loggingText := "****** Queue Priorities";
		
		foreach aQueue in allQueues where tmpQueueRef2.includes(aQueue) do			// 27/06/2011 cnwmh5 #27179
			invalidQueue := false;
			loggingText := "";
			if aQueue.isKindOf(CM_SubQueue) then
				if aQueue.CM_SubQueue.isUnidirectional then
				   loggingText := "UniDirectional";
				else
				   loggingText := "BiDirectional";
				endif;
			endif;
			self.writeLoggingText(Tab &amp; aQueue.id &amp; " " &amp; loggingText);
			if invalidQueue then
				loggingText := "";  // ### JIRA 35862 08SEP2025 NAVAB1
				continue;
			endif;
			
			if self.ti &lt;&gt; null and not aQueue.doesTIMatch(self.ti, criteriaFailReason) then
				// queue not suitable for ti
				self.writeLoggingText(Tab &amp; Tab &amp;"Cargo doesn't match criteria: " &amp; criteriaFailReason);
				continue;
			endif;
			
			if aQueue.isKindOf(CM_SubQueue) then
				self.writeLoggingText(Tab &amp; Tab &amp; "From: " &amp; aQueue.CM_SubQueue.allMoveFromTAMasters.getAreaAsString);
				self.writeLoggingText(Tab &amp; Tab &amp; "To: " &amp; aQueue.CM_SubQueue.allMoveToTAMasters.getAreaAsString);
			endif;
			
			// par 30158 - new rules say we put all the Full move queue tasks in the crane queues.
			// PAR #25693 CCMS POL 2008 Is this job a "Full Move Queueing" job with a voyage as the target location?
			// If so, we ignore non-voyageCrane queues when checking for available queues
			// if machine rule is a "Full Move Queueing" rule
			if isFullLegQueuing and  ( CM_VoyageController.hasInstance(tmpTargetLocation) or CM_VoyageController.hasInstance(tmpSourceLocation) ) then //cnwrd1 par 30076 27.7.2012
			//epr par 34939 23/9/14
				if self.myCurrentMachineTypeGroup &lt;&gt; null and self.myCurrentMachineTypeGroup.type &lt;&gt; MACHINETYPEGRP_RTG then //if this is a RTG grp then they will never be able to match voyage crane/workpoint queues
					if self.isVoyageJob and job.myJobSheet &lt;&gt; null then //if its non planned non worked won't have
						if not (CM_VoyageCraneQueue.hasInstance(aQueue) 
							or CM_VoyageWorkPointQueue.hasInstance(aQueue)) then // PAR 34743
							loggingText := "";  // ### JIRA 35862 08SEP2025 NAVAB1
							continue;
						endif;
					endif;
				endif;
			endif;
			// PAR #25693 CCMS POL 2008 end
			
			if aQueue.status = QSTATUS_HELD then
				loggingText := "";  // ### JIRA 35862 08SEP2025 NAVAB1
				continue;
			endif;
			self.writeLoggingText("****** Get Priority for queue: " &amp; aQueue.id);
			match := aQueue.getMatchPriority(arbiterRef,tmpSourceLocation,tmpTargetLocation);
			loggingText := loggingText &amp; CrLf &amp; "Priority " &amp; match.padLeadingWith('0', 2) &amp; " for " &amp; aQueue.id;
			// PAR 24866 - it failed to match then do not use this queue
			if match = CM_RadioTelemetryQueue.Match_Fail then
				loggingText := "";  // ### JIRA 35862 08SEP2025 NAVAB1
				continue;
			endif;
			
			if (match &gt; currentMatch) or (retQueue = null and currentMatch = 0 )then
				currentMatch := match;
				retQueue := aQueue;
				// PAR #28280 If we've found a valid queue for the job, and we're Full Move Queuing, we're happy with this one. No need to keep looking
				// (as long as it's not a Voyage job - we need to keep going in this case, as we may be doing the crane job)
				if currentMatch &gt; 0 
				and not self.isGroundedImportNoDischargeJob() // PAR 35091
				and not CM_VoyageController.hasInstance(tmpTargetLocation) 
				and not tmpSourceLocation.isVoyageController then  // cnwrd1 par 29349 2.4.2012 we only want to do this bit if we are an EXPORT rather than an import otherwise we place the first discharge job in the voyage queue not the crane queue
					if isFullLegQueuing then
						self.writeLoggingText("Move method rule is Full Move Queuing - using first queue found: " &amp; retQueue.id);
						break;
					endif;
				endif;
				// PAR #28280 end
			endif;
			
		endforeach;
		self.writeLoggingText(loggingText);
	endif;
	
	if retQueue = null then
		retQueue := masterQ;
		self.writeLoggingText("Queue not found setting to Master Queue");
	endif;

	//epr 11/8/11 CCMS 1033 refactored code block into own method
	if doCreateVoyageQueues then
		self.createVoyageQueues(job,retQueue);
	endif;
	if retQueue = null then
		retQueue := masterQ;
		self.writeLoggingText("Queue not found setting to Master Queue: " &amp; retQueue.id);
	endif;

	if retQueue = null then
		loggingText := "No queue found";
	else
		loggingText := retQueue.id;
	endif;
	return retQueue;
	
epilog
	delete iter;
	delete allQueues;
	delete criteriaQueues;
	delete dynaDict;
	self.writeLoggingText("****** Queue to use: " &amp; loggingText);
end;</source>
        <ReturnType type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocation" id="429aa667-5dff-4716-bbe9-df4cc299f3f5">
        <updating/>
        <source>getSourceLocation(): CM_LocationsController protected, updating;
//08 October 2010	cnwdw1	
// 29/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so can be written to logging form
// 30/08/2011	cnwdap1		PAR #25693 CCMS POL 2008 When dealing with a "Full Move Queueing" job,
//							use the WLE source instead of the task source
 // ### JIRA 35862 08SEP2025 NAVAB1 - added 'updating'
vars

begin
	// PAR #25693 Full Move Queueing - use WLE source
	if self.myRTMoveMethodRule &lt;&gt; null and self.myRTMoveMethodRule.queuingRule = FullMoveQueuing then
	    self.writeLoggingText("The WLE source will be used");
		return self.entry.getSourceLocation();
	endif;
	// PAR #25693 end
	
	//17/02/2011 cnwdz2 par27041
	if self.entry.allTasks.size() &gt; 0 then	
		return self.entry.allTasks.first.sourceLocation;
	else
		return null;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocForYardRequest" id="9f3cc105-8f8a-4b41-bfe3-b31786be5ec8">
        <source>getTargetLocForYardRequest() : CM_LocationsController protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwer1	Initial creation

*/

vars
	yardRequest : CM_YardRequest;
begin
	if self.wle = null or self.wle.myRequest = null then
		return null;
	endif;
	
	if not self.wle.myRequest.isKindOf(CM_YardRequest) then
		return null;
	endif;
	yardRequest:=self.wle.myRequest.CM_YardRequest;
	if yardRequest.myTargetTA = null then
		return null;
	endif;
	
	
	return yardRequest.myTargetTA.allLocationsControllers.first;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="ff86b227-2188-48bd-895d-2f48a96e49ac">
        <updating/>
        <source>getTargetLocation(): CM_LocationsController protected, updating;
//08 October 2010	cnwdw1	
// 29/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so can be sent to logging form
// 30/08/2011	cnwdap1		PAR #25693 CCMS POL 2008 When dealing with a "Full Move Queueing" job,
//							use the WLE target instead of the task target
 // ### JIRA 35862 08SEP2025 NAVAB1 - added 'updating'
vars

begin
	// PAR #25693 Full Move Queueing - use WLE target
	if self.myRTMoveMethodRule &lt;&gt; null and self.myRTMoveMethodRule.queuingRule = FullMoveQueuing then
   	    self.writeLoggingText("The WLE target will be used");
		return self.entry.getTargetLocation();
	endif;
	// PAR #25693 end
	
	//11/04/2011 cnwdz2 par27369
	if self.entry.allTasks.size() &gt; 0 then	
		return self.entry.allTasks.last.targetLocation;
	else
		return null;
	endif;
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="isForDirectorTask" id="23017583-0048-4ace-9b24-0bc28f199f28">
        <source>isForDirectorTask() : Boolean;
/*

Date		Who		Reason
21 August 2014	cnwer1	Initial creation CCMS 1391 VMT warehouse app

*/

vars

begin
	if self.myPreviousRTQueueEntry = null and
	   self.ti &lt;&gt; null and
	   self.entry &lt;&gt; null and
	   self.entry.allTasks.size = 1 and
	   self.entry.allTasks.first.taskType = TASK_DIRECTOR then
	   return true;
	 endif;
	 
	 return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isGroundedImportNoDischargeJob" id="95679800-a60b-4ffa-a298-454024db86dc">
        <source>isGroundedImportNoDischargeJob() : Boolean;
/*
Purpose:			
Date				Who		Reason
04 November 2014	cnwab1	Initial creation
06 November 2025	jlizm1	MTN 36328 Rotabox Assign Release To Vessel
*/

vars
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
begin
	ti := self.ti;
	if ti &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; null 
	and (ti.myPrimaryActualLocation.isCraneLaneController() or ti.myPrimaryActualLocation.isWorkPointLaneController()) then
		wle := ti.getVoyageWLEUnactionedNonRORO(false);
		
		if wle = null then
			if not ti.isExport then
				return true;
			endif;
		endif;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageJob" id="edfec8b9-195b-43b0-9055-6043c41f4547">
        <source>isVoyageJob(): Boolean;
//02 July 2010	cnwdw1	
// Return true if the job being queued is a voyage job
begin
	return job &lt;&gt; null and (job.isVoyageTypeJob()); // TFS TFS 4859
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYardJob" id="5e79d3bb-4a1a-4bb0-b2e3-2dff05d681c2">
        <source>isYardJob(): Boolean;
//02 July 2010	cnwdw1	
// Return true if the job being queued is a yard job
begin
	return job &lt;&gt; null and job.isYardInternalJob;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYardQueueAllowed" id="295033bc-d16c-4988-9e0d-ffffdc38905e">
        <source>isYardQueueAllowed(_fromLocation, _toLocation : CM_LocationsController) : Boolean;

/* If an IMV is available then we will be using this in the voyage queue so yard queues are allowed */
vars
	checkForSourceVoyage,
	checkForTargetVoyage: Boolean;
begin

	//epr par 22815 9/3/2010  if there is not move method then always check to see if it should use the voyage queue
	if self.myRTMoveMethod = null then
		checkForSourceVoyage:=true;
		checkForTargetVoyage:=true;
	else
		//only check voyage queue for source if the first move is a IMV or STRADDLE or FORK LIFT
		if self.currentMachineTypeGrpIndex = 1 and
			(self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_IMV or 
				self.myCurrentMachineTypeGroup.type =MACHINETYPEGRP_STRADDLE or
				self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_LIFTER	) then
				checkForSourceVoyage:=true;
		endif;
		//only check voyage queue for target if the last move is a IMV or STRADDLE or FORK LIFT
		if self.currentMachineTypeGrpIndex = self.myRTMoveMethod.allMachineTypeGroups.size and
			(self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_IMV or 
				self.myCurrentMachineTypeGroup.type =MACHINETYPEGRP_STRADDLE or
				self.myCurrentMachineTypeGroup.type = MACHINETYPEGRP_LIFTER ) then
				checkForTargetVoyage:=true;
		endif;
	endif;
	
	if checkForSourceVoyage then
		if (_fromLocation &lt;&gt; null and _fromLocation.isKindOf(CM_VoyageController)) then //epr par34939 23/9/14 
			return false;
		endif;
		
		if (_fromLocation &lt;&gt; null and (_fromLocation.isCraneLaneController or _fromLocation.isWorkPointLaneController)) then // PAR 35091
			if  self.isGroundedImportNoDischargeJob() then // PAR 35091
	
				return false;
			endif;
		endif;
	endif;
	
	if checkForTargetVoyage then
		if (_toLocation &lt;&gt; null and 
			(_toLocation.isKindOf(CM_VoyageController) or //epr par34939 23/9/14
			_toLocation.isKindOf(CM_CraneLaneController) 
			 or ( _toLocation.isKindOf(CM_YardICAreaLaneController) and not _toLocation.isYardLocation) //cnwrd1 ccms 1303 30842 if we are queued to a wp interchange!
			)) then //+cnwml2 PAR24268
			return false;
		endif;
	endif;
	
	return true;
end;
</source>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveEntryBasedOnToLocation" id="8804244d-267c-4fa9-90dd-32d4bd21aa4f">
        <updating/>
        <source>moveEntryBasedOnToLocation(_entry : CM_RTQueueEntry input; _terminal : CM_Terminal) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
27/06/2011	cnwmh5	#27179 - Change so that uses the queues in the order they are on the RT Queues screen
29/08/2011	cnwdap1	PAR #28280 Correct queue analysis for Full Move Queuing
04/12/2012	cnwer1  PAR 30385 - needed to handle release by type, also refactored to use getQueues method
*/

vars
	retQueue			: CM_RadioTelemetryQueue;
begin
	
	self.setMyTerminal(_terminal);
	
	// Get current machine group for screening.
	self.myCurrentMachineTypeGroup := app.myRoot.allMachineTypeGroups[_entry.machineTypeGroup];
	self.myRTMoveMethodRule:=_entry.myRTMoveMethodRule;
	if self.myRTMoveMethodRule &lt;&gt; null then
		self.myRTMoveMethod:=self.myRTMoveMethodRule.myRTMoveMethod;
	endif;
	// Wle will tell us pretty much all we need to know about this move.
	self.entry:=_entry;
	self.wle := _entry.myWorkListEntry;
	
	if wle = null then 
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Missing expected reference', null, null);
		return;
	endif;
	self.job:=wle.job;

	//epr par 30835 4/12/12
	retQueue:=self.getQueue();
		
	// We have a new queue so reset the queue entries queue.
	if retQueue &lt;&gt; null and retQueue &lt;&gt; _entry.myQueue then 
		//th2 added 23/01/07 deadlock 1081 @ CM_RadioTelemetryQueue::addQueueEntry(958)
		exclusiveLock(retQueue);
		retQueue.addQueueEntry(_entry);
	endif;

	// Tell the system about it.
	if _terminal &lt;&gt; null then
		//epr TFS 2684 21/9/16
		//the new queue entry note is the one the ITS is looking for so always raise this note - problem was when the queue didn't change this 
		// note wasn't raised and now the queue entry was available for the machine because the truck has moved in to the yard
		app.myEventManager.createSingleObjInfoNoteEvt(_entry.myQueue, _terminal.getTerminalEvent(Event_New_Queue_Entry),entry); 
		app.myEventManager.createSingleObjInfoNoteEvt(_entry, _terminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
	endif;

	 	//epr 21/4/10 CCMS 1099 need to know when target source changes for related entries
	_entry.sendNotesForRelatedEntry();
	
epilog

end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processMachineMoves" id="45a8bbf6-c9d6-40ae-9ce3-343d6cfa7e0e">
        <updating/>
        <source>processMachineMoves() updating;

// Created by cnwdvb1 on 14 August 2006
// 29/06/2011	cnwmh5	#27179 - Change to use writeLoggingText so can also appear in logging form
vars
	singleMovesOnly	: Boolean;
begin

	self.writeLoggingText('processMachineMoves: Get machine rule');

	// RE initialize the arbiter references.
	
	self.myPreviousRTQueueEntry		:= null;
	self.allRTQueueEntries.clear();

	if self.myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal is null', null, null);
		return;
	endif;
	
	//04 Sep 2014	NDL	Par 34717 - Knoble multi move for break-bulk. (Discussed with Doug)
	singleMovesOnly := false;
	if self.wle.myTrackedItem = null then
		if wle.myRequest.isBreakBulkReleaseByType() or wle.myRequest.isBulkMultiReleaseByType() then
			singleMovesOnly:=true;
		endif;
	elseif self.wle.myTrackedItem &lt;&gt; null and self.wle.myTrackedItem.myCargoType.allowDuplicates then
		//epr 17/2/15 par 35702 CCMS 2457
		singleMovesOnly:=self.myBulkReleaseMaster &lt;&gt; null;
	
	endif;
	
	if self.useMachineRules and not singleMovesOnly then									//+cnwml2 PAR24268
		//epr 17/3/15 refactored code block into method below
		self.determineMoveMethodRule();
	endif;
	self.myCurrentMachineTypeGroup	:= null;
	//epr par 35702 3/3/15 CCMS 2457
	if singleMovesOnly and self.myBulkReleaseMaster &lt;&gt; null then
		self.sourceLocation:=self.myBulkReleaseMaster.allTasks.first.sourceLocation;
		self.targetLocation:=self.myBulkReleaseMaster.allTasks.first.targetLocation;
		self.myRTMoveMethodRule:=self.myBulkReleaseMaster.myRTMoveMethodRule;
		self.myCurrentMachineTypeGroup:=app.myRoot.allMachineTypeGroups[self.myBulkReleaseMaster.machineTypeGroup];
		self.currentMachineTypeGrpIndex:=wle.allRTQueueEntries.indexOf(self.myBulkReleaseMaster);
	endif;
	
	// Evalute our move method.
	if self.myRTMoveMethod &lt;&gt; null then
		self.writeLoggingText('processMachineMoves: Using move method ' &amp; self.myRTMoveMethod.getName());
		self.myRTMoveMethod.buildQueueEntries(self);
	else
		self.writeLoggingText('processMachineMoves: No move method ');
		self.buildQueueEntryMaster();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="requeueWMMReturnShipToYard" id="4d75afc5-d8d0-481c-a6ec-94d507f9b21f">
        <updating/>
        <source>requeueWMMReturnShipToYard(	_wle : CM_WorkListEntry;						 
						_newTargetLocation : CM_LocationsController;
						_newMoveMethodRule 	: CM_RTMoveMethodRule ) updating;

/*

Purpose:	par 29286 cnwrd1 		

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2012	cnwrd1	Initial creation

*/

vars
	rtQueueEntry 	: CM_RTQueueEntry;
	rtQueueTask	, firstTask	: CM_RTQueueTask;
	iterMachineGrps,
	iterRTQueueEntries		:  Iterator;
	machineTypeGrp	: CM_MachineTypeGroup;
	allRTQueueEntriesToDelete : CM_RTQueueEntrySet;
	tmpPreferSource	, needToAdjustExistingEntry,
	adjustedLastTarget, foundRTQueueEntry: Boolean;
	machine			: CM_Machine;
	targetLC		 : CM_LocationsController;
	targetMachineTypeGrp : Integer;
begin
	self.reset;
	self.wle:=_wle;
	self.job:=_wle.job;
	self.setMyTerminal( _wle.getMyTerminal);
	self.ti:=_wle.myTrackedItem;
	self.myRTMoveMethodRule:=_newMoveMethodRule;
	if self.myRTMoveMethodRule &lt;&gt; null then
		self.myRTMoveMethod:=self.myRTMoveMethodRule.myRTMoveMethod;
	endif;
	_wle.getLastGroundedLocation(machine,self.sourceLocation);
	self.targetLocation:=_newTargetLocation;
	
	create allRTQueueEntriesToDelete transient;
	
	if self.myRTMoveMethod = null then	
		foreach rtQueueEntry in _wle.allRTQueueEntries do
			if rtQueueEntry.status &lt;&gt; ENTRY_WORKING
			and rtQueueEntry.status &lt;&gt; ENTRY_USER_HELD
			and rtQueueEntry.status &lt;&gt; ENTRY_SYSTEM_HELD	//22 Apr 2015	NDL	Par 36014
			then
				allRTQueueEntriesToDelete.add(rtQueueEntry);
			else
				rtQueueTask:=rtQueueEntry.allTasks.last;
		
			endif;
		endforeach;
		//_wle.allRTQueueEntries.copy(allRTQueueEntriesToDelete);
		allRTQueueEntriesToDelete.purge;
		
		// if we are on an IMV we need another leg
		
		//if we are another tyle and cant access the location we need another leg
		
		//else we can set the new target location
		
		if machine &lt;&gt; null and machine.isIMV then
			self.myPreviousRTQueueEntry	:= rtQueueTask.myEntry;
			self.sourceLocation := machine.myMachineController;
			rtQueueTask.targetLocation := self.targetLocation;
			self.buildQueueEntryMaster();
			rtQueueTask.myEntry.sendNotesForRelatedEntry();
			
		elseif machine &lt;&gt; null  and not machine.canMachineAccessTAObj(_newTargetLocation.getParentForMachine(machine).CM_TerminalAreaMaster, true) then
			self.myPreviousRTQueueEntry	:= rtQueueTask.myEntry;
			self.sourceLocation := machine.myMachineController;
			self.buildQueueEntryMaster();
			rtQueueTask.myEntry.sendNotesForRelatedEntry();
		elseif rtQueueTask &lt;&gt; null then
			rtQueueTask.setTargetLocation(_newTargetLocation);	
			rtQueueTask.myEntry.sendNotesForRelatedEntry();
		else
			self.buildQueueEntryMaster();
		endif;
		return;
	endif;
	
	if machine = null then
		firstTask:=_wle.allRTQueueEntries.first.allTasks.first;
		if firstTask.status &lt;&gt; TASK_COMPLETE then
			machine:=firstTask.machine;
		endif;
	endif;
	
	self.myRTMoveMethod.getInvalidWLEEntriesToDelete(_wle,machine,self.sourceLocation,allRTQueueEntriesToDelete);
	
	//before we do this if any are accepted/offered we need to raise an exception
	foreach rtQueueEntry in allRTQueueEntriesToDelete discreteLock do	
		foreach rtQueueTask in rtQueueEntry.allTasks discreteLock where rtQueueTask.status &lt;&gt; TASK_COMPLETE  do
			if rtQueueTask.machine &lt;&gt; null then
				app.raiseCMException1(Requeue_delete_working_task,rtQueueTask.machine.id,null,null);
				return;
			
			endif;		
		endforeach;	
	endforeach;
	allRTQueueEntriesToDelete.purge;
	
	
	
	iterMachineGrps:=self.myRTMoveMethod.allMachineTypeGroups.createIterator;
	iterRTQueueEntries:=self.wle.allRTQueueEntries.createIterator;
	needToAdjustExistingEntry:=self.wle.allRTQueueEntries.first &lt;&gt; null;
	self.isTargetMove := false;
	self.currentMachineTypeGrpIndex:=0;
	//while iterRTQueueEntries.next(machineTypeGrp) do
		
	tmpPreferSource := self.preferSource;
	adjustedLastTarget:=false;
	while iterMachineGrps.next(machineTypeGrp) do
		
		// The count here makes sure that if there are three parts to the move then
		// the final move is the opposite to the first when it comes to prefer source.
		// This forces the correct queue to be selected.
		
		self.myCurrentMachineTypeGroup := machineTypeGrp;
		foundRTQueueEntry:= iterRTQueueEntries.next(rtQueueEntry);
		
		if not foundRTQueueEntry then
			//need to adjust the tasks target Locations the first time we get here i the loop
			if needToAdjustExistingEntry and not  adjustedLastTarget then
				self.myRTMoveMethodRule.getTaskDetails(self,machineTypeGrp,false,targetLC,targetMachineTypeGrp);
				
				if self.myPreviousRTQueueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
					// get the imv task
					rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_MOVE,NULL_INTEGER);
					rtQueueTask.setTargetLocation(targetLC);	
				else
					//get the setdown task
					rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
					rtQueueTask.setTargetLocation(targetLC);	
					rtQueueTask.machineTypeGroup:=targetMachineTypeGrp;	
				endif;
				
				adjustedLastTarget:=true;
			endif;	
		endif;
		
		self.currentMachineTypeGrpIndex:=self.currentMachineTypeGrpIndex+1;
		if self.currentMachineTypeGrpIndex = self.myRTMoveMethod.allMachineTypeGroups.size  and machineTypeGrp.type &lt;&gt; MACHINETYPEGRP_IMV then
			self.preferSource := not self.preferSource;
		endif;
		if machineTypeGrp.type = MACHINETYPEGRP_SOURCEIC or
			machineTypeGrp.type = MACHINETYPEGRP_TARGETIC or	
			machineTypeGrp.type = MACHINETYPEGRP_MAFI  then //jlier1 TFS 54701 19/9/22
				continue;
		endif;
			
		if not foundRTQueueEntry then
			self.buildQueueEntryMaster();
		else
			self.entry:=rtQueueEntry;
			self.allRTQueueEntries.add(self.entry);
			self.entry.setMyRTMoveMethodRule(self.myRTMoveMethodRule);
			self.myPreviousRTQueueEntry	:= self.entry;
		endif;
		
	endwhile;
	
	// there is one entry left and it was not deleted and recreated we need to update the last entry
	// self.myPreviousEntry is always the last updated
	if needToAdjustExistingEntry and not  adjustedLastTarget then
		self.myRTMoveMethodRule.getTaskDetails(self,self.myCurrentMachineTypeGroup,false,targetLC,targetMachineTypeGrp);
		//get the setdown task
		rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
		if self.myPreviousRTQueueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// get the imv task
			rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_MOVE,NULL_INTEGER);
			rtQueueTask.setTargetLocation(targetLC);	
		else
			//get the setdown task
			rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
			rtQueueTask.setTargetLocation(targetLC);	
			rtQueueTask.machineTypeGroup:=targetMachineTypeGrp;	
		endif;		
	elseif  needToAdjustExistingEntry then  //cnwrd1 par 27996 22.8.2011
		if self.entry.myPreviousRelatedEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// previous task could be a working IMV task and this will need a note to update the machine.
			//need to send a note for this.
			self.entry.sendNotesForRelatedEntry();
		endif;
	endif;
	
	
	
epilog
	delete iterMachineGrps;
	delete iterRTQueueEntries;
	delete allRTQueueEntriesToDelete;
	self.preferSource:=tmpPreferSource;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_newTargetLocation" type="CM_LocationsController"/>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="requeueWithMoveMethod" id="961c7d07-d435-4c6f-8172-e4d68cdd208b">
        <updating/>
        <source>requeueWithMoveMethod(	_wle : CM_WorkListEntry;
						 
						_newTargetLocation : CM_LocationsController;
						_newMoveMethodRule 	: CM_RTMoveMethodRule ) updating;
/*

Purpose:		will requeue the wles	rtQueueEntries. it will delete any entries not in the 
				passed in wles to keep collection
				
				create the new entries based on the new move method and target location, this will be a
				multi machine move so will be linking those rt queue entries with the kept entries.

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2011	cnwer1	Initial creation

*/

vars
	rtQueueEntry 	: CM_RTQueueEntry;
	rtQueueTask	, firstTask	: CM_RTQueueTask;
	iterMachineGrps,
	iterRTQueueEntries		:  Iterator;
	machineTypeGrp	: CM_MachineTypeGroup;
	allRTQueueEntriesToDelete : CM_RTQueueEntrySet;
	tmpPreferSource	, needToAdjustExistingEntry,
	adjustedLastTarget, foundRTQueueEntry: Boolean;
	machine			: CM_Machine;
	targetLC		 : CM_LocationsController;
	targetMachineTypeGrp : Integer;
begin
	self.reset;
	self.wle:=_wle;
	self.job:=_wle.job;
	self.setMyTerminal( _wle.getMyTerminal);
	self.ti:=_wle.myTrackedItem;
	self.myRTMoveMethodRule:=_newMoveMethodRule;
	if self.myRTMoveMethodRule &lt;&gt; null then
		self.myRTMoveMethod:=self.myRTMoveMethodRule.myRTMoveMethod;
	endif;
	_wle.getLastGroundedLocation(machine,self.sourceLocation);
	self.targetLocation:=_newTargetLocation;
	
	create allRTQueueEntriesToDelete transient;
	
	if self.myRTMoveMethod = null then	
		_wle.allRTQueueEntries.copy(allRTQueueEntriesToDelete);
		allRTQueueEntriesToDelete.purge;
		self.buildQueueEntryMaster();
		return;
	endif;
	
	if machine = null then
		firstTask:=_wle.allRTQueueEntries.first.allTasks.first;
		if firstTask.status &lt;&gt; TASK_COMPLETE then
			machine:=firstTask.machine;
		endif;
	endif;
	
	self.myRTMoveMethod.getInvalidWLEEntriesToDelete(_wle,machine,self.sourceLocation,allRTQueueEntriesToDelete);
	
	//before we do this if any are accepted/offered we need to raise an exception
	foreach rtQueueEntry in allRTQueueEntriesToDelete discreteLock do	
		foreach rtQueueTask in rtQueueEntry.allTasks discreteLock where rtQueueTask.status &lt;&gt; TASK_COMPLETE  do
			if rtQueueTask.machine &lt;&gt; null then
				app.raiseCMException1(Requeue_delete_working_task,rtQueueTask.machine.id,null,null);
				return;
			
			endif;		
		endforeach;	
	endforeach;
	allRTQueueEntriesToDelete.purge;
	
	
	
	iterMachineGrps:=self.myRTMoveMethod.allMachineTypeGroups.createIterator;
	iterRTQueueEntries:=self.wle.allRTQueueEntries.createIterator;
	needToAdjustExistingEntry:=self.wle.allRTQueueEntries.first &lt;&gt; null;
	self.isTargetMove := false;
	self.currentMachineTypeGrpIndex:=0;
	//while iterRTQueueEntries.next(machineTypeGrp) do
		
	tmpPreferSource := self.preferSource;
	adjustedLastTarget:=false;
	while iterMachineGrps.next(machineTypeGrp) do
		
		// The count here makes sure that if there are three parts to the move then
		// the final move is the opposite to the first when it comes to prefer source.
		// This forces the correct queue to be selected.
		
		self.myCurrentMachineTypeGroup := machineTypeGrp;
		foundRTQueueEntry:= iterRTQueueEntries.next(rtQueueEntry);
		
		if not foundRTQueueEntry then
			//need to adjust the tasks target Locations the first time we get here i the loop
			if needToAdjustExistingEntry and not  adjustedLastTarget then
				self.myRTMoveMethodRule.getTaskDetails(self,machineTypeGrp,false,targetLC,targetMachineTypeGrp);
				
				if self.myPreviousRTQueueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
					// get the imv task
					rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_MOVE,NULL_INTEGER);
					rtQueueTask.setTargetLocation(targetLC);	
				else
					//get the setdown task
					rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
					rtQueueTask.setTargetLocation(targetLC);	
					rtQueueTask.machineTypeGroup:=targetMachineTypeGrp;	
				endif;
				
				adjustedLastTarget:=true;
			endif;	
		endif;
		
		self.currentMachineTypeGrpIndex:=self.currentMachineTypeGrpIndex+1;
		if self.currentMachineTypeGrpIndex = self.myRTMoveMethod.allMachineTypeGroups.size  and machineTypeGrp.type &lt;&gt; MACHINETYPEGRP_IMV then
			self.preferSource := not self.preferSource;
		endif;
		if machineTypeGrp.type = MACHINETYPEGRP_SOURCEIC or
			machineTypeGrp.type = MACHINETYPEGRP_TARGETIC or	
			machineTypeGrp.type = MACHINETYPEGRP_MAFI  then //jlier1 TFS 54701 19/9/22
				continue;
		endif;
			
		if not foundRTQueueEntry then
			self.buildQueueEntryMaster();
		else
			self.entry:=rtQueueEntry;
			self.allRTQueueEntries.add(self.entry);
			self.entry.setMyRTMoveMethodRule(self.myRTMoveMethodRule);
			self.myPreviousRTQueueEntry	:= self.entry;
		endif;
		
	endwhile;
	
	// there is one entry left and it was not deleted and recreated we need to update the last entry
	// self.myPreviousEntry is always the last updated
	if needToAdjustExistingEntry and not  adjustedLastTarget then
		self.myRTMoveMethodRule.getTaskDetails(self,self.myCurrentMachineTypeGroup,false,targetLC,targetMachineTypeGrp);
		//get the setdown task
		rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
		if self.myPreviousRTQueueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// get the imv task
			rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_MOVE,NULL_INTEGER);
			rtQueueTask.setTargetLocation(targetLC);	
		else
			//get the setdown task
			rtQueueTask:=self.myPreviousRTQueueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
			rtQueueTask.setTargetLocation(targetLC);	
			rtQueueTask.machineTypeGroup:=targetMachineTypeGrp;	
		endif;		
	elseif  needToAdjustExistingEntry then  //cnwrd1 par 27996 22.8.2011
		if self.entry.myPreviousRelatedEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// previous task could be a working IMV task and this will need a note to update the machine.
			//need to send a note for this.
			self.entry.sendNotesForRelatedEntry();
		endif;
	endif;
	
	
	
epilog
	delete iterMachineGrps;
	delete iterRTQueueEntries;
	delete allRTQueueEntriesToDelete;
	self.preferSource:=tmpPreferSource;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_newTargetLocation" type="CM_LocationsController"/>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="reset" id="c226b87f-c4f8-44c9-83a9-2d1d0d167309">
        <updating/>
        <source>reset() updating;

// Created by cnwdvb1 on 22 March 2007

vars


	
begin
	self.preferSource		:= false;
	self.useMachineRules	:= false;


	self.allRTQueueEntries.clear();
	self.isMultiQueueEntry			:= false;
	self.entry 						:= null;
	self.ignoreExtraChecks			:= false;
	self.isDoorTurnaround			:= false;
	self.isOverStowMove				:= false;
	self.isTargetMove				:= false;
	self.job						:= null;
	self.myCurrentMachineTypeGroup	:= null;
	self.currentMachineTypeGrpIndex :=0;
	self.myPreviousRTQueueEntry		:= null;
	self.myRTMoveMethod				:= null;
	self.myRTMoveMethodRule			:= null;
	self.myRule						:= null;
	self.myTerminal					:= null;
//	self.preferSource				:= false;
	self.queue						:= null;
	self.queueType					:= 0;
	self.sourceLocation				:= null;
	self.targetLocation				:= null;
	self.ti							:= null;
	self.tmpQueues1.clear();
	self.tmpQueues2.clear();
//	self.useMachineRules			:= false;
	self.wle						:= null;
	self.isDriverInitiatedMove		:=false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForQueueAssignmentQuery" id="5742023b-b8be-40bb-96a5-448bbcda5463">
        <updating/>
        <source>setForQueueAssignmentQuery(_entry : CM_RTQueueEntry) updating;
/*
Purpose:	

Date				Who		Reason
08 September 2025	navab1	JIRA 35862
02 October 2025		jlizm1	MTN 35861 RTQueue configuration - cargo attribute criteria
*/

vars

begin
	if _entry = null then
		self.captureLoggingMode :=false;
		return;
	endif;
	
	self.entry := _entry;
	self.captureLoggingMode := true;
	self.myTerminal := _entry.getMyTerminal();
	
	//jlier1 14/10/25 JIRA-36155
	if _entry.myWorkListEntry &lt;&gt; null and _entry.myWorkListEntry.myTrackedItem &lt;&gt; null then
		self.ti := _entry.myWorkListEntry.myTrackedItem;
		self.job:=_entry.myWorkListEntry.job;
	endif;
	
epilog

end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6f470427-a770-4682-bd84-8cadcbd1bfd6">
        <updating/>
        <source>setForUpdate(_ti : CM_TrackedItem; _job : CM_Job; _sourceLocation, _targetLocation : CM_LocationsController; _queue : CM_RadioTelemetryQueue;
				 _wle : CM_WorkListEntry; _terminal : CM_Terminal) updating;
/*
 ------------------------------------------------------------------------
Created:			27 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	self.ti := _ti;
	self.job := _job;
	self.sourceLocation := _sourceLocation;
	self.targetLocation := _targetLocation;
	self.queue := _queue;	
	self.wle := _wle;
	self.setMyTerminal( _terminal);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyRTMoveMethodRule" id="6838c2f5-3c2f-4757-92d9-9d88bcc13baa">
        <updating/>
        <source>setMyRTMoveMethodRule(_value : CM_RTMoveMethodRule) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars

begin
	self.myRTMoveMethodRule:=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="065e8f20-1f44-4e6b-b929-36cb6913474a">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTerminal:=_terminal;
	
	if _terminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal is null', null, null);
		return;
	endif;
	
	self.preferSource		:= self.myTerminal.getConfig(RtQueuePriorityFromOverTo).Boolean;
	self.useMachineRules	:= self.myTerminal.getConfig(GateAllowDualGate).Boolean;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="sortForOverstowTasks" id="fd0caab8-d73a-4b30-b1e4-77cb003a3037">
        <updating/>
        <source>sortForOverstowTasks() updating;
//We must make sure that the overstow tasks are now FIRST.
//in descending order from the top of the stack.
//Find the topti etc until we get to arbiter.ti (original box)
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	entries : CM_ObjectArray;
	tasks : CM_ObjectArray;
	newEntries : CM_ObjectArray;
	tmpEntries : CM_ObjectArray;
	anEntry	:	CM_RTQueueEntry;
	task	:	CM_RTQueueTask;
	aTI	:	CM_TrackedItem;
	lastTI : CM_TrackedItem;
	obj	:	Object;
	objTask	:	Object;
	tisInStack	: CM_TIArray;
	tiIndex : Integer;
begin
	if self.entry.allTasks.size &lt;= 2 then
		//--------------
		//Only 1 or 2 tasks here, probably pickup/setdown. Quit now
		//--------------
		return;
	endif;
	foreach task in entry.allTasks do
		if not task.sourceLocation.getParent.isKindOf(CM_GridArea) then
			return;
		endif;
	endforeach;

	tisInStack := task.sourceLocation.allTrackedItems;

	create entries transient;
	foreach task in entry.allTasks do
		if task.taskType = TASK_PICKUP then
			create tasks transient;
			aTI := task.ti;
		endif;
		tasks.add(task);
		if task.taskType = TASK_SETDOWN then
			if task.ti = aTI then
				//Add the "complete" tasks coll the entries coll.
				entries.add(tasks);			
			endif;
		endif;
	endforeach;
	//-------------
	//OK, we now have an array of entries, with the pickup &amp; set down tasks paired
	//for a TI, we now have to sort them by the topmost TI to the ground
	//-------------
	create newEntries;
	foreach objTask in entries do
		foreach obj in tasks do
			task := obj.CM_RTQueueTask;
			if task.taskType &lt;&gt; TASK_PICKUP then
				continue;
			endif;
			//--------------
			//Where is this TI in the array in the location controller?
			//--------------
			tiIndex := tisInStack.indexOf(task.ti);
			if tiIndex = 0 then
				//PANIC! Not there....
			endif;			
			newEntries.insert(tiIndex, objTask);
		endforeach;
	endforeach;
	//----------------
	//Now, the newEntries collection is in the bottom to top order
	//flip it over to get top to bottom..
	//----------------
	create tmpEntries;
	foreach objTask in newEntries reversed do
		tmpEntries.add(objTask);
	endforeach;

	foreach task in self.entry.allTasks do
		task.setMyEntry(null);
	endforeach;
	foreach obj in tmpEntries do
		task := obj.CM_RTQueueTask;
		task.setMyEntry(entry);
	endforeach;

epilog
	delete entries;
	delete tasks;
	delete newEntries;
	delete tmpEntries;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForHeldStatusDirectUpd" id="439ac858-b4a0-491c-ad9a-737b69d79435">
        <updating/>
        <source>validateForHeldStatusDirectUpd( _rtQueueTask : CM_RTQueueTask ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 March 2011	cnwndl1	Initial creation	Par 27156	/ CCMS 2030

*/

vars

begin
	// Validation to check whether or not there is any reason we shouldn't let the user
	// assign the held task directly to a machine.
	//
	// Set up the arbiter from the data on the RT Queue task.
	// If any of the data is missing we can't do the validation, but it is not a failure.

	if _rtQueueTask = null then
		return;
	endif;
	
	if _rtQueueTask.ti = null then
		return;
	else
		self.ti := _rtQueueTask.ti;
	endif;
	
	if _rtQueueTask.sourceLocation = null then
		return;
	else
		self.sourceLocation := _rtQueueTask.sourceLocation;
	endif;
	
	if _rtQueueTask.targetLocation = null then
		return;
	else
		self.targetLocation := _rtQueueTask.targetLocation;
	endif;
	
	if _rtQueueTask.myEntry = null then
		return;
	else
		self.entry := _rtQueueTask.myEntry;
	endif;
	
	if _rtQueueTask.myEntry.myWorkListEntry = null then
		return;
	else
		self.wle := _rtQueueTask.myEntry.myWorkListEntry;
	endif;
	
	if _rtQueueTask.myEntry.myQueue = null then
		return;
	else
		self.queue := _rtQueueTask.myEntry.myQueue;
	endif;
	
	if _rtQueueTask.myEntry.myJob = null then
		return;
	else
		self.job := _rtQueueTask.myEntry.myJob;
	endif;
	

	self.validateQueueEntry();


epilog

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="validateQueueEntry" id="ce696a67-7c5f-4673-bff1-c086aaa3d77a">
        <source>validateQueueEntry() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwer1	Initial creation
15 July 2010		cnwdap1	PAR #25021 review use of isImport/isExport for tranships
09 December 2014	cnwdap1	PAR #35081 New parameter for CM_TrackedItem isSuitableToRelease method
*/

vars
	tiID 		: String;
	container 	: CM_Container;
	yardRequest : CM_YardRequest;
	toArea 		: CM_Object;
	errorArray 	: IntegerArray;
	isRelease	: Boolean;
	idx 		: Integer;
	alert : CM_SystemAlert;
	aMsg : String;
	machine 	: CM_Machine;
	workzoneCover : Boolean;
	atask 		: CM_RTQueueTask;
	reason : String;
	task : CM_RTQueueTask;
begin
	if self.ignoreExtraChecks then
		return;
	endif;
	
	if self.ti = null then
		return;
	endif;
	if self.entry = null then
		return;
	endif;
	if self.job = null then
		return;
	endif;

	tiID:=self.ti.id;
	if self.job.hasStopThatPreventsRTQueuing(self.ti) then
		app.myPassport.createAlert(SEVERE_WARNING, 
						tiID &amp; " Queue Entry set to HELD: " &amp; tiID &amp; " HAS STOPS.",
						null,
						self.entry);
		self.entry.setEntryStatus(QSTATUS_HELD);
	endif;					
	// ### just added to an empty RTG LANE queue i.e. no machines working it
	//if self.queue.queueType = QTYPE_RTG  then
	if self.queue.queueType = QTYPE_RTG  or
		self.queue.queueType = QTYPE_RMG  then  //cnwrd1 par 25217 1.11.2010 updated for rmg and rtg
		if (self.queue.allMachines.isEmpty and self.queue.allPrimaryMachines.isEmpty) then
			app.myPassport.createAlert(SEVERE_WARNING, 
						self.queue.id &amp; " has RDT Queue entry but no RTG Crane!",
						EVENT_AT_RTGAlert,
						self.entry);
		
		else
		//cnwrd1 par 25217 CCMS 1170
			workzoneCover := false; // should be but hey
			// we have machine(s) now we need to check the workzones.
			atask := self.entry.getTaskOfType(TASK_SETDOWN, null);
			
			if atask &lt;&gt; null then
				foreach machine in self.queue.allMachines do
					if machine.canMachineAccessLocInWorkzone( atask.targetLocation, null) then
						workzoneCover := true; //ths one covers the target
						break;
					endif;
				endforeach;
				
				if not workzoneCover then
					foreach machine in self.queue.allPrimaryMachines do
						if machine.canMachineAccessLocInWorkzone( atask.targetLocation, null) then
							workzoneCover := true; //ths one covers the target
							break;
						endif;
					endforeach;
				endif;
			
				if not workzoneCover then
					app.myPassport.createAlert(SEVERE_WARNING, 
							app.getErrorString2(No_Workzone_Cover, tiID, self.entry.allTasks.last.getTargetLocationForDisplay() ),
							EVENT_RTG_WORKZONE,
							self.entry);
				endif;
			endif;
		endif;
	endif;
	
	//NFS 3162: If the request wants cous and generators, this ti should have them
	//Otherwise send an alert and hold the queue entry
	if CM_Container.hasInstance(self.ti) then
		container := self.ti.CM_Container;
	endif;
	
	if CM_YardRequest.hasInstance(wle.myRequest) then
		yardRequest := wle.myRequest.CM_YardRequest;
	endif;
	  
	if yardRequest &lt;&gt; null 
	and container &lt;&gt; null
	and CM_RoadJob.hasInstance(job) then
		if yardRequest.needCOU and container.getCou = null then
			app.myPassport.createAlert(SEVERE_WARNING, 
						tiID &amp; " Queue Entry set to HELD: " &amp; tiID &amp; " requires a COU for release.",
						null,
						self.entry);
			
			self.entry.setEntryStatus(QSTATUS_HELD); 
												 	
		endif;
		
		if yardRequest.needGenerator and container.getGenerator = null then
			app.myPassport.createAlert(SEVERE_WARNING, 
						tiID &amp; " Queue Entry set to HELD: "  &amp; tiID &amp; " requires a Generator for release.",
						null,
						self.entry);
		
			self.entry.setEntryStatus(QSTATUS_HELD); 
		endif;
	endif;

	if (not self.wle.isReceipt) then
		//PAR 3216 AJA 10/1/00: Check suitability for release, hold if unsuitable 
		//epr 17/2/15 par 35702 CCMS 2457
		if self.targetLocation &lt;&gt; null then
			toArea := self.targetLocation.getParent;
		endif;
		if toArea &lt;&gt; null then
			create errorArray transient;// XPOSE 1808
			//self.ti.isTISuitableToRelease(toArea, errorArray, isRelease);// XPOSE 1808	// PAR #35081
			self.ti.isTISuitableToRelease(toArea, errorArray, isRelease, wle.myRequest);	// PAR #35081
		endif;
		if errorArray &lt;&gt; null then// XPOSE 1808
			if errorArray.size &lt;&gt; 0 then // &lt;&gt; SUITABLE then // XPOSE 1808
				foreach idx in errorArray do// XPOSE 1808
					alert:=app.myPassport.createAlert(SEVERE_WARNING, 
						tiID &amp; " Queue Entry set to HELD: " &amp; app.getErrorString1(idx, tiID),
						null,
						self.entry);
					
					// Par 14395 Attach ti to alert as well cause these babies are getting lost.
					alert.setMyTrackedItem(self.ti);
					
					self.entry.setEntryStatus(QSTATUS_HELD);
			
				endforeach;
			endif;
		endif; 
		
		// Release job, check to make sure there are no receipts still on the vehicle/wagon
		if self.job.checkReceiptsNotQueued(self.wle) then
			app.myPassport.createAlert(SEVERE_WARNING, 
						 tiID &amp; " Queue Entry set to HELD: " &amp; self.job.jobId &amp; ' still has cargo on board',
						null,
						self.entry);
						
			self.entry.setEntryStatus(QSTATUS_HELD);
			
			//23 Feb 2016	NDL	Par 37572
	//		task := self.wle.getNextUnactionedRTQueueTask();
	//		if task &lt;&gt; null then
	//			if not task.requiresSystemHold(false, null, reason) then
	//				app.myUtilityUA.utlUpdateQueueTaskStatus(task, TASK_USER_HELD);
	//			endif;
	//		endif;
						
		endif; 
	endif;
	//----------------
	//Special case... If ship load box has problems... STOP!
	//----------------
	if container &lt;&gt; null then
		if container.isPlannedUDWithCOU then
			app.myPassport.createAlert(SEVERE_WARNING, 
						 tiID &amp; " Queue Entry set to HELD: " &amp; app.getErrorString2(ERR_COU_ATTACHED, tiID &amp; " (planned for under deck load)", container.couId.trimRight),
						null,
						self.entry);		

			self.entry.setEntryStatus(QSTATUS_HELD);			
		endif;
		
		if container.isChilled 
		and (container.isExport or container.isTranshipItem)		// PAR #25021
		and	(not self.job.isYardInternalJob)
		and self.myTerminal.getConfig(HoldChilledCargo).Boolean then
		
			app.myPassport.createAlert(SEVERE_WARNING, 
						tiID &amp; " Queue Entry set to HELD: Container " &amp; tiID &amp; " contains Chilled Cargo",
						null,
						self.entry);	
	
			self.entry.setEntryStatus(QSTATUS_HELD);				

		endif;
	
		//----------------------
		//Removed per otago FCF 3194, All connected boxes should be 
		//STOPPED before queueing DQ 03/12/1999
		//----------------------
		if container.isConnected and not(container.hasCOU) then
			//epr par 36103 30/4/15
			if self.myTerminal.getConfig(SetConnectedTIToHeld).Boolean then
				//-------------
				//If its connected (but NOT to a COU), then complain
				//-------------
				if container.getTower &lt;&gt; null then
					aMsg := "Refrigeration Tower";
				else
					aMsg := "Power";
				endif;
				//----------------
				//TI is connected.. A NO-NO!
				//----------------
				app.myPassport.createAlert(SEVERE_WARNING, 
							tiID &amp; " Queue Entry set to HELD: " &amp; app.getErrorString2(ERR_STILL_CONNECTED, tiID, aMsg),
							null,
							self.entry);	
							
				self.entry.setEntryStatus(QSTATUS_HELD);
			endif;
		endif;
	endif;
epilog
	delete errorArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="writeLoggingText" id="01ff50bc-5b5b-402c-b593-1225688ae729">
        <updating/>
        <source>writeLoggingText(_text : String) updating;

/*

Purpose:		Write text to log and also to logging form if not null	

Parameters:			

Return Value:		


Date			Who		Reason
29 June 2011	cnwmh5	Initial creation

*/

vars
begin

	app.writeLog(_text, LogDEBUG);

	if app.myLoggingForm &lt;&gt; null then
		app.doFormLogging( method, _text[1:512], null );
	endif;
	
	// ### JIRA 35862 08SEP2025 NAVAB1
	if self.captureLoggingMode then  
		self.captureLoggingText := self.captureLoggingText  &amp; _text &amp; "@#";
	endif;

epilog

end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
</Class>
