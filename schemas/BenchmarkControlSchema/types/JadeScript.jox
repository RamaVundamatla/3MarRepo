    <JadeMethod name="jhpCompareIni" id="dcd69ac9-5e4b-4934-b2e3-685bab9aeef0">
        <updating/>
        <source>jhpCompareIni() updating;
//	reformats an ini file so it can be sorted then compared with winmerge
vars
	i,j:Integer;
	s,t,section:String;
	f:File;
begin
	create f transient;
	f.mode:=File.Mode_Input;
	//f.fileName:="\\cnwchcs55\t$\marJreg\server\c_bin\marJreg.ini";
	//f.fileName:="\\cnwchcs55\t$\marJreg\server\c_bin\marpreg_orig.ini";
	//f.fileName:="C:\a\marpreg_2012_bmk\shortcuts\marJreg_s79.ini";
	f.fileName:="C:\a\marpreg_2012_bmk\shortcuts\marJreg_1.ini";
	write f.fileName;
	
	while not f.endOfFile do
		s:=f.readLine.trimBlanks;
		if s = null then continue; endif;
		if s.contains("[") then
			section:=s;
			continue;
		endif;
		write section &amp; s;
	endwhile;
epilog
	delete f;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpControlTPCA" id="e120f660-ce01-4c10-bc73-d90fdb49a506">
