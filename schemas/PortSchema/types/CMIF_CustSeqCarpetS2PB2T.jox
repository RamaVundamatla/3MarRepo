<CollClass name="CMIF_CustSeqCarpetS2PB2T" id="d1307136-2bbf-4357-9f98-44755c95813d">
    <duplicatesAllowed/>
    <memberType name="CMIF_CustomSequenceObject"/>
    <superclass name="CMIF_CustomSeqObjectDict"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
