// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cntrl	: Control;
begin

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.column &lt;&gt; table.columns and table.row &gt; table.fixedRows then
		table.column := table.columns;
	endif;

	cntrl := table.accessCell(table.row, table.columns).cellControl;
	if cntrl &lt;&gt; null then
		cntrl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	endif;

	self.tblSearchResultsSelectRow(table.row);	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
