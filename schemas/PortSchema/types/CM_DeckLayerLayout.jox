			itemLayout.showContainerPositionUnderGC(_gcLayout); // SHOW
			if self.type = ROROLayerType_Cargo then
				continue; // always show cargo
			endif;
		endif;

		//epr better detection of polygon intersection 3/2/12 par 29079
		if gcPoints.intersectsPolygon(contPoints) then
			itemLayout.hideContainerPositionsUnderGC(_gcLayout); 
