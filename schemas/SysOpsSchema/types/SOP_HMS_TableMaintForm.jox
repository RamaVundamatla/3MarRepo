    <JadeMethod name="mnuDeleteRow_click" id="ab62551e-0753-46d1-b760-595432d0ec6a">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDeleteRow_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
begin
	theRow := self.tblRoute.row;
	if theRow &gt; 0 and theRow &lt;= self.tblRoute.rows then
		self.tblRoute.deleteRow(theRow);
