    <JadeMethod name="isTug" id="4b783ae8-70fb-4b13-96c3-815587400e66">
        <source>isTug():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41410

*/

vars

	str : String;
	pos : Integer;

begin

	str := app.getErrorString( Vessel_Type_Equals_Tug ).toUpper;
	pos := self.description.toUpper.pos( str, 1 );
	
	return pos &gt; 0;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c81dd2be-def2-4684-b368-32e9c98131ea">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: HMS_VesselType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fd42223e-a9d5-4be3-88b8-5ecfed99c749">
        <updating/>
        <source>setForUpdate(_pxyVesselType: HMS_VesselType; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyVesselType, _passport);
	
	self.code 			:= _pxyVesselType.code.toUpper.trimBlanks;
	self.description	:= _pxyVesselType.description;
	self.myRoot			:= _pxyVesselType.myRoot;
end;</source>
        <Parameter name="_pxyVesselType" type="HMS_VesselType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="28ee0536-8eab-4610-8687-8cf43eb98b7d">
        <updating/>
        <source>setProxy(_root	:	CM_Root) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
epilog

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d304734f-2cde-4973-bb12-c0e62afa6c6b">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpVesselType	:	HMS_VesselType;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_Desc, ETRow_Description, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException( Input_required_field_harbRoot, null, null ); // cnwdb2	PAR 35364
	endif;
	
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpVesselType := self.myRoot.allVesselTypes.getAtKey(self.code);
	if tmpVesselType &lt;&gt; null then
		if self.isTransient and tmpVesselType &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Vessel Type', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Vessel Type already exists for %1 : Vessel_type_already_exists
			app.raiseCMException1(Vessel_type_already_exists , self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
