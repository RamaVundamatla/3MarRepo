    <JadeMethod name="doMnuWorkShowMacroInfoClick" id="3ce330bf-114d-4ef4-b6ec-c9387e3143ee">
        <updating/>
        <source>doMnuWorkShowMacroInfoClick(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if menuItem.caption = self.MNU_MACRO_SHOW then
		self.dkcExtraInfo.visible := true;
