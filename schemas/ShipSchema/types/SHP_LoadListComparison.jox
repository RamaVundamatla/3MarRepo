    <JadeMethod name="btnRunComparison_click" id="9a99a975-4667-47af-af9f-86faf64a8c28">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRunComparison_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//  20 Apr 2023   navmp20  Bug 56527: SNO -- Cargo Comparison Form - After each comparison the fields under the Field Settings tab and the Update Settings tab are cleared out
//----------------------------------------------------------------
vars

begin
	//Start 20.04.2023 navmp20 TFS 56527
	self.getXMLSettingsForSave();
	if self.comparisonMode = LOAD_COMPARISON then
		self.availableXML := self.loadXML;
	elseif self.comparisonMode = DISCHARGE_COMPARISON then
		self.availableXML := self.dischargeXML;
	endif;
	//End 20.04.2023 navmp20 TFS 56527
	self.doRunComparisonClick(false);
end;</source>
