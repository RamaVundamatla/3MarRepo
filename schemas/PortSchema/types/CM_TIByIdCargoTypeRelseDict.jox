<CollClass name="CM_TIByIdCargoTypeRelseDict" id="9489d8cd-612d-437d-8113-20809b741626">
    <duplicatesAllowed/>
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TIDictByIdCargoTypeDate"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tiDicts"/>
    <MemberKey>
        <property name="CM_TrackedItem::id"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_TrackedItem::cargoType"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_TrackedItem::releasedDT"/>
    </MemberKey>
    <JadeMethod name="lookupByIDExactMatch" id="ab092863-aac0-405e-826e-42c21afcf1f9">
        <source>lookupByIDExactMatch(_id : String; _cargoType : Integer; _passport : CM_Passport; _checkAccess : Boolean; _allTIs : Collection input);
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	tmpTI		: CM_TrackedItem;
	keyID		: String;
	keyCargoType	: Integer;
	keyTS		: TimeStamp;
	tmpDAC		: CM_DataAccessController;

begin
	iter := self.createIterator();
	if _cargoType = null then
		self.startKeyGeq(_id, null, null, iter);
	else
		self.startKeyGeq(_id, _cargoType, null, iter);
	endif;
	while iter.next(tmpTI) do
		iter.getCurrentKeys(keyID, keyCargoType, keyTS); //MTN-35226
		if (keyID &lt;&gt; _id) or 
		   (_cargoType &lt;&gt; null and keyCargoType &lt;&gt; _cargoType) then
			break;
		endif;
		if _checkAccess and (not tmpTI.canUserAccessSelf(null, tmpDAC, _passport)) then
			continue;
		endif;
		_allTIs.add(tmpTI);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_checkAccess" type="Boolean"/>
        <Parameter name="_allTIs" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupByIdPartialMatch" id="4eca89d4-0512-4101-b950-a06fb9126e65">
        <source>lookupByIdPartialMatch(_id : String; _cargoType : Integer; _passport : CM_Passport; _checkAccess : Boolean; _allTIs : Collection input);
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose: 
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys      
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	tmpTI		: CM_TrackedItem;
	keyID		: String;
	keyCargoType	: Integer;
	keyTS		: TimeStamp;
	tmpDAC		: CM_DataAccessController;

begin
	iter := self.createIterator();
	if _cargoType = TI_CargoType_Null then
		self.startKeyGeq(_id, null, null, iter);
	else
		self.startKeyGeq(_id, _cargoType, null, iter);
	endif;
	while iter.next(tmpTI) do
		iter.getCurrentKeys(keyID,keyCargoType,keyTS); //MTN-35226
		if _id &lt;&gt; null and (not keyID.startsWith(_id))  then
			break;
		endif;
		if _cargoType &lt;&gt; TI_CargoType_Null and keyCargoType &lt;&gt; _cargoType then
			continue;
		endif;
		if _checkAccess and (not tmpTI.canUserAccessSelf(null, tmpDAC, _passport)) then
			continue;
		endif;
		_allTIs.add(tmpTI);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_checkAccess" type="Boolean"/>
        <Parameter name="_allTIs" type="Collection" usage="input"/>
    </JadeMethod>
</CollClass>
