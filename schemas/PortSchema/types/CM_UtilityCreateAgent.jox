    <JadeMethod name="utlCreateMachineIdleHistory" id="4b688956-0828-42db-b80e-e93811d1a9d2">
        <source>utlCreateMachineIdleHistory(	_machine : CM_Machine; 
								_currentIdleHist : CM_MachineHistory; 
								_newIdleHist : CM_MachineStatusHistory output; 
								_mins : Integer;
								_passport : CM_Passport input	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 20/01/2021   cnwma1	    Bug 50433: MTN - 1090 error in RTQ screen (Idle Time settings not inherited)
//
vars
	rtConfig : CM_RTVehicleConfig;
	alert    : CM_SystemAlert;

begin
	
	//rtConfig := _machine.myRTVehicleConfig;                                 //20.01.2021 cnwma1 #50433
	rtConfig   := _machine.myTerminal.getRTVehicleConfigForObject(_machine);  //20.01.2021 cnwma1 #50433
	
	if rtConfig = null then                                                   //20.01.2021 cnwma1 #50433
		return;
	endif;
	
	// create a machine history entry if configured to do so, and we don't already have one
	if rtConfig.idleTimeRecordInHistory and _currentIdleHist = null then
		app.writeLog("Created an Idle History for machine " &amp; _machine.code, LogINFO);
		_newIdleHist := _machine.addIdleHistory();
		_machine.updateObjectEdition(_machine);
	endif;
	
	// create an alert if configured to do so, and we've exceeded the configured time
	if rtConfig.idleTimeUntilAlert &lt;&gt; null and _mins &gt; rtConfig.idleTimeUntilAlert then
		app.writeLog("Machine "  &amp; _machine.code &amp; " has been idle for " &amp; _mins.asStringJMT &amp; " minutes, alert time is " &amp; rtConfig.idleTimeUntilAlert.asStringJMT &amp; " minutes - create an alert", LogINFO);
		alert := _passport.createAlert(	SEVERE_ERROR, 
									app.getErrorString2(Machine_idle_alert, _machine.code, _mins.asStringJMT),
									EVENT_AT_MachineIdleAlert,
									null	);
		if alert &lt;&gt; null then
			alert.myTerminal := _machine.myTerminal;
		endif;
		app.commitAlert();
	endif;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_currentIdleHist" type="CM_MachineHistory"/>
        <Parameter name="_newIdleHist" type="CM_MachineStatusHistory" usage="output"/>
        <Parameter name="_mins" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
