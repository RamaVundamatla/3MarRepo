    <JadeMethod name="addAPIENDPOINTS" id="000aacdf-ea10-4299-82dc-48f16f567dfd">
        <source>addAPIENDPOINTS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
27 September 2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
*/

vars
	objectSet	: ObjectSet;
	extWebDef	: CM_ExternalWebServiceDef;
begin
	// 27 September 2024	navcs2	ChangeRequest 66181 Start
	self.tblInterfaces.setup();
	
	foreach extWebDef in app.myRoot.allExternalWebServices do
		create objectSet transient;
		extWebDef.allEndpoints.copy(objectSet);
		self.tblInterfaces.addParentAndChildren(extWebDef.name, "endpoint", extWebDef,  objectSet, 1, true);
	endforeach;
	// 27 September 2024	navcs2	ChangeRequest 66181 End
epilog
	delete objectSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="addCamsProtocols" id="23606d07-9d8d-4e9d-8a08-0b60e91ff2ab">
        <source>addCamsProtocols(_terminals : CM_TerminalByCodeDict);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
27 September 2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback

*/

vars
	prot : CM_CamProtocol;
	idx : Integer;
	terminal : CM_Terminal;
	objectSet : ObjectSet;
begin
	self.tblInterfaces.setup();
	
	if not _terminals.isEmpty then
		foreach terminal in _terminals do
			create objectSet transient;
			terminal.camProtocols.copy(objectSet);
			self.tblInterfaces.addParentAndChildren(terminal.code, "code", terminal, objectSet, 1, true);		// 27 September 2024	navcs2	ChangeRequest 66181
		endforeach;
	endif;
epilog
	delete objectSet;
end;</source>
        <Parameter name="_terminals" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
