    <JadeMethod name="btnClearFilters_click" id="781834f4-c730-461a-8aa0-f7ac63b512b3">
        <updating/>
        <source>btnClearFilters_click( _btn : CMUI_Button ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	msg : String;

begin

	if self.frmUpdFilter.visible then
		msg := app.getErrorString(Must_apply_cance_curre_filte_c);
		app.msgBox( msg, app.getErrorString(Error) , MsgBox_OK_Only );
		return;
	endif;

	self.doClearFilters( false );

epilog

end;</source>
        <Parameter name="_btn" type="CMUI_Button"/>
    </JadeMethod>
    <JadeMethod name="btnSelectAll_Click" id="663fed12-d173-4974-9fcf-b7afe359d992">
        <updating/>
        <source>btnSelectAll_Click( _btn : CMUI_Button ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2015	cnwndl1	Initial creation

*/

vars

	allSelected : Boolean;
	rowIndex : Integer;
	value : String;
	filterText : String;

begin

	app.mousePointer :=	Busy;

	foreach rowIndex in 1 to self.lstFilterProxy.rows do
		filterText := self.lstFilterProxy.accessCell( rowIndex, 2 ).text;
		if filterText = self.AllValues then 
			allSelected := self.lstFilterProxy.accessCell(rowIndex,1).text = TableCheckBox_Selected;
			break;
		endif;
	endforeach;

	if allSelected then 
		value := TableCheckBox_NotSelected;
		self.btnSelectAll.caption := app.getErrorString(SelectAll);
		
	else
		value := TableCheckBox_Selected;
		self.btnSelectAll.caption := app.getErrorString(Deselect_All);
	endif;
	
	foreach rowIndex in 1 to self.lstFilterProxy.rows do
		self.lstFilterProxy.setCellText(rowIndex,1,value);
	endforeach;
	
epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_btn" type="CMUI_Button"/>
    </JadeMethod>
    <JadeMethod name="btnShowHide_click" id="4d4927d6-81c5-4ab0-befa-22f7968a00fa">
        <updating/>
        <source>btnShowHide_click( _btn : CMUI_Button ) updating;
/*

Purpose:			

Parameters:			

