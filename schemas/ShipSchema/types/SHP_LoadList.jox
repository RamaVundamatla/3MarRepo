    <JadeMethod name="doTblTranshipContextMenu" id="8fe5c6a7-01a6-423a-bfe1-2640144cef08">
        <updating/>
        <source>doTblTranshipContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	theRow : Integer;
	theTI : CM_TrackedItem;
	theLocationsController : CM_LocationsController;
begin

	self.mnuInspectObject.visible := app.isAllowedToInspect();
		
	self.mnuLoadListPlanLoad.visible := false;

	theRow := cntrl.CM_BaseTable.getRowFromY(y);
	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;

		self.mnuInspectObject.userObject := theTI;
		
		// #####################
		// PLANNING TO SHIP?
		// #####################
		if app.myMoveController &lt;&gt; null then
			if theTI &lt;&gt; null then
				if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.mySlotRequest.isLoad and theTI.isTranshipItem then
						app.myMoveController.setMyTrackedItem(theTI);
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_Tranship);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Trans_Load_To) &amp; app.myMoveController.mySlotRequest.mySlotController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.myVoyageRequest.isLoad and theTI.isTranshipItem then
						app.myMoveController.setMyTrackedItem(theTI);
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_Tranship);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Trans_Load_To) &amp; app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				endif;
			endif;
		endif;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		if not self.splMain.getControlByName(self.tblInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtPlanned then
		if not self.splPlanned.getControlByName(self.tblPlannedInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtAll then
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtDLR then									// 30/9/19 MAP TFS 45590
		if not self.splDLR.getControlByName(self.tblDLRInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTranship then							// 30/9/19 MAP TFS 45590
		if not self.splTranShip.getControlByName(self.tblTranShipInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTBA then							// 30/9/19 MAP TFS 45590
		if not self.splTBA.getControlByName(self.tblTBAInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	else
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	endif;

		
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);


end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblTranshipMouseMove" id="56137a87-07f1-47cc-b9e4-0a29a45dfc86">
        <updating/>
        <source>doTblTranshipMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2013	cnwrd1	Initial creation

*/
vars

	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	moveController : CMIF_MoveController;
begin

	//if self.mode &lt;&gt; self.Mode_SummarySelection then	//25 Jan 2012	NDL	Par 25297
		self.tblTranShip.mouseMoveForDragSelect(table, button, shift, x, y);
	//endif;

	if self.tblTranShip.row &lt;= self.tblTranShip.fixedRows 
	or y &lt;= table.accessRow(self.tblTranShip.fixedRows).height then 
		self.origXPos := x;
		self.origYPos := y;
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and	app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and self.origYPos &gt; 20  // ###  may be doing a column resize!
	and not shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		theTI := self.tblTranShip.accessRow(self.tblTranShip.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null and not theTI.isPlanned(PLANNING_MODE) then
			app.myDraggedTrackedItem := theTI;
			create moveController transient;
			
			moveController.setMyTrackedItem(theTI);
			delete app.myMoveController;
			app.myMoveController := moveController;
			app.isDragging := true;
			moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(REAL_MODE));
			self.moveModeForm := PLANNING_MODE;
			moveController.setMoveMode(PLANNING_MODE);	
			table.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				table.dragCursor := lPicture.picture;
			endif;

		endif;
	else
		//do we really need to do this on a mouse move?   Mouse up is enough
		//self.frmStatLine.caption := self.statusStub &amp; " " &amp; $SHP_Selected &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	endif;
epilog
	if lPicture &lt;&gt; null then
		delete lPicture;
	endif;
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
