        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="8980a292-52dc-4d2f-810c-d8de3103ea25">
        <source>initShtMultiSelect();
/*
Purpose:			

Date		Who		Reason
07 August 2023	navab1	CR 56093 TASK 59625
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
*/

vars
	terminal : CM_Terminal;
	entDef	: EntTableDef;
begin
	inheritMethod();
	
	self.setupMultiSelect1("Stops To Clear",app.myRoot.allStopsTable,SOP_TableMaintForm::displayEntryStopTable.name);
	self.setupMultiSelect2("Stops To Apply",app.myRoot.allStopsTable,SOP_TableMaintForm::displayEntryStopTable.name);
	
	terminal := self.myForm.myTerminal;
	self.setupMultiSelect3("Next Document Types",terminal.allCustomDocumentTypes,SOP_TableMaintForm::displayEntryCustDocType.name);
	self.setupMultiSelect6("Custom Licenses",terminal.allCustomLicenses,SOP_TableMaintForm::displayEntryCustLicense.name);
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	entDef := app.myController.getEntTableDef(ETDef_CustDocTypeMandAttr);
	if entDef &lt;&gt; null then
		self.setupMultiSelect7("Mandatory Attributes", entDef.allEntTableRows, SOP_TableMaintForm::displayEntryCusDocTypeMandAttr.name);
	endif;
	
epilog

end;</source>
    </JadeMethod>
