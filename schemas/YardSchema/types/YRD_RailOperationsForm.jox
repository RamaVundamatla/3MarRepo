    <JadeMethod name="frmGridArea_mouseMove" id="0273684e-1847-4616-ad52-7d64b019fee4">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

begin
	if button &lt;&gt; 1 then
		return;
	endif;

	self.frmGridArea := frame.CMUI_GridAreaFrame;

	if app.dragDetected(x, y, origXPos, origYPos) then
		if shift.isControlKeyPressed then
			self.dragSelectStart(frame, x, y);
		else
			self.gridAreaMouseMoveEvent(button, x, y);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
