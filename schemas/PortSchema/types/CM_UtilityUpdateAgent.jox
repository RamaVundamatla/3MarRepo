    <JadeMethod name="utlUpdateRemovePinBR" id="4fb6e8e6-ba3c-40c3-abaa-7cdcf09c6d6f">
        <source>utlUpdateRemovePinBR(_brSet : CM_BulkReleaseSet; _carrierEmail: CM_ObjectEmail; _passport : CM_Passport input);
//----------------------------------------------------------------
//	Created:	07 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	realBR			: CM_BulkRelease;
	carrierEmail	: CM_PINObjectDefaultEmail;
begin

	self.initialiseActivity();

	foreach realBR in _brSet do

		exclusiveLock(realBR);
		if realBR.status &lt;&gt; BR_ACTIVE then
			continue;
		endif;
		
		// audit before text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realBR, true);
		endif;
		
		if realBR.myPinNo &lt;&gt; null then
			// 18/05/2009 cnwar2 CCMS1723/#???
			if _carrierEmail &lt;&gt; null and _carrierEmail.isKindOf(CM_PINObjectDefaultEmail) then
				carrierEmail := _carrierEmail.CM_PINObjectDefaultEmail;
			endif;
			if realBR.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then
				realBR.embargoPIN(carrierEmail);
			else
				realBR.myPinNo.erasePIN(carrierEmail);	//deleting old, force the use of the default email by passing in null
			endif;
		endif;
	
		// audit after text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realBR, false);
		endif;
		
		self.updateObjectEdition(realBR);	// par 30292
			
	endforeach;


end;</source>
        <Parameter name="_brSet" type="CM_BulkReleaseSet"/>
        <Parameter name="_carrierEmail" type="CM_ObjectEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRemovePinReleaseImp" id="05515788-d209-4041-8c61-966126ea539c">
        <updating/>
        <source>utlUpdateRemovePinReleaseImp(_tiSet : CM_TISet; _carrierEmail: CM_ObjectEmail; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	05 February 2009	by cnwvu1

Purpose:	Deletes PINs for Cargo Release Imports
   
Change Date		Who		Reason
30 Aug 2012		cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
------------------------------------------------------------------------------*/
vars
	realTI			: CM_TrackedItem;
	
begin

	self.initialiseActivity();

	foreach realTI in _tiSet do

		if realTI.myPinNo = null then
			continue;
		endif;

		exclusiveLock(realTI);
		
		// audit before text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realTI, true);
		endif;
		
		realTI.myPinNo.erasePIN(_carrierEmail);	//force the use of the default email by passing in null
	
		// audit after text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realTI, false);
		endif;
		
		self.updateObjectEdition(realTI);	// par 30292
			
	endforeach;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_carrierEmail" type="CM_ObjectEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRepack" id="0ebaa7da-6712-44a9-9c7c-d7637e0c0fee">
        <updating/>
        <source>utlUpdateRepack(_pxyContainerToEmpty, _pxyContainerToRepack : CM_TrackedItem input;
				_noCharge : Boolean input;
				_updateMode : Integer; 
				_passport : CM_Passport input ) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 02 December 2003
//
//********************************************************************
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 10/09/2013	cnwdap1		PAR #31196 Transfer Tranship details is we need to
// 20/11/2019	jlgzm1		TFS 47222 Remove All Import stops is redundant
vars
	realPackedContainer,
	realEmptiedContainer		: CM_TrackedItem;
	expectedEdition1,
	expectedEdition2			: Integer;
	theTransaction 				: CM_TITransaction;	
	theTransactionController 	: CMIF_RepackTransController;//CMIF_TITransactionController;
	// 31520 use CMIF_StorageTransController to get the .startTransaction populated
	storageController			: CMIF_StorageTransController;
	aStop						: CM_Stops;
	childSet					: CM_TISet;
	allStops					: CM_StopsByIdDict;
	transhipInterface			: CMIF_TranshipTIController;					// PAR #31196
	tiUpdateCntrlr				: CMIF_TIUpdateController;						// PAR #31196
	
begin
	self.initialiseActivity();
	
	_pxyContainerToRepack.pxyGetRealObjectAndEdition(realPackedContainer, expectedEdition1);
	_pxyContainerToEmpty.pxyGetRealObjectAndEdition(realEmptiedContainer, expectedEdition2);

	// PAR #31196 Store Tranship details for later use if required (otherwise details will be lost once 		// PAR #31196
	// utlUpdateTrackedItem is called below for _pxyContainerToEmpty);											// PAR #31196
	if realEmptiedContainer.isTranshipItem and not realPackedContainer.isTranshipItem then						// PAR #31196
		create transhipInterface transient;																		// PAR #31196
		transhipInterface.myExportDestPort 	:= app.myRoot.allPorts[realEmptiedContainer.destinationPort];		// PAR #31196
		// TFS 2122 add null test
		if realEmptiedContainer.myTranshipDetail &lt;&gt; null then
			transhipInterface.myExportDisPort	:= realEmptiedContainer.myTranshipDetail.myDischargePort;		// PAR #31196
		endif;
		if transhipInterface.myExportDisPort = null then														// PAR #31196
			transhipInterface.myExportDisPort := app.myRoot.allPorts[realEmptiedContainer.dischargePort];		// PAR #31196
		endif;																									// PAR #31196
		transhipInterface.myExportVoyage	:= realEmptiedContainer.myExportVoyage;								// PAR #31196
		transhipInterface.myTranshipToPort	:= realEmptiedContainer.myTranshipToPort;							// PAR #31196
		transhipInterface.remarks			:= realEmptiedContainer.remarksTranship;							// PAR #31196
		// TFS 2122 add null test
		if realEmptiedContainer.myTranshipDetail &lt;&gt; null then
			transhipInterface.bookingRef		:= realEmptiedContainer.myTranshipDetail.exportBookingReference;	// PAR #31196
			transhipInterface.billOfLading		:= realEmptiedContainer.myTranshipDetail.exportBOL;					// PAR #31196
		endif;
	endif;																										// PAR #31196
	
	//Update the Container that is being emptied.
	self.utlUpdateTrackedItem(_pxyContainerToEmpty, null, _updateMode, null, null, null, _passport); //cnwrd1 28.8.09 par 20545
	
	//Now update the container being packed
	self.utlUpdateTrackedItem(_pxyContainerToRepack, null, _updateMode, null, null, null, _passport); //cnwrd1 28.8.09 par 20545
	//	reset this flag in case it has been set so total weight will be re-calculated. CCMS1420
	// par 26377 cnwjre1 June 2011 moved below the utlUpdates as it caused an edition mismatch in that code
	realPackedContainer.setTotalWeightSetFlag(false);
	
	if not _passport.noErrors then
		return;
	endif;
	
	// PAR #31196 If the container to be emptied is a tranship, and the new container is not, transfer			// PAR #31196
	// the Tranship details to the new container																// PAR #31196
	if realEmptiedContainer.isTranshipItem and not realPackedContainer.isTranshipItem then						// PAR #31196
		_pxyContainerToRepack.setPxyFromCMIF_TranShip(transhipInterface, realPackedContainer);					// PAR #31196
		realPackedContainer.setMyVoyage(realEmptiedContainer.myImportVoyage, _passport);						// PAR #31196
		realPackedContainer.setTranship(_pxyContainerToRepack, _passport, true);								// PAR #31196 // TFS 47222
		delete transhipInterface;																				// PAR #31196
																												// PAR #31196
		_pxyContainerToEmpty.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);											// PAR #31196
		_pxyContainerToEmpty.zSetPxyRemarks(null);																// PAR #31196
		_pxyContainerToEmpty.zSetImportVoyage(null);															// PAR #31196
		tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);				// PAR #31196
		realEmptiedContainer.setTranshipToNonTranship(_pxyContainerToEmpty, tiUpdateCntrlr, _passport);			// PAR #31196
		realEmptiedContainer.changeVoyage(realEmptiedContainer.myTerminal.getNullVoyage, _passport);			// PAR #31196
		delete tiUpdateCntrlr;																					// PAR #31196
	endif;																										// PAR #31196
	
//	foreach aStop in realEmptiedContainer.getAllStops() do	// cnwrl1 14/12/2009 PAR 21889 - what it was
	create allStops transient;
	realEmptiedContainer.getAllActiveStops( allStops );
	foreach aStop in allStops do
		realPackedContainer.setStopsToBeApplied(aStop.id, true, _passport);
	endforeach;
	
//TRANSACTIONS FOR THE FULL AND EMPTY CONTAINER STARTNG WITH A STORAGE TRANSACTION

	create theTransactionController transient;
	create storageController transient;
	
	theTransactionController.userId := _passport.userCode;
	theTransactionController.noCharge := _noCharge;

	// 31520 use CMIF_StorageTransController to get the .startTransaction populated
	storageController.userId := _passport.userCode;
	storageController.noCharge := _noCharge;
	storageController.type := TRANS_TYPE_STORAGE;
	storageController.myOtherTrackedItem := null;
	theTransaction := realPackedContainer.createTransaction(storageController, _passport);

//Transaction for the full container
	theTransactionController.type := TRANS_TYPE_REPACK;
	theTransactionController.myTrackedItem := realPackedContainer;
	theTransactionController.myOtherTrackedItem := realEmptiedContainer;
	theTransaction := realPackedContainer.createTransaction(theTransactionController, _passport);
	
//Transaction for the empty container.
	theTransactionController.type := TRANS_TYPE_REPACK;
	theTransactionController.myTrackedItem := realEmptiedContainer;
	theTransactionController.myOtherTrackedItem := realPackedContainer;
	theTransaction := realEmptiedContainer.createTransaction(theTransactionController, _passport);

	if not _passport.noErrors then
		return;
	endif;
	
epilog
	delete theTransactionController;
	delete storageController;
	delete childSet;
	delete allStops;
	delete transhipInterface;								// PAR #31196
	delete tiUpdateCntrlr;									// PAR #31196
end;</source>
        <Parameter name="_pxyContainerToEmpty" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_pxyContainerToRepack" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_noCharge" type="Boolean" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRepairReason" id="64636a33-0d55-4a5a-ad9f-b70836e87487">
        <source>utlUpdateRepairReason(_pxyRepairReason : CM_RepairReason input;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/
vars
	realRepairReason		: CM_RepairReason;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyRepairReason, 'Repair Reason code proxy');
	
	_pxyRepairReason.pxyGetRealObjectAndEdition(realRepairReason, expectedEdition);
	self.raiseExceptionIfNull(realRepairReason, 'Repair Reason');
	
	_pxyRepairReason.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRepairReason, true);
	endif;
	
	realRepairReason.setForUpdate(_pxyRepairReason);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRepairReason, false);
	endif;
	
epilog

end;
</source>
        <Parameter name="_pxyRepairReason" type="CM_RepairReason" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRepairedDimensions" id="8ede79ee-789e-4aaf-9e9c-95a0466e71e6">
        <source>utlUpdateRepairedDimensions( _ti : CM_TrackedItem input;
							_diameter : Decimal input;
							_height : Decimal input;
							_volume : Decimal input;	
							_rollingLength : Decimal input;	
							_length : Decimal input;
							_grammage : Decimal input;
							_width : Decimal input;
							_passport : CM_Passport input
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars
	realTI					: CM_TrackedItem;
	expectedEdition			: Integer;
	valUpdateCntrl,
	tiUpdateCntrlr			: CMIF_TIUpdateController;
begin
	self.initialiseActivity();
	
	_ti.raiseExceptionIfNotProxy(method);
	_ti.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
	_ti.setDimensions(_diameter, _height, _volume, _rollingLength, _length, _grammage, _width);
	
	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	valUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	app.myValUA.valTrackedItem(_ti, valUpdateCntrl, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(realTI);
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	tiUpdateCntrlr.comment := null;
	
	if not _passport.noErrors then
		return;
	endif;
		
	realTI.setForUpdate(_ti, tiUpdateCntrlr, null, true, _passport);
	
epilog
	delete tiUpdateCntrlr;
	delete valUpdateCntrl;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_diameter" type="Decimal" usage="input"/>
        <Parameter name="_height" type="Decimal" usage="input"/>
        <Parameter name="_volume" type="Decimal" usage="input"/>
        <Parameter name="_rollingLength" type="Decimal" usage="input"/>
        <Parameter name="_length" type="Decimal" usage="input"/>
        <Parameter name="_grammage" type="Decimal" usage="input"/>
        <Parameter name="_width" type="Decimal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReparentMenuUserItem" id="a42e5461-ad7d-480f-bca5-19bd3781ebcb">
        <source>utlUpdateReparentMenuUserItem(_parent : CM_MenuEntity; _child : CM_MenuUserItem input;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     17 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _parent = null then
		app.raiseCMException1(ERR_NULL_OBJ, 'Parent entity', CM_MenuEntity.name, null);
	endif;

	if _child = null then
		app.raiseCMException1(ERR_NULL_OBJ, 'Child entity', CM_MenuEntity.name, null);
	endif;
	
	exclusiveLock(_parent);
	exclusiveLock(_child);
	if _parent.isKindOf(CM_MenuRoot) then
		_child.setMyParent(_parent);
		_child.setLevel(2);
		_child.setMyMenuRoot(_parent.CM_MenuRoot);
	
	elseif _parent.isKindOf(CM_MenuUserHdr) then
		_child.setMyParent(_parent);
		_child.setLevel(_parent.CM_MenuUserHdr.level +1);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Selected entity is not a header or a root -cannot move');
	endif;
	
epilog
	
	
end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_child" type="CM_MenuUserItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReportTemplate" id="55607ba1-c562-4cda-89e7-daac081cb6aa">
        <updating/>
        <source>utlUpdateReportTemplate(_pxyReportTemplate : CM_ReportTemplate;
						_newMenuUserReport	: CM_MenuUserReport output;
						_passport 			: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	reportTemplate	: CM_ReportTemplate;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);


	app.myValUA.valReportTemplate(_pxyReportTemplate);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	reportTemplate := _pxyReportTemplate.pxyGetRealObject();
	
	if reportTemplate = null then
		// Raise Exception;
		return;
	endif;
	
	self.exclusiveLock(reportTemplate);
	
	reportTemplate.setForUpdateTemplate(_pxyReportTemplate, _newMenuUserReport, _passport);
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	
end;</source>
        <Parameter name="_pxyReportTemplate" type="CM_ReportTemplate"/>
        <Parameter name="_newMenuUserReport" type="CM_MenuUserReport" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRequest" id="f3df8046-086f-4354-8f1c-42eb76d9b153">
        <updating/>
        <source>utlUpdateRequest(pProxyRequest:CM_Request input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realRequest:CM_Request;
	expectedEdition:Integer;
	lCMIF_Object	: CMIF_Object;
	lTIArray	: CM_TIArray;

begin

	self.initialiseActivity();

	pProxyRequest.raiseExceptionIfNotProxy(method);

	pProxyRequest.pxyGetRealObjectAndEdition(realRequest, expectedEdition);
	
	if realRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Request.name, null, null);
		return;
	endif;

	exclusiveLock(realRequest);

	if _passport.noErrors and realRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Request', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realRequest.setForUpdate(pProxyRequest);
	endif;

end;</source>
        <Parameter name="pProxyRequest" type="CM_Request" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRequestDetails" id="d37487bc-656f-4693-bc6e-ec07520f90ad">
        <updating/>
        <source>utlUpdateRequestDetails(_proxyRequest : CM_DeliveryRequest input; _wles : CM_WLEArray input; _termAreas : CM_TerminalAreaArray; _termGridObjs : CM_GridObjectArray;_bestPick : Boolean; _fifo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     May 2011 by cnwjre1
//
// Purpose:     Par 27097 POL CCMS 2043 combine Edit Remarks, Additional Instructions and Select Source Location
//					into one request edit form.  Combines utlUpdateRequest and utlUpdateWLEsQueueRequest plus additional auditing.
//
// Parameters:  
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realRequest	: CM_DeliveryRequest;
	wle			: CM_WorkListEntry;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();

	_proxyRequest.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	app.myValUA.valRequestDetails(_proxyRequest, _wles, _termAreas);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	_proxyRequest.pxyGetRealObjectAndEdition(realRequest, expectedEdition);
	
	if realRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DeliveryRequest.name, null, null);
		return;
	endif;

	exclusiveLock(realRequest);

	if _passport.noErrors and realRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Request', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realRequest.setForUpdate(_proxyRequest);
	endif;

	if _passport.noErrors then
		// also audit the bulk release, if any
		if realRequest.myOriginatingBulkRelease &lt;&gt; null then	//**todo - use an XL string below
			realRequest.myOriginatingBulkRelease.createAuditObjectInformation("Release updated to allow release, iso type="&amp;realRequest.isoType&amp;" iso group="&amp;realRequest.isoGroup);
		endif;
	endif;

	// update the source location(s)
	if _passport.noErrors then
		self.utlUpdateWLEsQueueRequest(_wles, _termAreas,_termGridObjs, _bestPick, _fifo, true, _passport);
		wle := _wles.first;
		if wle &lt;&gt; null then
			// raise a note to get the road ops form to refresh the id and iso type 
			app.myEventManager.createSingleObjInfoNoteEvt(wle, wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), wle);
		endif;
	endif;
end;</source>
        <Parameter name="_proxyRequest" type="CM_DeliveryRequest" usage="input"/>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
        <Parameter name="_termAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_termGridObjs" type="CM_GridObjectArray"/>
        <Parameter name="_bestPick" type="Boolean"/>
        <Parameter name="_fifo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateResourceType" id="c7dad4ab-36e6-4de6-9a97-afa260d8edc7">
        <source>utlUpdateResourceType(pProxyResourceType : CM_ResourceType; _passport : CM_Passport input);
/*
Date				Who		Reason
21 December 2009	conkc1	Initial creation CCMS MES 1006
*/
vars
	realResourceType    : CM_ResourceType;
	expectedEdition     : Integer;
	
begin

	self.initialiseActivity();

	pProxyResourceType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyResourceType.pxyGetRealObjectAndEdition(realResourceType, expectedEdition);
	
	if realResourceType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ResourceType.name, null, null);
		return;
	endif;

	app.myValUA.valResourceType(realResourceType, pProxyResourceType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realResourceType);

	if _passport.noErrors and realResourceType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ResourceType', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realResourceType, true);
	endif;
	
	if _passport.noErrors then
		realResourceType.setForUpdate(pProxyResourceType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realResourceType, false);
	endif;

epilog

end;</source>
        <Parameter name="pProxyResourceType" type="CM_ResourceType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateResourceTypeGroup" id="105ea002-372d-4694-91dc-01932baf41d3">
