    <JadeMethod name="testOman" id="4ae52bf0-8b02-42c1-88db-60437e9ab690">
        <source>testOman(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2017	jlgma1	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels

*/


vars
	theTI,ti		: CM_TrackedItem;
	dict		: CM_TIByCargoTypeIdDict;
	iter		: Iterator;
	cargoTypeKey: Integer;
	counter		: Real;
	idKey 		: String;
	newQty : Real;
begin

	theTI := _cmif.myTransaction.CM_TITransaction.myTrackedItem;
	newQty := _cmif.origQty;

	dict := theTI.myTerminal.allOnsiteTIsByCargoTypeId;
	iter := dict.createIterator;

	 // Counter for Passenger Cars Cargo Type
	
	dict.startKeyGeq(10055, null, iter); 
	while iter.next(ti) do
		dict.getIteratorKeys(cargoTypeKey, idKey, iter);
		if cargoTypeKey &lt;&gt; 10055 then 
			break;
		endif;
	if  ( ti.consignee = "A0122" or ti.consignee = "A0137" or ti.consignee = "M0094" or ti.consignee = "N0021" or ti.consignee = "R0022" or ti.consignee = "S0019" or ti.consignee = "S0040" or ti.consignee = "T0017" or ti.consignee = "T0027" ) then   //  Replace  with the required Operator 
	
			counter:= counter + ti.totalQuantity;
		endif;
	endwhile;

	// Repeating the Counter for Project RORO Cargo Type
	
		dict.startKeyGeq(10072, null, iter); 
	while iter.next(ti) do
		dict.getIteratorKeys(cargoTypeKey, idKey, iter);
		if cargoTypeKey &lt;&gt; 10072 then 
			break;
		endif;
	if ( ti.consignee = "A0122" or ti.consignee = "A0137" or ti.consignee = "M0094" or ti.consignee = "N0021" or ti.consignee = "R0022" or ti.consignee = "S0019" or ti.consignee = "S0040" or ti.consignee = "T0017" or ti.consignee = "T0027" ) then   //  Replace  with the required Operator 
			counter:= counter + ti.totalQuantity;
		endif;
	endwhile;

	
	app.invLog("Total Quanity of Cargos Onsite =" &amp;counter.asStringJMT, LogINFO.String);

	
	if counter &gt;= 2310 then
		
		app.invLog("Is an Overflow Shifting" &amp;ti.totalQuantity.asStringJMT, LogINFO.String);
		app.invLog("Overflow Quantity =" &amp;_cmif.origQty.asStringJMT, LogINFO.String);
		newQty := _cmif.origQty;

	else
		app.invLog("Is not an Overflow Shift, No lines created", LogINFO.String);
		app.invLog("Overflow Quantity = 0", LogINFO.String);
		newQty := 0;
	endif;
	
	return newQty;
epilog
	delete iter;

end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="testRQFormNotes" id="964c647e-7729-4359-9db7-c76749e0c893">
        <source>testRQFormNotes();
//
