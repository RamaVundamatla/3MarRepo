    <JadeMethod name="getMeasurementStringForAttrib" id="ae1ef81b-cb69-46d3-b53b-543118d35fd6">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
29/04/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
31/10/2013 	cnwer1		Par 32237
18 Oct 2023 navhl20 	Bug 60931: EUP - Delivery Dispatch Remedial [2]
*/
vars

begin
	if _attrName.isOneOf(ETRow_TotalWeight, ETRow_WeightTotal,ETRow_TotalVolume) then
		if self.getTotalWeight() &lt;&gt; null then														//18.10.2023 navhl20 #60931
			return app.convertMeasurementForDisplay(_measureType, self.getTotalWeight());
		else
			return null;
		endif;
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountDisplay" id="6f086768-0d81-4810-977e-c80d0d322ff3">
        <source>getMoveAmountDisplay(_showUnit : Boolean) : String;
/*

Date		Who		Reason
13 March 2014	cnwer1	Initial creation CCMS 1366

*/

vars
	
	ti 			: CM_TrackedItem;
	ct			: CM_CargoType;
	moveWeight 	: Decimal[14,4];
begin
	ti:=self.getMyTrackedITem;
	if ti &lt;&gt;  null then
		ct:=ti.myCargoType;
	else
		if self.myRequest &lt;&gt; null then
			ct:= self.myRequest.getCargoType;	
		endif;
	endif;
	
	if ct &lt;&gt; null and  ct.isBulkMulti then
		moveWeight:=self.weight;
		if moveWeight = 0 and  ti &lt;&gt;  null then
			moveWeight:=  ti.totalWeight;
		endif;
		return self.getMoveAmountForWeight(moveWeight,_showUnit);
	endif;		
	
	return self.getQuantity().asStringJMT;
	
		
	
	
epilog

end;</source>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountForWeight" id="40eb9092-ebaa-4528-b474-eaca7fc4c651">
        <source>getMoveAmountForWeight(_weight : Decimal;_showUnit : Boolean) : String;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	ti 			: CM_TrackedItem;
	ct			: CM_CargoType;
	product	 	: CM_Product;
	density 		: Decimal[14,4];
	
begin
	ti:=self.getMyTrackedITem;
	if ti &lt;&gt;  null then
		ct:=ti.myCargoType;
	else
		if self.myRequest &lt;&gt; null then
			ct:= self.myRequest.getCargoType;
		endif;
	endif;
	
	density:=self.getDensity();
	
	if ct &lt;&gt; null then
		return ct.getBulkTrackByDisplayForWeight(_weight,density,_showUnit);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
