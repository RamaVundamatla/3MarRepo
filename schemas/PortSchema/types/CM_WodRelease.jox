    <JadeMethod name="pxyCreateUpdateProxy" id="6042a729-9270-4b04-93ab-bb7dc99e621a">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 28/12/2022   navdp20     ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
// 03 Feb 2023	navcs2		ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
// 06 Jul 2023 	navhl20 	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
vars
	pxy 		: SelfType;
	completedOK : Boolean;

begin
	pxy := inheritMethod();
	
	pxy.myReleaseRequest    := self.myReleaseRequest;
	pxy.transport 		    := self.transport; 						//28.12.2022 navdp20 TFS 56661[56012]
	pxy.myVoyage		    := self.myVoyage; 						//03.02.2023	navcs2	ChangeRequest 55440 (54990)
	pxy.myTrain 			:= self.myTrain; 						//03.02.2023	navcs2	ChangeRequest 55440 (54990)
	pxy.myBookingRef 		:= self.myBookingRef;			//03.02.2023	navcs2	ChangeRequest 55440 (54990)			//06.7.2023 navhl20 #58952
	pxy.myBookingRefItem	:= self.myBookingRefItem;				//06.7.2023 navhl20 #58952
	pxy.myReserveDetail		:= self.myReserveDetail;				//30.03.2023	navcs2  #55440:[54990]
	
	completedOK := true;
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBooking" id="331adfbf-1291-4a63-8478-2911949a9dd7">
