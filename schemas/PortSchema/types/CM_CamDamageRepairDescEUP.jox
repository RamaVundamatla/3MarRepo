    <JadeMethod name="availableEvents" id="2e512978-d787-489a-83ec-6b0b96883a5a">
        <source>availableEvents(_eventList: IntegerArray input);
/*

Purpose:			
	This method adds the events available for EUP Damageand Repair
Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navra1	Initial creation for TFS - 55859

*/

vars
	event : CM_EventType;

begin
	_eventList.add(EVT_VoyExchangeCompleted);
	_eventList.add(EVT_VoyageArrival);
	_eventList.add(EVT_VoyageDeparture);
	
	foreach event in app.myRoot.allEventTypesByCategory do 
		if event.category = CM_EventType.VOYAGE_EVENT and event.type &gt; EVT_MAX_JMT then
			_eventList.add(event.type);
		endif;
	endforeach;

epilog
	
end;</source>
        <Parameter name="_eventList" type="IntegerArray" usage="input"/>
    </JadeMethod>
