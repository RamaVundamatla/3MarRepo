    <JadeMethod name="setForUpdate" id="4884ba7e-7d55-44f9-9b5c-0508cec58339">
        <updating/>
        <source>setForUpdate( _proxy : CM_InvTypeAdditionalCharges ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

begin

	self.rangeStart := _proxy.rangeStart;
	self.rangeEnd := _proxy.rangeEnd;
	self.myDebtor := _proxy.myDebtor;
	self.allAdditionChargeInvTypes.clear();
	_proxy.allAdditionChargeInvTypes.copy( self.allAdditionChargeInvTypes );
			
	self.mySurchargesAndExemptions := _proxy.mySurchargesAndExemptions;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeAdditionalCharges"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6f85ce90-56b5-4d4e-9f0e-fb329c186bab">
        <updating/>
        <source>setProxy(	_allAdditionalInvTypes : CM_InvoiceLineDescSet input;
			_myDebtor : CM_Debtor;
			_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
			_rangeStart : Real;
			_rangeEnd : Real
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

begin

	self.rangeStart := _rangeStart;
	self.rangeEnd := _rangeEnd;
	self.myDebtor := _myDebtor;
	self.allAdditionChargeInvTypes.clear();
	_allAdditionalInvTypes.copy( self.allAdditionChargeInvTypes );
			
	self.mySurchargesAndExemptions := _mySurchargeExemption;
			
epilog

end;</source>
        <Parameter name="_allAdditionalInvTypes" type="CM_InvoiceLineDescSet" usage="input"/>
        <Parameter name="_myDebtor" type="CM_Debtor"/>
        <Parameter name="_mySurchargeExemption" type="CM_InvoiceTypeSurchargeExempt"/>
        <Parameter name="_rangeStart" type="Real"/>
        <Parameter name="_rangeEnd" type="Real"/>
    </JadeMethod>
