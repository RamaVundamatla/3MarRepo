<Class name="JadeScriptPWSC" id="958ce5ea-2733-4a47-b83c-b457501a82ac">
    <superclass name="JadeScriptPW"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="pwSourceCompareBaseSchema" id="0741b627-0a5c-4e13-bad2-aa2d2248c0f6">
        <source>pwSourceCompareBaseSchema();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2021	navpw1	Initial creation

*/

vars
	agent	: DEV_SourceCompareFileAgent;
	
begin
	app.initialize();
	create agent transient;
	agent.doSanitiseScmFile("C:\JMT_Source\dmast\BaseSchema.scm", "BaseSchema", "dmast", "C:\temp\", true, true);

epilog
	delete agent;

end;</source>
    </JadeMethod>
