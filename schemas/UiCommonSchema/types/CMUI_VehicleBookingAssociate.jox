    <JadeMethod name="setupCarrierCombo" id="6a40d23b-07f5-44fb-bd52-8d5ea7a7cff8">
        <updating/>
        <source>setupCarrierCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.cmbCarrier.clear();
	
	self.myAssistant.comboBoxCarrierRoad( self.cmbCarrier, self.myCarrier );
	
	self.setupDriverCombo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDriverCombo" id="96e7f6f6-332f-4aa4-b315-6e828c5c747a">
        <updating/>
        <source>setupDriverCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	iter : Iterator;
	driver : CM_DriverDetails;

begin

	if self.myCarrier = null then
		self.cmbDriver.enabled := false;
		self.cmbDriver.clear();
		self.cmbDriver.addItem( app.getErrorString(AnyString) );
	
	else
		self.cmbDriver.clear();
		self.cmbDriver.enabled := true;
	
		self.cmbDriver.addItem( app.getErrorString(AnyString) );
		iter := self.myCarrier.allDrivers.createIterator;
		while iter.next( driver ) do
			if driver.myTerminal = self.myTerminal then
				self.cmbDriver.itemObject[self.cmbDriver.addItem( driver.name )] := driver;
			endif;
		endwhile;
		delete iter;
		
		if self.myDriver &lt;&gt; null then
			self.cmbDriver.listIndex := self.cmbDriver.findObject( self.myDriver );
		endif;
		
	endif;
	
	if self.cmbDriver.listIndex &lt; 1 then
		self.cmbDriver.listIndex := 1;
		self.myDriver := null;
	endif;
	
	self.setupVehicleCombo();

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a5c5d25f-54a6-4540-abb4-62313250b833">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	ts : TimeStamp;
	startTS : TimeStamp;
	endTS : TimeStamp;
	twelveHrs : TimeStampInterval;

begin
	
	inheritMethod();
	
	twelveHrs.set(0, ( 12 * 60 * 60000 ));
// PAR 33905	ts := app.actualTimeAppServer;
	self.centreOverParent(1);
	
	self.minimumWidth := 670;
	self.minimumHeight := 320;
	

	
	if self.myVehicleVisitRecord &lt;&gt; null then
		self.myCarrier := self.myVehicleVisitRecord.getCarrier;
		self.myDriver := self.myVehicleVisitRecord.myDriverDetails;
		self.myVehicle := self.myVehicleVisitRecord.vehicle;
		ts := self.systemToLocalTime(self.myVehicleVisitRecord.getArrivalTime());// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.myVehicleBookingTimeslot &lt;&gt; null then
		self.myCarrier := self.myProxyTrackedItem.myVehicleBookingTimeslot.myCarrier;
		self.myDriver := self.myProxyTrackedItem.myVehicleBookingTimeslot.myDriver;
		self.myVehicle := self.myProxyTrackedItem.myVehicleBookingTimeslot.myVehicle;
		ts := self.systemToLocalTime(self.myProxyTrackedItem.myVehicleBookingTimeslot.bookingTSstart);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	endif;
	
	if not ts.isValid then // PAR 33905
		ts := self.systemToLocalTime(app.actualTimeServer); // PAR 33905// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	
	startTS := ts - twelveHrs;
	endTS := ts + twelveHrs;
	
	self.txtDateStart.setDate( startTS.Date );
	self.txtTimeStart.setTime( startTS.Time );
	self.txtDateEnd.setDate( endTS.Date );
	self.txtTimeEnd.setTime( endTS.Time );
	
	self.setupCarrierCombo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupVehicleCombo" id="83b73c97-2ceb-4649-a858-324934ee5be5">
        <updating/>
        <source>setupVehicleCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	vehicle : CM_Vehicle;
	iter : Iterator;

begin

	if self.myDriver = null then
		self.cmbVehicle.enabled := false;
		self.cmbVehicle.clear();
		self.cmbVehicle.addItem( app.getErrorString(AnyString) );
		
	else
		self.cmbVehicle.enabled := true;
		self.cmbVehicle.clear();
		
		self.cmbVehicle.addItem( app.getErrorString(AnyString) );
		iter := self.myDriver.allVehicleMachines.createIterator;
		while iter.next( vehicle ) do
			self.cmbVehicle.itemObject[self.cmbVehicle.addItem( vehicle.regNumber )] := vehicle;
		endwhile;
		delete iter;
		
		if self.myVehicle &lt;&gt; null then
			self.cmbVehicle.listIndex := self.cmbVehicle.findObject( self.myVehicle );
		endif;
		
	endif;
	
	if self.cmbVehicle.listIndex &lt; 1 then
		self.cmbVehicle.listIndex := 1;
		self.myVehicle := null;
	endif;
	
	self.populateBookings();

epilog

	delete iter;

end;</source>
    </JadeMethod>
