    <JadeMethod name="dumpCallStack" id="79d84800-210d-4aeb-8c34-5390e2d8be6e">
        <source>dumpCallStack(pClassName: String);

vars
	ts: TimeStamp;
	callStack: ProcessStackArray;
	methCallDesc: MethodCallDesc;
	lMessage: String;
	processOidString: String;
begin
	processOidString := process.getOidString;
	create callStack;
	//	get the call stack for the current process
	process.currentStack(callStack);
	//	dump the call stack
	foreach methCallDesc in callStack do
		lMessage := app.name &amp; "." &amp; pClassName &amp; "::dumpCallStack " &amp; methCallDesc.getName() &amp; ' at position ' &amp;
																	   methCallDesc.position.String;
		JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Monitor_Note, true,
															ts.date.format("ddMMMyy ") &amp;
															ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
															processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
															lMessage);
	endforeach;
epilog
	callStack.purge;
	delete callStack;
end;</source>
        <Parameter name="pClassName" type="String"/>
    </JadeMethod>
