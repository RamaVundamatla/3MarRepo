    <JadeMethod name="delete" id="5109a782-ce05-456d-ab40-bca86e060882">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Each time a Package Interface is deleted, it's corresponding Service
//				Object (i.e. the receiver of this method in this case) will also be
//				deleted.  If this Service Object being deleted is the last one left
//				for the current Service Manager (there is only one Service Manager
//				object for each package), then we'll also delete that Manager object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	serviceManagerObj	: JSSServiceManagerObject;
	
begin
	if self.myServiceManager.isLastServiceInterface(self) then
		serviceManagerObj		:=	self.myServiceManager;	// Save a reference to the Manager object.
		self.myServiceManager	:=	null;					// Remove this Service object from the Manager's collection.
		serviceManagerObj.finalize();						// Perform any finalization tasks.
		delete serviceManagerObj;							// Delete the Manager object.
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getManager" id="9a8d67bf-fbb9-45b3-ad98-4fe9f3e70831">
        <source>getManager():JSSServiceManagerObject protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Return the receiver's service manager object.
//
// Parameters:	None
//
// Returns:		The service manager object
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceManager;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSServiceManagerObject"/>
    </JadeMethod>
    <JadeMethod name="getManagerClass" id="0c34eaa1-359c-447a-b30b-41caee071eaf">
        <source>getManagerClass():Class protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Return the class of the receiver.
//
// Parameters:	None
//
// Returns:		The receiver's class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	superclassObj	: Class;
	subclassObj		: Class;
	allSubclasses	: ClassNDict;
	
begin
	schemaObj		:=	self.class.schema;
	superclassObj	:=	schemaObj.getClass(JSSServiceManagerObject.name);
	allSubclasses	:=	superclassObj.getPropertyValue("subclasses").ClassNDict;
	
	if allSubclasses.size() = 0 then
		JSSException.raise_(JSS_EX_00002, "The Package's Service Manager subclass could not be found.");
	elseif allSubclasses.size() &gt; 1 then
		JSSException.raise_(JSS_EX_00003, "More than one Service Manager subclass was found for the Package.");
	else
		subclassObj		:=	allSubclasses.first();
	endif;
epilog
	return subclassObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
