    <JadeMethod name="registerMachine" id="a0efdd6d-de86-4ff9-8f41-20172f0e9c72">
        <updating/>
        <source>registerMachine() updating, protected;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
08 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	machineId		: String;
	
begin
	machineId := self.txtMachine.text.trimBlanks();
	if machineId = null then
		app.msgBox("Machine ID must not be null", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	self.myMachine := self.myControl.allMachines[machineId];
	
	if self.myMachine = null then
		beginTransaction;
		create self.myMachine persistent;
		self.myMachine.machineName := machineId;
		self.myMachine.myITSServer := self.myControl;
		commitTransaction;
	endif;
	
	endNotificationForSubscriber(self);
	self.beginNotification(self.myMachine, ITSMachine.ReceiveMessageFromJMT, Response_Continuous, null);
	
	self.registerForStartStop();
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
