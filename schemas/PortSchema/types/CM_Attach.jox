    <JadeMethod name="getDisplayStringForAttribute" id="7760a0df-179e-4219-8897-1dab95c9ee48">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			if self.otherTrackedItem &lt;&gt; null
			and self.otherTrackedItem.isKindOf(CM_Generator) 
			and ( self.otherTrackedItem.CM_Generator.isNoseMounted or self.otherTrackedItem.CM_Generator.isUnderSlung )
			then
				
				lDetail := app.getErrorString(CM_Generator_GC);
				lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
				lDetail := lDetail &amp; " " &amp; app.getErrorString(Attached);
			
			else
			
				lDetail :=  "Attached To";
				if self.getOtherTrackedItem() &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
				endif;
				
			endif;
		
			if lDetail &lt;&gt; "" then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			else
				lDetail := self.urNumber.String;
			endif;			
			
			return lDetail;
			
		endif;
	elseif _attrName = ETRow_AttachedId then
		if self.getOtherTrackedItem() &lt;&gt; null then
			return self.otherTrackedItem.id;
		else
			return null;
		endif;

	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="4d7a98ec-3983-49cc-bf44-728a037ec590">
        <source>getEnquiryRow(): String ;
// ---------------------------------------------------------------------------
// Created: May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
	
begin

	lDetail := inheritMethod();

	//Par17775. ccms1045 APM - Yard Ops, new generator types.
	if self.otherTrackedItem &lt;&gt; null
	and self.otherTrackedItem.isKindOf(CM_Generator) 
	and ( self.otherTrackedItem.CM_Generator.isNoseMounted or self.otherTrackedItem.CM_Generator.isUnderSlung )
	then
		
		lDetail := lDetail &amp; app.getErrorString(CM_Generator_GC);
		lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
		lDetail := lDetail &amp; " " &amp; app.getErrorString(Attached);
	
	else
	
		lDetail := lDetail &amp; "Attached To";
		if self.getOtherTrackedItem() &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
		endif;
		
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
