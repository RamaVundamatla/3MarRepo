    <JadeMethod name="setVoyageCode" id="fc87246c-f165-4149-a986-c3378126229e">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;

/*
Date			Who		Reason
14/01/2011		cnwrs1	CCMS1976
*/
	
vars
	updateColl	:Boolean;
	oldValue,
	newValue	:String;
	config		:CM_EDIConfig;
	coll 		:CM_EDITIsByVoyageCodeDict;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	updateColl 	:= not self.isTransient;
	oldValue	:= self.voyageCode.toUpper;
	config		:= self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	// remove the previous non-null value from this collection - only if not transient
	if updateColl and oldValue &lt;&gt; null and coll &lt;&gt; null then
		if coll.includesKey( self.voyageCode.toUpper, self ) then
			coll.removeKeyEntry( self.voyageCode.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null and not transient).
	self.voyageCode	:= _value[ 1 : self.voyageCode.maxLength ];
	newValue		:= self.voyageCode.toUpper;
	
	if updateColl and newValue &lt;&gt; null and coll &lt;&gt; null then
		if not coll.includesKey( newValue, self ) then
			coll.putAtKey( newValue, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateVesselVoyage" id="17f89116-22d2-452f-acbe-a3097d9067f7">
        <updating/>
        <source>translateVesselVoyage(_xlationOperator: CM_Operator) updating, protected;
/*
Date		Who		Reason
11 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	vesselName, 
	voyageDesc, 
	voyageCode	: String;
	foundMatch	: Boolean;
begin
	
	//Moved up
	if _xlationOperator = null then													//21.11.2022 navma1 #55424
		return;
	endif;
	
	// if we already have a valid voyageCode then dont do anything
	voyageCode := self.getVoyageCode();
	
	if voyageCode &lt;&gt; null then
		if self.getMyTerminal.lookupVoyage(voyageCode, null, false) &lt;&gt; null then
			return;
		endif;
	endif;

	// we previously saved the raw input in extra data
	//global.getExtraData (self.allExtraData, ETRow_VoyageCode, voyageDesc);    //21.11.2022 navma1 #55424
	voyageDesc := self.rawDataVoyageCode;										//21.11.2022 navma1 #55424
	
	// have set vesselName to the actual name not the code 
	vesselName 	:= self.vesselName;
	
	//if we have a vessel name then try to translate
	voyageCode 	:= _xlationOperator.getXlationSystemCode_Voyage(voyageDesc, vesselName, null, null, foundMatch);
	
	self.voyageCode := voyageCode;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
