    <JadeMethod name="updateIMVVehicleConfig" id="cdc31e84-0b6b-42f1-892c-22115a5accac">
        <source>updateIMVVehicleConfig( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2022	jlier1	Initial creation 52741

*/

vars
	rtConfig : CM_RTVehicleConfig;
	defaultPrimary : Boolean;	
	theEntDef : EntTableDef;
	theEntView : EntTableView;
	theName : String;
begin
	//not doing script been run at all because will only update imv configs with no primary task fields
	//if self.hasScriptBeenRunAtAll(method.name, _controller) then
	//	return;
	//endif;

	app.writeLog( method.qualifiedName &amp; 'Converting IMV rt configs to have weight and O/D in the primary task fields ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting IMV rt configs to have weight and O/D in the primary task fields ") ;	
	endif;
	theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];
	
	foreach rtConfig in CM_RTVehicleConfig.instances discreteLock do
		defaultPrimary:=false;
		if rtConfig.myPrimaryTaskFields &lt;&gt; null and rtConfig.myPrimaryTaskFields.allEntTableRows.size &gt; 0 then
			continue;
		endif;
		if rtConfig.myMachine &lt;&gt; null then
			if rtConfig.myMachine.machineType = MACHINETYPE_IMV then
				defaultPrimary:=true;
			else
				continue;
			endif;
		endif;
		
		if rtConfig.myTerminalMachineType &lt;&gt; null and rtConfig.myTerminalMachineType.myMachineType &lt;&gt; null and rtConfig.myTerminalMachineType.myMachineType.type = MACHINETYPE_IMV then
			defaultPrimary:=true;
		endif;
		
		if defaultPrimary then
			beginTransaction;
			if rtConfig.myPrimaryTaskFields = null then
				create theEntView persistent;
				rtConfig.setPropertyValue(CM_RTVehicleConfig::myPrimaryTaskFields.name,theEntView);
				theName:=rtConfig.getUniqueViewName&amp; "primary tasks";
				rtConfig.myPrimaryTaskFields.set(theName,theName,theEntDef);
			endif;
			
			rtConfig.myPrimaryTaskFields.addRowByName(ETRow_Weight);
			rtConfig.myPrimaryTaskFields.addRowByName(ETRow_IsOverDimension);
			commitTransaction;
		endif;
	endforeach;
	
	
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateOperator" id="514d894d-d120-4080-a606-93bbdbbb8556">
        <source>updateOperator(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2022	navhl20	ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?

*/

vars
	operator	: CM_Operator;
	desc : String;
	isAvail : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Update Booking Discrepancies in Operator ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Booking Discrepancies in Operator ") ;
	endif;
	
	beginTransaction;
	foreach operator in CM_Operator.instances do
		foreach desc in operator.allAttribForBookingRefDiscrep do
			if desc = "Controlled Atmosphere and Curtains In" then
				isAvail := true;
			endif;
		endforeach;
		if isAvail then
			operator.allAttribForBookingRefDiscrep.remove("Controlled Atmosphere and Curtains In");
			operator.allAttribForBookingRefDiscrep.add("Curtains In");
			operator.allAttribForBookingRefDiscrep.add("CO2");
			operator.allAttribForBookingRefDiscrep.add("O2");
			isAvail := false;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Booking Discrepancies in Operator", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Booking Discrepancies in Operator") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateRemoveJadeFromTooltips" id="6e1b1d2a-4d57-43fb-9d35-3958e88bc0be">
        <source>updateRemoveJadeFromTooltips(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 01SEP2025
ADO - JIRA 35719
*/


vars
       iter01 : Iterator;
       menuItem : CM_MenuUserToolbar;
       oArray : ObjectArray;
       newTooltip : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Remove 'JADE' from tooltips", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Remove 'JADE' from tooltips") ;	
	endif;
	
    create oArray transient;	
    CM_MenuUserToolbar.allInstances(oArray,0,false);
    iter01 := oArray.createIterator;
	
	beginTransaction;
	
      while iter01.next(menuItem) do
		  if menuItem.toolTip.pos("Jade",1) &gt; 0 then
			 newTooltip := menuItem.toolTip.removeSubstringPlusExtraChars("Jade",0);
			 menuItem.setPropertyValue("toolTip", newTooltip);
		  endif;

       endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all tooltips cleansed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all tooltips cleansed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
   delete oArray;
   delete iter01;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
