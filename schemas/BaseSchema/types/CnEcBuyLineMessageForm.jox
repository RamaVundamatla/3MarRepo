    <JadeMethod name="loadForm" id="d124e8f5-bda5-413f-a9f8-bd0468aa7970">
        <updating/>
        <source>loadForm() updating;

vars
	rootObj			: CnEcBaseRoot;
	managerObj		: CnEcBNZBuyLineMgr;
	
begin
	inheritMethod();
	
	rootObj		:=	app.myBaseRoot;	 
	managerObj	:=	rootObj.myBuyLineMgr;
	
	txtServer.text	:=	managerObj.buyLineServer;
	txtPath.text	:=	managerObj.buyLinePath;
end;</source>
    </JadeMethod>
