<GUIClass name="CMUI_OrganizeMenuRoots" id="4872d839-d8ff-4e4f-a93e-23e0f9955d27">
    <superclass name="CMUI_OrganizeMenu"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allMenuRootsArray" id="a22f6aed-07df-4724-baa8-46095da4ebfd">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="dblClick" id="fd2acdbe-3b9f-4c6c-84e9-d7c4d5ab7e4f">
        <controlMethod name="Form::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dblClick() updating;
//----------------------------------------------------------------
//	Created:	09 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " "  );
	self.lstBox.displayTree(true, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="displayMenuRoots" id="2789e9c3-350a-495c-9c8f-0db640169db8">
        <source>displayMenuRoots() protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuRoot			: CM_MenuRoot;
	idx					: Integer;
	obj					: Object;
begin
	self.lstBox.clear();
	self.lstBox.sorted := false;
	foreach obj in self.allMenuRootsArray do
		menuRoot := obj.CM_MenuRoot;
		idx := self.lstBox.addItem(menuRoot.getHeading);
		self.lstBox.itemObject[idx] := menuRoot;
		self.lstBox.itemPicture[idx] := menuRoot.pictureButton;
	endforeach;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="ef2f9867-48fb-4d6b-8ba8-45e9808163fd">
        <updating/>
        <source>doDragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if (self.dragOverIndex = self.origIndex)
	or (self.dragOverIndex &lt; 1)
	or (self.origIndex &lt; 1)
	or (self.myPickupEntity = null)
	then
		return;
	endif;
    
    self.allMenuRootsArray.removeAt(self.origIndex);
    
    if self.dragOverIndex &gt; self.allMenuRootsArray.size then
    	self.dragOverIndex := self.allMenuRootsArray.size;
    endif;
    
	self.allMenuRootsArray.insert(self.dragOverIndex, self.myPickupEntity);
	self.displayMenuRoots();
end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="232d02d0-7413-4af4-b21c-04b0118211a5">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user					: CM_User;
	userTerminalRoot		: CM_MenuRootUserTerminal;
	obj						: Object;
	idx						: Integer;
begin
	user := app.getMyUser();
	if user = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Application's current user returned null");
		self.doCancel;
	endif;
	//copy the roots back in order - record the desired position of the system items menu
	beginTransaction;
	user.allUserMenuRoots.clear();
	foreach idx in 1 to self.allMenuRootsArray.size do
		obj := self.allMenuRootsArray[idx];
		if CM_MenuRootForUser.hasInstance(obj) then
			obj.CM_MenuRootForUser.setPosition(idx);
		elseif CM_MenuRootUserTerminal.hasInstance(obj) then
			user.allUserMenuRoots.add(obj.CM_MenuRootUserTerminal);	
		endif;
	endforeach;
	commitTransaction;
	
	self.modalResult := IDOK;
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectPicture" id="08a7e2d5-fa9c-4ce5-9bcc-24f2733611b4">
        <updating/>
        <source>doSelectPicture(menuItem: MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	09 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(menuItem);
	self.displayMenuRoots();
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="45868bd7-32e6-4c1c-897d-3353fc5badda">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user					: CM_User;
	sysMenuRoot				: CM_MenuRootForUser;
	pos						: Integer;
begin
	self.width := 250;
	self.height := 400;

	inheritMethod();
	self.btnCancel.visible := true;
//	self.btnCancel.distanceFromRight := 80;
//	self.btnOk.distanceFromRight := 220;
	self.caption := 'Organize Terminals...';	
	self.lstBox.clear();
	
	user := app.getMyUser();
	self.allMenuRootsArray.clear();
	user.allUserMenuRoots.copy(self.allMenuRootsArray);
	sysMenuRoot := user.myMenuRootForSysEntities;
	if sysMenuRoot &lt;&gt; null then //they may not have a system security role
		pos := sysMenuRoot.position;
		if pos &lt; 1 or pos &gt; self.allMenuRootsArray.size then //add it on the end by default
			self.allMenuRootsArray.add(sysMenuRoot);
		else
			self.allMenuRootsArray.insert(sysMenuRoot.position, sysMenuRoot);
		endif;
	endif;
	
	self.displayMenuRoots();

	self.modalResult := IDCANCEL;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="da0cf8d7-0df7-412b-aff8-4e87be5bb491">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017436, locale);
end;</source>
    </JadeMethod>
</GUIClass>
