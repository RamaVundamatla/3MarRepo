    <JadeMethod name="setRawDataString" id="90e0c0f6-346f-42af-92ab-7c58b187178c">
        <updating/>
        <source>setRawDataString(_stringData :String) updating;
//
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData
//
vars

begin
	if _stringData = null then
		return;
	else	
		self.rawData.appendData(_stringData.compressToBinary(Binary.Compression_ZLib));		
	endif;

epilog

end;</source>
        <Parameter name="_stringData" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRunDateTime" id="b0dcb529-be19-4af2-b2e3-c68158d2f0bf">
