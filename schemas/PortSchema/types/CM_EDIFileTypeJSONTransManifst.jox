    <JadeMethod name="create" id="e753337e-2175-4b5b-aef6-89fbfd73fad3">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint

*/

vars

begin
	self.name := "Transport Manifest";
	self.type := EDIFileType_TransportManifest;
	
epilog

end;</source>
