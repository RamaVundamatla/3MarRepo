    <JadeMethod name="cellInputReady" id="cfa3855e-0551-4c9e-beef-46b784635d6e">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#		Description
============================================================================
15/10/2013	NDL		Par 32803 	Increase column number from 3 to 4.
30/11/2018	jlgka1	41225		Increase column number from 4 to 5.
============================================================================*/
vars
	theHeight			: Real;
begin
	inheritMethod(table, inputControl, cleft, ctop, cwidth, cheight);

	if table.row = table.rows and table.column = 5 then	// jlgka1 TFS 41225
		self.addDamageRow(null);//add new row for entry
	endif;
		
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
