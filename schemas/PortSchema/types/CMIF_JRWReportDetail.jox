<Class name="CMIF_JRWReportDetail" id="0a7e0e35-488f-4b97-b3f0-18a016f8612c">
    <superclass name="CMIF_ReportExtraDetail"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <PrimAttribute name="jrwDesignName" id="71a1dec8-a8a2-4e60-a249-5d86cd3355e2">
        <length>36</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="terminal" id="30cedbee-266c-442d-93ae-5b78d56c8c3b">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="70b2eb2b-98ad-4c9f-a189-3e648e4e36e1">
        <updating/>
        <source>cloneReferences(_proxyDetail : SelfType; _isTransient : Boolean) updating;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.terminal := _proxyDetail.terminal;

end;</source>
        <Parameter name="_proxyDetail" type="SelfType"/>
        <Parameter name="_isTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReportName" id="65a28250-bfed-4d08-8305-1db74d809a7f">
        <source>getReportName(): String;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.jrwDesignName;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupReport" id="141d33c7-80f1-45c2-a59c-a6a328f36064">
        <source>setupReport(): JadeReportWriterReport;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rm		: JadeReportWriterManager;
	rep		: JadeReportWriterReport;
begin

	rm := app.createReportWriterManager();
	rep := rm.getReport(self.jrwDesignName);
	
	if rep = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'report design (' &amp; self.jrwDesignName &amp; ') not found');
	endif;
	
	return rep;

epilog
	delete rm;
end;</source>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
</Class>
