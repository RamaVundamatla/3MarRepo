<Class name="WS_PostUnpackRequest" id="583d04b5-be92-4a5f-ae6a-fe1d33d95091">
    <superclass name="WS_RestRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="cargo" id="6eabcf01-d9df-44db-804e-ad992837f0fa">
        <memberTypeInverse/>
        <type name="WS_RestUnPackCargoObjArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="complete" id="2c31a73a-faff-416a-a964-9646576a588b">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="parent" id="77c4858d-199f-4305-8b15-4591188b795b">
        <embedded/>
        <type name="WS_RestUnPackCargoObject"/>
    </ImplicitInverseRef>
    <JadeMethod name="validateRequest" id="9ebd83ab-7393-4bc8-985d-32cecb31ad43">
        <source>validateRequest(_validParentTi : CM_TrackedItem output; _validChildTis : CM_ObjectSet input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 September 2024	navsp1	ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
08 October   2024   navsp1  JIRA 33031 CUX | Pack and Unpack APIs Issue
*/

vars
	parentCargo				: WS_RestUnPackCargoObject;
	childCargoArray			: WS_RestUnPackCargoObjArray;
	childCargoItem			: WS_RestUnPackCargoChildObject;
	cargoType				: CM_CargoType;
	parentCargoFound		: CM_TrackedItem;
	terminal				: CM_Terminal;
	validParent				: Boolean;
	childCMIF				: CMIF_UnPackingCargoChild;
begin
	terminal := app.myPassport.myTerminal;
	
	parentCargo := self.parent;
	
	validParent := true;

	if parentCargo = null then																												//JIRA 33031
		app.myPassport.addErrorFull(Canno_find_suita_paren_cargo_u, app.getErrorString(Canno_find_suita_paren_cargo_u), null, null, null);	//JIRA 33031
		return false;																														//JIRA 33031
	endif;																																	//JIRA 33031
	
	// Validate Request (check for required fields)
	if parentCargo.id = null then
		app.myPassport.addErrorFull(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, ParentCargoID), ETRow_Name, null, null);
		validParent := false;	
 	endif;
	
	if parentCargo.cargoTypeId = null then
		app.myPassport.addErrorFull(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, ParentCargoType), ETRow_Name, null, null);
		validParent := false;
  	endif;
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(parentCargo.cargoTypeId);
	
	if cargoType = null then
		app.myPassport.addErrorFull(Cargo_speci_track_item_not_val, app.getErrorString2(Cargo_speci_track_item_not_val, parentCargo.cargoTypeId, parentCargo.id), null, null, null);
		validParent := false;
 	else
		parentCargoFound := terminal.lookupTrackedItem(parentCargo.id, cargoType.id, TI_STATE_NORMAL, null, true);
	endif;
	
	if parentCargoFound = null then 
		app.myPassport.addErrorFull(Canno_find_suita_paren_cargo_u, app.getErrorString(Canno_find_suita_paren_cargo_u), null, null, null);
		validParent := false;
	endif;
	
	if validParent then
		_validParentTi := parentCargoFound;
	else
		return false; // No point going further if we dont have parent to un-pack the child
	endif;
	
	
	// CHECK THE CHILD CARGO
	
	childCargoArray := self.cargo;
	
	// Check we actually have some child cargo
	if childCargoArray = null or childCargoArray.isEmpty then
		app.myPassport.addErrorFull(No_Cargo_to_UnPack, app.getErrorString(No_Cargo_to_UnPack), null, null, null);
	endif;
	
	// Validate the child cargo items
	foreach childCargoItem in childCargoArray do			
		childCMIF := childCargoItem.validateRequest(parentCargoFound);	//JIRA 33031
		if childCargoItem.isValid and childCMIF &lt;&gt; null then
			_validChildTis.add(childCMIF);
		endif;
	endforeach;

	if app.myPassport.hasErrors then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_validParentTi" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_validChildTis" type="CM_ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
