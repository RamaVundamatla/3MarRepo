    <JadeMethod name="deleteVoyageDelay" id="3da4fd76-bc71-4529-b8fb-8ed072888c57">
        <source>deleteVoyageDelay(_startTS, _endTS, _estEndTS : TimeStamp; _voyage : CM_Voyage);
/*

Purpose:	Delete voyage delay		

Parameters:					

Date		Who		Reason
15/03/2018	jlgmh5	Initial creation

*/

vars

	delay					: CM_Delay;

begin
		
	if _startTS = null or _voyage = null then
		return;
	endif;
	
	foreach delay in _voyage.allDelays where delay.startDT = _startTS and delay.endDT = _endTS and
			delay.estEndDT = _estEndTS do
		app.myTrxDA.trxDeleteDelay(delay, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
