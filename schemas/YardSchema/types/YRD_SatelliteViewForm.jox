        <source>cmbYA_click(combobox: ComboBox input) updating;
/*
Purpose: User has selected a YA so need to update the graphic pane

Date		Who		Reason
27 April 2011	cnwdw1	CCMS CPL 2052
*/
vars

begin
	self.doYASelected(combobox.listObject.CM_YardAllocation);
epilog

end;</source>
