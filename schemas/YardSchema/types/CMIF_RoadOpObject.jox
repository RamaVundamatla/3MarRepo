    <JadeMethod name="getAllGateLanes" id="933d38e7-e649-4741-bfd6-acb72f08c5e8">
        <source>getAllGateLanes(_coll :CM_ObjectArray input)protected;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	obj		:Object;
begin
	create coll transient;
	
	self.getAllGateAreas (coll);
	
	foreach obj in coll do 
		obj.CM_GateArea.getAllLaneControllers (_coll);		
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
