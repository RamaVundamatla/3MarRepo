    <JadeMethod name="convertFor724" id="47485818-e423-487b-909f-9e855adec053">
        <updating/>
        <source>convertFor724() updating;
//----------------------------------------------------------------
//	Created:	04 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.useLongSeal then
		self.maxSealLength := 15;
	else
		self.maxSealLength := 10;
	endif;

end;</source>
    </JadeMethod>
