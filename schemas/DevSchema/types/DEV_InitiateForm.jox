    <JadeMethod name="showProgress" id="f9c2846c-2950-4c92-a3e0-33dcedbc589c">
        <updating/>
        <source>showProgress(_partsToDo, _totalParts : Integer; _message : String) updating;
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.writeLog(_message, LogINFO);
	self.prbInitialize.partsDone := _partsToDo;
	self.prbInitialize.partsInJob := _totalParts;
