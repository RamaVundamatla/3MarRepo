    <JadeMethod name="cmbVesseln_displayEntry" id="cdbb63a6-d13e-4357-bd8e-bba04f7903a2">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVesseln_displayEntry(combobox: ComboBox input; pVessel: CM_Vessel; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	failedDAC  : CM_DataAccessController; 

begin

	if pVessel = null then
		return null;
	endif;
	
	if (not pVessel.canCreateVoyages) then
		return null;
	endif;
	if (not pVessel.isBarge) then
		return null;
	endif;
	
	if not pVessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;
	
	return pVessel.code &amp; Tab &amp; pVessel.name;		
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="709a940c-ca87-403f-a067-83fc9d85872e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	self.permissionView  := PmShipBargeCopy;
	self.permissionMaint := PmShipBargeCopy;
	self.helpFileName := HelpFile_Voyage;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableDisableCargoFields" id="c4dac350-deab-41ee-aeef-de6ffae03ff7">
        <updating/>
        <source>doEnableDisableCargoFields(_enable : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	idx : Integer;
	textBoxCargoId : CMUI_TextBox;
	comboCargoType : CMUI_ComboBoxCargoTypeForTerm;
	comboCargoSubType : CMUI_ComboProduct;
	meas : CMUI_MeasurementTable;
	comboStow : CMUI_ComboSpecialStow;

begin
	self.lblCargoType.enabled := _enable;
	self.cmbCargoType.enabled := _enable;
	self.cmbCargoSubtype.enabled := _enable;
	self.txtTotalWeight.enabled := _enable;
	self.cmbSpecialStow.enabled := _enable;
	if not _enable then
		self.cmbCargoType.listIndex := -1;
		self.cmbCargoSubtype.clear;
		self.cmbCargoSubtype.listIndex := -1;
		self.txtTotalWeight.setup(Type_Weight, self.backColor);
		self.cmbSpecialStow.listIndex := -1;
	endif;
	
	// and copied controls
	while true do
		idx := idx + 1;
		textBoxCargoId := self.txtCoden.getControl(idx);
		if textBoxCargoId = null then
			break;
		endif;
		textBoxCargoId.enabled := _enable;
		if _enable and textBoxCargoId.text = null then
			textBoxCargoId.text := self.myAssistant.generateCargoIdForBargeCargo(self.txtVoyageCode.text.trimBlanks, self.txtTotal.text.trimBlanks.Integer, self.cmbVesseln.getControl(idx).CMUI_ComboBox.listObject.CM_Vessel);
		endif;
		
		comboCargoType := self.cmbCargoTypen.getControl(idx).CMUI_ComboBoxCargoTypeForTerm;
		comboCargoType.enabled := _enable;
		comboCargoSubType := self.cmbCargoSubtypen.getControl(idx).CMUI_ComboProduct;
		comboCargoSubType.enabled := _enable;
		meas := self.txtTotalWeightn.getControl(idx).CMUI_MeasurementTable;
		meas.enabled := _enable;
		comboStow := self.cmbSpecialStown.getControl(idx);
		comboStow.enabled := _enable;
		
		if not _enable then
			textBoxCargoId.text := null;
			comboCargoType.listIndex := -1;
			comboCargoSubType.listIndex := -1;
			comboCargoSubType.clear;
			meas.setup(Type_Weight, self.backColor);
			comboStow.listIndex := -1;
		endif;
	endwhile;
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="c382a7c5-2c21-4d56-bde2-774babec66fc">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	if self.doSave then
		inheritMethod();	//closes the form
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="28c727d0-a4d8-4eba-aa95-0d71ebff773c">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417
27 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	prefix : String;
	number : Integer;
	msg : String;
	index : Integer;
	combo : CMUI_ComboBox;
	//txt : CMUI_TextBox;			// TFS 50878
	lbl : CMUI_Label;				// TFS 50878
	vessel : CM_Vessel;
	voyageCode : String;
	vesselArray : CM_ObjectArray;
	voyageCodeArray : StringArray;
	pxyVoyage : CM_Voyage;
	allPxyVoyages : CM_VoyageArray;
	result : Integer;
	tiArray : CM_TIArray;			// TFS 50878
	tis : Boolean;					// TFS 50878
	
begin

	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	
	if number &gt; 30 then
		msg := app.getErrorString1( Maximum_value, "30" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtTotal.setFocus();
		return false;
	elseif number = 1 then
		msg := app.getErrorString1( Must_least, "2" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtTotal.setFocus();
		return false;
	elseif prefix.length &gt; 18 and number &gt; 9 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVesseln.caption, "18, when " &amp; self.lblTotal.caption &amp; " &gt; 9 ");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
		return false;
	endif;
	
	create vesselArray transient;
	create voyageCodeArray transient;
	create tiArray transient;						// TFS 50878
	self.setCargoDetails(tiArray);					// TFS 50878
	// TFS 50878 validation
	if self.chkCreateCargo.value then
		foreach index in 1 to tiArray.size do
			if tiArray[index] &lt;&gt; null then
				tis := true;
				break;
			endif;
		endforeach;
		if tiArray.isEmpty or not tis then
			app.msgBox(app.getErrorString(Create_cargo_no_details), app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	// TFS 50878 end of validation
	
	foreach index in 2 to number do
		combo := self.cmbVesseln.getControl( index ).CMUI_ComboBox;
		//txt := self.txtCoden.getControl( index ).CMUI_TextBox;			// TFS 50878
		lbl := self.lblVesseln.getControl( index ).CMUI_Label;				// TFS 50878
		vessel := combo.listObject.CM_Vessel;
		//voyageCode := txt.text;											// TFS 50878
		voyageCode := lbl.caption;											// TFS 50878
		if vessel = null then
			msg := "Must Select a Vessel for " &amp; voyageCode;
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			combo.setFocus();
			return false;
		endif;
		vesselArray[index - 1] := vessel;
		voyageCodeArray[index - 1 ] := voyageCode;
	endforeach;
	
	create allPxyVoyages transient;
	foreach index in 1 to vesselArray.size do
		pxyVoyage := self.myCurrentBarge.pxyFromBargeUsingVesselAndCode( vesselArray[index].CM_Vessel, voyageCodeArray[index], self.myTerminal );
		allPxyVoyages.add( pxyVoyage );
	endforeach;
	
	while true do
		app.mousePointer :=	Busy;
		//app.myTrxCA.trxCreateBargeCopies( allPxyVoyages, self.myCurrentBarge, app.myPassport );			// TFS 50878
		app.myTrxCA.trxCreateBargeCopies( allPxyVoyages, self.myCurrentBarge, tiArray, app.myPassport );	// TFS 50878
		
		if app.myPassport.trxCompletedOK then
			return true;
			break;
			
		else
			app.mousePointer :=	Idle;
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				// build carog details again because we may have removed some proxies from the array already
				tiArray.clear;
				self.setCargoDetails(tiArray);
				continue;
			endif;
	
		endif;
		return false;
		
	endwhile;
	
	return false;

epilog

	if allPxyVoyages &lt;&gt; null then
		allPxyVoyages.purge();
	endif;
	delete allPxyVoyages;
	delete vesselArray;
	delete voyageCodeArray;
	delete tiArray;						// TFS 50878

	app.mousePointer :=	Idle;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onCargoSubTypeChange" id="de2f70b7-a308-415a-a323-e01edf702395">
        <source>onCargoSubTypeChange(_index : Integer; _cargoSubType : CM_Product);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	measureType : CM_MeasurementType;
	textWeight : CMUI_MeasurementTable;

begin
	if _cargoSubType = null then
		return;
	endif;
	
	if _index &lt;&gt; null then
		textWeight := self.txtTotalWeightn.getControl(_index);
	else
		textWeight := self.txtTotalWeight;
	endif;
	
	if textWeight = null then
		return;
	endif;
	
	if _cargoSubType.myCargoType.isTrackByVolume then
		if _cargoSubType.getMyVolume &lt;&gt; null and _cargoSubType.getMyVolume.myMeasurementType &lt;&gt; null then
			measureType := _cargoSubType.getMyVolume.myMeasurementType;
			if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
				textWeight.setup(Type_Volume, self.backColor);
				textWeight.setValues(Space &amp; measureType.shortName);
			endif;
		endif;
	else
		if _cargoSubType.getMyWeight &lt;&gt; null and _cargoSubType.getMyWeight.myMeasurementType &lt;&gt; null then
			measureType := _cargoSubType.getMyWeight.myMeasurementType;
			if measureType &lt;&gt; self.txtTotalWeight.getMeasurementType then
				textWeight.setup(Type_Weight, self.backColor);
				textWeight.setValues(Space &amp; measureType.shortName);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="onCargoTypeChange" id="3349be44-a280-428f-b440-b3516cd63ca1">
        <source>onCargoTypeChange(_index : Integer; _cargoType : CM_CargoType);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	comboSubType : CMUI_ComboProduct;
	textWeight : CMUI_MeasurementTable;

begin
	if _index &lt;&gt; null then
		comboSubType := self.cmbCargoSubtypen.getControl(_index).CMUI_ComboProduct;
		textWeight := self.txtTotalWeightn.getControl(_index);
	else
		comboSubType := self.cmbCargoSubtype;
		textWeight := self.txtTotalWeight;
	endif;
	
	if comboSubType &lt;&gt; null then
		comboSubType.setCargoType(_cargoType);
		comboSubType.initialise(true);
	endif;
	
	if textWeight &lt;&gt; null and _cargoType &lt;&gt; null then
		if _cargoType.isTrackByWeight and _cargoType.myWeightMeasurementType &lt;&gt; textWeight.getMeasurementType then
			textWeight.setup(Type_Weight, self.backColor);
			textWeight.setValues(Space &amp; _cargoType.myWeightMeasurementType.shortName);
		elseif _cargoType.isTrackByVolume and _cargoType.myVolumeMeasurementType &lt;&gt; self.txtTotalWeight.getMeasurementType then
			textWeight.setup(Type_Volume, self.backColor);
			textWeight.setValues(Space &amp; _cargoType.myVolumeMeasurementType.shortName);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="onVesselChange" id="d8c829e9-9c24-4329-89bb-bfbf22d63b80">
        <source>onVesselChange(_idx : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	vesselCombo : CMUI_ComboBox;
	vessel: CM_Vessel;
	prefix, vesselName, vesselChar, cargoID : String;
	number, padLength : Integer;

begin
	vesselCombo := self.cmbVesseln.getControl(_idx);
	if vesselCombo = null then
		return;
	endif;
	
	vessel := vesselCombo.listObject.CM_Vessel;
	if vessel = null then
		return;
	endif;
	
	// generate the cargo ID 
	cargoID := self.myAssistant.generateCargoIdForBargeCargo(self.txtVoyageCode.text.trimBlanks.toUpper, self.txtTotal.text.Integer, vessel);
	/*prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	if number &lt; 10 then
		padLength := 1;
	else
		padLength := 2;
	endif;
	
	vesselName := vessel.code;
	vesselChar := vesselName[vesselName.length-2:end];
	if vesselChar.isInteger then
		cargoID := (prefix &amp; vesselChar);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	else
		cargoID := (prefix &amp; vesselName);
		cargoID.replaceChar(Space.Character, CN_UNDERSCORE);
	endif;*/
	self.txtCoden.getControl(_idx).CMUI_TextBox.text := cargoID;
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="reDisplayVessels" id="beb08fe2-febb-4417-81b8-161f0c866d71">
        <updating/>
        <source>reDisplayVessels( _prefix : String; _number : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417
27 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	label : CMUI_Label;
	combo : CMUI_ComboBox;
	txt : CMUI_TextBox;
	index : Integer;
	labelLeft : Real;
	labelTop : Real;
	labelWidth : Real;
	labelHeight : Real;
	comboLeft : Real;
	comboTop : Real;
	comboWidth : Real;
	comboHeight : Real;
	padLength : Integer;
	offsetDown : Real;
	voyCode : String;
	
	// TFS 50878 vars
	vessel : CM_Vessel;
	vesselName, vesselChar, cargoId : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	weight : String;
	specialStow : CM_SpecialStow;
	cargoTypeCombo : CMUI_ComboBoxCargoTypeForTerm;
	cargoSubTypeCombo : CMUI_ComboProduct;
	stowCombo : CMUI_ComboSpecialStow;
	weightTbl : CMUI_MeasurementTable;
	// TFS 50878 end

begin

	if _number &gt; 9 then
		padLength := 2;
	endif;
	offsetDown := 25;

	if _number &gt; 30 or _number &lt; 2 then
		self.picCopyVessels.visible := false;
		self.btnOk.visible := false;
		return;
	endif;
	
	self.picCopyVessels.visible := true;
	self.btnOk.visible := true;
	
	//hide any previous cloned controls higher than our new value.
	if _number &lt; 30 then
		foreach index in 30 to _number do
			label := self.lblVesseln.getControl( index ).CMUI_Label;
			if label &lt;&gt; null then
				label.visible := false;
				label.caption := null;
			endif;
			combo := self.cmbVesseln.getControl( index ).CMUI_ComboBox;
			if combo &lt;&gt; null then
				combo.visible := false;
				combo.listIndex := -1;
			endif;
			// TFS 50878 start
			cargoTypeCombo := self.cmbCargoTypen.getControl(index).CMUI_ComboBoxCargoTypeForTerm;
			if cargoTypeCombo &lt;&gt; null then
				cargoTypeCombo.visible := false;
				cargoTypeCombo.listIndex := -1;
			endif;
			cargoSubTypeCombo := self.cmbCargoSubtypen.getControl(index).CMUI_ComboProduct;
			if cargoSubTypeCombo &lt;&gt; null then
				cargoSubTypeCombo.visible := false;
				cargoSubTypeCombo.listIndex := -1;
			endif;
			weightTbl := self.txtTotalWeightn.getControl(index).CMUI_MeasurementTable;
			if weightTbl &lt;&gt; null then
				weightTbl.visible := false;
			endif;
			stowCombo := self.cmbSpecialStown.getControl(index).CMUI_ComboSpecialStow;
			if stowCombo &lt;&gt; null then
				stowCombo.visible := false;
				stowCombo.listIndex := -1;
			endif;
			// TFS 50878 end of this bit
		endforeach;
	endif;
	
	// create/show cloned controls less than or equal to our new value.
	self.lblVesseln.visible := false;
	self.cmbVesseln.visible := false;
	// TFS 50878 hide copy controls and get default values
	self.txtCoden.visible := false;
	self.cmbCargoTypen.visible := false;
	self.cmbCargoSubtypen.visible := false;
	self.txtTotalWeightn.visible := false;
	self.cmbSpecialStown.visible := false;
	vessel := self.myCurrentBarge.getMyVessel;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	cargoSubType := self.cmbCargoSubtype.listObject.CM_Product;
	weight := self.txtTotalWeight.getRawValue() &amp; Space &amp; self.txtTotalWeight.getUnit();
	specialStow := self.cmbSpecialStow.listObject.CM_SpecialStow;
	// generate the cargo IDs 
	cargoId := self.myAssistant.generateCargoIdForBargeCargo(_prefix, _number, vessel);
	// TFS 50878 end of this bit
	
	labelLeft := self.lblVesseln.left;
	labelTop := self.lblVesseln.top;
	labelWidth := self.lblVesseln.width;
	labelHeight := self.lblVesseln.height;
	comboLeft := self.cmbVesseln.left;
	comboTop := self.cmbVesseln.top;
	comboWidth := self.cmbVesseln.width;
	comboHeight := self.cmbVesseln.height;
	
	//foreach index in 2 to _number do												// TFS 50878
	foreach index in 1 to _number do												// TFS 50878 - index 1 is a line for the first voyage
		
		if index = 1 then															// TFS 50878
			voyCode := self.myCurrentBarge.code;									// TFS 50878
		else																		// TFS 50878
			voyCode := _prefix &amp; index.padLeadingWith('0',padLength);
		endif;																		// TFS 50878
		
		txt := self.txtCoden.getControl( index ).CMUI_TextBox;
		if txt = null then
			txt := self.txtCoden.loadControl( index ).CMUI_TextBox;
			txt.parent := self.frmCopyVessels;
			//txt.move(labelLeft, labelTop, labelWidth, labelHeight );				// TFS 50878
			txt.move(self.txtCoden.left, labelTop, comboWidth, labelHeight );		// TFS 50878
			txt.tabIndex := self.txtCoden.tabIndex + (10 * index);
		endif;
		//txt.text := voyCode;														// TFS 50878
		txt.visible := true;														// TFS 50878
		txt.enabled := self.txtCoden.enabled;										// TFS 50878
		if txt.enabled then															// TFS 50878
			txt.text := cargoId;													// TFS 50878
		endif;																		// TFS 50878
		
		label := self.lblVesseln.getControl( index ).CMUI_Label;
		if label = null then
			label := self.lblVesseln.loadControl( index ).CMUI_Label;
			label.parent := self.frmCopyVessels;
			//label.move(labelLeft, labelTop, labelWidth, labelHeight );			// TFS 50878
			label.move(self.lblVesseln.left, labelTop, labelWidth, labelHeight );	// TFS 50878
			label.tabIndex := self.lblVesseln.tabIndex + (10 * index);
		endif;
		//label.caption := app.getErrorString1( VesselFor, voyCode );				// TFS 50878
		label.caption := voyCode;													// TFS 50878
		label.visible := true;
		labelTop := labelTop + offsetDown;
		
		combo := self.cmbVesseln.getControl( index ).CMUI_ComboBox;
		if combo = null then
			combo := self.cmbVesseln.loadControl( index ).CMUI_ComboBox;
			combo.parent := self.frmCopyVessels;
			combo.move(comboLeft, comboTop, comboWidth, comboHeight );
			combo.tabIndex := self.cmbVesseln.tabIndex + (10 * index);
			combo.listCollection( app.myRoot.allVessels, true, 0 );
		endif;
		if vessel &lt;&gt; null then														// TFS 50878
			combo.listIndex := combo.findObject(vessel);							// TFS 50878
		endif;																		// TFS 50878
		if index = 1 then															// TFS 50878
			combo.enabled := false;													// TFS 50878
		endif;																		// TFS 50878
		combo.visible := true;
		
		// TFS 50878 cargo type, cargo subtype combos, weight table and special stow combo
		cargoTypeCombo := self.cmbCargoTypen.getControl(index).CMUI_ComboBoxCargoTypeForTerm;
		if cargoTypeCombo = null then
			cargoTypeCombo := self.cmbCargoTypen.loadControl(index).CMUI_ComboBoxCargoTypeForTerm;
			cargoTypeCombo.parent := self.frmCopyVessels;
			cargoTypeCombo.move(self.cmbCargoTypen.left, comboTop, comboWidth, comboHeight);
			cargoTypeCombo.tabIndex := self.cmbCargoTypen.tabIndex + (10 * index);
			cargoTypeCombo.setEventMapping("click", "cmbCargoTypen_click");
			cargoTypeCombo.myTerminal := self.myTerminal;
			cargoTypeCombo.initialise(true);
			if cargoType &lt;&gt; null then
				cargoTypeCombo.listIndex := cargoTypeCombo.findObject(cargoType);
				self.onCargoTypeChange(index, cargoType);
			endif;
		endif;
		cargoTypeCombo.visible := true;
		cargoTypeCombo.enabled := self.cmbCargoTypen.enabled;
		cargoSubTypeCombo := self.cmbCargoSubtypen.getControl(index).CMUI_ComboProduct;
		if cargoSubTypeCombo = null then
			cargoSubTypeCombo := self.cmbCargoSubtypen.loadControl(index).CMUI_ComboProduct;
			cargoSubTypeCombo.parent := self.frmCopyVessels;
			cargoSubTypeCombo.move(self.cmbCargoSubtypen.left, comboTop, comboWidth, comboHeight);
			cargoSubTypeCombo.tabIndex := self.cmbCargoSubtypen.tabIndex + (10 * index);
			cargoSubTypeCombo.setEventMapping("click", "cmbCargoSubtypen_click");
			cargoSubTypeCombo.initialise(true);
			if cargoType &lt;&gt; null and cargoSubType &lt;&gt; null then
				cargoSubTypeCombo.setCargoType(cargoType);
				cargoSubTypeCombo.initialise(true);
				cargoSubTypeCombo.listIndex := cargoSubTypeCombo.findObject(cargoSubType);
				self.onCargoSubTypeChange(index, cargoSubType);
			endif;
		endif;
		cargoSubTypeCombo.visible := true;
		cargoSubTypeCombo.enabled := self.cmbCargoSubtypen.enabled;
		weightTbl := self.txtTotalWeightn.getControl(index);
		if weightTbl = null then
			weightTbl := self.txtTotalWeightn.loadControl(index).CMUI_MeasurementTable;
			weightTbl.parent := self.frmCopyVessels;
			weightTbl.move(self.txtTotalWeightn.left, comboTop, self.txtTotalWeightn.width, comboHeight);
			weightTbl.tabIndex := self.txtTotalWeightn.tabIndex + (10 * index);
			weightTbl.setup(Type_Weight, self.backColor);
			if cargoType = null and cargoSubType = null then
				weightTbl.setup(Type_Weight, self.backColor);
			elseif cargoSubType &lt;&gt; null then
				self.onCargoSubTypeChange(index, cargoSubType);
			elseif cargoType &lt;&gt; null then
				self.onCargoTypeChange(index, cargoType);
			endif;
			if weight &lt;&gt; null then
				weightTbl.setValues(weight);
			endif;
		endif;
		weightTbl.visible := true;
		weightTbl.enabled := self.txtTotalWeightn.enabled;
		stowCombo := self.cmbSpecialStown.getControl(index);
		if stowCombo = null then
			stowCombo := self.cmbSpecialStown.loadControl(index).CMUI_ComboSpecialStow;
			stowCombo.parent := self.frmCopyVessels;
			stowCombo.move(self.cmbSpecialStown.left, comboTop, comboWidth, comboHeight);
			stowCombo.tabIndex := self.cmbSpecialStown.tabIndex + (10 * index);
			stowCombo.initialise(true);
			if specialStow &lt;&gt; null then
				stowCombo.listIndex := stowCombo.findObject(specialStow);
			endif;
		endif;
		stowCombo.visible := true;
		stowCombo.enabled := self.cmbSpecialStown.enabled;
		// TFS 50878 end of creating new controls
		
		comboTop := comboTop + offsetDown;
	endforeach;
	
	self.frmCopyVessels.height := comboTop;
	if not self.chkCreateCargo.value then			// TFS 50878
		self.doEnableDisableCargoFields(false);		// TFS 50878
	endif;											// TFS 50878

epilog

end;</source>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCargoDetails" id="beb4d03b-48a9-46aa-9970-e2b166d79517">
        <source>setCargoDetails(_tiArray : CM_TIArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	idx : Integer;
	baseVessel, vessel : CM_Vessel;
	cargoId : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	weight, density : Decimal [14,4];
	specialStow : CM_SpecialStow;
	pxyTI : CM_TrackedItem;
	comboVessel : CMUI_ComboBox;
	textCargoId : CMUI_TextBox;
	comboCargoType : CMUI_ComboBoxCargoTypeForTerm;
	comboCargoSubType : CMUI_ComboProduct;
	textWeight : CMUI_MeasurementTable;
	comboStow : CMUI_ComboSpecialStow;

begin
	if chkCreateCargo.value = false then
		return;
	endif;
	
	while true do
		idx := idx + 1;
		
		textCargoId := self.txtCoden.getControl(idx);
		if textCargoId = null then
			break;
		endif;
		
		cargoId := textCargoId.text.trimBlanks.toUpper;
		comboCargoType := self.cmbCargoTypen.getControl(idx).CMUI_ComboBoxCargoTypeForTerm;
		cargoType := comboCargoType.listObject.CM_CargoType;
		// need at least a cargo id and a cargo type to bother trying to create a cargo item
		if cargoType = null or cargoId = null then
			_tiArray.add(null);
			continue;
		endif;
		comboCargoSubType := self.cmbCargoSubtypen.getControl(idx).CMUI_ComboProduct;
		cargoSubType := comboCargoSubType.listObject.CM_Product;
		comboStow := self.cmbSpecialStown.getControl(idx).CMUI_ComboSpecialStow;
		specialStow := comboStow.listObject.CM_SpecialStow;
		textWeight := self.txtTotalWeightn.getControl(idx).CMUI_MeasurementTable;
		if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
			if cargoSubType = null then
				cargoSubType := cargoType.mySystemProductType;
			endif;
			density := cargoSubType.myDensityDec.value;			// ### TFS 52193 22Nov2021 NAVPW1
			weight := textWeight.getConvertedValue * density;
		else
			weight := textWeight.getConvertedValue;
		endif;
		
		create pxyTI as cargoType.myClassToCreate transient;
		pxyTI.zSetPxyId(cargoId);
		if cargoType &lt;&gt; null then
			pxyTI.setCargoType(cargoType.id);
		endif;
		pxyTI.setMyProduct(cargoSubType);
		pxyTI.setTotalWeight(weight, null, app.myPassport);
		if specialStow &lt;&gt; null then
			pxyTI.zSetPxySpecialStow(specialStow.code);
		endif;
		pxyTI.zSetPxyVoyage(self.myCurrentBarge, null);
		pxyTI.zSetPxyOperator(self.myCurrentBarge.myOperator);
		pxyTI.zSetPxyTerminal(self.myTerminal);
		pxyTI.zSetPxyState(TI_STATE_ONSHIP);
		pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_IMPORT);
		pxyTI.zSetPxyDischargePort(self.myTerminal.getConfig(PortDestCode).String);
		_tiArray.add(pxyTI);
	endwhile;
	
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentBarge" id="9db67199-e08c-4c06-abb6-d1288575a2d6">
        <updating/>
        <source>setMyCurrentBarge( _myCurrentVoyage : CM_Voyage )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	self.myCurrentBarge := _myCurrentVoyage;
	
	if self.myTerminal = null and self.myCurrentBarge &lt;&gt; null then
		self.myTerminal := self.myCurrentBarge.myTerminal;
	endif;

epilog

end;</source>
        <Parameter name="_myCurrentVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="668a4cf6-86b0-42b8-b9d8-517f8db31efe">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417
27 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	msg : String;
	pos : Integer;
	prefix : String;

begin

	if self.myCurrentBarge = null then
		msg := app.getErrorString( SHP_Select_Voyage_To_Copy );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm();
		return;
	endif;
	
	self.cmbVesseln.listCollection( app.myRoot.allVessels, true, 0 );
	
	inheritMethod();
	
	pos := self.myCurrentBarge.code.pos("-",1);
	if pos &gt; 1 then
		prefix := self.myCurrentBarge.code[1:pos - 1 ];
	elseif pos = 1 then
		msg := "Voyage name may not start with a hyphen";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm();
		return;
	else
		prefix := self.myCurrentBarge.code;
	endif;
	
	self.txtVoyageCode.text := prefix;
	
	self.cmbCargoType.myTerminal := self.myTerminal;			// TFS 50878
	self.cmbCargoType.initialise(true);							// TFS 50878
	self.txtTotalWeight.setup(Type_Weight, self.backColor);		// TFS 50878
	self.chkCreateCargo.value := true;							// TFS 50878
	self.chkCreateCargo_click(self.chkCreateCargo);				// TFS 50878
	
	self.reDisplayVessels( null, 0 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ce309d4d-1eec-4177-bb64-d0b4287c2104">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2021 10:13:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023901, locale);
	chkCreateCargo.translateCaption(Xlat_0024343, locale);
	lblCargoId.translateCaption(Xlat_0024344, locale);
	lblCargoSubtype.translateCaption(Xlat_0024345, locale);
	lblCargoSubtypen.translateCaption(Xlat_0024346, locale);
	lblCargoType.translateCaption(Xlat_0024347, locale);
	lblCargoTypen.translateCaption(Xlat_0024348, locale);
	lblSpecialStow.translateCaption(Xlat_0024349, locale);
	lblSpecialStown.translateCaption(Xlat_0024350, locale);
	lblTotal.translateCaption(Xlat_0023902, locale);
	lblTotalWeight.translateCaption(Xlat_0024351, locale);
	lblVessel.translateCaption(Xlat_0024352, locale);
	lblVesseln.translateCaption(Xlat_0023903, locale);
	lblVoyageCode.translateCaption(Xlat_0023904, locale);
	lblWeight.translateCaption(Xlat_0024353, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtTotal_change" id="92afee50-7dda-4382-9811-d6559c32db8a">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTotal_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	prefix : String;
	number : Integer;
	msg : String;

begin

	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	self.reDisplayVessels( prefix, number );
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTotal_lostFocus" id="882232f6-7eea-494e-ac6c-80f092425c03">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTotal_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	prefix : String;
	number : Integer;
	msg : String;

begin

	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	if number &lt; 1 then
		return;
	endif;
	if number &gt; 30 then
		msg := app.getErrorString1( Maximum_value, "30" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtTotal.setFocus();
	elseif number = 1 then
		msg := app.getErrorString1( Must_least, "2" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtTotal.setFocus();
	elseif prefix.length &gt; 18 and number &gt; 9 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVesseln.caption, "18, when " &amp; self.lblTotal.caption &amp; " &gt; 9 ");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtVoyageCode_lostFocus" id="154d09d6-08df-467c-a77e-145f0ba88c8a">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtVoyageCode_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	prefix : String;
	number : Integer;
	msg : String;

begin

	prefix := self.txtVoyageCode.text.trimBlanks.toUpper;
	number := self.txtTotal.text.Integer;
	if prefix.length &gt; 19 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVesseln.caption, "19" );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
	elseif prefix.length &gt; 18 and number &gt; 9 then
		msg := app.getErrorString2( Field_Value_Too_Long, self.lblVesseln.caption, "18, when " &amp; self.lblTotal.caption &amp; " &gt; 9 ");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtVoyageCode.setFocus();
	endif;
	
	self.reDisplayVessels( prefix, number );

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
