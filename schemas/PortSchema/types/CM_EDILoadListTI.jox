    <JadeMethod name="addTranshipPortCodes" id="1fa75139-a662-4d01-9ab5-291ed7151040">
        <source>addTranshipPortCodes(_value: String);
//
//cnwrs1 CCMS 1137 1 July 2010 
//
	
vars
	portCode : String;
	
begin
	if _value = null or 
	   self.transhipPortCodes.includes(_value) then
		return;
	endif;
	
	portCode := _value.trimBlanks;
	// Each Port Code can be delimited by any combination of space(s) or colon(s).
	// Convert all Colons into a Space.
	portCode := portCode.cnEcFindReplace(Colon, Space, false);
	portCode := portCode.cnEcFindReplace(SemiColon, Space, false);
	// Convert all double spaces into 1 space, triming blanks incase started or ended with a colon(s).
	portCode := portCode.trimBlanks.eliminateContiguous(Space.Character);
	// Now break this string into the separate codes delimited by space.
	portCode.getTokensForDelimiter(Space, self.transhipPortCodes);
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="assignValueSpecial" id="5bc40935-e99e-4390-9c5b-8ebe992d9ad0">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
Date		Who		Reason
11 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
10 May 2013	cnwcs5	par 31626 - make method public so can be used for hook code
30/06/2016  cnwma1  PAR 38002	VGM on load list
// 24 Feb 2017	cnwrs1	TFS 3470 set default cargo type for Load List TI
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
*/
vars
	foundMatch	: Boolean;
	cargoType : CM_CargoType;
	cargoTypeId : Integer;
	found : Boolean;
	strArray : StringArray;
begin
	if _propName = ETRow_CargoTypeDescr then
		// attempt to match the supplied data to either the cargo type abbreviation or the description.
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_processedValue);
		if cargoType = null then
			if _xlationOperator &lt;&gt; null then
				cargoTypeId := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_CARGOTYPE_BYOP, found).Integer;
				cargoType := app.myRoot.allCargoTypesById[cargoTypeId];
				if cargoType &lt;&gt; null then
					self.setPropertyValue(ETRow_CargoType, cargoType.id);
					self.setPropertyValue(ETRow_CargoTypeDescr, cargoType.description);	// in case abbreviation supplied.
					return true;
				endif;
			endif;
			// par 29533 - if cargo type description is not valid then clear out cargo type which would have been set
			// in the constructor and also setForCreate
//			self.cargoType	:= null;	// par 29533
//			self.cargoTypeDescr := _processedValue;
//			return false;		// this will default the screen to the supplied value
		endif;
	// par 31259 - code moved from setEDITIProperty
	elseif _propName = CM_EDILoadListTI::operatorCode.name then
		self.operatorCode := app.myRoot.getXlationSystemOperatorCode(null, _processedValue.String, foundMatch)[1:4];  
		return true;
		
	elseif _propName = CM_EDILoadListTI::temperature.name then
		if _processedValue &lt;&gt; null then
			self.temperature := self.extractNumber(_processedValue.String);
			
			if self.temperature &gt;= 0 then
				self.temperatureSign := '+';
				self.temperatureAbsolute := self.temperature;
			else
				self.temperatureSign := '-';
				self.temperatureAbsolute := self.temperature * (-1);
			endif;		
		endif;
		return true;
		
	elseif _propName = CM_EDILoadListTI::weight.name then
		self.weight := self.extractNumber(_processedValue.String).Integer;
		return true;
				
	elseif _propName = CM_EDILoadListTI::vent.name then
		if _processedValue &lt;&gt; null then 
			self.setVents(_processedValue.String);
		else
			self.vent := NULL_VENTILATION; 
		endif;
		return true;
		
	elseif _propName = ETRow_IsoTypeGroup then	//19 Aug 2015	NDL	Par 36779
		self.isoGroup := _processedValue.String;
		return true;
	
	elseif _propName = CM_EDILoadListTI::transhipPortCodes.name then
		self.transhipPortCodes.clear();
		strArray := _processedValue.getTokens();
		if strArray &lt;&gt; null and 
		   not strArray.isEmpty then
			strArray.copy(self.transhipPortCodes);
		endif;	
		return true;
	elseif _propName=ETRow_IsCertifiedWeight then	       //cnwma1 30/06/2016 PAR 38002 VGM on load list
		self.isWeightCertified := _processedValue.asBooleanJMT;
		return true;
	//navra1 - BUG-MTN-33010 - 10th Oct 2024 - start
	elseif _propName = ETRow_OpStatus then
		if _processedValue.String = "FCL" or _processedValue.String = "FULL" then
			self.contentsStatus := "FCL";
			return true;
		elseif _processedValue.String = "MT" or _processedValue.String = "EMPTY" then
			self.contentsStatus := "MT";
			return true;
		elseif _processedValue.String = "LCL" then
			self.contentsStatus := "LCL";
			return true;
		elseif _processedValue.String = "FLH" then
			self.contentsStatus := "FLH";
			return true;
		elseif _processedValue.String = "PLL" then
			self.contentsStatus := "PLL";
			return true;
		elseif _processedValue.String = "PLL" then
			self.contentsStatus := "PLL";
			return true;
		elseif _processedValue.String = "PLD" then
			self.contentsStatus := "PLD";
			return true;
		endif;
	//navra1 - BUG-MTN-33010 - 10th Oct 2024 - end
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog
	delete strArray;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="885e0d6a-8b34-4fb8-bc8f-e61343f3d751">
        <source>canUserSet(_propName: String): Boolean;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
vars

begin

	if _propName = CM_EDILoadListComparisonTI::myMatchedLLCAgent.name or
	   _propName = CM_EDILoadListTI::imCodes.name then
//	   _propName = CM_EDILoadListTI::transhipPortCodes.name then
		return false;
	elseif _propName = CM_EDITrackedItem::subTerminalCode.name or
	   _propName = CM_EDILoadListTI::specialStowage.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTemperatures" id="2bc39c81-551e-4d85-b1ec-5c10a8ea2445">
        <updating/>
        <source>checkTemperatures() updating;
//----------------------------------------------------------------
//	Created:	04 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

begin

	if self.temperature = NULL_TEMPERATURE then
		if self.temperatureAbsolute &lt;&gt; NULL_TEMPERATURE.abs() then
			self.temperature := self.getTempFromAbsolute();
		endif;
	else
		if self.temperatureAbsolute = NULL_TEMPERATURE.abs() then
			//set tempAbs
			self.temperatureAbsolute := self.temperature.abs();
			if temperature &lt; 0 then
				self.temperatureSign := '-';
			else
				self.temperatureSign := '+';
			endif;
		endif;
	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="consignee" id="57474201-d282-4cd3-98cd-e634a0657bba">
        <methodInvocation>mapping</methodInvocation>
        <source>consignee(set : Boolean; _value : String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwas3	Initial creation

*/

vars
	csgnee : CM_ConsigneeConsignor;
begin
	if not set then
		if self.consignee.length = 5 then
			csgnee := app.myRoot.allConsigneeConsignors.getAtKeyGeq(self.consignee);
			if csgnee &lt;&gt; null and csgnee.code = self.consignee then
				_value := csgnee.code;
			else
				_value := self.consignee;
			endif;
		else
			_value := self.consignee;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertTranshipVesselName" id="13d38704-eaa2-4b02-a5e7-37661069cb46">
        <updating/>
        <source>convertTranshipVesselName() updating;
//
// par 25195 cnwrs1 16 Aug 2010 - obsolete after 783
//
vars
	value : String;
begin
	if self.allExtraData.size &gt; 0 then
		global.getExtraData(self.allExtraData, CM_EDILoadListTI::transhipVesselName.name, value);
		if value &lt;&gt; null then
			beginTransaction;
			self.transhipVesselName := value;
			global.setExtraData(self.allExtraData, self, CM_EDILoadListTI::transhipVesselName.name, null);
			commitTransaction;
		endif;
	endif;
end;
</source>
        <text>remove after 783</text>
    </JadeMethod>
    <JadeMethod name="create" id="4b5caac4-145d-4f17-9722-736f868a3958">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 24 Feb 2017	cnwrs1	TFS 3470 set default cargo type for Load List TI
*/
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.temperature := NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY ); //par18451 nov 2008 cnwrs1
	self.vent := NULL_VENTILATION; //par18451 nov 2008 cnwrs1
	
	//cnwmc5 - 10 March 2014 - PAR 33001
	self.overHeight := NULL_INTEGER;
	self.overLengthBack := NULL_INTEGER;
	self.overLengthFront := NULL_INTEGER;
	self.overWidthLeft := NULL_INTEGER;
	self.overWidthRight := NULL_INTEGER;
	self.cargoType := TI_CargoType_Container;
end;


</source>
    </JadeMethod>
    <JadeMethod name="createAndGateInTesting" id="8b994cbd-e6c6-4ed4-92df-a041e1a8c844">
        <source>createAndGateInTesting(_terminal: CM_Terminal; _mc: CMIF_MoveController input);
//----------------------------------------------------------------
//	Created:	19 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	err				: CM_Error;
	loadPort		: String;
	comm			: CM_Commodity;
	voyage			: CM_Voyage;
	port			: CM_Port;
	pxyTI,realTI	: CM_TrackedItem;
	operator		: CM_Operator;
	csgnee			: CM_ConsigneeConsignor;
	tmpHazards : ObjectArray;
	obj : Object;
begin

	loadPort := _terminal.getConfig(PortDestCode).String;

	if self.loadPort &lt;&gt; loadPort then
		app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; self.loadPort &amp; " " &amp;  loadPort);
		return;
	endif;
	
	//lets make cargo
	pxyTI := _terminal.createTI(self.myCargoType, true);
	    
	voyage := _terminal.lookupVoyage(self.myEDIData.CM_EDIDataLoadList.voyageCode, null, false);
	//port := app.myRoot.allPorts[self.dischargePort.reverse[1:3].reverse];
	port := app.myRoot.allPorts[self.dischargePort.reverse[1:5].reverse];
	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
	else
		operator := app.myRoot.allOperators[self.myEDIData.operatorCode];
	endif;
	
	pxyTI.zSetPxyId(self.id);
	pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(_terminal);
	if app.isSubTerminalsOn(_terminal) then
		pxyTI.setSubTerminalDefaultFromTerm(_terminal);		// CCMS 1875
	endif;

	pxyTI.zSetPxyCompany(_terminal.companies.last);
	
	pxyTI.changeISOType(self.isoType, null, app.myPassport);
	
	if voyage = null then
		if port = null then
			pxyTI.zSetPxyDischargePort("SYD");
		else
			pxyTI.zSetPxyDischargePort(port.code);
		endif;
	else
		pxyTI.zSetPxyVoyage(voyage, self.myEDIData.CM_EDIDataLoadList.voyageCode);
		if port &lt;&gt; null 
		and voyage.includesPort(port) then
			pxyTI.zSetPxyDischargePort(port.code);
		else
			if voyage.allPorts.first.code = loadPort then
				if voyage.allPorts.size &gt; 1 then
					pxyTI.zSetPxyDischargePort(voyage.allPorts.last.code);
				else
					pxyTI.zSetPxyDischargePort("SYD");
				endif;
			else
				pxyTI.zSetPxyDischargePort(voyage.allPorts.first.code);
			endif;
		endif;
	endif;
	
	csgnee := app.myRoot.allConsigneeConsignors[self.consignee];//ccms 1915 - PAR 22271
	if csgnee &lt;&gt; null then
		pxyTI.zSetPxyConsignee(self.consignee);
	endif;
	
	comm := app.myRoot.allCommodities[self.commodity];
	
	if comm = null then
		pxyTI.zSetPxyCommodity("MT");
	else
		pxyTI.zSetPxyCommodity(self.commodity);
		if comm.requiresPower
		and CM_Container.hasInstance(pxyTI) then
			if self.temperature &lt; -50 then
				pxyTI.CM_Container.zSetPxyTemperatureCelsius(comm.minTemp);
			else
				pxyTI.CM_Container.zSetPxyTemperatureCelsius(self.temperature);
			endif;
			if self.cooledType = ContainerWaterCooled then
				pxyTI.CM_Container.setPropertyValue('coolingType', ContainerWaterCooled);
			else
				pxyTI.CM_Container.setPropertyValue('coolingType', ContainerAirCooled);
			endif;
		endif;
	endif;
	
	pxyTI.zSetPxyWeight(self.weight);
	pxyTI.zSetPxyBookingReference(self.bookingRef.toUpper);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);
	pxyTI.zSetPxyWidth(self.width);
	pxyTI.zSetPxyLength(self.length);
	pxyTI.zSetPxyHeight(self.height);
//	pxyTI.setPxyTIHazardsFromStringArray(self.imCodes);
	create tmpHazards transient;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	foreach obj in tmpHazards do
		obj.CM_TIHazard.setMyTrackedItem(pxyTI);
	endforeach;
	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	//create the persistent TI
	app.myTrxCA.trxCreateTrackedItem(pxyTI, realTI, app.myPassport);

	if not app.myPassport.trxCompletedOK then
		/* cnwrl1 17/06/2010 what it was
		if app.myPassport.hasErrors then
			app.writeStatement( "Create TI errors");
			foreach err in app.myPassport.allErrors do
				app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp; " " &amp; err.errorCode.String &amp; " " &amp; err.text);		
			endforeach;
		endif;
		*/
		return;
	endif;	

	//do a move it
	if realTI = null then
		return;
	endif;
	
	_mc.setMyTrackedItem(realTI);
	
	app.myPassport.warningsAcknowledged	:= true;
	app.myTrxUA.trxMoveTrackedItem(_mc, app.myPassport);
	
	/* cnwrl1 17/06/2010 what it was
	if not app.myPassport.trxCompletedOK then
		if app.myPassport.hasErrors then
			app.writeStatement( "Move TI errors");
			foreach err in app.myPassport.allErrors do
				app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp; " " &amp; err.errorCode.String &amp; " " &amp; err.text);		
			endforeach;
		endif;
	endif;
	*/

epilog
	delete tmpHazards;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_mc" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="dcc22af3-2a65-41c1-a1dd-39da7520c412">
        <updating/>
        <source>delete() updating;
//
// 20 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.myAttachedItems do
		if ediTI.isEDISealDetails then
			delete ediTI;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="55f1fe0f-f305-4e17-b788-c12962a41361">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
