        <updating/>
        <source>tblCompare_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	cmif : CMIF_ConfigOptionsDisplay;

begin

	self.mnuInspect.visible := false;

	self.mnuColumnOrg.visible := true;
	self.mnuColumnOrg.userObject := self.tblCompare;
	if app.isAllowedToInspect then
		cmif := table.accessRow(table.row).itemObject.CMIF_ConfigOptionsDisplay;
		if cmif &lt;&gt; null then
			self.mnuInspect.userObject := cmif;
			self.mnuInspect.visible := true;
		endif;
	endif;
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
