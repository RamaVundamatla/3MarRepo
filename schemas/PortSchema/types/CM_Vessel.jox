    <JadeMethod name="isPilotExempt" id="d2cd123c-db7d-4b48-b439-ddb263fdf2d6">
        <source>isPilotExempt( _harbour : HMS_Harbour ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	vdh : HMS_VesselDataHarbour;

begin

	if self.myHMSVesselData = null or _harbour = null then
		return false;
	endif;
	
	vdh := self.myHMSVesselData.allVesselDataForHarbour[ _harbour ];
	
	if vdh = null then
		return false;
	endif;
	
	return vdh.isPilotExempt;

epilog

end;</source>
