    </JadeMethod>
    <JadeMethod name="init" id="a9dfbd8d-4aab-4041-98e3-a15eca0873bb">
        <updating/>
        <source>init() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	availTrxTypes : CM_TransactionTypeByType;
	agent : CM_CashInvoiceProformaAgent;

begin

	self.minimumWidth := 660;
	
	create agent transient;
	create availTrxTypes transient;
	agent.getAvailTrxTypesFromRoot(availTrxTypes);
	
	self.mulTransactions.myAvailableListBox.sorted:=true;
	self.mulTransactions.mySelectedListBox.sorted:=false;
	self.mulTransactions.setupControl(app.getErrorString(Transactions), availTrxTypes, INV_ProformaCriteriaForm::getTranTypeName.name);
	
	if self.myProformaTransactionCriteria &lt;&gt; null then
		self.mulTransactions.setSelected( self.myProformaTransactionCriteria.allTransactionTypes );
	endif;
	self.mulTransactions.setVisibleButtons(true,true,false);
	// TFS 2071 'OK' to 'Save'
	self.btnOK.caption := app.getErrorString(Save);
epilog

	delete availTrxTypes;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCriteriaFrames" id="9ba6a6b6-62ca-40be-a562-f1df0ca8b13b">
        <updating/>
        <source>loadCriteriaFrames() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars
	i: Integer;
	top, left, height, width: Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criterias: Iterator;
	cntlTabIndex: Integer;
	propCount : Integer;
	splitAtPos : Integer;
	maxUsed : Integer;
	
begin

	top :=  1; 
	left := 1; 
	height := ((self.grpAllCriteria.height - 10) / 10).Integer;
	width := (self.grpAllCriteria.width / 2).Integer;
	propCount := self.allSelectedCriteriaTypes.size;
	splitAtPos := (propCount / 2).Decimal.rounded + 1;
	
	maxUsed := 20;
	

	cntlTabIndex := self.frmCriteria.tabIndex;

	foreach i in 1 to propCount do 
		
		if i = splitAtPos then
			left := width;	// second column
			top := 1;
		endif;
		criteriaFrame := self.frmCriteria.loadControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setWidth(width);			
		criteriaFrame.setTabIndex(cntlTabIndex);
		criteriaFrame.move(left, top, width, height);
		criteriaFrame.visible := true;
		criteriaFrame.tag := "true";	// to active three-state booleans
		top := top + height;
		maxUsed := maxUsed.max( top );
	endforeach;

	self.frmCriteria.visible := false;
	
	self.setHeight( maxUsed ); 
	
epilog
	delete criterias;
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="a4b3d138-951a-49d0-8ad5-6476c601c40e">
        <updating/>
        <source>populateCriteriaFrames() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	
begin

	if self.frmCriteria.getControl(1) = null then
		self.loadCriteriaFrames();
	endif;
	propCount := self.allSelectedCriteriaTypes.size;
	
	foreach i in 1 to self.allSelectedCriteriaTypes.size do 
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255		
		criteriaFrame.formCriteriaChangeMethodName := null;
		critType := self.allSelectedCriteriaTypes[i];
		
		if critType &lt;&gt; null then
			criteriaFrame.setCriteriaType( critType );
			criteriaFrame.setLabelVisible(true);
			if self.myProformaTransactionCriteria &lt;&gt; null then
				criteria := self.myProformaTransactionCriteria.getCriteriaForType(critType);
				if criteria &lt;&gt; null then
					criteriaFrame.setCriteria( criteria );
				endif;
			endif;
		endif;
		criteriaFrame.formCriteriaChangeMethodName := CMUI_YACriteriaMaintForm::doCriteriaChanged.name;
	endforeach;
	
	self.isModified := false;
	
epilog
//	delete iterCriteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="setHeight" id="b73e890c-4ce2-4680-a6cb-bfd05fd9fa20">
        <updating/>
        <source>setHeight( _maxUsed : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	newTop : Real;

begin

	self.grpAllCriteria.height :=  _maxUsed + 20;

	self.frmTransactions.top := _maxUsed + 20;
	self.frmTransactions.left := 10;
	self.frmTransactions.height := 215;
	self.frmTransactions.width := self.width - 20;
	self.frmTransactions.borderStyle := 0;
	
	newTop := self.frmTransactions.top + self.frmTransactions.height + 10;
	self.btnCancel.top := newTop;
	self.btnOK.top := newTop;
	self.btnUnits.top := newTop;
	self.btnHookCode.top := newTop;
	
	newTop := self.btnOK.top + self.btnOK.height + 35; //  was 30, extra room for skin
	self.height := newTop;
	
	self.btnCancel.zOrder(1);
	self.btnOK.zOrder(1);

epilog

end;</source>
        <Parameter name="_maxUsed" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setReferences" id="637e9ba8-1a32-46a3-ae03-a7a622acbb86">
        <updating/>
        <source>setReferences( 	_bank : CM_Bank;
				_critTypeDict : CM_YACriteriaTypeArray;
				_myProformaTransactionCriteria : CM_ProformaTransactionCriteria;
				_myCallingForm : INV_CashModuleConfigForm ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myBank := _bank;
	self.allSelectedCriteriaTypes.clear();
	if _critTypeDict &lt;&gt; null and not _critTypeDict.isEmpty then
		_critTypeDict.copy(self.allSelectedCriteriaTypes);
	endif;
	self.myProformaTransactionCriteria := _myProformaTransactionCriteria;
	if self.myProformaTransactionCriteria &lt;&gt; null then
		self.hookSource := _myProformaTransactionCriteria.getJadeCode();
	endif;
	self.myBankProformaPropsForm := _myCallingForm;

epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_critTypeDict" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_myProformaTransactionCriteria" type="CM_ProformaTransactionCriteria"/>
        <Parameter name="_myCallingForm" type="INV_CashModuleConfigForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="64269a2f-562d-4c0c-a964-de9ac8a20b68">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.handleMenusForModalDisplay();
	
	inheritMethod();
	
	init();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ce36682c-74b0-4e09-92ea-656995cbaade">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 February 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018420, locale);
	btnHookCode.translateBubbleHelp(Xlat_0020230, locale);
	btnHookCode.translateCaption(Xlat_0020231, locale);
	btnUnits.translateBubbleHelp(Xlat_0018421, locale);
	btnUnits.translateCaption(Xlat_0018422, locale);
end;</source>
    </JadeMethod>
</GUIClass>
