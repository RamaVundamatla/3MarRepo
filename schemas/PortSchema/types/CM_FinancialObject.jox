    <JadeMethod name="getRateEntryDecimalPlaces" id="78c9c1b6-c230-448f-9e86-21e1a773a306">
        <source>getRateEntryDecimalPlaces() : Integer;
/*

Purpose:			Replace the old $CM_RateEntry number format with the terminal config value instead


Date				Who		Reason
19 February 2018	jlgmd1	Initial creation TFS 36954 SNO - Error in SCT2 Rate Table

*/

vars
	dpl 	: Integer;
	term	: CM_Terminal;
begin
	term := self.getMyTerminal();
	if term &lt;&gt; null then
		dpl := term.getConfig(FinancialRateDPlaces).Integer;
	else
		dpl := $CM_RateEntry.decimalPlaces;	// 2 in WMAST
	endif;
	
	return dpl;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
