    <JadeMethod name="getPrenotedTrackedItems" id="2b75751b-cd77-46d6-80ca-e2fa20ed2584">
        <source>getPrenotedTrackedItems(_coll :Collection input;_contextObject : Object);
/*

Purpose:			Get all prenoted items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
17 Jun 2013	cnwcs5	Initial Creation - par 31670
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance
24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
*/

vars
	item	: CM_BookingRefItem;
	ti		: CM_TrackedItem;
	iter	: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		if item &lt;&gt; null then
			item.getPrenotedTrackedItems (_coll,_contextObject);			//24.07.2023 navma1 #59275
			return;
		endif;
	endif;
	
	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	self.allTIsByState.startKeyGeq(TI_STATE_NOTIFIED, "", 0, iter);
	
	beginLoad;
		while iter.next(ti) do
			//check state key
			if not ti.isMatchingTransportMode(_contextObject) then			//24.07.2023 navma1 #59275
				continue;
			endif;
			
			if iter.getCurrentKey(1).Integer &lt;&gt; TI_STATE_NOTIFIED then
				break;
			endif;
			_coll.add (ti);
		endwhile;
	endLoad;
	//tfs43864 end
	
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="_contextObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="getPrenotedWeight" id="2f6fbd1c-05ee-4f78-9e90-ec3cb9a665ca">
        <source>getPrenotedWeight() : Decimal;
/*

Date		Who		Reason
23 September 2014	cnwer1	Initial creation PAR 34935

*/

vars
	ti 			: CM_TrackedItem;
	total 	: Decimal[14,4];
	item 	: CM_BookingRefItem;
begin
	if not self.isBulkMulti then
		return 0;
	endif;
	
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		
		if item &lt;&gt; null then
			return item.getPrenotedWeight();
		endif;
	endif;

	foreach ti in self.allTIs where (ti.state = TI_STATE_NOTIFIED) do
		if not ti.myCargoType.isBulkMulti then
			continue;
		endif;
		total := total + ti.totalWeight;
	endforeach;
	
	return total;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
