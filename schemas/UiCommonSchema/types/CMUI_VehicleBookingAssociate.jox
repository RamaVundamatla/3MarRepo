    <JadeMethod name="doMnuFormContextMenu" id="1aeb7fe5-fcb6-4e43-a6b9-16e9878e2d8f">
        <updating/>
        <source>doMnuFormContextMenu(_table : Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2021	navndl1	Initial creation	TFS 51045

*/

vars

begin

	self.mnuColOrg.visible := true;
	self.mnuInpsectObj.visible := app.isAllowedToInspect();
	
	return self.showContextMenu(self.mnuContextOpts, _table, _conwin, _mouse, _x, _y);
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNoBookClick" id="085f5a66-fc1b-4cdd-93e4-15b32d5b7fce">
        <updating/>
        <source>doNoBookClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.myVehicleVisitRecord = null and self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.setPxyVehicleBookingTimeslot( null );
	endif;

	self.unloadForm;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="47ad4782-1bdb-410f-afe0-e6060eee28df">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	inheritMethod();
	
	self.frmBooking.top := 1;
	self.frmBooking.left := 1;
	
	self.frmBooking.width := self.clientWidth - 2;
	self.frmBooking.height := self.clientHeight -2 ;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUseBookClick" id="a6e70404-7259-424d-880b-2774084bec21">
        <updating/>
        <source>doUseBookClick()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars

	booking : CM_VehicleBookingTimeSlot;
	proxy : CM_VehicleBookingTimeSlot;
	vvr : CM_VehicleVisitRecord;
	theReturn : Integer;
	loadState : Boolean;
	strArray : StringArray;
	allDeliveryIds, allPickupIds : StringArray;			// TFS 51248
	ti : CM_TrackedItem;

begin

	if not self.doValidate( booking ) then
		return;
	endif;
	
	if self.myVehicleVisitRecord = null and self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.setPxyVehicleBookingTimeslot( booking );
	
	else
	
		app.cmsBeginLoad(loadState);
		proxy := booking.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
		app.cmsEndLoad(loadState);
		
		vvr := self.myVehicleVisitRecord;
		
		create strArray transient;
		create allDeliveryIds transient;			// TFS 51248
		create allPickupIds transient;				// TFS 51248
		if vvr = null then
			//booking.getTiIdsFromBookedItemsOrVvr(strArray);						// TFS 51248
			booking.getTiIdsFromBookedItemsOrVvr(allDeliveryIds, allPickupIds);		// TFS 51248
		else
			foreach ti in vvr.allReceivedTrackedItems do
				strArray.add( ti.id );
				allDeliveryIds.add( ti.id );		// TFS 51248
			endforeach;
			foreach ti in vvr.allReleasedTrackedItems do
				strArray.add( ti.id );
				allPickupIds.add( ti.id );			// TFS 51248
			endforeach;
		endif;
		
		proxy.setProxy(	booking.bookingTSstart,	//_scheduleTSstart : TimeStamp;
						booking.bookingTSend,	//_scheduleTSend : TimeStamp;
						booking.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
						booking.myCarrier,	//_myCarrier : CM_Carrier;
						null,				//_mySubCarrier : CM_Carrier;
						booking.myDriver,	//_myDriver : CM_DriverDetails;
						booking.myVehicle,	//_myVehicle : CM_Vehicle;
						booking.remarks,	//_remarks : String;
						booking.includesDelivery,	//_includesDelivery : Boolean;
						booking.includesPickUp,	//_includesPickUp : Boolean;
						strArray,	//_bookedTiIds : StringArray;
						vvr,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
						booking.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
						booking.id,	//_id : String;
						booking.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
						booking.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
						null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
						null,	// : Boolean;
						null,	//_preGateOutChck : Boolean;
						null,	//_kioskCheck : Boolean;
						null,	//_externalReference : String
						null 	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
						);
					
		while true do
			//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);								// TFS 51248
			app.myTrxUA.trxUpdateVehicleBooking(proxy, allDeliveryIds, allPickupIds, app.myPassport);	// TFS 51248
			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	
	endif;
	
	self.unloadForm;
	
epilog

	delete proxy;
	delete strArray;
	delete allDeliveryIds;		// TFS 51248
	delete allPickupIds;		// TFS 51248
	
	app.cmsEndLoad(loadState);

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="8e16e3fd-4eca-4e70-9334-4490ce7b0fe7">
        <source>doValidate( _booking : CM_VehicleBookingTimeSlot output
			):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		_booking := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;

	return _booking &lt;&gt; null;

epilog

end;</source>
        <Parameter name="_booking" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
