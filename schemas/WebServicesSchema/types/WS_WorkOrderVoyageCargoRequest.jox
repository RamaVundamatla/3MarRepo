    <JadeMethod name="setProxyFromObject" id="762a6c63-646d-42f1-8df6-089bbc092219">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodVoyageCargoRequest) updating;
/*
Purpose:	TFS 40435		
Date				Who			Reason
AUGUST 2018			CNWAB1		Initial creation
10 Jan 2021   		navma1		ChangeRequest 52510: SAL - Web Portal - Berth display in Cargo Request
21 Feb 2024			navsck1		ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
*/

vars
	marineServiceDetail  : CM_WodMarineServiceDetail;
	wsHMSResourceUsed	 : WS_HMSResourceUsed;
	wodCargoRequest 	 : CM_WodCargoRequest;
	wsDetail 			 : WS_WorkOrderCargoRequest;
	voyage 				 : CM_Voyage;
	towedVoyageData 	 : HMS_VoyageData;
	towedVoyage 		 : CM_Voyage;
	towedImsr 			 : CM_WodMarineServicesInitial;
	file 				 : CM_FileData;
	wsDocument 			 : WS_Document;
	wo					 : CM_WorkOrder;
begin
	inheritMethod(_object);
	
	if _object.myBerth &lt;&gt; null then
		self.toBerthOid:=_object.myBerth.getOidAsString;
	endif;
	self.occursOnDT:=_object.requiredByDT.asStringForWebInterface;
	
	//15 Oct 2018	NDL	TFS 41404
	voyage := _object.getMyVoyageObject();
	if voyage &lt;&gt; null then
		/* 10.01.2022 navma1 #52510
		processTerminal := voyage.getProcessTerminal();
		if processTerminal &lt;&gt; null then
			self.allowUpdateOfIMSRBerth := processTerminal.allowUpdateOfIMSRBerth;
		endif;
		*/
		//16 Oct 2018	NDL	TFS 41410
		if not voyage.allTowedVoyages.isEmpty then
			
			//self.allowUpdateOfIMSRBerth := false;      //10.01.2022 navma1 #52510
			
			towedVoyageData := voyage.allTowedVoyages.first;
			if towedVoyageData &lt;&gt; null then
				towedVoyage := towedVoyageData.myVoyage;
			endif;
			if towedVoyage &lt;&gt; null then
				towedImsr := towedVoyage.getWorkOrderForIMSR;
			endif;
			if towedImsr = null then
				self.toBerthOid := null;
				self.occursOnDT := null;
			else
				if towedImsr.myBerth &lt;&gt; null then
					self.toBerthOid := towedImsr.myBerth.getOidAsString;
				endif;
				self.occursOnDT := towedImsr.requiredByDT.asStringForWebInterface;
			endif;
		endif;
		
	endif;
	
	foreach marineServiceDetail in  _object.allMarineServiceDetails discreteLock do
		create wsHMSResourceUsed transient;
		wsHMSResourceUsed.setProxyFromMarineService(marineServiceDetail);
		self.allHMSResourcesUsed.add(wsHMSResourceUsed);
		
	endforeach;
	
	foreach wodCargoRequest in  _object.allCargoDetails  discreteLock do
		create wsDetail as WS_WorkOrderCargoRequest transient;
		wsDetail.setProxyFromObject(wodCargoRequest);
		self.allCargoRequests.add(wsDetail);
	endforeach;
	
	wo := _object.myParent;							// 21.02.2024 navsck1 #62237
	if wo &lt;&gt; null then								// 21.02.2024 navsck1 #62237
		foreach file in wo.allFiles do				// 21.02.2024 navsck1 #62237
			create wsDocument transient;			// 21.02.2024 navsck1 #62237
			wsDocument.setProxyFromObject(file);	// 21.02.2024 navsck1 #62237
			self.allDocuments.add(wsDocument);		// 21.02.2024 navsck1 #62237
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodVoyageCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="51c1483a-1ce7-44ef-a1f2-55ec601b9397">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodVoyageCargoRequest input);
/*
Purpose:	TFS 40435		
Date				Who			Reason
AUGUST 2018		CNWAB1		Initial creation
*/

vars
	berthTo : HMS_Berth;
	pxyResourceUsed : HMS_ResourceUsed;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	voyage,
	myTowingVoyage 	: CM_Voyage;
	voyageStatus  	: CM_VoyageStatus;
	hmsResource 	: HMS_Resource;
	wodCargoRequest, pxyWorkOrder : CM_WodCargoRequest;
	wsDetail : WS_WorkOrderDetail;
	wscDetail : WS_WorkOrderCargoRequest;
	allFiles : CM_FileDataSet;
	wsDocument : WS_Document;
	pxyFile : CM_FileData;

begin
	inheritMethod(_pxyWorkOrder);
	
	if self.toBerthOid &lt;&gt; null then
		berthTo := app.myPassport.getObjectOfTypeFromOid(self.toBerthOid,HMS_Berth).HMS_Berth;
	endif;
	
	
	_pxyWorkOrder.setProxyWodVoyageCargoRequest(self.occursOnDT.asTimeStampFromWebInterface,
											berthTo);
	
	

	
	create allPxyHMSResourcesUsed transient;
	
	foreach wsHMSResourceUsed in self.allHMSResourcesUsed discreteLock do
		create pxyResourceUsed transient;
		wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
		
		allPxyHMSResourcesUsed.add(pxyResourceUsed);		
	endforeach;
	
	_pxyWorkOrder.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);

	foreach wsDetail in self.allCargoRequests	discreteLock do
		wscDetail := wsDetail.WS_WorkOrderCargoRequest;
		
		// Copy my documents onto the first cargo request
		if not self.allDocuments.isEmpty() then
			self.allDocuments.copy(wscDetail.allDocuments);
			self.allDocuments.purge;
		endif;
		
		create pxyWorkOrder transient;
		wscDetail.updateProxyWorkOrder(pxyWorkOrder);
		_pxyWorkOrder.allCargoDetails.add(pxyWorkOrder);
	endforeach;
	

epilog
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
	endif;
	delete allPxyHMSResourcesUsed;

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodVoyageCargoRequest" usage="input"/>
    </JadeMethod>
</Class>
