    <JadeMethod name="getXMLItemCost" id="a492c1ca-addf-45b4-b914-e0e9ca44997e">
        <source>getXMLItemCost() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
vars
	result	: String;
	rate	: Real;
//	gst,
//	net,
//	total	: Decimal[18,2];
	gst, net, total	: Decimal[22,2];	//11 May 2018	NDL	TFS 38528
begin
	if self.quantity &gt; 0 then
		rate := self.lineTotal / self.quantity;
	endif;
	net := self.lineTotal;
	gst	:= self.getTaxAmountForLine();
	total := net + gst;

	result := '&lt;itemcost&gt;' &amp; CrLf &amp;
			  '&lt;currency&gt;NZD&lt;/currency&gt;' &amp; CrLf &amp;
			  //'&lt;unitprice&gt;' &amp; rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false) &amp; '&lt;/unitprice&gt;' &amp; CrLf &amp;
			  '&lt;unitprice&gt;' &amp; rate.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, false) &amp; '&lt;/unitprice&gt;' &amp; CrLf &amp;		// TFS 36954 MPD 20 Feb 2018
			  '&lt;quantity&gt;' &amp; self.quantity.rounded.String &amp; '&lt;/quantity&gt;' &amp; CrLf &amp;
			  '&lt;netamount&gt;' &amp; net.String &amp; '&lt;/netamount&gt;' &amp; CrLf &amp;
			  '&lt;gst&gt;' &amp; gst.String &amp; '&lt;/gst&gt;' &amp; CrLf &amp;
			  '&lt;totalamount&gt;' &amp; total.String &amp; '&lt;/totalamount&gt;' &amp; CrLf &amp;
			  '&lt;/itemcost&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLItemDetails" id="0a1343c4-07c8-4d8c-9513-2e31f5d1e745">
        <source>getXMLItemDetails() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
	itemId	: String;
begin
	//itemId := self.invoiceLineDesc.getDebtorInvLineType;
	result := '&lt;itemdetails&gt;' &amp; CrLf &amp;
			  '&lt;itemidentifier&gt;' &amp; itemId &amp; '&lt;/itemidentifier&gt;' &amp; CrLf &amp;
			  '&lt;itemdescription&gt;' &amp; self.invoiceLineDesc.narration &amp; '&lt;/itemdescription&gt;' &amp; CrLf &amp;
			  '&lt;/itemdetails&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSubline" id="7bfde7dc-2f01-4951-830f-094e77c364e2">
        <source>getXMLSubline() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
	isStorage	: Boolean;
	equipType	: String;
	itemId		: String;
	dateId		: String;
	eventDate	: Date;
	startDate,
	endDate		: Date;
	ti			: CM_TrackedItem;
begin
	if self.myTransactionTI &lt;&gt; null and self.myTransactionTI.isKindOf(CM_Storage) then
		isStorage := true;
	endif;
	equipType := "UN";
	ti := self.getTrackedItem();
	if ti &lt;&gt; null and
	   ti.isContainer() then
		equipType := "CH";
	endif;
	itemId := self.getTIID();
	eventDate := self.chargeTime.date;
	dateId := '140';

	if itemId &lt;&gt; null then
		result := '&lt;equipment&gt;' &amp; CrLf &amp;
				'&lt;equipmenttype&gt;' &amp; equipType &amp; '&lt;/equipmenttype&gt;' &amp; CrLf &amp;
				'&lt;equipmentidentifier&gt;' &amp; itemId &amp; '&lt;/equipmentidentifier&gt;' &amp; CrLf &amp;
				'&lt;quantity&gt;' &amp; self.quantity.String &amp; '&lt;/quantity&gt;' &amp; CrLf &amp;
				'&lt;/equipment&gt;' &amp; CrLf;
	endif;
	result := result &amp; '&lt;eventdate&gt;' &amp; CrLf &amp;
			  '&lt;dateidentifier&gt;' &amp; dateId &amp; '&lt;/dateidentifier&gt;' &amp; CrLf &amp;
			  '&lt;datevalue&gt;' &amp; eventDate.userFormat($ODBC_Date) &amp; '&lt;/datevalue&gt;' &amp; CrLf &amp;
			  '&lt;/eventdate&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
