    <JadeMethod name="getLocationDisplay" id="efd71c71-6140-411d-9424-7071e7579380">
        <source>getLocationDisplay(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	08 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.usage = BUILDING_USE then
		return LOC_Display_Building;
	elseif self.usage = LIGHT_TOWER_USE then
		return LOC_Display_LightTower;
	elseif self.usage = REEFERGANTRY_USE then
		return LOC_Display_ReeferGantry;
	elseif self.availability &lt;&gt; PAD_AVAILABLE then
		return LOC_Display_Unavailable;
	elseif self.is45ft then
		return LOC_Display_45ft;
	elseif self.is20ft then // PAR 18682 CCMS SFW 1055
		return LOC_Display_20ft; // PAR 18682 CCMS SFW 1055
	elseif self.is40ft then // PAR 18682 CCMS SFW 1055
		return LOC_Display_40ft; // PAR 18682 CCMS SFW 1055
	elseif self.is30ft then
		return LOC_Display_30ft; // PAR 16415 CCMS 1029
	elseif self.is53ft then
		return LOC_Display_53ft; // PAR 16415 CCMS 1029
	endif;
	
	return inheritMethod();


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxAllowedStackingHeight" id="0a5f4fda-8370-44f4-a183-6f93d4ff130f">
        <source>getMaxAllowedStackingHeight(set : CM_GridControllersByRowColumn; oa : ObjectArray io) : Integer;

/*

Purpose:			Gets the smaller of the stacking heights from self 
					and the nextController
					Also saves self and next so they are not used again

Parameters:			

Return Value:		Number of containers allowed


Date		Who		Reason
21 August 2008	conkc1	Initial creation

*/
vars
	nextGC            : CM_GridController;
	maxStackingHeight : Integer;
	nextGCMaxStackingHeight : Integer;
begin
	//
	// Get the next CM_GridController
	//
	nextGC := self.myNextController;
	//
	// nextGC must exist and must be in the set and self and nextGC must not have been
	// used in a previous calculation
	//
	if nextGC = null then
		return 0;
	endif;
	if set.includes(nextGC) = false then
		return 0;
	endif;
	if oa.includes(self) = true then
		return 0;
	endif;
	if oa.includes(nextGC) = true then
		return 0;
	endif;
	//
	// Add self and nextGC to array so we dont use them again
	// This then handles both ascending and descending order of LC's
	//
	oa.add(self);
	oa.add(nextGC);
	// Get my maxStackingHeight
	maxStackingHeight := self.getMaxStackingHeight;
	// Get nextControllers maxStackingHeight and use the smaller
	nextGCMaxStackingHeight := nextGC.getMaxStackingHeight;
	if nextGCMaxStackingHeight &lt;= maxStackingHeight then
		return nextGCMaxStackingHeight;
	else
		return maxStackingHeight;
	endif;

	return 0;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <Parameter name="oa" type="ObjectArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxStackingHeight" id="8c16d7d4-c176-4169-a623-8b8580c65c31">
        <source>getMaxStackingHeight() : Integer;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	maxHeight	: Integer;
	area		: CM_GridArea;
begin

	// DVB 5/04/04 Par 7462. Added resynch. Getting wrong max height.
	
	if self.availability = PAD_AVAILABLE then
		area := self.myTerminalArea.CM_GridArea;
		//self.resynchObject(area);
		maxHeight := area.heightOfStack;
	else 
		// DVB changed to stop it returning negatives.
		maxHeight := (self.availability  - 3).max(0); // PAR 7861
	endif;
	return maxHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPic" id="f3cc9bb0-58bf-4db1-afd5-6a1fa52d2af9">
        <source>getPic(): String;
/*
----------   ----------  --------------------------------------------------
