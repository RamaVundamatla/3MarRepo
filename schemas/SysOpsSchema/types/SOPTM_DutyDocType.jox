    <JadeMethod name="setupThumbnailDetails" id="7da7a787-7390-4872-9dd8-dcb3719b9521">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_DutyDocType);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_DutyDocType);	
	self.myForm.shtTblInput1.visible := true;
	//epr par 31299 18/3/13
	self.myForm.myAssistant.comboBoxIMEXStatus(self.myForm.comboBox1, null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="092aa5e2-7085-450c-87c1-bcc6b87922b1">
        <updating/>
        <source>showThumbnail(_hsType : CM_DutyDocType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Code, _hsType.code);
	self.myForm.tblInput1.setValueByName(ETRow_Description,	_hsType.description);
	self.myForm.tblInput1.setValueByName(ETRow_DutyCharged, _hsType.dutyCharged);
	self.myForm.tblInput1.setValueByName(ETRow_ImexStatus, _hsType.getImexString()); //epr par 31299 18/3/13
	self.myForm.comboBox1.text := _hsType.getImexString();
epilog

end;</source>
        <Parameter name="_hsType" type="CM_DutyDocType"/>
    </JadeMethod>
</Class>
