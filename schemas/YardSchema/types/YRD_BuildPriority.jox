    <JadeMethod name="buildComboStatus" id="bbffc281-2835-4a61-8870-6811a7568963">
        <source>buildComboStatus();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/05/2010	cnwdap1		CCMS 1116 Tranship changes
// ---------------------------------------------------------------------------

vars
/*	str		: String;
	theRow 	: Integer;
	exportDescr	: String;*/
	contents : CM_ContentsStatus;
	idx : Integer;
	status : CM_IMEXStatus;		
begin

	self.cmbImexStatus.clear;
	
	foreach status in app.myRoot.allImexStatuses do
		if status.code = TI_IMEX_STATUS_EXPORT or
		   status.code = TI_IMEX_STATUS_IMPORT or
		   status.code = TI_IMEX_STATUS_STORAGE or
		   status.code = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
			idx := 	self.cmbImexStatus.addItem(status.description);
			self.cmbImexStatus.itemObject[idx] := status;
			self.cmbImexStatus.itemData[idx] := status.code;
		endif;
	endforeach;
	
	contents := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_EMPTY];
	
	idx := 	self.cmbImexStatus.addItem(contents.description);
	self.cmbImexStatus.itemObject[idx] := contents;
	self.cmbImexStatus.itemData[idx] := contents.code;	
	
/*	exportDescr := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
	
	// if these codes are added/deleted then may need to alter GTE_Assistant.receival_SetTableByIMEXStatus as well
	str := exportDescr &amp; Tab &amp;
			app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT].description &amp; Tab &amp;
			app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE].description &amp; Tab &amp;
			app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_EMPTY].description &amp; Tab;
	
	theRow := self.tblStatus.getRow(ETRow_StatusString);
	self.tblStatus.setComboValues(theRow, str);
	self.tblStatus.setValue(theRow, exportDescr);
	
	self.cmbStatus.addItem("Import");
	self.cmbStatus.addItem("Export");
	self.cmbStatus.addItem("Storage");
	self.cmbStatus.addItem("Empties");

	self.cmbImexStatus.listIndex := 2;*/
	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboTransferTerminals" id="236126ad-932b-4d35-b5c3-e8684e9a446c">
        <source>buildComboTransferTerminals();
// -------------------------------------------
// Created 29 July 2004 by cnwdvb1
// -------------------------------------------
vars

	terminal	: CM_Terminal;

begin

	terminal := app.myPassport.myTerminal;
	terminal.getOtherTerminals(self.allOtherTerminals);
	self.cmbDestTerminal.listCollection(self.allOtherTerminals, false, 0);
	self.cmbDestTerminal2.listCollection(self.allOtherTerminals, false, 0);

end;</source>
