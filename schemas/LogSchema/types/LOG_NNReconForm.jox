    <JadeMethod name="setupForm" id="3e0bd53a-451b-4911-90c3-35ed79037e78">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 08 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	int : Integer;
begin
	inheritMethod();
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;

	self.lblSupplier.caption	:=	app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	int := self.getTextExtent(self.lblSupplier.caption);
	self.lblSupplier.width		:=	int;
	self.cmbOperator.left		:=	self.lblSupplier.left + int + 7;
	self.splMain.parentAspect	:=	Control.ParentAspect_StretchBoth;

	self.initForm();
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.btnNext.enabled:= false;
		self.grpUpdate.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblLocations_click" id="13a0080b-0eb5-4db2-949c-426740b61244">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocations_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	self.selectCurrentRow(table);
	self.loadNNDtlsMatchSpec();
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
