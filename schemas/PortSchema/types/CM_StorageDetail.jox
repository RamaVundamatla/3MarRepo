    <JadeMethod name="setForUpdate" id="3470e52c-9f78-48a5-bcda-ebc13ffc7a5a">
        <updating/>
        <source>setForUpdate(_proxyStorageDetail : CM_StorageDetail) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 21 Jul 2017			cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
//20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
// 29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date
//30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
//16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
//29/02/2023	navkc1 	CR 61899 Task 61904: Jade - Storage TRX
vars
	pxyCriteria,criteria: CM_YACriteria;
	sortValue		: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
begin
	self.chargedDaysType := _proxyStorageDetail.chargedDaysType;
	self.freeDaysType := _proxyStorageDetail.freeDaysType;
	self.freeStorageDays := _proxyStorageDetail.freeStorageDays;
	self.stopCompletionFreeDays := _proxyStorageDetail.stopCompletionFreeDays;			// TFS 2570
	
	self.chargeDays := _proxyStorageDetail.chargeDays; // PAR 36275 NEW
	self.receivalDateRule := _proxyStorageDetail.receivalDateRule;  //epr TFS 2884 19/12/16
	self.noStorageIfNotFullyReceived := _proxyStorageDetail.noStorageIfNotFullyReceived;  //epr TFS 2884 19/12/16
	self.myFutureStorageStop :=_proxyStorageDetail.myFutureStorageStop; //21.07.2017 cnwma1 TFS #5409
	
	// 29/05/2023	navkc1	CR 58011 Task 58012
	self.roadReceivalType := _proxyStorageDetail.roadReceivalType;
	self.shipReceivalType := _proxyStorageDetail.shipReceivalType;
	self.railReceivalType := _proxyStorageDetail.railReceivalType;
	self.unpackReceivalType := _proxyStorageDetail.unpackReceivalType;
	
	//16/06/2023	navkc1	CR 58221 Task 58222
	self.cooFreeDaysType := _proxyStorageDetail.cooFreeDaysType;
	self.cooFreeStorageDays := _proxyStorageDetail.cooFreeStorageDays;
	
	// 30/05/2023	navkc1	CR 58013 Task 58014
	self.allAdditionalCalendars.clear();
	_proxyStorageDetail.allAdditionalCalendars.copy(self.allAdditionalCalendars);
	
	self.myStorageConfig := _proxyStorageDetail.myStorageConfig;
	if self.allCriteria &lt;&gt; null and not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;
	sortValue	:=	0;
	foreach pxyCriteria in _proxyStorageDetail.allCriteria do
		create criteria persistent;
		criteria.setForCreate(	pxyCriteria );		
		criteria.setPriorityValue(2 ^ sortValue);
		criteria.setYardAllocation(self);
		
		sortValue		:=	sortValue + 1;
	endforeach;
//	self.recalculateCriteriaPriorities();	//18 May 2016	NDL	TFS 1981
	// TFS 4271 self.priorityValue := _proxyStorageDetail.priorityValue;	//18 May 2016	NDL	TFS 1981
	
	self.validateCriteria();
	
	if _proxyStorageDetail.description.trimBlanks = null then // TFS 5225
		self.description := self.getDefaultDescription();  // TFS 5225
	else
		self.description :=  _proxyStorageDetail.description.trimBlanks; // TFS 5225
	endif;
	
	self.includeFirstDay := _proxyStorageDetail.includeFirstDay; //29/02/2023	navkc1 CR 61899 Task 61904
	self.includeLastDay := _proxyStorageDetail.includeLastDay; //29/02/2023	navkc1 CR 61899 Task 61904
	
	self.setPriority(); // TFS 4271

end;
</source>
        <Parameter name="_proxyStorageDetail" type="CM_StorageDetail"/>
    </JadeMethod>
    <JadeMethod name="setMyStorageConfig" id="ff5718ae-92d3-4a62-a74b-cd25934560aa">
        <updating/>
        <source>setMyStorageConfig(_config : CM_StorageConfig) updating;
/*
Purpose:			
Date		Who		Reason
04 July 2017	cnwab1	Initial creation
*/

vars

begin
