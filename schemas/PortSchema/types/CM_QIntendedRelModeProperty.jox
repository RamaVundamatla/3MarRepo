<Class name="CM_QIntendedRelModeProperty" id="7f4c6c5a-b38b-464e-84f5-bd9d4d1b2877">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="89d4fc7d-b330-4369-a7f7-7d0f76433440">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="379a11dc-a1f1-4701-97b9-c4c5f469779e">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_RAIL).length;
	length := length.max (app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_ROAD).length);
	length := length.max (app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_SHIP).length);
	length := length.max (app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_NULL).length);
	
	return length;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
