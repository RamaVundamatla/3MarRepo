<Class name="CM_YATypeSubTerminal" id="af01f3d6-a239-450a-b47c-36631f3c27bc">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="ad2f2ac1-5aee-439e-8bfb-c9d16f8630d8">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	_terminalObj.allSubTerminals.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="328c4814-9a4a-4cac-bdef-6f55e6e756e2">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
// --------------------------------------------------------------------------------
// Created:		17 April 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_criteriaObject	:=	_ti.mySubTerminal;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="c3864f05-5b13-41e7-bd09-cf15972e3b16">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="93f777cd-77c1-4b83-a4ee-644bebe37fd6">
        <source>getDisplay(dataObj: Object): String;
// --------------------------------------------------------------------------------
// Created:		17 April 2009 by cnwdad1
//
// Purpose:		Standard method to return a display value for an instance of the
//				receiver's data type.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return dataObj.CM_SubTerminal.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="52b921c9-7bb1-488b-b901-a95ea52c208b">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Dec 2010	cnwjre1	25237 method was not implemented
*/
vars
	subTerm    : CM_SubTerminal;
	terminal : CM_Terminal;
begin

	terminal := app.getMyTerminalDO_NOT_USE;
	
	foreach subTerm in terminal.allSubTerminals do 
		objects[subTerm.getYAIdentifier()] := subTerm;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="58309ecb-d3df-4278-b894-3e9da488440c">
