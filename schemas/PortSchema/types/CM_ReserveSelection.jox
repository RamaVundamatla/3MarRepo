    <JadeMethod name="getWeight" id="2e31bee1-3d86-44de-81bb-afcf32e62da8">
        <source>getWeight(): Integer;
// 20/10/2015 	cnwma1 PAR #36146 Provisional Baplie File for Vessel
//25 Mar 2024 	navma1 ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
vars
	isoType : CM_ISOType;
	isoGrp  : CM_ISOTypeGroup;
begin
	// CCMS 1925 
	if self.weightSelection &lt;&gt; 0 then
		return self.weightSelection.Integer;
	endif;
	
	// CCMS 1925 DJW the weight of a container is its empty weight - needed for bulk empty releases on ship
	isoType := self.myISOType;					 //25.03.2024 navma1 #63141
	if isoType &lt;&gt; null then
		return isoType.tareKilos;
	endif;
	
	isoGrp := self.myISOGroup;					 //25.03.2024 navma1 #63141
	if isoGrp &lt;&gt; null then   					 //20/10/2015 cnwma1 PAR #36146
		return isoGrp.maxTareWeight;
	endif;	
	
	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
