    <JadeMethod name="isContainerImport" id="aa6508c6-55e0-4e69-94ac-f419cb349bd7">
        <source>isContainerImport(_containerId : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	job : CM_VoyageJob;
	theTI		: CM_TrackedItem;

begin
	theTI := self.isValidOnQueuedVoyageTIID(_containerId,null);

	if theTI = null then
		theTI := self.isValidTIID(_containerId,null);
	endif;
	
	if theTI = null then
		return false;
	endif;
	
	job := theTI.getFirstAvailableDischargeJob();
	if job &lt;&gt; null  then
		if (job.myVoyage &lt;&gt; self.myVoyage) and (self.myVoyage &lt;&gt; null) then
			return false;
		endif;
	endif;
	
	return (job &lt;&gt; null);
epilog
end;


</source>
        <Parameter name="_containerId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isHazardous" id="8ec4612e-762e-4edb-aa46-b751756b4201">
        <source>isHazardous(_fwd : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		26 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tag : String;
begin
	tag := " (HAZARDOUS)";
	
	if _fwd then
	
		if self.myTI_FWD &lt;&gt; null and self.myTI_FWD.isHazardous then
			return tag;
		endif;
	else
		if self.myTI_AFT &lt;&gt; null and self.myTI_AFT.isHazardous then
			return tag;
		endif;
	
	endif;
	
	return null;
end;</source>
        <Parameter name="_fwd" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidContainer" id="ff937f4c-a277-467a-8aa7-078bffae8e72">
        <updating/>
        <source>isValidContainer(_get : Boolean; _fwd : Boolean; _vehicleID, _containerId, _voyageCode, 
					_sealCust, _sealOp, _sealShip : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	job : CM_VoyageJob;
	vehicle		: CM_Machine;
	error		: DTO_HandHeldGateError;
	roadJob		: CM_RoadJob;
	theTI		: CM_TrackedItem;
	inJob, sealChecked		: Boolean;
	wleArray	: CM_WLEArray;
	wle			: CM_WorkListEntry;
	tag, tiVoyageCode : String;
begin


	vehicle := self.doConfirmIMV(_vehicleID, _errorMsgs);
	if vehicle = null then
		// an error has already been raised
		return null;
	endif;
	if _fwd then
		tag := "forward";
	else
		tag := "aft";
		
	endif;
	self.voyageCode := _voyageCode;
	
	theTI := self.isValidOnQueuedVoyageTIID(_containerId,_errorMsgs);

	//epr par 15508 18/7/08
	if not _errorMsgs.isEmpty then
		return null;
	endif;
	
	if theTI = null then
		theTI := self.isValidTIID(_containerId,_errorMsgs);
		if theTI = null then
			self.addError(Err_HandHeldID_No_Good, app.getErrorString1(Err_HandHeldID_No_Good, tag),_errorMsgs);
			return null;
		endif;
	endif;
	if theTI.id &lt;&gt; _containerId then
		self.addError(Err_HandHeldID_No_Good, app.getErrorString1(Err_HandHeldID_No_Good, tag),_errorMsgs);
		return null;
	endif;
	
	/* WAS PAR 22168
	if  (theTI.voyageCode &lt;&gt; self.voyageCode) then
		self.addError(Contai_voyage_your_curren_voya, app.getErrorString3(Contai_voyage_your_curren_voya, theTI.id, theTI.voyageCode, self.voyageCode), _errorMsgs);
		return null;
	
	endif;
	NOW from here */

	if theTI.myVoyage &lt;&gt; null then
		tiVoyageCode := theTI.myVoyage.code; 
	else
		tiVoyageCode := theTI.voyageCode;
	endif;
	if  (tiVoyageCode &lt;&gt; self.voyageCode) then
		self.addError(Contai_voyage_your_curren_voya, app.getErrorString3(Contai_voyage_your_curren_voya, theTI.id, theTI.voyageCode, self.voyageCode), _errorMsgs);
		return null;
	endif;
	// PAR 22168 to here

	if theTI &lt;&gt; null then
		_errorMsgs.clear;
	endif;
	
	if _get then
		return theTI;
	endif;
	
	self.isValidJobAndLane(_fwd, theTI,_errorMsgs);

	//validate id, customs seal, operator seal and shipper seal
	if theTI.id &lt;&gt; _containerId then
		self.addError(Err_HandHeldID_No_Good, app.getErrorString1(Err_HandHeldID_No_Good, tag),_errorMsgs);
	endif;


	// PAR 21958
	if theTI.isRehandle then
		if theTI.isOnSite then
			job := theTI.getFirstAvailableLoadJob();
		else
			job := theTI.getFirstAvailableDischargeJob();
		endif;
	else
		job := theTI.getFirstAvailableDischargeJob();
	endif;
	
	if theTI.isKindOf(CM_Container) and job &lt;&gt; null then // imports and storage only		
		//epr 8/12/09 CCMS 1900 par 21806 moved validation into CM_ValidationUpdateAgent::valCargoSeals
		self.doUpdateSeals(theTI, _sealCust, _sealOp, _sealShip, _errorMsgs); // CCMS 1668 PAR 16534
	endif;

	if _fwd then
		self.myTI_FWD := theTI;
	else
		self.myTI_AFT := theTI;
	endif;
	
	return null;
epilog
end;


</source>
        <Parameter name="_get" type="Boolean"/>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_containerId" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_sealCust" type="String"/>
        <Parameter name="_sealOp" type="String"/>
        <Parameter name="_sealShip" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="isValidJobAndLane" id="a7480c7b-0109-4bca-8933-8184c2bf9a92">
        <updating/>
        <source>isValidJobAndLane(_fwd : Boolean; _container : CM_TrackedItem; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date			Who		Reason
// 09 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
// 15/07/2010	cnwdap1	PAR #25021 - review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	crane	:	CM_Crane;
	job	:	CM_VoyageJob;
	msgStr,tiId	:	String;
	acontinue	:	Boolean;
	tmpLC	: CM_LocationsController;
	clc : CM_CraneLaneController;
	itsAvailable: Boolean;
	queueTask: CM_RTQueueTask;

begin
	//------------------
	//Make sure TI is a DISCHARGE TI, this means that its either ON the ship, OR
	//Sitting in a locations controller that is part of a CTA. (it can be moved here
	//by the code below, when offered to a machine (who rejects it, and leaves the TI
	//there).
	//We check the job stuff after this...
	//------------------
	tmpLC :=_container.getPrimaryLocation(REAL_MODE);
	if tmpLC.isYardLocation() then
		if _container.isImport  then
			self.addError(Already_yard, app.getErrorString2(Already_yard, _container.id.trimRight, tmpLC.getFullId()), _errorMsgs);
		else
			self.addError(Still_yard, app.getErrorString2(Still_yard, _container.id.trimRight, tmpLC.getFullId()), _errorMsgs);
		endif;
		return;
	
	endif;

	
	
	itsAvailable := false;
	if tmpLC.isKindOf(CM_MachineController) then
		//check to see if this ti has been left dangling from a machine in error 1724 rs 20/2/2002
		//ie if a machine has it and the queuetask is unactioned then its available
		queueTask := _container.getQueueTask;
		if queueTask &lt;&gt; null then
			if queueTask.machine = null and queueTask.status = TASK_UNACTIONED then
				itsAvailable := true;
			endif;
			//if _container.isExport and									// PAR #25021
			if (_container.isExport or _container.isTranshipOutbound) and 	// PAR #25021
			   queueTask.machine &lt;&gt; null and
			   queueTask.machine.myMachineController = tmpLC and
			   queueTask.status = TASK_WORKING then
				itsAvailable := true;
			endif;
		else
			itsAvailable := true;
		endif;
	elseif tmpLC.isKindOf(CM_SlotController) then
		itsAvailable := true;
	elseif tmpLC.getParent.isKindOf(CM_CraneTransferArea) then
		itsAvailable := true;
	endif;
	if not itsAvailable then
		//if _container.isExport then									// PAR #25021
		if _container.isExport or _container.isTranshipOutbound then	// PAR #25021
			if tmpLC.isYardLocation() then
				self.addError(Been_assigne_still_yard, app.getErrorString2(Been_assigne_still_yard, _container.id.trimRight, tmpLC.getFullId()), _errorMsgs);
			else
				self.addError(Been_assigned, app.getErrorString1(Been_assigned, _container.id.trimRight), _errorMsgs);
			endif;
			return;
		else
			// not on ship, on IMV on under crane, so is already discharged.
			self.addError(Already_discharged, app.getErrorString2(Already_discharged, _container.id.trimRight, tmpLC.getFullId()), _errorMsgs);
			return;
		endif;
	endif;
	//------------------
	//Ascertain the job we are working on
	//------------------
	//if _container.isExport then									// PAR #25021
	if _container.isExport or _container.isTranshipOutbound then	// PAR #25021
		job := _container.getFirstAvailableLoadJob();

		if job = null then
			self.addError(Part_export, app.getErrorString1(Part_export, _container.id.trimRight), _errorMsgs);
			return;
		endif;
	
		if job.isDischarge then
			self.addError(Part_import_must_part_export, app.getErrorString1(Part_import_must_part_export, _container.id.trimRight), _errorMsgs);
			return;
		endif;
	// PAR 21958
	elseif _container.isRehandle then
		if _container.isOnSite() then 
			job := _container.getFirstAvailableLoadJob();
		else
			job := _container.getFirstAvailableDischargeJob();
		endif;
		if job = null then
			msgStr := app.getErrorString1(ERR_NOT_DISCHARGE, _container.id.trimRight);
			self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
			return;
		endif;
	else
		job := _container.getFirstAvailableDischargeJob();
		if job = null then
			msgStr := app.getErrorString1(ERR_NOT_DISCHARGE, _container.id.trimRight);
			self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
			return;
		endif;
	
		if not job.isDischarge then
			msgStr := app.getErrorString1(ERR_NOT_DISCHARGE, _container.id.trimRight);
			self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
			return;
		endif;
	endif;
	

	if self.craneLaneID.trimRight = null then
		//------------------
		//Send the crane lane if we have it...
		//------------------
		if _container.site = TI_SITE_ONSITE and tmpLC.isKindOf(CM_CraneLaneController) then
			self.craneLaneID := tmpLC.CM_CraneLaneController.getLaneId();
			acontinue := true;
		endif;
	else
		acontinue := true;
	endif;
	//------------------
	//Check the lane exists.
	if _fwd then
		self.myVoyageJob_FWD := job;
	else
		self.myVoyageJob_AFT := job;
	endif;
	//------------------
	crane := job.getJobCrane();
	clc := null;
	if crane = null then
		clc := null;
	else
		if acontinue = false then
			//------------------
			//OK, supply a default lane
			//------------------
			clc := crane.transferArea.getFirstAvailableDischLane().CM_CraneLaneController;
			if clc = null then
				/*msgStr := app.getErrorString1(Full_Replacement_Message, "There is no available discharge lane specified for the crane queue.");
				self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
				self.addError(There_avail_disch_lane_speci_c, app.getErrorString(There_avail_disch_lane_speci_c), _errorMsgs);
				return;	
 			endif;		
			self.craneLaneID := clc.getLaneId();
		else
			clc := crane.transferArea.getLaneLC(self.craneLaneID).CM_CraneLaneController;
		endif;
	endif;

	if clc = null then
		//--------------
		//Invalid location
		//--------------
		/*msgStr := app.getErrorString1(ERR_INVALID_LOCN, self.craneLaneID);
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
		self.addError(ERR_INVALID_LOCN, app.getErrorString1(ERR_INVALID_LOCN, self.craneLaneID), _errorMsgs);
		return;
	endif;
	
	if _fwd then
		self.myCraneLaneLC_FWD := clc;
	else
		self.myCraneLaneLC_AFT := clc;
	endif;

end;</source>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_container" type="CM_TrackedItem"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isValidOnQueuedVoyageTIID" id="f28a3208-d599-46dc-b32e-673dddaba7a4">
        <source>isValidOnQueuedVoyageTIID(_containerId : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//As we have major problems determining WHICH voyage we are working on, then we find all
//of the current Queues that are for voyages, and ask each voyage for the TI we are looking for
//hopefully, we will hit the one we want.
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	voyages	:	CM_VoyageArray;
	term	:	CM_Terminal;
	masterQ	:	CM_MasterQueue;
	tiId	:	String;
	ti	:	CM_TrackedItem;
	voyage	:	CM_Voyage;
	aQ	:	CM_RadioTelemetryQueue;
	msgStr	:	String;
	theSize : Integer;
	tiSet	: CM_TISet;
	
begin
	tiId := _containerId;
	if tiId = null then
		//-------------------
		//No id. Simply do nothing!
		//-------------------
		return null;
	endif;
	
	//par 18768 cnwjo3
	if self.myMachine = null then
		//machine has been cleared but other items have not
		//been refreshed, so cancel out
		return null;
	endif;
	
	create tiSet transient;
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.searchForOnShipTI(tiId.toUpper, tiSet) then
			self.doUpdateRemoveChildren(tiSet); // PAR 22155
			theSize := tiSet.size();
			if theSize &gt; 1 then
				//epr par 15508 18/7/08
				msgStr:=app.getErrorString(MultipleItems);
				self.addError(MultipleItems, msgStr, _errorMsgs);
				return null;
				//app.raiseCMException1(MultipleItems, null, null, null);
			else
				ti := tiSet.first();
				return ti;
			endif;
		endif;
		
		///  PAR 20078 cnwrs2
		self.myVoyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(tiId.toUpper, TI_CargoType_Null, tiSet, null);
		self.doUpdateRemoveChildren(tiSet); // PAR 22155
		theSize := tiSet.size();
		if theSize &gt; 1 then
			//epr par 15508 18/7/08
			msgStr:=app.getErrorString(MultipleItems);
			self.addError(MultipleItems, msgStr, _errorMsgs);
			return null;
			//app.raiseCMException1(MultipleItems, null, null, null);
		elseif theSize = 1 then
			ti := tiSet.first();
			return ti;
		endif;
		///
	endif;
	
	term	:=	self.myTerminal;
	masterQ := term.radioTelemetry.masterQueue;
	if masterQ = null then
		return null;
	endif;
	//------------------
	//This machine is in a Queue, if its a voyage queue, use that first!
	//------------------
	aQ := self.myMachine.getQueue();
	if aQ.isKindOf(CM_VoyageQueue) then
		voyage := aQ.CM_VoyageQueue.myVoyage;
	elseif aQ.isKindOf(CM_VoyageCraneQueue) then
		voyage := aQ.CM_VoyageCraneQueue.myVoyage;
	endif;

	//----------------
	//Grab all other queues
	//----------------
	if voyage = null then
		voyages	:= masterQ.getVoyageQueueVoyages();
		if voyages = null then
			return null;
		endif;
	else
		create voyages transient;
		voyages.add(voyage);
 	endif;
	//---------------------
	//Search for the TI. (on each voyage)
	//---------------------
	
	/*foreach voyage in voyages do
		ti := voyage.searchForOnShipTI(tiId.toUpper);
		if ti &lt;&gt; null then
			resynchObject(ti);
			return ti;
		endif;
 	endforeach;*/
	
	foreach voyage in voyages do
		if voyage.searchForOnShipTI(tiId.toUpper, tiSet) then
			self.doUpdateRemoveChildren(tiSet); // PAR 22155
			theSize := tiSet.size();
			if theSize &gt; 1 then
				//epr par 15508 18/7/08
				msgStr	:=	app.getErrorString(MultipleItems);
				self.addError(MultipleItems, msgStr, _errorMsgs);
				return null;
			else
				ti := tiSet.first();
				return ti;
			endif;
		endif;
		
		///  PAR 20078 cnwrs2
		voyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(tiId.toUpper, TI_CargoType_Null, tiSet, null);
		self.doUpdateRemoveChildren(tiSet); // PAR 22155
		theSize := tiSet.size();
		if theSize &gt; 1 then
			//epr par 15508 18/7/08
			msgStr	:=	app.getErrorString(MultipleItems);
			self.addError(MultipleItems, msgStr, _errorMsgs);
			return null;
			//app.raiseCMException1(MultipleItems, null, null, null);
		elseif theSize = 1 then
			ti := tiSet.first();
			return ti;
		endif;
		///
	endforeach;
	//-------------------
	//Could NOT locate TI on any of the voyages, or is bad type!
	//-------------------
	if ti = null then
		//Bad id, its not reversed, or a valid ti type!
		//-------------------
		msgStr := app.getErrorString2(ERR_KEY_NOT_FOUND, tiId, "Queued Voyages");
		self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
		return null;
	endif;
epilog
	//Transient array is created in mq::getVoyageQueueVoyages
	delete voyages;
	delete tiSet;
end;</source>
        <Parameter name="_containerId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="isValidTIID" id="eab966f6-96cc-4317-8e43-e8c03bc97640">
        <source>isValidTIID(_containerId : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Retrieves a field from a form that is REQUIRED to be the TI Id field.
//It then does a lookup, and if it finds it, returns a reference to the TI.
//If we cannot find it, we throw a hey-you message to the window, and return null.
//Use this to validate all ti-ids.
vars
	term	:	CM_Terminal;
	tiId	:	String;
	msgStr	:	String;
	ti	:	CM_TrackedItem;
	matches : Integer;
begin

	term := self.myTerminal;
	tiId := _containerId;
	if tiId = null then
		//-------------------
		//No id. Simply do nothing!
		//-------------------
		return null;
	endif;
	if self.myMachine = null then
		self.addError(IMV_Must_entered, app.getErrorString(IMV_Must_entered),_errorMsgs);
		return null;
	endif;
	
	//---------------------
	//Search for the TI.
	//---------------------
	ti := term.searchForOnsiteTI(tiId.toUpper(), matches, TI_CargoType_Container);
//	ti := term.searchForOnsiteTI(tiId.toUpper(), matches, TI_CargoType_Null);

	if ti = null then
		ti := term.searchForOnsiteTI(tiId.toUpper(), matches, TI_CargoType_Generator);
	endif;

	if ti = null then
		ti := self.myMachine.myMachineController.allTrackedItemsById[tiId.toUpper(), TI_CargoType_Container];
		if ti = null then
		
			//-------------------
			//Bad id, its not reversed, or a valid ti type!
			//-------------------
			msgStr := app.getErrorString2(ERR_KEY_NOT_FOUND, tiId, "Tracked Items");
			self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
			return null;
		endif;
	endif;
	if matches &gt; 1 then		
		msgStr := matches.String &amp; " items match this ID. Please re-enter";
		self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
		return null;
	endif;
	
	if _errorMsgs &lt;&gt; null then
		_errorMsgs.clear;
	endif;
	return ti;
end;</source>
        <Parameter name="_containerId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
