        <updating/>
        <source>frmGridArea_dblClick(frame: Frame input) updating;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	gridPoint : CMUI_GridPoint;
begin

	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;
	
	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos); 

	if gridPoint &lt;&gt; null then
		ti := gridPoint.getTI(self.origXPos, self.origYPos);
		if ti &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
		endif;
	endif;

end;</source>
