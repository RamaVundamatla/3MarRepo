    <JadeMethod name="validate" id="fc8acc9f-dcf2-49c0-8e0f-8b158cc5a2d0">
        <source>validate(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_passport);
	
	if self.myTerminalArea = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal Area', null, null);
		app.raiseCMException(Input_required_field_termArea, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9468490b-6d71-4849-9df5-286e1f5bc974">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	iter : Iterator;
	task : CM_RTQueueTask;
	invalidObj : Boolean;

begin
	if not self.allVehicleMachines.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId, app.getErrorString (Vehicle), null, null);
	endif;
	
	//28 July 2014	NDL	Par 34607
	on Exception do app.handleDeletedObject(exception, task, invalidObj);
	iter := CM_RTQueueTask.instances.createIterator;
	while iter.next(task) do
		if task.sourceLocation = self then
			app.raiseCMException2(ObjectStillHasEntries, self.getFullId, app.getErrorString (Task), null, null);
			break;
		elseif task.targetLocation = self then
			app.raiseCMException2(ObjectStillHasEntries, self.getFullId, app.getErrorString (Task), null, null);
			break;
		endif;
	endwhile;

	inheritMethod();

epilog
	
	delete iter;						// 29/07/2014 cnwmh5 
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateLocnCellsAscInArray" id="a83ff4a6-ab10-47c8-8196-0f806fb963e1">
        <source>validateLocnCellsAscInArray(_locnCellArray: CM_YALocationCellArray);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx,
	prevIdx		: Integer;
	locnCell	: CM_YALocationCell;
	tmpArray	: CM_YALocationCellArray;
begin

	tmpArray := _locnCellArray;
	prevIdx := 0;
	
	foreach locnCell in self.allYAYardLocationCells do
		idx := tmpArray.indexOf(locnCell);
		if idx &lt; prevIdx then
			app.raiseCMException3(INVALID_LOCN_CELL_ORDER, self.myTerminalArea.id &amp; ' ' &amp; self.ident, 'descending', 'IN', 'allYAYardLocationCells', null);
			return;
		endif;
		prevIdx := idx;	
	endforeach;

end;</source>
        <Parameter name="_locnCellArray" type="CM_YALocationCellArray"/>
    </JadeMethod>
    <JadeMethod name="validateLocnCellsDescInArray" id="12d5aa51-2d47-45ee-b875-1021a4b0fb46">
        <source>validateLocnCellsDescInArray(_locnCellArray: CM_YALocationCellArray);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx,
	prevIdx		: Integer;
	locnCell	: CM_YALocationCell;
	tmpArray	: CM_YALocationCellArray;
begin

	tmpArray := _locnCellArray;
	prevIdx := tmpArray.size;
	
	foreach locnCell in self.allYAYardLocationCells do
		idx := tmpArray.indexOf(locnCell);
		if idx &gt; prevIdx then
			app.raiseCMException3(INVALID_LOCN_CELL_ORDER, self.myTerminalArea.id &amp; ' ' &amp; self.ident, 'ascending', 'OUT', 'allYAYardLocationCells', null);
			return;
		endif;
		prevIdx := idx;	
	endforeach;

end;</source>
        <Parameter name="_locnCellArray" type="CM_YALocationCellArray"/>
    </JadeMethod>
    <JadeMethod name="validateMoveHazardRestriction" id="9628ddbc-5285-4c93-b7ac-35e5e0cccb31">
        <source>validateMoveHazardRestriction(_control: CMIF_MoveController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazDetail : CM_TerminalAreaHazDetails;
	ti : CM_TrackedItem;
	allowNonHaz : Boolean;
	match : Boolean;
	showError : Boolean;
	haz : CM_Hazard;
	tiHaz : CM_TIHazard;

begin
	sharedLock(self);
	
	if self.allTerminalAreaHazDetails.isEmpty then
		//No worries
		return;
	endif;
	
	ti := _control.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	allowNonHaz := false;
	match := false;
	showError := false;
	foreach hazDetail in self.allTerminalAreaHazDetails do
		// check for non-hazardous 
		if hazDetail.allowNonHazardous then
			allowNonHaz := true;
		endif;
		if hazDetail.showError then
			showError := true;
		endif;
		
		if ti.isHazardous then
			// check for matches on hazardous criteria
			foreach haz in ti.allTIHazards do
				tiHaz := haz.CM_TIHazard;
				if hazDetail.myHazardClass = null or hazDetail.myHazardClass.code = tiHaz.code then
					if hazDetail.allHazTempRanges.isEmpty or self.hasMatchingRangeForTemp(tiHaz.flashpointTemperature) then
						if hazDetail.packingGroups.isEmpty or hazDetail.packingGroups.includes(tiHaz.packingGroup) then
							if hazDetail.acidBase = null or hazDetail.acidBase = tiHaz.acidsBases then
								match := true;
								break;
							endif;
						endif;
					endif;
				endif;
			endforeach;
		endif;
		
		if match then
			break;
		endif;
	endforeach;
	
	// Are we trying to put a non-hazardous ti in an area that doesn't allow non-hazardous cargo?
	if not ti.isHazardous and not allowNonHaz then
		// raise error/warning - non-hazardous cargo not allowed here
		if showError then
			app.raiseCMException1(Terminal_Area_Not_NonHaz, _control.myToPrimaryLocationString, null, null);
		else
			app.raiseCMWarning1(Terminal_Area_Not_NonHaz, _control.myToPrimaryLocationString, null, null, null);
		endif;
	endif;
	
	// Did we find any matches on any hazardous criteria? No? - error/warning
	if ti.isHazardous and not match then
		if showError then
			app.raiseCMException2(Cargo_No_Match_Haz_Restrict, ti.id, _control.myToPrimaryLocationString, null, null);
		else
			app.raiseCMWarning2(Cargo_No_Match_Haz_Restrict, ti.id, _control.myToPrimaryLocationString, null, null, null);
		endif;
	endif;

epilog
	unlock(self);
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="05ed2c9c-b039-4f61-8e03-ef44a0e5f1cc">
        <source>validateMoveLabourRestriction(control : CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			31 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	sharedLock(self);
	
	if self.allLabourRestrictions.isEmpty then
		//No worries
		return;
	endif;
	
	// moved to CM_LabourRestriction::createWarning
	//if control.isRadioTelemetryMove then
	//	self.allLabourRestrictions.first.createWarningAsAlert(WARN_RESTRICT_LABOUR);
	//endif;

	self.allLabourRestrictions.first.createWarning(control);

epilog
	unlock(self);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="4faaf35c-6076-464f-b5ec-c79c3d3b1408">
        <source>validateMoveTo(_control: CMIF_MoveController input);
// -------------------------------------------
// Created 10 June 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 06/12/2011	cnwdap1		PAR #26619 CCMS SFW 1260 Raise an error if moving on top of an over-height TI
// 29/05/2019   cnwma1		Bug 44966: DPH - Location ID in error Code :87378 is not same as shown on grid area form
vars
	topTI		: CM_TrackedItem;		// PAR #26619
begin

	inheritMethod(_control);
	
	// PAR #26619 is there an over-height container under where I'm going to go?
	topTI := self.getTopTI(REAL_MODE);
	if topTI = null then
		topTI := self.getTopTI(QUEUE_MODE);
	endif;
	if topTI = null then
		topTI := self.getTopTI(PLANNING_MODE);
	endif;
	if topTI &lt;&gt; null and topTI &lt;&gt; _control.myTrackedItem and topTI.isOverHeight then
		
		if _control.myTrackedItem.isContainer and _control.myTrackedItem.CM_Container.isFrame then	//05 Feb 2018	NDL	TFS 36752
			//app.raiseCMWarning2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(_control.moveMode) &amp; "' " &amp; _control.myTrackedItem.id, myTerminalArea.id &amp; " " &amp; self.getNiceName, null, null, self); //29.05.2019 cnwma1 # 44966
			app.raiseCMWarning2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(_control.moveMode) &amp; "' " &amp; _control.myTrackedItem.id, _control.myToPrimaryLocationString, null, null, self);           //29.05.2019 cnwma1 # 44966
		else
			//app.raiseCMException2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(_control.moveMode) &amp; "' " &amp; _control.myTrackedItem.id, myTerminalArea.id &amp; " " &amp; self.getNiceName, null, self);      //29.05.2019 cnwma1 # 44966
			app.raiseCMException2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(_control.moveMode) &amp; "' " &amp; _control.myTrackedItem.id, _control.myToPrimaryLocationString, null, self);                //29.05.2019 cnwma1 # 44966
		endif;
		return;
	endif;
	// PAR #26619 end
	
	if _control.isForcedMove then
		return;
	endif;

	app.autoPlanValidateMoveToYA(self.myTerminal, self, _control.myTrackedItem);
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
