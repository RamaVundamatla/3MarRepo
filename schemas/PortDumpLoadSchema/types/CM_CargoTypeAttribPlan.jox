<Class name="CM_CargoTypeAttribPlan">
    <JadeMethod name="importPLXMLCollections" id="70cee6da-55cb-4d3b-a10f-2e62ad66010b">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars

begin
	inheritMethod(_name, _collectionsBlock);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="d821fb6f-9359-4967-b463-2d8a759b5663">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_CargoTypeAttribPlan::myMoveMap.name then
		return app.getMyTerminalDO_NOT_USE().moveMaps[_theCode];
	elseif _name = CM_CargoTypeAttribPlan::myCargoType.name then
		return app.myRoot.allCargoTypesById[_theCode.Integer];
	elseif _name = CM_CargoTypeAttribPlan::commodityGroup.name then
		return app.myRoot.allCommodityGroups[_theCode];
	elseif _name = CM_CargoTypeAttribPlan::isoTypeGroup.name then
		return app.myRoot.allISOTypeGroups[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
