    <JadeMethod name="keyDown" id="a9ab3902-1df0-49be-8d25-02ac3aa63232">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars

begin
	inheritMethod(keyCode, shift);
	
	if not self.aIsKeyStrokeReceived then
		btn_Dialog1.setFocus();
		self.aIsKeyStrokeReceived	:=	true; 
		
		if keyCode = 13 and shift = 0 then
			if btn_Dialog1.default then
				btn_Dialog1_click(btn_Dialog1);
			elseif btn_Dialog2.default then
				btn_Dialog2_click(btn_Dialog2);
			elseif btn_Dialog3.default then
				btn_Dialog3_click(btn_Dialog3);
			endif;
		endif;
	endif;

	if self.checkAccelerator(btn_Dialog1, keyCode) then
		btn_Dialog1.click(btn_Dialog1);
	elseif self.checkAccelerator(btn_Dialog2, keyCode) then
		btn_Dialog2.click(btn_Dialog2);
	elseif self.checkAccelerator(btn_Dialog3, keyCode) then
		btn_Dialog3.click(btn_Dialog3);
	endif;
end;
</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="repositionControls" id="5311bde2-ee71-43f5-a661-4889a7ed7b93">
        <source>repositionControls();

vars
	button1Obj		: Button;
	button2Obj		: Button;
	button3Obj		: Button;
	pictureObj		: Picture;
	allButtonsObj	: ObjectArray;
	visibleCount	: Integer;
	leftPos			: Real;
	topPos			: Real;
	
begin
	create allButtonsObj transient;
	
	if btn_Dialog1.visible then
		allButtonsObj.add(btn_Dialog1);
	endif;
	
	if btn_Dialog2.visible then
		allButtonsObj.add(btn_Dialog2);
	endif;
	
	if btn_Dialog3.visible then
		allButtonsObj.add(btn_Dialog3);
	endif;
	
	visibleCount	:=	allButtonsObj.size();
	
	if visibleCount = 1 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.clientWidth / 2) - (button1Obj.width / 2);
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
	elseif visibleCount = 2 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.width / 2) - button1Obj.width - 3;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.width / 2) + 3;
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
	elseif visibleCount = 3 then
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.width / 2) - (button2Obj.width / 2);
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	button2Obj.left - button1Obj.width - 6;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button3Obj	:=	allButtonsObj[3].Button;
		leftPos		:=	button2Obj.left + button2Obj.width + 6;
		button3Obj.move(leftPos, button3Obj.top, button3Obj.width, button3Obj.height);
	endif;
	
epilog
	delete allButtonsObj;
end;</source>
    </JadeMethod>
