    <JadeMethod name="getToDoTaskType" id="32749dda-041c-4b7a-8800-ae67382c24be">
        <source>getToDoTaskType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars
	wod : CM_WorkOrderDtl;
begin
	if self.myWODtl &lt;&gt; null then
		wod := self.myWODtl;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then
		wod := self.myWorkOrderDtlToDo;
	endif;
	
	if wod &lt;&gt; null then
		if wod.isKindOf(CM_WorkOrderToDoDtl) and wod.CM_WorkOrderToDoDtl.allToDoTasksDescs.isNotEmpty() then
			return app.getToDoTaskIntToString(wod.CM_WorkOrderToDoDtl.allToDoTasksDescs.first.type);
		elseif wod.isKindOf(CM_WodToDo) and wod.CM_WodToDo.allToDoTasksDescs.isNotEmpty() then
			return app.getToDoTaskIntToString(wod.CM_WodToDo.allToDoTasksDescs.first.type);
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWLEWithoutTi" id="0ce9cbdf-4056-4527-8c26-ede0320be9f7">
