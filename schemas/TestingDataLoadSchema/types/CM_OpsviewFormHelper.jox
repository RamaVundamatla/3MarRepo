    <JadeMethod name="setForCreate" id="8deada48-3fdc-4ef1-8a96-118795ac53c0">
        <updating/>
        <source>setForCreate(_cargoType :String;_delay:String;_isBol:String;_isBooking:String;_testName:String;_totalCargo:String;_terminal:String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2022	navsp1	Initial creation

*/

vars

begin
beginTransaction;
	self.cargoType := _cargoType;
	self.delay		:= _delay;
	self.isBol		:= _isBol;
	self.isBooking	:= _isBooking;
	self.testName	:= _testName;
	self.totalCargo	:= _totalCargo;
	self.terminal := _terminal;
commitTransaction;
epilog

end;</source>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_delay" type="String"/>
        <Parameter name="_isBol" type="String"/>
        <Parameter name="_isBooking" type="String"/>
        <Parameter name="_testName" type="String"/>
        <Parameter name="_totalCargo" type="String"/>
        <Parameter name="_terminal" type="String"/>
    </JadeMethod>
