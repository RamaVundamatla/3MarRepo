    <JadeMethod name="menuEditBGR" id="f2a43853-cec1-4734-8192-12a4ff10468f">
        <updating/>
        <source>menuEditBGR() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userRep			: CM_MenuUserReport;
	
begin	
	if self.tblBGPReports.allSelectedObjects.size &gt; 1 then
//		app.msgBox('You may only edit one background report at a time', 'Multi select disallowed', 0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( Only_Edit_BGP_Report_At_A_Time ),
					app.getString( Multi_Select_Disallowed ),
					MsgBox_OK_Only );
		return;
	endif;
	
	if self.tblBGPReports.accessRow(self.tblBGPReports.row).selected then
		userRep := self.tblBGPReports.accessRow(self.tblBGPReports.row).itemObject.CM_MenuUserReport;
	endif;
	
	if userRep = null then
//		app.msgBox('Please selected something to edit', 'Nothing selected',0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( Please_Select_Something_First, app.getString( Edit ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only );
		return;
	endif;
	
	self.myBGPReport := userRep;
	self.myReportAgent.setState(self.myReportAgent.STATE_BGR_EDIT);
	self.tblBGPEnt.setValueByName(ETRow_ReportName, userRep.name);
	self.tblBGPEnt.setValueByName(ETRow_ReportDescr, userRep.description);
	self.tblBGPEnt.setFocus();
	self.tblBGPEnt.goToRowByName(ETRow_ReportName);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuMoveBGRToFolder" id="09bb9d56-c117-43f6-a807-4267b610b65c">
        <updating/>
        <source>menuMoveBGRToFolder() protected, updating;
// ---------------------------------------------------------------------------
// Created:     28 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	userRep			: CM_MenuUserReport;
	menuRootSet		: CM_MenuEntitySet;
	obj				: Object;
	user			: CM_User;
	folderPicker	: CMUI_OrganizeMenu;
	toEntity		: CM_MenuEntity;
	theParent		: CM_MenuEntity;
	
begin
	theParent:=	self.lbReportTree.listObject.CM_MenuEntity;
	
	if self.tblBGPReports.allSelectedObjects.isEmpty then
//		app.msgBox('Please selected something to move', 'Nothing selected',0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( Please_Select_Something_First, app.getString( Move ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only );
		return;	
	endif;
	
	user := app.getMyUser();
	create menuRootSet transient;
	create folderPicker transient;

	menuRootSet.add(user.myMenuRootBGRSaved);
	
	//set up the picker form
	folderPicker.lstBox.allMenuRoots.clear();
	menuRootSet.copy(folderPicker.lstBox.allMenuRoots);
//	folderPicker.caption := 'Select Folder...';	// cnwrl1 11/11/2009 PAR 19951 - what it was
	folderPicker.caption := app.getString( Select_Folder );
	folderPicker.showModal;
	if folderPicker.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	toEntity := folderPicker.mySelectedMenuEntity;
	if toEntity = null then
		return;
	endif;
	
	foreach obj in self.tblBGPReports.allSelectedObjects do
		if not obj.isKindOf(CM_MenuUserReport) then
			continue;
		endif;
		userRep := obj.CM_MenuUserReport;
		if toEntity.isKindOf(CM_MenuRoot) then	
			beginTransaction;
			userRep.setMyMenuRoot(toEntity.CM_MenuRoot);
			userRep.setMyParent(toEntity);
			commitTransaction;
			
		elseif toEntity.isKindOf(CM_MenuUserHdr) then
			beginTransaction;
			userRep.setMyMenuRoot(null);
			userRep.setMyParent(toEntity);
			commitTransaction;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid toEntity');
			return;
		endif;
	endforeach;
	
	// Par 9843
	self.lbReportTree.displayTree(true, null);
	self.lbReportTree.listObject := theParent; //epr par 11904 14/6/2006 was toEntity;
	self.doTreeClick();
	
epilog
	delete folderPicker;	
	delete menuRootSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuResetAllReportMenu" id="79311687-46fb-4034-b3e8-83939ac2f22e">
        <updating/>
        <source>menuResetAllReportMenu() protected, updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;
begin
	create agent transient;
	agent.trxResetReportMenusForAllUsers(false);
	//need to refresh current user's report menu here
	self.loadReportTree();
	
epilog
	delete agent;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuResetFromJMTDefault" id="4dee0642-5536-4384-82d0-c41d118cd60e">
        <updating/>
        <source>menuResetFromJMTDefault() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user		: CM_User;
	ut			: CM_UserTerminal;
	fromEntity	: CM_MenuEntity;
	
begin
//	if not app.msgBox('Are you sure you wish to reset your report menu to the JMT default?','Are you sure?', MsgBox_OK_Cancel) = MsgBox_Return_OK then	// cnwrl1 11/11/2009 PAR 19951 - what it was
	if not app.msgBox(	app.getString( Reset_Report_Menu_To_Default ),
						app.getString( Are_You_Sure ),
						MsgBox_OK_Cancel + MsgBox_Default_Second ) = MsgBox_Return_OK then
		return;
	endif;
	
	fromEntity := self.lbReportTree.listObject.CM_MenuEntity;
	
	if not (fromEntity.isKindOf(CM_MenuUserItem) or fromEntity.isKindOf(CM_MenuRoot))  then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Move called for non-menuUserItem');
	endif;
	
	user := app.getMyUser;
	ut := user.getUserTerminal(fromEntity.getMyTerminal);
	
	if ut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User Terminal object could not be found');
		return;
	endif;
	
	beginTransaction;
	ut.resetReportMenuFromJMTDefault(true);
	commitTransaction;
	self.loadReportTree();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuResetFromSysDefault" id="d6298583-e49d-4b84-98cf-2438ca1b6051">
        <updating/>
        <source>menuResetFromSysDefault() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2003	cnwth2	Initial creation  
27 Jan 2020 cnwma1 Bug 48379: STWO - Error 75768 is showing when click on reset from system default option
*/

vars
	user		: CM_User;
	ut			: CM_UserTerminal;
	fromEntity	: CM_MenuEntity;
	term        : CM_Terminal;
begin

	if not app.msgBox(	app.getString( Reset_ReportMenu_SystemDefault ),
						app.getString( Are_You_Sure ),
						MsgBox_OK_Cancel + MsgBox_Default_Second ) = MsgBox_Return_OK then
		return;
	endif;
	
	fromEntity := self.lbReportTree.listObject.CM_MenuEntity;
	
	if not (fromEntity.isKindOf(CM_MenuUserItem) or fromEntity.isKindOf(CM_MenuRoot))  then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Move called for non-menuUserItem');
	endif;
	
	user := app.getMyUser;
	term := fromEntity.getMyTerminal; //27.01.2020 cnwma1 #48379  
	
	if term = null then               //27.01.2020 cnwma1 #48379
		term := self.myTerminal;
	endif;
	
	ut := user.getUserTerminal(term);
	
	if ut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User Terminal object could not be found');
		return;
	endif;
	
	beginTransaction;
	ut.resetReportMenuFromSysDefault(true);
	commitTransaction;
	self.loadReportTree();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuSaveAsJMTDefault" id="8ac4b2a7-351e-4c84-b09d-bb410eab1f5f">
        <updating/>
        <source>menuSaveAsJMTDefault() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuAgent			: CM_MenuAgent;
	obj					: Object;	
	userRoot			: CM_MenuRoot;
	
begin
	if (not app.isSpecial()) then
		return;
	endif;
	
	if not app.msgBox("You're about to re-define global constant text that defines the" &amp; CrLf &amp;
 					'parent child relationship of JMT report menu entities ' &amp; CrLf &amp;
 					'This operation will create ReportMenuHdr global constants for any ' &amp; CrLf &amp;
 					'menu headers that do not already exist - these can only be removed in the IDE.','READ ME FIRST', MsgBox_OK_Cancel + MsgBox_Default_Second ) = MsgBox_Return_OK then
		return;
	endif;
	
	create menuAgent transient;
	
	userRoot := self.lbReportTree.getRootOfCurrentEntity;
	
	if userRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User menu root could not be found');
		return;
	endif;
	
	menuAgent.trxSaveReportMenuAsJMTDefault(menuAgent.myJMTMenuReportRoot, userRoot);

epilog
	app.mousePointer := MousePointer_Default;
	delete menuAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuSaveAsSysDefault" id="caffb440-3b70-4f33-ac13-db8cc34e229f">
        <source>menuSaveAsSysDefault() protected;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	menuAgent			: CM_MenuAgent;
	obj					: Object;	
	userRoot			: CM_MenuRoot;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create menuAgent transient;
	userRoot := self.lbReportTree.getRootOfCurrentEntity;
	//permission should have been checked before this - but small overhead - belts/braces etc.
	beginTransaction;
	menuAgent.trxSaveToSourceMenuRoot(userRoot, menuAgent.mySystemMenuReportRoot, null, true);
	commitTransaction;
epilog
	app.mousePointer := MousePointer_Default;
	delete menuAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
