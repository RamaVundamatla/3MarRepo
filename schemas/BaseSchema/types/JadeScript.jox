    <JadeMethod name="cnwdad1_Test_Get_Request" id="3ed3319c-e23d-4a91-baa0-51071c481da7">
        <source>cnwdad1_Test_Get_Request();
// --------------------------------------------------------------------------------
// Created:		18 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tcpConnect  : CnEcTcpConnection;
	response    : String;
	startTime	: Integer;

begin
	startTime	:=	app.clock();
	create tcpConnect transient;

	if tcpConnect.cnEcDoWebGetRequest(	"143.96.129.230", //"www.ozemail.com.au",
										null, //"/Darrell/index.htm",
										null,
										2,
										response) then
		write "Success!" &amp; CrLf &amp; response;
	else
		write "Error: " &amp; tcpConnect.cnEcErrorMessage;
	endif;
epilog
	delete tcpConnect;
	
	write "Get Request completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_HtmlPage" id="b045bf6f-83f4-48c5-a7f6-89ba0de6b757">
        <source>cnwdad1_Test_HtmlPage();
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	OUTPUT_FILE		: String = "c:\temp\htmltest.html";
	
vars
	htmlFileObj		: File;
	htmlPageObj		: CnEcHtmlPage;
	pageHeadObj		: CnEcPageHead;
	pageBodyObj		: CnEcPageBody;
	fontTagObj		: CnEcHtmlFontTag;
	lineRuleObj		: CnEcHtmlHorizontalRuleTag;
	paragraphObj	: CnEcHtmlParagraphTag;
	tableTagObj		: CnEcHtmlTableTag;
	tableRowObj		: CnEcHtmlTableRowTag;
	tableCellObj	: CnEcHtmlTableDataTag;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	write "Building the HTML objects...";
	
	create htmlPageObj transient;
	pageHeadObj				:=	htmlPageObj.myHead;
	pageHeadObj.headTitle	:=	"Geological Eras";
	pageBodyObj				:=	htmlPageObj.myBody;
	
	paragraphObj			:=	pageBodyObj.createParagraph();
	paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
	fontTagObj				:=	paragraphObj.createFont();
	fontTagObj.setFontSize(1, true);
	fontTagObj.fontColor	:=	CNEC_HEX_BLUE;
	fontTagObj.fontValue	:=	"Geological Eras";
	
	lineRuleObj				:=	pageBodyObj.createHorizontalRule();
	lineRuleObj.ruleWidth	:=	"100%";
	
	paragraphObj			:=	pageBodyObj.createParagraph();
	paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
	paragraphObj.paragraphValue	:=	"The following table gives a broad outline of the major ages of the Earth.";
	
	paragraphObj			:=	pageBodyObj.createParagraph();
	paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
	tableTagObj				:=	paragraphObj.createTable();
	tableTagObj.tableBorderWidth	:=	1;
	tableTagObj.tableColumns		:=	2;
	tableTagObj.tableCellPadding	:=	2;
	tableTagObj.tableCellSpacing	:=	2;
	
	tableRowObj				:=	tableTagObj.createRow();
	tableRowObj.setTableAlign(CnEcHtmlTagObject.ALIGN_CENTER);
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"&lt;B&gt;Epoch&lt;/B&gt;";
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"&lt;B&gt;Years ago (mn)&lt;/B&gt;";
	
	tableRowObj				:=	tableTagObj.createRow();
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"Pre-Cambrian";
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.setTableAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
	tableCellObj.cellValue	:=	"4 000";
	
	tableRowObj				:=	tableTagObj.createRow();
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"Palaeozoic";
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.setTableAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
	tableCellObj.cellValue	:=	"570";
	
	tableRowObj				:=	tableTagObj.createRow();
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"Mesozoic";
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.setTableAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
	tableCellObj.cellValue	:=	"250";
	
	tableRowObj				:=	tableTagObj.createRow();
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.cellValue	:=	"Cenozoic";
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.setTableAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
	tableCellObj.cellValue	:=	"65";
	
	write "Generating the HTML page and writing it to disk...";
	
	create htmlFileObj transient;	
	htmlFileObj.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	htmlFileObj.fileName	:=	OUTPUT_FILE;
	htmlFileObj.writeString(htmlPageObj.getHtml());
	htmlFileObj.close();
	write "HTML page written to: " &amp; OUTPUT_FILE;
	
	write "Deleting File and HTML objects...";
epilog
	delete htmlPageObj;
	delete htmlFileObj;
	
	write "HTML page completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_HttpGetBinary" id="d60130f8-ed8e-47be-af4b-d05aa6019e51">
        <source>cnwdad1_Test_HttpGetBinary();
// --------------------------------------------------------------------------------
// Created:		17 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime		: Integer;
	requestResponse	: String;
	binaryData		: Binary;
	theDataFile		: File;
	
begin
	startTime		:=	app.clock();
	create app.myCnKarmaCntrl transient;
	requestResponse	:=	global.cnEcGetHttpBinary("http://www.partizan.com/partizan/media/clips/734.mov", false, true, binaryData);

	if requestResponse = null then
		create theDataFile transient;
		theDataFile.fileName	:=	"c:\temp\webfile.dat";
		theDataFile.kind		:=	File.Kind_Binary;
		theDataFile.writeBinary(binaryData);
		write "Success!";
	else
		write requestResponse;
	endif;
epilog
	delete theDataFile;
	delete app.myCnKarmaCntrl;
	write "Done in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_HttpGetFile" id="2442663b-210a-4742-8220-03d75bc331ba">
        <source>cnwdad1_Test_HttpGetFile();
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime		: Integer;
	requestResponse	: String;
	
begin
	startTime		:=	app.clock();
	create app.myCnKarmaCntrl transient;
	//requestResponse	:=	global.cnEcGetHttpFile("cnwdad1a", "images/austmap.gif", "c:\temp\_aaapic.gif", false, false);
	requestResponse	:=	global.cnEcGetHttpFile("www.partizan.com", "partizan/media/clips/734.mov", "c:\temp\qtime.mov", false, true);

	if requestResponse = null then
		write "Success!";
	else
		write requestResponse;
	endif;
epilog
	delete app.myCnKarmaCntrl;
	write "Done in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_INI_Setting" id="62851695-b5f3-40a1-b9d4-7736a361feac">
        <source>cnwdad1_Test_INI_Setting();
// --------------------------------------------------------------------------------
// Created:		18 April 2003 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	INI_SECTION		: String = "JadeLog";
	LOG_DIRECTORY	: String = "LogDirectory";
	LOG_FILENAME	: String = "LogFile";
	
begin
	write "Local Client:";
	write app.getIniFileName();
	write app.getProfileString(app.getIniFileName(), INI_SECTION, LOG_DIRECTORY, app.getTempDir());
	write app.getProfileString(app.getIniFileName(), INI_SECTION, LOG_FILENAME, process.userCode &amp; ".log");
	
	write CrLf &amp; "Server Node:";
	write app.getIniFileNameAppServer();
	write app.getProfileStringAppServer(app.getIniFileNameAppServer(), INI_SECTION, LOG_DIRECTORY, app.getTempDirAppServer());
	write app.getProfileStringAppServer(app.getIniFileNameAppServer(), INI_SECTION, LOG_FILENAME, process.userCode &amp; ".log");
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_IsValidHttpFile" id="4f0244d9-fa56-45d2-abdd-0ccb02983a2a">
        <source>cnwdad1_Test_IsValidHttpFile();
// --------------------------------------------------------------------------------
// Created:		28 September 2000 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	filePathName	: String;
	errorMessage	: String;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	filePathName	:=	"http://cnwdad1a/Darrell/images/h_shbridge.gif";		// Good file name.
//	filePathName	:=	"http://cnwdad1a/Darrell/images/zh_shbridge.gif";		// Bad file name.
	
	if global.cnEcIsValidHttpFile(filePathName, false, errorMessage) then
		write "The file is valid.";
	else
		write errorMessage;
	endif;
epilog
	write "HTTP file validation completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_MDArray" id="f4ed97f4-b60e-4df3-b557-4ac30e1a49b7">
        <source>cnwdad1_Test_MDArray() protected;
// --------------------------------------------------------------------------------
// Created:		27 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayObj	: CnEcMDArray;
	dimension	: Integer;
	index		: Integer;
	size		: Integer;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create arrayObj transient;
	arrayObj.initializeMe(StringArray, 5);
	
	foreach dimension in 1 to arrayObj.dimensions do
		arrayObj.add(dimension.cnEcAsWords(null), dimension);
	endforeach;
	
	foreach dimension in 1 to arrayObj.dimensions do
		arrayObj.add("Dimension " &amp; dimension.String, dimension);
	endforeach;
	
	size	:=	arrayObj.getArray(1).size();
	//arrayObj.inspectModal();
	
	write "Elements fetched in tab-delimited strings:";
	
	foreach dimension in 1 to arrayObj.dimensions do
		write CrLf &amp; "Results dimension " &amp; dimension.String &amp; ": ";
		write arrayObj.getDimensionAsString(dimension, index, Tab);
	endforeach;
	
	write CrLf &amp; "Elements fetched individually:";
	
	foreach dimension in 1 to arrayObj.dimensions do
		write CrLf &amp; "Results dimension " &amp; dimension.String &amp; ": " &amp; CrLf;
		
		foreach index in 1 to size do
			write "Element " &amp; index.String &amp; ":" &amp; arrayObj.at(index, dimension).String;
		endforeach;
	endforeach;
epilog
	delete arrayObj;
	write CrLf &amp; "Multi-dimensional array completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
