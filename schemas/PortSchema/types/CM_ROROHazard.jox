    <JadeMethod name="cloneMySelf" id="32a73c46-eadf-4ec2-8d32-5d5840888621">
        <source>cloneMySelf(_newLocn : CM_ROROLocnDefn; _copy : Boolean) : CM_ROROHazard;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars

	newMe : SelfType;
begin
	newMe := self.cloneSelf(_copy);
	newMe.myROROLocnDefn := _newLocn;
	
	return newMe;


epilog

end;</source>
        <Parameter name="_newLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_copy" type="Boolean"/>
