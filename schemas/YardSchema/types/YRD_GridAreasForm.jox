    <JadeMethod name="canShiftLeft" id="69dd07b8-b78c-46c2-8266-3f03e971401c">
        <source>canShiftLeft(_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin

	if _theTI = null then
		return false;
	endif;
	
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		return _theTI.canShiftLeft(REAL_MODE);
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		return _theTI.canShiftLeft(QUEUE_MODE);
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		return _theTI.canShiftLeft(PLANNING_MODE);
	endif;
		
	return false;
	
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canShiftRight" id="256f6735-6e7b-4fb3-a2b3-b70f405b15e1">
