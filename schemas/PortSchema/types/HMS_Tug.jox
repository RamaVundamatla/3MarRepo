    <JadeMethod name="getDisplayStringForAttribute" id="e21f214c-a51a-4efe-98e6-2f19ff9ae974">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

vars
	resourceTug	:	HMS_ResourceForTug;
begin
	if _attrName = ETRow_MyHarbour then
		if self.myCurrentHarbour &lt;&gt; null then
			return self.myCurrentHarbour.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyArrivalResource then
	resourceTug := self.allResourcesForTug[self.myCurrentHarbour, self];
		if resourceTug &lt;&gt; null and resourceTug.myArrivalResource &lt;&gt; null then 
			return (resourceTug.myArrivalResource.description);
		else 
			return null;
		endif;
		
	elseif _attrName = ETRow_MyDepartResource then
	resourceTug := self.allResourcesForTug[self.myCurrentHarbour, self];
		if resourceTug &lt;&gt; null and resourceTug.myDepartResource &lt;&gt; null then 
			return (resourceTug.myDepartResource.description);
		else 
			return null;
		endif;
	elseif _attrName = ETRow_MyShiftResource then
	resourceTug := self.allResourcesForTug[self.myCurrentHarbour, self];
		if resourceTug &lt;&gt; null and resourceTug.myShiftResource &lt;&gt; null then 
			return (resourceTug.myShiftResource.description);
		else 
			return null;
		endif;
		
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceForHarbourMovement" id="864b7217-1ce5-4717-ab51-ae7c4aa2e58d">
        <source>getResourceForHarbourMovement(_harbour : HMS_Harbour; _movement : String) : HMS_Resource;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realResource : HMS_Resource;
	resourceTug : HMS_ResourceForTug;
begin		
	if _harbour = null then
		return null;
	endif;
	
	resourceTug := self.allResourcesForTug[_harbour, self];
	if resourceTug &lt;&gt; null then
		if _movement = HMSMovementTypeArrival then
			return resourceTug.myArrivalResource;
		elseif _movement = HMSMovementTypeDeparture then
			return resourceTug.myDepartResource;
		else
			return resourceTug.myShiftResource;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="String"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9f1719d2-3092-4019-a2be-60970cc824dd">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 14 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 	:	HMS_Tug;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	proxy.myCurrentHarbour := self.myCurrentHarbour;		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="144f8aaf-677f-47bd-9766-9a5507d16964">
        <updating/>
        <source>setForDelete(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourceForTug	: HMS_ResourceForTug;
begin
	inheritMethod(_passport);
	foreach resourceForTug in self.allResourcesForTug do
		resourceForTug.setForDelete(_passport);
		resourceForTug.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cf70b158-d8ea-4d7a-92c8-cb692e6cd04d">
        <updating/>
        <source>setForUpdate(_pxyTug  : HMS_Tug ; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	tmpResourcesForTug,
	resourcesForTug	:	HMS_ResourceForTug;
begin
	inheritMethod(_pxyTug, _passport);
	
	self.code 					:= _pxyTug.code.toUpper.trimBlanks;
	self.description			:= _pxyTug.description;
	self.isNotAvailableForEntry	:= _pxyTug.isNotAvailableForEntry; 	//  cnwma1 3/7/2014   CCMS SFW 1328
	self.myCurrentHarbour		:= _pxyTug.myCurrentHarbour;
	self.myRoot			:= _pxyTug.myRoot;
	
	foreach tmpResourcesForTug in self.allResourcesForTug do
		tmpResourcesForTug.setForDelete(_passport);
	endforeach;

	self.allResourcesForTug.purge();
	
	foreach tmpResourcesForTug in _pxyTug.allResourcesForTug do
		create resourcesForTug persistent;
		resourcesForTug.setTug(self);
		resourcesForTug.setForUpdate(tmpResourcesForTug, _passport);
	endforeach;
end;</source>
        <Parameter name="_pxyTug" type="HMS_Tug"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1836358d-ce12-4cc6-b49f-a1a0622bfc17">
        <updating/>
        <source>setProxy(_root : CM_Root)updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 11 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="7b470057-d330-4f5c-9e6b-d3807bef90da">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 14 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if (not self.allVoyageMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Voyage Movement", null, null);	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b75f240a-fc81-47e3-ae97-d1d10123b8f3">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 14 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpTug	:	HMS_Tug;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_Desc, ETRow_Description, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Root', null, null );
		app.raiseCMException(Input_required_field_root, null, null ); // cnwdb2	PAR 35364
	endif;

	if self.myCurrentHarbour = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Harbour ', null, null );
		app.raiseCMException( Input_required_field_harbour, null, null ); // cnwdb2	PAR 35364
	endif;	
	
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpTug := self.myRoot.allTugs.getAtKey(self.code);
	if tmpTug &lt;&gt; null then
		if self.isTransient and tmpTug &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Tug', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Tug already exists for %1 : Tug_Already_exists
			app.raiseCMException1(Tug_Already_exists, self.code, ETRow_Code, null);  //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
