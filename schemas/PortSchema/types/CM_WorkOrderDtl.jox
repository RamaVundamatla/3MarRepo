    <JadeMethod name="doUpdateCompletedTansaction" id="8397a1b9-beb2-41db-a908-31749c264732">
        <updating/>
        <source>doUpdateCompletedTansaction() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	woTransaction : CM_WOTransaction;
begin
	
	foreach woTransaction in self.allWODtlTransactions discreteLock do
