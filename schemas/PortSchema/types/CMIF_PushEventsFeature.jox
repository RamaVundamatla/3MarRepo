    <JadeMethod name="buildFromDataDumpFeature" id="0768998a-c40b-4449-afd4-4af725c83a2c">
        <updating/>
        <source>buildFromDataDumpFeature(_ddFeature : CM_DataDumpFeature;
						 _subClassName : String) updating;
/*

Purpose:			Populate the receiver from the passed in Data Dump feature definition, in the context of the
					passed in (sub)class name

Parameters:			CM_DataDumpFeature to copy, and relevant subclass to build from

Return Value:		None

Date		Who		Reason
20 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; ' ' &amp; self.String &amp; ' created for feature ' &amp; _ddFeature.featureName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	self.featureName := _ddFeature.featureName;
	self.isFeatureMethod := _ddFeature.isFeatureMethod();
	self.myFeatureType := _ddFeature.getFeatureTypeForJSON();
	
	if self.myFeatureType &lt;&gt; null then
		self.isFeatureTypePrimitive := self.myFeatureType.isKindOf(PrimType);
	endif;
	
epilog

end;</source>
        <Parameter name="_ddFeature" type="CM_DataDumpFeature"/>
        <Parameter name="_subClassName" type="String"/>
    </JadeMethod>
</Class>
