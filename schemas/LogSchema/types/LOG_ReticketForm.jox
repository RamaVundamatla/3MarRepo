	self.tblActionData.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblActionData.showHideRowsByViewName("viewTransfer", CM_EntryTable.ShowHideRows, false); 
	self.tblActionData.adjustHeight(1000);
end;</source>
