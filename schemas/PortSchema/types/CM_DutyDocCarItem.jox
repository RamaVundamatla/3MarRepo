    <JadeMethod name="doPrint" id="c3843528-74af-488f-b53d-99f3a8a5962c">
        <source>doPrint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	term : CM_Terminal;
	reportString : String;

begin

	term := self.myDutyDocTerminalRoot.myTerminal;
	
	if term &lt;&gt; null then
		reportString := term.getConfig(DutyDocCarReport).String;
	endif;
	
	if reportString = null then
		reportString := DefRep_DutyDocumentCarReport;
	endif;
	
	if reportString.pos("?DOT", 1) &gt; 0 then
		app.printReportDotMatrix(reportString, self, false);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c9d93de0-3605-4187-a396-10ca3600695c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	
	if _attrName = ETRow_VehicleMake then
		return self.vehicleMake;
	elseif _attrName = ETRow_Colour then
		return self.color;
	elseif _attrName = ETRow_VccNo then
		return self.vccNo;
	elseif _attrName = ETRow_VccDate then
		return self.vccDate.asStringJMT;
	elseif _attrName = ETRow_VehicleModel then
		return self.vehicleModel;
	elseif _attrName = ETRow_ChassisNo then
		return self.chassisNo;
	elseif _attrName = ETRow_EngineNo then
		return self.engineNo;
	elseif _attrName = ETRow_NumberPlate then
		return self.numberPlate;
	elseif _attrName = ETRow_VehicleType then
		return self.vehicleType;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVCCNo" id="578b4bdb-b6e2-4c85-ad30-9d84f6cfa5a3">
        <source>getNextVCCNo() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwmc5	Initial creation	HAT 2189
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	lastDutyDocCar	: CM_DutyDocCarItem;
	yearPart 		: String;
	numberPart 		: Integer;
begin
	lastDutyDocCar := CM_DutyDocCarItem.lastInstance();
	
	yearPart := app.actualTimeServer.date.year.String;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if lastDutyDocCar = null or lastDutyDocCar.vccNo[1:4] &lt;&gt; yearPart then
		return yearPart &amp; "000001";
	endif;
	
	numberPart:=lastDutyDocCar.vccNo[5:end].Integer;
	numberPart:=numberPart + 1;
	//reset back to 1
	if numberPart.String.length &gt; 6 then
		numberPart:=1;
	endif;
	return yearPart &amp; numberPart.padLeadingWith("0",6);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
