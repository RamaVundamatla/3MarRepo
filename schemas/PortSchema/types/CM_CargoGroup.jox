    <JadeMethod name="onSiteAssignedCount" id="5ea94cbe-d35e-42ca-b737-35518995e55a">
        <source>onSiteAssignedCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2015	cnwndl1	Initial creation	Par 36338
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	totalOnsiteQuantity : Integer;
	cargoGroupDtl : CM_CargoGroupDetail;
	ti : CM_TrackedItem;
begin
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.site = TI_SITE_ONSITE then
				totalOnsiteQuantity += ti.totalQuantity;
			endif;
		endforeach;
	else
		foreach cargoGroupDtl in self.allCargoGroupDetails do
			if cargoGroupDtl.site = TI_SITE_ONSITE then
				totalOnsiteQuantity := totalOnsiteQuantity + cargoGroupDtl.totalQuantity;
			endif;
		endforeach;
	endif;
	
	return totalOnsiteQuantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
