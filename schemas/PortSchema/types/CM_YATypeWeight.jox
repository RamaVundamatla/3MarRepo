    <JadeMethod name="isCMIFDataMatch" id="76485943-b5c4-4e17-8745-61129831a238">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 01 June 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return _cmifAutoPlan.isWeight_Match(_yaData);


end;</source>
