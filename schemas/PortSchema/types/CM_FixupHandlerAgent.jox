    <CompAttribute name="parameterArray" id="3a49fb76-c3eb-4ebc-8044-13a603be3e28">
        <type name="HugeStringArray"/>
        <text>36385 changed from StringArray to HugeStringArray to handle file name as one of the parameters</text>
    </CompAttribute>
    <JadeMethod name="doBolTrxTermPopulate" id="3a60da5f-b96a-4572-83f5-7459f71056af">
        <source>doBolTrxTermPopulate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	param : String;
	param2 : String;
	param3 : String;
	startDate : Date;
	endDate : Date;
	update : Boolean;
	count : Boolean;
	info : String;
	days : Integer;
	latestDate : Date;
	earliestDate : Date;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;			
		elseif self.parameterArray.size = 3 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			param3 := self.parameterArray[3].trimBlanks.toUpper;
		endif;
		if param = "UPDATE" then
			update := true;
		elseif param = "COUNT" then
			count := true;
		endif;
		if param2 &lt;&gt; null then
			startDate := param2.asDate;
		endif;
		if param3 &lt;&gt; null then
			endDate := param3.asDate;
		endif;
 	endif;
	
	if (not update and not count) or not startDate.isValid or not endDate.isValid then
		info := "Parameter(s) entered are not valid!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS 47100 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The ability to search BOL Transactions was added in TFS 47100." &amp; CrLf;
		info := info &amp; "This activity requires the BOL Transactions to be in a special collection on the associated terminal." &amp; CrLf;
		info := info &amp; "BOL Transactions created before TFS 47100 was implemented are NOT in a Terminal collection." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a mechanism to allow older BOL Transactions to potentially be added to the appropriate" &amp; CrLf;
		info := info &amp; "terminal collection, and therefore be included in any Selector Queries." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "NOTE: This method should NOT be run during a busy period as it will have an impact on the system peformance." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "NOTE: JMT recommends that if you decide to perform this action, that you start with a very small date range so that" &amp; CrLf;
		info := info &amp; "you can gauge the effects on your system. (Perhaps just one week initially)" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;	
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "COUNT  &lt;ddmmmyyyy&gt; &lt;ddmmmyyyy&gt; - Will read the data and try to establish how many BOL Transactions" &amp; CrLf;
		info := info &amp; "                             	 within the data range entered exist, and how many of these may be able to be" &amp; CrLf;
		info := info &amp; "                             	 updated onto a Terminal collection from their associated BOL." &amp; CrLf;
		info := info &amp; "UPDATE &lt;ddmmmyyyy&gt; &lt;ddmmmyyyy&gt; - Will add the Bol Transaction to the appropriate 'Terminal' collection for any BOL Transactions" &amp; CrLf;
		info := info &amp; "                             	 within the selected date range based on the Terminal associated with the BOL of the Transaction." &amp; CrLf;
		info := info &amp; "                             	 If the BOL is no longer valid or the BOL has no assoication with a Terminal the" &amp; CrLf;
		info := info &amp; "                              	 BOL Transaction will NOT be updated." &amp; CrLf;
		info := info &amp; "                             	 an error will be logged." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "E.g." &amp; CrLf;
		info := info &amp; "UPDATE 01Jan2019 15Jan2019" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	if startDate &gt; endDate then
		days := startDate - endDate;
		latestDate := startDate;
		earliestDate := endDate;
	elseif endDate &gt; startDate then
		days := endDate - startDate;
		latestDate := endDate;
		earliestDate := startDate;
	else
		days := 1;
		latestDate := endDate;
		earliestDate := startDate;
	endif;
	
	if update and days &gt; 365 then
		info := info &amp; "You may not attempt to update more than 1 year at a time." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doBolTrxTermPopulateWork( count, latestDate, earliestDate );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBolTrxTermPopulateWork" id="3e11ceac-8723-45c1-86ab-443f01c9bf53">
        <source>doBolTrxTermPopulateWork( _countOnly : Boolean; _latestDate : Date; _earliestDate : Date )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	
	str: String;

	latestTS  : TimeStamp;
	earliestTS  : TimeStamp;
	
	class : Class;
	cc	: ClassColl;
	bolTrxClass : Class;
	
	iter : Iterator;
	bolTrx : CM_BOLTransaction;
	
	allPropsepcts : CM_BOLTransactionByDate;
	term : CM_Terminal;
	count : Integer;

begin

	str := "Gathering data..." &amp; CrLf;
	writeOutputToMyForm(str);

	create allPropsepcts transient;

	latestTS.setDate( _latestDate );
	latestTS.setTime( "23:59:59".Time );
	
	earliestTS.setDate( _earliestDate );
	earliestTS.setTime( "00:00:00".Time );

	class := CM_BOLTransaction;
	
	create cc transient;
	class.allSubclasses(cc);
	
	foreach bolTrxClass in cc do
		delete iter;
		iter := bolTrxClass.instances.createIterator();
		
		while iter.back( bolTrx ) do
			if bolTrx.createdTime &lt; earliestTS then
				//too old, bail
				break;
			endif;
			if bolTrx.createdTime &gt; latestTS then
				//still too recent, keep going
				continue;
			endif;
			if bolTrx.myTerminal &lt;&gt; null then
				//already populated
				continue;
			endif;
			
			allPropsepcts.add( bolTrx );
			
		endwhile;
		
	endforeach;
	
	delete iter;
	
	str := allPropsepcts.size.String &amp; " prospects found..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	
	iter := allPropsepcts.createIterator;
	while iter.next( bolTrx ) do
		term := bolTrx.getMyTerminal();
		if term &lt;&gt; null then
			count := count + 1;
			if not _countOnly then
				beginTransaction;
				bolTrx.setPropertyValue( CM_BOLTransaction::myTerminal.name, term );
				commitTransaction;
			endif;
		endif;
	endwhile;
	
	if _countOnly then
		str := count.String &amp; " of the prospects found would currently be able to be added to a valid terminal collection." &amp; CrLf;
	else
		str := count.String &amp; " of the prospects found were added to a valid terminal collection." &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);

epilog

	delete cc;
	delete iter;
	delete allPropsepcts;

end;</source>
        <access>protected</access>
        <Parameter name="_countOnly" type="Boolean"/>
        <Parameter name="_latestDate" type="Date"/>
        <Parameter name="_earliestDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doCargoMoveOffsite" id="b633cbf2-66ec-459b-988f-a8547b21f77b">
        <source>doCargoMoveOffsite();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2011	cnwndl1	Initial creation	Par 28686

*/

vars

	param : String;
	param2 : String;
	param3 : String;
	user : CM_User;
	iter : Iterator;
	userTerminal : CM_UserTerminal;
	term : CM_Terminal;
	update : Boolean;
	info : String;
	ti : CM_TrackedItem;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;			
		elseif self.parameterArray.size = 3 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;
			param3 := self.parameterArray[3].trimBlanks.toUpper;
		endif;
		if param = "UPDATE" then
			update := true;
		endif;
		if param2 &lt;&gt; null then
			user := app.getMyUser;
			if user = null then
				info := info &amp; "" &amp; CrLf;
				info := info &amp; "Unable to establish User!!." &amp; CrLf;
				info := info &amp; "" &amp; CrLf;
				self.writeOutputToMyForm(info);
				return;
			endif;
			iter := user.allUserTerminals.createIterator;
			while iter.next( userTerminal )do
				if userTerminal.myTerminal.code.toUpper = param2 then
					term := userTerminal.myTerminal;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
 	endif;
	
	if not update or term = null or param3.length = 0 then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 28686 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Some cargo is believed to have been prematurely moved from an onsite location" &amp; CrLf;
		info := info &amp; "to a 'planned train' instead of onsite to an 'arrived train'." &amp; CrLf;
		info := info &amp; "Subsequently when the planned train was 'arrived', 'receival jobs' were created for the cargo that had to" &amp; CrLf;
		info := info &amp; "be manually deleted, before the wagon could be cleared from the rake." &amp; CrLf;
		info := info &amp; "A consequence of this was that the cargo did not move 'offsite' correctly when the train was departed." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a method to move this cargo off-site" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The only processing option available for this method is update." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is the users responsibility to ensure that the correct terminal and cargo id is entered" &amp; CrLf;
		info := info &amp; "as the action is not reversible." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE &lt;term id&gt; &lt;cargo id&gt; - Will search for the cargo item in the onsite cargo of the nominated terminal." &amp; CrLf;
		info := info &amp; "                              If the cargo can be uniquely identified from the id entered," &amp; CrLf;
		info := info &amp; "                              the cargo will immediately moved offsite." &amp; CrLf;
		info := info &amp; "                              If the cargo can NOT be uniquely identified from the id entered," &amp; CrLf;
		info := info &amp; "                              an error will be logged." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "E.g." &amp; CrLf;
		info := info &amp; "UPDATE T01 ABCD7654321" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		if user &lt;&gt; null and param2 &lt;&gt; null and term = null then
			info := info &amp; "'" &amp; param2 &amp; "' is not a valid terminal id!" &amp; CrLf;
			info := info &amp; "" &amp; CrLf;
			info := info &amp; "Valid Terminal ids are:" &amp; CrLf;
			iter := user.allUserTerminals.createIterator;
			while iter.next( userTerminal )do
				info := info &amp; "   " &amp; userTerminal.myTerminal.code.toUpper &amp; CrLf;
			endwhile;
			delete iter;
		endif;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	ti := self.doCargoMoveOffsiteCargoSelect( term, param3 );
	if ti = null then
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doCargoMoveOffsiteCargoWork( user, term, ti );
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoMoveOffsiteCargoSelect" id="efcea6e1-d62d-48f8-b0e6-32f2478c8046">
        <source>doCargoMoveOffsiteCargoSelect( _term : CM_Terminal; _cargoId : String ): CM_TrackedItem protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Nov 2011	cnwndl1	Initial creation	Par 28686
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars

	iter : Iterator;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;
	allMatchingItems : CM_TIArray;
	str : String;
	locStr : String;

begin

	iter := _term.allOnsiteTIsByIdCargoType.createIterator;
	startObject := _term.allOnsiteTIsByIdCargoType.getAtKeyGeq( _cargoId, null );
	if startObject = null or startObject.id &lt;&gt; _cargoId then
		str := "Cargo item '" &amp; _cargoId &amp; "' not found in terminal '" &amp; _term.code &amp; "'." &amp; CrLf;
		str := str &amp; "No action possible." &amp; CrLf;
		writeOutputToMyForm(str);
		return null;
	endif;
	
	create allMatchingItems transient;
	iter.startAtObject( startObject );
	while iter.next( ti ) do
		if ti.id &lt;&gt; _cargoId then
			break;
		endif;
		allMatchingItems.add( ti );
	endwhile;
	
	if allMatchingItems.size = 1 then
		return allMatchingItems.first;
		
	else
		// ok we have multiples on site...
		foreach ti in allMatchingItems do
			locStr := null;
			if ti.myPrimaryActualLocation &lt;&gt; null then
				locStr := ti.myPrimaryActualLocation.getFullId;
			endif;
			str := "'" &amp; allMatchingItems.size.String &amp; "' cargo items with the id '" &amp; _cargoId &amp; "' were found in terminal '" &amp; _term.code &amp; "'." &amp; CrLf;
			str := str &amp; "Do you want to move the one with cargo type of '" &amp; ti.cargoTypeDescr &amp; "' currently located at '" &amp; locStr &amp; "'?";
			if app.msgBox(str, "Move this one offsite?", MsgBox_Yes_No ) = MsgBox_Return_Yes then
				return ti;
			endif;
		endforeach;
		
		str := "Multiple Cargo items with the id of '" &amp; _cargoId &amp; "' in terminal '" &amp; _term.code &amp; "' were identified." &amp; CrLf;
		str := str &amp; "None of these cargo items was selected by the user." &amp; CrLf;
		writeOutputToMyForm(str);
		return null;
		
	endif;

epilog
	delete iter;
	delete allMatchingItems;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doCargoMoveOffsiteCargoWork" id="6da9b85a-9091-4832-9443-b83a399b1ba9">
        <source>doCargoMoveOffsiteCargoWork( _user : CM_User; _term : CM_Terminal; _ti : CM_TrackedItem ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2011	cnwndl1	Initial creation	Par 28686

*/

vars

	moveController : CMIF_MoveController;
	origLocn : CM_LocationsController;
	str : String;

begin

	app.myPassport.setMyUser( _user );
	app.myPassport.setMyTerminal( _term );

	create moveController transient;	
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(null);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;
	moveController.isSystemMove := true;
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	str := app.myPassport.getAllErrorsWarningsAsString;
	if str = null then
		str := "Cargo item '" &amp; _ti.id &amp; "' from terminal '" &amp; _term.code &amp; "' moved off site.  [" &amp; _ti.String &amp; "]";
	else
		str := "Error trying to move '" &amp; _ti.id &amp; "' off site from terminal '" &amp; _term.code &amp; "': " &amp; CrLf &amp; str;
	endif;
	
	writeOutputToMyForm(str);

epilog

	delete moveController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doCheckPackedLocations" id="285a6434-8fcf-468a-b2e4-c3fadd0f4c41">
        <source>doCheckPackedLocations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2016	cnwndl1	Initial creation	FS 1969

*/

vars

	param : String;
	list : Boolean;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		endif;
		if param = "LIST" then
			list := true;
		elseif param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 37849 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If cargo that has been gated in is immediately packed (prior to its associated Queued move being worked)" &amp; CrLf;
		info := info &amp; "and then the Work List Entry is manually 'moved' from the Road Operations form (i.e. after the item has become a child)," &amp; CrLf;
		info := info &amp; "JMT was erroneously updating the yard location so as to record that the cargo was there too." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Once the parent container is then moved off site, or on to a ship, the yard location still has a link to the child." &amp; CrLf;
		info := info &amp; "The cargo is not actually shown on-site anywhere in JMT, but the associated voyage of the cargo, will continue to be shown in the" &amp; CrLf;
		info := info &amp; "list of voyages on the Satellite View, even after the Voyage has been marked as never show." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a way to list the cargo that is in this state and to optionally correct the erroneous data" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will find all of the effected cargo items." &amp; CrLf;
		info := info &amp; "UPDATE - Will remove the incorrect 'yard location' association with the effected cargo items." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doCheckPackedLocationsWork( update );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckPackedLocationsWork" id="61f5b43f-fcdd-4db7-a2cc-5bbc43bf9e4d">
        <source>doCheckPackedLocationsWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2016	cnwndl1	Initial creation	TFS 1969

*/

vars

	msg : String;
	iterLc : Iterator;
	iterTi : Iterator;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	objArray : ObjectArray;
	lc : CM_LocationsController;
	actualLocation : String;

begin

	if _update then
		msg := "Processing in UPDATE mode :" &amp; CrLf;
	else
		msg := "Processing in LIST mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(msg);
	writeOutputToMyForm(CrLf);
	
	msg := "Checking all on site Yard locations..." &amp; CrLf;
	
	writeOutputToMyForm(msg);
	writeOutputToMyForm(CrLf);
	
	
	create objArray transient;
	create tiArray transient;
	CM_YardController.allInstances(objArray, 0, true);
	
	iterLc := objArray.createIterator;
	while iterLc.next(lc) do
	
		if lc.myTerminalArea = null or lc.myTerminalArea.myType = null then
			continue;
		endif;
		if lc.myTerminalArea.myType.isLogicalDeleteArea then
			continue;
		endif;
		
		iterTi := lc.allTrackedItems.createIterator;
		tiArray.clear();
		while iterTi.next(ti) do
			if not ti.isOnSite then
				if ti.isChild then
					tiArray.add(ti);
				endif;
			endif;
		endwhile;
		delete iterTi;
		
		if not tiArray.isEmpty then
			msg := "Location '" &amp; lc.getFullId &amp; "' in '" &amp; lc.myTerminal.code &amp; "' has incorrect references to the following cargo item(s):" &amp; CrLf;
			writeOutputToMyForm(msg);
			foreach ti in tiArray do
				actualLocation := "Offsite";
				if ti.myPrimaryActualLocation &lt;&gt; null then
					actualLocation := ti.myPrimaryActualLocation.getFullId;
				endif;
				if _update then
					beginTransaction;
					ti.allLocations.remove(lc);
					commitTransaction;
					msg := "'" &amp; ti.id &amp; "' in '" &amp; actualLocation &amp; "' has been updated" &amp; CrLf;
				else
					msg := "'" &amp; ti.id &amp; "' now '" &amp; actualLocation &amp; "'" &amp; CrLf;
				endif;
				writeOutputToMyForm(msg);
			endforeach;
			writeOutputToMyForm(CrLf);
		endif;
	endwhile;
	
	delete iterLc;
	
	msg := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(msg);
	
epilog

	delete objArray;
	delete tiArray;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCheckPrinterDefs" id="26abd228-44c0-4a49-9b0b-f3668965476a">
        <source>doCheckPrinterDefs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2013	cnwndl1	Initial creation	Par 31842

*/

vars

	param : String;
	list : Boolean;
	info : String;
	local : Boolean;
	server : Boolean;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			elseif param = "LOCAL" then
				local := true;
			elseif param = "SERVER" then
				server := true;
			endif;
		endif;
 	endif;
	
	if not list and not local and not server then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is provided to enable users to check the setup of their 'Printers' declared in System Administration." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The 'Printer definition objects' declared in System Administration are primarily used in JMT to provide a link to" &amp; CrLf;
		info := info &amp; "a server declared printer for BGP tasks." &amp; CrLf;
		info := info &amp; "In a situation where the 'Printer definition object' contains a 'Physical printer name' that is NOT known on the server" &amp; CrLf;
		info := info &amp; "and the 'Printer definition object' is used by a BGP process, the output may NOT be printed.  In the event that the" &amp; CrLf;
		info := info &amp; "output is printed, it is likely to be on the servers 'default' windows printer, which may not be an appropriate choice." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides an easy way to check that the 'Physical Printer Name' of all 'Printer definition objects' declared" &amp; CrLf;
		info := info &amp; "in System Administration equates to a known server printer." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will simply report all 'Printer definition objects' reporting back that it is OK, or that" &amp; CrLf;
		info := info &amp; "a server printer was not found matching the 'Physical Printer Name' used." &amp; CrLf;	
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will advise of the state of all 'Printer definition objects' relative to a matching server printer." &amp; CrLf;
		info := info &amp; "LOCAL - will list the names of all printers known to this local PC." &amp; CrLf;
		info := info &amp; "SERVER - will list the names of all printers known to the server." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST', 'LOCAL' or 'SERVER' are valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;



	self.doCheckPrinterDefsWork( list, local, server );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckPrinterDefsWork" id="bc7783cd-f91f-4bdb-9e4e-ec99fab594f9">
        <source>doCheckPrinterDefsWork( _list, _local, _server :Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2013	cnwndl1	Initial creation
10 Jul 2017		NDL		Add printer list 

*/

vars

	iter : Iterator;
	printerDef : CM_PrinterDef;
	
	local : Boolean;
	server : Boolean;
	msg : String;
	
	printerArray : CnStringArray;

begin

	if _list then
		msg := "Processing in LIST mode :" &amp; CrLf;
	elseif _local then
		msg := "Processing in LOCAL mode :" &amp; CrLf;
	elseif _server then
		msg := "Processing in SERVER mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(msg);
	writeOutputToMyForm(CrLf);

	if _list then
		iter := app.myRoot.allPrinterDefsByLogicalName.createIterator;
		while iter.next( printerDef ) do
		
			msg := null;
			local := app.validatePrinterName( printerDef.physicalPrinterName, false, true );
			server := app.validatePrinterName( printerDef.physicalPrinterName, true, false );
			
			if not local and not server then
				msg := app.getErrorString1( Printer_not_known_anywhere, printerDef.physicalPrinterName );
			elseif not server then
				msg := app.getErrorString1( Printer_local_NOT_server, printerDef.physicalPrinterName );
			else
				msg := "Is OK.";
			endif;
			
			if msg &lt;&gt; null then
				writeOutputToMyForm( printerDef.description &amp; " - " &amp;msg &amp; CrLf);
			endif;
		
		endwhile;
	
	elseif _local then
	
		create printerArray transient;
		app.printer.getAllPrinters(printerArray);
		
		if printerArray.isEmpty then
			writeOutputToMyForm( "*** NO Windows Local printer(s) found *** " &amp; CrLf);
			writeOutputToMyForm( CrLf );
		else
		
			writeOutputToMyForm( "*** Windows Local printer(s) configured are:" &amp; CrLf);
			
			foreach msg in printerArray do
				writeOutputToMyForm( "'" &amp; msg &amp; "'" &amp; CrLf);
			endforeach;
			
			writeOutputToMyForm( CrLf );
		endif;
	
	elseif _server then
	
		create printerArray transient;
		global.getAllServerPrinters(printerArray);
		
		if printerArray.isEmpty then
			writeOutputToMyForm( "*** NO Windows Server printer(s) found *** " &amp; CrLf);
			writeOutputToMyForm( CrLf );
		else
		
			writeOutputToMyForm( "*** Windows Server printer(s) configured are:" &amp; CrLf);
			
			foreach msg in printerArray do
				writeOutputToMyForm( "'" &amp; msg &amp; "'" &amp; CrLf);
			endforeach;
			
			writeOutputToMyForm( CrLf );
		endif;
	
	endif;
	
	writeOutputToMyForm(CrLf);
	msg := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(msg);

epilog

	delete printerArray;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_list" type="Boolean"/>
        <Parameter name="_local" type="Boolean"/>
        <Parameter name="_server" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCleanUpVesselStructure" id="4d8c0969-0f3c-4196-9fc7-f7a107499deb">
        <source>doCleanUpVesselStructure();

/*

niceName="Clean up null 'Cellular Vessel Structure' objects"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2011	cnwndl1	Initial creation	Par 27826

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 27826 &amp; 24838 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There is a situation where a CM_VesselStructure object can be left with no associated Vessel reference" &amp; CrLf;
		info := info &amp; "These CM_VesselStructure objects are orphaned in the database." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If JMT has one of these orphaned objects, it causes a 1310 error to be given when a copy of any Vessel is attempted." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to find and delete these orphans if they exist." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will simply report if an orphan exists" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will find and delete the orphan." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will advise if an orphaned CM_VesselStructure object exists." &amp; CrLf;
		info := info &amp; "UPDATE - will advise if an orphaned CM_VesselStructure object exists and delete it." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doCleanUpVesselStructureWork( update );
	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doCleanUpVesselStructureWork" id="b03da324-2ffc-466c-a602-438525753b41">
        <source>doCleanUpVesselStructureWork( _update : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2011	cnwndl1	Initial creation	Par 27826

*/

vars

	objsToDelete : ObjectArray;
	iter : Iterator;
	vessStruct : CM_CellularVesselStructure;
	genVessStruct : CM_GeneralCargoVesselStructure;
	obj : Object;
	str : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create objsToDelete transient;

	iter := CM_CellularVesselStructure.instances.createIterator;
	while iter.next( vessStruct ) do
		if vessStruct.myVessel = null then
			objsToDelete.add( vessStruct );
		endif;
	endwhile;
	delete iter;
	
	iter := CM_GeneralCargoVesselStructure.instances.createIterator;
	while iter.next( genVessStruct ) do
		if genVessStruct.myVessel = null then
			objsToDelete.add( genVessStruct );
		endif;
	endwhile;
	delete iter;
	
	if objsToDelete.isEmpty then
		str := "No orphaned CM_VesselStructure objects found." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	if _update then
		
		foreach obj in objsToDelete do
			str := "Found an orphaned " &amp; obj.String &amp; ", and have removed it.";
			writeOutputToMyForm(str &amp; CrLf);
			beginTransaction;
			delete obj;
			commitTransaction;
		endforeach;
		
	else
	
		foreach obj in objsToDelete do
			str := "Found an orphaned " &amp; obj.String &amp; ".";
			writeOutputToMyForm(str &amp; CrLf);
		endforeach;
	
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete objsToDelete;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCleanUpYACellHeights" id="702087e6-387d-49fb-a770-d2a66ded13f0">
        <source>doCleanUpYACellHeights();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2012	cnwndl1	Initial creation		Par 29504

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered, please enter a valid parameter!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 29604 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Some specific combinations of changes to Gridded Block (Fork Lift) Stacks could result in the height values" &amp; CrLf;
		info := info &amp; "of individual locations within the GBS being incorrect.  These conditions could also result in additional unused" &amp; CrLf;
		info := info &amp; "cells remaining after GBS heights had been reduced and empty positions in the cell arrays." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "These issues could result in some auto planning operations failing to find appropriate cargo positions in GBS areas," &amp; CrLf;
		info := info &amp; "meaning that JMT would not always correctly plan cargo according to the decking rules in Gridded Block Stacks." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method identifies the effected cell locations and corrects their height values where necessary." &amp; CrLf;
		info := info &amp; "It also identifies and cleans up extra cells and empty positions." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will simply list the GBS locations that have incorrect height data etc." &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will correct the length values etc. for the effected location(s)." &amp; CrLf;		
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list the GBS locations that have incorrect height data or extra cells etc." &amp; CrLf;
		info := info &amp; "UPDATE - will re-calculate and correct the effected cells." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doCleanUpYACellHeightsWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCleanUpYACellHeightsWork" id="65b6e0b1-1910-411e-94b6-9c086e46e413">
        <source>doCleanUpYACellHeightsWork( _update : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2012	cnwndl1	Initial creation	Par 29504

*/

vars

	gbs : CM_ForkLiftStack;
	iterBlockFork : Iterator;
	yaBlockFork : CM_YABlockFork;
	blockDeckOpt : CM_YADeckingOptionsBlock;
	taDeckOpt : CM_YADeckingOptionsTA;
	cellArray : CM_YALocationCellArray;
	iter : Iterator;
	cell : CM_YALocationCell;
	
	row : Integer;
	col : Integer;
	height : Integer;
	expectedHeight : Integer;
	
	emptyCells : Boolean;
	str : String;
	cellName : String;
	tmpCellArray : CM_YALocationCellArray;
	
	lcSet : CM_LCSet;
	iterGridCont : Iterator;
	gridController : CM_GridController;
	
	noData : Boolean;
	maxHeight : Integer;
	cellsToDelete : CM_YALocationCellSet;
	effectedCells : CM_YALocationCellSet;
	
begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	noData := true;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	create effectedCells transient;
	create tmpCellArray transient;

	//find null objects 'cell' refrences in the GBS decking IN collection
	iterBlockFork := CM_ForkLiftStack.instances.createIterator;
	while iterBlockFork.next( gbs ) do
		taDeckOpt := gbs.myYADeckingOptions;
		if taDeckOpt = null then
			continue;
		endif;
		cellArray := taDeckOpt.allYALocationCellsIn;
		if cellArray = null or cellArray.isEmpty then
			continue;
		endif;
		emptyCells := false;
		iter := cellArray.createIterator;
		while iter.next( cell ) do
			if cell = null then
				if not _update then
					str := '"' &amp; gbs.myTerminal.code &amp; '"  "' &amp; gbs.id &amp; '"  decking IN contains empty cell references.' &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
				emptyCells := true;
				noData := false;
				break;
			endif;
		endwhile;
		delete iter;
		if emptyCells  and _update then
			tmpCellArray.clear();
			iter := cellArray.createIterator;
			while iter.next( cell ) do
				if cell &lt;&gt; null then
					tmpCellArray.add(cell);
				endif;
			endwhile;
			beginTransaction;
			cellArray.clear();
			tmpCellArray.copy(cellArray);
			str := '"' &amp; gbs.myTerminal.code &amp; '"  "' &amp; gbs.id &amp; '"  empty cell references repaired [decking IN].' &amp; CrLf;
			writeOutputToMyForm(str);
			writeOutputToMyForm(CrLf);
			commitTransaction;
		endif;
	endwhile;
	delete iterBlockFork;
	
	
	//find null objects 'cell' refrences in the GBS decking OUT collection
	iterBlockFork := CM_ForkLiftStack.instances.createIterator;
	while iterBlockFork.next( gbs ) do
		taDeckOpt := gbs.myYADeckingOptions;
		if taDeckOpt = null then
			continue;
		endif;
		cellArray := taDeckOpt.allYALocationCellsOut;
		if cellArray = null or cellArray.isEmpty then
			continue;
		endif;
		emptyCells := false;
		iter := cellArray.createIterator;
		while iter.next( cell ) do
			if cell = null then
				if not _update then
					str := '"' &amp; gbs.myTerminal.code &amp; '"  "' &amp; gbs.id &amp; '"  decking OUT contains empty cell references.' &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
				emptyCells := true;
				noData := false;
				break;
			endif;
		endwhile;
		delete iter;
		if emptyCells  and _update then
			tmpCellArray.clear();
			iter := cellArray.createIterator;
			while iter.next( cell ) do
				if cell &lt;&gt; null then
					tmpCellArray.add(cell);
				endif;
			endwhile;
			beginTransaction;
			cellArray.clear();
			tmpCellArray.copy(cellArray);
			str := '"' &amp; gbs.myTerminal.code &amp; '"  "' &amp; gbs.id &amp; '"  empty cell references repaired [decking OUT].' &amp; CrLf;
			writeOutputToMyForm(str);
			writeOutputToMyForm(CrLf);
			commitTransaction;
		endif;
	endwhile;
	delete iterBlockFork;

	// find incorrect height values in the gridcontroller arrays for Gridded Bolock Stacks.
	iterBlockFork := CM_ForkLiftStack.instances.createIterator;
	while iterBlockFork.next( gbs ) do
		lcSet := gbs.allLocationsControllers;
		if lcSet = null or lcSet.isEmpty then
			continue;
		endif;
		maxHeight := gbs.heightOfStack;
		iterGridCont := lcSet.createIterator;
		while iterGridCont.next( gridController ) do
			if not gridController.isGap and not gridController.isOverhang and not gridController.isKindOf( CM_StackController ) then
				continue;
			endif;
			cellArray := gridController.allYAYardLocationCells;
			if cellArray = null or cellArray.isEmpty then
				continue;
			endif;
			iter := cellArray.createIterator;
			expectedHeight := 0;
			while iter.next( cell ) do
				if cell = null then
					if _update then
						str := '"' &amp; gbs.myTerminal.code &amp; '"  "' &amp; gbs.id &amp; '"  empty cell after ' &amp; row.String &amp; ", " &amp; col.String &amp; ", " &amp; height.String &amp; CrLf;
						writeOutputToMyForm(str);
					endif;
					continue;
				endif;
				if row &lt;&gt; cell.row then
					row := cell.row;
					expectedHeight := 0;
				endif;
				if col &lt;&gt; cell.column then
					col := cell.column;
					expectedHeight := 0;
				endif;
				if expectedHeight = 0 then
					expectedHeight := 1;
				else
					expectedHeight := expectedHeight + 1;
				endif;
				height := cell.height;
				cellName := cell.String &amp; ', ' &amp; gbs.myTerminal.code &amp; ',  ' &amp; gbs.id &amp; ', row ' &amp; row.String &amp; ", column " &amp; col.String &amp; ", ";
				if height &lt;&gt; expectedHeight and expectedHeight &lt;= maxHeight then
					// wrong height value for position in stack array.
					if not _update then
						if not effectedCells.includes(cell) then
							effectedCells.add(cell);
							str := cellName &amp; "height of " &amp; height.String &amp; " incorrect, expected " &amp; expectedHeight.String &amp; CrLf;
							writeOutputToMyForm(str);
						endif;
					else
						str := cellName &amp; "height was " &amp; height.String &amp; " set to " &amp; expectedHeight.String &amp; CrLf;
						writeOutputToMyForm(str);
						beginTransaction;
						cell.setPropertyValue("height",expectedHeight);
						commitTransaction;
					endif;
					noData := false;
				elseif height &gt; maxHeight then
					// existing height value greater than stack height.
					if not _update then
						if not effectedCells.includes(cell) then
							effectedCells.add(cell);
							str := cellName &amp; "height " &amp; height.String &amp; " above GBS max height  " &amp; maxHeight.String &amp; CrLf;
							writeOutputToMyForm(str);
						endif;
					else
						str := cellName &amp; "extra cell deleted." &amp; CrLf;
						writeOutputToMyForm(str);
						if cellsToDelete = null then
							create cellsToDelete transient;
						endif;
						cellsToDelete.add( cell );
					endif;
					noData := false;
				elseif expectedHeight &gt; maxHeight then
					// further up the array than the stack height goes.
					if not _update then
						if not effectedCells.includes(cell) then
							effectedCells.add(cell);
							str := cellName &amp; "array position " &amp; expectedHeight.String &amp; " above GBS max height  " &amp; maxHeight.String &amp; CrLf;
							writeOutputToMyForm(str);
						endif;
					else
						str := cellName &amp; "extra cell deleted." &amp; CrLf;
						writeOutputToMyForm(str);
						if cellsToDelete = null then
							create cellsToDelete transient;
						endif;
						cellsToDelete.add( cell );
					endif;
					noData := false;
				endif;
			endwhile;
			delete iter; 
		
		endwhile;
		delete iterGridCont;
		
	
	endwhile;
	delete iterBlockFork;
	
	if _update then
		if cellsToDelete &lt;&gt; null then
			if not cellsToDelete.isEmpty then
				beginTransaction;
				cellsToDelete.purge();
				commitTransaction;
			endif;
			delete cellsToDelete;
		endif;
	endif;
	
	if noData then
		if _update then
			str := "No cell locations found that required updating." &amp; CrLf;
		else
			str := "No cell locations found with incorrect height(s).  No further action required." &amp; CrLf;
		endif;
		writeOutputToMyForm(str);
	endif;
	
epilog

	delete iterBlockFork;
	delete iterGridCont;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCleanseCashReceiptTIs" id="9e41e560-ddf3-470c-a37f-2947a74dd7a2">
        <source>doCleanseCashReceiptTIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2016	cnwndl1	Initial creation

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		param := self.parameterArray.first.trimBlanks.toUpper;
		if param = "UPDATE" then
			update := true;
		elseif param = "LIST" then
			list := true;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method relates to Parsys 37714 / TFS 1726." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method clears any invalid Tracked Item (Cargo) object references found in Cash Receipts." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Under certain circumstances, it is possible to delete cargo from the system after a Cash Receipt has been raised." &amp; CrLf;
		info := info &amp; "If one of these 'deleted' cargo items are encountered in code accessing a Cash Receipt, the system may encounter an Error 4." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Running this method should only be performed in a period of low activity, otherwise perfomance or locking issues may occur." &amp; CrLf;
		info := info &amp; "The time taken to run this method will be proportional to the number of Cash Receipts in the system, and may take several minutes." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in 'UPDATE' mode this method will clear these invalid references, if run in 'LIST' mode it will identify any" &amp; CrLf;		
		info := info &amp; "Cash Receipts that have an association with deleted Cargo." &amp; CrLf;	
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will determine if any Cash Receipts have an association with deleted cargo." &amp; CrLf;
		info := info &amp; "UPDATE - will clear any invalid cargo object references from the Cash Receipts." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'UPDATE' or 'LIST' are considered a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doCleanseCashReceiptTIsWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCleanseCashReceiptTIsWork" id="bed1d828-9d45-429b-bbfc-d8d7936af5da">
        <source>doCleanseCashReceiptTIsWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2016	cnwndl1	Initial creation	TFS 1726

*/

vars

	str : String;
	ti : CM_TrackedItem;
	invalidTi : Boolean;
	cashReceipt : CM_CashReceipt;
	cashRecSet : CM_CashReceiptSet;
	iter : Iterator;
	edition : Integer;

begin

	if _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	else
		str := "Processing in LIST mode :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);
	
	on Exception do app.handleDeletedObject( exception, ti, invalidTi);
	
	str := CM_CashReceipt.instances.size.String &amp; " Cash Receipts in the system to process..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	str := "Gathering Cash Receipt data..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	create cashRecSet transient;
	
	iter := CM_CashReceipt.instances.createIterator;
	while iter.next( cashReceipt ) do
		foreach ti in cashReceipt.allTrackedItems discreteLock do
			invalidTi := false;
			edition := ti.edition;
			if invalidTi then
				cashRecSet.add( cashReceipt );
				break;
			endif;
		endforeach;
	endwhile;
	delete iter;
	
	if cashRecSet.isEmpty then
		str := "Cash Receipt data gathering complete.  No associations with deleted Cargo found." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		str := "Cash Receipt data gathering complete.  " &amp; cashRecSet.size.String &amp; " associations with deleted Cargo found." &amp; CrLf;
		writeOutputToMyForm(str);
		if not _update then
			//list only
			foreach cashReceipt in cashRecSet do
				str := Tab &amp; "'" &amp; cashReceipt.getDescription &amp; "' has one or more associations with deleted Cargo." &amp; CrLf;
				writeOutputToMyForm(str);
			endforeach;
		else
			foreach cashReceipt in cashRecSet do
				beginTransaction;
				cashReceipt.clearInvalidTiRefs();
				commitTransaction;
				str := Tab &amp; "'" &amp; cashReceipt.getDescription &amp; "' association(s) with deleted Cargo removed." &amp; CrLf;
				writeOutputToMyForm(str);
			endforeach;
		endif;
	
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	

epilog

	delete cashRecSet;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearInvalidObjsFromRail" id="58603c7a-ef9a-4d66-9796-dd253023dfec">
        <source>doClearInvalidObjsFromRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2013	cnwndl1	Initial creation

*/

vars

	param : String;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		param := self.parameterArray.first.trimBlanks.toUpper;
		if param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not update then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is clears any invalid Wagon obj references in Railines." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "There was an historic issue that could leave references to invalid Wagons in the collection on Rail lines." &amp; CrLf;
		info := info &amp; "These could prohibit the ability for user to maintain Rail Line area details" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will clear these invalid references" &amp; CrLf;		
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will clear any invalid objects from the all wagons collection on Rail lines." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'UPDATE' is considered a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doClearInvalidObjsFromRailWork();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearInvalidObjsFromRailWork" id="96243e57-7c7f-4fe0-b7bc-2ee55f23c09e">
        <source>doClearInvalidObjsFromRailWork() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2013	cnwndl1	Initial creation

*/

vars

	railLine : CM_RailLine;
	str : String;
	invalidWagon : Boolean;
	wagon : CM_Wagon;
	localWagons : CM_WagonSet;
	edition : Integer;

begin

	str := "Processing in UPDATE mode :" &amp; CrLf;
	writeOutputToMyForm(str);
	
	on Exception do app.handleDeletedObject( exception, wagon, invalidWagon);
	create localWagons transient;

	foreach railLine in CM_RailLine.instances do
	
		localWagons.clear();
		foreach wagon in railLine.allWagons do
			invalidWagon := false;
			if wagon &lt;&gt; null then
				edition := wagon.edition;
				if invalidWagon then
					continue;
				endif;
				localWagons.add(wagon);
			endif;
		endforeach;
		
		beginTransaction;
			railLine.allWagons.clear();
			localWagons.copy(railLine.allWagons);
		commitTransaction;
		
	endforeach;

	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete localWagons;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConvertPilotExemptStatus" id="db7e9ce9-ad5a-42ab-95b8-c776031b683e">
        <source>doConvertPilotExemptStatus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 29496 / PNL CCMS 2064 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The requirements for Pilots aboard vessels changed during 2011 at Port Nelson." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This script provides a mechanism to set the 'Pilot Exempt' flag on all Vessels defined in JMT that" &amp; CrLf;
		info := info &amp; "have an 'LOA' value of LESS than 40.00 metres" &amp; CrLf;
		info := info &amp; "This script will also set the 'Pilot Exempt' flag on all futures Voyages defined in JMT that" &amp; CrLf;
		info := info &amp; "have an 'LOA' value of LESS than 40.00 metres" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "'Vessels' and 'Future Voyages' with an 'LOA' of 40.00 metres or greater will NOT be touched by this process." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will simply report the Vessels and Future Voyages that would have the 'Pilot Exempt' flag set." &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will update the the 'Pilot Exempt' flag of appropriate Vessels and Future Voyages" &amp; CrLf;		
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list those Vessels and Future Voyages that would have the 'Pilot Exempt' flag set." &amp; CrLf;
		info := info &amp; "UPDATE - will set the he 'Pilot Exempt' flag on those Vessels and Future Voyages less than 40.00 metres of LOA." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doConvertPilotExemptStatusWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doConvertPilotExemptStatusWork" id="6b678693-db56-4267-946b-fb17670fb69c">
        <source>doConvertPilotExemptStatusWork( _update : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	vesselsToUpdate : ObjectArray;
	voyagesToUpdate : ObjectArray;
	iter : Iterator;
	vessel : CM_Vessel;
	loa : Decimal [12,2];
	pilotExempt : Boolean;
	term : CM_Terminal;
	voyage : CM_Voyage;
	now : TimeStamp;
	startVoyage : CM_Voyage;
	str : String;
	obj : Object;
	vdh : HMS_VesselDataHarbour;
	futureMovements : HMS_VoyageMovementSet;
	voyageMovement : HMS_VoyageMovement;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	now := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create vesselsToUpdate transient;
	create voyagesToUpdate transient;

	iter := CM_Vessel.instances.createIterator;
	while iter.next( vessel ) do
		if vessel.myHMSVesselData = null then
			continue;
		endif;
		loa := vessel.myHMSVesselData.dim_LengthOverall;
		if loa &gt;= 40.00 then
			continue;
		endif;
		pilotExempt := true;
		foreach vdh in vessel.myHMSVesselData.allVesselDataForHarbour do
			if not vdh.isPilotExempt then
				pilotExempt := false;
				break;
			endif;
		endforeach;
		if pilotExempt then
			continue;
		endif;
		vesselsToUpdate.add( vessel );
	endwhile;
	delete iter;
	
	foreach term in app.myRoot.allTerminals do
		startVoyage := null;
		iter := term.allVoyagesByArrivalDTCode.createIterator;
		startVoyage := term.allVoyagesByArrivalDTCode.getAtKeyGeq( now, null );
		if startVoyage = null then
			continue;
		endif;
		iter.startAtObject( startVoyage );
		while iter.next( voyage ) do
			if voyage.isNullVoyage or voyage.myHMSVoyageData = null then
				continue;
			endif;
			loa := voyage.myHMSVoyageData.dim_LengthOverall;
			if loa &gt;= 40.00 then
				continue;
			endif;
			pilotExempt := voyage.myHMSVoyageData.isPilotExempt;
			if pilotExempt then
				continue;
			endif;
			voyagesToUpdate.add( voyage );
		endwhile;
		delete iter;
	endforeach;
	
	if vesselsToUpdate.isEmpty and voyagesToUpdate.isEmpty then
		str := "No Vessels or Future Voyages found that need their 'Pilot Exempt' flag set." &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
		
	foreach obj in vesselsToUpdate do
		vessel := obj.CM_Vessel;
		str := "Vessel " &amp; vessel.code &amp; " - " &amp; vessel.myHMSVesselData.dim_LengthOverall.String &amp; "m";
		if _update then
			beginTransaction;
			foreach vdh in vessel.myHMSVesselData.allVesselDataForHarbour do
				if not vdh.isPilotExempt then
					vdh.setPropertyValue("isPilotExempt",true);
				endif;
			endforeach;
			commitTransaction;
			str := str &amp; " : now marked as Pilot Exempt";
		endif;
		writeOutputToMyForm(str &amp; CrLf);
	endforeach;
	
	create futureMovements transient;
	foreach obj in voyagesToUpdate do
		voyage := obj.CM_Voyage;
		term := voyage.getMyTerminal;
		if term &lt;&gt; null then
			str := term.code &amp; " - Voyage " &amp; voyage.code.String &amp; " due " &amp; voyage.arrivedDT.String &amp; " - " &amp; voyage.myHMSVoyageData.dim_LengthOverall.String &amp; "m";
		else
			str := "Unknown terminal - Voyage " &amp; voyage.code.String &amp; " due " &amp; voyage.arrivedDT.String &amp; " - " &amp; voyage.myHMSVoyageData.dim_LengthOverall.String &amp; "m";
		endif;
		
		if _update then
			futureMovements.clear();
			voyage.myHMSVoyageData.getFutureMovementsForConv( now, futureMovements );
			beginTransaction;
			voyage.myHMSVoyageData.setPropertyValue("isPilotExempt",true);
			if not futureMovements.isEmpty then
				foreach voyageMovement in futureMovements do
					voyageMovement.setPropertyValue("pilotExempt",true);
				endforeach;
			endif;
			commitTransaction;
			str := str &amp; " : now marked as Pilot Exempt";
		endif;
		writeOutputToMyForm(str &amp; CrLf);
	endforeach;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete voyagesToUpdate;
	delete vesselsToUpdate;
	delete iter;
	delete futureMovements;
	
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateBATs" id="3056431b-d413-4207-b440-82c27a022ab8">
        <source>doCreateBATs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2012	cnwndl1	Initial creation	Par 29417

*/

vars

	paramString : String;
	paramsOK : Boolean;
	str : String;
	maxSize : Integer;
	
	term : CM_Terminal;	
	prefix : String;
	zeroFillLength : Integer;
	start : Integer;
	finish : Integer;
	
	info : String;

begin

	if self.parameterArray.size = 5 then
		paramsOK := true;
		paramString := self.parameterArray[1].toUpper;
		term := app.myRoot.allTerminals.getAtKey(paramString);
		if term = null then
			paramsOK := false;
			str := "PARAMETER ERROR - first parameter '" &amp; paramString &amp; "' does not resolve to a recognised terminal!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		paramString := self.parameterArray[2].toUpper.trimBlanks;
		prefix := paramString;
		if prefix = "-" then
			prefix := null;
		endif;
		
		paramString := self.parameterArray[3];
		if paramString.isInteger then
			start := paramString.Integer;
		else
			paramsOK := false;
			str := "PARAMETER ERROR - third parameter '" &amp; paramString &amp; "' first number must be a number!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		paramString := self.parameterArray[4];
		if paramString.isInteger then
			finish := paramString.Integer;
		else
			paramsOK := false;
			str := "PARAMETER ERROR - fourth parameter '" &amp; paramString &amp; "' last number must be a number!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		paramString := self.parameterArray[5];
		if paramString.isInteger then
			zeroFillLength := paramString.Integer;
		else
			paramsOK := false;
			str := "PARAMETER ERROR - fifth parameter '" &amp; paramString &amp; "' zero fill leading positions must be a number!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		maxSize := prefix.length + zeroFillLength;
		if maxSize &gt; 30 then
			paramsOK := false;
			str := "PARAMETER ERROR - 'Prefix' value and 'Zero Fill' value would result in values too big for the data base";
			writeOutputToMyForm(str);
		endif;
		
		if start &gt; finish then
			paramsOK := false;
			str := "PARAMETER ERROR - 'First number' value '" &amp; start.String &amp; "' may not be greater than 'Last number' value'" &amp; finish.String &amp; "'";
			writeOutputToMyForm(str);
		endif;
		
		maxSize := prefix.length + finish.String.length;
		if maxSize &gt; 30 then
			paramsOK := false;
			str := "PARAMETER ERROR - 'Prefix' value and 'Last number' value would result in values too big for the data base";
			writeOutputToMyForm(str);
		endif;
		
		if finish - start &gt; 200 then
			paramsOK := false;
			str := "PARAMETER ERROR - Must process in batches of 200 items (or less) per run.";
			writeOutputToMyForm(str);
		endif;
		
		if not paramsOK then
			str := CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		endif;
		
	else
		paramsOK := false;
		str := "PARAMETER ERROR - 5 space delimited parameters required. " &amp; self.parameterArray.size.String &amp; " found" &amp; CrLf  &amp; CrLf;
		writeOutputToMyForm(str);
 	endif;
	
	if paramsOK then
		str := "Attempting to process using the following parameters:" &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Terminal - " &amp; term.code &amp; CrLf;
		writeOutputToMyForm(str);
		if prefix = null then
			str := "No Prefix"&amp; CrLf;
		else
			str := "Prefix - '" &amp; prefix &amp; "'" &amp; CrLf;
		endif;
		writeOutputToMyForm(str);
		str := "First number - " &amp; start.String &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Last number - " &amp; finish.String &amp; CrLf;
		writeOutputToMyForm(str);
		if zeroFillLength = 0 then
			str := "Do not Zero fill";
		else
			str := "Zero fill number portion to - " &amp; zeroFillLength.String &amp; " (digits)" &amp; CrLf;
		endif;
		writeOutputToMyForm(str);
		
		if not app.msgBox("Will attempt to run with the listed parameters." &amp; CrLf &amp; "Do you want to continue?","Continue?",MsgBox_Yes_No) = MsgBox_Return_Yes then
			str := "User aborteded the run after seeing teh parameters ";
			writeOutputToMyForm(str);
			return;
		endif;
	else
	
		info := "No recognised parameter(s) entered, or errors encountered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 29417 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides a quick way to build generic BAT numbers (stored as RFID Tags) in JMT," &amp; CrLf;
		info := info &amp; "providing that they are purely numeric, or zero left justified numeric." &amp; CrLf;
		info := info &amp; "Optionally they may also include a prefix." &amp; CrLf;
		info := info &amp; "e.g. 1, 2, 3, 4     or  001, 002, 003, 004   or  ABC1, ABC2, ABC3, ABC4  or ABC001, ABC002, ABC003, ABC004." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The RFID tags are created against an indivual terminal, and are created as 'Available'." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "NOTE: If you not want one of the formats listed above, these items must be entered manually!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "ALL 5 Parameters must be provided, they must be entered in the correct order and they must be space delimited:" &amp; CrLf;
		info := info &amp; "The parameters are &lt;Terminal code&gt; &lt;prefix value&gt; &lt;fisrt number&gt; &lt;last number&gt; &lt;zero fill value&gt;" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;Terminal code&gt; - The 'code' value of the terminal that you want to create the data for." &amp; CrLf;
		info := info &amp; "                 				I.e. " &amp; CM_Terminal.firstInstance.code &amp; CrLf;
		info := info &amp; "&lt;prefix value&gt; - The alpha portion of the value required or a hyphen character'-' if no alpha is required." &amp; CrLf;
		info := info &amp; "                 				I.e. ABC for the 'ABC1' or 'ABC001' examples above, or a space character for the '1'" &amp; CrLf;
		info := info &amp; "                 				or '001' examples." &amp; CrLf;		
		info := info &amp; "&lt;first number&gt; - The first number in the series when adding the RFID item." &amp; CrLf;
		info := info &amp; "                 				I.e. In our example above this would '1'" &amp; CrLf;
		info := info &amp; "&lt;last number&gt; - The last number in the series when adding the RFID item." &amp; CrLf;
		info := info &amp; "                 				I.e. In our example above this would '4'" &amp; CrLf;
		info := info &amp; "&lt;zero fill value&gt; - The maximum length to make the numeric portion of the RFID Tag value when making '001' or ABC001' examples above," &amp; CrLf;
		info := info &amp; "                                or '0' if no padding is required.  I.e. In the '001' and ABC001' examples this would '3'," &amp; CrLf;
		info := info &amp; "                 				in the '1' and ABC1' examples this would '0'" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Examples: (Do not include the quote character ('))" &amp; CrLf;
		info := info &amp; "For values of 1, 2, 3, 4 enter a parameter =    '" &amp; CM_Terminal.firstInstance.code &amp; " - 1 4 0'" &amp; CrLf;
		info := info &amp; "For values of 001, 002, 003, 004 enter a parameter =    '" &amp; CM_Terminal.firstInstance.code &amp; " - 1 4 3'" &amp; CrLf;
		info := info &amp; "For values of ABC1, ABC2, ABC3, ABC4 enter a parameter =    '" &amp; CM_Terminal.firstInstance.code &amp; " ABC 1 4 0'" &amp; CrLf;
		info := info &amp; "For values of ABC001, ABC002, ABC003, ABC004 enter a parameter =    '" &amp; CM_Terminal.firstInstance.code &amp; " ABC 1 4 3'" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		
		return;
		
	endif;

	self.doCreateBATsWork(	term, prefix, zeroFillLength, start, finish );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateBATsWork" id="c4da1ab1-75ef-4e6a-84dd-734637b63201">
        <source>doCreateBATsWork(	_term : CM_Terminal input;	
					_prefix : String;
					_numLength : Integer;
					_start : Integer;
					_end : Integer
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2012	cnwndl1	Initial creation	Par 29417

*/

vars

	errorMess : String;
	str : String;
	maxSize : Integer;
	index : Integer;
	code : String;
	pxyRfid : CM_RFIDTag;
	pxyDict : CM_RFIDTagByCodeDict;
	codesInUse : StringArray;
	realRfid : CM_RFIDTag;
	count : Integer;

begin

	create pxyDict transient;
	create codesInUse transient;
	
	app.myPassport.setMyTerminal(_term);

	//create a bunch of proxies.
	foreach index in _start to _end do
		code := _prefix;
		if _numLength &gt; 0 then
			code := code &amp; index.padLeadingWith('0',_numLength);
		else
			code := code &amp; index.String;
		endif;
		create pxyRfid transient;
		pxyRfid.setProxy(	code,	//_code,
							code,	//_description,
							code,	//_internalNumber : String;
							true,	//_isAvailable : Boolean;
							null	//_remarks : String
							);
		pxyDict.add(pxyRfid);
	endforeach;

	if not _term.allRFIDTagsByCode.isEmpty then
		//find any existing dups
		str := " " &amp; CrLf &amp; "Checking - " &amp; pxyDict.size.String &amp; " RFID Tag(s) to check..." &amp; CrLf;
		writeOutputToMyForm(str);
		
		foreach pxyRfid in pxyDict do
			if _term.allRFIDTagsBySerialNo[pxyRfid.serialNumber] &lt;&gt; null then
				codesInUse.add( pxyRfid.serialNumber );
				continue;
			endif;
			if _term.allRFIDTagsByCode[pxyRfid.code] &lt;&gt; null then
				codesInUse.add( pxyRfid.code );
				continue;
			endif;
		endforeach;
		
		//bail if you find any.
		if not codesInUse.isEmpty then
			str := " " &amp; CrLf &amp; "Unable to use the following RFID Tag(s) values, which are laready in use:" &amp; CrLf;
			writeOutputToMyForm(str);
			foreach str in codesInUse do
				writeOutputToMyForm(str &amp; CrLf);
			endforeach;
			return;
		endif;
	endif;
	
	//persist the proxies.
	foreach pxyRfid in pxyDict do
		app.myTrxCA.trxCreateRFIDTag(pxyRfid, realRfid, _term, app.myPassport);
		if app.myPassport.trxCompletedOK then
			str := "'" &amp; pxyRfid.code &amp; "' RFID Tag created." &amp; CrLf;
			writeOutputToMyForm(str);
			count := count + 1;
		else
			str := " " &amp; CrLf &amp; "FAILED to create RFID Tag for '" &amp; pxyRfid.code &amp; "'" &amp; CrLf;
			writeOutputToMyForm(str);
			str := " " &amp; CrLf &amp; "Remainder of update aborted." &amp; CrLf;
			writeOutputToMyForm(str);
			break;
		endif;
	endforeach;
	
	str := " " &amp; CrLf &amp; "Created - " &amp; count.String &amp; " RFID Tag(s) created..." &amp; CrLf;
	writeOutputToMyForm(str);

epilog

	if errorMess &lt;&gt; null then
		writeOutputToMyForm(errorMess);
		writeOutputToMyForm(CrLf);
	endif;
	
	if not pxyDict.isEmpty then
		pxyDict.purge();
	endif;
	delete pxyDict;
	delete codesInUse;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal" usage="input"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_numLength" type="Integer"/>
        <Parameter name="_start" type="Integer"/>
        <Parameter name="_end" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDeleteArchivedVoyages" id="e144405a-de1c-4e77-afbe-74f19aa3c684">
        <source>doDeleteArchivedVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2019	jlgdi1	TFS# 43985 Initial creation

*/

constants
	FIVE_YEARS : Integer = -5;
	SIX_YEARS : Integer = -6;
	
vars
	operation : String;
	terminalCode : String;
	startDate : Date;
	endDate : Date;
	info : String;
	sampleDate : Date;
	sampleTerminalCode : String;
	
begin
	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 4 then			
			operation := self.parameterArray[1].trimBlanks.toUpper;
			terminalCode := self.parameterArray[2].trimBlanks.toUpper;
			startDate := self.parameterArray[3].trimBlanks.Date;
			endDate := self.parameterArray[4].trimBlanks.Date;
		endif;
 	endif;
	
	sampleTerminalCode := CM_Terminal.firstInstance().code;
	
	if self.parameterArray.isEmpty() or 
	   not startDate.isValid() or 
	   not endDate.isValid() or 
	   terminalCode = null or
	   (operation &lt;&gt; ListOperation and operation &lt;&gt; DeleteOperation)
	then
		info := "No recognised parameter(s) or invalid parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to TFS# 43985 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method will delete all archived voyages where the arrived date is between the user specified dates (start date and end date)." &amp; CrLf;
		info := info &amp; "Initially, the business requirement is expected to satisfied using Garbage Collection by ticking the 'Archive Voyages' checkbox and " &amp; CrLf;
		info := info &amp; "setting the date in the 'Purge Records With Date Less Than or Equal To' in the Garbage Collection screen. However, due to the fact that " &amp; CrLf;
		info := info &amp; "the 'Purge Records With Date Less Than or Equal To' refers to the archived Date/Time and NOT the 'arrival date' of the voyage, this special " &amp; CrLf;
		info := info &amp; "method came to an existence." &amp; CrLf; 
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Parameters : " &amp; CrLf;
		info := info &amp; "&lt;operation type&gt; &lt;terminal code&gt; &lt;start date&gt; &lt;end date&gt;" &amp; CrLf;
		info := info &amp; CrLf;
		info := info &amp; "where " &amp; CrLf;		
		info := info &amp; "&lt;operation type&gt; " &amp; Tab &amp; "- either LIST or DELETE. Not case sensitive" &amp; CrLf;
		info := info &amp; Tab &amp; Tab &amp; "  LIST operation will list all archived voyages matching the arrival date specified in the start date and end date parameters" &amp; CrLf;
		info := info &amp; Tab &amp; Tab &amp; "  DELETE operation will delete all matched archived voyages" &amp; CrLf;
		info := info &amp; "&lt;terminal code&gt;" &amp; Tab &amp; "- terminal code" &amp; CrLf;
		info := info &amp; "&lt;start date&gt;" &amp; Tab &amp; "- (date format ddMMMyyyy) will find all archived voyages with arrival date equal or later than the specified date" &amp; CrLf;
		info := info &amp; "&lt;end date&gt;" &amp; Tab &amp; "- (date format ddMMMyyyy) will find all archived voyages with arrival date equal or earlier than the specified date" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "NOTE: " &amp; CrLf;
		info := info &amp; "All parameters are mandatory, space delimited and must be in the correct order." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Example" &amp; CrLf;
		info := info &amp; ListOperation &amp; " " &amp; sampleTerminalCode &amp; " " &amp; sampleDate.addYears(SIX_YEARS).format("ddMMMyyy") &amp; " " &amp;  sampleDate.addYears(FIVE_YEARS).format("ddMMMyyy") &amp; CrLf;
		info := info &amp; DeleteOperation &amp; " " &amp; sampleTerminalCode &amp; " " &amp; sampleDate.addYears(SIX_YEARS).format("ddMMMyyy") &amp; " " &amp;  sampleDate.addYears(FIVE_YEARS).format("ddMMMyyy") &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doDeleteArchivedVoyagesWork(operation,
									 terminalCode,
									 startDate, 
									 endDate);
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteArchivedVoyagesWork" id="3cb4df0a-a316-43b1-8c3b-c4d066e34856">
        <source>doDeleteArchivedVoyagesWork(_operation : String;
							_terminalCode : String;
							_startDate : Date;
							_endDate : Date) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2019	jlgdi1	TFS# 43985 Initial creation

*/

vars
	voyages : CM_VoyageArray;	
	voyage : CM_Voyage;
	voyagesByArrival : CM_VoyageByArrivalDTTerminal;
	message : String;
	iterator : Iterator;
	count : Integer;
	size : String;
	invalid : Boolean;
	voyageDesc : String;
		
begin
	app.myPassport.clearErrorsWarnings();
	
	message := "Processing in " &amp; _operation &amp; " MODE" &amp; CrLf;
	writeOutputToMyForm(message);
	
	create voyages transient;
	create voyagesByArrival transient;
	CM_Voyage.allInstances(voyages, 0, true);
	
	message := CrLf &amp; "Getting archived voyages from terminal " &amp; _terminalCode &amp; " that arrived between " &amp; _startDate.asStringJMT &amp; " and " &amp; _endDate.asStringJMT &amp; CrLf;
	writeOutputToMyForm(message);
	
	foreach voyage in voyages do
		if (voyage.archived) and
		   (voyage.myTerminal.code = _terminalCode) and 
		   (voyage.arrivedDT.Date &gt;= _startDate) and 
		   (voyage.arrivedDT.Date &lt;= _endDate)
		then
			voyagesByArrival.add(voyage);
		endif;
	endforeach;

	size := voyagesByArrival.size.asStringJMT;
	message := CrLf &amp; "There are " &amp; size &amp; " archived voyage(s) identified for deletion." &amp; CrLf;
	writeOutputToMyForm(message);
	
	on Exception do self.eraseExceptionHandler(exception);
	on Exception do app.handleDeletedObject(exception, voyage, invalid); 
			
	iterator := voyagesByArrival.createIterator;
	count := 0;
	while iterator.next(voyage) do
		voyageDesc := "Terminal : " &amp; voyage.myTerminal.code &amp; Tab &amp; "Voyage Code : " &amp; voyage.code &amp; Tab &amp; "Arrived on : " &amp; voyage.arrivedDT.date.asStringJMT;
		
		if _operation = DeleteOperation then
			invalid := false;
			if not invalid then			
				if not process.isInTransactionState then
					beginTransaction;
				endif;
				
				voyage.erase(NORMAL_ERASE);
				count := count + 1;
				if process.isInTransactionState then
					commitTransaction;
					voyageDesc := voyageDesc &amp; " - deleted";
					app.writeLog(voyageDesc, 0);
				endif;
			endif;
		endif;
		
		writeOutputToMyForm(voyageDesc &amp; CrLf);
	endwhile;
	
	if _operation = DeleteOperation then 
		message := CrLf &amp; "Total deleted archived voyage(s) : " &amp; count.asStringJMT &amp; CrLf;
		writeOutputToMyForm(message);
	endif;
	
	message := CrLf &amp; _operation &amp; " Task completed ";
	writeOutputToMyForm(message);

epilog
	delete iterator;
	delete voyages;
	delete voyagesByArrival;
	on Exception do null;
end;</source>
        <access>protected</access>
        <Parameter name="_operation" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doDeleteStateStrings" id="4850aa76-daf5-43c6-9cbe-596bec46da31">
        <source>doDeleteStateStrings();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26 July 2016	cnwdap1		Initial creation C3 TFS #2211
//
vars
	timeToRun : Integer;
	info : String;
	startTime : TimeStamp;
	nowTime : TimeStamp;
	result, stringDel, objectDel : Integer;

begin
	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 2 then
			timeToRun := self.parameterArray.last.trimBlanks.Integer;
		endif;
 	endif;
	
	if timeToRun = null then
	
		info := "No recognised parameter(s) or invalid parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to PAR 37809 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Prior to 2010 there was a chance of the system creating CM_StateString objects then leaving them" &amp; CrLf;
		info := info &amp; "as orphans when their parent objects were deleted. These state string objects then have no way of being deleted." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to delete these orphaned state string objects." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The only processing option available for this method is TIMETORUN, which allows the method to run for a " &amp; CrLf;
		info := info &amp; "specified number of minutes before stopping. This is so the processing for this method can be staggered if required." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameter:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "TIMETORUN nnnn - Will read as many CM_StateString objects as it can in the number of minutes entered and delete those that have " &amp; CrLf;
		info := info &amp; "been orphaned. Entering 9999 as the TIMETORUN will cause the method to read ALL CM_StateString objects before stopping -" &amp; CrLf;
		info := info &amp; "on some systems this may take a period of hours." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	result := self.doDeleteStateStringsWork( timeToRun, stringDel, objectDel );
	if result = 1 then
		self.writeOutputToMyForm("Terminated processing after " &amp; timeToRun.String &amp; " minutes: " &amp; CrLf &amp;
								 Tab &amp; "Deleted " &amp; stringDel.String &amp; " CM_StateString instances" &amp; CrLf &amp;
								 Tab &amp; "Deleted " &amp; objectDel.String &amp; " CM_StateObject instances" &amp; CrLf &amp;
								 "There may still be CM_StateString objects that could be purged from the database.");
	else
		self.writeOutputToMyForm("All CM_StateString and CM_StateObject instances have been checked" &amp; CrLf &amp;
								 Tab &amp; "Deleted " &amp; stringDel.String &amp; " CM_StateString instances" &amp; CrLf &amp;
								 Tab &amp; "Deleted " &amp; objectDel.String &amp; " CM_StateObject instances");
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteStateStringsEx" id="372d3219-4806-42b7-a03a-ed87e3e0ac88">
        <source>doDeleteStateStringsEx(ex : Exception; invalidObj : Boolean output) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/07/2016	cnwdap1		Initial creation C3 TFS #2211
//
vars

begin
	if ex.errorCode = 4 then
		invalidObj := true;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="invalidObj" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDeleteStateStringsWork" id="52edec3d-266f-49d9-b2ce-c923f3e06790">
        <source>doDeleteStateStringsWork(_timeToRun : Integer; _stringsDeleted, _objectsDeleted : Integer output) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:			0 - ran to end of processing without being interrupted
//							1 - ran to end of specified time to run
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/07/2016	cnwdap1		Initial creation C3 TFS #2211
//
constants
	CommitTime = 2000;		// 2 seconds between commits
	
vars
	startTime, nowTime, progressTime : TimeStamp;
	timeToRunFor : Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	stateString : CM_StateString;
	stateObject : CM_StateObject;
	finishedDueToTime : Boolean;
	idx, deletedString, deletedObject : Integer;
	oid, key : String;
	obj : Object;
	handledEx : Boolean;

begin
	if _timeToRun &lt;&gt; 9999 then
		timeToRunFor := _timeToRun * 1000 * 60;			// milliseconds
	endif;
	
	progressTS := app.actualTimeServer;
	startTime := app.actualTimeServer;
	
	on Exception do self.doDeleteStateStringsEx(exception, handledEx);
	
	beginTransaction;
	
	foreach stateString in CM_StateString.instances discreteLock do
		progressInt := app.actualTimeServer - progressTS;
		if progressInt.getMilliseconds &gt;= CommitTime then
			commitTransaction;
			progressInt := app.actualTimeServer - startTime;
			if progressInt.getMilliseconds &gt; timeToRunFor and timeToRunFor &lt;&gt; null then
				finishedDueToTime := true;
				break;
			endif;
			progressTS := app.actualTimeServer();
			beginTransaction;
		endif;
		
		// check strings are all valid
		if stateString.myStateObject &lt;&gt; null and not app.isValidObject(stateString.myStateObject) then
			delete stateString;
			deletedString := deletedString + 1;
		elseif stateString.myStateObject = null and stateString.myTrackedItem = null and stateString.myBOL = null and stateString.myParent = null then
			delete stateString;
			deletedString := deletedString + 1;
		elseif stateString.myTrackedItem = null and stateString.myBOL = null and stateString.myParent = null then
			idx := stateString.key.pos("-", 1);
			if idx &lt;&gt; null then
				oid := stateString.key[idx+1:stateString.key.length-idx];
				key := stateString.key[1:idx-1];
				obj := oid.asObject;
				obj.creationTime;
				if handledEx then
					delete stateString;
					deletedString := deletedString + 1;
				endif;
			endif;
		else
			if stateString.myBOL &lt;&gt; null then
				if stateString.key = "ActualPieceCountError" then
					continue;
				endif;
				if stateString.key = "OPID" then
					oid := "opid";
				else	
					oid := stateString.key;
				endif;
				key := stateString.myBOL.getPropertyValue(oid).String;
				if key = stateString.CM_StateString.value then
					delete stateString;
					deletedString := deletedString + 1;
				endif;
			endif;					
		endif;
	endforeach;
	
	if finishedDueToTime then
		return 1;
	endif;
	
	// check CM_StateObjects to see if we can delete any because they no longer have any state strings attached
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	foreach stateObject in CM_StateObject.instances discreteLock do 
		progressInt := app.actualTimeServer - progressTS;
		if progressInt.getMilliseconds &gt;= CommitTime then
			commitTransaction;
			progressTS := app.actualTimeServer();
			beginTransaction;
		endif;
		
		if stateObject.allStateData.isEmpty 
		or (stateObject.myCMObject &lt;&gt; null and not app.isValidObject(stateObject.myCMObject)) 
		or stateObject.myCMObject = null then
			delete stateObject;
			deletedObject := deletedObject + 1;
		endif;
	endforeach;
	
	commitTransaction;
	return 0;
	
epilog
	_stringsDeleted := deletedString;
	_objectsDeleted := deletedObject;
	abortTransaction;
end;</source>
        <access>protected</access>
        <Parameter name="_timeToRun" type="Integer"/>
        <Parameter name="_stringsDeleted" type="Integer" usage="output"/>
        <Parameter name="_objectsDeleted" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDeleteUnknownTrucks" id="e948e081-64c9-4aec-8e49-d9f44cc4a037">
        <source>doDeleteUnknownTrucks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2016	cnwndl1	Initial creation	Par 37215
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	param : String;
	list : Boolean;
	update : Boolean;
	info : String;
	toDate : Date;
	exampleDate : Date;

begin

	exampleDate := app.actualTimeServer.Date - 30;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	// check that we have parameters and capture locally what we will be doing.
	toDate := null;
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 2 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			toDate := self.parameterArray.last.trimBlanks.Date;
		endif;
		if param = "COUNT" then
			list := true;
		elseif param = "DELETE" then
			update := true;
		endif;
 	endif;
	
	if not list and not update or not toDate.isValid or toDate &gt; exampleDate then
	
		info := "No recognised parameter(s) or invalid parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 37215 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "**********************************************************************************************" &amp; CrLf;
		info := info &amp; "BEFORE running this script, please ensure that NO users have the 'Terminal Administration' form open." &amp; CrLf;
		info := info &amp; "**********************************************************************************************" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Systems using the security gate option can gate in 'Unknown' trucks into the security area (outside the terminal)" &amp; CrLf;
		info := info &amp; "These trucks are created as 'Vehicle' objects in JMT, with JMT generated ids. (registration)" &amp; CrLf;
		info := info &amp; "Under normal circumstances these temporary vehicles are deleted when the real regisatration is recorded at the terminal gate" &amp; CrLf;
		info := info &amp; "If these 'Unknown' trucks never enter the real terminal, these tempoaray vehicles just stay in JMT." &amp; CrLf;
		info := info &amp; "Once the unknown truck has left the security area and a period of time has passed" &amp; CrLf; 
		info := info &amp; "the vehicle object and its associated 'Vehicle Visit' information is of little or no practical use." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to find these 'Unknown' vehicles, and delete them up to a date in the past (at least 30 days ago)." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The only processing options available for this method are delete or count, along with an associated date in the format DDMMMYYYY." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "COUNT " &amp; exampleDate.format("ddMMMyyy") &amp; " - Will find all 'unknown' trucks created up until " &amp; exampleDate.format("ddMMMyyy") &amp; " and return a count of how many could be deleted." &amp; CrLf;
		info := info &amp; "DELETE " &amp; exampleDate.format("ddMMMyyy") &amp; " - Will delete all 'unknown' trucks created up until " &amp; exampleDate.format("ddMMMyyy") &amp; " ." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doDeleteUnknownTrucksWork( update, toDate );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteUnknownTrucksWork" id="bdb1aa94-78d1-47c0-a22d-e88c021b2a78">
        <source>doDeleteUnknownTrucksWork( _update : Boolean; _toDate : Date )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2016	cnwndl1	Initial creation	Par 37215

*/

vars

	vehiclesToDelete : CM_VehicleSet;
	term : CM_Terminal;
	iter : Iterator;
	vehicle : CM_Vehicle;
	startAtVehicle : CM_Vehicle;
	str : String;
	vvr : CM_VehicleVisitRecord;

begin

	str := " " &amp; CrLf &amp; "Gathering Vehicle data..." &amp; CrLf;
	writeOutputToMyForm(str);


	create vehiclesToDelete transient;

	foreach term in app.myRoot.allTerminals discreteLock do
		startAtVehicle :=null;
		startAtVehicle := term.vehicles.getAtKeyGeq( Unknown_Truck_Prefix, null );
		if startAtVehicle = null or not startAtVehicle.isUnknownVehicle then
			continue;
		endif;
		iter := term.vehicles.createIterator;
		iter.startAtObject(startAtVehicle);
		while iter.next( vehicle ) do
			if not vehicle.isUnknownVehicle then
				break;
			endif;
			if vehicle.createdTime.date &gt;= _toDate then
				continue;
			endif;
			if vehicle.visitRecords.size &gt; 1 then
				continue;
			endif;
			if not vehicle.allRoadJobs.isEmpty then
				continue;
			endif;
			vehiclesToDelete.addNoDuplicates( vehicle, false );
		endwhile;
		delete iter;
	endforeach;
	
	if not _update then
		str := " " &amp; CrLf &amp; "Found " &amp; vehiclesToDelete.size.String &amp; " Unknown Vehicle(s) created before " &amp; _toDate.asStringJMT &amp; " that could be deleted" &amp; CrLf;
		writeOutputToMyForm(str);
	
	else
		str := " " &amp; CrLf &amp; "Found " &amp; vehiclesToDelete.size.String &amp; " Unknown Vehicle(s) created before " &amp; _toDate.asStringJMT &amp; " to delete..." &amp; CrLf;
		writeOutputToMyForm(str);
		
		str := " " &amp; CrLf &amp; "Deleting..." &amp; CrLf;
		writeOutputToMyForm(str);
		
		iter := vehiclesToDelete.createIterator;
		while iter.next( vehicle ) do
			foreach vvr in vehicle.visitRecords do
				beginTransaction;
				vvr.erase(NORMAL_ERASE);
				commitTransaction;
			endforeach;
			app.myPassport.warningsAcknowledged := true;
			app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
		endwhile;
		delete iter;
		
		str := " " &amp; CrLf &amp; vehiclesToDelete.size.String &amp; " Unknown Vehicle(s) created before " &amp; _toDate.asStringJMT &amp; " deleted." &amp; CrLf;
		writeOutputToMyForm(str);
	
	endif;

epilog

	delete iter;
	delete vehiclesToDelete;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_toDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doExtractLoad" id="c2085316-edc1-4bbd-950b-439d2287c35f">
        <source>doExtractLoad();

/*

Purpose:			Allow extract and load of selective invoice data

Parameters:			EXTRACT/LOAD &lt;terminal&gt; &lt;business unit&gt; &lt;file name&gt; &lt;data type&gt;
					or EXTRACT/LOAD DEBTORS &lt;file name&gt;
					or EXTRACT/LOAD CALCULATIONTYPES &lt;file name&gt;

Return Value:		


Date		Who		Reason
May 2015	cnwjre1	Initial creation	Par 36358
19 Jun 2017	cnwma1 	TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1	TFS #7659 STWO - FW: Transaction Map: PROBLEM
07 Dec 2018	NDL		TFS 42061 - Allow for extract / load of Invoice Type Surcharges
07 Sep 2022	navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries
10 Oct 2022	navpw1	TFS: 54566 - Added extracting and loading of Invoice Line Mappings
16 Jan 2022 navmv20 TFS 55650 Task 55701: Jade - Contracts XML Extract TRX 
*/

vars

	paramString : String;
	testString	: String;
	paramsOK : Boolean;
	str : String;
	found	: Boolean;
	tmpStr : String;
	term	: CM_Terminal;
	bank	: CM_Bank;
	action	: String;
	option	: String;
	fileName : String;
	logFileName	: String;
	pos			: Integer;
	optionType	: Integer;		// 1=debtors, 2=calculation types, 3=GL code, 4=services, 5=invoice types, 6=invoice line types ,7= Invoice allocation map, 8 = Storage Configuration
	info : String;
	invAllocMapName : String ; //19/06/2017 cnwma1 TFS #4498
	idx : Integer;
begin

	if self.parameterArray.size &gt; 2 then
		paramsOK := true;
		paramString := self.parameterArray[1].trimBlanks;
		action := paramString.toUpper();
		if action &lt;&gt; "EXTRACT" and action &lt;&gt; "LOAD" then
			paramsOK := false;
			str := "PARAMETER ERROR - first parameter '" &amp; paramString &amp; "' must be either EXTRACT or LOAD!" &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
		paramString := self.parameterArray[2].trimBlanks;
		testString := paramString.toUpper;
		// is either DEBTOR[S] or terminal code/name
		if testString = "DEBTOR" or testString = "DEBTORS" then
			optionType  := 1;
			option := testString;
		elseif testString = "CALCULATIONTYPE" or testString = "CALCULATIONTYPES" then
			optionType  := 2;
			option := testString;
		else
			// find terminal by either name or code
			foreach term in app.myRoot.allTerminals do
				if term.code = testString or
				   term.name = paramString then
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				term := null;
			endif;
			if term = null then
				paramsOK := false;
				str := "PARAMETER ERROR - second parameter '" &amp; paramString &amp; "' is not a valid terminal!" &amp; CrLf;
				writeOutputToMyForm(str);
			endif;
		endif;

		paramString := self.parameterArray[3].trimBlanks;
		testString := paramString.toUpper;
		// if DEBTORS or CALCULATIONTYPES then is file name
		if optionType = 1 or
		   optionType = 2 then
			fileName := paramString;
		else
			if self.parameterArray.size = 4 then
				testString := self.parameterArray[4];
				if testString = "STORAGECONFIG" then
					option := "STORAGECONFIG";
					fileName := paramString;
				endif;
			endif;
			
			if option = "" then // GENERAL LEDGER CODES, SERVICES, INVOICE TYPES, INVOICE LINE TYPES
				// otherwise is business unit code
				if term &lt;&gt; null then
					bank := term.companies[testString];
				endif;
				if bank = null then
					paramsOK := false;
					str := "PARAMETER ERROR - third parameter '" &amp; paramString &amp; "' is not a valid Business Unit!" &amp; CrLf;
					writeOutputToMyForm(str);
				endif;
			endif;
		endif;
		
		if option = "" then // GENERAL LEDGER CODES, SERVICES, INVOICE TYPES, INVOICE LINE TYPES

			if self.parameterArray.size &gt; 3 then
				paramString := self.parameterArray[4];
				fileName := paramString;
			endif;
	
			if self.parameterArray.size &gt; 4 then
				paramString := self.parameterArray[5];
				testString := paramString.toUpper;
				option := testString;
			endif;
	
			if self.parameterArray.size &gt; 5 then
				paramString := self.parameterArray[6];
				testString := paramString.toUpper;
				option := option &amp; " " &amp; testString;
			endif;
	
			if self.parameterArray.size &gt; 6 then
				paramString := self.parameterArray[7];
				testString := paramString.toUpper;
				option := option &amp; " " &amp; testString;
			endif;
			// ### TFS 54564 (54379) 02Sep2022 NAVPW1 - Added option check to only do this if the option is for "INVOICE ALLOCATION MAP" in case the option name may be longer
			if option = "INVOICE ALLOCATION MAP" and self.parameterArray.size &gt; 7 then //09/06/2017 cnwma1 TFS #4498 
				idx :=7;
				foreach str in self.parameterArray do
					idx :=idx+1;
					tmpStr := tmpStr &amp; self.parameterArray[idx]&amp;" ";
					if idx &gt;= self.parameterArray.size then
						break;
					endif;
				endforeach;
				//paramString := self.parameterArray[8];
				tmpStr :=tmpStr.truncatedAt(tmpStr.length-1);
				//invAllocMapName := tmpStr.toUpper;			// TFS 7659
				invAllocMapName := tmpStr;
			elseif self.parameterArray.size &gt; 7 then
				idx := 8;
				while idx &lt;= self.parameterArray.size do
					tmpStr := tmpStr &amp; self.parameterArray[idx] &amp; " ";
					if idx &gt;= self.parameterArray.size then
						break;
					endif;
					idx += 1;
				endwhile;
				option &amp;= " " &amp; tmpStr.trimWhiteSpace();
			endif;
			// ### TFS 54564 (54379) 02Sep2022 NAVPW1
		endif;	
		

		// optionType is 1=debtors, 2=calculation types, 3=GL code, 4=services, 5=invoice types, 6=invoice line types
		if option = "DEBTOR" or option = "DEBTORS" then
			optionType  := 1;
		elseif option = "CALCULATIONTYPE" or option = "CALCULATIONTYPES" then
			optionType  := 2;
		elseif option = "GENERAL LEDGER" or option = "GENERAL LEDGER CODES" then
			optionType := 3;
		elseif option = "SERVICE" or option = "SERVICES" then
			optionType := 4;
		elseif option = "INVOICE TYPE" or option = "INVOICE TYPES" then
			optionType := 5;
		elseif option = "INVOICE LINE TYPE" or option = "INVOICE LINE TYPES" then
			optionType := 6;
		elseif option = "INVOICE ALLOCATION MAP" then //19/06/2017 cnwma1 TFS #4498
			optionType := 7;
		elseif option = "STORAGECONFIG" then // TFS 5232
			optionType := 8; // TFS 5232
		elseif option = "SURCHARGES" then
			optionType := 9;
		elseif option = "SERVICE PAYMENT TYPES"	then
			optionType := 10;
		// ### TFS 54564 (54379) 02Sep2022 NAVPW1
		elseif option = "INVOICE LINE TYPE TRANS" then
			optionType := 11;
		// ### TFS 54564 (54379) 02Sep2022 NAVPW1
		// ### TFS 54566 28Sep2022 NAVPW1
		elseif option = "INVOICE LINE TYPE MAP" then
			optionType := 12;
		// ### TFS 54566 28Sep2022 NAVPW1
		elseif option = 'INVOICE CONTRACTS' then  //16/01/2023 navmv20 TFS 55650 TASK 55701 
			optionType := 13; //16/01/2023 navmv20 TFS 55650 TASK 55701
		else
			paramsOK := false;
			str := "PARAMETER ERROR - " &amp; option &amp; " is not a valid option." &amp;CrLf;
			writeOutputToMyForm(str);
		endif;

		if not paramsOK then
			str := CrLf &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
		
	else
		paramsOK := false;
		if self.parameterArray.size &gt; 0 then
			str := "PARAMETER ERROR - must be EXTRACT or LOAD, terminal id, business unit code, file name and then option. " &amp; CrLf  &amp; 
				" or EXTRACT/LOAD DEBTORS then file name" &amp; CrLf &amp; CrLf;
			writeOutputToMyForm(str);
		endif;
 	endif;
	
	if paramsOK then
		str := "About to " &amp; action &amp; " " &amp; option;
		if action = "EXTRACT" then
			if optionType = 1 or
			   optionType = 2 then
				str := str &amp; " to file " &amp; fileName;
			else
				//str := str &amp; " from terminal " &amp; term.name &amp; " and business unit " &amp; bank.code &amp; " to file " &amp; fileName; //19/06/2017 cnwma1 TFS #4498
				if invAllocMapName &lt;&gt; null then //09/06/2017 cnwma1 TFS #4498
					str := str &amp;":"&amp; invAllocMapName &amp; " from file " &amp; fileName &amp; " to terminal " &amp; term.name &amp; " and business unit " &amp; bank.code;
				elseif optionType = 8 then
					str := str &amp; " from terminal " &amp; term.name;
				else
					str := str &amp; " from file " &amp; fileName &amp; " to terminal " &amp; term.name &amp; " and business unit " &amp; bank.code;
				endif;
			endif;
		elseif action = "LOAD" then
			if optionType = 1 or 
			   optionType = 2 then
				str := str &amp; " from file " &amp; fileName;
			else
				//str := str &amp; " from file " &amp; fileName &amp; " to terminal " &amp; term.name &amp; " and business unit " &amp; bank.code; //19/06/2017 cnwma1 TFS #4498
				if invAllocMapName &lt;&gt; null then //09/06/2017 cnwma1 TFS #4498
					str := str &amp;":"&amp; invAllocMapName &amp; " from file " &amp; fileName &amp; " to terminal " &amp; term.name &amp; " and business unit " &amp; bank.code;
				elseif optionType = 8 then
					str := str &amp; " to terminal " &amp; term.name;
				else
					str := str &amp; " from file " &amp; fileName &amp; " to terminal " &amp; term.name &amp; " and business unit " &amp; bank.code;
				endif;
			endif;
			if fileName &lt;&gt; null then
				//pos := 1;
				//fileName.scanUntil(".", pos);
				pos := fileName.reversePos("."); //TFS 53050, AjitM, navam1
				if pos &gt; 0 then
					logFileName	:= fileName[1:(pos-1)] &amp; '.log';
				else
					logFileName	:= fileName &amp; '.log';
				endif;
				writeOutputToMyForm(str &amp; CrLf);
				str := "The results of the load will be written to log file " &amp; logFileName;
				writeOutputToMyForm(str &amp; CrLf);
			endif;
	
		endif;
		str := CrLf;
		writeOutputToMyForm(str);
		
		if not app.msgBox(action &amp; " " &amp; option &amp; CrLf &amp; "Do you want to continue?","Continue?",MsgBox_Yes_No) = MsgBox_Return_Yes then
			str := "User aborted the run after seeing the options.";
			writeOutputToMyForm(str);
			return;
		endif;
	else

	info := "This method provides a way to extract various invoicing setup data from JMT, for a given business unit of a terminal
and then load it back into the same copy of JMT but a different terminal or business unit.
It can also be used to load to a different copy of JMT, which allows copying invoice setup data from UAT to production, for example.

The file format for all options is XML so a file suffix of '.xml' is recommended.

For a load, the result of the load is written to a log file named &lt;file name&gt;.log


#### - Debtor Extract/Load for System

  EXTRACT DEBTORS &lt;file name&gt;
  LOAD DEBTORS &lt;file name&gt;
  
 &lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

 
#### - Calculation Types Extract/Load for System 

  EXTRACT CALCULATIONTYPES &lt;file name&gt;
  LOAD CALCULATIONTYPES &lt;file name&gt;
  
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.


#### - Invoice Allocation Map Extract/Load for a Business Unit of a Terminal 

  Extract and load Cargo Invoice Allocations and Inventory Allocatioon transaction maps.

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE ALLOCATION MAP &lt;allocation Map Name&gt;
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE ALLOCATION MAP &lt;allocation Map Name&gt;
	Note: If the map already exists, then it will be replaced by the imported one.
  
&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.
&lt;allocation Map Name&gt; - The name of the Cargo Allocation transaction map to be extracted/loaded. 

  
#### - Storage Configuration Including Future Storage Mappings Extract/Load for a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;file name&gt; STORAGECONFIG
  LOAD &lt;Terminal code&gt; &lt;file name&gt; STORAGECONFIG
  
&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

  
#### - Invoice Type Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE TYPES
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE TYPES

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

  
#### - General Ledger Codes Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; GENERAL LEDGER
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; GENERAL LEDGER

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

  
#### - Service Schedule Codes Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SERVICES
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SERVICES

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

  
#### - Invoice Line Types Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPES
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPES

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

  
#### - Invoice Type Surcharges and Exemptions Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SURCHARGES
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SURCHARGES

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.


#### - Service Payment Types Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SERVICE PAYMENT TYPES
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; SERVICE PAYMENT TYPES

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

#### - Invoice Line Type Translations Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPE TRANS
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPE TRANS
	Note: If the translation already exist, then it will be replaced by the imported one.

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

#### - Invoice Line Type Mappings Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPE MAP
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE LINE TYPE MAP
	Note: If the mapping already exist, then it will be replaced by the imported one.

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

#### - Invoice Contracts Extract/Load for a Business Unit of a Terminal 

  EXTRACT &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE CONTRACTS
  LOAD &lt;Terminal code&gt; &lt;Business unit code&gt; &lt;file name&gt; INVOICE CONTRACTS
	Note: If the contract already exist, then it will be replaced by the imported one.

&lt;Terminal code&gt; - The 'name' or 'code' value of the Terminal that you want to extract from/load into.
&lt;Business unit code&gt; - The 'code' value of the Business Unit from the terminal that you want to extract from/load into.
&lt;file name&gt; - The name of the file on the client PC to which the data is to be extracted/loaded.

";
	
		self.writeOutputToMyForm(info);
		
		return;
		
	endif;

	self.doExtractLoadWork(	term, bank, action, optionType, option, fileName ,invAllocMapName); //19/06/2017 cnwma1 TFS #4498

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractLoadWork" id="32b82f5b-354b-4b07-8916-9ebb6e316981">
        <source>doExtractLoadWork(	_term : CM_Terminal input; _bank : CM_Bank; _action : String; _optionType : Integer; _option : String; _fileName : String;_invAllocTranMap : String) protected;

/*

Purpose:			

Parameters:		optionType		1=debtors, 2=GL code, 3=services, 4=invoice types, 5=invoice line types


Return Value:		


Date		Who		Reason
May 2015	cnwjre1	Initial creation	Par 36538
19 Jun 2017	cnwma1  TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1	TFS #7659 STWO - FW: Transaction Map: PROBLEM
07 Sep 2022	navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries
06 Oct 2022	navpw1	TFS: 54566 - Added extract and load for Invoice Line Type Mappings
17 Jan 2022 navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
17 Jan 2022 navmv20 TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	errorMess   : String;
	str 		: String;
	count 		: Integer;
	agent		: CM_ExtractLoadAgent;
	bank		: CM_Bank;
	file		: File;
	invAllocTranMap : String; //09/06/2017 cnwma1 TFS #4498
	allocMapLinesCount : Integer; 
	contract 	: CM_InvoiceContract; //17/01/2023 navmv20 TFS 55650 TASK 55702
	allInvContracts : CM_InvoiceContractSet; //17/01/2023 navmv20 TFS 55650 TASK 55702
begin

	if _term &lt;&gt; null then
		app.myPassport.setMyTerminal(_term);
	endif;

	create agent transient;
	create file transient;
	file.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	bank := _bank;
	invAllocTranMap := _invAllocTranMap; //09/06/2017 cnwma1 TFS #4498;
	// extract
	if _action = "EXTRACT" then
		file.openOutput(_fileName);
		if _optionType = 1 then
			count := agent.extractDebtors(file);
		elseif _optionType = 2 then
			count := agent.extractCalculationTypes(file);
		elseif _optionType = 3 then
			count := agent.extractGLCodesForBank(file, bank);
		elseif _optionType = 4 then
			count := agent.extractServices(file, bank);
		elseif _optionType = 5 then
			count := agent.extractInvoiceTypes(file, bank);
		elseif _optionType = 6 then
			count := agent.extractInvoiceLineTypes(file, bank);
		elseif _optionType = 7 then  //19/06/2017 cnwma1 TFS #4498
			//count := agent.extractInvAllocTranMap(file,bank,invAllocTranMap.toUpper,allocMapLinesCount); //07/06/2017 cnwma1 TFS #4498	//-TFS 7659 don't force uppercase
			count := agent.extractInvAllocTranMap(file,bank,invAllocTranMap,allocMapLinesCount);	//TFS 7659
		elseif _optionType = 8 then  // TFS 5232
			count := agent.extractStorageConfiguration(file,_term); // TFS 5232
		elseif _optionType = 9 then  // 07 Dec 2018	NDL	TFS 42061
			count := agent.extractSurcharges(file,bank); 
		elseif _optionType = 10 then  // 11 Dec 2018	NDL	TFS 42061
			count := agent.extractServicePaymentTypes(file,bank);
		// ### TFS 54564 (54379) 31Aug2022 NAVPW1
		elseif _optionType = 11 then
			count := agent.extractInvoiceLineTranslation(file,bank);
		// ### TFS 54564 (54379) 31Aug2022 NAVPW1
		// ### TFS 54566 28Sep2022 NAVPW1
		elseif _optionType = 12 then
			count := agent.extractInvoiceLineMapping(file,bank);
		// ### TFS 54566 28Sep2022 NAVPW1
		//start - 17/01/2023 navmv20 TFS 55650 TASK 55701
		elseif _optionType = 13 then
			create allInvContracts transient;
			foreach contract in bank.allInvoiceContractsById do
				allInvContracts.add(contract);
			endforeach;
			count := agent.extractInvoiceContracts(file,bank,allInvContracts);
		//end - 17/01/2023 navmv20 TFS 55650 TASK 55701
		endif;
		if _optionType = 7 then
			str := " " &amp; CrLf &amp; count.String &amp; " " &amp; _option &amp; " extracted"  &amp; "  " &amp; " Total Lines extracted :" &amp; allocMapLinesCount.String &amp;CrLf;
		else
			str := " " &amp; CrLf &amp; count.String &amp; " " &amp; _option &amp; " extracted" &amp; CrLf;
		endif;
	// load
	elseif _action = "LOAD" then
		//START - 17/01/2023 navmv20 TFS 55650 TASK 55702
		file.fileName := _fileName;
		if (not file.isAvailable) then
			app.msgBox(app.getErrorString1(File_available, _fileName),app.getErrorString(VB_FILE_ERROR),MsgBox_OK_Only);
			return;
		endif;
		//END - 17/01/2023 navmv20 TFS 55650 TASK 55702
		file.openInput(_fileName);
		if _optionType = 1 then
			count := agent.loadDebtors(file);
		elseif _optionType = 2 then
			count := agent.loadCalculationTypes(file);
		elseif _optionType = 3 then
			count := agent.loadGLCodes(file, bank);
		elseif _optionType = 4 then
			count := agent.loadServices(file, bank);
		elseif _optionType = 5 then
			count := agent.loadInvoiceTypes(file, bank);
		elseif _optionType = 6 then
			count := agent.loadInvoiceLineTypes(file, bank);
		elseif _optionType = 7 then												 //19/06/2017 cnwma1 TFS #4498
			count := agent.loadInvAllocTranMap(file, bank,_invAllocTranMap);     //19/06/2017 cnwma1 TFS #4498
		elseif _optionType = 8 then	// TFS 5232											 
			count := agent.loadStorageConfig(file, _term);  	// TFS 5232
		elseif _optionType = 9 then  // 07 Dec 2018	NDL	TFS 42061
			count := agent.loadSurcharges(file,bank); 
			if count = 0 then
				str := app.myPassport.getAllErrorsWarningsAsString();
				if str &lt;&gt; null then
					writeOutputToMyForm( " " &amp; CrLf &amp; str  &amp; CrLf );
				endif;
			endif;
		elseif _optionType = 10 then  // 12 Dec 2018	NDL	TFS 42060
			count := agent.loadServicePaymentTypes(file,bank); 
			if count = 0 then
				str := app.myPassport.getAllErrorsWarningsAsString();
				if str &lt;&gt; null then
					writeOutputToMyForm( " " &amp; CrLf &amp; str  &amp; CrLf );
				endif;
			endif;
		// ### TFS 54564 (54379) 02Sep2022 NAVPW1
		elseif _optionType = 11 then
			count := agent.loadInvoiceLineTranslation(file, bank); 
			if count = 0 then
				str := app.myPassport.getAllErrorsWarningsAsString();
				if str &lt;&gt; null then
					writeOutputToMyForm( " " &amp; CrLf &amp; str  &amp; CrLf );
				endif;
			endif;
		// ### TFS 54564 (54379) 02Sep2022 NAVPW1
		// ### TFS 54566 07Oct2022 NAVPW1
		elseif _optionType = 12 then
			count := agent.loadInvoiceLineMapping(file,bank);
			if count = 0 then
				str := app.myPassport.getAllErrorsWarningsAsString();
				if str &lt;&gt; null then
					writeOutputToMyForm( " " &amp; CrLf &amp; str  &amp; CrLf );
				endif;
			endif;
		// ### TFS 54566 07Oct2022 NAVPW1
		//start - 17/01/2023 navmv20 TFS 55650 TASK 55702
		elseif _optionType = 13 then
			count := agent.loadContracts(file,bank,bank.terminal,XML_FORMAT);
			if count = 0 then
				str := app.myPassport.getAllErrorsWarningsAsString();
				if str &lt;&gt; null then
					writeOutputToMyForm( " " &amp; CrLf &amp; str  &amp; CrLf );
				endif;
			endif;
		//end - 17/01/2023 navmv20 TFS 55650 TASK 55702
		endif;
		str := " " &amp; CrLf &amp; count.String &amp; " " &amp; _option &amp; " loaded" &amp; CrLf;
	endif;

	writeOutputToMyForm(str);

epilog

	if errorMess &lt;&gt; null then
		writeOutputToMyForm(errorMess);
		writeOutputToMyForm(CrLf);
	endif;
	delete agent;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close;
		endif;
		delete file;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_action" type="String"/>
        <Parameter name="_optionType" type="Integer"/>
        <Parameter name="_option" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_invAllocTranMap" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFindDepartWagOnsiteCargo" id="4b77ad8d-1c72-48de-8b96-134e32cf3cf7">
        <source>doFindDepartWagOnsiteCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2013	cnwndl1	Initial creation	Par 33189

*/

vars

	param : String;
	list : Boolean;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		endif;
		if param = "LIST" then
			list := true;
		elseif param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not list and not update then
	
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 33189 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If a user deleted an incomplete rail receival job (to unload cargo from a wagon), and then departed the wagon without moving" &amp; CrLf;
		info := info &amp; "the cargo.  JMT would not have created the correct release transaction or moved the cargo off-site correctly.  This would potentially" &amp; CrLf;
		info := info &amp; "leave the cargo in a state where it was very difficult to deal with." &amp; CrLf; 
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This situation can no longer occur." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to find these cargo items, create the correct release transaction and correctly move the cargo" &amp; CrLf;
		info := info &amp; "from the onsite cargo collection." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The only processing options available for this method are list or update." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will find the effected cargo and list it" &amp; CrLf;
		info := info &amp; "UPDATE - Will find the effected cargo, generate the 'Rail Release' transaction, and move teh cargo from the on-site cargo collection." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindDepartWagOnsiteCargoWork( update );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindDepartWagOnsiteCargoWork" id="156c07dc-abde-4823-b41f-da46e00dabec">
        <source>doFindDepartWagOnsiteCargoWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2013	cnwndl1	Initial creation	Par 33189
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	str : String;
	iterTerm : Iterator;
	term : CM_Terminal;
	iterTi : Iterator;
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	wc : CM_WagonController;
	wagon : CM_Wagon;
	train : CM_Train;
	tsDeparted : TimeStamp;
	now : TimeStamp;

begin

	now := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);

	str := " " &amp; CrLf &amp; "Gathering data..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	create tiSet transient;

	iterTerm := CM_Terminal.instances.createIterator;
	while iterTerm.next( term ) do
	
		iterTi := term.allOnsiteTIsByIdCargoType.createIterator;
		while iterTi.next( ti ) do
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			if not ti.myPrimaryActualLocation.isWagon then
				continue;
			endif;
			wc := ti.myPrimaryActualLocation.CM_WagonController;
			wagon := wc.myWagon;
			if wagon = null then
				continue;
			endif;
			if wagon.isDeparted then
				tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
		delete iterTi;
		
	endwhile;
	
	iterTi := tiSet.createIterator;
	while iterTi.next( ti ) do
	
		tsDeparted := null;
		wc := ti.myPrimaryActualLocation.CM_WagonController;
		wagon := wc.myWagon;
		train := wagon.myTrainOutwards;
		if train &lt;&gt; null then
			tsDeparted := train.departureDT;
			if not tsDeparted.date.isValid then
				tsDeparted := train.scheduledDepartureDT;
			endif;
		endif;
		if not tsDeparted.date.isValid then
			tsDeparted := now;
		endif;
		term := ti.myTerminal;
		if term = null then
			term := ti.myTerminalArea.myTerminal;
		endif;
			
		if not _update then
			str := ti.id &amp; " (" &amp; term.code &amp; ") is on wagon " &amp; wagon.id &amp; " which departed " &amp; tsDeparted.asStringJMT &amp; CrLf;
			writeOutputToMyForm(str);
			
		else
			app.myPassport.setMyTerminal( term );
			
			str := ti.id &amp; " (" &amp; term.code &amp; ") was on marked as on-site on a departed wagon and has now had its release trx created and been removed from the on-site collection." &amp; CrLf;
			writeOutputToMyForm(str);
			

			beginTransaction;
			
			ti.setMyInTransitTerminalTo(null);
			//ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,   false, ti.totalQuantity, null,app.myPassport);		// TFS 2651
			ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,   false, ti.totalQuantity, null,null,null,null,app.myPassport);	// TFS 2651

			commitTransaction;
			
		endif;
	endwhile;

epilog

	delete iterTerm;
	delete iterTi;
	delete tiSet;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFindOnshipWithoutRelease" id="7802c318-6edb-43a7-ace7-968f3f1323e5">
        <source>doFindOnshipWithoutRelease();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2012	cnwndl1	Initial creation	Par 29034

*/

vars

	param : String;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		endif;
		if param = "LIST" then
			list := true;
		endif;
 	endif;
	
	if not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 29034 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "A generic change in late 2011 to the Move Controller meant that Teklogix initiated moves to Ship" &amp; CrLf;
		info := info &amp; "would not always create 'Ship Release', 'Storage' or 'Wharfage' transactions." &amp; CrLf;
		info := info &amp; "The problem has now been resolved." &amp; CrLf;
		info := info &amp; "This method is provided to enable cargo that did not have these transactions generated to be" &amp; CrLf;
		info := info &amp; "identified." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method will search all 'On Ship' cargo and identify any cargo that has a recieval trx, and is now on board ship without" &amp; CrLf;
		info := info &amp; "an appropriate release transaction." &amp; CrLf;
		info := info &amp; "The only processing option available for this method is list." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will search all 'On Ship' cargo items that have been received into the terminal, then exported" &amp; CrLf;
		info := info &amp; "       form this terminal, without having generated a 'Ship Release' transaction." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindOnshipWithoutReleaseWork();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindOnshipWithoutReleaseWork" id="941b5bef-c883-4113-b578-ed2c6561d8dd">
        <source>doFindOnshipWithoutReleaseWork() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Jan 2012	cnwndl1	Initial creation	Par 29034
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars

	objArray : ObjectArray;
	iter : Iterator;
	obj : Object;
	ti : CM_TrackedItem;
	noReleaseArray : CM_TIArray;
	today : Date;
	str : String;
	count : Integer;
	invalid : Boolean;

begin

	str := " " &amp; CrLf &amp; "Gathering data..." &amp; CrLf;
	writeOutputToMyForm(str);

	create objArray transient;
	create noReleaseArray transient;
	CM_TrackedItem.allInstances( objArray, 0, true );
	
	count := objArray.size;
	str := " " &amp; CrLf &amp; "Checking - " &amp; count.String &amp; " Cargo item(s) to check..." &amp; CrLf;
	writeOutputToMyForm(str);
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	iter := objArray.createIterator;
	while iter.next(obj) do
		invalid := false;
		ti := obj.CM_TrackedItem;
		count := count - 1;
		if count mod 100000 = 0 then
			if count &gt; 1 then
				str := "             - " &amp; count.String &amp; " Cargo item(s) still to check..." &amp; CrLf;
				writeOutputToMyForm(str);
				process.sleep(0);
			endif;
		endif;
		if ti.isOnShip then
			if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT then
				continue;
			endif;
			if ti.getTransRelease &lt;&gt; null then
				continue;
			endif;
			if ti.allTransactions.isEmpty then
				continue;
			endif;
			if ti.allTransactions.last.createdTime.Date + 365 &lt; today then
				continue;
			endif;
			if ti.findLastReceivalTrans = null then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			if ti.isRehandle then
				continue;
			endif;
			if invalid then
				continue;
			endif;
			noReleaseArray.add(ti);
		endif;
	endwhile;
	
	str := CrLf &amp; "'" &amp; noReleaseArray.size.String &amp; "' On Ship cargo items with no release transaction found." &amp; CrLf;
	writeOutputToMyForm(str);
	
	if noReleaseArray.isEmpty then
		return;
	endif;
	
	str := " " &amp; CrLf;
	writeOutputToMyForm(str);
		
	foreach ti in noReleaseArray do
		invalid := false;
		str := ti.id &amp; " - On voyage '" &amp; ti.voyageCode &amp; "', last transaction was " &amp; ti.allTransactions.last.createdTime.Date.String &amp; " - " &amp; ti.myTerminal.code &amp; CrLf;
		if invalid then
			continue;
		endif;
		writeOutputToMyForm(str);
	endforeach;
		
	return;
	
epilog
	delete iter;
	delete objArray;
	delete noReleaseArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFindReportWriterUsage" id="ac892931-5f5a-4f9a-9d3b-d8bb45a7770c">
        <source>doFindReportWriterUsage();

/*

niceName="Show Report Writer Usage"

Purpose:	To show the views and reports using a given feature (class and property/method names entered)

Parameters:			

Return Value:		


Date		Who		 Reason
Sep 2011	cnwnjre1 Par 28028 CCMS 1120 
*/

vars

	param1 : String;
	param2 : String;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param1 := self.parameterArray[1].trimBlanks;
		elseif self.parameterArray.size = 2 then
			param1 := self.parameterArray[1].trimBlanks;
			param2 := self.parameterArray[2].trimBlanks;
		endif;
 	endif;
	
	if param1 = null then
		info := "No recognised parameters entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This function reports on the usage in Report Writer views and reports of a give Jade feature." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "&lt;class name&gt;  will list any views using this class." &amp; CrLf;
		info := info &amp; "&lt;class name&gt; &lt;feature name&gt;  will list any views and reports using this feature." &amp; CrLf &amp; CrLf;
		info := info &amp; "The class name is a Jade class name such as CM_TrackedItem and" &amp; CrLf;
		info := info &amp; "the feature name is a Jade property or method name such as id or getDisplayTempForReports." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindReportWriterUsageWork( param1, param2 );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindReportWriterUsageWork" id="b36c37f6-c111-4dfd-a107-f59cb129f9ba">
        <source>doFindReportWriterUsageWork(_className : String; _featureName : String) protected;

vars
	invalid	: Boolean;
	rws	: Schema;
	root	: Object;
	allViews : MemberKeyDictionary;
	view	: Object;
	allTypes : MemberKeyDictionary;
	type	: Object;
	allFields : MemberKeyDictionary;
	feature	: Object;
	allUsages : ObjectSet;
	usage	: Object;
	report	: Object;
	reportNames : StringArray;
	reportName	: String;
	
begin
	on Exception do app.handleDeletedObject(exception, view, invalid);
	on Exception do app.handleDeletedObject(exception, type, invalid);
	on Exception do app.handleDeletedObject(exception, feature, invalid);
	on Exception do app.handleDeletedObject(exception, report, invalid);

	if _featureName &lt;&gt; null then
		writeLineOutputToMyForm("Class:  " &amp; _className &amp; " Feature:  " &amp; _featureName);
		writeLineOutputToMyForm("Report Writer view and report usage:");
	else
		writeLineOutputToMyForm("Class:  " &amp; _className);
		writeLineOutputToMyForm("Report Writer view usage:");
	endif;

	rws := rootSchema.getSchema("JadeReportWriterSchema");
	if rws = null then
		return;
	endif;
	root := rws.getClass("JRDRoot").firstInstance;
	if root = null then
		return;
	endif;
	
	create reportNames transient;
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	foreach view in allViews do
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		if invalid then
			invalid := false;
			continue;
		endif;
		type := allTypes.getAtKey(_className, null);
		if type = null then
			continue;
		endif;
		// if only class name is entered, just show the views using that class
		if _featureName = null then
			writeLineOutputToMyForm(CrLf &amp; "Reporting view:  " &amp; view.getPropertyValue("name").String);
			continue;
		endif;
		allFields := type.getPropertyValue("allReportingFields").MemberKeyDictionary;
		if invalid then
			invalid := false;
			continue;
		endif;
		feature := allFields.getAtKey(_featureName);
		if feature = null then
			continue;
		endif;
		writeLineOutputToMyForm(CrLf &amp; "Reporting view:  " &amp; view.getPropertyValue("name").String);
		allUsages := feature.getPropertyValue("allFeatureUsages").ObjectSet;
		if invalid then
			invalid := false;
			continue;
		endif;
		reportNames.clear;
		foreach usage in allUsages do
			report := usage.getPropertyValue("myReportEntity").Object;
			if report &lt;&gt; null then
				reportName := report.getPropertyValue("name").String;
				if invalid then
					invalid := false;
					continue;
				endif;
				// same feature can be used multiple times in report, show once only
				if not reportNames.includes(reportName) then
					writeLineOutputToMyForm("  Report:  " &amp; reportName);
					reportNames.add(reportName);
				endif;
			endif;
		endforeach;
	endforeach;
epilog
	delete reportNames;
end;
</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <Parameter name="_featureName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFindSemiQueuedCargo" id="5477b42c-1200-4cb3-86e0-7d13a23cd94d">
        <source>doFindSemiQueuedCargo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2012	cnwndl1	Initial creation	Par 30252

*/

vars

	param : String;
	list : Boolean;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		endif;
		if param = "LIST" then
			list := true;
		elseif param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not list and not update then
	
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 30252." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "When 'Crane Queues' ( or 'Work point Queues' ) are set up to 'Use Ship Lander App', then in previous releases" &amp; CrLf;
		info := info &amp; "of JMT, it was possible, to get cargo into a semi queued state where it was unable to be released." &amp; CrLf;
		info := info &amp; "This state occurred if cargo was planned to a position on a voyage, and was moved as far as the crane transfer area,"&amp; CrLf;
		info := info &amp; "(completing the move on the RTQ form), but then was NOT loaded to the ship, but instead was moved back to the yard." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The cargo that has experienced this process can be left partially queued." &amp; CrLf;
		info := info &amp; "This 'Semi queued' state is not directly visible to the users." &amp; CrLf;
		info := info &amp; "The issue manifests itself simply as an error '84790' when the user is attempting a subsequent queued move, even though" &amp; CrLf;
		info := info &amp; "there is no indication on the cargo, or in the RTQ form, that the cargo is actually queued, and no current way of 'un queueing' it." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The situation that causes this state can no longer occur. (JMT detects and rectifies this state before it occurs)" &amp; CrLf;
		info := info &amp; "However, there may be existing cargo already in a 'Semi queued' state within the system." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method finds any existing cargo in a 'Semi queued' state and lists/fixes it." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will search all cargo on site and list any that are in a 'Semi queued' state" &amp; CrLf;
		info := info &amp; "UPDATE - Will perform the same as 'LIST' but will also fix the 'Semi queued' state" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindSemiQueuedCargoWork( update );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindSemiQueuedCargoWork" id="63e26fd2-05cf-4b15-b448-125eb215770c">
        <source>doFindSemiQueuedCargoWork( _update : Boolean )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2012	cnwndl1	Initial creation	Par 30252
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	iterTerm : Iterator;
	term : CM_Terminal;
	iterTi : Iterator;
	ti : CM_TrackedItem;
	allEffectedTis : CM_TISet;
	str : String;

begin

//	find all onsite cargo
//	Check that the 'queues' in 'allQueues.size' matches the queues of any queued future moves.

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	writeOutputToMyForm(str);

	str := CrLf &amp; "Checking On site cargo... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);

	create allEffectedTis transient;
	iterTerm := app.myRoot.allTerminals.createIterator;
	
	while iterTerm.next( term ) do
		delete iterTi;
		iterTi := term.allOnsiteTIsByIdCargoType.createIterator;
		
		while iterTi.next( ti ) do
			if ti.allQueues.isEmpty then
				continue;
			endif;
			if ti.allQueuedFutureMoves.isEmpty then
				allEffectedTis.addNoDuplicates( ti, false );
			endif;
		endwhile;
	
	endwhile;
	
	if allEffectedTis.isEmpty then
		str := CrLf &amp; "No cargo found in a 'Semi queued' state." &amp; CrLf;
		writeOutputToMyForm(str);
		
	else
		str := CrLf &amp; allEffectedTis.size.String &amp; " cargo item(s) found in a 'Semi queued' state :" &amp; CrLf;
		writeOutputToMyForm(str);
		
		delete iterTi;
		iterTi := allEffectedTis.createIterator;
		while iterTi.next( ti ) do
			str := "    Cargo item '" &amp; ti.id &amp; "' in terminal '" &amp; ti.myTerminal.code; 
			if not _update then
				str := str &amp; "' is in a 'Semi queued' state." &amp; CrLf;
			else
				beginTransaction;
				ti.allQueues.clear;
				str := str &amp; "' was in a 'Semi queued' state, and has been repaired." &amp; CrLf;
				commitTransaction;
			endif;
			writeOutputToMyForm(str);
		endwhile;
	
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

epilog

	delete iterTerm;
	delete iterTi;
	delete allEffectedTis;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFindVesselsWithBadSlots" id="74a39c12-6618-4b84-863f-c16b860c445c">
        <source>doFindVesselsWithBadSlots();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2012	cnwndl1	Initial creation	Par 28640 / 09 Feb 2012
14 Feb 2012	NDL	Par 28975
25 Jul 2012	NDL	Par 30627

*/

vars

	param : String;
	list : Boolean;
	update : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		endif;
		if param = "LIST" then
			list := true;
		elseif param = "UPDATE" then
			update := true;
		endif;
 	endif;
	
	if not list and not update then
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Pars 28640, 28975, 30627 and 30779." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Historical issues (now resolved) have allowed inconsistant updating of forty foot 'back end' and 'front end' attributes" &amp; CrLf;
		info := info &amp; "on Vessels and/or Voyages within JMT." &amp; CrLf;
		info := info &amp; "When this occurred on a Vessel, all Voyages created or copied from that Vessel inherited the problem." &amp; CrLf;
		info := info &amp; "When it occurred on a Voyage, the Voyage planning form behaved incorrectly, allowing the planning of 40 foot containers to" &amp; CrLf;
		info := info &amp; "invalid slot combinations, and/or prohibiting the planning of 40's to valid locations." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is provided to identify 'Vessels' and current 'Voyages' that have slots with invalid combinations of '40 Foot' attributes." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Rules specifically tested in this fix:" &amp; CrLf;
		info := info &amp; "- That slots in the first bay in a hold can NOT have the 'Back end 40' attribute set." &amp; CrLf;
		info := info &amp; "- That slots in the last bay in a hold can NOT have the 'Front end 40' attribute set." &amp; CrLf;
		info := info &amp; "- That only slots in a centre bay of a triple bay hold may have  both the 'Front end 40' AND the 'Back end 40' attributes set together." &amp; CrLf;
		info := info &amp; "- That the slot immediately AFT of a slot marked as unavailable can NOT have its 'Back end 40' attribute set." &amp; CrLf;
		info := info &amp; "- That the slot immediately FWD of a slot marked as unavailable can NOT have its 'Front end 40' attribute set." &amp; CrLf;
		info := info &amp; "- That slots within a single bay hold can NOT have either the 'Back end 40' OR the 'Front end 40' attributes set." &amp; CrLf;
		info := info &amp; "- That each slot marked as 'available' that has a forward slot marked as a 'Front end 40' (and within the rules above) is marked as a 'Back end 40'." &amp; CrLf; //25 Jul 2012	NDL	Par 30627
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will search all 'Vessel' definitions and current (or future) 'Voyages' and list any that contain one or more slots with invalid 40" &amp; CrLf;
		info := info &amp; "         foot attributes" &amp; CrLf;
		info := info &amp; "UPDATE - Will perform the same as 'LIST' but will continue on and remove any forty foot attributes that are invalid according to the" &amp; CrLf;
		info := info &amp; "         rules above." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "It is recommended that having run this method in update mode that any Vessels and/or Voyages that are marked as having been" &amp; CrLf;
		info := info &amp; "repaired are checked manually." &amp; CrLf;
		
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindVesselsWithBadSlotsWork( update );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindVesselsWithBadSlotsWork" id="87a3e590-12ae-4d20-a809-49f7227cd93c">
        <source>doFindVesselsWithBadSlotsWork( _update : Boolean )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2012	cnwndl1	Initial creation	Par 28640 
14 Feb 2012	NDl	Par 28975
25 Jul 2012	NDL	Par 30627
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	slotDefnVessel : CM_SlotDefnVessel;
	iter : Iterator;
	vesselsWithIssues : CM_ObjectSet;
	vessel : CM_Vessel;
	obj : Object;
	obj2 : Object;
	bay : CM_Bay;
	str : String;
	
	bayVoyage : CM_BayVoyage;
	slotDefnVoy : CM_SlotDefnVoyage;
	voyage : CM_Voyage;
	voyagesWithIssues : CM_ObjectSet;
	breakVoyage : Boolean;
	
	term : CM_Terminal;
	currentVoyages : CM_VoyageSet;
	
	bayIter : Iterator;
	slotCont : CM_SlotController;

begin

	str := " " &amp; CrLf &amp; "Gathering Vessel data... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);
	
	create vesselsWithIssues transient;
	create voyagesWithIssues transient;
	create currentVoyages transient;
	
	// find all vessel definitions with issues.
	iter := CM_SlotDefnVessel.instances.createIterator;
	while iter.next( slotDefnVessel ) do
		bay := slotDefnVessel.myBay;
		if slotDefnVessel.fortyBack and slotDefnVessel.fortyFront then
			if bay.bayType = BAY_TYPE_TRIPLE then
				if bay.isFirstInHold() then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				elseif bay.isLastInHold() then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				endif;
			else
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			endif;
		 elseif slotDefnVessel.fortyBack then
			if bay.isFirstInHold() then
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			endif;
		elseif slotDefnVessel.fortyFront then
			if bay.isLastInHold() then
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			//24 Oct 2012	NDL	Par 30627
			else
				if slotDefnVessel.myAftSlot &lt;&gt; null and not slotDefnVessel.myAftSlot.unavailable and not slotDefnVessel.myAftSlot.fortyBack then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				endif;  
			endif;
		endif;
	endwhile;
	delete iter;
	
	if vesselsWithIssues.isEmpty then
		str := CrLf &amp; "No Vessels found with invalid 40 foot slot attributes. " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		writeOutputToMyForm(str);
	else
		str := CrLf;
		writeOutputToMyForm(str);
		foreach obj in vesselsWithIssues do
			str := "'Vessel '" &amp; obj.CM_Vessel.code &amp; "' has one or more 40 foot slots that have invalid attributes." &amp; CrLf;
			writeOutputToMyForm(str);
		endforeach;
	endif;

	
	
	str := " " &amp; CrLf &amp; "Finding current Voyages... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);
	
	// get a collection of the the current voyages first	
	foreach term in app.myRoot.allTerminals discreteLock do
		iter := term.allVoyagesNew.createIterator();
		while iter.next(voyage) do
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			if voyage.archived or voyage.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			if not currentVoyages.includes(voyage) then
				currentVoyages.add(voyage);
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	
	str := " " &amp; CrLf &amp; "Checking current Voyages... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);
	
	// iterate thru the current voyages finding those with bad slots
	foreach voyage in currentVoyages discreteLock do 
	
		if voyage.myCellularVoyageStructure = null then
			continue;
		endif;
		breakVoyage := false;
		foreach bayVoyage in voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do 
			iter := bayVoyage.allSlotControllersByOrdinal.createIterator;
			while iter.next( slotCont ) do
				slotDefnVoy := slotCont.mySlotDefnVoyage;
				if slotDefnVoy = null then
					continue;
				endif;
				if slotDefnVoy.fortyBack and slotDefnVoy.fortyFront then
					if bayVoyage.bayType = BAY_TYPE_TRIPLE then
						if bayVoyage.isFirstInHold() then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						elseif bayVoyage.isLastInHold() then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						endif;
					else
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					endif;
				 elseif slotDefnVoy.fortyBack then
					if bayVoyage.isFirstInHold() then
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					endif;
				elseif slotDefnVoy.fortyFront then
					if bayVoyage.isLastInHold() then
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					//24 Oct 2012	NDL	Par 30627
					else
						if slotDefnVoy.myAftSlot &lt;&gt; null and not slotDefnVoy.myAftSlot.unavailable and not slotDefnVoy.myAftSlot.fortyBack then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						endif; 
					endif;
				endif;
			endwhile;
			
			delete iter;
			if breakVoyage then
				break;
			endif;
			
		endforeach;
		
	endforeach; 
	
	if voyagesWithIssues.isEmpty then
		str := CrLf &amp; "No Voyages found with invalid 40 foot slot attributes. " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		writeOutputToMyForm(str);
	else
		str := CrLf;
		writeOutputToMyForm(str);
		foreach obj in voyagesWithIssues do
			str := "'Voyage '" &amp; obj.CM_Voyage.code &amp; "' has one or more 40 foot slots that have invalid attributes. (" &amp; obj.CM_Voyage.getMyTerminal.code &amp; ")" &amp; CrLf;
			writeOutputToMyForm(str);
		endforeach;
	
	endif;

	
	if _update then
		// so now we are going to fix the duds...
		if not vesselsWithIssues.isEmpty then
			str := " " &amp; CrLf &amp; "Repairing Vessel(s)... " &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			writeOutputToMyForm(str);
		endif;
	
		foreach obj in vesselsWithIssues discreteLock do
			vessel := obj.CM_Vessel;
			bayIter := vessel.myCellularVesselStructure.allBaysByOrdinal.createIterator;
			// have to process everything, and in order from the aft to fwd...
			while bayIter.back( bay ) do
				iter := bay.allSlotsByOrdinal.createIterator;
				while iter.next( slotDefnVessel ) do
					if slotDefnVessel.fortyBack or slotDefnVessel.fortyFront then
						beginTransaction;
						slotDefnVessel.setAsFortyFoot(true);
						commitTransaction;
					else
						beginTransaction;
						slotDefnVessel.setAsFortyFoot(false);
						commitTransaction;
					endif;
				endwhile;
				delete iter;
			endwhile;
			delete bayIter;
			str := "'Vessel '" &amp; obj.CM_Vessel.code &amp; "' has had its 40 foot slots attributes repaired." &amp; CrLf;
			writeOutputToMyForm(str);
			
		endforeach;
		
		
		if not voyagesWithIssues.isEmpty then
			str := " " &amp; CrLf &amp; "Repairing Voyage(s)..." &amp; app.actualTimeServer.asStringJMT &amp; CrLf;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			writeOutputToMyForm(str);
		endif;
		
		foreach obj in voyagesWithIssues discreteLock do
			voyage := obj.CM_Voyage;
			
			iter := voyage.allVoyageLocations.createIterator;
			// have to process everything, and in order from the aft to fwd...
			while iter.back( obj2 ) do
				if not obj2.isKindOf( CM_SlotController ) then
					continue;
				endif;
				slotCont := obj2.CM_SlotController;
				slotDefnVoy := slotCont.mySlotDefnVoyage;
				if slotDefnVoy.fortyBack or slotDefnVoy.fortyFront then
					beginTransaction;
					slotDefnVoy.setAsFortyFoot(true);
					commitTransaction;
				else
					beginTransaction;
					slotDefnVoy.setAsFortyFoot(false);
					commitTransaction;
				endif;		
			endwhile; 
			delete iter;
			
			str := "'Voyage '" &amp; obj.CM_Voyage.code &amp; "' has had its 40 foot slots attributes repaired. (" &amp; obj.CM_Voyage.getMyTerminal.code &amp; ")" &amp; CrLf;
			writeOutputToMyForm(str);
			
		endforeach; 
		
	endif;

epilog

	delete iter;
	delete vesselsWithIssues;
	delete voyagesWithIssues;
	delete bayIter;
	delete currentVoyages;

end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFindYADataPatterns" id="379912b0-a9c6-492b-acde-7f36b32b7279">
        <source>doFindYADataPatterns();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2016	cnwndl1	Initial creation	Par 37510

*/

vars

	param : String;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 37510 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "During 2008, a pattern matching feature was added to a small selection of the Yard Allocation Criteria." &amp; CrLf;
		info := info &amp; "The pattern matching was implemented to allow a value within a 'range' to be compared." &amp; CrLf;
		info := info &amp; "I.e. Weight of 20T - 30T, would match on any value between 20 and 30 Tonnes, not just exactly 20 or 30" &amp; CrLf;
		info := info &amp; "The presence of the '-' in the string '20T - 30T' is used to recognise that a pattern is present," &amp; CrLf;
		info := info &amp; "this causes a 'pattern' data object, instead of 'object set' data to be created for later evaluation." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "During 2009, the pattern feature was to be extended to include wild card checking. This is signified by the presence of a '!' or a '*'." &amp; CrLf;
		info := info &amp; "At the time provision was made to exclude a single occurrence of the 'null voyage' represented by '********', but no provisions was made for the null operator" &amp; CrLf;
		info := info &amp; "'****' or any other object name that uses the '*' or '!' characters, or for a comma delimted list of voyages including the null voyage" &amp; CrLf;
		info := info &amp; "The wildcard feature has not yet been progressed, but the check is still active." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Recently a user has created Yard Allocations for a list of operators including the 'null operator'. (represented by '****')" &amp; CrLf;
		info := info &amp; "The String that represents this collection was then incorrectly stored by JMT as 'pattern' style of allocation." &amp; CrLf;
		info := info &amp; "This situation can lead to a '1086' error during a yard allocation search, and may invalidate the operator check during auto planning" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "JMT 8.4.2.050 has code that now stores and uses these yard allocations correctly, but in order to correct the data, each of the Yard Allocations" &amp; CrLf;
		info := info &amp; "that has the potential to have been effected needs to be manually opened from the Yard Allocation Manager, and 'Saved'" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "To get a list of the Yard Allocations that need to be manually opened and Saved again, please run this supervisors method with the parameter set to 'LIST'" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list those Yard Allocations that have the potential to cause a 1086 error. They should be manually opened from" &amp; CrLf;
		info := info &amp; "      within the Yard Allocation Manager form, and 'Saved' again." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' is considered a valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFindYADataPatternsWork( list );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindYADataPatternsWork" id="77cb9850-0c72-4124-b859-0f777bc334bd">
        <source>doFindYADataPatternsWork( _list : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2016	cnwndl1	Initial creation	Par 37510

*/

vars

	str : String;
	iter : Iterator;
	yaDataPattern : CM_YADataPattern;
	pattern : CMIF_YAPattern;
	nameDict: ObjectLongNameDict;
	tokens: StringArray;
	yaParent : CM_YACriteriaPriority;
	yardAllocation : CM_YardAllocation;
	noMatchCount : Integer;
	matchCount : Integer;
	token :String;
	obj :Object;
	term : CM_Terminal;

begin

	str := "Processing in LIST mode :" &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create nameDict transient;
	create tokens transient;

	iter := CM_YADataPattern.instances.createIterator;
	while iter.next(yaDataPattern) do
		if not yaDataPattern.pattern.containsOneOf("*!") then
			continue;
		endif;
		if yaDataPattern.myCriteriaType = null then
			continue;
		endif;
		
		yaParent := yaDataPattern.myYAParent;
		if yaParent.isKindOf(CM_YACriteria) then
			yardAllocation := yaParent.CM_YACriteria.myYardAllocation;
			if yardAllocation = null then
				continue;
			endif;
			term := yardAllocation.myTerminal;
		endif;
		
		app.myPassport.setMyTerminal( term );
		
		delete pattern;
		create pattern transient;
		pattern.setPattern( yaDataPattern.pattern, CMIF_YAPattern.YAPattern_Wildcard );
		
		nameDict.clear();
		yaDataPattern.myCriteriaType.getObjects(nameDict);
		if nameDict.isEmpty then
			continue;
		endif;
		
		tokens.clear();
		pattern.getTokens(pattern.pattern, tokens);
		
		noMatchCount := 0;
		matchCount := 0;
		foreach token in tokens do
			if token.containsOneOf("*!") then
				obj := nameDict[token.toUpper()];
				if obj = null then
					noMatchCount := noMatchCount + 1;
				else
					matchCount := matchCount + 1;
				endif;
			endif;
		endforeach;
		
		//If we found at least one matching and 
		
		if matchCount &gt; 0  then
			str := "Yard Allocation '" &amp; yardAllocation.code &amp; "' in '" &amp; term.code &amp; "' needs opening and saving from 'Yard Allocation Manager form', it is created as a pattern and should be an object set." &amp; CrLf;
			writeOutputToMyForm(str);	
		endif;
	
	endwhile;
	
	writeOutputToMyForm(CrLf);
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);

epilog

	delete pattern;
	delete nameDict;
	delete tokens;

end;</source>
        <access>protected</access>
        <Parameter name="_list" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFixCashPaymentExtra" id="220c83a8-c94a-4b5c-894f-39457120bc33">
        <source>doFixCashPaymentExtra( _cr : CM_CashReceipt; _ti : CM_TrackedItem; _total : Decimal; _extraInvoice : CM_Invoice; _update : Boolean; _allCashProxies : ObjectArray input) protected;

/*

Purpose:			Create an extra cash payment for overpayment, has no associated invoice line

Parameters:			

Return Value:		


Date		Who		Reason
12/01/2015	cnwjre1	Initial creation	Par 35443 and 35464/35373
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	cr				: CM_CashReceipt;
	ti				: CM_TrackedItem;
	extraInvoice	: CM_Invoice;
	pxyCashPayment  : CM_CashPayment;
	now				: TimeStamp;

begin

	cr := _cr;
	ti := _ti;
	now := ti.releasedDT;
	extraInvoice := _extraInvoice;
		
	create pxyCashPayment transient;
			
	pxyCashPayment.setProxy(_total,							//_cashValue : Decimal;
							0,								//_taxAmount : Decimal;
							now,							//_dateTime : TimeStamp;
							null,							//_proformaDesc : String;
							false,							//_manual : Boolean;
							0,								//_status : Integer;
							false,							//_voided : Boolean;	
							cr.myDebtorTerminal,			//_myDebtorTerminal : CM_DebtorTerminal;
							ti,								//_myTrackedItem : CM_TrackedItem;
							extraInvoice,					//_myInvoice : CM_Invoice;
							ti.getVehicleVisitRelease(),	//_vvr : CM_VehicleVisitRecord;
							cr.myUser						//_myUser : CM_User;
							);

	pxyCashPayment.setCashReceipt(cr);
	app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
	_allCashProxies.add(pxyCashPayment);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cr" type="CM_CashReceipt"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="_extraInvoice" type="CM_Invoice"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_allCashProxies" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFixCashPaymentProfDetail" id="e42193d9-dce3-4823-8299-e23e384b5be2">
        <source>doFixCashPaymentProfDetail(	_ti : CM_TrackedItem) protected;
/*

Purpose:		Update the cash payments from cargo release, converting pro forma payments into one or more real ones.
				Based in CM_UtilityUpdateAgent::utlUpdateCashPaymentFromTI to repeat this processing for released
				cargo still with pro forma payments, but back-dating the payments to the cargo release date.

Parameters:			

Return Value:		


Date		Who		Reason
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed

*/

vars
	debtorTerminal 		: CM_DebtorTerminal;
	vvr 				: CM_VehicleVisitRecord;	
	cashInvoice			: CM_Invoice;
	cashReceipt			: CM_CashReceipt;
	cashPayment			: CM_CashPayment;
	invoice 			: CM_Invoice;
	lastLine			: CM_InvoiceLine;
	invLine 			: CM_InvoiceLine;
	terminal 			: CM_Terminal;
	allInvoices 		: CM_InvoiceSet;
	oldInvoices			: CM_InvoiceSet;
	pxyCashPayment 		: CM_CashPayment;
	proformaPayments	: CM_CashPaymentSet;
	allCashProxies		: ObjectArray;
	allInvLines 		: CM_InvoiceLineSet;
	proformaTotal,
	invCashCharge,
	
	invCashPayment,
	totalToAllocate,
	totalAllocated,
	paidCharges			: Decimal[23,6]; //21.10.2019 cnwma1 TFS #47081
	receiptId			: String;
	str					: String;
	user				: CM_User;
	now					: TimeStamp;
	extraUser			: CM_User;
	extraDebtorTerminal	: CM_DebtorTerminal;
	extraInvoice		: CM_Invoice;
	extraReceipt		: CM_CashReceipt;
begin
	terminal:=_ti.myTerminal;
	
	now := _ti.releasedDT;
	
	create allInvoices transient;
	create allInvLines transient;
	create proformaPayments transient;

	foreach invLine in _ti.invoiceLines where invLine.debtor.isCashOnlyDebtor(terminal) do
		if invLine.voided then
			continue;
		endif;
		
		if debtorTerminal = null then
			debtorTerminal:= terminal.allDebtorTerminals[invLine.debtor];
		endif;
		allInvLines.addNoDuplicates(invLine,false);
		invoice := invLine.invoice;
		if invoice &lt;&gt; null then
			allInvoices.addNoDuplicates(invoice,false);
		endif;
	endforeach;

				
	// move new charges since payment into the cash receipt invoice if any
	foreach invoice in allInvoices do
		cashReceipt := invoice.getCashReceipt();
		if cashReceipt &lt;&gt; null then
			cashInvoice := invoice;
			break;
		endif;
	endforeach;
	if cashInvoice &lt;&gt; null then
		create oldInvoices transient;
		foreach invLine in allInvLines where invLine.invoice &lt;&gt; cashInvoice do
			if not oldInvoices.includes(invLine.invoice) then
				oldInvoices.add(invLine.invoice);
			endif;
			invLine.moveLineToInvoice(cashInvoice);
			if not cashReceipt.allInvoiceLines.includes(invLine) then
				cashReceipt.allInvoiceLines.add(invLine);
			endif;
		endforeach;
		foreach invoice in oldInvoices do
			allInvoices.remove(invoice);
		endforeach;
	endif;

	// safety check - if no cashInvoice use the last invoice
	if cashInvoice = null then
		cashInvoice := allInvoices.last;
	endif;

	if cashReceipt &lt;&gt; null then
		foreach invLine in allInvLines do
			if not cashReceipt.allInvoiceLines.includes(invLine) then
				cashReceipt.allInvoiceLines.add(invLine);
			endif;
		endforeach;
	endif;
		
	cashReceipt := null;
	create allCashProxies transient;
	// update the payments with the vehicle visit record
	// and convert proforma payments to regular
	foreach cashPayment in _ti.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		if cashPayment.voided then
			continue;
		endif;
		if cashPayment.isProformaPayment then
			// proforma, add the total paid to use below
			proformaTotal := proformaTotal + cashPayment.cashValue;
			proformaPayments.add(cashPayment);
			extraDebtorTerminal := cashPayment.myDebtorTerminal;
			extraReceipt := cashPayment.myCashReceipt;
			if extraInvoice = null then
				if extraReceipt &lt;&gt; null then
					extraInvoice := extraReceipt.myCashInvoice;
				endif;
			endif;
			extraUser := cashPayment.myUser;
		else
			// non-proforma, update carrier, driver etc - update it directly
			cashPayment.setVehicleVisitRecord(vvr);
		endif;								
	endforeach;
	
	// use the proforma total to pay the remaining unpaid invoice lines
	if proformaTotal &lt;&gt; 0 then
		foreach lastLine in allInvLines do
		endforeach;

		foreach cashPayment in proformaPayments do
				cashReceipt := cashPayment.myCashReceipt;
				user := cashPayment.myUser;
				if debtorTerminal = null then
					debtorTerminal := cashPayment.myDebtorTerminal;
				endif;
				// proforma, add the total paid to use below
				proformaTotal := cashPayment.cashValue;
				totalToAllocate := proformaTotal;
				foreach invLine in allInvLines do
					invCashCharge := invLine.lineTotal;
					paidCharges := 0;
					foreach cashPayment in invLine.allCashPayments do
						if cashPayment.voided then
							continue;
						endif;
						paidCharges := paidCharges + cashPayment.cashValue;
					endforeach;
					if invCashCharge &gt; 0 then
						if invCashCharge &gt; paidCharges then
							invCashPayment := invCashCharge - paidCharges;
						else
							invCashPayment := 0;
							continue;		// nothing to pay
						endif;
						
						if invCashPayment &gt; totalToAllocate then
							invCashPayment := totalToAllocate;
						endif;

						totalToAllocate := totalToAllocate - invCashPayment;
						if invCashPayment &gt; 0 then
							if cashReceipt.externalInvoiceNumber &lt;&gt; null then
								receiptId := cashReceipt.externalInvoiceNumber;
							else
								receiptId := cashReceipt.myTerminal.code &amp; " " &amp; cashReceipt.String;
							endif;
							str := "New payment from pro forma " &amp; invCashPayment.String &amp; " receipt " &amp; receiptId &amp; " " &amp; _ti.id &amp; " invoice line " &amp; invLine.sequenceNum.String &amp; " " &amp; invLine.invoiceLineDesc.narration;
							self.writeOutputToMyForm(str &amp; CrLf);
							create pxyCashPayment transient;

							totalAllocated := totalAllocated + invCashPayment;
			
							pxyCashPayment.setProxy(invCashPayment,		//_cashValue : Decimal;
												0,						//_taxAmount : Decimal;
												now,					//_dateTime : TimeStamp;
												null,					//_proformaDesc : String;
												false,					//_manual : Boolean;
												0,						//_status : Integer;
												false,					//_voided : Boolean;	
												debtorTerminal,			//_myDebtorTerminal : CM_DebtorTerminal;
												_ti,					//_myTrackedItem : CM_TrackedItem;
												invLine.invoice,		//_myInvoice : CM_Invoice;
												vvr,					//_vvr : CM_VehicleVisitRecord;
												user					//_myUser : CM_User;
												);
							pxyCashPayment.setInvoiceLine(invLine);
							pxyCashPayment.setCashReceipt(cashReceipt);
							app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
							allCashProxies.add(pxyCashPayment);
						endif;
					endif;
					if totalToAllocate &lt;= 0 then
						break;
					endif;
				endforeach;
		endforeach;
		// write any overpayments to a separate cash payment with no invoice line
		if totalToAllocate &gt; 0 then
			if extraReceipt.externalInvoiceNumber &lt;&gt; null then
				receiptId := extraReceipt.externalInvoiceNumber;
			else
				receiptId := extraReceipt.myTerminal.code &amp; " " &amp; extraReceipt.String;
			endif;
			str := "New payment from pro forma excess " &amp; totalToAllocate.String &amp; " receipt " &amp; receiptId &amp; " " &amp; _ti.id;
			if invoice &lt;&gt; null then
				str := str &amp; " invoice " &amp; extraInvoice.sequenceNum.String;
			endif;
			self.writeOutputToMyForm(str &amp; CrLf);

			create pxyCashPayment transient;
			
			pxyCashPayment.setProxy(totalToAllocate,	//_cashValue : Decimal;
								0,						//_taxAmount : Decimal;
								now,					//_dateTime : TimeStamp;
								null,					//_proformaDesc : String;
								false,					//_manual : Boolean;
								0,						//_status : Integer;
								false,					//_voided : Boolean;	
								extraDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
								_ti,					//_myTrackedItem : CM_TrackedItem;
								extraInvoice,			//_myInvoice : CM_Invoice;
								vvr,					//_vvr : CM_VehicleVisitRecord;
								extraUser				//_myUser : CM_User;
								);

			pxyCashPayment.setCashReceipt(extraReceipt);
			app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
			allCashProxies.add(pxyCashPayment);
		endif;
	endif;
	
	_ti.checkProformaCashPayments();
	
epilog
	delete allInvoices;
	delete oldInvoices;
	delete allInvLines;
	delete proformaPayments;
	if allCashProxies &lt;&gt; null then
		allCashProxies.purge;
		delete allCashProxies;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doFixCashPayments" id="b43eafd0-04c5-4f3b-bd74-57afde27535c">
        <source>doFixCashPayments();

/*

niceName="Fix up cash payments"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/01/2015	cnwjre1	Initial creation	Par 35443 and 35464/35373

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Pars 35443, 35464 and 35373 only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Some cash receipts for released cargo have missed payments for some release charges such as storage" &amp; CrLf;
		info := info &amp; "and reefer daily charges." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Other cash receipts for released cargo still have pro forma payments which have not been applied" &amp; CrLf;
		info := info &amp; "to the release charges." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to recreate these missing payments and process any outstanding pro forma payments." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will simply report what the missing payments would be." &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will create and list the missing payments." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list the missing payment details." &amp; CrLf;
		info := info &amp; "UPDATE - will create and list the missing payments." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFixCashPaymentsWork( update );

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doFixCashPaymentsDetail" id="9b8ffc62-e2d3-475a-9feb-f35bd3af884c">
        <source>doFixCashPaymentsDetail( _cr : CM_CashReceipt; _ti : CM_TrackedItem; _total : Decimal; _isProforma : Boolean; _extraInvoice : CM_Invoice; _update : Boolean; _allCashProxies : ObjectArray input ) : Decimal protected;

/*

Purpose:			The under-paid update of doFixCashPaymentsDetail for each cargo item

Parameters:			

Return Value:		


Date		Who		Reason
12/01/2015	cnwjre1	Initial creation	Par 35443 and 35464/35373

*/

vars

	cr				: CM_CashReceipt;
	cp				: CM_CashPayment;
	ti				: CM_TrackedItem;
	il				: CM_InvoiceLine;
	vvr				: CM_VehicleVisitRecord;
	term			: CM_Terminal;
	pxyCashPayment 	: CM_CashPayment;
	toPay,
	toAllocate,
	cashTotal		: Decimal[23, 6];	//21.10.2019 cnwma1 TFS #47081
	now	: TimeStamp;
	str : String;

begin

	cr   := _cr;
	ti   := _ti;
	vvr  := ti.getVehicleVisitRelease();
	now  := ti.releasedDT;
	term := cr.myTerminal;
	
	toAllocate := _total;
	// update existing payment carrier etc
	if _update then
		foreach cp in ti.allCashPayments do
			if cp.isTaxPayment &lt;&gt; null then // TFS 7357 tax payment ignore
				continue; 					// TFS 7357
			endif; 							// TFS 7357
			if not cp.isProformaPayment then
				cp.setVehicleVisitRecord(vvr);
			endif;
		endforeach;
	endif;

	// TFS 1990 24/05/2016 get the invoice lines from the tracked item not transactions to get those copied from split/merged items
	///foreach trx in ti.allTransactions where trx.isCharged do
		///foreach il in trx.allInvoiceLines where il.debtor.isCashOnlyDebtor(term) do
	foreach il in ti.invoiceLines where il.debtor.isCashOnlyDebtor(term) do
		if il.voided then
			continue;
		endif;
		cashTotal := 0;
		foreach cp in il.allCashPayments do
			if cp.voided then
				continue;
			endif;
			cashTotal := cashTotal + cp.cashValue;
		endforeach;
		toPay := il.lineTotal - cashTotal;
		if toPay &gt; 0  and toPay &gt; toAllocate then
			toPay := toAllocate;
		endif;
		if toPay &gt; 0 then
			str := "   New payment " &amp; toPay.String &amp; " " &amp; ti.id &amp; " invoice line " &amp; il.sequenceNum.String &amp; " " &amp; il.invoiceLineDesc.narration;
			writeOutputToMyForm(str &amp; CrLf);

			create pxyCashPayment transient;
			pxyCashPayment.setProxy(toPay,					//_cashValue : Decimal;
									0,						//_taxAmount : Decimal;
									now,					//_dateTime : TimeStamp;
									null,					//_proformaDesc : String;
									false,					//_manual : Boolean;
									0,						//_status : Integer;
									false,					//_voided : Boolean;	
									cr.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
									ti,						//_myTrackedItem : CM_TrackedItem;
									il.invoice,				//_myInvoice : CM_Invoice;
									vvr,					//_vvr : CM_VehicleVisitRecord;
									cr.myUser				//_myUser : CM_User;
									);
			pxyCashPayment.setInvoiceLine(il);
			pxyCashPayment.setCashReceipt(cr);
			app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
			_allCashProxies.add(pxyCashPayment);

			toAllocate := toAllocate - toPay;
			if toAllocate = 0 then
				break;
			endif;
		endif;
		if toAllocate = 0 then
			break;
		endif;
	endforeach;

	ti.checkProformaCashPayments();
	
	return toAllocate;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cr" type="CM_CashReceipt"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="_isProforma" type="Boolean"/>
        <Parameter name="_extraInvoice" type="CM_Invoice"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_allCashProxies" type="ObjectArray" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doFixCashPaymentsProForma" id="205d9632-3aee-4793-8d17-761779c250c7">
        <source>doFixCashPaymentsProForma( _allTIs : CM_ObjectSetActual; _update : Boolean; _allCashProxies : ObjectArray input ) protected;

/*

Purpose:			Apply existing pro forma payments to released cargo
					
Parameters:			

Return Value:		


Date		Who		Reason
12/01/2015	cnwjre1	Initial creation	Par 35443 and 35464/35373

*/

vars

	obj	: CM_Object;
	ti	: CM_TrackedItem;

begin

	foreach obj in _allTIs do
		ti := obj.CM_TrackedItem;
		self.doFixCashPaymentProfDetail(ti);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allTIs" type="CM_ObjectSetActual"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_allCashProxies" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFixCashPaymentsWork" id="d603a091-8f59-4766-8c3f-78c7e234541a">
        <source>doFixCashPaymentsWork( _update : Boolean ) protected;

/*

Purpose:			NEW Version - do proformas first then under-paid

Parameters:			

Return Value:		


Date		Who		Reason
12/01/2015	cnwjre1	Initial creation	Par 35443 and 35464/35373

*/

vars

	cr	: CM_CashReceipt;
	cp	: CM_CashPayment;
	extraInvoice	: CM_Invoice;
	ti	: CM_TrackedItem;
	term	: CM_Terminal;
	allCashProxies	: ObjectArray;
	allTIs		: CM_ObjectSetActual;
	receiptTotal,
	paymentTotal	: Decimal[16, 6];
	proformaTotal,
	toAllocate,
	balance		: Decimal[16, 6];
	tiCount,
	offsiteCount	: Integer;
	receiptId		: String;
	str : String;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	// do both LIST and UPDATE in transaction state to create the new payments get the reporting correct but abort for LIST
	beginTransaction;
	create allCashProxies transient;
	create allTIs transient;

	// pass 1 for offsite cargo still with pro forma payments
	foreach cr in CM_CashReceipt.instances do
		foreach ti in cr.allTrackedItems do
			// protect against crap data in development
			if not global.isValidObject(ti) then
				continue;
			endif;
			if ti.isOffSite then
				foreach cp in ti.allCashPayments do
					if cp.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
						continue; // TFS 7357
					endif; // TFS 7357
					if cp.isProformaPayment and not cp.voided then
						if not allTIs.includes(ti) then
							allTIs.add(ti);
							break;
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;
	
	self.doFixCashPaymentsProForma( allTIs, _update, allCashProxies);
	
	// pass 2 for offsite cargo with under-payments
	foreach cr in CM_CashReceipt.instances do
		receiptTotal := cr.cashValue;
		paymentTotal := 0;
		proformaTotal := 0;
		foreach cp in cr.allCashPayments do
			if cp.voided then
				continue;
			endif;
			paymentTotal := paymentTotal + cp.cashValue;
			if cp.isProformaPayment then
				proformaTotal := proformaTotal + cp.cashValue;
			endif;
		endforeach;
		tiCount := 0;
		offsiteCount := 0;
		foreach ti in cr.allTrackedItems do
			// protect against crap data in development
			if not global.isValidObject(ti) then
				continue;
			endif;
			tiCount := tiCount + 1;
			if ti.isOffSite then
				offsiteCount := offsiteCount + 1;
			endif;
		endforeach;
		if offsiteCount = 0 then
			continue;
		endif;
	
		// has offsite cargo and unpaid invoice lines, pro forma processing has been done
		if receiptTotal.roundedTo(2) &gt; paymentTotal.roundedTo(2) then
			if cr.externalInvoiceNumber &lt;&gt; null then
				receiptId := cr.externalInvoiceNumber;
			else
				receiptId := cr.myTerminal.code &amp; " " &amp; cr.String;
			endif;
			str := "Found unpaid  " &amp; receiptId &amp; " receipt " &amp; receiptTotal.String &amp; " payments " &amp; paymentTotal.String &amp;
					" pro forma payment " &amp; proformaTotal.String &amp; " items " &amp; tiCount.String &amp; " offsite " &amp; offsiteCount.String &amp; ".";
			writeOutputToMyForm(str &amp; CrLf);

			toAllocate := receiptTotal - paymentTotal;
			term := cr.myTerminal;
			ti := null;
			foreach ti in cr.allTrackedItems do
				if not global.isValidObject(ti) then
					continue;
				endif;
				if ti.isOnSite then
					continue;
				endif;
				balance := self.doFixCashPaymentsDetail(cr, ti, toAllocate, false, null, _update, allCashProxies);
				toAllocate := balance;
			endforeach;

			// allocate any remaining payment to the last cargo item, no invoice line
			if ti &lt;&gt; null and toAllocate &gt; 0 then
				str := "   New payment " &amp; toAllocate.String &amp; " " &amp; ti.id;
				extraInvoice := null;
				foreach cp in ti.allCashPayments do
					if extraInvoice = null then
						if cp.myCashReceipt &lt;&gt; null then
							extraInvoice := cp.myCashReceipt.myCashInvoice;
						endif;
					endif;
				endforeach;
				if extraInvoice &lt;&gt; null then
					str := str &amp; " invoice " &amp; extraInvoice.sequenceNum.String;
				endif;
				writeOutputToMyForm(str &amp; CrLf);

				self.doFixCashPaymentExtra( cr, ti, toAllocate, extraInvoice, _update, allCashProxies);
			endif;
				
		endif;

	endforeach;
	
	if _update then
		commitTransaction;
	else
		abortTransaction;
	endif;

	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog
	if allCashProxies &lt;&gt; null then
		allCashProxies.purge;
		delete allCashProxies;
	endif;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFixSplitInvoiceLines" id="b67457ca-5916-4d16-99e6-5ee9bfd28254">
        <source>doFixSplitInvoiceLines();

/*

niceName="Fix up split invoice lines"

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/07/2016	cnwjre1	Initial creation	TFS 2379

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "The 8.4.2.090 release inadvertantly introduced a change where weight-based and volume-based charges for transactions " &amp; CrLf;
		info := info &amp; "could have additional invoice lines created from each subsequent cargo split and merge activity." &amp; CrLf;
		info := info &amp; "These lines had the quantity and value scaled by the percentage that the cargo was split or merged." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This applied to bulk and break-bulk cargo only." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method provides the ability to list the transactions with the extra invoice lines, and to correct them." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "If 'Run' in list mode this method will list the transactions that have extra invoice lines." &amp; CrLf;
		info := info &amp; "If 'Run' in update mode this method will remove the extra lines and recreate the original invoice lines for each affected transaction." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - will list transactions with extra split invoice lines." &amp; CrLf;
		info := info &amp; "UPDATE - will list the transactions, remove the extra split invoice lines and create new invoice lines." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only the 'LIST' or 'UPDATE' are considered valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doFixSplitInvoiceLinesWork( update );

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doFixSplitInvoiceLinesWork" id="63c86948-bd31-487e-ae63-ee776d9bd4d7">
        <source>doFixSplitInvoiceLinesWork( _update : Boolean ) protected;

/*

Purpose:			Fix stuff up

Parameters:			

Return Value:		


Date		Who		Reason
21/07/2016	cnwjre1	Initial creation	TFS 2379

*/
constants
	Max_Trans_Time = 2;		// 2 seconds per delete transaction
vars
	nextCommitTS	: TimeStamp;
	startDate		: Date;
	total			: Real;
	str				: String;
	invLine			: CM_InvoiceLine;
	invLineDesc		: CM_InvoiceLineDesc;
	tiTrans			: CM_TITransaction;
	tiArray			: CM_TransactionArray;
	controller		: CMIF_TiTransactionResync;
	passport 		: CM_Passport;

begin

	if not _update then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	self.writeOutputToMyForm(str);
	self.writeOutputToMyForm(CrLf);

	if _update then
		// show existing results as before
		str := "Before updating:" &amp; CrLf;
		self.writeOutputToMyForm(str);
	endif;

	// set this just before the earliest date that 8.4.2.090 could have been used (was released 04/07)
	startDate := "03/07/2016".Date;
	create tiArray transient;
	
	// do all terminals at once
	foreach invLineDesc in CM_InvoiceLineDesc.instances do
		if invLineDesc.isWeightBased or
		   invLineDesc.isVolumeBased then
			// invoice lines is a dictionary on sequence so the latest are at the end
			foreach invLine in invLineDesc.invoiceLines reversed do
				if invLine.createdTime.date &lt; startDate then
					break;
				endif;
				// the lines created have both .manual and .myTransactionTI set, and only lines from the affected code do
				if invLine.manual and
				   invLine.myTransactionTI &lt;&gt; null then
					if not tiArray.includes(invLine.myTransactionTI) then
						tiArray.add(invLine.myTransactionTI);
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
	
	foreach tiTrans in tiArray do
		str := "Terminal " &amp; tiTrans.myTerminal.code &amp; " transaction '" &amp; tiTrans.typeString &amp; "' dated " &amp; tiTrans.dateTime.asStringJMT &amp; 
				" for cargo " &amp; tiTrans.myTrackedItem.id &amp; " " &amp; tiTrans.myTrackedItem.cargoTypeDescr &amp; " has " &amp; tiTrans.allInvoiceLines.size.String &amp; " invoice lines" &amp; CrLf;
		self.writeOutputToMyForm(str);
	endforeach;
	if tiArray.isEmpty then
		self.writeOutputToMyForm(CrLf &amp; "NO invoice lines needing fixing were found." &amp; CrLf);
	endif;
	
	if _update then
		create controller transient;
		create passport;
		foreach tiTrans in tiArray do
			// delete the manual lines and then recreate the original invoice line by resync
			//  do a timed delete - there can be tens of thousands of spare invoice lines here
			beginTransaction;
			nextCommitTS := app.actualTimeServer.addSeconds(Max_Trans_Time);
			foreach invLine in tiTrans.allInvoiceLines do
				if app.actualTimeServer &gt; nextCommitTS then
					commitTransaction;
					nextCommitTS := app.actualTimeServer.addSeconds(Max_Trans_Time);
					beginTransaction;
				endif;
				if invLine.manual and
				   invLine.myTransactionTI &lt;&gt; null then
					delete invLine;
				endif;
			endforeach;
			commitTransaction;
				
			passport.setMyTerminal(tiTrans.myTerminal);
			controller.myTrackedItem := tiTrans.myTrackedItem;
			controller.force := true;
			controller.allTransactions.clear();
			controller.allTransactions.add(tiTrans);
			app.myTrxUA.trxUpdateRsyncTrans(controller, passport);
		endforeach;
		
		// show the new results
		str := CrLf &amp; CrLf &amp; "Results after updating:" &amp; CrLf;
		self.writeOutputToMyForm(str);
		foreach tiTrans in tiArray do
			total := 0;
			foreach invLine in tiTrans.allInvoiceLines do
				total := total + invLine.lineTotal;
			endforeach;
			str := "Terminal " &amp; tiTrans.myTerminal.code &amp; " transaction '" &amp; tiTrans.typeString &amp; "' dated " &amp; tiTrans.dateTime.asStringJMT &amp; 
					" for cargo " &amp; tiTrans.myTrackedItem.id &amp; " " &amp; tiTrans.myTrackedItem.cargoTypeDescr &amp; " has " &amp; tiTrans.allInvoiceLines.size.String &amp;
					" invoice line(s) value=" &amp; total.roundedTo(2).asStringJMT &amp; CrLf;
			self.writeOutputToMyForm(str);
		endforeach;
	endif;

	str := CrLf &amp; "Processing completed normally.";
	self.writeOutputToMyForm(str);
	
epilog
	delete tiArray;
	delete controller;
	delete passport;
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFixVoyagePortRotations" id="945e7359-9411-479e-bd4b-b2d83450a5b2">
        <updating/>
        <source>doFixVoyagePortRotations() updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2017 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// FOR SCT ITALY TFS 4353
// ---------------------------------------------------------------------------

vars


	param :String;
	param2 :String;

	update : Boolean;
	
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
			endif;
		endif;
 	endif;

	
	if not update then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "UPDATE - will fix links between all voyages and their port rotations." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doFixVoyagePortRotationsWork();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFixVoyagePortRotationsWork" id="ac92bf89-4733-48f3-9762-c2e4e083ebaa">
        <source>doFixVoyagePortRotationsWork() protected;
// ---------------------------------------------------------------------------
// Created:     17 May 2017 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//  TFS 4353
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
	root : CM_Root;
	term : CM_Terminal;
	
	port : CM_Port;
	portRot, protation : CM_PortRotation;
begin

	root := CM_Root.firstInstance();
	
	foreach term in root.allTerminals  discreteLock do
		foreach voy in term.allVoyagesByCode  discreteLock do
			beginTransaction;
			voy.allPorts.rebuild();
			
			if voy.allPorts.isEmpty then
				if voy.myTrade &lt;&gt; null then
				
					self.writeOutputToMyForm("Fixing Voyage '" &amp; voy.code &amp; "' Port Rotations" &amp; CrLf);

					foreach portRot in voy.myTrade.allPortRotations do
						port := portRot.myPort;
							
						if port &lt;&gt; null then
							voy.allPorts.add(port);
							
							create protation;
							protation.setPropertyValue("myPort", port);
							protation.setPropertyValue("myVoyage", voy);
						endif;
					endforeach;
					
				endif;
			endif;
			
			commitTransaction;
 
		endforeach;
	
	
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doForceDataExtract" id="cf8be59d-7c19-4039-a344-c65ade07bfc7">
        <source>doForceDataExtract();

/*

Purpose:	Update the edition of cargo so that it is re extracted by data extract		

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2011	cnwdw1	Initial creation	Par 28892

*/

vars

	param, param2 : String;
	update : Boolean;
	list : Boolean;
	count : Boolean;
	info : String;
	startDate: Date;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;			
		endif;
		
		startDate.setDate(0,0,0);
		if param2.length = 8 then
			startDate.setDate(param2[1:2].Integer, param2[3:2].Integer, param2[5:4].Integer);
		endif;

		if param = "UPDATE" then
			update := true;
		elseif param = "LIST" then
			list := true;
		elseif param = "COUNT" then
			count := true;
		endif;
 	endif;
	
	if not startDate.isValid or (not update and not list and not count) then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This special method will update the edition of all the cargo created on or after the date entered." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This will result the cargo being re-extracted by Data Extract." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "COUNT &lt;DDMMYYY&gt; - Find the affected cargo and advise how many there are that could be fixed." &amp; CrLf;
		info := info &amp; "LIST &lt;DDMMYYY&gt; - Find and list ALL affected cargo." &amp; CrLf;
		info := info &amp; "UPDATE &lt;DDMMYYY&gt; - Find ALL affected cargo, and update the edition." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	
	self.doForceDataExtractWork( update, list, count, startDate );
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doForceDataExtractWork" id="ee28fa1a-0b92-4a67-85f8-0f0b257626b4">
        <source>doForceDataExtractWork( _update : Boolean; _list : Boolean; _count : Boolean; _startDate : Date ) protected;
/*

Date		Who		Reason
21 Dec 2011	cnwdw1	Initial creation	Par 28892
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	allTis : ObjectArray;
	tisToProcess : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	size : Integer;
	str : String;
	count : Integer;

begin

	if _count then
		str := "Processing in COUNT mode :" &amp; CrLf;
	elseif _list then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create allTis transient;
	create tisToProcess transient;
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);

	CM_TrackedItem.allInstances(allTis,0,true);
	
	str := "Checking " &amp; allTis.size.String &amp; " Cargo items..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	iter := allTis.createIterator;
	while iter.next( ti ) do
		if ti.creationTime &lt; _startDate.TimeStamp then
			continue;
		endif;
		tisToProcess.add( ti );
	endwhile;
	delete iter;
	
	if tisToProcess.isEmpty then
		str := "No Cargo items created since " &amp; _startDate.asStringJMT() &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		size := tisToProcess.size;
		str := size.String &amp; " Cargo items have been created since " &amp; _startDate.asStringJMT() &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	if _count then
		// nothing more
	elseif _list then
		writeOutputToMyForm(CrLf);
		foreach ti in tisToProcess do
			str := ti.id &amp; " created " &amp; ti.createdTime.asStringJMT();
			writeOutputToMyForm(str &amp; CrLf);
		endforeach;
	
	elseif _update then
		writeOutputToMyForm(CrLf);
			
		foreach ti in tisToProcess do		
			beginTransaction;
			ti.updateObjectEdition(ti);	// par 30292
			commitTransaction;

			count := count + 1;
			if count mod 1000 = 0 then
				str := count.String &amp; " items processed, continuing...";
				writeOutputToMyForm(str &amp; CrLf);
			endif;
		
		endforeach;
		
		writeOutputToMyForm(CrLf);
		str := count.String &amp; " Cargo items updated.";
		writeOutputToMyForm(str &amp; CrLf);
		
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
epilog

	delete tisToProcess;
	delete allTis;
	delete iter;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_list" type="Boolean"/>
        <Parameter name="_count" type="Boolean"/>
        <Parameter name="_startDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doForceDataExtractWorkByClass" id="1c6eb75b-c315-4fae-aa1c-8f848e913a9d">
        <source>doForceDataExtractWorkByClass( _update : Boolean; _class : String; _list : Boolean; _count : Boolean; _startDate : Date ; _endDate : Date) protected;
/*

Date		Who		Reason
21 Dec 2011	cnwdw1	Initial creation	Par 28892
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	allObjs : ObjectArray;
	objToProcess : ObjectArray;
	iter : Iterator;
	obj : Object;
	cmObj : CM_Object;
	size : Integer;
	str : String;
	count : Integer;
	schema					: Schema;
	klass					: Class;
begin
	
	writeOutputToMyForm( CrLf);
	str  := "doForceDataExtractWorkByClass start time : " &amp; app.actualTimeServer.asStringJMT;
	writeOutputToMyForm(str &amp; CrLf);
	writeOutputToMyForm( CrLf);
			
			
	// check that SchemaComparisonUtility schema exists
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
			str  := "Unable to find PortSchema.  Exiting Script.";
			writeOutputToMyForm(str);
			writeOutputToMyForm(CrLf);		
		return;
	endif;

	
	
	if _class = null then
		str := CrLf &amp; "No Class entered..." &amp; CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		writeOutputToMyForm(CrLf);
		return;
	endif;
		
	klass := schema.getClass(_class);
	if klass = null then 
		str := "Unable to find class " &amp; _class &amp; "  Exiting JadeScript.";
		writeOutputToMyForm(str);
		writeOutputToMyForm(CrLf);	
		return;		
	endif;
	
	
	str := "Finding all instances of " &amp; _class &amp; "  and sublcasses for update.";
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);	
	
	if _count then
		str := "Processing in COUNT mode :" &amp; CrLf;
	elseif _list then
		str := "Processing in LIST mode :" &amp; CrLf;
	elseif _update then
		str := "Processing in UPDATE mode :" &amp; CrLf;
	endif;
	
	
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);

	create allObjs transient;
	create objToProcess transient;
	
	str := "Collecting data..." &amp; CrLf;
	writeOutputToMyForm(str);


	klass.allInstances(allObjs,0,true);
	
	str := "Checking " &amp; allObjs.size.String &amp; " Objects items..." &amp; CrLf;
	writeOutputToMyForm(str);
	writeOutputToMyForm(CrLf);
	
	iter := allObjs.createIterator;
	while iter.next( obj ) do
		if obj.creationTime &lt; _startDate.TimeStamp then
			continue;
		endif;
		
		if obj.creationTime &gt; _endDate.TimeStamp then
			continue;
		endif;
		
		objToProcess.add( obj );
	endwhile;
	delete iter;
	
	if objToProcess.isEmpty then
		str := "No object items created since " &amp; _startDate.asStringJMT() &amp; CrLf;
		str := str &amp; "No further action required." &amp; CrLf;
		writeOutputToMyForm(str);
	else
		size := objToProcess.size;
		str := size.String &amp; " Object items have been created since " &amp; _startDate.asStringJMT() &amp; CrLf;
		writeOutputToMyForm(str);
	endif;
	
	if _count then
		// nothing more
	elseif _list then
		writeOutputToMyForm(CrLf);
		foreach obj in objToProcess do
			cmObj := obj.CM_Object;
			str := cmObj.getOidString &amp; " created " &amp; cmObj.createdTime.asStringJMT();
			writeOutputToMyForm(str &amp; CrLf);
		endforeach;
	
	elseif _update then
		writeOutputToMyForm(CrLf);
		
		beginTransaction;
		foreach obj in objToProcess do		
			
			obj.updateObjectEdition(obj);	// par 30292
			

			count := count + 1;
			if count mod 1000 = 0 then
				commitTransaction;
				beginTransaction;
				str := count.String &amp; " items processed, continuing...";
				writeOutputToMyForm(str &amp; CrLf);
			endif;
		
		endforeach;
		
		commitTransaction;
		
		writeOutputToMyForm(CrLf);
		str := count.String &amp; " Cargo items updated.";
		writeOutputToMyForm(str &amp; CrLf);
		
	endif;
	
	str := CrLf &amp; "Processing completed normally.";
	writeOutputToMyForm(str);
	
	
	writeOutputToMyForm( CrLf);
	str  := "doForceDataExtractWorkByClass end time : " &amp; app.actualTimeServer.asStringJMT;
	writeOutputToMyForm(str &amp; CrLf);

epilog

	delete objToProcess;
	delete allObjs;
	delete iter;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_class" type="String"/>
        <Parameter name="_list" type="Boolean"/>
        <Parameter name="_count" type="Boolean"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doInvAddStoExpForOffItem" id="3739c831-5920-4773-a81c-12a0e94e2ae8">
        <source>doInvAddStoExpForOffItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/05/2024	navkc1 CR63806 Task 63878: Jade - Storage Expiry Fixup Script

*/

vars
	paramTransType,
	paramTerminal,
	paramAction,
	info				: String;
	error,
	list,
	update				: Boolean;
	paramFromDate,
	paramToDate			: Date;
	transType 			: Integer;
	terminal			: CM_Terminal;
	
begin
	
	if self.parameterArray.isEmpty() then
		error := true;
	else
		if self.parameterArray.size() &lt;&gt; 5 then
			error := true;
		endif;
		
		paramAction := self.parameterArray[1].toUpper(); // Action [READ or UPDATE]
		
		if paramAction = "READ" then
			list := true;
		elseif paramAction = "UPDATE" then
			update := true;
		endif;
		
		paramTerminal := self.parameterArray[2].toUpper(); // Terminal [terminal code]
		paramFromDate := self.parameterArray[3].asDate(); // From Date [ddmmyyyy]
		paramToDate := self.parameterArray[4].asDate(); // To Date [ddmmyyyy]
		paramTransType := self.parameterArray[5].toUpper(); // Transaction Type [SHIP or RAIL or ROAD or ALL]
		
		terminal := app.myRoot.allTerminals[paramTerminal];
		
		// Either "READ" or "UPDATE"
		if (not list and not update) then
			error := true;
			info &amp;= CrLf &amp; "ERROR - Invalid Action (READ or UPDATE).";
		endif;
		
		// Terminal cannot be null
		if terminal = null then	
			error := true;
			info &amp;= CrLf &amp; "ERROR - Invalid Terminal Code.";
		endif;
		
		// Date must be valid dd/mm/yyyy
		if (not paramFromDate.isValid() or not paramToDate.isValid()) then
			error := true;
			info &amp;= CrLf &amp; "ERROR - Invalid date format.";
		endif;
		
		// FromDate cannot be greather than ToDat
		if paramFromDate &gt; paramToDate then
			error := true;
			info &amp;= CrLf &amp; "ERROR - From Date cannot be greater than To Date.";
		endif;
		
		// Must be SHIP/ROAD/RAIL/ALL
		if (paramTransType &lt;&gt; "SHIP" and paramTransType &lt;&gt; "ROAD" and paramTransType &lt;&gt; "RAIL" and paramTransType &lt;&gt; "ALL") then
			error := true;
			info &amp;= CrLf &amp; "ERROR - Invalid transaction type.";
		endif;
	endif;
	
	if error then
		info &amp;= CrLf &amp; CrLf &amp; 'Invalid parameter(s) entered!
		
This script is only for offsite TIs that do not have a storage expiry detail.

Valid Parameters:
	READ &lt;terminal&gt; &lt;fromDate - dd/mm/yyyy&gt; &lt;toDate - dd/mm/yyyy&gt; &lt;Release Transaction - ROAD or RAIL or SHIP or ALL&gt;
		i.e. - READ KCT 01/05/2024 15/05/2024 SHIP

	UPDATE &lt;terminal&gt; &lt;fromDate&gt; &lt;toDate&gt; &lt;Release Transaction i.e ROAD or RAIL or SHIP or ALL&gt; 
		i.e. - UPDATE KCT 01/05/2024 15/05/2024 ALL
';
		
		self.writeOutputToMyForm(info);
		return;
	endif;
	
	if paramTransType = "SHIP" then
		transType := TRANS_TYPE_REL_SHIP;
	elseif paramTransType = "ROAD" then
		transType := TRANS_TYPE_REL_ROAD;
	elseif paramTransType = "RAIL" then
		transType := TRANS_TYPE_REL_RAIL;
	endif;
	
	self.doInvAddStoExpForOffItemWork(update, terminal, paramFromDate, paramToDate, transType);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doInvAddStoExpForOffItemWork" id="a7ec619c-eee6-4d0e-95f9-b399e80be8bf">
        <source>doInvAddStoExpForOffItemWork(_update : Boolean; _terminal : CM_Terminal; _fromDate : Date; _toDate : Date; _transType : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/05/2024	navkc1 CR63806 Task 63878: Jade - Storage Expiry Fixup Script

*/

vars
	terminal : CM_Terminal;
	dict : CM_TITransactionByTypeDateDict;
	iterator : Iterator;
	ti : CM_TrackedItem;
	storageExpDetl : CM_StorageExpiryDetail;
	operator : CM_Operator;
	operatorCode : String;
	transaction, recTrans, adjTrans, resyncTran, setNoChTran : CM_TITransaction;
	dateTime : TimeStamp;
	totalQuantity : Integer;
	totalWeight,
	totalVolume : Decimal[14,4];
	idx : Integer;
	stoDetail : CM_StorageDetail;
	freeStorageDays, freeStorageDaysType, chargedDaysType, addStorageDays : Integer;
	changeReason : String;
	freeExpTS : TimeStamp;
	tiRecTS, tiRelTS, transStart, transEnd : TimeStamp;
	actualFreeStoExp : TimeStamp;
	sameDT, updating, updateTIAddStoExpDtl  : Boolean;
	transtype : Integer;
	logInfo	: String;
begin
	
	terminal := _terminal;
	updating := _update;
	transtype := _transType;
	transStart.setDate(_fromDate); transStart.setTime("00:00:00".asTimeJMT());
	transEnd.setDate(_toDate); transEnd.setTime("23:59:59".asTimeJMT());
	
	if not updating then
		logInfo := "Idx,ID, Desc,ACTION, Rec Date,Rel Date, Actual Free Expiry, Calcd Free Expiry, SAME, Actual Free Days, SBE Free Days";
	endif;
	
	dict := terminal.allTITransactionsByTypeDate;	
	transaction := dict.getAtKeyGeq(transtype,transStart);
	
	iterator := dict.createIterator;
	if transaction &lt;&gt; null then
		iterator.startAtObject(transaction);
	endif;
	
	while iterator.next(transaction) do
		// Doing "ALL" transaction (ROAD RAIL SHIP)
		if transtype = null then
			if transaction.type &lt;&gt; TRANS_TYPE_REL_ROAD and transaction.type &lt;&gt; TRANS_TYPE_REL_RAIL and transaction.type &lt;&gt; TRANS_TYPE_REL_SHIP then
				continue;
			endif;
			
			if transaction.dateTime &lt; transStart or transaction.dateTime &gt; transEnd then
				continue;
			endif;
		else
		// Doing a specific transaction
			if transaction.type &lt;&gt; transtype then
				break;
			endif;
			
			if transaction.dateTime &gt; transEnd then
				break;
			endif;
		endif;
		
		ti := transaction.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		if not ti.isOffSite() then
			continue;
		endif;
		
		idx += 1;
		updateTIAddStoExpDtl := false;
		resyncTran := null;
		setNoChTran := null;
		
		tiRecTS := ti.receivedDT;
		if not tiRecTS.isValid then
			tiRecTS := ti.createdTime;
		endif;
		
		tiRelTS := ti.releasedDT;
		
		stoDetail:= ti.getMatchingFreeStorageDetail(null);
		if stoDetail = null then
			if not updating then
				logInfo &amp;= CrLf &amp; idx.String &amp; ", " &amp;  ti.id &amp; ", has no storage CONFIG - no action taken, NO ACTION," &amp; tiRecTS.date.asXMLFormat();
			endif;
			continue;
		endif;

		freeExpTS := tiRecTS.addDays(stoDetail.freeStorageDays);
		
		if stoDetail.includeFirstDay then
			freeExpTS := freeExpTS.addDays(-1);
		endif;
		
		actualFreeStoExp := ti.getFreeStorageExpiry();
		sameDT := freeExpTS.date = actualFreeStoExp.date;
		
		storageExpDetl := ti.allStorageExpiryDetails.first;
		if storageExpDetl = null then
			if not updating then
				logInfo &amp;= CrLf &amp; idx.String &amp; ", " &amp;  ti.id &amp; ", has no storage expiry detail - needs fixing (create storage expiry), NEEDS FIX,"  &amp; tiRecTS.date.asXMLFormat() &amp; ", " &amp; tiRelTS.date.asXMLFormat() &amp; ", " &amp; actualFreeStoExp.date.asXMLFormat() &amp; ", " &amp; freeExpTS.date.asXMLFormat() &amp; "," &amp; sameDT.getYesNo &amp; "," &amp; ti.getFreeStorageDays().String &amp;"," &amp; stoDetail.freeStorageDays.String;
			endif;
			
			updateTIAddStoExpDtl := true; // FIXUP
		elseif storageExpDetl.freeStorageDays = 0 then
			if stoDetail &lt;&gt; null 
			and stoDetail.freeStorageDays &gt; 0 then
				if not updating then
					logInfo &amp;= CrLf &amp; idx.String &amp; ", " &amp;  ti.id &amp; ", has ZERO free days  - needs fixing (populate storage expiry), NEEDS FIX, " &amp; tiRecTS.date.asXMLFormat() &amp; ", " &amp; tiRelTS.date.asXMLFormat() &amp; ", " &amp; actualFreeStoExp.date.asXMLFormat() &amp; ", " &amp; freeExpTS.date.asXMLFormat()  &amp; "," &amp; sameDT.getYesNo &amp; "," &amp; ti.getFreeStorageDays().String &amp; "," &amp; stoDetail.freeStorageDays.String;
				endif;
				updateTIAddStoExpDtl := true; // FIXUP
			endif;
		endif;
		
		// #####################################################
		// #####################################################
		if updating then
			// ### FIXUP - CREATE STORAGE EXPIRY DETAIL
			if updateTIAddStoExpDtl then
				beginTransaction;
					ti.allStorageExpiryDetails.purge();
					create storageExpDetl persistent;
					recTrans := ti.allTransactions.findFirstReceivalTrans();
					if recTrans &lt;&gt; null then
						dateTime := recTrans.dateTime;
						totalQuantity := recTrans.totalQuantity;
						totalWeight := recTrans.totalWeight;
						totalVolume := recTrans.totalVolume;
					else
						totalQuantity := 0;
						totalWeight := 0;
						totalVolume := 0;
						dateTime := null;
					endif;
					operator := ti.getReceiveOperator();
					if operator &lt;&gt; null then
						operatorCode := operator.code;
					endif;
						
					freeStorageDays := 0;
					freeStorageDaysType := CM_StorageDetail.Calendar_Days;
					chargedDaysType := CM_StorageDetail.Calendar_Days;
					stoDetail:= ti.getMatchingFreeStorageDetail(null);
					if stoDetail &lt;&gt; null  then
						freeStorageDays := stoDetail.freeStorageDays;
						freeStorageDaysType := stoDetail.freeDaysType;
						chargedDaysType := stoDetail.chargedDaysType;
					endif;
					
					addStorageDays := 0;
					changeReason := "";
					adjTrans := ti.getLastTransOfType(TRANS_TYPE_FREE_STORAGE_ADJ);
					if adjTrans &lt;&gt; null then
						addStorageDays := adjTrans.CM_FreeStorageAdjustment.additionalStorageDays;
						changeReason := adjTrans.CM_FreeStorageAdjustment.changeReason;
					endif;
					
					storageExpDetl.setProxy(addStorageDays,dateTime,null,freeStorageDaysType,null,freeStorageDays,null,
															dateTime,
															ti.plannedDT,null,null,
															stoDetail,
															ti,
															operatorCode,null,
															changeReason,
															totalQuantity,totalVolume,totalWeight,
															chargedDaysType);
															
					// the evaluation of the free storage expiry at this point will use the values set in the 'setProxy()'
					freeExpTS := ti.getFreeStExpDTFirstTime().TimeStamp;								
					storageExpDetl.setFreeStorageExpDate(freeExpTS);						
				commitTransaction;
				
				logInfo &amp;= CrLf &amp; idx.String &amp; " - " &amp; ti.id &amp; ", fixed storage expiry details.";
			endif;
		endif;
		// #####################################################
	endwhile;
	
	self.writeOutputToMyForm(logInfo);
	
epilog
	delete iterator;
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_fromDate" type="Date"/>
        <Parameter name="_toDate" type="Date"/>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doListJMTRefreshConfig" id="79ba5bf8-d828-4d97-b5fc-af193ed6e13b">
        <source>doListJMTRefreshConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlger1	Initial creation 42569
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
07 Oct 2022	navkc1	Bug 52310: SAL - JMT Backup Failing &amp; Settings not set after refresh
*/

vars
	root : CM_Root;
	t : CM_Terminal;
	param : String;
	list : Boolean;
	entRowName,
	configValue,
	info : String;
	entRow : EntTableRow;
	camsEntDef,
	eDIEntDef : EntTableDef;
	 
	webConfig : CM_WebSiteConfig;
	backup		: CM_Backup;
	prop		: Property;
	propColl 	: PropertyNDict;
	
begin
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is provided to list the current systems configs  in a format recognised by the ini in JMTRefreshParameters. "  &amp; CrLf;
		info := info &amp; "This can be used when refreshing Test or UAT environments from Production, so the system configuration remains the same as before the refresh. "  &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "'LIST' is the only valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	root := CM_Root.firstInstance;
	writeLineOutputToMyForm("[" &amp; JMTRefreshSection &amp; "]");
	// Non config options
	writeLineOutputToMyForm("SystemMode=[Test|UAT]");
	writeLineOutputToMyForm("DisableAllBGPSchedules=[true|false]");
	writeLineOutputToMyForm("EnableUser1=SUPERUSER");
	writeLineOutputToMyForm("EnableUserX=[User Code]");
	writeLineOutputToMyForm("ActiveCargoChainDef=[External Web Service Name]");   //14.07.2020 cnwma1 #49243
	writeLineOutputToMyForm("ActiveOpsViewDef=[External Web Service Name]");      //19.08.2020 cnwma1 TFS #49758
	
	writeLineOutputToMyForm(AppBackgroundColor  &amp;"=" &amp;   root.getConfig(AppBackgroundColor).String);
	writeLineOutputToMyForm(SystemTitle   &amp;"=" &amp;   root.getConfig(SystemTitle ).String);
	writeLineOutputToMyForm(SystemTempDir  &amp;"=" &amp;   root.getConfig(SystemTempDir).String);
	writeLineOutputToMyForm(BgpEmailTestMode  &amp;"=" &amp;   root.getConfig(BgpEmailTestMode).String);
	writeLineOutputToMyForm(BgpEmailTestAddress  &amp;"=" &amp;   root.getConfig(BgpEmailTestAddress).String);
	writeLineOutputToMyForm(AutoDisableEmailAddress  &amp;"=" &amp;   root.getConfig(AutoDisableEmailAddress).String);
	writeLineOutputToMyForm(AutoSendersEmailAddress  &amp;"=" &amp;   root.getConfig(AutoSendersEmailAddress).String);
	writeLineOutputToMyForm(AutoSupportEmailAddress  &amp;"=" &amp;   root.getConfig(AutoSupportEmailAddress).String);
	
	// 07/10/2022	navkc1	#52310 starts
	backup := root.myBackup;
	if backup &lt;&gt; null then
		propColl := CM_Backup.getProperties();
		writeLineOutputToMyForm("[" &amp; JMTRefreshSection &amp; "_Backup]" );
		foreach prop in propColl where not prop.isKindOf(Reference) do
			if	prop = CM_Backup::dbRemoteBackupPath or
				prop = CM_Backup::debug or
				prop = CM_Backup::displayStatus or
				prop = CM_Backup::journalNumber or
				prop = CM_Backup::status then
				continue;
			endif;
			writeLineOutputToMyForm(prop.name &amp;"="&amp; backup.getPropertyValue(prop.name).String );
		endforeach;
	endif;
	// 07/10/2022	navkc1	#52310 ends
	
	eDIEntDef := root.myEntTableDataRoot.allEntTableDefs[ETDef_EDIConfig];
	camsEntDef:= root.myEntTableDataRoot.allEntTableDefs[ETDef_CamsConfig];
	foreach t in root.allTerminals discreteLock do
		writeLineOutputToMyForm("[" &amp; JMTRefreshSection &amp; "_" &amp; t.code &amp; "]");
		foreach entRow in eDIEntDef.allEntTableRows do
			entRowName:=entRow.name;
			entRowName.firstCharToUpper;
			configValue:=t.getConfig(entRowName).String;
			if configValue &lt;&gt; null then
				writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
			endif;
		endforeach;
		foreach entRow in camsEntDef.allEntTableRows do
			entRowName:=entRow.name;
			entRowName.firstCharToUpper;
			configValue:=t.getConfig(entRowName).String;
			if configValue &lt;&gt; null then
				writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
			endif;
		endforeach;
	endforeach;
	
	foreach webConfig in root.allWebSiteConfigs discreteLock do
		writeLineOutputToMyForm("[" &amp; JMTRefreshSection &amp; "_WEB_" &amp; webConfig.name &amp; "]");
		configValue:=webConfig.sessionTimeoutMinutes.String;
		entRowName:=CM_WebSiteConfig::sessionTimeoutMinutes.name;
		entRowName.firstCharToUpper;
		if configValue &lt;&gt; null then
			writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
		endif;
		configValue:=webConfig.downloadFileDirectoryPath.String;
		entRowName:=CM_WebSiteConfig::downloadFileDirectoryPath.name;
		entRowName.firstCharToUpper;
		if configValue &lt;&gt; null then
			writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
		endif;
		configValue:=webConfig.downloadFileDirectoryURL.String;
		entRowName:=CM_WebSiteConfig::downloadFileDirectoryURL.name;
		entRowName.firstCharToUpper;
		if configValue &lt;&gt; null then
			writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
		endif;
		configValue:=webConfig.downloadFileTimeout.String;
		entRowName:=CM_WebSiteConfig::downloadFileTimeout.name;
		entRowName.firstCharToUpper;
		if configValue &lt;&gt; null then
			writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
		endif;
		configValue:=webConfig.helpFileURL.String;
		entRowName:=CM_WebSiteConfig::helpFileURL.name;
		entRowName.firstCharToUpper;
		if configValue &lt;&gt; null then
			writeLineOutputToMyForm(entRowName  &amp;"=" &amp; configValue   );
		endif;
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListPatchedMethods" id="7d3ea5a6-1fbc-48b7-9b28-6432b2b261b9">
        <source>doListPatchedMethods();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2015	cnwndl1	Initial creation

*/

vars

	ts : TimeStamp;
	list : Boolean;
	baseLevel : String;
	param : String;
	info : String;

begin

	ts := app.getJMTReleaseExtractTime;
	baseLevel := app.appVersion;
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;

	if not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is provided to allow JMT Support staff to verify the list of methods that has been patched into this." &amp; CrLf;
		info := info &amp; "environment since the base level '" &amp; baseLevel &amp; "' was cut on '" &amp; ts.asStringJMT &amp; "'." &amp; CrLf;		
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Run this method in 'LIST' mode." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will list all methods that have been re-compliled in any schema after the cut date of the release" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "'LIST' is the only valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doListPatchedMethodsWork( ts );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListPatchedMethodsWork" id="ef401af5-e107-4282-a5ce-8134f685a193">
        <source>doListPatchedMethodsWork( _ts : TimeStamp ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2015	cnwndl1	Initial creation	Par 37174

*/

vars

	schema : Schema;
	schemaColl : SchemaColl;
	type : Type;
	meth : Method;
	str : String;

begin

	str := CrLf &amp; "Database = " &amp; app.dbPath();
	writeOutputToMyForm(str);
	
	str := CrLf &amp; "Base JMT Version = " &amp; app.appVersion &amp; CrLf;
	writeOutputToMyForm(str);

	str := CrLf &amp; "Searching for all methods changed since " &amp; _ts.asStringJMT &amp; CrLf;
	writeOutputToMyForm(str);

	schema := rootSchema.getSchema("RootSchema");
	if schema = null then
		str := "Unable to find Schema RootSchema.  Exiting JadeScript...";
		writeOutputToMyForm(str);
		return;
	endif;
	
	create schemaColl transient;
	schemaColl.add(schema);
	schema.allSubschemas(schemaColl);
	
	foreach schema in schemaColl do
		str := CrLf &amp; "Checking " &amp; schema.name &amp; " ...";
		writeOutputToMyForm(str);
		foreach type in schema.allPrimitives() do
			foreach meth in type.cnGetMethods() do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt;= _ts then
					continue;
				endif;
				str := CrLf &amp; Tab &amp; schema.name &amp; "::" &amp; meth.qualifiedName &amp; "     - " &amp; meth.cnEcGetModifyTimeStamp.asStringJMT;
				writeOutputToMyForm(str);
			endforeach;
		endforeach;
		foreach type in schema.allClasses() do
			foreach meth in type.cnGetMethods() do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt;= _ts then
					continue;
				endif;
				str := CrLf &amp; Tab &amp; schema.name &amp; "::" &amp; meth.qualifiedName &amp; "     - " &amp; meth.cnEcGetModifyTimeStamp.asStringJMT;
				writeOutputToMyForm(str);
			endforeach;
		endforeach;
		str := CrLf &amp; " " &amp; schema.name &amp; " completed";
		writeOutputToMyForm(str);
	endforeach;
	
	str := CrLf &amp; CrLf &amp; "All complete";
	writeOutputToMyForm(str);
	
epilog

	delete schemaColl;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doListRampRates" id="b69b57b1-60ea-4fa5-aa0c-b8ab7c3d3245">
        <source>doListRampRates();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2019	jlgndl1	Initial creation	TFS 45084

*/

vars

	ts : TimeStamp;
	list : Boolean;
	baseLevel : String;
	param : String;
	info : String;

begin

	ts := app.getJMTReleaseExtractTime;
	baseLevel := app.appVersion;
	
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;

	if not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is display a list of the Rates associated with Calculation Types that have been changed to 'Ramp rate' from" &amp; CrLf;
		info := info &amp; "a 'Single Rate'." &amp; CrLf;		
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is provided solely to assist the manual conversion of the existing data when the 'Ramp rate' is first turned on." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Run this method in 'LIST' mode." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will list all rates associated with the Calculation type.  They will be shown in 2 groups, firstly the ones that exist" &amp; CrLf;
		info := info &amp; "with only one recorded rate against them, followed by the ones that have been updated to include the 2nd rate" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "'LIST' is the only valid parameter for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doListRampRatesWork();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListRampRatesWork" id="3ab2ebf1-723d-4316-a103-9c926d64e691">
        <source>doListRampRatesWork()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2019	jlgndl1	Initial creation	TFS 45084

*/

vars

	calcType : CM_CalculationType;
	iter : Iterator;
	count : Integer;
	rampCalcTypes : ObjectArray;
	obj : Object;
	invLineType : CM_InvoiceLineDesc;
	service : CM_Service;
	allServices : ObjectArray;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	rateEntriesToConvert : DynaDictionary;
	rateEntriesConverted : DynaDictionary;
	obj2 : Object;
	
	term : CM_Terminal;
	bank : CM_Bank;
	debtor : CM_DebtorNode;
	drRate : CM_DebtorRate;
	real : Real;
	tmpStr : String;
	
	meth : Method;
	str : String;

begin

	str := CrLf &amp; "Processing..." &amp; CrLf &amp; CrLf;
	writeOutputToMyForm(str);

	create rampCalcTypes transient;
	create allServices transient;
	
	create rateEntriesToConvert transient;
	rateEntriesToConvert.setMembership( CM_RateEntry );
	rateEntriesToConvert.addExternalKey(String,30,false,true); //term
	rateEntriesToConvert.addExternalKey(String,30,false,true); //bank
	rateEntriesToConvert.addExternalKey(String,30,false,true); //debtor
	rateEntriesToConvert.addExternalKey(String,30,false,true); //service
	rateEntriesToConvert.addExternalKey(String,30,false,true); //rateEntryOid
	rateEntriesToConvert.endKeys(true);
	
	create rateEntriesConverted transient;
	rateEntriesConverted.setMembership( CM_RateEntry );
	rateEntriesConverted.addExternalKey(String,30,false,true); //term
	rateEntriesConverted.addExternalKey(String,30,false,true); //bank
	rateEntriesConverted.addExternalKey(String,30,false,true); //debtor
	rateEntriesConverted.addExternalKey(String,30,false,true); //service
	rateEntriesConverted.addExternalKey(String,30,false,true); //rateEntryOid
	rateEntriesConverted.endKeys(true);

	iter := app.myRoot.allCalculationTypesByCode.createIterator;
	while iter.next( calcType ) do
		if calcType.rateType = 2 then
			rampCalcTypes.add( calcType );
		endif;
	endwhile;
	delete iter;
	
	iter := rampCalcTypes.createIterator;
	while iter.next( obj ) do
		calcType := obj.CM_CalculationType;
		foreach service in calcType.allServices do
			allServices.addExclusive( service );
		endforeach;
	endwhile;
	delete iter;
	
	iter := allServices.createIterator;
	while iter.next( obj ) do
		service := obj.CM_Service;
		bank := service.bank;
		term := bank.terminal;
		foreach debtorRate in service.debtorNodeRates do
			foreach rateEntry in debtorRate.rateEntries do
				if rateEntry.rate &lt;&gt; null and rateEntry.rate.isKindOf( CM_DebtorRate ) then
					drRate := rateEntry.rate.CM_DebtorRate;
					debtor := drRate.debtorNode;
				else
					continue;
				endif;
				
				if rateEntry.allCostPerUnits = null or rateEntry.allCostPerUnits.size &lt; 2 or rateEntry.allCostPerUnits[2] = 0.0 then
					if rateEntriesToConvert.includes( rateEntry ) then
						continue;
					endif;
					rateEntriesToConvert.putAtKey( term.code, bank.code, debtor.name[1:30], service.name[1:30], rateEntry.getOidString, rateEntry );// term, bank, debtor, service
				else
					if rateEntriesToConvert.includes( rateEntry ) then
						continue;
					endif;
					rateEntriesConverted.putAtKey( term.code, bank.code, debtor.name[1:30], service.name[1:30], rateEntry.getOidString, rateEntry );// term, bank, debtor, service
				endif;
			endforeach;
		endforeach;
	endwhile;

	if not rateEntriesToConvert.isEmpty then
		str := "Rate entries using 'RAMP' with no second cpu set up" &amp; CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Terminal / Business Unit / Debtor / Service" &amp; CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		
		foreach obj in rateEntriesToConvert do
			rateEntry := obj.CM_RateEntry;
			if rateEntry.rate &lt;&gt; null and rateEntry.rate.isKindOf( CM_DebtorRate ) then
				drRate := rateEntry.rate.CM_DebtorRate;
				debtor := drRate.debtorNode;	
				if debtor = null then
					continue;
				endif;
				service := drRate.service;
				if service &lt;&gt; null then
					bank := service.bank; 
					if bank &lt;&gt; null and bank.terminal &lt;&gt; null then
						term := bank.terminal;
						str := term.code &amp; " / " &amp; bank.code &amp; " / " &amp; debtor.name &amp; " / " &amp; service.name &amp; CrLf;
						writeOutputToMyForm(str);
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	str := " " &amp; CrLf;
	writeOutputToMyForm(str);
	
	if not rateEntriesConverted.isEmpty then
		str := "Rate entries using 'RAMP' - setup values" &amp; CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		str := "Terminal / Business Unit / Debtor / Service" &amp; CrLf &amp; CrLf;
		writeOutputToMyForm(str);
		
		foreach obj in rateEntriesConverted do
			rateEntry := obj.CM_RateEntry;
			if rateEntry.rate &lt;&gt; null and rateEntry.rate.isKindOf( CM_DebtorRate ) then
				drRate := rateEntry.rate.CM_DebtorRate;
				debtor := drRate.debtorNode;	
				service := drRate.service;
				if service &lt;&gt; null then
					bank := service.bank; 
					if bank &lt;&gt; null and bank.terminal &lt;&gt; null then
						term := bank.terminal;
						tmpStr := null;
						foreach real in rateEntry.allCostPerUnits do
							if tmpStr = null then
								tmpStr := real.String;
							else
								tmpStr := tmpStr &amp; ", " &amp; real.String;
							endif;
						endforeach;
						str :=  term.code &amp; " / " &amp; bank.code &amp; " / " &amp; debtor.name &amp; " / " &amp; service.name &amp; Tab &amp; Tab &amp; " = " &amp; tmpStr &amp; CrLf;	
						writeOutputToMyForm(str);
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
epilog

	delete iter;
	delete rampCalcTypes;
	delete allServices;
	delete rateEntriesToConvert;
	delete rateEntriesConverted;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doListUsersAndRoles" id="7e40891b-0cf6-461d-8bfa-0001e70c4aa9">
        <source>doListUsersAndRoles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2015	cnwndl1	Initial creation

*/

vars

	param :String;
	param2 :String;

	roles : Boolean;
	users : Boolean;
	
	info : String;

begin

	// check that we have parameters and capture locally what we will be doing.
	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
		elseif self.parameterArray.size = 2 then
			param := self.parameterArray[1].trimBlanks.toUpper;
			param2 := self.parameterArray[2].trimBlanks.toUpper;			
		endif;

		if param = "ROLES" then
			roles := true;
		elseif param = "USERS" then
			users := true;
		endif;
		
		if param2 = "ROLES" then
			roles := true;
		elseif param2 = "USERS" then
			users := true;
		endif;
		
 	endif;
	
	if not roles and not users then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This special method will list out the details of the Permissions setup." &amp; CrLf;
		info := info &amp; "for Users and/or Roles in the current environment" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "These listings will be quite large, and can take some time to run." &amp; CrLf;
		info := info &amp; "For USERS allow approx 100 users per minute." &amp; CrLf;
		info := info &amp; "This environment has " &amp; app.myRoot.allUsers.size.String &amp; " users." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "For ROLES allow approx 1 role per minute." &amp; CrLf;
		info := info &amp; "This environment has " &amp; app.myRoot.allRoles.size.String &amp; " roles." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "USERS - To list each user, the terminals they have access to, and their Security Roles." &amp; CrLf;
		info := info &amp; "ROLES - To list each Role, its parent in the heirarchy, and its granted permissions." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;

	self.doListUsersAndRolesWork( roles, users );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListUsersAndRolesWork" id="bf24428b-26c3-43e8-9c19-3fcb89ae96f7">
        <source>doListUsersAndRolesWork( _roles, _users : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2015	cnwndl1	Initial creation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	role : CM_SecurityRole;
	iter : Iterator;
	index : Integer;
	perm : XLAT_Translation;
	str : String;
	size : Integer;
	user : CM_User;
	termSecRoleName : String;
	userTerminal : CM_UserTerminal;

begin

	str := CrLf &amp; "Database = " &amp; app.dbPath();
	writeOutputToMyForm(str);
	
	str := CrLf &amp; "Base JMT Version = " &amp; app.appVersion;
	writeOutputToMyForm(str);

	str := CrLf &amp; "As at = " &amp; app.actualTimeServer.asStringJMT;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	writeOutputToMyForm(str);
	
	if _roles and _users then
		str := CrLf &amp; "Roles and Users ";
	elseif _roles then
		str := CrLf &amp; "Roles only ";
	elseif _users then
		str := CrLf &amp; "Users only";
	endif;
	writeOutputToMyForm(str &amp; CrLf &amp; CrLf);

	if _roles then
	
		str := CrLf &amp; "Roles" &amp; CrLf &amp; "++++++++++++++++++++++++++++++++++++++++++++++++++++++" &amp; CrLf;
		writeOutputToMyForm(str &amp; CrLf &amp; CrLf);

		iter := app.myRoot.allRoles.createIterator;
		while iter.next( role ) do
			str := CrLf &amp; CrLf &amp; "Role = " &amp; role.name;
			writeOutputToMyForm(str);
			
			str := CrLf &amp; Tab &amp; "Parent Role = " &amp; role.getParentHeirarchyString;
			writeOutputToMyForm(str);
			
			str := CrLf &amp; Tab &amp; "Includes permissions for:";
			writeOutputToMyForm(str);
			
			size := role.permissions.size;
			foreach index in 1 to size do
				if role.permissions[index] then
					perm := app.zGetTranslatedText(XLAT_Permissions, index);
					if perm &lt;&gt; null then
						str := CrLf &amp; Tab &amp; Tab &amp; perm.text;
						writeOutputToMyForm(str);
					endif;
				endif;
			endforeach;
			
		endwhile;
		delete iter;
	
	endif;
	
	if _users then
	
		str := CrLf &amp; "Users" &amp; CrLf &amp; "++++++++++++++++++++++++++++++++++++++++++++++++++++++" &amp; CrLf;
		writeOutputToMyForm(str &amp; CrLf &amp; CrLf);
	
		iter := app.myRoot.allUsers.createIterator;
		while iter.next( user ) do
			str := CrLf  &amp; CrLf &amp; "User = " &amp; user.code &amp; "/" &amp; user.userName;
			writeOutputToMyForm(str);
			
			if user.mySystemSecurityRole &lt;&gt; null then
				str := CrLf &amp; Tab &amp; " System Security = " &amp; user.mySystemSecurityRole.name;
				writeOutputToMyForm(str);
			endif;
			
			str := CrLf &amp; Tab &amp; "Includes terminal access for:";
			writeOutputToMyForm(str);
			
			foreach userTerminal in user.allUserTerminals do
			
				termSecRoleName := null;
				if userTerminal.mySecurityRole &lt;&gt; null then
					termSecRoleName := " Terminal Security = " &amp;  userTerminal.mySecurityRole.name;
				endif;
				
				str := CrLf &amp; Tab &amp; Tab &amp; userTerminal.myTerminal.code &amp; " - " &amp; termSecRoleName;
				writeOutputToMyForm(str);
						
			endforeach;

		endwhile;
		delete iter;
	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_roles" type="Boolean"/>
        <Parameter name="_users" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPopulateCountryCodes" id="1d05e891-a97f-4836-8b13-bde56d88a8de">
        <source>doPopulateCountryCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2013	cnwndl1	Initial creation	Par 32305

*/

vars

	param : String;
	update : Boolean;
	list : Boolean;
	info : String;

begin

	if not self.parameterArray.isEmpty then
		if self.parameterArray.size = 1 then
			param := self.parameterArray.first.trimBlanks.toUpper;
			if param = "UPDATE" then
				update := true;
				list := true;
			elseif param = "LIST" then
				list := true;
			endif;
		endif;
 	endif;
	
	if not update and not list then
		info := "No recognised parameter(s) entered!" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "This method is relative to Par 32305, but may be run at any time to update or load the Country Code details." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "There are a set of Internationally recognised names and codes used to describe Countries in computer systems." &amp; CrLf;
		info := info &amp; "In JMT we primarily use the 2 digit ISO code, but also store the 3 digit ISO code and the 3 digit UN number." &amp; CrLf;
		info := info &amp; "This method is provided to highlight and optionally update the 3 digit ISO code, the 3 digit UN number" &amp; CrLf;
		info := info &amp; "and the country name based on the 2 digit ISO codes, so as to match the standard details known to JMT." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Run this method in 'LIST' mode to see what variations from standard exist within your database." &amp; CrLf;
		info := info &amp; "Run this method in 'UPDATE' mode to update your data to match the standard set." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;		
		info := info &amp; "Valid Parameters:" &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "LIST - Will highlight any countries that are missing, and list where the set up of the country data differs from" &amp; CrLf;
		info := info &amp; "         the values believed to be standard by JMT." &amp; CrLf; 
		info := info &amp; "UPDATE - Will add any countries that are missing, and update the 3 digit ISO code, the 3 digit UN number" &amp; CrLf;
		info := info &amp; "         and the country names to match the values used as standard by JMT." &amp; CrLf; 
		info := info &amp; "" &amp; CrLf;
		info := info &amp; "Only 'LIST' or 'UPDATE' are valid parameters for this method." &amp; CrLf;
		info := info &amp; "" &amp; CrLf;
				
		self.writeOutputToMyForm(info);
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;


	self.doPopulateCountryCodesWork( update );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateCountryCodesWork" id="008939dd-5639-4821-a45a-6d57829d144e">
        <source>doPopulateCountryCodesWork( _update : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2013	cnwndl1	Initial creation	Par 32305

*/

vars

	twoCharArray : StringArray;	// ISO 2 digit aplpha code
	threeCharArray : StringArray;	// ISO 3 digit aplha code
