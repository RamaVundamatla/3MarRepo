    <JadeMethod name="zTestGetForm" id="b1e2db01-43d9-49ec-b8f6-9dafff2cacbb">
        <source>zTestGetForm(pTheStartClass : Class; pLevel : Integer; pAllValidSchemas : SchemaColl);

vars
	theClass	: Class;
	formDate	: Date;
	allClasses	: ClassColl;
	listPointer	: Integer;

begin
//	filter startClass here

	formDate := pTheStartClass.cnEcGetModifyTimeStamp().Date;

	if pTheStartClass = Form then
				// keep Form, as it's the starting point...
	elseif not pAllValidSchemas.includes(pTheStartClass.schema) then
		return;	// invalid form
	elseif (aEarliestDate = null) or (formDate &gt;= aEarliestDate) then
				// valid date - keep
	else
		return;	// not valid date
	endif;

//		write(myLevel.String &amp; Tab &amp; startClass.name);

//	listPointer := lbForms.addItem(startClass.name &amp; " (" &amp; startClass.cnEcGetModifiedTimeStamp.Date.format("dd/MM/yy") &amp; ")");
//	lbForms.itemObject[listPointer] := pTheStartClass;

	tblSelectedForms.row := tblSelectedForms.addItem(pTheStartClass.name &amp; Tab &amp; pTheStartClass.cnEcGetModifyTimeStamp().Date.String);
	tblSelectedForms.column := 1;
	tblSelectedForms.itemObject := pTheStartClass;
	tblSelectedForms.column := 2;
	tblSelectedForms.itemObject := pTheStartClass;
/*
	listPointer := lbForms.addItem(pTheStartClass.name);
	lbForms.itemLevel[listPointer] := pLevel;
	lbForms.itemExpanded[listPointer] := true;
*/
	if pTheStartClass.hasSubclasses then
		create allClasses transient;
		pTheStartClass.allSubclassesInSubschemas(allClasses);
		
		foreach theClass in allClasses do
			self.zTestGetForm(theClass, pLevel + 1, pAllValidSchemas);
		endforeach;

		delete allClasses;
	endif;
end;</source>
        <Parameter name="pTheStartClass" type="Class"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="pAllValidSchemas" type="SchemaColl"/>
    </JadeMethod>
    <JadeMethod name="zTestLaunchGetForm" id="a138fe28-c545-4bbf-ba85-0f26da046b7d">
        <updating/>
        <source>zTestLaunchGetForm() updating;
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	validClasses	: ClassColl;
	validSchemas	: SchemaColl;
	theSchema		: Schema;
	date			: Date;
	t1, t2			: TimeStamp;
begin
	t1 := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	tblSelectedForms.clear();
	tblSelectedForms.rows := 0;
	tblSelectedForms.columns := 2;
	tblSelectedForms.visible := true;

	self.aEarliestDate := txtStartDate.text.Date;

	theSchema := lstSchema.listObject.Schema;
	
	if theSchema = null then
		self.setStatusLine("No schema selected", false);
		return;
	endif;

	create validSchemas transient;
	if chkSubschemas.value then
		theSchema.allSubschemas(validSchemas);
	endif;
	
	validSchemas.add(theSchema);

	create validClasses transient;

	self.zTestGetForm(Form, 1, validSchemas);

	delete validClasses;
	delete validSchemas;
	t2 := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.setStatusLine((t2.time - t1.time).String, true);
end;</source>
    </JadeMethod>
</GUIClass>
