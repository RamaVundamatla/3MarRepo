<GUIClass name="SOP_ViewAuditsForm" id="69192dfd-636e-4884-9019-9887bb21db92">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="tblAudits" id="74bdf04d-0b6f-43d2-8a80-9e64b60bcf2f">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="transText" id="f264b9ba-e009-4dd7-8877-4fa877c2781c">
        <embedded/>
        <type name="XLAT_TranslatableText"/>
    </ImplicitInverseRef>
    <JadeMethod name="setupForm" id="842cd5c1-3704-4f09-889d-28a2294a4e5e">
        <updating/>
        <source>setupForm() updating;

vars
	translation : XLAT_Translation;
	audit : CM_AuditObject;

begin
	inheritMethod();
	btnOk.visible:= false;
	btnCancel.visible := false;

	// Display audits for all translations of translatable text item
	// selected on the SOP_TextTranslationForm.
	tblAudits.setCellText(1, 1, "Timestamp" &amp; Tab &amp; "User" &amp; Tab &amp; "Translation");
	if self.transText &lt;&gt; null then //added by cnwyl1 for par15520
		foreach translation in self.transText.allTextByLocale do
			foreach audit in translation.allAuditObjectsForClass do 	//21 Jan 2021	NDL	TFS 50152
				tblAudits.addItem(audit.timestamp.String &amp; Tab &amp; audit.userCode &amp; Tab &amp; audit.auditText);
			endforeach;
		endforeach;
	endif;
	
	// Display the most recent audits first.
	tblAudits.sortColumn[1] := 1;
	tblAudits.sortType[1] := Table.SortType_TimeStamp;
	tblAudits.sortAsc[1] := false;
	tblAudits.resort;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9905cd22-626e-4d38-a798-31558f2482f3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007234, locale);
end;</source>
    </JadeMethod>
</GUIClass>
