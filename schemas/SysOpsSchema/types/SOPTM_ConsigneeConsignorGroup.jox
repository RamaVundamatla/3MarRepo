    <JadeMethod name="doSave" id="d2729766-adda-4e5d-a52b-73d5f90853ae">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj				:	CM_Error;
	idx					:	Integer;
	tmpListBox			:	ListBox;
	ignoreWarnings,
	rtnValue			:	Boolean;
	code,
	groupDescription	:	String;
	theForm 			: 	SOP_TableMaintForm;
	proxyConsigneeConsignorGroup	:	CM_ConsigneeConsignorGroup;
	theConsigGrp			:	CM_ConsignByCodeDict;
begin
  theForm := self.myForm; 

	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	groupDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ConsigneeConsignorGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	create theConsigGrp transient;
	theForm.mulSelect1.getSelected(theConsigGrp);
	
	proxyConsigneeConsignorGroup := theForm.myProxyObject.CM_ConsigneeConsignorGroup;
	proxyConsigneeConsignorGroup.setProxy(code, groupDescription, theConsigGrp);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateConsignGroup(proxyConsigneeConsignorGroup, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateConsignGroup(proxyConsigneeConsignorGroup,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();

epilog
	delete theConsigGrp;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
