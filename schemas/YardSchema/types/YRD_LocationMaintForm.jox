    </JadeMethod>
    <JadeMethod name="doBtnHeightSave" id="82f512ca-2fbc-4630-8a15-24e01e8de816">
        <updating/>
        <source>doBtnHeightSave() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, result : Integer;
	theRegion : CMIF_GridTARegion;
	aPoint : CMUI_GridPoint;
	rtnValue : Boolean;
	aController : CM_LocationsController;
//	theLCS : CM_LCArray;
	anObject : Object;
begin
	if self.allInterfaceObjects.size &lt; 1 then
		return;
	endif;
	self.modalDialogShow(null, 'Cancel', null, null, "Location Heights","Saving...");

	self.mousePointer := Window.MousePointer_HourGlass;
//	// ### copy these away for updating the GUI
//	create theLCS transient;
//	foreach anObject in self.allInterfaceObjects do
//		theRegion := anObject.CMIF_GridTARegion;
//		theRegion.allLocationControllers.copy(theLCS);
//	endforeach;

	while true do
		app.myTrxUA.trxUpdateGridControllers(self.allInterfaceObjects,self.myCurrentTerminalArea,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.myCurrentTerminalArea.id &amp; ' Pad Edit', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			//self.allInterfaceObjects.purge(); 
			return;
		endif;
		break;
	endwhile;

	self.allInterfaceObjects.purge(); 
//	self.doUpdateGridArea(theLCS);// UPDATE GUI
	self.doMenuHeightsHide(true, false);
epilog
	self.frmModalDialog.visible := false;
//	delete theLCS;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLabourAdd" id="85efb0c1-249d-4ed5-8c35-34f237a70813">
        <updating/>
        <source>doBtnLabourAdd() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;

begin
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	self.tblOther.clearValues();
	
	//08 July 2015	NDL	Par 36588
	self.mulNotifyEmails.visible := true;
	self.mulNotifyEmails.multiSelect := ListBox.MultiSelect_Simple;
	self.mulNotifyEmails.formDisplayEntryMethodName := YRD_LocationMaintForm::displayEmailAddress.name;
	self.mulNotifyEmails.availableHeading := app.getErrorString(Available_email_addresses);
	self.mulNotifyEmails.selectedHeading :=  app.getErrorString(Selected_email_addresses);
	self.mulNotifyEmails.caption := app.getErrorString(Notify_adddeleteexpiry);
	self.mulNotifyEmails.myBaseForm	:= self;
	self.mulNotifyEmails.mySelectedListBox.sorted := true;
	
	self.mulNotifyEmails.setSelected( null );	//08 Jul 2015	NDL	Par 36588
//	self.cmbNotify.clear();	
	self.cmbOrganisation.clear();	
	self.cmbReason.clear();		
//	self.txtDurationHours.setTime(null);
	self.tblOther.setValueByName(ETRow_DurationHours, null);
	
	self.frmGridArea.enabled := true;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(true);
	self.myCurrentLabourRestriction := null;

	self.tblOther.disableRowByName(ETRow_Expiry);	
	self.tblOther.hideRowByName(ETRow_Expiry,false);
	
	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then
		theArea.paintColour := Yellow;
		theArea.editMode := true;	
	endif;

	self.tblOther.goToRowByName(ETRow_Code);

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLabourCancel" id="a37547f1-b13e-4af7-8692-2248ce85a68e">
        <updating/>
        <source>doBtnLabourCancel() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;
	theReturn : Integer;
	dataChanged : Boolean;
begin
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	dataChanged := self.tblOther.hasChanged;
	if not dataChanged and theArea &lt;&gt; null then
		dataChanged := theArea.dataChanged;
	endif;
	if dataChanged  then
		theReturn := app.msgBox("You have changed data on this Labour Restriction." &amp; Cr &amp; "Do you want to save now?","Confirm Save",
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
		if theReturn = MsgBox_Return_Yes then
			self.doBtnLabourSave();
			return;
		endif;
	endif;

	self.tblOther.clearValues();
	self.mulNotifyEmails.setSelected( null );	//08 Jul 2015	NDL	Par 36588
	self.tblOther.showRowByName(ETRow_Expiry,false);
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(false);

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then
		self.frmGridArea.enabled := false;
		
		theArea.doLockAll(false);
		theArea.clearAllSelectedItems();
		theArea.editMode := false;	
		self.mySDF.drawSelf();

//		self.myCurrentObject := self.myCurrentSubBlockStack;
		self.displayLabour(self.myCurrentLabourRestriction);
	endif;
	
	
epilog
	delete self.myProxyLabourRestriction;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLabourEdit" id="549ae925-fa1e-49b4-8c51-105f2d4b717a">
        <updating/>
        <source>doBtnLabourEdit() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;

begin
	//self.lstRestrictions_click(self.lstRestrictions);						
	
	if self.myCurrentLabourRestriction = null then
		app.msgBox("Please select a Labour Restriction to Edit","Edit Labour Restriction",MsgBox_OK_Only);
		return;
	endif;
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.frmGridArea.enabled := true;
	self.tblOther.disableRowByName(ETRow_Expiry);

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then
		theArea.paintColour := self.myCurrentLabourRestriction.colour;
		theArea.editMode := true;	
		theArea.drawingMode := true;
		self.mySDF.drawSelf();
		theArea.drawingMode := false;
	endif;
	self.doEnableControls(true);

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLabourRemove" id="a607beb7-8224-462f-9a4c-8a9b5864e55f">
        <updating/>
        <source>doBtnLabourRemove() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	rtnValue : Boolean;
	theReturn,theIndex : Integer;
	theLCS : CM_LCArray;
	theLocations : CM_LCArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	self.frmGridArea.enabled := false;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Labour Restriction","Removing...");
	self.tblOther.clearValues();
	self.mulNotifyEmails.setSelected( null );	//08 Jul 2015	NDL	Par 36588
	self.tblOther.showRowByName(ETRow_Expiry,false);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRestrictionLabour(self.myCurrentLabourRestriction, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Labour Restriction', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentLabourRestriction := null;

	app.checkLabourRestrictionHook(self.myCurrentTerminalArea, theLocations); // PAR 21639 cnwgb1 28.4.2010

epilog
	self.frmModalDialog.visible := false;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLabourSave" id="45a45fd2-01de-48e2-865e-1b96896e9033">
        <updating/>
        <source>doBtnLabourSave() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 18/05/2021	navdap1		TFS 49899 MTN Labour on Block for New GC Areas
// ---------------------------------------------------------------------------

vars
	theLCS : CM_LCArray;
	result : Integer;
	aPoint : CMUI_GridPoint;
	loadStateSet : Boolean;
	aController : CM_LocationsController;
	newRestriction : CM_LabourRestriction;
	theLocations : CM_LCArray;
	theIndex : Integer;
	emails : CM_EmailAddressByAddressDict;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Labour Restriction","Saving...");
	// ################################
	// ### SET UP PROXY
	if self.myCurrentLabourRestriction &lt;&gt; null then
		theIndex := self.lstRestrictions.findObject(self.myCurrentLabourRestriction);
	else
		theIndex := self.getListIndexForAdd();
	endif;
	if self.mode = self.Mode_Add then
		// Create a proxy
		create self.myProxyLabourRestriction as CM_LabourRestriction transient;
	endif;
	
	create theLCS transient;
	if self.mode = self.Mode_Update then
		// keep these for updating GUI
		self.myCurrentLabourRestriction.allLocationControllers.copy(theLCS);
	
		app.cmsBeginLoad(loadStateSet);
		self.myProxyLabourRestriction := self.myCurrentLabourRestriction.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadStateSet);
	endif;	

	create theLocations transient;

	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
		if self.myCurrentTerminalArea.isKindOf(CM_Depot) then // PAR 8745
			theLocations.add(self.myCurrentTerminalArea.CM_Depot.myLocationsController);	 // PAR 8745
		else
			theLocations.add(self.myCurrentTerminalArea.CM_BlockStack.myLocationsController);	
		endif;
	else
		foreach aPoint in self.frmGridArea.myGridArea.allSelectedPoints do
			aController := aPoint.myLocationsController;
			if aController &lt;&gt; null then
				if not theLocations.includes(aController)then
					theLocations.add(aController);
				endif;
			endif;
		endforeach;
	endif;
	
	//08 Jul 2015	NDL	Par 36588
	create emails transient;
	self.mulNotifyEmails.getSelected(emails);
	
	self.myProxyLabourRestriction.setProxy(	self.tblOther.getValueByName(ETRow_Colour).Integer,
											app.getMyUserCode(),
											self.tblOther.getValueByName(ETRow_Comment).String, 
											self.tblOther.getValueByName(ETRow_DurationHours).Time, 
											self.tblOther.getValueByName(ETRow_DurationDays).Integer, 
											self.cmbReason.myObject.CM_LabourRestrictionReasonCode, 
											theLocations,
											self.tblOther.getValueByName(ETRow_Id).String,
											self.tblOther.getValueByName(ETRow_IgnoreLights).Boolean,
											self.cmbOrganisation.myObject.CM_Organisation,
											null,
											emails,					//_emails : CM_EmailAddressByAddressDict;
											self.myCurrentTerminalArea);
	
	self.modalDialogShow(null, 'Cancel', null, null, "Labour Restriction " &amp; self.myProxyLabourRestriction.id,"Saving...");
	// ################################
	// ### TRX IT
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateRestrictionLabour(self.myProxyLabourRestriction, newRestriction, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.myCurrentLabourRestriction := newRestriction.CM_LabourRestriction;
			endif;
			
		else
			app.myTrxUA.trxUpdateRestrictionLabour(self.myProxyLabourRestriction, self.myCurrentLabourRestriction, app.myPassport);			
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Labour Restriction', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	// ################################
	// ### CLEAN UP GUI
	self.frmGridArea.enabled := false;
	self.doEnableControls(false);
	self.displayLabour(self.myCurrentLabourRestriction);

	app.checkLabourRestrictionHook(self.myCurrentTerminalArea, theLocations); // PAR 21639 cnwgb1 28.4.2010
	
	self.doComboTermAreaClick(self.cmbTermAreas);							// TFS 49899
	if theIndex &gt; 0 and theIndex &lt;= self.lstRestrictions.listCount then		// TFS 49899
		self.lstRestrictions.listIndex := theIndex;							// TFS 49899
		self.lstRestrictions.click(self.lstRestrictions);					// TFS 49899
	endif;																	// TFS 49899
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	self.frmModalDialog.visible := false;
	delete self.myProxyLabourRestriction;
	delete theLocations;
	delete theLCS;
	delete emails;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSubAdd" id="28200032-f206-42b7-8f34-5bddcc3b46e2">
        <updating/>
        <source>doBtnSubAdd() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.frmGridArea.enabled := true;
	theArea :=self.frmGridArea.myGridArea.YRD_PadArea;
	self.tblOther.clearValues();

	self.doEnableControls(true);
	self.myCurrentSubBlockStack := null;
	theArea.doLockSubBlock(null);
	theArea.paintColour := Yellow;
	theArea.editMode := true;
	theArea.drawingMode := true;
	self.mySDF.drawSelf();
	theArea.drawingMode := false;
	self.tblOther.setValueByName(ETRow_StockControlled,self.myTerminal.getConfig(DefTAStockControlled).Boolean);

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSubCancel" id="b792454b-73d9-4b71-9de2-2dfb3f957218">
        <updating/>
        <source>doBtnSubCancel() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;
	theReturn : Integer;
	dataChanged : Boolean;
begin
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
		dataChanged := self.tblOther.hasChanged;
		if not dataChanged and theArea &lt;&gt; null then
			dataChanged := theArea.dataChanged;
		endif;
		if dataChanged  then
			theReturn := app.msgBox("You have changed data on this Sub Blockstack." &amp; Cr &amp; "Do you want to save now?","Confirm Save",
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
			if theReturn = MsgBox_Return_Yes then
				self.doBtnSubSave();
				return;
			endif;
		endif;
	self.tblOther.clearValues();

	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(false);
	
	theArea.doLockAll(false);
	theArea.clearAllSelectedItems();
	theArea.editMode := false;
	
	self.mySDF.drawSelf();
	self.frmGridArea.enabled := false;
	
	// reset this as can be cleared by inherited code.	
	self.myCurrentObject := self.myCurrentSubBlockStack;
	self.displaySBS(self.myCurrentSubBlockStack);
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSubEdit" id="2b1a5292-a3a4-4faf-ae00-7f8e2409feff">
        <updating/>
        <source>doBtnSubEdit() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;
begin
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	if self.myCurrentSubBlockStack = null then
		app.msgBox("Please select a Sub Block Stack to Edit","Edit Sub Block Stack",MsgBox_OK_Only);
		return;
	endif;

	self.frmGridArea.enabled := true;
	self.mousePointer := Window.MousePointer_HourGlass;
