        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMaintainSeal_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
*/

vars
	vvr		: CM_VehicleVisitRecord;
	tbl		: CM_DataTable;
	job		: CM_Job;
	frm 	: CMUI_SealObjectMaintForm;
begin
	tbl := menuItem.userObject.CM_DataTable;
	job	:= tbl.allSelectedObjects.first.CM_Job;
	
	if job.isKindOf(CM_RoadJob) then
		vvr := job.CM_RoadJob.myVehicleVisit;
	endif;
	
	if vvr = null then
		return;
	endif;
	
	frm := app.loadForm(CMUI_SealObjectMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_SealObjectMaintForm;
	
	if frm = null then
		return;
	endif;
	
	frm.setMyTerminal(self.myTerminal);	
	frm.setMySealedObject( vvr );
	frm.setRetroDT(vvr.allVehicleVisitRecordDetails.last.timeStart);		//01.03.2024 navhl20 #62705
	
	frm.show;
epilog

end;</source>
