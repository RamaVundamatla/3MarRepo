    <JadeMethod name="getMultiMoveDeckingInLocsFrom" id="5b78b32c-3f06-4d8d-acfb-1e4fb2925255">
        <source>getMultiMoveDeckingInLocsFrom(	_firstLocation : CM_LocationsController;
								_targetLocns : CM_LCArray io
								);

/*

Purpose:			

Parameters:		Get a collection of locations suitable for multi moves
				from a start location to the end based on the decking rules. 	

Return Value:		


Date		Who		Reason
22 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	yaLocnCells: CM_YALocationCellArray;
	yaCell : CM_YALocationCell;
	locn : CM_YardController;
	foundFirstOne : Boolean;

begin

	if self.myYADeckingOptions &lt;&gt; null then
		yaLocnCells := self.myYADeckingOptions.allYALocationCellsIn;
	endif;
	
	if yaLocnCells &lt;&gt; null then
		foreach yaCell in yaLocnCells do
			locn := yaCell.myYardController;
			if _firstLocation = null or _firstLocation = locn then
				foundFirstOne := true;
			endif;
			if not foundFirstOne then
				continue;
			endif;
			if yaCell.isAvailForMultiMove() then
				if locn &lt;&gt; null then
					_targetLocns.add( locn );
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_firstLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocns" type="CM_LCArray" usage="io"/>
    </JadeMethod>
