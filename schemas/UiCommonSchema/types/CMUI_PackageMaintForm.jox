    <JadeMethod name="doDelete" id="baf5eb31-8c6b-4ee2-97b0-4547156539b7">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

	result				: Integer;
	msgStr				: String;
	selectedObj 		: CM_Object;
	objectArray			: CM_ObjectArrayActual;
	obj					: CM_Object;					//navra1 - CR 61910//Task 62303 - 12th Feb 2024
	bankUsingPackage 	: Boolean;						//navra1 - CR 61910//Task 62303 - 12th Feb 2024
	
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then	   	
		msgStr := app.getErrorString(Sure_want_delete_select_packag);
	elseif self.myCurrentPackage &lt;&gt; null then
		selectedObj := self.myCurrentPackage;		
		msgStr := app.getErrorString1(Sure_want_delete_the_packag, self.myCurrentPackage.code);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
		if selectedObj &lt;&gt; null then
			//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - start
			if selectedObj.isKindOf(CM_PackageInvoice) then
				if selectedObj.CM_PackageInvoice.allBanks.size() &gt; 0 then					
					msgStr := app.getErrorString(Packa_selec_delet_confi_defau_);
					if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
						return;
					endif;
				endif;
			endif;
			//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - end
		  	app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		else
			create objectArray transient;
			self.tblData.allSelectedObjects.copy(objectArray);
			
			//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - start
			foreach obj in objectArray do
				if obj.isKindOf(CM_PackageInvoice) then
					if obj.CM_PackageInvoice.allBanks.size() &gt; 0 then
						bankUsingPackage := true;
					endif;
				endif;
			endforeach;
			
			if bankUsingPackage then
				msgStr := "Some packages selected for delete are configured as the default package for banks. Do you still want to delete them?";
				if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
					return;
				endif;			
			endif;
			//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - end
		  	app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);	
		endif;		  	  
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
