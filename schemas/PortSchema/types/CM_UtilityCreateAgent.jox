        <source>utlCreateWorkOrderTask(	_proxyTask : CM_WorkOrderDtl io; 
						_task : CM_WorkOrderDtl output;	
						_realWorkOrder : CM_WorkOrder;
						_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwmd1	Initial creation

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
