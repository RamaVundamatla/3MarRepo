    <JadeMethod name="isCMIFDataMatch" id="a7624ab7-9984-4391-a189-72e70d3fccf6">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

	
begin

	return _cmifAutoPlan.isThirty_Match(_yaData);
	
end;</source>
