/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation

*/

vars

	form : CMUI_ComboFilterSelectionForm;
	tbl : CM_EntryTable;
	maxRows,
	idx	: Integer;
	entRowTrans : EntTableRowTransient;
	row1Text : String;
	pControlName : String;

begin

	if self.myTerminal.getConfig(CarrierCmbFilter).Boolean then
	
		tbl := comboBox.parent.CM_EntryTable;
		if not CM_EntryTable.hasInstance(comboBox.parent) then
			return;
		endif;
		
		pControlName := comboBox.name;
		
		maxRows := tbl.allEntRowTransients.size;
		foreach idx in 1 to maxRows do
			entRowTrans := tbl.allEntRowTransients[idx].EntTableRowTransient;
			if entRowTrans.controlName = pControlName then
				row1Text := tbl.accessCell(idx,1).text;
				break;
			endif;
		endforeach;
	
		create form transient;
		form.setMyRelatedCombo( self, comboBox.CMUI_ComboBox, row1Text );
		form.showModal();
		
		self.cmbRelCarrier_lostFocus(self.cmbRelCarrier);
		
	endif;

epilog

end;</source>
