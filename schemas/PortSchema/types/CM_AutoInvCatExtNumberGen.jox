        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="currSeq" id="60fec307-cf71-4cbe-95ee-1076543e0061">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="currYear" id="51503f82-6820-436c-906e-7b1fc140d3b2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myBusinessUnit" id="3eb7cb34-945e-4c14-933b-c52cebf294b1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
