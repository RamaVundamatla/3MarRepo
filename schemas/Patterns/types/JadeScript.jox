<Class name="JadeScript">
    <JadeMethod name="printTest1" id="020863ae-2d40-4b12-a89e-d36a44674ec4">
        <source>printTest1();
//18 August 2009	cnwdw1	
//
vars
	car: Car;
begin
	create car transient;
	car.print();
epilog
	delete car;
end;</source>
    </JadeMethod>
    <JadeMethod name="strategyTest1" id="27891737-5651-47fc-903c-e3f79942a24a">
        <source>strategyTest1();
//25 August 2009	cnwdw1	
//
vars
	duck1, duck2: Duck;
begin

	create duck1 as MallardDuck transient;
	duck1.fly;
	duck1.quack;
	
	create duck2 as RubberDuck transient;
	duck2.fly;
	duck2.quack;

epilog
	delete duck1;
	delete duck2;
end;</source>
    </JadeMethod>
    <JadeMethod name="visitorTest1" id="4d9af7e5-22f1-4ae2-a871-1985d0abb989">
        <source>visitorTest1();
//18 August 2009	cnwdw1	
//
vars
	car: Car;
	visitor: CarElementPrintVisitor;
begin

	create car transient;
	
	create visitor transient;
	
	visitor.visitCar(car);
epilog
	delete car;
	delete visitor;
end;</source>
    </JadeMethod>
    <JadeMethod name="visitorTest2" id="b43a9770-fa3e-4f5f-b5a0-622699a7fe4c">
        <source>visitorTest2();
//18 August 2009	cnwdw1	
//
vars
	car: Car;
	printVisitor: CarElementPrintVisitor;
	doVisitor: CarElementDoVisitor;
begin

	create car transient;
	
	create printVisitor transient;
	create doVisitor transient;
	
	printVisitor.visitCar(car);
	doVisitor.visitCar(car);
epilog
	delete car;
	delete printVisitor;
	delete doVisitor;
end;</source>
    </JadeMethod>
</Class>
