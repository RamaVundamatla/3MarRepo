    <JadeMethod name="create" id="2e433c9e-eb63-410b-8fb5-30fbe6b01e86">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2003 by cnwrs2
//
// Purpose:     
