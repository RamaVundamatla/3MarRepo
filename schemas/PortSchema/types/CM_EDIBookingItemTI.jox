    <JadeMethod name="translateCommodity" id="c50082e1-2316-435c-98ab-8ff2bc174b06">
        <updating/>
        <source>translateCommodity(_xlationOperator : CM_Operator) updating, protected;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//11 Sep 2015   cnwma1  PAR #36737 COPARN Booking Commodity
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	commodityObj : CM_Commodity;
	mtCmdty : String;
	defCmdty : String;
	refCmdty : String;
	hazCmdty : String;
	value : String;
	code : String;
	foundMatch : Boolean;
	iftmbc96bFile : Boolean;
begin
	inheritMethod(_xlationOperator);
//	self.translateCommodityWithDescr(_xlationOperator);
//	if self.commodity = null then
//		self.commodity := self.commodityDescription[1:4];
//	endif;
	iftmbc96bFile := (self.myEDIData.ediFileCode = EDIFileType_IFTMBC96B);
	if iftmbc96bFile then
		value := self.commodityDescription;
	
		if value &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then
				code := _xlationOperator.getXlationSystemCode_Commodity(value, foundMatch, self.temperature)[1:4];
			endif;
					
			if foundMatch then
				self.commodity := code;
			else
				self.commodity := self.commodityDescription[1:4];
			endif;
		endif;
		if self.commodity &lt;&gt; null and
		   self.getMyTerminal.getConfig(EdiBookingCommodity).Boolean then
			commodityObj := app.myRoot.allCommodities[self.commodity];
			if commodityObj = null then
				self.commodity := null;
			endif;
		endif;
		if self.commodity = null then
			app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);	
			if self.fullOrMT = "E" then
				self.commodity := mtCmdty;
			endif;
			if self.isHazardous then
				self.commodity := hazCmdty;
			endif;
			if self.temperature &lt;&gt; NULL_TEMPERATURE then
				// if we don't have a commodity xlation by now it is a reefer 
				self.commodity := refCmdty;
			endif;
			if self.commodity = null then
				self.commodity := defCmdty;
			endif;
		endif;
	else
		if self.commodity &lt;&gt; null and
		   self.getMyTerminal.getConfig(EdiBookingCommodity).Boolean then
			commodityObj := app.myRoot.allCommodities[self.commodity];
			if commodityObj = null then
				self.commodity := null;
			endif;
		endif;
		if self.commodity = null then
			if self.getMyTerminal.getConfig(EdiBookingCommodity).Boolean then
				app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);	
				if self.fullOrMT = "E" then
					self.commodity := mtCmdty;
				endif;
				if self.isHazardous then
					self.commodity := hazCmdty;
				endif;
				if self.temperature &lt;&gt; NULL_TEMPERATURE then
					// if we don't have a commodity xlation by now it is a reefer 
					self.commodity := refCmdty;
				endif;
				if self.commodity = null then
					self.commodity := defCmdty;
				endif;
			else
				self.commodity := self.commodityDescription[1:4];
			endif;
		endif;
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="validateIMCodesForVerify" id="1fe4dcaf-b287-49bd-bb06-c246a39490c7">
        <source>validateIMCodesForVerify();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 12/03/2010	cnwsh3		PAR22880
// Validate the hazard codes that have been included in the imCodes actually
// exist in the system.
//----------------------------------------------------------------------
vars
	hazCode : String;
	
begin
//PAR25648
//Was being called from CM_EDIDataBooking.verifyEDIDataTIs but didn't work for IFTMCS files.
//Taken out the validation for the time being as this was raised internally and customers who have upgraded to 7.8.2 
//are having problems loading EDI booking files. 
	foreach hazCode in self.imCodes do
		if app.myRoot.allHazardClasses[hazCode] = null then
			app.raiseCMException2(ERR_InvalidHazardForBooking, hazCode, self.id, CM_EDIBookingItemTI::imCodes.name, self);
		endif;
	endforeach;
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="validateLinkedBookingIDs" id="720ab524-263c-4c00-860c-f806fc0915a4">
        <updating/>
        <source>validateLinkedBookingIDs(
	_ediHeader	: CM_EDIBookingHeaderTI;
	_terminal	: CM_Terminal;
	_operator	: CM_Operator;
	_voyage		: CM_Voyage ) updating;
	
/*
Purpose:	Validate the Linked Booking IDs entered, there can be none, one or many booking ids entered.
			To be valid the entered booking ids must be:
			1) This Booking must be for an Stock booking
			2) The operator and voyage must be entered and valid.
			3) Not the same as this booking.
			4) The linked booking must be an existing booking for this operator and voyage.
			5) The linked booking must be an export booking.
			
			NOTE: This list of IDs is assummed to be space separated if the ID is to
			contain a space then it must be inclosed in a matching single quote.

Date				Who		Reason
15 April 2010		cnwrl1	Initial creation as part of PAR 23624 - Add new fields to EDI Booking
*/
//06 June 2014	cnwrs1	par34261 find booking for the booking reaf and voyage specified.
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//	
vars
	idString		: String;
	allIDsString	: String;
	bookingIDs		: StringArray;
	bookingRef		: CM_BookingRef;
	
begin
	allIDsString	:= self.linkedBookingIDs.trimBlanks;
	if allIDsString = null then
		return;					// nothing to validate so everything must be OK.
	endif;
	
	if _ediHeader = null then
		// will have other more major errors to fix, so just return in this method.
		return;
	endif;
	
	// Make sure the booking we are attempting to linked to is a stock booking.
	if not _ediHeader.isStockBookingRef then
		app.raiseCMException1(	Booking_MustBe_StockBooking,
								_ediHeader.id,
								ETRow_Id,
								self );
		return;
	endif;
	
	if _operator = null or _voyage = null then		// Note that the _voyage can be the NULL voyage.
		app.raiseCMException3(	Booking_Requires_Oper_Voyage,
								allIDsString,
								_ediHeader.operatorCode,
//								_ediHeader.voyageCode,	// cnwrl1 09/06/2010 PAR 24299 - what it was
								_ediHeader.getVoyageCode(),
								ETRow_LinkedBookingIDs,
								self );
		return;
	endif;
	if _voyage.allOperators[_operator.code] = null then
		app.raiseCMException3(	Booking_Requires_Oper_Voyage,
								allIDsString,
								_ediHeader.operatorCode,
								_ediHeader.getVoyageCode(),
								ETRow_LinkedBookingIDs,
								self );
		return;
	endif;
	
	// OK if got to here the very basic validation is OK.
	create bookingIDs transient;
	
	// Break the Linked Booking IDs into separate IDs.
	// Convert all single quotes into double quotes (neither are allowed in the IDs).
	allIDsString	:= allIDsString.cnEcFindReplace( SingleQuote, DoubleQuote, false );
	
	// Add each of the IDs into the array delimited on Space.
	allIDsString.csvToStringArray( bookingIDs, Space.Character );
	
	// Now for each of these IDs in turn do the required validation
	foreach idString in bookingIDs do
		// make sure not linking to ourselves.
		if idString = self.id then
			app.raiseCMException1(	Cannot_Link_Booking_To_Self,
									idString,
									ETRow_LinkedBookingIDs,
									self );
			continue;
		endif;
		
		// make sure the booking exists for this operator/voyage.
		bookingRef	:= _terminal.getBookingReferenceForVoyage(idString, _voyage);	//06 June 2014	cnwrs1	par34261 find booking for the booking reaf and voyage specified.
		if bookingRef = null then
			//10 Mar 2017	NDL	TFS 3703 - its OK if its not there as long as we are adding this one too.
			if self.myEDIData.allEDITrackedItems.includesStockBook(	idString,
																	_operator.code,
																	_voyage.code
																	) then
				continue;
			endif;
			
			app.raiseCMException3(	Booking_DoesNotExist4_OpVoyage,
									idString,
									_operator.code,
									_voyage.code,
									ETRow_LinkedBookingIDs,
									self );
			continue;
		endif;
		
		// make sure it is an export booking.
		if bookingRef.isStockBookingRef then
			app.raiseCMException1(	Cannot_Link_NoneExport_Booking,
									idString,
									ETRow_LinkedBookingIDs,
									self );
			continue;
		endif;
	endforeach;
	
epilog
	delete bookingIDs;
	
end;
</source>
        <Parameter name="_ediHeader" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateTemperature" id="ce38113b-33f7-4d90-a1bf-4531130b4fec">
        <source>validateTemperature();
// --------------------------------------------------------------------------------
// Created:		18 November 2010 par 26085
//
// Purpose:		Validates the receiver's temperature. Implemented for PAR #26085.
//
// Rules:
//
// 	1.	If a temperature exists (i.e. the field is not NULL_TEMPERATURE), then the Commodity must
//		have a temperature range, and the temperature must fall within that range.
//
// 	1.	If a temperature exists (i.e. the field is not NULL_TEMPERATURE), then the ISO Type must
//		be powered, and the Commodity must have a temperature range.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
//30/12/2o14    cnwgb1      PAR 33710 Have yet to apply defaults so some validation may be premature
// --------------------------------------------------------------------------------
vars
	rootObj			: CM_Root;
	commodityObj	: CM_Commodity;
	isoTypeObj		: CM_ISOType;
	
begin
	rootObj	:=	app.myRoot;
	
// cnwdad1 22/11/2010.
	if self.temperature = NULL_TEMPERATURE then
		return;
	endif;
	
	commodityObj	:=	rootObj.allCommodities[self.commodity];
	isoTypeObj		:=	rootObj.allISOTypes[self.isoType];
	
	if commodityObj = null then
		if self.commodity = null then
			app.raiseCMException( ERR_NO_COMMODITY_TEMP,
									ETRow_Commodity,
									self );
		endif;
		/*app.raiseCMException1(	ERR_INVALID_COMMODITY,
								self.commodity,
								ETRow_Commodity,
								self);*/
	endif;
	
	if isoTypeObj = null then
		app.raiseCMException2(	ERR_FIELD_VALUE,
								self.isoType,
								app.getString(ISO_Type),
								ETRow_ISOType,
								self);
	endif;
	
	if commodityObj = null or isoTypeObj = null then
		return;
	endif;
	
	if self.temperature &lt;&gt; NULL_TEMPERATURE then
		if commodityObj.hasTemp then
			if not self.temperature.isBetween(commodityObj.minTemp, commodityObj.maxTemp) then
				app.raiseCMException4(	VB_TEMP_VALIDATION,
										app.temperatureDisplayString(self.temperature),
										self.id,
										app.temperatureDisplayString(commodityObj.minTemp),
										app.temperatureDisplayString(commodityObj.maxTemp),
										ETRow_Temperature,
										self);
			endif;
		else
			app.raiseCMException2(	ERR_Commodity_does_not_require,
									self.id,
									app.getErrorString(CM_TemperatureExtra),
									ETRow_Temperature,
									self);
		endif;
		
		if not isoTypeObj.isPowered() then
			app.raiseCMException(	Has_Temp_ISOType_Not_Powered,
									ETRow_ISOType,
									self);
		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
