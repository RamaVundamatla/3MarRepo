end;</source>
        <ReturnType type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPosUnderGCLoad" id="14ad04ef-65c4-409f-a140-91ecda3ecc24">
        <source>hideContainerPosUnderGCLoad(_layout : CM_DeckItemLayout input);
/*

Date		Who		Reason
18 September 2013	cnwer1	Initial creation PAR 32488 when unrotating in load mode have to check if covered by gc jobs

*/

vars
	iter : Iterator;
	deckLayout : CM_DeckLayerLayout;
begin
	iter :=self.allDeckLayerLayouts.createIterator;

	
	while iter.next(deckLayout) do 
		if not deckLayout.isVisible then
			continue;
		endif;
		
		if deckLayout.type &lt;&gt; ROROLayerType_CCLoad then
			continue;
		endif;
		
		deckLayout.hideContainerPosUnderGCLoad(_layout);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_layout" type="CM_DeckItemLayout" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPositionsUnderGA" id="b04d7524-0888-4896-a0fd-4fb601967754">
        <source>hideContainerPositionsUnderGA(_gcLayout : CM_DeckItemLayout);
/*
Purpose: 29178 pass in the Equipment or General Area  polygon 'hide' any container positions that are inside the poly. By hide mean set reference.			
Date				Who			Reason
MARCH 2012		CNWAB1		Initial creation
*/

vars
	iter : Iterator;
	deckLayout : CM_DeckLayerLayout;
begin
	iter :=self.allDeckLayerLayouts.createIterator;

	_gcLayout.showAllCoveredPolygons(); 

	
	while iter.next(deckLayout) do 
		if not deckLayout.isVisible then
			continue;
		endif;

		deckLayout.hideContainerPositionsUnderGA(_gcLayout);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_gcLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPositionsUnderGC" id="bcf0bdb0-4a8c-4412-98f3-1086b513822c">
        <source>hideContainerPositionsUnderGC(_gcLayout : CM_DeckItemLayout);
/*
Purpose: pass in the GC polygon 'hide' any container positions that are inside the poly. By hide mean set reference.			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/

vars
	iter : Iterator;
	deckLayout : CM_DeckLayerLayout;
begin
	iter :=self.allDeckLayerLayouts.createIterator;

	_gcLayout.showAllCoveredPolygons(); // PAR 29066

	
	while iter.next(deckLayout) do 
		if not deckLayout.isVisible then
			continue;
		endif;
		
		
		if  deckLayout.type = ROROLayerType_Structure then
		
			deckLayout.hidePillarsUnderGC(_gcLayout);
			continue;
		endif;

		deckLayout.hideContainerPositionsUnderGC(_gcLayout);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_gcLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="efeba828-2df0-4c78-a676-0b767a4a815a">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	allDeckLayerLayoutElements : JadeXMLElementArray;
	deckLayerLayoutElement 	: JadeXMLElement;
	deckLayerLayout 			: CM_DeckLayerLayout;	
begin
	if _property = CM_DeckLayout::allDeckLayerLayouts then
		create allDeckLayerLayoutElements transient;
		_xmlElement.getAllElementsByTagName(CM_DeckLayerLayout.name,allDeckLayerLayoutElements);
		
		foreach deckLayerLayoutElement in allDeckLayerLayoutElements do
			create deckLayerLayout transient;
			deckLayerLayout.setDeckLayout(self);
			deckLayerLayout.importFromXMLDoc(deckLayerLayoutElement);
		endforeach;	
	endif;

epilog
	delete allDeckLayerLayoutElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="matchOrderOfLayers" id="c78e91a7-4204-4d90-ac1d-25dd2b5e699a">
        <updating/>
        <source>matchOrderOfLayers(_newOrder : CM_ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	tmpLayer, realLayer : CM_DeckLayerLayout;
	objs, objs2 : CM_ObjectArray;
	obj : Object;
begin
	create objs transient;
	create objs2 transient;

	self.allDeckLayerLayouts.copy(objs);
	
	// DETTACH LAYERS
	foreach obj in objs discreteLock do
		if obj.CM_DeckLayerLayout.isDefinable() then 		//cnwmc5 - 17/01/2013 - PAR #30969
			realLayer := obj.CM_DeckLayerLayout;
			realLayer.setDeckLayout(null);
		endif;
	endforeach;
	
	// REORDER LAYERS
	foreach obj in _newOrder discreteLock do
		tmpLayer := obj.CM_DeckLayerLayout;
		realLayer := tmpLayer.pxyGetRealObject().CM_DeckLayerLayout;
		if realLayer = null then
		
		endif;
		objs2.add(realLayer); // NEW ORDER
	endforeach;
	// REATTACH LAYERS
	foreach obj in objs2 discreteLock do
		tmpLayer := obj.CM_DeckLayerLayout;
		tmpLayer.setDeckLayout(self);
		tmpLayer.setOrderOnAllLocations();
	endforeach;
	
	
epilog
	delete objs;
	delete objs2;
end;</source>
        <Parameter name="_newOrder" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="moveCCLayersToTop" id="7d777cfa-5c0d-4ce2-ba49-f869f6bff2d4">
        <source>moveCCLayersToTop() ;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	realCC, layerDisch, layerLoad : CM_DeckLayerLayout;
	found : Boolean;
begin
	foreach realCC in self.allDeckLayerLayouts discreteLock where realCC.type = ROROLayerType_CCDischarge do
		layerDisch := realCC;
	endforeach;
	foreach realCC in self.allDeckLayerLayouts discreteLock where realCC.type = ROROLayerType_CCLoad do
		layerLoad := realCC;
	endforeach;

	self.moveLayerToTop(layerDisch); 
	self.moveLayerToTop(layerLoad); 
	

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="moveLayerToTop" id="fa4f4e9c-ec1e-409a-bc1e-ac9fb489716b">
        <source>moveLayerToTop(_layer : CM_DeckLayerLayout input);
/*
Purpose:			
Date		Who		Reason
14 June 2011	cnwab1	Initial creation
*/

vars

begin
	if _layer = null then
		return;
	endif;
	
	if not self.allDeckLayerLayouts.includes(_layer) then
		return;
	endif;
	
	_layer.moveLayerToTop();
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="813e8c2d-0d41-4e31-8bb0-ad7b423ac752">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyMe.myDeck := self.myDeck.pxyGetProxyObject();
	if pxyMe.myDeck = null then
		pxyMe.myDeck := self.myDeck;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCeateNonStructuralLayers" id="ba9eb57c-7079-4e8b-8329-7411abbb0e2c">
        <source>setForCeateNonStructuralLayers();
/*
Purpose:	
Date		Who		Reason
17 August 2012	cnwab1	Initial creation
*/

vars

begin
	self.getGCLayer();
	self.getCCDischargeLayer();
	self.getCCLoadLayer();
	self.getOOTLLayer();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d27ae9e9-2ba8-4795-a159-415f4408a848">
        <updating/>
        <source>setForCreate(_pxyMe : CM_DeckLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	
	self.myDeck := _pxyMe.myDeck.pxyGetRealObject();
	if self.myDeck = null and not _pxyMe.myDeck.isTransient then	// 34541 Oct 2014 prevent persistent - transient error in copy
		self.myDeck := _pxyMe.myDeck;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_DeckLayout"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="ff9d15fc-b383-4ca4-9e2c-b8fea461a776">
        <updating/>
        <source>setForCreateImport(_proxyLayout : CM_DeckLayout input; _passport : CM_Passport input) updating ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	pxyDeckLayerLayout,realDeckLayerLayout : CM_DeckLayerLayout;
begin
	self.code := _proxyLayout.code;
	self.description := _proxyLayout.description;
	self.remarks := _proxyLayout.remarks;

	
	foreach pxyDeckLayerLayout in _proxyLayout.allDeckLayerLayouts discreteLock do
		create realDeckLayerLayout persistent;
		realDeckLayerLayout.setDeckLayout(self);
		realDeckLayerLayout.setForCreateImport(pxyDeckLayerLayout,_passport);
		
		
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_proxyLayout" type="CM_DeckLayout" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="60661df2-e0ce-4b1c-8fcc-d18b396c4b78">
        <updating/>
        <source>setForUpdate(_pxyMe : CM_DeckLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyDeckLayerLayout, realDeckLayerLayout : CM_DeckLayerLayout;
	pxyDeckItemLayout, realDeckItemLayout : CM_DeckItemLayout;
	idx, cnt : Integer;
	idxItem, cntItem : Integer;
begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	
	cnt := self.allDeckLayerLayouts.size;
	foreach idx in 1 to cnt do
		realDeckLayerLayout := self.allDeckLayerLayouts[idx];
		pxyDeckLayerLayout := realDeckLayerLayout.pxyGetProxyObject();
		if pxyDeckLayerLayout = null then
			app.myUtilityDA.utlDeleteDeckLayerLayout(realDeckLayerLayout, app.myPassport);
		endif;
	endforeach;
	
	cnt := _pxyMe.allDeckLayerLayouts.size;
	foreach idx in 1 to cnt do
		pxyDeckLayerLayout := _pxyMe.allDeckLayerLayouts[idx];
		realDeckLayerLayout := pxyDeckLayerLayout.pxyGetRealObject();
		// CREATE
		if realDeckLayerLayout = null then
			pxyDeckLayerLayout.setDeckLayout(self);
			app.myUtilityCA.utlCreateDeckLayerLayout(pxyDeckLayerLayout, realDeckLayerLayout, false, app.myPassport);  // PAR 28330
			// ### join pxy and real
			app.myProxyManager.createProxyLink(realDeckLayerLayout, pxyDeckLayerLayout);
			
			cntItem := pxyDeckLayerLayout.allDeckItemLayouts.size;
			foreach idxItem in 1 to cntItem do
				pxyDeckItemLayout := pxyDeckLayerLayout.allDeckItemLayouts[idxItem];
				create realDeckItemLayout;
				realDeckItemLayout.setForCreate(pxyDeckItemLayout);
				
			endforeach;
		// UPDATE
		else
			app.myUtilityUA.utlUpdateDeckLayerLayout(pxyDeckLayerLayout, app.myPassport);
		endif;
	endforeach;
epilog
	delete pxyDeckLayerLayout;
end;</source>
        <Parameter name="_pxyMe" type="CM_DeckLayout"/>
    </JadeMethod>
    <JadeMethod name="setMyDeck" id="e2e6686f-c374-41d9-ad51-dbf380609895">
