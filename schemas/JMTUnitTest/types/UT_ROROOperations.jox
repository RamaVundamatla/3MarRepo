        <source>tRotatingROROCellsBoth() updating;
// cnwmp6
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2012	cnwmc5	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.createVesselVoyage("UTMC_RORO_2", "UTMCRORO1", null);
	
