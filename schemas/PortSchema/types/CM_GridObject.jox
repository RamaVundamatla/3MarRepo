    <JadeMethod name="applyDeckingRuleIn" id="41b65c85-5d36-4301-a7e6-c0e329ae1c20">
        <source>applyDeckingRuleIn(_rule: CM_YADeckingRule; _gridObjectIndex: Integer io; _allYALocationCellsIn: CM_YALocationCellArray input);
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridCntrlDict	: CM_MemberKeyDictionary;
	theRuleType		: Integer;
	gridController	: Object;
	intLayer		: Integer;
begin
	theRuleType := _rule.deckingRuleType;



	gridCntrlDict := self.getDictForDecking();


	if theRuleType = Height_Then_Next_Col_Pos
	or theRuleType = Height_Then_Next_Row_Pos then
		foreach gridController in gridCntrlDict do
			gridController.CM_YardController.setForDeckingIn(_rule.heightFrom, _rule.heightTo, _allYALocationCellsIn, _gridObjectIndex);
		endforeach;
	elseif theRuleType = Layer_Then_First_Col_Pos
	or theRuleType = Layer_Then_First_Row_Pos then
		foreach intLayer in _rule.heightFrom to _rule.heightTo do
			foreach gridController in gridCntrlDict do
				gridController.CM_YardController.setForDeckingIn(intLayer, intLayer, _allYALocationCellsIn, _gridObjectIndex);
			endforeach;
		endforeach;
	elseif theRuleType = Height_Then_Prev_Col_Pos
	or theRuleType = Height_Then_Prev_Row_Pos then
		foreach gridController in gridCntrlDict reversed do
			gridController.CM_YardController.setForDeckingIn(_rule.heightFrom, _rule.heightTo, _allYALocationCellsIn, _gridObjectIndex);
		endforeach;
	elseif theRuleType = Layer_Then_Last_Col_Pos
	or theRuleType = Layer_Then_Last_Row_Pos then
		foreach intLayer in _rule.heightFrom to _rule.heightTo do
			foreach gridController in gridCntrlDict reversed do
				gridController.CM_YardController.setForDeckingIn(intLayer, intLayer, _allYALocationCellsIn, _gridObjectIndex);
			endforeach;
		endforeach;
	endif;

end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridObjectIndex" type="Integer" usage="io"/>
        <Parameter name="_allYALocationCellsIn" type="CM_YALocationCellArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applyDeckingRuleOut" id="3b414076-0b35-4d9f-905c-f71b1122f3b5">
        <source>applyDeckingRuleOut(_rule: CM_YADeckingRule; _gridObjectIndex: Integer io; _allYALocationCellsOut: CM_YALocationCellArray input);
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridCntrlDict	: CM_MemberKeyDictionary;
	theRuleType		: Integer;
	gridController	: Object;
	intLayer		: Integer;
begin
	theRuleType := _rule.deckingRuleType;



	gridCntrlDict := self.getDictForDecking();


	if theRuleType = Height_Then_Next_Col_Pos
	or theRuleType = Height_Then_Next_Row_Pos then
		foreach gridController in gridCntrlDict do
			gridController.CM_YardController.setForDeckingOut(_rule.heightFrom, _rule.heightTo, _allYALocationCellsOut, _gridObjectIndex);
		endforeach;
	elseif theRuleType = Layer_Then_First_Col_Pos
	or theRuleType = Layer_Then_First_Row_Pos then
		foreach intLayer in _rule.heightTo to _rule.heightFrom step-1 do
			foreach gridController in gridCntrlDict do
				gridController.CM_YardController.setForDeckingOut(intLayer, intLayer, _allYALocationCellsOut, _gridObjectIndex);
			endforeach;
		endforeach;
	elseif theRuleType = Height_Then_Prev_Col_Pos
	or theRuleType = Height_Then_Prev_Row_Pos then
		foreach gridController in gridCntrlDict reversed do
			gridController.CM_YardController.setForDeckingOut(_rule.heightFrom, _rule.heightTo, _allYALocationCellsOut, _gridObjectIndex);
		endforeach;	
	elseif theRuleType = Layer_Then_Last_Col_Pos
	or theRuleType = Layer_Then_Last_Row_Pos then
		foreach intLayer in _rule.heightTo to _rule.heightFrom step-1 do
			foreach gridController in gridCntrlDict reversed do
				gridController.CM_YardController.setForDeckingOut(intLayer, intLayer, _allYALocationCellsOut, _gridObjectIndex);
			endforeach;
		endforeach;
	endif;

end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridObjectIndex" type="Integer" usage="io"/>
        <Parameter name="_allYALocationCellsOut" type="CM_YALocationCellArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applyDeckingRulesToCellOrder" id="82276699-5d60-4b34-b316-a4e5fefc8b28">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule		: CM_YADeckingRule;
	index		: Integer;
begin
	//the rules have just been updated - we need to rearrange the YALocnCells based on new rules

	index := 0;
	//IN
	foreach rule in self.myDeckingOptions.allDeckingRulesIn do
		self.applyDeckingRuleIn(rule, index, self.myDeckingOptions.allYALocationCellsIn);
	endforeach;
	
	index := 0;
	//OUT
	foreach rule in self.myDeckingOptions.allDeckingRulesOut do
		self.applyDeckingRuleOut(rule, index, self.myDeckingOptions.allYALocationCellsOut);
	endforeach;
	
end;</source>
    </JadeMethod>
