    <JadeMethod name="crc16" id="b8967bc3-3856-4349-b300-121b9f97845f">
        <source>crc16(_code : String) : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 May 2007 By cnwmo1

Purpose:	returns CRC16 checksum as a string

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	crc16	: Integer;
	n		: Integer;
	char	: Character;
	poly	: Integer;
	i 		: Integer;
	//shift : String;
	messageLength 	: Integer;
begin

	crc16 := #ffff; // initialize the register CRC16 to 0xFFFF (all ones)
	poly := #A001;
	
	messageLength := _code.length;
	
	foreach i in 1 to messageLength do 
			char  := _code[i]; // get byte
			crc16 := char.Integer.bitXor(crc16);
			foreach n in 1 to 8 do	
				if crc16.bitAnd(1) &lt;&gt; 0 then // check if there is a carry
					crc16 := crc16.rightBitShift(1); //shift right
					crc16 := crc16.bitXor(poly); // CRC16 XOR with the polynomial
				else
					crc16:=crc16.rightBitShift(1); // shift right
				endif;
			endforeach;	
	endforeach;
	
	
	return crc16.asHexReversed(4);
	
end;

</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createActivityHistory" id="120e207c-5eb9-4b78-800b-43b3e2c87f01">
        <source>createActivityHistory(_type : Integer; _terminal : CM_Terminal; _objectForExtraDetail : Object; _description : String; _insideTransaction : Boolean; _temp: Boolean);
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars
	activityHistory : CM_ActivityHistory;
	alert			: CM_SystemAlert;
	detail			: String;
begin
	if  app.isSDSSecondaryDB() then	// CCMS1150 cnwrs1 10 June 2011
		return;
	endif;
	if _type = ActivityHistoryGeneral then
		create activityHistory as CM_ActivityHistoryGeneral transient;
	elseif _type = ActivityHistoryEmail then
		create activityHistory as CM_ActivityHistoryEmail transient;
	elseif _type = ActivityHistoryCams then
		create activityHistory as CM_ActivityHistoryCams transient;
	elseif _type = ActivityHistoryEDI then
		create activityHistory as CM_ActivityHistoryEDI transient;
	elseif _type = ActivityHistoryDBPurge then
		create activityHistory as CM_ActivityHistoryDBPurge transient;
	elseif _type = ActivityHistoryLoadrite then
		create activityHistory as CM_ActivityHistoryLoadrite transient;
	elseif _type = ActivityHistoryGeneralSys then	//04 Mar 2015	NDL	Par 34583
		create activityHistory as CM_ActivityHistoryGeneralSys transient;
	elseif _type = ActivityHistoryUnitTest then
		create activityHistory as CM_ActivityHistUnitTest transient ; // 02/06/2015 cnwdb2
	elseif _type = ActivityHistoryExtInterface then	//17 Apr 2018	NDL	TFS 38135
		create activityHistory as CM_ActivityHistoryExtInterface transient;
	endif;
	
	if activityHistory = null then
		return;
	endif;
	
	activityHistory.setProxy(_type, _terminal, _temp);
	activityHistory.setDescription(_description);	
	if global.isValidObject(_objectForExtraDetail) then
		_objectForExtraDetail.setExtraActivityHistory(activityHistory);
	endif;
	
	if _insideTransaction then
		app.myUtilityCA.utlCreateActivityHistory(activityHistory, app.myPassport);
	else
		app.myTrxCA.trxCreateActivityHistory(activityHistory, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			detail := app.getErrorString(FailedToCreateActivityHist);
			app.remoteErrorWarningToAlert(detail, null , app.myPassport.allErrors, null, false, false);
		endif;
	endif;

epilog
	delete activityHistory;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_objectForExtraDetail" type="Object"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_insideTransaction" type="Boolean"/>
        <Parameter name="_temp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAlert" id="c563e056-e970-4ba0-9028-02566b4af234">
        <source>createAlert(_details : String; _doCommit : Boolean);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	alert	: CM_SystemAlert;

begin

	create alert transient;
	alert.details := _details;
	if _details.containsOneOf(CrLf) then
		alert.addLogEntry(_details);
	endif;
	
//	app.outputProcessStackToAlert(alert);
	alert.setSeverity(SEVERE_ERROR);
	alert.add;
	if _doCommit then
		app.commitAlert();
	endif;

end;</source>
        <Parameter name="_details" type="String"/>
        <Parameter name="_doCommit" type="Boolean"/>
    </JadeMethod>
