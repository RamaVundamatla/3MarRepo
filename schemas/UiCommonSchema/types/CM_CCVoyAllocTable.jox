    <JadeMethod name="addCCVoyAllocTableRow" id="62581ab4-d7da-4100-aef9-645fb1903e81">
        <updating/>
        <source>addCCVoyAllocTableRow( _ccVoyAllocRow : CMIF_CCVoyAllocRow ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	str : String;
	rowIndex : Integer;
	row : JadeTableRow;
	nameCellColour : Integer;
	nameCellColumnIndex : Integer;
	cell :  JadeTableCell;

begin

	str := _ccVoyAllocRow.getTableRowDataDisplay( nameCellColour );
	self.rows := self.rows + 1;
	rowIndex := self.rows;
	self.setCellText( rowIndex, 1, str );
	
	row := self.accessRow( rowIndex );
	row.itemObject := _ccVoyAllocRow.myVoyageAllocation;
	row.gridBottom := false;
	row.gridRight := false;
	
	nameCellColumnIndex := self.getColumnByRowName( ETRow_AllocName );
	cell := self.accessCell( rowIndex, nameCellColumnIndex );
	cell.backColor := nameCellColour;
	cell.foreColor := nameCellColour.getInverseColour;
	
epilog

end;</source>
        <Parameter name="_ccVoyAllocRow" type="CMIF_CCVoyAllocRow"/>
    </JadeMethod>
