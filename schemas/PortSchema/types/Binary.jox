    <JadeMethod name="reverse" id="c016b22a-d647-4374-a20b-837af35033db">
        <source>reverse(): Binary;

vars
	out:  Binary;
	i:    Integer;
	len:  Integer;
begin
	len := length;
	foreach i in 1 to length do
		out[len - i + 1] := self[i];
	endforeach;

	return out;
end;
</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="truncatedAt" id="4ca8b421-4e36-4df7-883a-a83263f63865">
        <source>truncatedAt(maxLen : Integer) : Binary;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnonkc1
//
// Purpose:     Handle truncation of Binarys in SQL Bulk Data Extract
//
// Parameters:  None
//
// Returns:     Truncated value 
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	s : Binary;
	
begin

	s := self;

	if maxLen &lt; 1 or s.length &lt;= maxLen then
		return s;
	endif;

	return s[1 : maxLen];
	
end;</source>
        <Parameter name="maxLen" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="uncompressToBinaryJMT" id="17260af2-8d36-458f-b6b4-ac359a68a459">
        <source>uncompressToBinaryJMT():Binary;
// --------------------------------------------------------------------------------
// Created:		25 February 2009 by cnwdad1
//
// Purpose:		Uncompresses the receiver, and returns the binary result.
//
// Parameters:	None
//
// Returns:		The uncompressed receiver, or self.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/11/2025	navmd1		MTN-36524 JADE 2025 no longer has Binary::uncompress as an available method
// --------------------------------------------------------------------------------
vars
	isRetry				: Boolean;
	uncompressedData	: Binary;
	
begin
	isRetry	:=	false;
	
	on Exception do app.xHandlerUncompress(exception, isRetry);
	
	uncompressedData	:=	self.uncompressToBinary();
	
	// Uncompress failed, likely old/transitional data, so assume its already uncompressed and just return it
	if isRetry then
		return self;
	endif;
	
	return uncompressedData;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="uncompressToStringJMT" id="f37408e8-ada5-4b7f-bb98-59dec6005fb6">
        <source>uncompressToStringJMT():String;
// --------------------------------------------------------------------------------
// Created:		25 February 2009 by cnwdad1
//
// Purpose:		Uncompresses the receiver, and returns the result as a string.
//
// Parameters:	None
//
// Returns:		The uncompressed receiver as a string, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/11/2025	navmd1		MTN-36524 JADE 2025 no longer has Binary::uncompressString as an available method
// --------------------------------------------------------------------------------
vars
	isRetry				: Boolean;
	uncompressedData	: String;
	
begin
	isRetry	:=	false;
	
	on Exception do app.xHandlerUncompress(exception, isRetry);
	
	uncompressedData	:=	self.uncompressToString();
	
	if isRetry then
		return null;
	endif;
	
	return uncompressedData;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unpackCStringJMT" id="1b31a5ad-1256-40a0-8de5-64ad3da8bc2e">
        <source>unpackCStringJMT(_pos : Integer io) : String;
/*

Purpose:			Return a string extracted from the binary, starting at the position specified 
					by the _pos parameter and including all characters up to (but not including) 
					the first null character (ANSI #[00] or Unicode #[00 00])
					Functionality similar to unpackCString, with _pos updated to point to the 
					next byte following the null character.

Parameters:			Position to start searching for the null character

Return Value:		String up to and not including the null character, and _pos updated
					to the next character position

Date		Who		Reason
03 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	returnString	: String;
	nullChar,
	testChar		: Binary;
	foundPos		: Integer;
	selfLen			: Integer;
	foundNull		: Boolean;
	
begin
	if app.isUnicode then
		// First validate incoming _pos, which must be an odd number
		if _pos.isEven() then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, Binary.name, method.name, 'Start position must be odd.', null, null);
			return null;
		endif;
		
		nullChar := 0.Character.Binary;
		
		foundPos := _pos;
		selfLen := self.length();
		while foundPos &lt; selfLen do
			testChar := self[foundPos:2];
			if testChar = nullChar then
				foundNull := true;
				break;
			endif;
			foundPos := foundPos + 2;
		endwhile;
	
		if foundNull then
			returnString := self[_pos:foundPos - _pos].String;
		else
			returnString := self[_pos:end].String;
		endif;
		_pos := _pos + returnString.lengthInBytes() + 2;
	else
		returnString := self.unpackCString(_pos);
		_pos := _pos + returnString.lengthInBytes() + 1;
	endif;
	
	return returnString;
	
epilog

end;</source>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeSlobToFile" id="de4157e4-186c-41d5-9d33-94e2671e7ba5">
        <source>writeSlobToFile(_fileName : String) : Boolean;

// cnwdvb1 02 May 2003 

vars

	theFile : File;

begin

	create theFile transient;
	theFile.openOutput(_fileName);
	if not theFile.isOpen then
		return false;
	endif;
	theFile.writeLine(self.String);
	return true;
epilog
	theFile.close();
	delete theFile;	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</PrimType>
