    <JadeMethod name="executeDisplayNotesForMove" id="922e1d92-2700-4162-afde-46d2fad721a0">
        <source>executeDisplayNotesForMove(_controller: CMIF_MoveController);

vars
	theTerminal : CM_Terminal;
	theTA	: CM_TerminalArea;
	theTI 	: CM_TrackedItem;
begin

	theTA := self.myTerminalArea;

	if theTA = null then
		theTA := self.myTILC.myTerminalArea;
	endif;

	if theTA = null then
		return;
	endif;

	theTerminal := self.myTerminal;
	theTI := _controller.myTrackedItem;

	if  self = _controller.myOriginatingLocation then
		app.myEventManager.createSingleObjInfoNoteEvt(theTA, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
		app.myEventManager.createSingleObjInfoNoteEvt(theTA, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
	elseif self = _controller.myToPrimaryLocation then
		app.myEventManager.createSingleObjInfoNoteEvt(theTA, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
	endif;
	
	app.myEventManager.createSingleObjInfoNoteEvt(theTA, theTerminal.getTerminalEvent(EVENT_TI_MOVE), self);

end;
</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForOrigLocation" id="e88c1660-f59b-4eab-8c21-a683c924c04f">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2022	jlier1	Initial creation 54700
13/04/2023		navkc1	CR 57063 Task 57546: Jade - MAFI Operator Voyage Discharge Port Checking
14/04/2023		navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
13/11/2023		jlika1	TFS 61130 61013 CUX | Cargo Priority - Cargo Maintenance
02/07/2024		jlika1	TFS 64992 CUX - Code 70102 when moving a container between MAFI's in Voyage Ops Live
15 July 2024 	jlier1 TFS 65208 - creating trx for trailer load unload here now after the tilc has its details updated
18 July 2024 	jlier1 TFS 65223 -removed special stow stuff
01 October 2024		navsaa30 MTN-14839 CUX | MasterTerminalAPI - Move API
27 Feb 2025     navsp1  JIRA-19358 CUX | Missing Transactions for Trailers When Cargo Onboarded
*/

vars
	tiSet 		: CM_TISet;
	ti 			: CM_TrackedItem;
	proxy 		: CM_TrackedItem;
	controller	: CMIF_TIUpdateController;
	information : StringArray512;
	terminal	: CM_Terminal; //13/04/2023	navkc1	CR 57063 TASK 57546
	tilc		: CM_TILC;
	txnParams	: CMIF_MoveTransactionController;	
begin
	inheritMethod(control, _passport);
	if control.isUndoMove then
		return;
	endif;
	
	tilc := self.myTILC;
	ti	:=control.myTrackedItem;		//JIRA-19358
	if control.moveMode = REAL_MODE and tilc &lt;&gt; null and tilc.isMAFI then
		//ti	:=control.myTrackedItem;//JIRA-19358
		create tiSet transient;
		tilc.getAllOnboardTIs(tiSet);
		if tiSet.isEmpty then
			//set to MT content status
			// if clear voyage for IMEX Storage is set 
			proxy := tilc.pxyCreateUpdateProxy();
			proxy.clearDetailsForUnpack(); // IMEX is being set to storage here, Voyage is set to null voyage, discharge, destination port is being set to null.
			proxy.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);  // 7/9/22 	jlier1	TFS 54700
			proxy.setMyCustomerPriority(null);
			
			//Only change when the MAFI is onsite.
			if tilc.isOnSite then
				proxy.setImExStatus(TI_IMEX_STATUS_STORAGE);
				
				terminal := proxy.getMyTerminal();
			
				//13/04/2023	navkc1	CR 57063 TASK 57546
				if terminal &lt;&gt; null and terminal.getConfig(ClearVoyageIMEXStorage).Boolean then
					proxy.setMyVoyage(terminal.getNullVoyage(), _passport);
					proxy.setDischargePort(null);
					proxy.setDestinationPort(null);
				endif;
			else// Revert to the current IMEX, Voyage, Discharge and Destination port that was changed from clearDetailsForUnpack
				proxy.setImExStatus(tilc.getImExStatus());
				proxy.setMyVoyage(tilc.myVoyage, _passport);
				proxy.setDischargePort(tilc.dischargePort);
				proxy.setDestinationPort(tilc.destinationPort);
			endif;
			
			// set height to height of the trailer type
			if tilc.myTILCType &lt;&gt; null then
				proxy.setHeight(tilc.myTILCType.height);
			endif;
		else
			// ### TFS BUG 57053 27MAR2023 NAVAB1 - if fully lashed auto change to partially loaded
			if tilc.contentsStatus = TI_CONTENTS_STATUS_FULLLASHED then 
				proxy := tilc.pxyCreateUpdateProxy();
				proxy.setContentsStatus(TI_CONTENTS_STATUS_PRTLOAD);
				create information transient;
				information.add("Was fully lashed, now partially loaded");
				tilc.createInfomationTransaction("Item moved from " &amp; tilc.id, information, null, app.myPassport );
			endif;

		endif;
		if proxy &lt;&gt; null then
			controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
			tilc.setForUpdate(proxy, controller, null, true, _passport); 
		else
			// 14/04/2023	navkc1	CR 57036 Task 57589
			// Something moved off the MAFI, deliberately cause an update event
			tilc.updateObjectEdition(tilc);
		endif;
		
		//jlier1 TFS 65208 15/7/24
		tilc.updateMAFIPriorityChanged(_passport);
	endif;
	
	if ti &lt;&gt; null and tilc &lt;&gt; null and (tilc.isMAFI or tilc.isTrailer) then		//JIRA-19358 - moved out of the 'if' condition
		create txnParams transient;
		txnParams.type := TRANS_TYPE_TRAILER_CARGO_DIS;
		txnParams.myTrackedItem := tilc;				
		txnParams.myOtherTrackedItem := ti;
		txnParams.dateTime 	:= control.retrospectiveDT;			// 01/10/2024   navsaa30 #14839
		tilc.createTransaction(txnParams, _passport);

		txnParams.type := TRANS_TYPE_TRAILER_DIS;
		txnParams.myTrackedItem := ti;				
		txnParams.myOtherTrackedItem :=tilc;
		ti.createTransaction(txnParams, _passport);
	endif;
epilog
	delete controller;
	delete proxy;	
	delete tiSet;
	delete information;
	delete txnParams;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="9c41838c-2799-4395-a266-41d843bd8490">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 August 2022		jlier1	Initial creation 54700
11/04/2023			navkc1	CR#57036 Task 57546: Jade - MAFI Operator Voyage Discharge Port Checking
02/11/2023			jlika1	TFS 61065	CUX | Retain MAFI 'partially full' status when max weight is reached
08 Jan 2024			jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
16/2024				jlika1	TFS 64453 CUX | Non-containerised cargo to inherit MAFI details
15 July 2024 		jlier1 	TFS 65208 - creating trx for trailer load unload here now after the tilc has its details updated
18 July 2024 		jlier1 	TFS 65223 -removed special stow stuff
24 July 2024 		jlier1 	TFS 65290 - Update of inheritance rules
18 September 2024	jlizm1	TFS 66182 CUX Inheritance of Cargo Operator to MAFI Operator not required
01 October 2024		navsaa30 MTN-14839 CUX | MasterTerminalAPI - Move API
14 October 2024		jlizm1	MTN 32973 MSL Issues setting stops on trailers
27 Feb 2025     	navsp1  JIRA-19358 CUX | Missing Transactions for Trailers When Cargo Onboarded
*/

vars
	ti 			: CM_TrackedItem;
	proxyTILC	: CM_TrackedItem;
	controller	: CMIF_TIUpdateController;
	tilc		: CM_TILC;
	txnParams	: CMIF_MoveTransactionController;
	extraParams : CMIF_TIUpdateExtraParams;
	isRoadProcessIsASPA	: Boolean;	//JIRA-19358
begin
	inheritMethod(control, _passport);
	
	if control.isUndoMove then
		return;
	endif;
	
	tilc := self.myTILC;
	
	if tilc = null then
		return;
	endif;
	
	if control.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	// only need to look at the current cargo being moved
	ti := control.myTrackedItem;	//JIRA-19358
	if ti = null then				//JIRA-19358
		return;						//JIRA-19358
	endif;							//JIRA-19358
	isRoadProcessIsASPA := tilc.myTerminal.roadProcessIsASPA();				//JIRA-19358
	// NAVAB1 30NOV2023 - was breaking UT_RoadProcess::tASPARoadProcess1
	if isRoadProcessIsASPA or not tilc.isMAFI then							//JIRA-19358
		// contents status needs to be updated to show trailer is not empty
		proxyTILC := tilc.pxyCreateUpdateProxy();
		
		if proxyTILC.getContentsStatus() = TI_CONTENTS_STATUS_NULL 
		or proxyTILC.getContentsStatus() = TI_CONTENTS_STATUS_EMPTY then
			proxyTILC.setContentsStatus(TI_CONTENTS_STATUS_PRTLOAD);
		endif;
		
		if ti.isContainer then
			proxyTILC.setContentsStatus(TI_CONTENTS_STATUS_FCL);
		endif;
		
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		tilc.setForUpdate(proxyTILC, controller, extraParams, true, _passport);
		
	else
		proxyTILC := tilc.pxyCreateUpdateProxy();	
		
		proxyTILC.setImExStatus(ti.getImExStatus);
		
		//11/04/2023	navkc1	CR#57036 Task 57546
		if proxyTILC.getContentsStatus() = TI_CONTENTS_STATUS_NULL 
		or proxyTILC.getContentsStatus() = TI_CONTENTS_STATUS_EMPTY then
			proxyTILC.setContentsStatus(TI_CONTENTS_STATUS_PRTLOAD);
		endif;
		
		//jlier1 TFS no need to go back to everything else that has loaded just deal with current cargo
		if  ti.isContainer then
			proxyTILC.setContentsStatus(TI_CONTENTS_STATUS_FCL);
		endif;
		
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		//doing extra updates of voyage and discharge port in extra params so the trxs are correctly created on the mafi and cargo
		create extraParams transient;
		extraParams.myCargoLoadedToMAFI:=control.myTrackedItem;
		extraParams.doUpdateMAFIPriority:=true;
		tilc.setForUpdate(proxyTILC, controller, extraParams, true, _passport); 
	endif;	
	
	if not isRoadProcessIsASPA and (tilc.isMAFI or tilc.isTrailer) then							//JIRA-19358 - moved out of the 'if' condition, and 'isTrailer' check included
		//create TRANS_TYPE_TRAILER_CARGO_LOAD for the mafi and
		create txnParams transient;
		txnParams.type := TRANS_TYPE_TRAILER_CARGO_LOAD;
		txnParams.myTrackedItem := tilc;				
		txnParams.myOtherTrackedItem := ti;
		txnParams.dateTime 	:= control.retrospectiveDT;
		tilc.createTransaction(txnParams, _passport);
		
		// create TRANS_TYPE_TRAILER_LOAD for the cargo	
		txnParams.type := TRANS_TYPE_TRAILER_LOAD;
		txnParams.myTrackedItem := ti;				
		txnParams.myOtherTrackedItem :=tilc;
		ti.createTransaction(txnParams, _passport);
	endif;
epilog
	delete controller;
	delete proxyTILC;	
	delete txnParams;
	delete extraParams;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="7eddd348-cdde-451e-8980-ef00bc20cf9b">
        <source>getFullId(): String;
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anLC : CM_LocationsController;
	tiLC : CM_TILC;
	lc   : CM_LocationsController;
begin
	
	tiLC := self.myTILC;
	
	if tiLC &lt;&gt; null then
		
		lc := tiLC.myPrimaryActualLocation;
		
		if lc = null then
			return tiLC.id;
		else
			anLC := lc.getGroundLC(REAL_MODE);
			return tiLC.id &amp; "-" &amp;  anLC.getFullId();
		endif;
	else
		return inheritMethod();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdAndLevel" id="4df756a2-2a19-4b2e-9ae2-3ba18db998e0">
        <source>getFullIdAndLevel(_ti: CM_TrackedItem; _mode: Integer; _isTarget: Boolean): String;
/*
Purpose:	If I'm a 	MAFI in a MAFI heap then return that the TI is queued to that MAFI heap		

Date		Who		Reason
30 Mar 2023	navab1	TFS BUG 57417
19 Oct 2023 navma1	Bug 60942: PEN- Error 1090 When Using Receive and Release Trailers on Road Gate
*/

vars
	mafiLC  : CM_LocationsController;
	ta 	    : CM_TerminalArea;
	tlc 	: CM_TILC;
begin
	
	tlc := self.myTILC;										//19.10.2023 navma1 #60942
	
	if _ti &lt;&gt; null
	and _ti.isContainer()
	and tlc &lt;&gt; null 
	and tlc.isMAFI() then // not trailer					//19.10.2023 navma1 #60942
		mafiLC := tlc.myPrimaryActualLocation;				//19.10.2023 navma1 #60942
		if mafiLC &lt;&gt; null then
			ta := mafiLC.getMyTerminalArea();
			if ta &lt;&gt; null 
			and ta.type = TA_TYPE_MAFI then
				return ta.id;
			endif;
		endif;
	endif;

	return inheritMethod(_ti, _mode, _isTarget);

epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGroundLC" id="b04b195c-0b35-4819-af93-d9e991abb664">
        <source>getGroundLC(_mode : Integer): CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:		14 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anLC : CM_LocationsController;
begin
	if self.myTILC &lt;&gt; null then
		if _mode = REAL_MODE then
			anLC := self.myTILC.myPrimaryActualLocation;
		elseif _mode = PLANNING_MODE then
			anLC := self.myTILC.myPrimaryPlannedLocation;
		elseif _mode = QUEUE_MODE then
			anLC := self.myTILC.myPrimaryQueuedLocation;
		endif;
		//26 Sep 2013	NDL	Par 32569
/*		if anLC.isKindOf(CM_TILCController) and anLC &lt;&gt; self then
			anLC := anLC.getGroundLC(_mode);
		endif; */
		return anLC;
	else
		return inheritMethod(_mode);
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
