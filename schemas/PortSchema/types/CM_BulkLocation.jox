    <JadeMethod name="testAutoPlanRequestYA" id="e064ef17-95fa-4f33-b5f8-8059f3b43b00">
        <source>testAutoPlanRequestYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
/*

Date		Who		Reason
24 February 2015	cnwer1	Initial creation PAR
07 January  2015    cnwma1  PAR #37313 Release Requests - Yard Areas

*/

vars
	totalFound,
	totalWeNeed	: Integer;
	cmifRequest	: CMIF_YARequest;
	ti			: CM_TrackedItem;
	testIds		: Boolean;
	tiId		: String;
	bulkRelease	: CM_BulkRelease;
	fMove		: CM_FutureMove;
	wle			: CM_WorkListEntry;
	assignedTIs : CM_TISet;
begin
	

	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	
	/*if cmifRequest.totalRequested &gt; self.allTrackedItems.size then
		//Not enough here.. Quit
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient objects in this area to satisfy request (need " &amp; cmifRequest.totalRequested.String &amp; ", area contains " &amp;   self.allTrackedItems.size.String &amp; ".. Skipping.", true);
		return false;
	endif;*/

	if cmifRequest.ids.isEmpty() then
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification masks to test on Request.", true);
		testIds := true;
	endif;

	if cmifRequest.isDeliveryRequest then	//05 Apr 2016	NDL	TFS 1779
		totalWeNeed := cmifRequest.totalRequested;
	elseif cmifRequest.myReserveSelection &lt;&gt; null then                   // 07/01/2015 cnwma1 PAR #37313 
		if cmifRequest.myReserveSelection.myCargoType &lt;&gt; null then
			if cmifRequest.myReserveSelection.myCargoType.id = TI_CargoType_Container then
				totalWeNeed :=cmifRequest.myReserveSelection.totalRequested;
			else 
				totalWeNeed := cmifRequest.totalRequested;
			endif;
		endif;
	else
		totalWeNeed := cmifRequest.totalRequested;
	endif;
	
	if cmifRequest.isDeliveryRequest then
		bulkRelease := cmifRequest.myDeliveryRequest.myOriginatingBulkRelease;
	endif;
	//cnwrd1 par 31623 we may be working a release item that hasnt been manually assigned so we do not want to exclude non assigned ti's as we normally would 30.5.2013
	create assignedTIs transient;	
	if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.isEmpty then
		bulkRelease.getAvailableAssignedTis( assignedTIs, cmifRequest.myDeliveryRequest );	//24 Apr 2020	NDL	TFS 49095 // ### TFS 52721 16NOV2022 NAVAB1
	/*	foreach ti in bulkRelease.allTrackedItemsAssigned do
			//epr par 33595 4/3/14
			if ti.hasBeenMerged then
				continue;
			endif;
			
			if ti.myPrimaryActualLocation.isVehicle 
			or ti.myPrimaryActualLocation.isMachineController
			or ti.myPrimaryActualLocation.isYardInterchangeAreaLocation then
				continue;
			endif;				
			assignedTIs.add(ti);			
		endforeach; */
	endif;	

	foreach ti in self.allTrackedItems discreteLock do : outerLoop
		// Don't count tis that have already been used.
		if _yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.includes(ti) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' has already been allocated.', true);
			totalFound := totalFound + 1;
			continue;
		endif;
		
		if not ti.allQueuedFutureMoves.isEmpty() then
			foreach fMove in ti.allQueuedFutureMoves do
				wle := fMove.myWorkListEntry;
				if wle = null then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Could not determine wle from queued move skipping..', true);
					continue outerLoop;
				elseif wle.job = _yaAgent.myCurrentJob then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is already queued to job, skipping ... ' &amp; wle.job.jobId, true);
					continue outerLoop;
				else
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is queued to a different job stopping...', true);
					continue outerLoop;
				endif;
			endforeach;
		endif;
		
		if testIds then
			tiId := ti.id.trimRight;
			if cmifRequest.ids.compareIds(tiId) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification Masking, " &amp; tiId  &amp; " passed mask test, testing potentially good Item..", true);
			else
				continue;
			endif;
		endif;
		
			
		if bulkRelease &lt;&gt; null then
			if not assignedTIs.isEmpty then //cnwrd1 par 31623 
				if (not assignedTIs.includes(ti)) then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is not allocated to bulk release', true);
					// Par 11819 DVB changed 25/05/2006
					//return false;
					continue;
				endif;	
			endif;
			
			// Par 12270
			if (not ti.allBulkReleasesAssigned.isEmpty()) and (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
			//	if (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is assigned to another bulk release', true);
				// Par 11819 DVB changed 25/05/2006
				//return false;
				continue;
			endif;
		endif;
		
		if ti.testAutoPlanRequestYA(_yaAgent) then
			_yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(ti);
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' matched criteria.', true);
			totalFound := totalFound + 1;
		endif;
		
		if totalFound &gt;= totalWeNeed then
			_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
			return true;
		endif;
 	endforeach; 
 	
	// TFS 3045
	if totalFound &lt;  totalWeNeed and totalFound &gt; 0 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient items in '" &amp; self.getFullId() &amp; "' to satisfy request (need " &amp; totalWeNeed.String &amp; ", area contains " &amp;   totalFound.String &amp; ".. Skipping.", true);
	
	endif;
 	
 	return false;
epilog 
	delete assignedTIs;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFull" id="91fbdec3-d0f4-4e56-8b7b-e69297aac973">
        <source>testIsControllerFull(obj: CMIF_AutoMovePlan input);
/*

Date		Who		Reason
02 April 2014	cnwer1	Initial creation CCMS 1366

*/

vars

begin

	if self.testIsControllerFullTAMax(obj) then
		return;
	endif;
	obj.updateController(self);
epilog

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFullYA" id="ab34832d-9b4f-4e17-9ab2-cf88e1545bc6">
        <source>testIsControllerFullYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation CCMS 1366

*/

vars

	hasSomeCapacity : Boolean;

begin
	
	//epr CCMS 1366 bulk
	if self.testIsControllerFullTAMaxYA(_yaAgent, hasSomeCapacity) then
		if hasSomeCapacity then
			_yaAgent.myCMIFYAAutoPlan.addLocationForSplitQ( _yaAgent.myCurrentAllocation, self);	//15 Jun 2016	NDL	TFS 2172
		endif;
		return true;
	endif;
	
	return false;
epilog
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="d9ca770d-0d2e-4c92-80d5-54a6d5b856bc">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*

Date		Who		Reason
02 April 2014	cnwer1	Initial creation PAR

*/

vars
	tAutoPlanMove 	: CMIF_AutoMovePlan;
begin
	inheritMethod(_control);
	//------------------
	//  Create a transient automoveplan from our moveController so we can share
	//  same code as the autoPlan tests.
	//------------------
	tAutoPlanMove := _control.createAsAutoMovePlan();
	
	tAutoPlanMove.setOriginatingController(self);
		
	//------------------------
	//	Full?	CCMS 1095
	//------------------------	
	self.testIsControllerFull(tAutoPlanMove);
	
	//------------------
	//Thats it!	
	//------------------

epilog
	delete tAutoPlanMove;end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
