    <JadeMethod name="trxCreateHazardsCheckTrans" id="db7229f9-b939-4bc5-b5fa-3299aed5b8f0">
        <updating/>
        <source>trxCreateHazardsCheckTrans(_trackedItem : CM_TrackedItem; _passport : CM_Passport input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 March 2023
TFS#		: 56882
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theTIProxy					: CM_TrackedItem;
	theTransactionController	: CMIF_TITransactionController;
	txnControllerDict 			: CMIF_TITxnContrlrByTypeDTDict;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	beginTransaction;
	theTIProxy := _trackedItem.pxyCreateUpdateProxy();
	
	create txnControllerDict transient;
	create theTransactionController transient;
	
	theTransactionController.type := TRANS_TYPE_HAZ_CHECK;
	theTransactionController.myTrackedItem := _trackedItem;
	
	txnControllerDict.add(theTransactionController);
		
	app.myPassport.setWarningsIgnored(true);	
	app.myUtilityUA.utlUpdateTrackedItem(theTIProxy, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, app.myPassport);
epilog
	delete theTIProxy;	
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
