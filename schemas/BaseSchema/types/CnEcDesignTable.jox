    <JadeMethod name="generateDisplayEntryCode" id="e3a64128-c40b-4285-808b-1f229643c254">
        <source>generateDisplayEntryCode();

vars
	columnHeading			: String;
	tempString				: String;
begin
	tempString := "if columnHeading = '";
	foreach columnHeading in columnHeadingArray do
		if tempString.trimBlanks &lt;&gt; null then
			tempString := tempString &amp; columnHeading &amp; "' then";
			write Tab &amp; tempString;
			write Tab &amp; Tab &amp; "   return(null);";
			tempString := "elseif columnHeading = '";
		endif;
	endforeach;
	write Tab &amp; "endif;";
end;</source>
    </JadeMethod>
    <JadeMethod name="getColumnByHeading" id="04e781aa-b2e8-4971-a51e-43c60a0f8563">
        <updating/>
        <source>getColumnByHeading(columnHeading : String) : Integer updating;

vars
	loopIndex			: Integer;
	heading				: String;
begin
	loopIndex	:= 1;
	foreach heading in columnHeadingArray do
		loopIndex := loopIndex + 1;
		if heading = columnHeading then
			return(loopIndex);
		endif;
	endforeach;
	return(0);
end;</source>
        <Parameter name="columnHeading" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPropertyDisplay" id="f18e0437-e917-4acf-aa50-338766aebce9">
        <source>getPropertyDisplay(property : String; str : String io) : Boolean;

vars

begin
	if property = 'layout' then
		if layout = null then
			str := 'Undefined';
		else	
			str := 'Defined';
		endif;	
		return true;
	endif;
	if property = 'webHyperlinkColumn' then
		if webHyperlinkColumn &lt; 0 or webHyperlinkColumn &gt; self.columns then
			str := '0';
		endif;
	endif;
	return inheritMethod(property, str);	
end;</source>
        <Parameter name="property" type="String"/>
        <Parameter name="str" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
