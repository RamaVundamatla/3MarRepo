    <JadeMethod name="validateSplitMergeC" id="2b660251-d515-4b84-ad3e-5f73fed0b544">
        <source>validateSplitMergeC(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after the merge back
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments (should be none, it's been zombied)
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "Original cargo payments after merge");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			//self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First original invoice line after merge");
			self.assertEqualMsg(line.lineTotal, 3000.Decimal, "First original invoice line after merge");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after merge");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 2, "Original invoice lines after merge");   26/10/2016 cnwma1 TFS #2861
	self.assertEqualMsg(count, 0, "Original invoice lines after merge");

	count := 0;
	foreach payment in splitCargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		//if count = 1 or count = 3 or count = 4 or count = 5 then
		if count = 1 or count = 3  or count = 5 then
			//self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Split cargo payment " &amp; count.String &amp; " after merge");
				self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Split cargo payment " &amp; count.String &amp; " after merge");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Split cargo payment " &amp; count.String &amp; " after merge");
		elseif count =4 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "Split cargo payment " &amp; count.String &amp; " after merge");

		elseif count = 6 or count = 7 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Split cargo payment " &amp; count.String &amp; " after merge");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 7, "Split cargo payments after merge");
	self.assertEqualMsg(count, 6, "Split cargo payments after merge");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "Third Split invoice line after merge");
				
		elseif count = 2 then
			//self.assertEqualMsg(line.lineTotal, 1000.Decimal, "Fourth Split invoice line after merge");  26/10/2016 cnwma1 TFS #2861
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Fourth Split invoice line after merge");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 2, "Split invoice lines after merge"); 26/10/2016 cnwma1 TFS #2861
	self.assertEqualMsg(count, 3, "Split invoice lines after merge");

end;
</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_splitCargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateSplitMergeD" id="ec05b220-2aef-4bd1-9ce8-55f26623131e">
        <source>validateSplitMergeD(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after cargo release
vars
	count	: Integer;
	totalValue	: Decimal[23, 6];
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments (should be none, it's been zombied)
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "Original cargo payments after release");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First original invoice line after release");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after release");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 2, "Original invoice lines after release");  26/10/2016 cnwma1 TFS #2861
	self.assertEqualMsg(count, 0, "Original invoice lines after release");  //26/10/2016 cnwma1 TFS #2861
	count := 0;
	foreach payment in splitCargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		totalValue := totalValue + payment.cashValue;
		//if count = 1 or count = 3 or count = 4 or count = 5 then
			if count = 1 or count = 3 or count = 5 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Split cargo payment " &amp; count.String &amp; " after release");
			//self.assertEqualMsg(payment.cashValue, 3000.Decimal, "Split cargo payment " &amp; count.String &amp; " after release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Split cargo payment " &amp; count.String &amp; " after release");
		elseif count = 4 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "Split cargo payment " &amp; count.String &amp; " after release");
		elseif count = 6 or count = 7 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Split cargo payment " &amp; count.String &amp; " after release");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 7, "Split cargo payments after release");
		self.assertEqualMsg(count, 6, "Split cargo payments after release");
	// 15000 was paid in the original receipt, it should all still be here
	self.assertEqualMsg(totalValue, 15000.Decimal, "Total payment after release");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "Third Split invoice line after release");
		elseif count = 2 then
			//self.assertEqualMsg(line.lineTotal, 1000.Decimal, "Fourth Split invoice line after release"); //26/10/2016 cnwma1 TFS #2861
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Fourth Split invoice line after release");   //26/10/2016 cnwma1 TFS #2861
		elseif count = 3 then
			//self.assertEqualMsg(line.lineTotal, 2000.Decimal, "Fifth Split invoice line after release");
			self.assertEqualMsg(line.lineTotal, 3000.Decimal, "Fifth Split invoice line after release");
		endif;
	endforeach;
	//self.assertEqualMsg(count, 3, "Split invoice lines after release"); //26/10/2016 cnwma1 TFS #2861
	self.assertEqualMsg(count, 4, "Split invoice lines after release");

end;
</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_splitCargo" type="CM_TrackedItem"/>
    </JadeMethod>
