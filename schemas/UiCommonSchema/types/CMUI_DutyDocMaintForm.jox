    <JadeMethod name="btnAddCargo_click" id="fc7da026-5787-45d4-b4d5-80c55877494b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddCargo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	dutyItemForm : CMUI_DutyDocItemMaintForm;

begin

	
	self.doSave(false);
	

	if self.myDutyDoc = null then
		return;
	endif;
		
		
	dutyItemForm := app.loadForm(CMUI_DutyDocItemMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DutyDocItemMaintForm;
	dutyItemForm.setBaseData( self.myDutyDoc, null, null,self );
	dutyItemForm.showModal();
	
	self.setPrintCarVisibility();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCharges_click" id="0cde1dbd-ad2f-433e-9cc5-a69c42878937">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCharges_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	invSchema 	: Schema;
	invClass	: Class;
	assistant	: CMUI_Assistant;
	
	agent		: CM_ConsigneeConsignor;
	debtor		: CM_Debtor;
	invoice		: CM_Invoice;
	allExtraChargeInvs : CM_InvoiceSet;
begin
	invSchema := rootSchema.getSchema("InvoiceSchema");
	invClass := invSchema.getClass("INV_Assistant");
	
	agent := self.myAssistant.getConsignFromCombo(self.cmbConsignee.text);
	debtor := agent.debtor;
	
	create assistant as invClass transient;
	
	assistant.myTerminal := self.myTerminal;
	// 32269 to new screen to enter extra charges
	create allExtraChargeInvs transient;
	debtor.getDutyDocExtraCharges( self.myTerminal, allExtraChargeInvs );
	// all invoices in allExtraChargeInvs will show in this form - taking the last is arbitrary but should work OK
	invoice := allExtraChargeInvs.last();
	if invoice &lt;&gt; null then
		assistant.showDutyDocExtraChargesForm(debtor, invoice, self.myDutyDoc);
	endif;
	
epilog
	delete assistant;
	delete allExtraChargeInvs;
end;</source>
