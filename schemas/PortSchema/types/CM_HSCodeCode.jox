    <JadeMethod name="setForUpdate" id="ec35a51c-d530-4cb1-aa77-315a34afdf43">
        <updating/>
        <source>setForUpdate(_proxy: CM_HSCodeCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod(_proxy);

	if _proxy.myHSHeading &lt;&gt; null then
		self.myHSHeading := _proxy.myHSHeading;
	else
		self.myHSHeading := _proxy.getParentFromRoot();
	endif;
	
	self.externalRef1 	:= _proxy.externalRef1;
	self.externalRef2 	:= _proxy.externalRef2;
	self.externalRef3 	:= _proxy.externalRef3;
	self.unitQuantity	:= _proxy.unitQuantity;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_HSCodeCode"/>
    </JadeMethod>
