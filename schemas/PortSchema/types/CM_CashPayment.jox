11 Nov 2014 cnwma1  PAR #35196 	Bill of Lading-Service not showing in Cash Payment in selector
06 Jun 2019 jlgka1	TFS 45113 	GUQ - Bill of lading on selector window display 
								and search malfunction and Cash receipt BL use malfunction
============================================================================*/

vars
	billOfLading  : String;
begin

	if self.myTrackedItem &lt;&gt; null then                    // 11/11/2014  cnwma1 PAR #35196  //jlgka1 TFS 45113
		billOfLading := self.myTrackedItem.billOfLading;
	endif;
	
	if billOfLading = null and self.myCashReceipt &lt;&gt; null then                        
		billOfLading := self.myCashReceipt.getBOLNumber;
	endif;
	
	return billOfLading;

end;</source>
