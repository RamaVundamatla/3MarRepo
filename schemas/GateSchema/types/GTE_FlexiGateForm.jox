    <JadeMethod name="cmbRegNo_click" id="973ba139-b23a-4563-a011-0e5753d924b7">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRegNo_click(combobox: ComboBox input) updating;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR
20 Nov 2024	navah1	Bug 32770: CUX - Road Gate - Search is not working when a truck with a similar license plate is already on terminal
28 Mar 2025	navhn30	Bug MTN-34499: CUX | Issues on Road Gate Form when new Vehicle and Driver created
*/

vars
	userInput : String;
    matchCount : Integer;
    i : Integer;
begin 
	/*		//20.11.2024 navah1 #32770 
	if combobox.isDroppedDown then
		self.onRegChanged();
		if self.cmbRegNo.listObject &lt;&gt; null then
			self.detailsChangedVehicle := true;
		endif;
	endif;
	*/
	//self.onRegChanged();	//28.03.25	navhn30	  MTN-34499						//MTN-36422
	
	// Capture the current user input from the ComboBox text                    //MTN-36422
    userInput := combobox.text;                                                 //MTN-36422
    matchCount := 0;                                                            //MTN-36422
    
    // Iterate through combo box items to count matches                         //MTN-36422
    foreach i in 1 to combobox.listCount do                                     //MTN-36422
        // Perform a case-insensitive search for starting text match            //MTN-36422
        if combobox.itemText[i].pos(userInput, 1) = 1 then                      //MTN-36422
            matchCount := matchCount + 1;                                       //MTN-36422
        endif;                                                                  //MTN-36422
    endforeach;                                                                 //MTN-36422

    // Check if multiple matches are found                                      //MTN-36422
    if matchCount = 1 then                                                      //MTN-36422
        self.onRegChanged();                                                    //MTN-36422
    endif;                                                                      //MTN-36422
	
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbRegNo_closeup" id="d391de48-e353-4334-ae25-418571453d6a">
