        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getRowsFromTIs" id="3d4b0405-f4d9-461d-9ebb-12c9fef21b75">
        <source>getRowsFromTIs() : CM_ObjectArray;
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797

vars
	theTIs : CM_TISet;
	theRows : CM_ObjectArray;
	aTI : CM_TrackedItem;
	aRow : CM_GridRow;
	dynaDict : DynaDictionary;
begin
	create theTIs transient;
	create theRows transient;
	
	if self.fldMain.topSheet = self.shtNonplanned then
		self.tblData.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.tblPlanned.allSelectedObjects.copy(theTIs);
	elseif self.fldMain.topSheet = self.shtAll then
		self.tblAll.allSelectedObjects.copy(theTIs);
	endif;
	
	foreach aTI in theTIs do
		if not  aTI.myPrimaryActualLocation.isKindOf(CM_GridController) then
			continue;
		endif;
		
		aRow := aTI.myPrimaryActualLocation.CM_GridController.myGridRow;
		
		if not theRows.includes(aRow) then
			theRows.add(aRow);
		endif;
	endforeach;

	create dynaDict transient;	
	dynaDict.setMembership(CM_GridRow);
	dynaDict.addMemberKey("myGridArea.id", false, true);
	dynaDict.addMemberKey("label", false, true);
	dynaDict.endKeys(true);

	theRows.copy(dynaDict);
	theRows.clear;
	dynaDict.copy(theRows);
	
	return theRows;
epilog
	delete dynaDict;
	delete theTIs;
end;</source>
        <ReturnType type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTIs" id="37a67e63-2dd6-4462-b2d5-4459ce981b9e">
        <source>getSelectedTIs(objArray : ObjectArray input) protected;
/*

Date		Who		Reason
01 October 2013	cnwer1	Initial creation PAR 32613

*/

vars

begin
    if self.fldMain.topSheet = self.shtNonplanned then
		if self.tblData.row &lt; self.tblData.fixedRows then//
			return;
		endif;
		self.tblData.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtPlanned then
		if self.tblPlanned.row &lt; self.tblPlanned.fixedRows then
			return;
		endif;
		self.tblPlanned.allSelectedObjects.copy(objArray);
	elseif self.fldMain.topSheet = self.shtAll then
		if self.tblAll.row &lt; self.tblAll.fixedRows then
			return;
		endif;
		self.tblAll.allSelectedObjects.copy(objArray);
	else
		return;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsForColumnKey" id="5a90e0f8-d6e7-4295-bf66-8cdba205aaa4">
        <source>getTIsForColumnKey(_tiArray: ObjectArray input; _tiSet: CM_TISet; _columnKey: Integer);
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	colKey	: Integer;
begin
	colKey := _columnKey;
	
	if _tiSet = null then
		return;
	endif;
	
	foreach ti in _tiSet do
		if colKey = self.Column_LoadPlanned then
			if ti.plannedSite = TI_SITE_ONSHIP then
				_tiArray.add(ti);		
			endif;
			
		elseif colKey = self.Column_LoadToPlan then
			if ti.plannedSite &lt;&gt; TI_SITE_ONSHIP then
				_tiArray.add(ti);		
			endif;
			
		elseif colKey = self.Column_SpecialStows then
			if ti.isSpecialStow then
				_tiArray.add(ti);		
			endif;
			
		else
			_tiArray.add(ti);		
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiArray" type="ObjectArray" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
