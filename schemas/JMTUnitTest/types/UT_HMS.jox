    <JadeMethod name="addVoyWithContStructAndPorts" id="4f34527e-5a08-4555-b9ae-a9b68ddb6ad2">
        <source>addVoyWithContStructAndPorts(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String ) : CM_Voyage;

/*

Purpose:			

Parameters:			

Return Value:		


/****Changes

Date		Name	TFS#			Description
============================================================================
02/12/2009	cnwas3					Initial creation
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/

vars
	vessel					: CM_Vessel;
	pxyVoyage				: CM_Voyage;
	voyage					: CM_Voyage;
	pxyCellStructure 		: CM_CellularVoyageStructure;
	now						: TimeStamp;
	arrivalDate				: TimeStamp; 
	departureDate 			: TimeStamp;
	pxyGlobalVoyage			: CM_VoyageGlobal;
	trade					: CM_Trade;
	pxyVoyagePortRotation	: CM_PortRotation;
	portRotation			: CM_PortRotation;
	portRotationArray		: CM_PortRotationArray;									// 24/02/2014 cnwmh5 - Transient Leaks
begin
	vessel := getRoot.allVessels[_vesselCode];
	trade := self.getRoot.allTradesByDescription["Chief Tasman"];
	
	create portRotationArray transient;
	
	create pxyVoyage transient;							

	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay, 
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id, 
											vessel.myCellularVesselStructure.useBayCellTierNumbering);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	pxyVoyage.setProxyVoyage(	null,
								"",
								_code,
								"",
								"",
								vessel.code,
								vessel.name,
								"",
								false,
/* PAR 33644								false,
								false, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null, 
								null,
								null,
								null,
								null,null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								null,
								pxyVoyage.isBarge,	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();


	return voyage;
epilog

	//  24/02/2014 cnwmh5 - Transient Leaks
	delete pxyCellStructure;
	foreach portRotation in portRotationArray do
		delete portRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;

	delete pxyGlobalVoyage;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
