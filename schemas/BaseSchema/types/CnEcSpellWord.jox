    <JadeMethod name="setMetaphone" id="fa85274e-5b5f-4958-8090-82340c4669f2">
        <updating/>
        <source>setMetaphone() updating, protected;

vars
	metaphoneObj	: CnEcMetaphone;
	
begin
	create metaphoneObj transient;
	metaphoneObj.updateMe(self.name);
	self.metaPhoneName	:=	metaphoneObj.getTransform(5);

epilog
	delete metaphoneObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSoundex" id="6629c706-755f-4d4a-bb3c-dbfa32e7fe40">
        <updating/>
        <source>setSoundex() updating, protected;

vars
	soundexObj	: CnEcSoundex;
	
begin
	create soundexObj transient;
	soundexObj.updateMe(self.name);
	self.soundexName	:=	soundexObj.getTransform(5);
epilog
	delete soundexObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="dfe3b841-e622-4789-a729-f29330d411d1">
        <updating/>
        <source>updateMe(pSpellRootObj:CnEcSpellRoot; pName:String) : String updating; 

// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
// Please add any validation required then delete this comment.
vars
	errorMessage	: String;

begin
	// Validation

	self.validateMe(pSpellRootObj, pName);  

	// Attributes (Non Keys)

	// Attributes (Keys)

	if self.name &lt;&gt; pName then
		self.name	:=	pName;
		self.setSoundex();
		self.setMetaphone();
	endif;

	// Singleton References

	if self.myRoot &lt;&gt; pSpellRootObj then
		self.myRoot := 	pSpellRootObj;
	endif;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a61d6be7-1a76-4c66-a50c-a36a761f82c2">
        <updating/>
        <source>validateMe(pSpellRootObj:CnEcSpellRoot; pName:String) updating, protected; 

// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
// Please add any validation required then delete this comment.
vars
	errorMessage	: String;
	attribLength	: Integer;
	wordObj			: CnEcSpellWord;

begin
	// Validation
	
	wordObj	:=	pSpellRootObj.allSpellWords[pName];
	
	if wordObj &lt;&gt; null and wordObj &lt;&gt; self then
		errorMessage	:=	errorMessage.cnEcAppendErrorMsg("This word already exists in the dictionary: " &amp; pName);
	endif;
	
// cnwdad1 05/09/2002 - When fetching the length of the name field, the property
// value was being used instead of the property name.
//	attribLength := self.class.cnEcGetStringPropertyLength(name);
	attribLength := self.class().cnEcGetStringPropertyLength(CnEcSpellWord::name.name);
	
	if attribLength &gt; 0 and attribLength &lt; pName.length() then
		errorMessage	:=	errorMessage.cnEcAppendErrorMsg(pName &amp; ' - text too long.');
	endif;
epilog
	if errorMessage &lt;&gt; null then
		CnEcBaseSchemaException.raise_(CNEC_X_12005, errorMessage); 
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
