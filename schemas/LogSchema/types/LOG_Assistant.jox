    </JadeMethod>
    <JadeMethod name="comboBoxVoyageCode" id="54cf2369-a771-4335-b1d6-2a066894449f">
        <source>comboBoxVoyageCode(pCmb: ComboBox input; pVoyage: CM_Voyage; _includeArchived : Boolean; _includeCompleted : Boolean);
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyageCol	: CM_VoyageByCodeArrivalDT;
	iter 		: Iterator;
	voy 		: CM_Voyage;
	str 		: String;
	ls			: Boolean;
begin
	pCmb.clear();

	//Reset allows you to dump current collection and start again
	//if desired. Otherwise we only build the collection once
	if self.allVoyageCodes.size &gt; 0 then
		self.allVoyageCodes.clear;
	    self.allVoyages.clear;
	endif;

	voyageCol := self.myTerminal.allVoyagesByCode;
	app.cmsBeginLoad(ls);

	// use an iterator as dict is an external key dict
	iter := voyageCol.createIterator;
	while iter.next(voy) do
		
//		if not voy.isKindOf(CM_LogVoyage) then
		if voy.myLogVoyageStructure = null then 
			continue;
		endif;
		
		if voy.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if (not _includeArchived) and
		   (voy.myTerminalArchived &lt;&gt; null) then
			continue;
		endif;
		//	29 Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't show completed voyages
		if not _includeCompleted and
		   voy.isClosedStatus() then
			continue;
		endif;
		str := voy.code &amp; Tab &amp; voy.description;
   		self.allVoyageCodes.add(str); 
	    self.allVoyages.add(voy);    		
	  	
	endwhile;

	if pCmb.isKindOf(CMUI_ComboForVoyageActive) then
		pCmb.CMUI_ComboForVoyageActive.init(self.allVoyages, self.myTerminal, _includeArchived);
	else
		pCmb.listCollection(self.allVoyages, false, 0);
	endif;
	
	if pVoyage &lt;&gt; null then
		pCmb.listIndex := pCmb.findObject(pVoyage);
	endif;

epilog
	app.cmsEndLoad(ls);
	delete iter;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_includeCompleted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageOperator" id="e881a28d-50ad-4eae-ad3d-de2a4f8b7e83">
        <source>comboBoxVoyageOperator(_cmb : ComboBox input; _voyageOperator : CM_VoyageOperator; _voyage : CM_Voyage);
//--------------------------------------------------------------
//Created: 25 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _voyage &lt;&gt; null then
		_cmb.listCollection(_voyage.allVoyageIOperators, true, 0);
	endif;
	
	if _voyageOperator &lt;&gt; null then
		_cmb.text := self.displayEntryVoyageOperator(_voyageOperator);
	endif;	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyageOperator" type="CM_VoyageOperator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageStatus" id="5d13cbda-248b-41d2-99e3-6cbaef3e1810">
        <source>comboBoxVoyageStatus(pTbl : Table input; _column, _row, _status : Integer);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str, cmbStr, status	: String;
	
begin
	
	foreach str in self.allVoyageStatuses do
		if str &lt;&gt; null then
			cmbStr := str &amp; Tab &amp; cmbStr;
		endif;
	endforeach;		

	pTbl.accessCell(_row, _column).comboList := cmbStr;
	
	status := app.voyageStatusEnumToString(_status, true);

	if self.allVoyageStatuses.includes(status) then
		pTbl.accessCell(_row, _column).text := status;
	endif;

end;</source>
        <Parameter name="pTbl" type="Table" usage="input"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
