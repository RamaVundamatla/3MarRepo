    <JadeMethod name="xHMS_MarineServiceTimings" id="df22a399-311d-45de-8895-2d1af61aecfc">
        <updating/>
        <source>xHMS_MarineServiceTimings(_features : CMIF_ExternalDBFeatureSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2024	navnk30	ChangeRequest 62313: ATD - Add feature Marine Service timing

*/

vars
	xdbFeature  : CMIF_ExternalDBFeature;
	schName,
	clsName	: String;
	cls		: Class;
	props	: PropertyNDict;
	prop	: Property;
begin
	schName := "PortSchema";
	clsName := "HMS_MarineServicesTimings";
	cls := rootSchema.getSchema(schName).getClass(clsName);
	props := cls.getProperties;
	
	foreach prop in props discreteLock do
		if prop.type.isKindOf(CollClass) then
			continue;
		endif;
		create xdbFeature transient;
		xdbFeature.setupAndBuildSet(prop.name, clsName, prop.name, "", _features);
	endforeach;

epilog

end;</source>
        <Parameter name="_features" type="CMIF_ExternalDBFeatureSet" usage="input"/>
    </JadeMethod>
