    <JadeMethod name="getQueue" id="c8e9483f-eb5c-47e5-a81e-e7181b05d206">
        <source>getQueue() : CM_RadioTelemetryQueue;
//As we are now working in &gt;1 queue, we need a nice way of getting
//the one we are currently working on.. This is it.
vars

begin
	if self.workingInQueue &lt;&gt; null then
		if self.currentQueueTask &lt;&gt; null and 
			(self.currentQueueTask.queue = self.workingInQueue) then
			return self.workingInQueue;
		endif;
	endif;

	return self.myPrimaryQueue;

end;</source>
