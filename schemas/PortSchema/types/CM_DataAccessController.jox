    <JadeMethod name="canAccess" id="5c5b630f-e3cc-4786-beb4-9e71960305de">
        <source>canAccess(obj : CM_Object) : Boolean;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			Test to see if the calling object is one of the ones we can access     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if obj = null then
		if self.includeIfNull then
			return true;
		else
			return false;
		endif;
	endif;
	// sgp 26 May 2003 : changed to hasInstance to avoid
	// dereferencing obj for performance reasons
	if not self.myClassContained.hasInstance(obj) then
	//if (not obj.class.inheritsFrom(self.myClassContained)) then
		return true;
	endif;
	if self.mustNotBeIncluded = false then
		//The object must be here to see it
		return self.allObjects.includes(obj);
	endif;
	//If the object is here we CANT see it.
	return (not self.allObjects.includes(obj));
end;</source>
        <Parameter name="obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
