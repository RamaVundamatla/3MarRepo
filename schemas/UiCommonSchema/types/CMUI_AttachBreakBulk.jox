    <JadeMethod name="doCmbVoyageClick" id="12ea9ee6-fc95-4d97-892a-ca86bde18d68">
        <source>doCmbVoyageClick() protected;
// ---------------------------------------------------------------------------
// Created:     18 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	
	// lorcan - replacing port combobox - 11/4/2006
	self.cmbDisPort.myTerminal := self.myTerminal;// so text for port is displayed in correct order from config
	self.cmbDisPort.myAssistant := self.myAssistant;
	self.cmbDisPort.showAllDestinations := true;
	
	if self.cmbVoyage.listObject = null then
		self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), null);
	else
		// 01/06/2010 cnwar2 #24346 - use actual voyage to populate discharge ports
		voyage := self.cmbVoyage.listObject.CM_Voyage;
		if CM_VoyageInlandTerminal.hasInstance(voyage) then
			self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), voyage.CM_VoyageInlandTerminal.myVoyage);
		else
			self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), voyage);
		endif;
		//self.cmbDisPort.setObjectFromCodeAndVoyage (self.cmbDisPort.getCode(), self.cmbVoyage.listObject.CM_Voyage);
 	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
