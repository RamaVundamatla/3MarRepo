    <JadeMethod name="doBtnPrintStats" id="c4acf00d-7770-4209-8d59-38a8d7d8ee93">
        <source>doBtnPrintStats();
// ---------------------------------------------------------------------------
// Created:		04 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16/08/2011	cnwcs5	CCMS MES 1033 RORO KPI
vars
	voyage		:CM_Voyage;
	tmpTitle 	: String;
begin
	voyage := self.myCurrentVoyage;
	
	if voyage &lt;&gt; null then//added by cnwyl for par15717
		if self.fldMain.topSheet = self.shtBays then
			tmpTitle := app.getErrorString1 (Voyage_bay_statistics, voyage.getDisplayDetails(false));
			
			self.doPrintOutTable(self.tblBays, tmpTitle, true, false, true, false);
		else
			tmpTitle := app.getErrorString1 (Voyage_statistics, voyage.getDisplayDetails(false));
			
			if self.isShowROROKPI then
				self.doPrintOutTables(self.tblStats, self.tblTimings,self.tblRORODecks, self.tblROROMoves, self.tblDelays, tmpTitle, true, false, true, false);
			else
				self.doPrintOutTables(self.tblStats, self.tblTimings, null, null, self.tblDelays, tmpTitle, true, false, true, false);
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolbarPRINT" id="fc019474-fdf2-424b-8603-7cbd73bf94a2">
        <source>doBtnToolbarPRINT();
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpJadeReport  : JadeReport;
	tmpTable : Table;
	theReturn, idx : Integer;
	theLeft : Real;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	gridArea : CMUI_GridArea;
	theReport : CMUI_ReportLine;
	theType, theCode : String;
	theString : String;
	theX, theY, theWidth, theHeight, theColour : Integer;
	thePicture : Binary;
begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage to print","Print Error",MsgBox_OK_Only);
		return;
	endif;
	if self.sdf01.scaleFactor &lt;&gt; 1 then 
		app.msgBox("Please redraw the holds using a zoom factor of 1","Print Error",MsgBox_OK_Only);
	endif;

	theString := "Are you sure that you want to print " &amp; self.myCurrentVoyage.code &amp; "?";

	create theReport;
	theReport.initReport;
	theReport.lblTitle01.caption :=  app.getProductName;
	theReport.lblTitle03.caption :=  null; //app.myRoot.getVersionAndPatchLevel();
	theReport.lblTitle04.caption := self.myCurrentVoyage.vesselName.trimBlanks;
	theReport.lblTitle02.caption := self.myCurrentVoyage.code &amp; " -"  ;
	theReport.lblPrintedBy.caption := null;
	theReport.lblPrintedBylbl.caption := null;
	theReport.initReportForLandscape();
	app.printer.setMargins(Print_Landscape,5,5,5,5);
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Side Profile";
	app.printer.setReport(tmpJadeReport);

	app.printer.printPreview := false;
	app.printer.documentType := Print_A4;
	
	
	// ## PRINT THE MAIN SHIP GRAPHIC		
	theReport.printLine("");
	self.frmGridAreaPrint.visible := false;
	theColour := self.frmGridArea.backColor;
	self.frmGridArea.backColor := White;
	app.printer.setPrintPosition(100);				
	thePicture := self.frmGridArea.createPictureIndirect(false,true);
	self.frmGridAreaPrint.move(10,1,1050,500);
	self.frmGridAreaPrint.drawPictureAt(thePicture,1,1);
	app.printer.print(self.frmGridAreaPrint);
	self.frmGridArea.backColor := theColour;
	theReport.printLine("");
	theReport.printLine(self.caption);


//	app.printer.close();
//	app.printPreview(tmpJadeReport, true);

//return
	app.printer.newPage();
	app.printer.setPrintPosition(130);				

	// ### PRINT STATS TABLE
	theReport.printLine("");
	
	self.doCopyInfoTable();
//	thePicture := self.tblGridAreaInfo.createPictureIndirect(true,true);
	thePicture := self.tblGridAreaInfPr.createPictureIndirect(false,true);
	self.frmGridAreaPrint.clearGraphics();
//	self.frmGridAreaPrint.move(10,100,self.tblGridAreaInfo.width,self.tblGridAreaInfo.height);
	self.frmGridAreaPrint.move(10,100,self.tblGridAreaInfPr.width,self.tblGridAreaInfPr.height);
	self.frmGridAreaPrint.drawPictureAt(thePicture,1,1);
	app.printer.print(self.frmGridAreaPrint);


	// ### PRINT LINE GRAPH
	theReport.printLine("");
	thePicture := self.frmCraneMove.createPictureIndirect(false,true);
	self.frmGridAreaPrint.clearGraphics();
	self.frmGridAreaPrint.move(10,1,self.frmCraneMove.width,self.frmCraneMove.height);
	self.frmGridAreaPrint.drawPictureAt(thePicture,1,1);
	app.printer.print(self.frmGridAreaPrint);
	
	
	
	app.printer.close();
	app.printPreview(tmpJadeReport, true);
	
epilog
	self.frmGridAreaPrint.visible := false;
	self.frmGridArea.left := 5;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuCrane" id="ef6c29ea-c3a4-402f-83cc-039181e5aab6">
        <source>doBuildMnuCrane(_crane : CM_Crane);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
	aJob,theJob : CM_VoyageJob;
	theBay, theBayAft : CM_Bay;
	aJS : CM_JobSheet;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		if _crane.id = aJS.CM_VoyageJobSheet.crane then
			if aJS.CM_VoyageJobSheet.myCurrentJob &lt;&gt; null then
				theJob := aJS.CM_VoyageJobSheet.myCurrentJob.CM_VoyageJob;
				break;
			endif;
		endif;
	endforeach;
	if theJob &lt;&gt; null then
		theJob.getBays(theBay, theBayAft);
	endif;
	self.mnuProfileCrane.caption := "Crane " &amp; _crane.id;
	if theBay &lt;&gt; null then
		mnuChild := self.mnuProfileCrane.getMenuItem(1); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := self.mnuProfileCrane.loadSubMenu(1); // Clone menu
		endif;
		mnuChild.caption := "Crane " &amp; _crane.id &amp; " Planning Bay " &amp; theBay.id &amp; "...";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := "PLANNING";
		mnuChild.userObject := theBay;
	endif;
	if theJob &lt;&gt; null then
		// ### OOW
		mnuChild := self.mnuProfileCrane.getMenuItem(2); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := self.mnuProfileCrane.loadSubMenu(2); // Clone menu
		endif;
		mnuChild.caption := "Crane " &amp; _crane.id &amp; " OOW Jobs...";
		mnuChild.visible := true;
		mnuChild.helpKeyword := "OOW";
		mnuChild.enabled := true;
		mnuChild.userObject := _crane;
		// ### JOB MAINT
		mnuChild := self.mnuProfileCrane.getMenuItem(3); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := self.mnuProfileCrane.loadSubMenu(3); // Clone menu
		endif;
		mnuChild.caption := "Crane " &amp; _crane.id &amp; " Edit Job " &amp; theJob.jobNum &amp; "...";
		mnuChild.helpKeyword := "EDIT";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.userObject := theJob;

	endif;
end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="2182b54a-6976-4d23-8abb-511877885da6">
        <source>doBuildMnuZoom(_theZoomMenu : MenuItem input);
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	_theZoomMenu.visible := false;
end;</source>
        <Parameter name="_theZoomMenu" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbAreasBuild" id="56e4cf98-9f1a-4165-b807-ffb1a7d14f28">
        <updating/>
        <source>doCmbAreasBuild() updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage : CM_Voyage;
	aBay : CM_Bay;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	self.cmbArea.clear;
	
	create theVoyages transient;
	
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,true, false);
	
	foreach	aVoyage in theVoyages do
//		if not aVoyage.hasStructureOfType(CellularStructure) and
//		   not aVoyage.hasStructureOfType(CellularStructureRORO) then	// PAR 21745 CCMS MES 1031
//			continue;
//		endif;
		
		idx := self.cmbArea.addItem(aVoyage.code.trimBlanks &amp; " " &amp; aVoyage.vesselName.trimBlanks);
		self.cmbArea.itemObject[idx] := aVoyage;
	endforeach;
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();
	
	if aVoyage &lt;&gt; null then // PAR 20252
		if self.cmbArea.findObject(aVoyage) &gt; 0 then // PAR 20252
			self.cmbArea.listObject := aVoyage; // PAR 20252
			self.myCurrentVoyage := aVoyage; // PAR 20252
		endif;
	endif;
	
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageClick" id="ff86ced9-7bbb-4780-b1d0-f5f3ea09bbfe">
        <updating/>
        <source>doComboVoyageClick(_combo: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 18/08/2011	cnwcs5	Fixed exception when coming into form with app.myCurrentVoyage = null
// 08/11/2012	CNWCS5	PAR 30519 - delay notifications
vars
	terminal		: CM_Terminal;
	voyage, 
	currentVoyage 	: CM_Voyage;
	table			: Table;
	showROROKPI		: Boolean;
begin
	_combo.backColor := _combo.itemBackColor[_combo.listIndex];
	_combo.foreColor := _combo.itemForeColor[_combo.listIndex];
	
	terminal	:= self.myTerminal;
	voyage 		:= _combo.itemObject[_combo.listIndex].CM_Voyage;
	
	if voyage &lt;&gt; null then
		currentVoyage := self.myCurrentVoyage;
		
		// PAR 20252 we now drill through from Voyage Enquiry so need to setup notes for any voyage, 
		// as this screen now shows KPI details not just a graphic.
		if self.myCurrentVoyage &lt;&gt; voyage and currentVoyage &lt;&gt; null then
			// we have to end notifications individually as we have a web cam notification that is registered for the life of the form
			self.endNotification(currentVoyage, terminal.getTerminalEvent(Voyage_Update_Event));
			self.endNotification(currentVoyage, EVENT_WLE_COMPLETE);
			self.endNotification(currentVoyage, terminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED));
			self.endNotification(currentVoyage, terminal.getTerminalEvent(EVENT_KPISHIPMOVEUPDATE));
			
			self.endNotification (currentVoyage, terminal.getTerminalEvent (EVENT_DELAY_CREATE));	// PAR 30519
			self.endNotification (currentVoyage, terminal.getTerminalEvent (EVENT_DELAY_UPDATE));	// PAR 30519
			self.endNotification (currentVoyage, terminal.getTerminalEvent (EVENT_DELAY_DELETE));	// PAR 30519
			
			table := self.tblDelays;		table.rows	:= table.fixedRows;
			table := self.tblTimings;		table.rows 	:= table.fixedRows;
			table := self.tblBays;			table.rows 	:= table.fixedRows;
			table := self.tblStats;			table.rows 	:= table.fixedRows;
			
			self.tblRORODecks.rows	:= 0;
			self.tblROROMoves.rows	:= 0;
			
			if self.myVesselVoyageController = null then
				create self.myVesselVoyageController;
			endif;
			
			self.myVesselVoyageController.init();
		endif;
		
		self.beginNotification(voyage, terminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);
		self.beginNotification(voyage, EVENT_WLE_COMPLETE, Response_Continuous, null);
		self.beginNotification(voyage, terminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), Response_Continuous, null);
		self.beginNotification(voyage, terminal.getTerminalEvent(EVENT_KPISHIPMOVEUPDATE), Response_Continuous, null);
		
		self.beginNotification (voyage, terminal.getTerminalEvent (EVENT_DELAY_CREATE), Response_Continuous, null);	// par 30519
		self.beginNotification (voyage, terminal.getTerminalEvent (EVENT_DELAY_UPDATE), Response_Continuous, null);	// par 30519
		self.beginNotification (voyage, terminal.getTerminalEvent (EVENT_DELAY_DELETE), Response_Continuous, null);	// par 30519
		
		self.kpiDetail := self.KPIDetail_Voyage;
		
		self.setCurrentVoyage(voyage);
		app.setMyCurrentVoyage(voyage);
		// does not matter what we pas as the parameter here
		self.setCaption(null); 
		
		self.sdf01.viewMode 		:= TI_ColourMode_DischargePort;
		self.flipH 					:= not voyage.starboardBerthed; // flip if port berthed
		self.sdf01.drawInReverse 	:= self.flipH;
		
		// set up the notes for this voyage
		self.sdf01.doNotableClear();
		self.sdf01.doNotableAdd(voyage);
		
		self.fldMain.topSheet := self.shtProfile;
	else
		// append terminal to caption
		self.setCaption (null);
	endif;	
	
	showROROKPI	:= self.isShowROROKPI;

	self.shtRORODecks.visible	:= showROROKPI;
	self.shtROROMoves.visible	:= showROROKPI;

	self.doDrawGridArea();
	self.showCraneMoves();
	 // PAR 36118self.showTableStats();
	self.showTableStatsAB(); // PAR 36118
	self.showTimings();

//	TI_ColourMode_DischargePort
//	self.frmColLegendTIs.displayDischPortForVoyage(self.myCurrentVoyage);	//There is only the one view mode by Disharge Port in the form. Par 18247 Mar 2009
	self.doDrawingLegend();

	self.sptBottom.cnEcResizeContents();
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCopyInfoTable" id="3e7847fa-f128-49c7-8011-1ee721c06ad4">
        <source>doCopyInfoTable();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		The table to picture method creates a picture of what is on the screen. 
//				So if the table has scroll bars you get a cropped picture of the table info.
//				This method copies the data to another table for printing.
//
// ---------------------------------------------------------------------------

vars
	frTable, toTable : CM_DataTable;
	aRow, aCol, idx : Integer;
	tmpTxt : String;
begin
	frTable := self.tblGridAreaInfo;
	toTable := self.tblGridAreaInfPr;
	
	toTable.borderStyle := Table.BorderStyle_Single;
	toTable.columns := frTable.columns;
	toTable.rows := frTable.rows + 1;
	toTable.accessColumn(1).backColor := frTable.accessColumn(1).backColor;
	toTable.fixedRows := frTable.fixedRows;
	toTable.fixedColumns := toTable.fixedColumns;
	toTable.fixed3D := false;
	
	foreach aCol in 1 to frTable.columns do
		toTable.accessColumn(aCol).width := frTable.accessColumn(aCol).width;
		foreach aRow in 1 to frTable.rows do
			tmpTxt := frTable.accessCell(aRow,aCol).text ;
			
			toTable.accessCell(aRow + 1,aCol).text := tmpTxt;
			toTable.accessedCell.fontBold := frTable.accessedCell.fontBold;
		endforeach;
	endforeach;
	toTable.move(1,1,800,200);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawGridArea" id="04036adf-8010-4050-b441-3b206d583a34">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDrawGridArea() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/11/2012	cnwcs5		par 30519 - took out call to setNavigatorHeading
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	cmuiGridArea 			: CMUI_GridArea;
	theGridXMLCompressed 	: Binary;
	theGridXML 				: String;
	startTime, endTime 		: TimeStamp;
	drawAttrs				: CMIF_DrawingAttrController;
	drawing					: CMUI_ScrollableDrawingFrame;
	voyage					: CM_Voyage;
begin
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	app.mousePointer 	:= Window.MousePointer_HourGlass;
	startTime 			:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	drawing				:= self.sdf01;
	voyage 				:= self.myCurrentVoyage;
	
	// 34696 extend to RORO structure as well
	if voyage = null or (voyage.myCellularVoyageStructure = null and voyage.myROROStructure = null) then
		drawing.visible := false;
		return;
	else
		drawing.visible := true;
	endif;
	
	self.modalDialogShow(null,null, null, null, app.getErrorString1 (Loading_voyage, voyage.code), app.getErrorString (Getting_voyage_data));
	
	// ###########################
	// This gets the actual cells, teirs and slots etc in XML
	create drawAttrs transient;
	
	// 34696 handle voyages with RORO structures only
	if voyage.myCellularVoyageStructure &lt;&gt; null then
		theGridXMLCompressed := voyage.myCellularVoyageStructure.getXMLGridSideProfile(true, ShpDisplayMode_Defn, null, self.flipH); // PAR 17551
		theGridXML := theGridXMLCompressed.uncompressToString();
	elseif voyage.myROROStructure &lt;&gt; null then
		theGridXML := voyage.myROROStructure.getXMLGridSideProfile();
	endif;
	
	// ###########################
	// this gets rid of all the existing bays etc.
	drawing.purgeAllGridAreas();
	
	drawing.myHLabels.visible 				:= false;
	drawing.myVLabels.visible 				:= false;
	drawing.myTopLeftFillerFrame.visible	:= false;
	cmuiGridArea 							:= self.frmGridArea.myGridArea;
	
	delete cmuiGridArea;

	self.frmGridArea.visible := true;
	
	self.myAssistant.allGridAreasByLabel.purge;

	self.modalDialogUpdateInfo(app.getErrorString (Building_voyage_data));	
	
	// ##################################
	// create the transients that describe the look of the bays etc. using the XML.
	self.gridXMLCreate(theGridXML);
	
	self.modalDialogUpdateInfo(app.getErrorString (Drawing_voyage_data));	

	// #####################################
	// Put the transient grid  objects on the screen
	drawing.drawSelf();

	endTime := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	// par 30519 - no need to set navigator heading here
	self.doResize();
	drawing.setFocus();
	
epilog
	delete drawAttrs;
	
	app.mousePointer 			:= Window.MousePointer_Default;
	self.frmModalDialog.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawingLegend" id="118b91ab-d2f2-486c-9393-da407181978e">
        <source>doDrawingLegend() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2012	cnwer1	Initial creation SFW 1295

*/
constants
	ArrowWidth = 14;
	ArrowHeight = 23;
	PointHeight = 5;
	SquareWidth = 12;
	SquareHeight = 15;
vars
	shipProfileArea : SHP_ProfileArea;
	startX, startY : Integer;
	allPoints : RealArray;
	minleft : Integer;
begin
	self.frmDrawLegend.parent := self.frmGridArea;//self.myCurrentSDF;
	self.frmDrawLegend.top:=0;
	// from 34696 handle last-saved option being off and keep the option on change of voyage
	if self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW or
	   self.myCurrentVoyage = null then
		self.frmDrawLegend.visible := false;
	else
		self.frmDrawLegend.visible := true;
	endif;

	self.doResizeDrawingLegend();
	self.frmDrawLegend.backColor :=White;
	self.frmDrawLegend.transparent :=false;//true;//:=Gray;
	self.frmDrawLegend.clearGraphics;
	self.frmDrawLegend.autoRedraw:=true;
	self.frmDrawLegend.drawTextAlign := Frame.DrawTextAlign_Center;
	self.frmDrawLegend.drawFontSize := 7;
	self.frmDrawLegend.drawFontName := "Microsoft Sans Serif";
	
	startX :=5;
	startY :=self.lblKeyLoad.top.Integer + 5;
	

	create allPoints transient;
	allPoints.add(startX);allPoints.add(startY); // ## 1
	allPoints.add(startX + ArrowWidth);allPoints.add(startY); // ## 2
	allPoints.add(startX + ArrowWidth);allPoints.add(startY+ ArrowHeight - PointHeight); // ## 3
	allPoints.add(startX + (ArrowWidth/2));allPoints.add(startY + ArrowHeight); // ## 4
	allPoints.add(startX);allPoints.add(startY+ ArrowHeight - PointHeight); // ## 5
	
	frmDrawLegend.drawFillColor := Blue;
	frmDrawLegend.drawFilledPolygon(allPoints,Black);
	frmDrawLegend.drawTextAt("10",startX + (ArrowWidth/2),startY - 1,White);
	frmDrawLegend.drawTextAt("8",startX + (ArrowWidth/2),startY + 8,White);
	
	startY:=self.lblKeyDischarge.top.Integer + 5;  
	
	allPoints.clear;
	allPoints.add(startX);allPoints.add(startY +PointHeight); // ## 1
	allPoints.add(startX + (ArrowWidth/2));allPoints.add(startY); // ## 2
	allPoints.add(startX + ArrowWidth);allPoints.add(startY + PointHeight); // ## 3
	allPoints.add(startX + ArrowWidth);allPoints.add(startY + ArrowHeight); // ## 4
	allPoints.add(startX);allPoints.add(startY + ArrowHeight); // ## 5
	
	frmDrawLegend.drawFillColor := Green;
	frmDrawLegend.drawFilledPolygon(allPoints,Black);
	frmDrawLegend.drawTextAt("10",startX + (ArrowWidth/2),startY + 1,White);
	frmDrawLegend.drawTextAt("5",startX + (ArrowWidth/2),startY + 11,White);
	
	startY:=self.lblKeyBay.top.Integer + 5;
	
	frmDrawLegend.drawFillColor := White;
	frmDrawLegend.drawFilledRectangle(startX,startY,startX  + ArrowWidth,startY + SquareHeight,Black);
	frmDrawLegend.drawTextAt("01",startX + (ArrowWidth/2),startY + 1,Black);
	
	startY:=self.lblKeyTotalCC.top.Integer + 5; 
	
	frmDrawLegend.drawFillColor := Black;
	frmDrawLegend.drawFilledRectangle(startX  ,startY,startX  + ArrowWidth + 1,startY + SquareHeight,White);
	frmDrawLegend.drawTextAt("10",startX + (ArrowWidth/2), startY + 1,White);
	
	startY:=self.lblKeyIncom.top.Integer + 5; 
	
	frmDrawLegend.drawFillColor := Black;
	frmDrawLegend.drawFilledRectangle(startX  ,startY,startX  + ArrowWidth + 1,startY + SquareHeight,White);
	frmDrawLegend.drawTextAt("8",startX + (ArrowWidth/2), startY + 1,White);
	
	startY:=self.lblKeyCrane.top.Integer+ 5; 
	
	allPoints.clear;
	allPoints.add(startX);allPoints.add(startY +PointHeight); // ## 1
	allPoints.add(startX + (ArrowWidth/2));allPoints.add(startY); // ## 2
	allPoints.add(startX + ArrowWidth);allPoints.add(startY + PointHeight); // ## 3
	allPoints.add(startX + ArrowWidth);allPoints.add(startY + ArrowHeight); // ## 4
	allPoints.add(startX);allPoints.add(startY + ArrowHeight); // ## 5
	
	frmDrawLegend.drawFillColor := LightGreen;
	frmDrawLegend.drawFilledPolygon(allPoints,Black);
	frmDrawLegend.drawTextAt("C1",startX + (ArrowWidth/2),startY + 6,Black);

epilog
	delete allPoints;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseDownEvent" id="03042eed-dc3c-4199-a7f8-d970ca78d537">
        <updating/>
        <source>doGridAreaMouseDownEvent(frame: Frame input;button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	anObject	: CM_Object;
begin
	if frame.CMUI_GridAreaFrame.myGridArea = null then
		return;
	endif;

	//write method.qualifiedName&amp;" x="&amp;x.String&amp;" y="&amp;y.String;
	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y); //frmGridArea
	if gridPoint &lt;&gt; null then
		self.showExtraInfo(gridPoint,x,y);
		//write " point.x1="&amp;gridPoint.x1.String
		//		&amp;" x2="&amp;gridPoint.x2.String&amp;" y1="&amp;gridPoint.y1.String&amp;" y2="&amp;gridPoint.y2.String;
	else
		anObject := frame.CMUI_GridAreaFrame.myGridArea.getObjectLabel(null,null,y.Integer , 25);
		if anObject &lt;&gt; null then
			self.mnuProfileCrane.visible := true;
			self.doBuildMnuCrane(anObject.CM_Crane);
		else
			self.mnuProfileCrane.visible := false;

		endif;
	endif;

	if button = Window.MouseButton_Left  then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doInitialiseSDF" id="2c5966a0-fc91-42f1-a6d9-18a1ec93cd72">
        <updating/>
        <source>doInitialiseSDF() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin

	self.moveModeForm := self.myTerminal.getConfig(StartupMoveMode).Integer;
	
	self.sdf01.setHLabelDetails(30);
	self.sdf01.setVLabelDetails(30);
	self.sdf01.labels := ScrollBars_Both;
	self.sdf01.myTerminal := self.myTerminal;
	self.sdf01.setupFrame();
	
	self.sdf01.viewMode := TI_ColourMode_DischargePort;
	self.sdf01.displayMode := DISPLAY_MODE_ACTUAL;
	self.sdf01.myDrawingFrame.backColor := COLOUR_WATER;
	self.backColor := COLOUR_WATER;
	self.frmGridArea.backColor := COLOUR_WATER;
	self.sdf01.moveMode := self.moveModeForm;
	self.sdf01.myParentForm := self;
	
	self.setMyCurrentSDF(self.sdf01,false);
	self.sdf01.scaleFactor := 1;
	self.sdf01.backColor := COLOUR_WATER;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doKPIExport" id="44f7f080-e056-4940-8027-fdeecf59cfd5">
        <source>doKPIExport();
// ---------------------------------------------------------------------------
// Created:		25 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 17/08/2011	cnwcs5	CCMS MES 1033 RORO KPI
// 15/05/2023   navmk20	Bug 57851: POL - Side Profile Export to CSV not working for Delays Tab
vars
	ts		: TimeStamp;
	sheet	: Sheet;
begin
	ts 		:= app.actualTimeServer;
	sheet 	:= self.fldMain.topSheet;
	
	if sheet = self.shtBays then
		self.tblBays.outputAsCSV("JMTBayDtls" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
		
	elseif sheet = self.shtMoves then
		self.tblStats.outputAsCSV("JMTMoves" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
		
	elseif sheet = self.shtTimings then
		self.tblTimings.outputAsCSV("JMTTimings" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
		
	elseif sheet = self.shtRORODecks then
		self.tblRORODecks.outputAsCSV("JMTRORODecks" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
		
	elseif sheet = self.shtROROMoves then
		self.tblROROMoves.outputAsCSV("JMTROROMoves" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
	// Start 15.5.2023 navmk20 57851
	elseif sheet = self.shtDelays then
		self.tblDelays.outputAsCSV("JMTDelays" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv");
		
	elseif sheet = self.shtProfile then
		self.tblGridAreaInfo.outputAsCSV("JMTSideProfile" &amp; ts.date.formatAsYYYYMMDD() &amp; ".csv"); 
	endif;
	// End 15.5.2023 navmk20 57851

end;</source>
    </JadeMethod>
