// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if combobox.listObject &lt;&gt; null then
		self.myFiltLogLot := combobox.listObject.CM_LogLot;
	else
		self.myFiltLogLot := null;
	endif;
	
	self.doSearch();
end;</source>
