<Class name="WS_User" id="c326d0d1-bf97-47da-89cb-121d6e1f1ed3">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents all users used in the system</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="2349b458-ee7b-4a2a-be60-f22e1d28ba0b">
        <type name="String"/>
        <text>User code ex.web</text>
    </PrimAttribute>
    <PrimAttribute name="emailAddress" id="d6e40869-6395-4f17-9a50-858cb855730d">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myUser" id="86a5adf0-97ee-4200-ab5a-6c7dd963696d">
        <embedded/>
        <type name="CM_User"/>
    </ImplicitInverseRef>
    <PrimAttribute name="userName" id="74b094f7-ba9f-48aa-90ad-66c9f140421c">
        <type name="String"/>
        <text>User name ex.Web user (WEB)
Concatenated user name and user name. ex.[Web user(Web)]</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="e411937f-c51b-4d0d-8de8-7d12c3c7b6b4">
        <updating/>
        <source>setProxyFromObject  (_object: CM_User) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	inheritMethod(_object);
	
	self.code := _object.code;
	//self.userName := _object.userName &amp; " (" &amp; _object.code &amp; ")";
	self.userName := _object.userName;
	self.myUser := _object;
	
	if _object.myEmailEntity &lt;&gt; null then
		self.emailAddress := _object.myEmailEntity.getEmailAddress();
	endif;

epilog

end;</source>
        <Parameter name="_object" type="CM_User"/>
    </JadeMethod>
</Class>
