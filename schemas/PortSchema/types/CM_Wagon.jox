	criteriaCodes : CM_StringArray;

begin
	
	foreach cont in self.allLocationsControllers do 
		foreach wle in cont.CM_WagonController.allRailWLELoad do
			myRequest := wle.myRequest;
			if myRequest &lt;&gt; null then
				myReserveDetail :=  myRequest.myReserveDetail;
				if myReserveDetail &lt;&gt; null then
				
					criteriaCodes := myReserveDetail.getMyCommodityCriteriaDesc();
					
					if criteriaCodes &lt;&gt; null then
						foreach myCommodityCriteriaDesc in criteriaCodes do
							/*
							if data.pos(myCommodityCriteriaDesc,1) = 0 then
								if data = null then
									data := myCommodityCriteriaDesc;
								else
									data := data &amp; ", " &amp; myCommodityCriteriaDesc;
								endif;
							endif; 
							*/
							
							data.addStringToList(myCommodityCriteriaDesc, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
						endforeach; 
