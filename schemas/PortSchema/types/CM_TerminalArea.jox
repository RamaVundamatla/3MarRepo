    <JadeMethod name="getExtraInfo" id="c40174de-ba67-4704-8905-bbc286476975">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 30 Oct 2008	consw1		SFW1030 - Remove unused auto plan flags
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	yal : CM_YardAllocation;
begin
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, null);
	block.addNewItem(self.id, DC_Data, 1, null);
	
	// CCMS 1013
	//foreach yal in self.allYardAllocations do
	foreach yal in self.allYardAllocations where yal.includeInYardDisplays() do
		block := _dataContainer.addNewBlock;
		block.addNewItem("Yard Allocation", DC_MoreInfo, 1, self);
		yal.getExtraInfo(_dataContainer);
	endforeach;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
