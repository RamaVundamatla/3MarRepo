<Class name="BGP_LocationStatistics" id="da96fd1f-7704-4250-a073-9061e2023a04">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Location Statistics&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="finish" id="b05bc5fd-fbb2-49a0-b2ff-c0c83c414c70">
        <updating/>
        <source>finish() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	conkc1	Initial creation

*/

vars

begin
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initApp" id="78e60085-9b54-4013-b7a1-5e0c430af607">
        <updating/>
        <source>initApp() updating;
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1		PAR #18009 - Allow ini file control of transient check

*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	ls      	: Boolean;
	str	        : String;
	errorText	: String;
	errorCode	: Integer;
	movementLogController : CMIF_MovementLogController;
	msg : String;
begin

	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; 
	
	app.setCnAppAlias(self.class.name);		 //epr TFS 36655 29/4/19
	
	app.initialize();

	app.setIsBackGroundApp(true);
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009
 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	create movementLogController transient;
	movementLogController.initMovementLog;
epilog
	app.cmsEndLoad(ls);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="d4186bfd-42e1-4bc1-a944-78f062b5d0f3">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

vars

begin
	self.name				:= 'Location Statistics';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
