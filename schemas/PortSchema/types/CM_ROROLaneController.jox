    <JadeMethod name="getFullId" id="5f297af6-b7bd-4576-bcc7-cbf29c75e47d">
        <source>getFullId() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	ti : CM_TrackedItem;
	tmpStr : String;
begin
	
	if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;
	return tmpStr &amp; " " &amp; self.ident;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
