    <JadeMethod name="cloneOnto" id="bd1f554b-515b-4602-a6e8-f0505ea1be90">
        <source>cloneOnto( _movement : HMS_Movement input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39296

*/

vars

	timings : HMS_MarineServicesTimings;
	
begin

	timings := self.cloneSelf( _movement.isTransient );
	timings.setMyVoyageMovement( _movement );

epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChangeFromProxy" id="7f451f74-c9ab-4f07-829e-8ac76b25fdee">
        <source>createPropertyChangeFromProxy(_transaction : HMS_Transaction; _pxyMarineServices : HMS_MarineServicesTimings);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars
	oldStr,
	newStr:			String;
 	propertyChange:	HMS_PropertyChange;
begin
	if _pxyMarineServices = null then
		return;
	endif;
	
    if self.hasRamp &lt;&gt; _pxyMarineServices.hasRamp then
		create propertyChange;
   		propertyChange.set(_transaction, "Has Ramp", self.hasRamp.asStringJMT,_pxyMarineServices.hasRamp.asStringJMT);
	endif;
	
	if self.linesActualTS &lt;&gt; _pxyMarineServices.linesActualTS then
		oldStr := self.linesActualTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.linesActualTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Lines Actual", oldStr,newStr);
	endif;
	
	if self.linesApprovedTS &lt;&gt; _pxyMarineServices.linesApprovedTS then
		oldStr := self.linesApprovedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.linesApprovedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Lines Approved", oldStr,newStr);
	endif;
	
	if self.linesRemarks &lt;&gt; _pxyMarineServices.linesRemarks then
		create propertyChange;
   		propertyChange.set(_transaction, "Lines Remarks", self.linesRemarks, _pxyMarineServices.linesRemarks);
	endif;
	
	if self.linesRequestedTS &lt;&gt; _pxyMarineServices.linesRequestedTS then
		oldStr := self.linesRequestedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.linesRequestedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Lines Requested", oldStr,newStr);
	endif;
	
	if self.movementActualTS &lt;&gt; _pxyMarineServices.movementActualTS then
		oldStr := self.movementActualTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.movementActualTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Movement Actual", oldStr,newStr);
	endif;
	
	if self.movementApprovedTS &lt;&gt; _pxyMarineServices.movementApprovedTS then
		oldStr := self.movementApprovedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.movementApprovedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Movement Approved", oldStr,newStr);
	endif;
	
	if self.movementBerthArrival &lt;&gt; _pxyMarineServices.movementBerthArrival then
		oldStr := self.movementBerthArrival.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.movementBerthArrival.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Movement Berth Arrival", oldStr,newStr);
	endif;
	
	if self.movementRemarks &lt;&gt; _pxyMarineServices.movementRemarks then
		create propertyChange;
   		propertyChange.set(_transaction, "Movement Remarks", self.movementRemarks,_pxyMarineServices.movementRemarks);
	endif;
	
	if self.movementRequestedTS &lt;&gt; _pxyMarineServices.movementRequestedTS then
		oldStr := self.movementRequestedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.movementRequestedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Movement Requested", oldStr,newStr);
	endif;
	
	if self.pilotActualTS &lt;&gt; _pxyMarineServices.pilotActualTS then
		oldStr := self.pilotActualTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotActualTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Actual", oldStr,newStr);
	endif;
	
	if self.pilotApprovedTS &lt;&gt; _pxyMarineServices.pilotApprovedTS then
		oldStr := self.pilotApprovedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotApprovedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Approved", oldStr,newStr);
	endif;
	
	if self.pilotFinishMoving &lt;&gt; _pxyMarineServices.pilotFinishMoving then
		oldStr := self.pilotFinishMoving.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotFinishMoving.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Finish Moving", oldStr,newStr);
	endif;
	
	if self.pilotOffboard &lt;&gt; _pxyMarineServices.pilotOffboard then
		oldStr := self.pilotOffboard.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotOffboard.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Off Board", oldStr,newStr);
	endif;
	
	if self.pilotRemarks &lt;&gt; _pxyMarineServices.pilotRemarks then
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Remarks", self.pilotRemarks,_pxyMarineServices.pilotRemarks);
	endif;
	
	if self.pilotRequestedTS &lt;&gt; _pxyMarineServices.pilotRequestedTS then
		oldStr := self.pilotRequestedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotRequestedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Requested", oldStr,newStr);
	endif;
	
	if self.pilotStartsMoving &lt;&gt; _pxyMarineServices.pilotStartsMoving then
		oldStr := self.pilotStartsMoving.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.pilotStartsMoving.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Start Moving", oldStr,newStr);
	endif;
	
	if self.pilotSurchargeInvLIneTypeRTS &lt;&gt; _pxyMarineServices.pilotSurchargeInvLIneTypeRTS then
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Surcharge Inv Line Type RTS", self.pilotSurchargeInvLIneTypeRTS.asStringJMT,_pxyMarineServices.pilotSurchargeInvLIneTypeRTS.asStringJMT);
	endif;
	
	if self.pilotSurchargeInvLIneTypeVNR &lt;&gt; _pxyMarineServices.pilotSurchargeInvLIneTypeVNR then
		create propertyChange;
   		propertyChange.set(_transaction, "Pilot Surcharge Inv Line Type VNR", self.pilotSurchargeInvLIneTypeVNR.asStringJMT,_pxyMarineServices.pilotSurchargeInvLIneTypeVNR.asStringJMT);
	endif;
	
	if self.tugsActualTS &lt;&gt; _pxyMarineServices.tugsActualTS then
		oldStr := self.tugsActualTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsActualTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Actual", oldStr,newStr);
	endif;
	
	if self.tugsActualTSTo &lt;&gt; _pxyMarineServices.tugsActualTSTo then
		oldStr := self.tugsActualTSTo.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsActualTSTo.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Actual To", oldStr,newStr);
	endif;
	
	if self.tugsApprovedTS &lt;&gt; _pxyMarineServices.tugsApprovedTS then
		oldStr := self.tugsApprovedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsApprovedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Approved", oldStr,newStr);
	endif;
	
	if self.tugsApprovedTSTo &lt;&gt; _pxyMarineServices.tugsApprovedTSTo then
		oldStr := self.tugsApprovedTSTo.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsApprovedTSTo.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Approved To", oldStr,newStr);
	endif;
	
	if self.tugsRemarks &lt;&gt; _pxyMarineServices.tugsRemarks then 
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Remarks", self.tugsRemarks,_pxyMarineServices.tugsRemarks);
	endif;
	
	if self.tugsRequestedTS &lt;&gt; _pxyMarineServices.tugsRequestedTS then
		oldStr := self.tugsRequestedTS.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsRequestedTS.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Requested", oldStr,newStr);
	endif;
	
	if self.tugsRequestedTSTo &lt;&gt; _pxyMarineServices.tugsRequestedTSTo then
		oldStr := self.tugsRequestedTSTo.shortCurrentLocaleSystemUTC();
		newStr := _pxyMarineServices.tugsRequestedTSTo.shortCurrentLocaleSystemUTC();
		create propertyChange;
   		propertyChange.set(_transaction, "Tugs Requested To", oldStr,newStr);
	endif;
	
epilog

end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_pxyMarineServices" type="HMS_MarineServicesTimings"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="3c6a9803-094e-4ba4-b8d0-c9f2538e74ab">
        <source>createTransaction(_type : Integer; _pxyMST : HMS_MarineServicesTimings; _passport : CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars
	cmifTrans 	: CMIF_HMS_TransactionController;
	movement	: HMS_Movement;
	hmsVoy		: HMS_VoyageMovement;
begin
	create cmifTrans transient;
	
	cmifTrans.myMarineServicesTimings := self;
	cmifTrans.myProxyHMSObject := _pxyMST;
	movement := self.myMovement;
	if movement = null then
		return;
	endif;
	if movement.isHMSVoyageMovement then
		hmsVoy := movement.HMS_VoyageMovement;
		cmifTrans.myHMSVoyageData := hmsVoy.myHMSVoyageData;
	endif;
	
	// set the terminal
	if cmifTrans.myTerminal = null then
		cmifTrans.myTerminal := _passport.myTerminal;
	endif;
	// set the type
	cmifTrans.type := _type;
	// create the transaction
	cmifTrans.createTransaction(_passport);
epilog
	delete cmifTrans;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_pxyMST" type="HMS_MarineServicesTimings"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
