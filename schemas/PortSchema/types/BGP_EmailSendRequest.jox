end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSourceDescription" id="b01e2273-9b06-4003-9420-f22a1a6640a1">
        <source>getSourceDescription(_sourceOfEmail, _instanceId : Integer) : String protected;
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
vars

	desc,
	rtnStr : String;

begin

	if _sourceOfEmail = EmailSource_CAMS then
		desc := app.getErrorString(CAMS);
	elseif _sourceOfEmail = EmailSource_EDI then
		desc := app.getErrorString(EDI);
	elseif _sourceOfEmail = EmailSource_HMS then
		desc := app.getErrorString(HMS);
	elseif _sourceOfEmail = EmailSource_Reports then
		desc := app.getErrorString(Reports);
	elseif _sourceOfEmail = EmailSource_Remote then
		desc := app.getErrorString(Remote_XML_Processing);
	elseif _sourceOfEmail = EmailSource_System then
		desc := app.getErrorString(System_GC);
	elseif _sourceOfEmail = EmailSource_Gate then
		desc := app.getErrorString(Gate);
	elseif _sourceOfEmail = EmailSource_VBS then	// 20 Mar 2015	NDL	Par 35882
		desc := app.getErrorString(Vehicle_schedul_booking_slot);
	elseif _sourceOfEmail = EmailSource_UserPW then
		desc := app.getErrorString(Password_reset); // User Password Reset
	elseif _sourceOfEmail = EmailSource_WorkOrder then	//23 Aug 2018	NDL	TFS 40216
		desc := app.getErrorString(WorkOrder);
	elseif _sourceOfEmail = EmailSource_Invoice then // ### TFS 55514 18JAN2023 NAVAB1
		desc := app.getErrorString(Invoice); // ### TFS 55514 18JAN2023 NAVAB1
	else
		desc := app.getErrorString(Unknown);
	endif;
	
	rtnStr :=  desc &amp; ' (ID - ' &amp; _instanceId.String &amp; ').';
	return rtnStr;
end;</source>
        <access>protected</access>
        <Parameter name="_sourceOfEmail" type="Integer"/>
        <Parameter name="_instanceId" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handlePollError" id="562fcc3a-abc2-44cf-b1a8-1467d02a0832">
        <source>handlePollError() : Boolean protected;
// -------------------------------------------
// Created 03 March 2004 by cnwdvb1
// -------------------------------------------
// This method is used to deterine whether it is time
// to alert the uses that the system has failed to make
// a connection to the pop server for a number of times
// and is therefore unable to check the email.
vars

	task	: CM_AutoTaskEmail;
	rtn		: Boolean;

begin

	if global.isValidObject(self.myUpdateCallbackObject) and self.myUpdateCallbackObject.isKindOf(CM_AutoTaskEmail) then
		task := self.myUpdateCallbackObject.CM_AutoTaskEmail;
		beginTransaction;
		exclusiveLock(task);
		rtn := task.checkPollTimeOnError(app.actualTimeServer, self);
		commitTransaction;
		return rtn;
	endif;
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initSendEmail" id="9f9b4e9f-b76d-479b-b307-ad059a37547c">
        <updating/>
        <source>initSendEmail(	_checkCanBeProcessed	: Boolean;
				_alertDesc,
				_toAddress,
				_fromAddress,
				_ccAddresses,
				_bccAddresses,
				_subject,
				_message 				: String;
				_allAttachedFilePaths	: HugeStringArray;
				_allFileData			: CM_FileDataStorageHdrSet input;				
				_blob					: Binary;
				_blobFileName			: String;
				_sourceOfEmail			: Integer;
				_updateCallbackObject	: Object) : Integer updating;

// cnwdvb1 10 February 2003 
// Method to initialise sending of email.

vars
/*
	filePath	: String;
	header		: CM_FileDataStorageHeader;
	instanceId	: Integer;*/

begin
	
	self.setEmailRequest(_toAddress,
						_alertDesc,
						_toAddress,
						_fromAddress,
						_ccAddresses,
						_bccAddresses,
						_subject,
						_message,
						app.getMyUser(),
						self.myTerminal,
						_allAttachedFilePaths,
						_allFileData,
						_blob,
						_blobFileName,
						_sourceOfEmail);
	
	return self.sendInitialisedEmail(_checkCanBeProcessed, _updateCallbackObject);

end;</source>
        <Parameter name="_checkCanBeProcessed" type="Boolean"/>
        <Parameter name="_alertDesc" type="String"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_fromAddress" type="String"/>
        <Parameter name="_ccAddresses" type="String"/>
        <Parameter name="_bccAddresses" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_allAttachedFilePaths" type="HugeStringArray"/>
        <Parameter name="_allFileData" type="CM_FileDataStorageHdrSet" usage="input"/>
        <Parameter name="_blob" type="Binary"/>
        <Parameter name="_blobFileName" type="String"/>
        <Parameter name="_sourceOfEmail" type="Integer"/>
        <Parameter name="_updateCallbackObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logAndRaiseException" id="7dddf995-0eaa-4405-ab11-ff3ab6568c21">
        <source>logAndRaiseException(_msg : String) protected;
/*

Purpose:			Move common logging to one method in case we need to change it all again :\

Parameters:			

Return Value:		

Date				Who		Reason
16 January 2024		navmd1	Initial creation TFS 55021

*/

vars
	
begin
	if _msg = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No log message provided");
		return;
	endif;
	
	app.writeLog(_msg, LogERROR);
	app.raiseCMException1(Email_Send_Failure, _msg, null, null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="67dcb76e-94d9-4491-b12d-5bf6e1edea41">
        <source>raiseAlert( _str : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwndl1	Initial creation	Par 27049

*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars
	msg : String;
begin
	msg := "(Active X Control Failure) " &amp; _str;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	app.createAlert(msg, true);

epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendAOS" id="fdbd7752-1c6d-4c71-a9cb-af39ad6eecf5">
        <source>sendAOS() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2007 cnwdvb1 Initial creation
10 Dec 2014	cnwcb2	PAR 35364
06 May 2019	jlgzm1	TFS 43670 '14213' errors propogating 
*/
constants
	NORMAL_RECIPIENT = 0;  
	CARBON_COPY	= 1;
	BLIND_CARBON_COPY = 2;
	
vars
	oSmtp 	: AOSMTP_Mail;
	timeOut	: Integer;
	file,
	userName,
	password,
	tmpStr	: String;
	obj		: Object;
	huge	: HugeStringArray;	
	auth	: Integer;
	thePort,
	theSSL	: Integer;
	theServer,
	theCharSet,
	err		: String;
	isSSL	: Boolean;
	messageRecipientsTest : String; //par 17833 cnwrs1 sept 2008
	systemTestMode : Boolean;
	tmpDir	: String;
	msg : String;
	noSoftware : Boolean; // tfs43670
begin
	on Exception do xHandler(exception, null, noSoftware); // tfs43670

	//systemTestMode := app.myRoot.getConfig(BgpEmailTestMode).Boolean; // systemTestMode is deleted by CCMS 1163 PAR25611. new BgpEmailTestMode flag is introduced in Config System. 11/11/2010
	systemTestMode	:= false;	// Now, emailing mechanism is intact regardless BGP Email Mode: either test or standard. 11/11/2010

	create oSmtp transient;
	
	theServer := app.myRoot.getConfig(AutoSmtpServer).String.trimBlanks();
	oSmtp.serverAddr := theServer;
	// if error then abort
	if noSoftware then 
		return; // tfs43670
	endif;
	msg := 'SMTP Server = ' &amp; theServer;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	thePort := app.myRoot.getConfig(AutoSmtpServerPort).Integer;
	oSmtp.serverPort := thePort;
	msg := 'SMTP Port = ' &amp; thePort.String;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	/* This application utilizes a licensed copy of ADS Objects. ADS
	Objects is copyrighted and owned exclusively by ADMINSYSTEM SOFTWARE
	LIMITED. All rights reserved. Use of the objects outside of the
	context of this application is a violation of federal copyright laws
	and international treaty provisions */
	
	// oSmtp.registerKey := "AM-XS1088813180-00998-0FAD79BC40F009177DCE61A34C4DF1AC";
	// PAR 22506
	app.emailArchitectSetLicenseSMTP(oSmtp);

	theCharSet := app.myRoot.getConfig(AutoCharset).String;
	oSmtp.charset := theCharSet;
	msg := 'Charset = ' &amp; theCharSet;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	timeOut := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	
	if timeOut &lt; 2 or timeOut &gt; 60 then
		timeOut := 30;
	endif;
	
	oSmtp.timeout := timeOut;
	
	theSSL := app.myRoot.getConfig(AutoUseSSL).Integer;
	
	if theSSL &lt;&gt; BGP_EmailSendRequest.SSL_NONE then
		msg := 'Init SSL connection';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		if oSmtp.sSL_init() &lt;&gt; 0 then
			err := oSmtp.getLastErrDescription();
			app.raiseCMException1(Email_SSL_Failure, err, null, null);
			return;
		endif;
		msg := 'Setting SSL value to ' &amp; theSSL.String;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		oSmtp.sSL_starttls := theSSL;
		isSSL := true;
	endif;
	
	// All this needs to be configurable.
	auth := app.myRoot.getConfig(AutoAuthType).Integer;
	
	if auth &lt;&gt; AUTH_NONE then
		oSmtp.authType := auth;
		userName := app.myRoot.getConfig(AutoOutwardAccount).String;
		password := app.myRoot.getPwForUse(AutoOutwardPassword).String;
		
		if userName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Outward Account', null, null);
			app.raiseCMException(Input_required_field_outwrdAcc, null, null); // cnwdb2	PAR 35364

			return;
		endif;
		
		if password = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Outward Password', null, null);
			app.raiseCMException(Input_required_field_outwrdPas, null, null); // cnwdb2	PAR 35364


			
			return;
		endif;
		
		oSmtp.userName := userName;
		oSmtp.password := password;
		msg := 'AuthType = ' &amp; auth.String;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;

	oSmtp.from     := self.fromAddress;
    oSmtp.fromAddr  := self.fromAddress;
	
	tmpStr := self.toAddress.doInvalidCharacterSweep();
	
	if tmpStr = null then
		app.raiseCMException1(ERR_Email_Blank, app.getErrorString(Recipients), null, null);
		return;
	endif;
	
	if not systemTestMode then //par17833 cnwrs1 sep 2008
		oSmtp.addRecipientEx(tmpStr, NORMAL_RECIPIENT);
	else
		messageRecipientsTest := "To:" &amp; tmpStr;
	endif;
	
	tmpStr := self.ccAddresses.doInvalidCharacterSweep();
	
	if tmpStr &lt;&gt; null then
		if not systemTestMode then //par17833 cnwrs1 sep 2008
			oSmtp.addRecipientEx(tmpStr, CARBON_COPY);
		else
			messageRecipientsTest := messageRecipientsTest &amp; " CC:" &amp; tmpStr;
		endif;
	endif;
	
	tmpStr := self.bccAddresses.doInvalidCharacterSweep();
	
	if tmpStr &lt;&gt; null then
		if not systemTestMode then //par17833 cnwrs1 sep 2008
			oSmtp.addRecipientEx(tmpStr, BLIND_CARBON_COPY);
		else
			messageRecipientsTest := messageRecipientsTest &amp; " BCC:" &amp; tmpStr;
		endif;
	endif;
	
	oSmtp.subject := self.sendSubject;
	
	if not systemTestMode then //par17833 cnwrs1 sep 2008
		oSmtp.bodyText := self.sendMessage;
	else
		tmpStr := app.myRoot.getConfig(AutoSupportEmailAddress).String;
		oSmtp.addRecipientEx(tmpStr, NORMAL_RECIPIENT);
		oSmtp.bodyText := "Test message, original was to " &amp; messageRecipientsTest &amp; CrLf &amp; self.sendMessage;
	endif;

	if not self.allAttachedFiles.isEmpty() then
		create huge transient;
	endif;
	
	tmpDir := app.getTempDirectoryFromSysConfig();//PAR22336 - cnwsh3 - try and provide a location away from the temp dir to process.
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name&amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);
	
	foreach obj in self.allAttachedFiles do
		file := app.writeBinaryToFile(obj.CM_FileDataStorageHeader, tmpDir);
		
		if file &lt;&gt; null then
			msg := 'FileName - ' &amp; file;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			oSmtp.addAttachment(file);
			huge.add(file);
		endif;
	endforeach;
	
	if oSmtp.sendMail() &lt;&gt; 0 then
		err := oSmtp.getLastErrDescription();
		app.writeLog('SMTP Error = ' &amp; err, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.raiseCMException1(Email_Send_Failure, err, null, null);
	endif;
epilog
	if isSSL then
		oSmtp.sSL_uninit();
	endif;
	
	delete oSmtp;
	
	if huge &lt;&gt; null then
		foreach file in huge do
			self.deleteFile(file);
		endforeach;
		
		delete huge;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendCardSchema" id="0d675c99-7c3d-4ecd-b539-e2e899bcd57c">
        <source>sendCardSchema() protected;
// cnwdvb1 10 February 2003 
//12 Aug 2013	cnwrs1	Par 32224 setup timeout value for this connection
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 17/03/2015	cnwmh5	Transient Leaks
//25 May 2015	cnwrs1	Par36314 the sm object cant be deleted by jmt as it is used by cardschema to send the email and cardschem deletes the object
constants

	Double_Semi = ";;";
	Single_Semi	= ";";
vars
	attachment	: CnAttachment;
	sm			: CM_SmtpConnection;
	file		: String;
	obj			: Object;
	tmpStr		: String;
	tmpDir		: String;
	msg : String;
	timeOut : Integer;
begin
	msg := 'Using CardSchema to send mail';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if not app.myRoot.getConfig(BgpEmailTestMode).Boolean then	// When BGP Test Mode, a similar record is registered in log file already.	PAR25611 11/11/2010
		msg := 'Sending email to ' &amp; self.toAddress;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;
	
	create sm;	
	//epr par 34068 6/11/14 changed encoding type to Base64 so could send message with extended ascii characters like ŕ in italian
	sm.encodingType := CnSmtpConnection.Base64; 
	sm.beginNotification(sm, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);

	app.writeLog(sm.contentType,LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	//Set up the mail server name
	sm.name			:= app.myRoot.getConfig(AutoSmtpServer).String;

	timeOut := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	if timeOut &lt; 2 or timeOut &gt; 60 then
		timeOut := 30;
	endif;
	sm.timeout := timeOut * 1000;

	//Set up the message parameters
	sm.sendFrom		:=	self.fromAddress;		// Who the message is from ...							
	
	tmpStr := self.toAddress.doInvalidCharacterSweep();
	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
	//sm.sendTo		:=	self.toAddress.replaceString(Double_Semi, Single_Semi);  		// Who the message is to ...
	sm.sendTo		:= tmpStr;
	
	tmpStr := self.ccAddresses.doInvalidCharacterSweep();
	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
    //sm.cc			:=	self.ccAddresses.replaceString(Double_Semi, Single_Semi);		// CC Addresses;
    sm.cc			:= tmpStr;
    
    tmpStr := self.bccAddresses.doInvalidCharacterSweep();
	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
   // sm.bcc			:=	self.bccAddresses.replaceString(Double_Semi, Single_Semi);		// Blind cc addresses
	sm.bcc			:= tmpStr;
   
	sm.subject		:=	self.sendSubject;		// The message subject ...                    		
    sm.message		:=	self.sendMessage;		// The message text itself ...
	
	tmpDir := app.getTempDirectoryFromSysConfig(); //PAR22336 - cnwsh3 - try and provide a location away from the temp dir to process.
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);//PAR22336 - cnwsh3 30/07/2010
    //Create the attachments
    foreach obj in self.allAttachedFiles do
		file := app.writeBinaryToFile(obj.CM_FileDataStorageHeader, tmpDir);
		if file &lt;&gt; null then
		    create attachment;								
		    attachment.fileName			:=	file;
			attachment.mySmtpConnection	:=	sm;
			attachment.encodingType		:= CnSmtpConnection.Base64; // adm 100709 Par 20094
//			attachment.contentType := self.getContentType(file);
		endif;
	endforeach;

    //Send the message and its attachments
    sm.send; 	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendEATls" id="a6a3602e-8ece-4f4f-a691-8a67249215d7">
        <updating/>
        <source>sendEATls(_emailArchitect : CMIF_EmailArchitect input) protected, updating;
/*

Purpose:			Send Email via Email Architect (EA) using SMTP

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
23 February 2022	navpw1	Initial creation TFS: 51526
19 July 2022		navpw1	Bug: 54066 GPHA - BGP Stuck when sending email via OAUTH doesn't return
18 OCT 2022			NAVSP1  ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
16 January 2024		navmd1	TFS 55021 Tidyup and Rewrite
26 May 2024			navmd1	TFS 64279 Fix CC and BCC addresses not being populated
*/

vars
	user, server, password,
	toString, ccString, bccString,
	errorTxt, tmpDir, fileName,
	smtpConversation, fromAddr, charset 	: String;
	authType, sslUsage, portNumber, timeout,
	idx, startMsg, endMsg 					: Integer;
	useSSL, useTls							: Boolean;
	obj 									: Object;
	huge 									: HugeStringArray;
	smtpMail,smtpServer						: JadeDotNetType;
begin
	// do some basic validation first
	toString := self.toAddress.doInvalidCharacterSweep();
	if toString = null then
		app.raiseCMException1(ERR_Email_Blank, app.getErrorString(Recipients), null, null);
		return;
	endif;

	/*
	* Validation
	*/
	server 		:= app.myRoot.getConfig(AutoSmtpServer).String;
	user 		:= app.myRoot.getConfig(AutoOutwardAccount).String;
	password 	:= app.myRoot.getPwForUse(AutoOutwardPassword);
	portNumber	:= app.myRoot.getConfig(AutoSmtpServerPort).Integer;
	sslUsage 	:= app.myRoot.getConfig(AutoUseSSL).Integer;
	authType	:= app.myRoot.getConfig(AutoAuthType).Integer;
	timeout 	:= app.myRoot.getConfig(AutoEmailTimeout).Integer;
	charset 	:= app.myRoot.getConfig(AutoCharset).String;
	
	//Convert BGP_EmailSendRequest Constant to EASendSmtpServer ConnectType Constant as they have different numbers
	sslUsage 	:= _emailArchitect.convertSndSSLFromOCXtoDotNet(sslUsage);
	
	if sslUsage = EAGetMailSupport.SmtpConnectType_ConnectDirectSSL then
		useSSL 		:= true;
		
	elseif sslUsage = EAGetMailSupport.SmtpConnectType_ConnectSTARTTLS then
		useTls 		:= true;
		
	elseif sslUsage = -1 then
		app.writeLog("Invalid SSL/TLS Option selected for 'SMTP SSL Usage'", LogWARN);
		app.createAlert("Invalid SSL/TLS Option selected for 'SMTP SSL Usage'", true);
		return; //We have invalid settings so do not continue
		
	endif;
	
	//Convert BGP_EmailSendRequest Constant to EASendSmtpServer ConnectType Constant as they have different numbers
	authType := _emailArchitect.convertAuthFromOCXtoDotNet(authType);
	if authType = -1 then
		app.writeLog("Invalid Auth Type Option selected for 'SMTP Authentication Type'", LogWARN);
		app.createAlert("Invalid Auth Type Option selected for 'SMTP Authentication Type'", true);
		return; //We have invalid settings so do not continue
		
	endif;
	
	if portNumber = 0 then
		if useSSL then
			portNumber := 465;
			
		elseif useTls then
			portNumber := 587;
			
		else
			portNumber := 25;
			app.writeLog("It is recommended you use SSL/TLS to connect to the web server to retrieve email", LogWARN);
			app.createAlert("It is recommended you use SSL/TLS to connect to the web server to retrieve email", true);
			
		endif;
	else
		if portNumber &lt;&gt; 465 and portNumber &lt;&gt; 587 then
			app.writeLog("It is recommended you use SSL/TLS to connect to the web server to retrieve email", LogWARN);
			app.createAlert("It is recommended you use SSL/TLS to connect to the web server to retrieve email", true);
		
		// This check is too strict - which 587 is the default port for STARTTLS, STARTTLS also allows SSL fallback
		//elseif (portNumber = 465 and not useSSL) or (portNumber = 587 and not useTls)  then
		// So just complain if *neither* SSL nor STARTTLS is enabled
		elseif (portNumber = 465 or portNumber = 587) and (not useSSL and not useTls) then
			app.raiseCMException1(SSL_Required_On_Port, portNumber.String, null, null);
			return; //In case someone adds an exception handler
		endif;
	endif;
	
	fromAddr := self.fromAddress;
	if fromAddr = null then
		fromAddr := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	endif;
	
	//Create SMTP Server
	//create the SMTP server object
	smtpServer := _emailArchitect.createSmtpServer(server, user, password, portNumber, authType, sslUsage);
	if smtpServer = null then
		self.logAndRaiseException("Error creating smtp server - &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; PORT &gt;&gt;" &amp; portNumber.String &amp; "&lt;&lt; Auth Type &gt;&gt;" &amp; authType.String &amp; "&lt;&lt; SSL Type &gt;&gt;" &amp; sslUsage.String &amp; "&lt;&lt;");
		return; //In case someone adds an exception handler
	endif;
	
	/* This application utilizes a licensed copy of ADS Objects. ADS
	Objects is copyrighted and owned exclusively by ADMINSYSTEM SOFTWARE
	LIMITED. All rights reserved. Use of the objects outside of the
	context of this application is a violation of federal copyright laws
	and international treaty provisions */
	
	// Create the SMTP mail object - this is the email we're going to send
	smtpMail := _emailArchitect.createSmtpMail(charset);
	if smtpMail = null then
		self.logAndRaiseException("Error creating smtp mail - &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user);
		return; //In case someone adds an exception handler
	endif;
	
	ccString := self.ccAddresses.doInvalidCharacterSweep();
	bccString := self.bccAddresses.doInvalidCharacterSweep();
	
	if not _emailArchitect.assembleMessage(smtpMail, fromAddr, toString, ccString, bccString, self.sendSubject, self.sendMessage) then
		self.logAndRaiseException("Error assembling message | &lt;&lt; FROM &gt;&gt;" &amp; fromAddr &amp; "&lt;&lt; TO &gt;&gt;" &amp; toString &amp; "&lt;&lt; CC &gt;&gt;" &amp; ccString &amp; "&lt;&lt; BCC &gt;&gt;" &amp; bccString);
		return;
	endif;
	
	// Attachments
	tmpDir := app.getTempDirectoryFromSysConfig();
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name&amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);
	
	create huge transient;
	foreach obj in self.allAttachedFiles do
		fileName := app.writeBinaryToFile(obj.CM_FileDataStorageHeader, tmpDir);
		if fileName &lt;&gt; null then
			//write app.actualTimeServer.String &amp; Tab &amp; 'FileName - ' &amp; fileName;
			if not _emailArchitect.addAttachment(smtpMail, fileName) then
				// We've never checked this before, so just log a warning and continue
				app.writeLog("Error adding attachment | " &amp; fileName, LogWARN);
				app.createAlert("Error adding attachment to email | " &amp; fileName, true);
			endif;
			huge.add(fileName);
		endif;
	endforeach;
	
	app.writeLog("Ready to send - creating SMTP Client and sending the email", LogINFO);
	
	if _emailArchitect.sendMail(smtpServer, smtpMail, timeout, smtpConversation) then
		app.writeLog(smtpConversation, LogTRACE);	// Just for good measure, log the successful smtp conversations on TRACE too
	else
		idx := 1;
		app.writeLog(smtpConversation, LogTRACE);
		
		idx := smtpConversation.pos('ResponseClass="Error"', idx);
		if idx &gt; 1 then
			// we got an error back 
			startMsg := smtpConversation.pos("&lt;m:MessageText&gt;", idx) + 15;
			endMsg := smtpConversation.pos("&lt;/m:MessageText&gt;", idx);
			errorTxt := smtpConversation[startMsg:endMsg-startMsg];
			
			app.writeLog("Email Send failed  - error message was " &amp; errorTxt, LogERROR);
			app.createAlert("Email Send failed  - error message was " &amp; errorTxt &amp; CrLf &amp; smtpConversation, true);
			app.raiseCMException1(EmailReceiveFailure, errorTxt, null, null);
			process.isMPD;	// TODO: Write out the smtpconvo to the alert for more info
		endif;
		
		self.logAndRaiseException("Error sending smtp mail - &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; PORT &gt;&gt;" &amp; portNumber.String &amp; "&lt;&lt; Auth Type &gt;&gt;" &amp; authType.String &amp; "&lt;&lt; SSL Type &gt;&gt;" &amp; sslUsage.String &amp; "&lt;&lt;");
		return;	
	endif;
	
	app.writeLog("Email sent successfully", LogINFO);
epilog
	if huge &lt;&gt; null then
		foreach fileName in huge do
			self.deleteFile(fileName);
		endforeach;
		delete huge;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_emailArchitect" type="CMIF_EmailArchitect" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sendIDS" id="99b517f1-6828-4bbf-8fff-6c1ed3dacaec">
        <source>sendIDS()  : String protected;
// -------------------------------------------
// Created 02 March 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//06 May 2019	jlgzm1	TFS 43670 '14213' errors propogating 
constants

	KEY			=	"ZXS74GYCGDNQ";
	IDSM_SYS_SMTP_POP	= 10;
	Double_Semi = ";;";
	Single_Semi	= ";";
	Comma		= ",";
	MINUTES = 60;
	IDSM_ENC_ENC_ALLSYSTEMS = 128;
	IDSM_ENC_UUENCODE = 1;
vars

	mailIDS		: IDS_Server;
	key,
	smtp,
	fromAdd,
	toAdd,
	ccAdd,
	bccAdd,
	toAdd2,
	attach,
	message,
	subj,
	file,
	tmpStr		: String;
	mailSystem,
	utcBias,
	timeOut		: Integer;	
	obj			: Object;	
	huge		: HugeStringArray;	
	locale		: Locale;
	tmpInteger,
	encoding	: Integer;
	requireLogout : Boolean;
	tmpDir		: String;
	msg 		: String;
	noSoftware  : Boolean; // tfs43670
begin

	on Exception do self.xHandler(exception, mailIDS, noSoftware);
	msg := 'Using OCS Control to send mail';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	locale := app.currentLocale;
	utcBias := -((app.currentUTCBias(CurrentLocation)) / MINUTES).Integer;
	msg := 'Locale = ' &amp; locale.makeLocaleName() &amp; ' UTC Bias = ' &amp; utcBias.String;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create huge transient;	
	create mailIDS transient;
	
	// THIS IS A VERY IMPORTANT LINE FOR ANY NT SYSTEM.
	// THE SERVER NAME NEEDS TO BE SET BEFORE CONTROL CAN
	// BE ACCESSED.
	mailIDS.remoteServerName := app.computerName;
	// This apparently works with SMTP
	// This hasn't been any help with diagnostics and crasheds Owens.
//	mailIDS.internetLogging := -1;

	key 				:= KEY;
//	mailSystem			:= app.myRoot.getConfig(AutoMailSystem).Integer;
//	if mailSystem = 0 then
		mailSystem := IDSM_SYS_SMTP_POP;
//	endif;
	smtp	:= app.myRoot.getConfig(AutoSmtpServer).String.trimBlanks();
	fromAdd := self.fromAddress;
	message := self.sendMessage;
	subj	:= self.sendSubject;
	
	encoding := IDSM_ENC_UUENCODE;
	mailIDS.newMessage();
	// if error then abort
	if noSoftware then // tfs43670
		return null;
	endif;
	mailIDS.objectKey(key);
	mailIDS.putmailSystem(mailSystem);
	mailIDS.putSMTPServer(smtp);
	
	timeOut := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	if timeOut &lt; 2 or timeOut &gt; 60 then
		timeOut := 30;
	endif;
	timeOut := timeOut * 1000;
	mailIDS.putTimeoutConnect(timeOut);
	mailIDS.putTimeoutProtocol(timeOut);
	mailIDS.internetLogging := -1;
	
	tmpInteger := 0;
	mailIDS.putLoginDialog(tmpInteger);
//	mailIDS.putattachmentEncoding(encoding);
	
	msg := 'From ' &amp; fromAdd;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	mailIDS.putfrom(fromAdd);		// Who the message is from ...				
	// Par 8019 Added utcBias to try and correct Otago's problem.
	mailIDS.putUTCOffset(utcBias);

	tmpStr := self.toAddress.replaceString(Single_Semi, Comma);
	tmpStr := tmpStr.doInvalidCharacterSweep();
	tmpStr.parseCSV(huge);  	
	foreach toAdd in huge do
		if toAdd &lt;&gt; null then
			mailIDS.addRecipientTo(toAdd);
			msg := 'To ' &amp; toAdd;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
	endforeach;
		
	tmpStr := self.ccAddresses.replaceString(Single_Semi, Comma);
	tmpStr := tmpStr.doInvalidCharacterSweep();
	tmpStr.parseCSV(huge);  	
	foreach ccAdd in huge do		
		if ccAdd &lt;&gt; null then
			mailIDS.addRecipientCc(ccAdd);
			msg := 'CC ' &amp; ccAdd;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
	endforeach;
	
	tmpStr := self.bccAddresses.replaceString(Single_Semi,Comma);
	tmpStr := tmpStr.doInvalidCharacterSweep();
	tmpStr.parseCSV(huge);  
	foreach bccAdd in huge do	
		if bccAdd &lt;&gt; null then
			mailIDS.addRecipientBcc(bccAdd);
			msg := 'BCC ' &amp; bccAdd;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
	endforeach;

	mailIDS.putsubject(subj);
	mailIDS.putMessage(message);
	//Create the attachments
	huge.clear();
	
	tmpDir := app.getTempDirectoryFromSysConfig();//PAR22336 - cnwsh3 - try and provide a location away from the temp dir to process.
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);
    foreach obj in self.allAttachedFiles do
		file := app.writeBinaryToFile(obj.CM_FileDataStorageHeader, tmpDir);
		if file &lt;&gt; null then
			msg := 'FileName - ' &amp; file;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			huge.add(file);
			mailIDS.addAttachment(file);
		endif;
	endforeach;

	requireLogout := true;
	mailIDS.send();

	return  mailIDS.serverPath.String;
	msg := 'Successfully ran mail IDS send command';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
epilog

	if requireLogout then
		mailIDS.logout();
	endif;
	
	if huge &lt;&gt; null then
		foreach file in huge do
			self.deleteFile(file);
		endforeach;
	endif;

	delete mailIDS;
	delete huge;
	process.sleep(500);

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendInitialisedEmail" id="647c1603-7d21-4390-8bcb-e6d265d84469">
        <updating/>
        <source>sendInitialisedEmail(_checkCanBeProcessed : Boolean; _updateCallbackObject : Object) : Integer updating;
//-----------------------------------------
// Created: 19 May 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars

begin
	self.initRequestEvent(_checkCanBeProcessed, false, _updateCallbackObject);
	
	return self.getInstanceIdForObject64(self).Integer;

end;</source>
        <Parameter name="_checkCanBeProcessed" type="Boolean"/>
        <Parameter name="_updateCallbackObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendOAuth" id="3a1dea96-2c41-4a9f-9427-d9e2015706a7">
        <source>sendOAuth(_emailArchitect : CMIF_EmailArchitect input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/07/2020	jlgdap1		Initial creation TFS 49764 MTN Retire Basic Authentication to Exchange Online
// 21/05/2021	navdap1		TFS 51244 PNL OAUTH set up
// 05/08/2021	navdap1		TFS 51509 PNL OAUTH Outbound emails not using Sender's Email Address configuration
// 26/11/2021	navmd1		TFS 52461 Change logging levels to make more sense!
// 19/07/2022	navpw1		Bug: 52562 MTN - .Net Exceptions in OAUTH code
// 19/07/2022	navpw1		Bug: 54066 GPHA - BGP Stuck when sending email via OAUTH doesn't return
// 03/10/2022	navmd1		TFS 55020 Moved OAuth Token logic to CMIF_EmailArchitect
// 18/10/2022	NAVSP1      ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
// 16/01/2024	navmd1		TFS 55021 Tidyup and Rewrite
// 30/08/2024	navmd1		TFS 65917 Bail earlier if no oauth token was returned
vars
	toString, ccString, bccString 	: String;
	idx, startMsg, endMsg, timeout	: Integer;
	charset, user, server			: String;
	smtpMail, smtpServer 			: JadeDotNetType;
	errorTxt, tmpDir, fileName 		: String;
	file							: CM_FileDataStorageHeader;
	huge							: HugeStringArray;
	smtpConversation 				: String;
	fromAddr						: String;
	token							: String;
	isOk							: Boolean;
begin
	// do some basic validation first
	fromAddr := self.fromAddress;
	if fromAddr = null then
		fromAddr := app.myRoot.getConfig(AutoSendersEmailAddress).String;
		if fromAddr = null then
			app.raiseCMException1(ERR_Email_Blank, app.getErrorString(From), null, null);
			return;
		endif;
	endif;
		
	toString := self.toAddress.doInvalidCharacterSweep();
	if toString = null then
		app.raiseCMException1(ERR_Email_Blank, app.getErrorString(Recipients), null, null);
		return;
	endif;
	
	ccString := self.ccAddresses.doInvalidCharacterSweep();
	bccString := self.bccAddresses.doInvalidCharacterSweep();
	
	
	user := app.myRoot.getConfig(AutoOutwardAccount).String;
	server := app.myRoot.getConfig(AutoSmtpServer).String;
	charset := app.myRoot.getConfig(AutoCharset).String;
	timeout := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	
	// create the SMTP server object
	token := _emailArchitect.getOAuthToken(self.myTerminal);
	if token = null then
		self.logAndRaiseException("Error retrieving token | &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; Auth Type &gt;&gt;" &amp; EAGetMailSupport.ServerAuthType_AuthXOAUTH2.String &amp; "&lt;&lt; Protocol &gt;&gt;" &amp; EAGetMailSupport.ServerProtocol_ExchangeEWS.String &amp; "&lt;&lt;");
		return;
	endif;
	
	smtpServer := _emailArchitect.createSmtpServer(server, user, token, null, EAGetMailSupport.SmtpAuthType_XOAUTH2, EAGetMailSupport.SmtpConnectType_ConnectSSLAuto);
	if smtpServer = null then
		self.logAndRaiseException("Error creating smtp server | &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; FROM &gt;&gt;" &amp; fromAddr);
		return; //In case someone adds an exception handler
	endif;
		
	smtpMail := _emailArchitect.createSmtpMail(charset);
	if smtpMail = null then
		self.logAndRaiseException("Error creating smtp mail | &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; CHARSET &gt;&gt;" &amp; charset);
		return; //In case someone adds an exception handler
	endif;
	
	if not _emailArchitect.assembleMessage(smtpMail, fromAddr, toString, ccString, bccString, self.sendSubject, self.sendMessage) then
		self.logAndRaiseException("Error assembling message | &lt;&lt; FROM &gt;&gt;" &amp; fromAddr &amp; "&lt;&lt; TO &gt;&gt;" &amp; toString &amp; "&lt;&lt; CC &gt;&gt;" &amp; ccString &amp; "&lt;&lt; BCC &gt;&gt;" &amp; bccString);
		return;
	endif;
	
	// Attachments
	tmpDir := app.getTempDirectoryFromSysConfig();
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name&amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);
	
	create huge transient;
	foreach file in self.allAttachedFiles do
		fileName := app.writeBinaryToFile(file, tmpDir);
		if fileName &lt;&gt; null then
			_emailArchitect.addAttachment(smtpMail, fileName);
			huge.add(fileName);
		endif;
	endforeach;
	
	app.writeLog("Ready to send - creating SMTP Client and sending the email", LogINFO);
	
	isOk := _emailArchitect.sendMail(smtpServer, smtpMail, timeout, smtpConversation);
		
	if not isOk then
	
		idx := 1;
		app.writeLog(smtpConversation, LogTRACE);
		
		idx := smtpConversation.pos('ResponseClass="Error"', idx);
		if idx &gt; 1 then
			// we got an error back 
			startMsg := smtpConversation.pos("&lt;m:MessageText&gt;", idx) + 15;
			endMsg := smtpConversation.pos("&lt;/m:MessageText&gt;", idx);
			errorTxt := smtpConversation[startMsg:endMsg-startMsg];
//			app.writeLog("Email Send failed  - error message was " &amp; errorTxt, LogERROR);
//			app.createAlert("Email Send failed  - error message was " &amp; errorTxt, true);
//			app.raiseCMException1(EmailReceiveFailure, errorTxt, null, null);
			process.isMPD;	// TODO: Write out the smtpconvo to the alert for more info
		endif;
			
		self.logAndRaiseException("Error sending smtp mail | &lt;&lt; SERVER &gt;&gt;" &amp; server &amp; "&lt;&lt; USER &gt;&gt;" &amp; user &amp; "&lt;&lt; FROM &gt;&gt;" &amp; fromAddr);
		return;
	endif;
	
	app.writeLog("Email sent successfully", LogINFO);
epilog	
	if huge &lt;&gt; null then
		foreach fileName in huge do
			self.deleteFile(fileName);
		endforeach;
		delete huge;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_emailArchitect" type="CMIF_EmailArchitect" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEmailRequest" id="55148db1-179a-43ee-869a-4019822f3456">
        <updating/>
        <source>setEmailRequest(_keyAddress,
				_alertDesc,
				_toAddress,
				_fromAddress,
				_ccAddresses,
				_bccAddresses,
				_subject,
				_message 				: String;
				_user					: CM_User;
				_terminal				: CM_Terminal;
				_allAttachedFilePaths	: HugeStringArray;
				_allFileData			: CM_FileDataStorageHdrSet input;
				_blob					: Binary;
				_blobFileName			: String;
				_sourceOfEmail			: Integer) updating;
//-----------------------------------------
// Created: 19 May 2005 By: cnwgd1
//-----------------------------------------
// 17 Jun 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
//
vars
	filePath	: String;
	header		: CM_FileDataStorageHeader;
begin

	self.keyAddress				:= _keyAddress[1:50];
	self.myUser					:= _user;
	self.myTerminal				:= _terminal;
	self.alertDescription		:=	_alertDesc;
	self.fromAddress			:= _fromAddress[1:50];
	self.toAddress				:= _toAddress;
	self.setSendSubject( _subject );	//10 Feb 2021	NDL	TFS 50736
	self.sendMessage			:= _message;
	self.ccAddresses			:= _ccAddresses;
	self.bccAddresses			:= _bccAddresses;

	if _allFileData &lt;&gt; null then
		_allFileData.swapFileData(self.allAttachedFiles);
	endif;
	

	// Can attach a binary file. This is used by reports.
	if _blob &lt;&gt; null then
		header := app.convertBlobForRequest(_blob, _blobFileName, false, 0);
		if header &lt;&gt; null then
			self.allAttachedFiles.add(header);
		endif;
	endif;
	
	// Simply provided the path to the files we want to attach. 
	if _allAttachedFilePaths &lt;&gt; null then
		foreach filePath in _allAttachedFilePaths do		
			header := app.writeFileToBinary(filePath, false, false, null,true);
			if header &lt;&gt; null then
				self.allAttachedFiles.add(header);
			endif;
		endforeach;
	endif;
	
	self.sourceOfEmail := _sourceOfEmail;

	if app.myRoot.getConfig(BgpEmailTestMode).Boolean then	//PAR 25611	10/11/2010
		self.setEmailRequestForBGPTestMode();
	endif;
	
end;</source>
        <Parameter name="_keyAddress" type="String"/>
        <Parameter name="_alertDesc" type="String"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_fromAddress" type="String"/>
        <Parameter name="_ccAddresses" type="String"/>
        <Parameter name="_bccAddresses" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allAttachedFilePaths" type="HugeStringArray"/>
        <Parameter name="_allFileData" type="CM_FileDataStorageHdrSet" usage="input"/>
        <Parameter name="_blob" type="Binary"/>
        <Parameter name="_blobFileName" type="String"/>
        <Parameter name="_sourceOfEmail" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setEmailRequestForBGPTestMode" id="e9a2b5f5-ec4d-4dba-a2bc-fb7515f3b5a4">
        <updating/>
        <source>setEmailRequestForBGPTestMode() updating, protected;
/* ---------------------------------------------------------------------------
Created:	11 November 2010	by cnwvu1

Purpose:	CCMS SFW 1063, PAR 25611. When sending emails, they will be sent to
			test email address instead of live customers.

   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	body	: String;

begin

	// to check, when BGP turned of.
	if self.alertDescription = app.getErrorString(BGP_Processing) then
		return;	// this is system email when BGP is turned of. Leaving email intact and it will be send to an administator.
	endif;
	
	body := 
"Original recipients: " &amp; self.toAddress &amp; CrLf &amp;
"CC: "  &amp; self.ccAddresses &amp; CrLf &amp;
"BCC: " &amp; self.bccAddresses &amp; CrLf &amp; CrLf;
	
	self.toAddress				:= app.myRoot.getConfig(BgpEmailTestAddress).String;
	self.ccAddresses			:= null;
	self.bccAddresses			:= null;

	self.setSendSubject( "BGP Email Test Mode: " &amp; self.sendSubject );	//11 Feb 2021	NDL	TFS 50736
	self.sendMessage			:= body &amp; self.sendMessage;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setExtraActivityHistory" id="f20ba13f-1503-4fdd-9393-3eaf55c8d5ab">
        <source>setExtraActivityHistory(_activityHistory: CM_ActivityHistory input);
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
// This method is used to provide extra detail to the email
// activity history.
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars

	strArray				: StringArray;
	header					: CM_FileDataStorageHeader;
	instanceId				: Integer;
	activityHistoryEmail	: CM_ActivityHistoryEmail;
	activityHistoryGeneral	: CM_ActivityHistoryGeneral;

begin

	if _activityHistory.isKindOf(CM_ActivityHistoryEmail) then
		activityHistoryEmail := _activityHistory.CM_ActivityHistoryEmail;
		create strArray transient;
		foreach header in self.allAttachedFiles do
			strArray.add(header.fileName);
		endforeach;	
		instanceId := self.getInstanceIdForObject64(self).Integer;
		activityHistoryEmail.setEmailAttributes(self.myUser,
												self.toAddress,
										 		self.fromAddress,
										 		self.ccAddresses,
										 		self.bccAddresses,
										 		self.sendSubject,
										 		self.sendMessage,
										 		self.getSourceDescription(self.sourceOfEmail, instanceId),
										 		self.sourceOfEmail,
										 		self.numberOfRetries,
										 		strArray);

	elseif _activityHistory.isKindOf(CM_ActivityHistoryGeneral) then
		activityHistoryGeneral := _activityHistory.CM_ActivityHistoryGeneral;
		activityHistoryGeneral.setExtraDetail('Request Deleted' &amp; Tab &amp; self.getDisplay().removeTabCrLfs);
	endif;

	
epilog
	delete strArray;
end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistory" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsProcessed" id="cc49f51c-2501-42fc-be35-8d3d3a6907f7">
        <updating/>
        <source>setIsProcessed(_isProcessed: Boolean; _errCode: Integer; _errTxt: String) updating;
// -------------------------------------------
// Created 04 March 2004 by cnwdvb1
// -------------------------------------------
// This reimplemented method keeps track of how many times
// this request has attemped to send an email.
vars

begin
	inheritMethod(_isProcessed, _errCode, _errTxt);
	if _errCode &lt;&gt; null then
		self.numberOfRetries := self.numberOfRetries + 1;
	endif;


end;</source>
        <Parameter name="_isProcessed" type="Boolean"/>
        <Parameter name="_errCode" type="Integer"/>
        <Parameter name="_errTxt" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSendSubject" id="10ed3569-707a-47cb-a9d5-b5870ce9e272">
        <updating/>
        <source>setSendSubject( _subjectLine : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2021	jlgndl1	Initial creation	TFS 50736

*/

vars

	charSetToReplace : String;
	pos : Integer;
	str : String;
	subjectLine : String;

begin

	charSetToReplace := app.myRoot.getConfig(EmailHeadingInvalChars).String.trimBlanks();
	subjectLine := _subjectLine;
	
	if charSetToReplace &lt;&gt; null then
		foreach pos in 1 to charSetToReplace.length do
			str := charSetToReplace[pos];
			if str = " " then
				continue;
			endif;
			subjectLine := subjectLine.replace(str, " ");
		endforeach;
	endif;
	
	self.sendSubject := subjectLine.trimBlanks;

epilog

end;</source>
        <Parameter name="_subjectLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="015f2076-1f79-4b7d-8d94-065b5fcd344f">
        <source>validateMe();
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	userString,
	terminalCode: String;
begin

	if self.myUser &lt;&gt; null then
		userString := app.getErrorString(User) &amp; ' = ' &amp; self.getUserCode;
	else
		userString := app.getErrorString(User) &amp; ' ' &amp; app.getErrorString(Unknown);
	endif;
	
	if self.myTerminal &lt;&gt; null then
		terminalCode := app.getErrorString(Terminal) &amp; ' ' &amp; self.myTerminal.code;
	else
		terminalCode := app.getErrorString(Terminal) &amp; ' ' &amp; app.getErrorString(Unknown);
	endif;

	if self.toAddress = null then
		//app.raiseCMException1(Full_Replacement_Message, app.getErrorString(Invalid) &amp; ' ' &amp; app.getErrorString(Email_Address_Destination) &amp; ' (' &amp; self.alertDescription &amp; ') ' &amp; userString &amp; ' ' &amp; terminalCode, null, null); //- cnwmd1, Par 20524
		app.raiseCMException3(Inval_email_add_destin_ext, self.alertDescription, userString, terminalCode, null, null); //+ cnwmd1, Par 20524
		app.writeLog(class.name&amp;'::'&amp;method.name&amp; "Email Issue:  The TO email address '" &amp; self.fromAddress &amp; "' is null", LogERROR);  // ### JIRA 35465 04AUG2025 NAVAB1
		return;
	endif;
	
	if self.fromAddress = null then
		//app.raiseCMException1(Full_Replacement_Message, app.getErrorString(Invalid) &amp; ' ' &amp; app.getErrorString(Email_Address_Sender) &amp; ' (' &amp; self.alertDescription &amp; ') ' &amp; userString &amp; ' ' &amp; terminalCode, null, null); //- cnwmd1, Par 20524
		app.writeLog(class.name&amp;'::'&amp;method.name&amp; "Email Issue:  The FROM email address '" &amp; self.fromAddress &amp; "' is null", LogERROR);  // ### JIRA 35465 04AUG2025 NAVAB1
		app.raiseCMException3(Inval_email_add_sender_ext, self.alertDescription, userString, terminalCode, null, null); //+ cnwmd1, Par 20524
		return;
	endif;
	
	if app.isDevelopmentSystem then
		if self.toAddress.toLower.pos("jade" ,1) = 0 and self.toAddress.toLower.pos("navis" ,1) = 0  and self.toAddress.toLower.pos("kaleris" ,1) = 0 then
			//app.raiseCMException1(Full_Replacement_Message, app.getErrorString(Email_Development)  &amp; ' (' &amp; self.alertDescription &amp; ')', null, null); //- cnwmd1, Par 20524
			//dev only exception - no translation required.
			app.writeLog(class.name&amp;'::'&amp;method.name&amp; "DEVELOPMENT SYSTEM:  The email address '" &amp; self.toAddress &amp; "' does not appear to be a Jade email address. (" &amp; self.alertDescription &amp; ")", LogERROR);  // ### JIRA 35465 04AUG2025 NAVAB1
			app.raiseUnexpectedProgramError(self.class.name, method.name, "DEVELOPMENT SYSTEM:  The email address '" &amp; self.toAddress &amp; "' does not appear to be a Jade email address. (" &amp; self.alertDescription &amp; ")"); //+ cnwmd1, Par 20524
			return;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xHandler" id="fb5a0131-6dfa-4ca0-a514-cef6202d9f5c">
        <source>xHandler(exObj : Exception input; _receiveMailIDS : IDS_Server input; _noSoftware : Boolean output) : Integer;
/*

Purpose:			Email specific exception handler.

Parameters:			exObj : the exception object;
					_recveiveMailIDS : the IDS_Server
					_NoSoftware : error because no email software installed

Return Value:		

Date		Who		Reason
13 Feb 2003 cnwdvb1 Initial creation
03 Jan 2013	cnwrs1	32983 crash after user deleted.
06 May 2019	jlgzm1	TFS 43670 '14213' errors propogating 
*/
vars
	err, mailSystem,
	errDecode,
	errDecodeAPI		: Integer;
	errMessage,
	str,
	detail				: String;
	pos					: Integer;
	msg : String;
begin
	msg := 'Email exception handler kicking in';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
//	if exObj.errorCode = 14181 and _receiveMailIDS &lt;&gt; null then
	if exObj.errorCode = 14181 then	// 14 Mar 2011	NDL Par 27049
	
		// We have had some email specific errors.
		pos := (exObj.extendedErrorText.pos('=', 1) + 1);
		
		if pos &lt;&gt; 0 then
			// Try and work out what type of IDS email error we have had.
			str := exObj.extendedErrorText[pos + 1 : end];
			app.writeLog(str, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			if str.pos("-2147215477", 1) &lt;&gt; 0 then
				// The IDS email software has had a polling error.
				// Check what the system wants to do.
				if not self.handlePollError() then
					msg := 'Polling error but not notified';
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					return Ex_Resume_Next;
				endif;
			endif;
			
			if _receiveMailIDS &lt;&gt; null then	// 14 Mar 2011	NDL Par 27049	- moved code down.
				exObj.extendedErrorText := self.getErrorMessage(str, _receiveMailIDS);
			endif;
			
			self.raiseAlert( exObj.extendedErrorText.trimBlanks );	// 14 Mar 2011	NDL Par 27049
			return Ex_Pass_Back;
			
		elseif exObj.extendedErrorText.trimBlanks &lt;&gt; null then	// 14 Mar 2011	NDL Par 27049
		
			self.raiseAlert( exObj.extendedErrorText.trimBlanks );	// 14 Mar 2011	NDL Par 27049
			return Ex_Pass_Back;	// 14 Mar 2011	NDL Par 27049
			
		endif;
		
	elseif exObj.errorCode = 14213 then
		//msg := "Please Install IDS Mail V6";
		msg := app.getErrorString(Email_softw_not_installed);	// TFS 43670
		_noSoftware := true;									// TFS 43670
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		self.raiseAlert(msg);	// 14 Mar 2011	NDL Par 27049 - moved to seperate method
		return Ex_Resume_Next;
	endif;
	
	// Don't handle non email specific errors.
	return Ex_Pass_Back; 
end;</source>
        <Parameter name="exObj" type="Exception" usage="input"/>
        <Parameter name="_receiveMailIDS" type="IDS_Server" usage="input"/>
        <Parameter name="_noSoftware" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
