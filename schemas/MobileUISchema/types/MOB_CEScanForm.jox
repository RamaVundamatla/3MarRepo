    <JadeMethod name="getSelectedLocation" id="d4f19627-4681-488b-92a2-5667db323faf">
        <source>getSelectedLocation(): String;
//3 July 2008	cnwdw1	
// Get the location associated with the current row
vars
	loc: CM_LocationsController;
begin
	loc	:= self.getLocationForRow();
	if loc &lt;&gt; null then
		return loc.getFullId;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleF3Key" id="d88b52b7-892d-4302-975d-6481c47b38db">
        <updating/>
        <source>handleF3Key() updating;

vars
	tiObj	: CM_TrackedItem;
	blnNew	: Boolean;
begin
	tiObj	:=	self.getTrackedItemForRow(blnNew);
	
	if tiObj &lt;&gt; null then
		app.myMobileGUIAgent.loadRecordDamageForm(tiObj);
	elseif blnNew then
		app.msgBox('The selected item is new, and must be set down before you can record damage against it.', '', MsgBox_OK_Only);
	else
		app.msgBox('There is no item selected to record damage against.', '', MsgBox_OK_Only);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleF5Key" id="6b61fbb9-1eea-4c4d-9ddd-978ba94aeaa7">
        <updating/>
        <source>handleF5Key() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tiObj	: CM_TrackedItem;
	blnNew  : Boolean;
begin
	if not app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobCargoEnquiry) then
		app.msgBox(app.getErrorString1(NoPermission, 'view cargo items.'), '', MsgBox_OK_Only);
		return;
	endif;
	tiObj	:=	self.getTrackedItemForRow(blnNew);
	
	if tiObj &lt;&gt; null then
		app.myMobileGUIAgent.loadCargoEnquiryForm(tiObj);
	elseif blnNew then
		app.msgBox("The selected item is new and cannot be inspected until it has been set down", '', MsgBox_OK_Only);
	else
		app.myMobileGUIAgent.loadCargoEnquiryForm(null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleF6Key" id="0c0c702f-07df-4d0d-90ca-f9c922d683d6">
        <updating/>
        <source>handleF6Key() updating;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
	
	Changed On	By			Reason
	----------	--------	---------------------------------------------------------------------
	04/08/2010	cnwdap1		PAR #25290 Don't pass a null TI reference through to updateTILocation
*/
vars
	tiObj	: CM_TrackedItem;
	loc 	: CM_LocationsController;
	blnNew 	: Boolean;
begin
	if not app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobMaintainAllocations) then
		app.msgBox(app.getErrorString1(NoPermission, 'allocate storage.'), '', MsgBox_OK_Only);
		return;
	endif;
	tiObj	:=	self.getTrackedItemForRow(blnNew);
	loc 	:= 	self.getLocationForRow();
	
	if loc = null and tiObj &lt;&gt; null then
		loc := tiObj.getPrimaryLocation(REAL_MODE);
	endif;
	if app.myMobileGUIAgent.loadStorageAllocateForm(tiObj, loc) = MB_MODAL_UPDATE then
	// ti may be null (item has just been added as new) PAR 17517
		// PAR #25290 If we've just hit F6 without selecting a TI from the table on the form we've come from,
		// tiObj will be null - in this case, DON'T call updateTILocation, as the first thing this method does
		// is reference the (null) tiObj
		if tiObj &lt;&gt; null then
			self.updateTILocation(tiObj);
		endif;
		
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleF9Key" id="64ce872a-a31f-4f65-b2e5-542f4f1fe800">
        <source>handleF9Key();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	#cnwdz2	ccms1801 

*/

vars
	tiObj	: CM_TrackedItem;
	blnNew  : Boolean;
begin
	if not app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobCargoEnquiry) then
		app.msgBox(app.getErrorString1(NoPermission, 'view location summary.'), '', MsgBox_OK_Only);
		return;
	endif;
	tiObj	:=	self.getTrackedItemForRow(blnNew);
	
	if tiObj &lt;&gt; null then
		app.myMobileGUIAgent.loadLocationSummaryForm(tiObj);
	elseif blnNew then
		app.msgBox("The selected item is new and cannot be inspected until it has been set down", '', MsgBox_OK_Only);
	else
		app.myMobileGUIAgent.loadLocationSummaryForm(null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="itemAlreadyInTable" id="a6be8af0-7c3b-425d-b387-e2e877168919">
        <source>itemAlreadyInTable(id : String; tbl : CM_MobTable input): Boolean;

/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	row 		: Integer;
	
begin
	foreach row in 2 to tbl.rows do
		if tbl.accessCell(row, self.getIDColumn()).text.toUpper() = id.toUpper() then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0200a063-3418-4ec5-942c-6fa531bb7172">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018472, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
