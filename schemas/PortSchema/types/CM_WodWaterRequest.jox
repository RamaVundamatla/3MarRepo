    <JadeMethod name="actionForCancelled" id="fb008e80-53f2-480d-8f45-662479ce499c">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2018	jlgndl1	Initial creation	TFS 41170

*/

vars

	arrival : HMS_VoyageMovement;
	resourceUsed : HMS_ResourceUsed;
	resourceUsedToDelete : HMS_Object;

begin
	
	arrival := _voyage.myHMSVoyageData.allVoyageMovements.first;
	if arrival &lt;&gt; null then			// 2/9/19 MAP TFS45926
		foreach resourceUsed in arrival.allResourceUsed discreteLock do
			if resourceUsed.myResource &lt;&gt; self.myHMSResource then
				continue;
			endif;
			if resourceUsed.myResourceType &lt;&gt; self.myHMSResourceType then
				continue;
			endif;
			if resourceUsed.fromDateTime &lt;&gt; self.fromDateTime then
				continue;
			endif;
			if resourceUsed.toDateTime &lt;&gt; self.toDateTime then
				continue;
			endif;
			resourceUsedToDelete := resourceUsed;
			break;
		endforeach;
	
		if resourceUsedToDelete &lt;&gt; null then
			app.myUtilityDA.utlDeleteHMSObject(resourceUsedToDelete, app.myPassport);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="d9ef1e7e-b088-4703-bf28-0f7936f3b4ae">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work Order Transactions
//
vars
	harbour : HMS_Harbour;
	resourceUsed, pxyResourceUsed : HMS_ResourceUsed;
	arrival : HMS_VoyageMovement;

begin
	// create a hms resource usage
	harbour := self.getMyTerminal.myHarbour;	
	arrival := self.getMyVoyageObject.myHMSVoyageData.allVoyageMovements.first;
	if arrival &lt;&gt; null then			// 2/9/19 MAP TFS45926
		create pxyResourceUsed transient;
		pxyResourceUsed.setProxy(harbour, self.myHMSResourceType, self.myHMSResource, null, self.fromDateTime, self.toDateTime, self.unitsUsed, false,	//_poc : Boolean;
									self,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
									null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
									);
		create resourceUsed;
		arrival.allResourceUsed.add(resourceUsed);
		resourceUsed.setForCreate(pxyResourceUsed, app.myPassport);
		resourceUsed.setTransferType(self.transferType);
	
		if _passport.noErrors then
			self.setIsComplete;
			self.myResourceUsed := resourceUsed;
			// create the appropriate transaction for billing  purpose	// TFS 39165
			self.createWorkOrderTransaction(TRANS_TYPE_WO_WATERREQUEST);		// TFS 39165
		endif;
	endif;
epilog
	delete pxyResourceUsed;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
