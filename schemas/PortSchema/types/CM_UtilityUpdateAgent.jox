    <JadeMethod name="utlUpdateRoRoLaneFreedLength" id="22e752e3-490c-459e-b0be-d4101bdd6d58">
        <updating/>
        <source>utlUpdateRoRoLaneFreedLength(_rc : CM_RoRoController input; _freedLength : Decimal; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwjk3	CCMS 1018

*/

vars

begin
	_rc.setFreedLength(_freedLength);
	_rc.reCalcUsedLengths(false);			// cnwjk3 PAR 23443 26/03/2010
	
	// Send a note so that the lane re-draws
	app.myEventManager.createSingleObjInfoNoteEvt(_rc.myRoRoLaneArea, 
				_rc.myTerminal.getTerminalEvent(EVENT_TI_MOVE),
				_rc);

epilog

end;</source>
