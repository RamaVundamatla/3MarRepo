    <JadeMethod name="updateUsedProducts" id="ff302e5d-b833-467a-8193-38e17f073ef8">
        <source>updateUsedProducts() protected;
//19 June 2008	cnwdw1	
// Update the legend table with the products in use by the general cargo area
vars
	allProductsObj	:  CM_ProductByCodeCargoTypeDict;	//10 Jun 2015	NDL	Par 36392
begin
	create allProductsObj transient;	
	if self.myCurrentTerminalArea &lt;&gt; null then
		self.myCurrentTerminalArea.CM_IrregularBlockArea.getAllProducts(allProductsObj);
		self.frmColLegendTIs.saveAllUsedProducts(allProductsObj);	
	endif;
		
epilog
	delete allProductsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="67d705cc-0b05-40db-b1af-92fcf5b70d3d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	app.mousePointer	:=	Busy;
	
	if eventType = EVENT_CODE_COLOUR_CHANGE then
		self.frmColLegendTIs.redisplayViewModeCodes();
		return;
	endif;
	self.doNotableNotification(eventType, theObject, eventTag, userInfo);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xmlToolbar" id="58e98b3d-79f5-4344-b82b-0a7f537f1cf4">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>xmlToolbar(set: Boolean; _value: Boolean io) mapping, updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	if set then
		if not _value then
			self.mnuGridHideToolbar.caption		:=	self.MNU_TOOLBAR_HIDE;
		else
			self.doMnuHideToolbarHide(true);
			self.mnuGridHideToolbar.caption		:=	self.MNU_TOOLBAR_SHOW;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zCloneMenu" id="0916d7e7-fa15-4804-944a-139565a64d3a">
        <updating/>
        <source>zCloneMenu(_cloneMaster, _sourceMenu : MenuItem input; _loadAsSubMenu : Boolean): MenuItem updating, protected;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/
vars
	oidStr	: String;
	newMenu	: MenuItem;
	invalidObject : Boolean;
	clonedMenuCount : Integer;
begin
	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
	endif;

	on Exception do app.handleDeletedObject(exception,newMenu,invalidObject);
	
	if newMenu = null or invalidObject then
		clonedMenuCount := clonedMenuCount + 1;
		
		if _loadAsSubMenu then
			newMenu := _cloneMaster.loadSubMenu(clonedMenuCount);
		else
			newMenu := _cloneMaster.loadMenu(clonedMenuCount);
		endif;
		newMenu.userObject	:= _sourceMenu;
		
		_sourceMenu.description	:= newMenu.getOidString;
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	
	return newMenu;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_loadAsSubMenu" type="Boolean"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
</GUIClass>
