    <JadeMethod name="setAllTblItems" id="7edeafea-c635-4e30-a202-32183ac65c05">
        <updating/>
        <source>setAllTblItems(_mode : String) updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/08/2013	cnwdap1		PAR #32294 Allow access to Vehicle Colour for everyone, not just Duty Docs
//							(because Vehicle Colour has been used as the Cargo Colour table)
// 07/10/2013	cnwdap1		PAR #32605 Allow access to Vehicle Make, Model and Type for everyone as well
// 19 Sep 2019	cnwrs1		TFS 46087 SFTP
// 28/09/2022	navkc1		ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 10 Oct 2022  navma1		ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
// 14 Sep 2023  navhl20 	ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
// ---------------------------------------------------------------------------
vars
	subClasses		: ClassColl;
	subClass		: Class;
	item			: SOP_TableMaintItem;
	tmpTerminal		: CM_Terminal;
	tmpUser			: CM_User;
	includeDutyDoc	: Boolean;
begin
	beginLoad;
	
	//cnwmc5 - 09/01/2013- CCMS 2189
	includeDutyDoc := app.isDutyDocEnabled;
	self.allTableItems.purge;
	self.setCurrentTableItem(null);
	
	if _mode = Mode_System then
		tmpTerminal := null;
	else
		tmpTerminal := self.myTerminal;
	endif;
	
	tmpUser := app.getMyUser;

	create subClasses transient;
	SOP_TableMaintItem.allLocalSubclasses(subClasses);
	
	foreach subClass in subClasses do

		if subClass.abstract then
			continue;
		endif;
		
		if subClass.Class = SOPTM_EDIActions then //CCMS SFW 1012 AMS Processing PAR 17931 cnwgb1 8.10.08
			continue;							  // Now has own Customs Action Form - but leave for 7.6.3
		endif;
		
		// JLGAB1 TFS 39618 Invoice Status Maint is now a seperate form on the navigator under Invoicing - INV_InvoiceStatusForm
		if subClass.Class = SOPTM_InvoiceStatus then
			continue;
		endif;
		
		if not app.myPassport.isVASEnabled() and 
			(subClass.Class = SOPTM_WOJobGrouping or //14.9.2023 navhl20 #60063
			subClass.Class = SOPTM_ToDoTaskResourceGroup)	// ### TFS 58761 (60739) 21Nov2023 NAVPW1
		then		
			continue;
		endif;
		
		//cnwmc5 - 09/01/2013 - CCMS 2189
		if not includeDutyDoc then
			if subClass = SOPTM_DutyDocHSCodes 
			or subClass = SOPTM_DutyDocType 
			or subClass = SOPTM_DutyDocExchangeRate then
			//or subClass = SOPTM_VehicleColour 						// PAR #32294
			//or subClass = SOPTM_VehicleMake 							// PAR #32605
			//or subClass = SOPTM_VehicleModel							// PAR #32605
			//or subClass = SOPTM_VehicleType then						// PAR #32605
				continue;
			endif;
		endif;
		
		if subClass = SOPTM_VehicleBookingType then						//05.10.2022 navma1 #52967
			if tmpTerminal &lt;&gt; null and  not tmpTerminal.isVehicleBookingEnabled then
				continue;
			endif;
			
		endif;
		// Shifted to Voyage Definition form, will remove class later
		if subClass = SOPTM_Status or
		   subClass = SOPTM_HMS or
		   subClass.inheritsFrom(SOPTM_HMS) then //Has own form
			continue;
		endif;		
		
		//14 April 2009 By cnwdz2 CCMS1735 
		//22/06/2009 cnwdz2  par20027
		//29/06/2009 cnwdz2 20149
		if subClass = SOPTM_DataAccessSubTerminal or subClass = SOPTM_SubTerminal then
			if not app.isSubTerminalsLicensed then
			   continue;
			endif;
		endif;
		
		// navkc1	30/09/2022	#54463 starts - Do not display if does not have Advance Damage code permission
		if 	subClass = SOPTM_DamageParty or
			subClass = SOPTM_DamagePlace or
			subClass = SOPTM_DamageReason or
			subClass = SOPTM_DamageRepairReason or
			subClass = SOPTM_DamageSeverity then
			if not tmpUser.canDo(tmpTerminal, PmAdmDamageCodeAdvancedMaint) then
				continue;
			endif;
		endif;
		// navkc1	30/09/2022	#54463 ends
		
		   //27 Nov 2020	NDL	TFS 50191
	/*	if not app.isSFTPEnabled then
			if subClass = SOPTM_SFTPEntity then
				continue;
			endif;
		endif; */

		create item as subClass transient;
		
		if _mode &lt;&gt; Mode_All then
			if (_mode = Mode_Terminal and item.isSystemItem)
			or (_mode = Mode_System and (not item.isSystemItem))
			then
				delete item;
				continue;
			endif;
		endif;
				
		if (item.permissionGroup &lt;&gt; 0 and 
		   (not tmpUser.canDo(tmpTerminal, item.permissionGroup))) or 
		   (not tmpUser.canDo(tmpTerminal, item.permissionView))
		then			
			delete item;
			continue;
		endif;		
		
		self.allTableItems.add(item);	
// write item.name;
	endforeach;
	
	if self.allTableItems.isEmpty then
		self.permissionMaint	:= 0;
		self.permissionView		:= 0;
	else
		item := self.allTableItems.first;
		self.permissionMaint	:= item.permissionMaint;
		self.permissionView		:= item.permissionView;
	endif;
epilog
	endLoad;
	delete subClasses;
end;</source>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCellTextFromControl" id="d688d748-279a-42da-85e4-35bdf6728f1c">
        <source>setCellTextFromControl(_control: ComboBox; _text: String);
//----------------------------------------------------------------
//	Created:	20 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	entTable	: CM_EntryTable;
	row			: Integer;
	
begin
	entTable := _control.parent.CM_EntryTable;
	row := entTable.getRowByControlName(_control.name);

	if row &gt; 0 then
		entTable.setValueByControlName(_control.name, _text);
	endif;

end;</source>
        <Parameter name="_control" type="ComboBox"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="aeb23aaa-d520-4ba3-9526-62f2b24b405a">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// 21 Dec 2017 cnwer1	tfs 8211 removed old drawing stuff
vars
	theBackColour : Integer;
begin
	inheritMethod(_colorControl);
	theBackColour := self.backColor;
//	self.fldInput.backColor		:= theBackColour;

	self.frmAdhoc.backColor		:= theBackColour;


	self.mulAlign1.backColor		:= theBackColour;
	self.mulSelect1.backColor		:= theBackColour;
	self.mulSelect2.backColor		:= theBackColour;
	self.mulSelect3.backColor		:= theBackColour;
	self.mulSelect41.backColor		:= theBackColour;
	self.mulSelect42.backColor		:= theBackColour;
	self.mulSelect8.backColor	:= theBackColour;
	self.mulSelIn21.backColor		:= theBackColour;

	self.shtDataTable1.backColor		:= theBackColour;
	self.shtMultiAlign.backColor		:= theBackColour;
	self.shtMultiSelect1.backColor		:= theBackColour;
	self.shtMultiSelect2.backColor		:= theBackColour;
	self.shtMultiSelect3.backColor		:= theBackColour;
	self.shtMultiSelect4.backColor		:= theBackColour;
	self.shtMultiSelect5.backColor		:= theBackColour;
	self.shtSingleSelect1.backColor		:= theBackColour;
	self.shtSingleSelect2.backColor		:= theBackColour;
	self.shtTblInput1.backColor			:= theBackColour;
	self.shtTblInput2.backColor			:= theBackColour;
	self.shtTblInput3.backColor			:= theBackColour;
	self.shtTreeViewMulti.backColor		:= theBackColour;
	self.shtViewTable1.backColor		:= theBackColour;
	//self.shtViewTable2.backColor		:= theBackColour;

	self.setColorsForEntryTable(self.tblInput1);
	self.setColorsForEntryTable(self.tblInput2);
	self.setColorsForEntryTable(self.tblInput3);
	self.setColorsForTable(self.tblData4);
	self.setColorsForTable(self.tblData1);
	self.setColorsForTable(self.tblData5);	// 25/05/2009 cnwar2 CCMS1040
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="1c46702c-a1a0-426a-b653-745b25ccd963">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/08/2016	cnwdap1		TFS #2447 Prevent lower case being allowed in upper-case-only fields
// 19/10/2020	jlgdap1		TFS 50107 GUQ Error 1310 - Transaction Map - Cargo Allocation
// 04/06/2021	navmd1		TFS 51320 - Add filter box to Sys/Terminal forms
// ---------------------------------------------------------------------------
vars
	row, col : Integer;			// TFS 50107
	
begin
	row := self.tblInput1.row; 										// TFS 50107
	col := self.tblInput1.column;									// TFS 50107
	self.tblInput1.row := 1; 										// TFS 50107
	self.tblInput1.column := self.tblInput1.ColumnValue;			// TFS 50107
	
	self.cmbTable.enabled			:=	false;
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.txtFilterBox.enabled		:=	false;						// TFS 51320
	self.frmTableFilter.txtFilterBox.enabled := false; //25/06/2024	navkc1 CR 64823 Task 64824
	self.chkShowNotAvail.enabled	:=	false;
	self.enteredPassword			:= null;	//PAR13406
	self.enteredPassword2			:= null;	//26 Aug 2021	NDL	TFS 51632
	
	// PAR 23102
	if self.btnImport.visible then
		self.btnImport.enabled := false;
	endif;
	
	self.myCurrentTableItem.setControlsForAddEdit();
	if self.mode = self.Mode_Add then								// TFS 50107
		self.resetFirstRowCase();									// TFS 50107
	elseif self.mode = self.Mode_Update then						// TFS 50107
		self.tblInput1.row := row; self.tblInput1.column := col;	// TFS 50107
	endif;															// TFS 50107
	
	//25 Aug 2021	NDL	TFS 51632 - Don't want to be on the password field
	// when we go into add/edit mode, it causes us to bypass the password form.
	if self.tblInput1.row = self.tblInput1.getRowByName( ETRow_Password )
	or self.tblInput1.row = self.tblInput1.getRowByName( ETRow_MessagePassword )
	then
		if self.tblInput1.row &lt; self.tblInput1.rows then
			self.tblInput1.row := self.tblInput1.row + 1;
		elseif self.tblInput1.row &gt; 1 then
			self.tblInput1.row := self.tblInput1.row - 1;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="30bdc353-ce16-415c-b603-360441fb513b">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/04/2017 cnwrh7         TFS       #3603		Import Button Availability on System / Harbour Admin Screen
// 04/06/2021	navmd1		TFS 51320 - Add filter box to Sys/Terminal forms
// ---------------------------------------------------------------------------
vars
	mthName : String;
	
begin
	cmbTable.enabled		:=	true;
	chkShowNotAvail.enabled	:=	true;
	btnAdvanced.enabled		:=	true;
	//25/06/2024	navkc1 CR 64823 Task 64824
	//txtFilterBox.enabled	:=	true;		// TFS 51320
	self.frmTableFilter.txtFilterBox.enabled := true;
	
	// PAR 23102
// TFS 2210	if self.btnImport.visible then
// TFS 2210		self.btnImport.enabled := true;
		// TFS 2101 CNWAB1

	if self.btnImport.visible then																				//+TFS3603
		if not  app.myCurrentUserCan(null, self.permissionMaint) then
			self.btnImport.enabled := false;
		else
			self.btnImport.enabled := true;
		endif;
	endif; 
		
// TFS 2210	endif;

	if self.myCurrentTableItem &lt;&gt; null then
		self.myCurrentTableItem.setCtrlsForView;
	endif;

		
end;</source>
    </JadeMethod>
