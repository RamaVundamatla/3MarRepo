        <Parameter name="pMinutes" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssAddSeconds" id="55d38c47-1f6b-443b-b8ed-618ba09bec03">
        <source>jssAddSeconds(pSeconds:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver time.
//
// Parameters:	pSeconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (pSeconds * 1000);
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

