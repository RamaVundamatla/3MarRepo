    <JadeMethod name="cnEcGetProcessorSpeed" id="f354b62a-9808-49ae-8ef5-99bd829b938e">
        <source>cnEcGetProcessorSpeed():String protected;
// --------------------------------------------------------------------------------
// Created:		29 September 2005 by cnwdad1
//
// Purpose:		Returns the clock speed of the central processor on the executing
//				process.
//
// Parameters:	None
//
// Returns:		The central processor's clock speed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	HKEY_CLASSES_ROOT		: Integer = #80000000;
	HKEY_CURRENT_USER		: Integer = #80000001;
	HKEY_LOCAL_MACHINE		: Integer = #80000002;
	HKEY_USERS				: Integer = #80000003;
	HKEY_PERFORMANCE_DATA	: Integer = #80000004;
	HKEY_CURRENT_CONFIG		: Integer = #80000005;
	HKEY_DYN_DATA			: Integer = #80000006;

vars
	hKey		: Integer;
	subKey		: String[256];
	valueName	: String[256];
	data		: Binary[256];	
	openKey		: Integer;
	result		: Integer;	
	openResult	: Integer;
	length		: Integer;
	
begin
	hKey			:=	HKEY_LOCAL_MACHINE;
	subKey[256:1]	:=	'';
	subKey			:=	'HARDWARE\DESCRIPTION\System\CentralProcessor\0';
	
	if app.isUnicode() then
		openResult := call cnEcRegOpenKeyW(hKey, subKey, openKey);
	else
		openResult := call cnEcRegOpenKeyA(hKey, subKey, openKey);
	endif;
	
	data[255:1]			:=	0.Binary;
	length				:=	255;
	valueName[256:1]	:=	'';
	valueName			:=	'~MHz';
	
	if app.isUnicode() then
	 	result := call cnEcRegQueryValueExW(openKey, valueName, null, null, data, length);
	else
	 	result := call cnEcRegQueryValueExA(openKey, valueName, null, null, data, length);
	endif;
	
	result := call cnEcRegCloseKey(openKey);
	
	return data.Binary[1:4].Integer.String &amp; ' MHz';
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetProcessorSpeedAppServer" id="48f263be-e0b6-4a38-ba07-c73ebfeb3074">
        <source>cnEcGetProcessorSpeedAppServer():String;
// --------------------------------------------------------------------------------
// Created:		29 September 2005 by cnwdad1
//
// Purpose:		Returns the clock speed of the central processor on the application
//				server machine.
//
// Parameters:	None
//
// Returns:		The central processor's clock speed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	HKEY_CLASSES_ROOT		: Integer = #80000000;
	HKEY_CURRENT_USER		: Integer = #80000001;
	HKEY_LOCAL_MACHINE		: Integer = #80000002;
	HKEY_USERS				: Integer = #80000003;
	HKEY_PERFORMANCE_DATA	: Integer = #80000004;
	HKEY_CURRENT_CONFIG		: Integer = #80000005;
	HKEY_DYN_DATA			: Integer = #80000006;

vars
	hKey		: Integer;
	subKey		: String[256];
	valueName	: String[256];
	data		: Binary[256];	
	openKey		: Integer;
	result		: Integer;	
	openResult	: Integer;
	length		: Integer;
	
begin
	hKey			:=	HKEY_LOCAL_MACHINE;
	subKey[256:1]	:=	'';
	subKey			:=	'HARDWARE\DESCRIPTION\System\CentralProcessor\0';
	
	if app.isUnicode() then
		openResult := call cnEcRegOpenKeyAppServerW(hKey, subKey, openKey);
	else
		openResult := call cnEcRegOpenKeyAppServerA(hKey, subKey, openKey);
	endif;
	
	data[255:1]			:=	0.Binary;
	length				:=	255;
	valueName[256:1]	:=	'';
	valueName			:=	'~MHz';
	
	if app.isUnicode() then
	 	result := call cnEcRegQueryAppServerW(openKey, valueName, null, null, data, length);
	else
	 	result := call cnEcRegQueryAppServerA(openKey, valueName, null, null, data, length);
	 endif;
	 
	result := call cnEcRegCloseKeyAppServer(openKey);
	
 	return data.Binary[1:4].Integer.String &amp; ' MHz';	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetProcessorSpeedClient" id="b2857ecc-2691-4efb-a5ac-d2554df02c82">
        <executionLocation>client</executionLocation>
