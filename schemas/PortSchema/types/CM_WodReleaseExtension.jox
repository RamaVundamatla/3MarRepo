    <JadeMethod name="getExtraInfo" id="623408ec-0340-488a-9387-0a61aa6cfbb2">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2019	jlgndl1	Initial creation	TFS 43405
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars

	block 		 	: CM_DataContainerBlock;
	dateRangeStr 	: String;
	toDo 		 	: CM_WodToDo;
	toDoStr 	 	: String;
	wodRel		 	: CM_WodRelease;
	wodRelParent	: CM_WorkOrder;
begin

	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ExtensionTo), DC_Label, 1, null);
	
	wodRel 			:= self.myReleaseWorkOrder;															//06.03.2023 navma1 #56457:[56458]
	wodRelParent	:= wodRel.myParent;																	//06.03.2023 navma1 #56457:[56458]
	
	if wodRel &lt;&gt; null then
		block.addNewItem(wodRelParent.id, DC_Data, 1, null);
	else
		block.addNewItem(app.getErrorString(Unknown), DC_Data, 1, null);
	endif;
	
	//only relevant before it is actioned
	if wodRelParent.approvalExpiryTS &lt; self.requiredByDT then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Extending_fromto), DC_Label, 1, null);
		dateRangeStr := wodRelParent.approvalExpiryTS.asStringJMT &amp; " - " &amp; self.requiredByDT.asStringJMT;
		block.addNewItem(dateRangeStr, DC_Data, 1, null);
	endif;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyReleaseRequest" id="ce1fa689-a32b-4975-a04a-4cb0eba6833d">
        <source>getMyReleaseRequest():CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	invalid : Boolean;
	edition : Integer;
	relReq : CM_BulkRelease;

begin

	on Exception do app.handleDeletedObject( exception, relReq, invalid );

	relReq := self.myReleaseRequest;	
	if relReq &lt;&gt; null then
		edition := relReq.edition;
		if not invalid then
			return relReq;
		endif;
	endif;
	
	invalid := false;
	if self.myReleaseWorkOrder &lt;&gt; null then
		relReq := self.myReleaseWorkOrder.myReleaseRequest;
		if relReq &lt;&gt; null then
			edition := relReq.edition;
			if not invalid then
				return relReq;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
