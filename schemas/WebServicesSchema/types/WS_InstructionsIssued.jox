    <JadeMethod name="setProxyFromObject" id="74dfd9fb-9fc3-4e38-9ac9-789dbc0056d4">
        <updating/>
        <source>setProxyFromObject(_object: CM_InstructionsIssued) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Apr 2023	navcs2	Initial creation
13 Oct 2023	navma1  ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
27 Oct 2023 navnk30	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
03 Jan 2023 navhl20 Bug 61873: FR | 53891 - Mobile App changes for Delivery Dispatch (EP Tickets)
*/

vars

begin
	self.internalInstructions 	:= _object.internalInstructions;
	self.externalInstructions 	:= _object.externalInstruction;
	self.instructionTypeCode	:= _object.getInstructionCode;
	self.instructionTypeDesc	:= _object.getInstructionDesc;
	self.parentType				:= _object.getParentType;
	self.reference				:= _object.getReferenceId();		//27.10.2023 navnk30 #60646
	self.reservePackType		:= _object.getPackingType();		//03.01.2023 navhl20 #61873
epilog

end;</source>
        <Parameter name="_object" type="CM_InstructionsIssued"/>
    </JadeMethod>
