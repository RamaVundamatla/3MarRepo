    <JadeMethod name="displayEntry" id="8cce2801-7d03-4ca9-bd79-21a59b11ea8d">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _timezone:  CMIF_TimeZoneInfo; lstIndex: Integer): String updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwns1	Initial creation

*/

vars

begin
	if _timezone = null then
		return null;
	endif;
	
	return _timezone.displayName;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_timezone" type="CMIF_TimeZoneInfo"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="7f0ea75c-cfdd-4c31-b554-1a309c7f414a">
        <source>getCollectionJMT(): Collection protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwns1	Initial creation

*/

vars
	
begin
	self.allTimeZones.purge();
	
	app.myTimeZoneHelper.getSystemTimeZones(self.allTimeZones);
	
	return self.allTimeZones;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
