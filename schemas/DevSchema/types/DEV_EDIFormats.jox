    <JadeMethod name="lstXMLDisplay_mouseUp" id="68238ac7-62a7-4fd1-b86c-2a37fd225e7e">
        <controlMethod name="ListBox::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstXMLDisplay_mouseUp(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int		: Integer;
begin

	if shift = 2 then
		int := listbox.listIndex;
		if self.allSelectedFieldRows.includes(int) then
			self.allSelectedFieldRows.remove(int);
		else
			self.allSelectedFieldRows.add(int);
		endif;
	else
		self.allSelectedFieldRows.clear;
		self.allSelectedFieldRows.add(listbox.listIndex);
	endif;  

	self.lblAllSelected.caption := self.allSelectedFieldRows.asCSV(false);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resetControls" id="477718c0-db44-4fa2-bd24-f2f5f9869208">
        <source>resetControls();
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fileField	: CM_EDIItemField;
begin
	
	self.lstXMLDisplay.clear;
	
	self.doCmbEDIDataClick();
	/*
	foreach fileField in self.allMatchedFileFields do
		if fileField.name &lt;&gt; null then
			fileField.setNonSystemAttributes(null, null, null);
		endif;
	endforeach;
	*/
	
	self.allMatchedFileFields.clear;
	self.updateMatchedDisplay();

end;</source>
    </JadeMethod>
    <JadeMethod name="resetTagChkBoxes" id="2cda49b5-1e35-4fc6-b310-8d1313af3373">
        <source>resetTagChkBoxes();
//----------------------------------------------------------------
//	Created:	18 November 2004	by Jason Chapman  (cnwjc2)
