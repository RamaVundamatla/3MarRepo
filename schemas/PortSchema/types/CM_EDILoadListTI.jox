    <JadeMethod name="getLLDisplayString" id="a7f24c4c-1ef1-4b74-8d25-f9b68c7027e2">
        <source>getLLDisplayString(_entTblRows: StringArray):String;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
// 27Jan2015    cnwma1 PAR #35580 Columns arranged incorrectly in the Cargo Comparison 
//----------------------------------------------------------------
vars
	entRow		: String;
	strReturn	: String;
begin
	
	strReturn := '';
	foreach entRow in _entTblRows do
	
		/*if strReturn &lt;&gt; '' then					 //27/01/2015 cnwma1 PAR #35580
			strReturn := strReturn &amp; Tab;
		endif;
		*/
		if entRow = ETRow_Id then
			strReturn := strReturn &amp; self.getid;
		elseif entRow = ETRow_CurtainsIn then
			if self.curtainsIn then
				strReturn := strReturn &amp; "Yes";
			endif;
		else
			strReturn := strReturn &amp; self.getDisplayStringForAttribute(entRow, false);
		endif;
		
		strReturn := strReturn &amp; Tab;   			 //27/01/2015 cnwma1 PAR #35580
	endforeach;
	
epilog
	return strReturn;		
	
end;</source>
        <Parameter name="_entTblRows" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="6f03f79d-e5dd-4892-9b54-e541ea68ca03">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	elseif _attrName = ETRow_OverHeight and self.overHeight = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverLengthFront and self.overLengthFront = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverLengthBack and self.overLengthBack = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverWidthLeft and self.overWidthLeft = NULL_INTEGER then
		return null;
	elseif _attrName = ETRow_OverWidthRight and self.overWidthRight = NULL_INTEGER then
		return null;
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
