        <embedded/>
        <type name="WS_RestCustTaxObject"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="terminalSpecificConfiguration" id="95a5a226-0bdc-48c7-8948-6e92115ab9b1">
