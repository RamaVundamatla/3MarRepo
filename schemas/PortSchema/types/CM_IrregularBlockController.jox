    <JadeMethod name="buildLocationStatsTranisent" id="b2c36d15-186f-49a5-a215-0ca5cc81f7ee">
        <source>buildLocationStatsTranisent( _ls : CM_LocationStatistics io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2013	cnwndl1	Initial creation
10/10/2018 	JLGNS1	Bug 40801: STWO - Issue 37878 occuring again in PROD
*/

vars
	
	free			: Integer;
	plannedIn		: Integer;
	plannedOut		: Integer;
	queuedIn		: Integer;
	queuedOut		: Integer;
	total			: Integer;
	used			: Integer;

	fm				: CM_FutureMove;
	fmq				: CM_FutureMoveQueued;
	fmp				: CM_FutureMovePlanned;
	ti				: CM_TrackedItem;
	
	shelf : CM_RackShelfController;
	
begin

	if _ls = null then
		create _ls transient;
	endif;
	
	_ls.setParent(self);
	
	if self.isRack then
	
		foreach shelf in self.allSubLocations do
		
			//count all TIs being queued out of the area
			foreach ti in shelf.allTrackedItems discreteLock do
			
				used := used + ti.totalQuantity;
				
				if ti.myPrimaryQueuedLocation &lt;&gt; null then
					if ti.myPrimaryQueuedLocation.myTerminalArea &lt;&gt; shelf.myTerminalArea then
						queuedOut := queuedOut + ti.totalQuantity;
					endif;
				endif;	
				
				//count all TIs being planned out of the area
				if ti.myPrimaryPlannedLocation &lt;&gt; null then
					if ti.myPrimaryPlannedLocation.myTerminalArea &lt;&gt; shelf.myTerminalArea then
						plannedOut := plannedOut + ti.totalQuantity;
					endif;
				endif;
			endforeach;	
			
			//count all TIs being queued in to the area
			foreach fm in shelf.allQueuedFutureMoves discreteLock do
				if fm.isKindOf(CM_FutureMoveQueued) then
					fmq := fm.CM_FutureMoveQueued;
					ti := fmq.myTrackedItem;
					if ti &lt;&gt; null then // Bug 40801
						queuedIn := queuedIn + ti.totalQuantity;
					endif;	
				endif;
			endforeach;
		
			//count all TIs being planned in to the area
			foreach fm in shelf.allPlannedFutureMoves discreteLock do
				if fm.isKindOf(CM_FutureMovePlanned) then
					fmp := fm.CM_FutureMovePlanned;
					ti := fmp.myTrackedItem;
					if ti &lt;&gt; null then // Bug 40801
						plannedIn := plannedIn + ti.totalQuantity;
					endif;	
				endif;
			endforeach;		
		
			//total := total + shelf.maxCapacity;
			total := total + shelf.getCurrentCapacity;	//28 Oct 2015	NDL	Par 36928
			
		endforeach;
		
		if total &gt; 0 then
			free := total - used;
		endif;
	
	else
	
		//count all TIs being queued out of the area
		foreach ti in self.allTrackedItems discreteLock do
		
			used := used + ti.totalQuantity;
			
			if ti.myPrimaryQueuedLocation &lt;&gt; null then
				if ti.myPrimaryQueuedLocation.myTerminalArea &lt;&gt; self.myTerminalArea then
					queuedOut := queuedOut + ti.totalQuantity;
				endif;
			endif;	
			
			//count all TIs being planned out of the area
			if ti.myPrimaryPlannedLocation &lt;&gt; null then
				if ti.myPrimaryPlannedLocation.myTerminalArea &lt;&gt; self.myTerminalArea then
					plannedOut := plannedOut + ti.totalQuantity;
				endif;
			endif;
		endforeach;	
		
		//count all TIs being queued in to the area
		foreach fm in self.allQueuedFutureMoves discreteLock do
			if fm.isKindOf(CM_FutureMoveQueued) then
				fmq := fm.CM_FutureMoveQueued;
				ti := fmq.myTrackedItem;
				if ti &lt;&gt; null then // Bug 40801
					queuedIn := queuedIn + ti.totalQuantity;
				endif;	
			endif;
		endforeach;
	
		//count all TIs being planned in to the area
		foreach fm in self.allPlannedFutureMoves discreteLock do
			if fm.isKindOf(CM_FutureMovePlanned) then
				fmp := fm.CM_FutureMovePlanned;
				ti := fmp.myTrackedItem;
				if ti &lt;&gt; null then // Bug 40801
					plannedIn := plannedIn + ti.totalQuantity;
				endif;
			endif;
		endforeach;		
	
		//total := self.maxCapacity;
		total := self.getCurrentCapacity;	//28 Oct 2015	NDL	Par 36928
		if total &gt; 0 then
			free := total - used;
		endif;
			
	endif;
	
	_ls.total := total;
	_ls.used := used;
	_ls.free := free;
	_ls.queuedIn := queuedIn;
	_ls.queuedOut := queuedOut;
	_ls.plannedIn := plannedIn;
	_ls.plannedOut := plannedOut;
	
end;
</source>
        <Parameter name="_ls" type="CM_LocationStatistics" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canReceiveBulkMove" id="e747840a-842c-481e-a02c-f26aa254d8de">
