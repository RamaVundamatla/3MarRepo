    <JadeMethod name="doMnuInvUpdatePaymentStClick" id="5ab6da18-6948-41cb-b78a-a1375b466374">
        <updating/>
        <source>doMnuInvUpdatePaymentStClick(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars
	pxyInvoice : CM_Invoice;
	newPaymentStatus : Integer;
begin
	pxyInvoice := app.createUpdateProxy(self.myCurrentInvoice).CM_Invoice;
	
	if self.myCurrentInvoice.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
		newPaymentStatus := CM_Invoice.INVOICE_PAYMENT_PAID;
	
	elseif self.myCurrentInvoice.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
		newPaymentStatus := CM_Invoice.INVOICE_PAYMENT_CANCEL;

	elseif self.myCurrentInvoice.paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL then
		newPaymentStatus := CM_Invoice.INVOICE_PAYMENT_NOTPAID;
	endif;
	
	app.myTrxUA.trxUpdateInvoicePaymentStatus(pxyInvoice,newPaymentStatus,app.myPassport);
epilog
	delete pxyInvoice;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
