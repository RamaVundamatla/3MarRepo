epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="6885a926-efdd-4517-8672-f272d460c7b0">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	audTxt, 
	tmpStr			: String;
	size,
	year,
	seq				: Integer;
begin
	audTxt[10000] 	:= '*';
	
	audTxt := inheritMethod();
	
	size := self.nextSequenceNumArray.size();
	
	if size = 0 then
		return audTxt;
	endif;
	
	while year &lt; size do
		year += 1;
		
		seq := self.nextSequenceNumArray[year].Integer;
		
		if seq = 0 then
			continue;
		endif;
		
		tmpStr := (2000 + year).String &amp; "-" &amp; seq.String &amp; Cr &amp; tmpStr;
	endwhile;
	
	audTxt := audTxt &amp; AuditStringSeparator &amp; CM_AutoTaxNumberGen::nextSequenceNum.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr;
	
	return audTxt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSequenceNumArray" id="95f2faa5-b42e-4bea-83f3-6cf778933f0a">
        <source>getNextSequenceNumArray( theYear : Integer ): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197

*/

vars

begin
	if self.nextSequenceNumArray.size &lt; theYear then
		return 0;
	endif;
	return self.nextSequenceNumArray[ theYear ];

epilog

end;</source>
        <Parameter name="theYear" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
