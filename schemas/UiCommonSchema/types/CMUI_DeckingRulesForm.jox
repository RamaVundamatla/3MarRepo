    <JadeMethod name="btnCustomSaveClick" id="85e18068-6f13-47b9-a777-7766d66f9c31">
        <updating/>
        <source>btnCustomSaveClick() updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.saveCustomOrder();
	
	self.enableFormCustomClose();
	self.frmCustomSetting.visible := false;
	
end;</source>
