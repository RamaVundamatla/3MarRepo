    <JadeMethod name="doPurgeReleaseRequests" id="689f5d36-ee11-4b16-ab3d-c876317c21e8">
        <updating/>
        <source>doPurgeReleaseRequests(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request

*/

vars
	date 		: TimeStamp;
	terminal 	: CM_Terminal;
	releaseRequests : CM_BulkRelease;
	iter		: Iterator;
	count, theSize : Integer;
	deleted     : Integer; 
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Release_Requests), false, false);

	date := self.date.TimeStamp;
	terminal := self.myTerminal;
	
	iter := terminal.allBulkReleasesByCodeDate.createIterator();
	theSize := terminal.allBulkReleasesByCodeDate.size();
	while iter.next(releaseRequests) do
		if releaseRequests.createdTime &lt; date then
			count := count + 1;
			if count mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteBulkRelease(releaseRequests, app.myPassport);
			if app.myPassport.trxCompletedOK then
				deleted := deleted + 1;
			endif;
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; deleted.String &amp; " Release request records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeReleasedCargoGroups" id="b4ef5a14-b80e-4aa0-8385-d94b7bc9031f">
        <updating/>
        <source>doPurgeReleasedCargoGroups() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars


begin

	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Cargo_group_with_remai_onsit_c), false, false);
	app.myTrxDA.trxDeleteDBPurgeCargoGroups(self.myTerminal, self.date.TimeStamp.cnEcAddDays(1), self, app.myPassport);
	// Get stats if any.
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	return not self.isToAbort;	

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeSecGateUnknTrucks" id="df478ee5-1fc7-4c66-92b6-cd95a2bacad7">
        <updating/>
        <source>doPurgeSecGateUnknTrucks() : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2021	navpw1	Initial creation TFS: 51994

*/

vars

	allUnknTrucksToPurge	: DynaDictionary;
	obj						: Object;
	vehicle					: CM_Vehicle;
	errCode					: Integer;
	errTxt					: String;
	rtnCode					: Boolean;

begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp; ' ' &amp; app.getErrorString(Security_Gate_Unknown_Trucks), false, false);
	
	create allUnknTrucksToPurge transient;
	
	allUnknTrucksToPurge.setMembership(CM_Vehicle);
	allUnknTrucksToPurge.addMemberKey(CM_Vehicle::regNumber.name, false, false);
	allUnknTrucksToPurge.endKeys(true);
	
	self.getUnknownTrucksOlderThanDate(allUnknTrucksToPurge);
	
	app.myTrxDA.trxDeleteDBPurgeUnknTrucks(allUnknTrucksToPurge, self, app.myPassport);
	
	return true;
	
epilog
	
	delete allUnknTrucksToPurge;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeSundry" id="3b462562-5031-4ce9-879e-0ff78b6a4d7e">
        <updating/>
        <source>doPurgeSundry() : Boolean protected, updating;
// -------------------------------------------
// Created Apr 2005 by cnwrs1
// -------------------------------------------
/*

Date		Who		Reason
11/12/2009	cnwdap1		CCMES MES 1007 CM_TempReading myReeferProperties check
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT

*/

vars
	objArray: ObjectArray;
	objArray2 : ObjectArray;
	obj: Object;
	errCode, count1, count2, count3, size: Integer;
	errTxt: String;
	rtnCode: Boolean;
	slotController: CM_SlotController;
	slotDefn: CM_SlotDefnVessel;
	dict: CM_DiscrepancyArray;
	ti: CM_TrackedItem;
	tr: CM_TITransaction;
	tempReading: CM_TempReading;
	camTaskHistory: CM_CamTaskHistory;
	term: CM_Terminal;
	dictUsed: Boolean;
	aClass: Class;
	classId: Integer;
	instId, lastInstId: Integer;
	idx: Integer;
	str : String;
	version : Integer;
begin

	on Exception do self.sundryExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	version := app.myRoot.getConfig(DBPurgeSundryVersion).Integer;
	if version = 0 then //this is setup so this only runs once per database
		version := 1;
		self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Sundry)&amp;" objects for version 1.", false, false);
	
		if self.myBGPRequest.currentSundryObject &lt;&gt; null then
			// need to establish where we were up to
			aClass := self.myBGPRequest.currentSundryObject.class;
			global.getOidStringForObject(self.myBGPRequest.currentSundryObject).oidStringToClassAndInstanceId(classId, instId);
			// now we have a class num  and inst num to restart from we just go for it 
		else
			// not restart so setup restart to first class and first inst of that class
			aClass := CM_SlotRequest;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
	
		if aClass = CM_SlotRequest then
			self.createActivityHistory("Find orphaned Slot Requests ", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_SlotRequest;
				if not global.isValidObject(obj) then
					continue;
				endif;
				errTxt := null;
				self.doInitiateProcess();
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);

					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_SlotRequest.myBay = null then
					obj.CM_SlotRequest.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
				// Will get here if trx has been unsuccessful due to abort.
				rtnCode := self.isToAbort or self.abort();
				if rtnCode then
					return false;
				endif;
				if errTxt &lt;&gt; null then
					self.allErrors.add(errTxt);
				endif;
				self.doCheckForError();
			endforeach;
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);

			self.createActivityHistory("Purged "&amp;count1.String&amp;" SlotRequests.", false, false);
			aClass := CM_SlotController;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
	
		if aClass = CM_SlotController then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Find orphaned SlotControllers", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_SlotController;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				slotController := obj.CM_SlotController;
				if slotController.myBayVoyage = null then
					slotController.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				else
					if not global.isValidObject(slotController.mySlotRequestDischarge) then
						slotController.setPropertyValue(CM_SlotController::mySlotRequestDischarge.name, null);
					endif;
					if not global.isValidObject(slotController.mySlotRequestLoad) then
						slotController.setPropertyValue(CM_SlotController::mySlotRequestLoad.name, null);
					endif;
					if (slotController.mySlotRequestDischarge = null or
						slotController.allSlotRequestsDischarge.includes(slotController.mySlotRequestDischarge)) then
						slotController.setPropertyValue(CM_SlotController::mySlotRequestDischarge.name, slotController.allSlotRequestsDischarge.first); 
					endif;
					if (slotController.mySlotRequestLoad = null or
						slotController.allSlotRequestsDischarge.includes(slotController.mySlotRequestLoad)) then
						slotController.setPropertyValue(CM_SlotController::mySlotRequestLoad.name, slotController.allSlotRequestsLoad.first); 
					endif;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" SlotControllers.", false, false);
			aClass := CM_SlotDefnVessel;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_SlotDefnVessel then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Find orphaned SlotDefnVessels", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_SlotDefnVessel;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				slotDefn := obj.CM_SlotDefnVessel;
				if slotDefn.myBay = null then
					slotDefn.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" SlotDefnVessels.", false, false);
			aClass := CM_TrackedItem;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_TrackedItem then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Find orphaned TrackedItems", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_TrackedItem;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
		
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				ti := obj.CM_TrackedItem;
				if ti.site = 0 and //undefined
				   ti.state = 7 and //EDI
				   ti.allPlannedFutureMoves.size = 0 then
					ti.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				elseif not global.isValidObject(ti.myVoyage) then
					ti.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				elseif not global.isValidObject(ti.myOperator) then
					ti.setPropertyValue(CM_TrackedItem::myOperator.name, null);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" TrackedItems.", false, false);
			aClass := CM_TITransaction;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_TITransaction then
			count1 := 0;
			count2 := 0;
			count3 := 0;
			self.createActivityHistory("Find orphaned TITransaction", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_TITransaction;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				tr := obj.CM_TITransaction;
				if tr.myTrackedItem = null and //undefined
				   tr.myTerminal = null then
					tr.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
				if tr.class &lt;&gt; global.getTiTxnClassForType(tr.type, true) then
					count3 := count3 + 1;
					tr.setPropertyValue('type', global.getTiTxnTypeForClass(tr.class));
				endif;	
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" TITransaction.", false, false);
			if count3 &gt; 0 then
				self.createActivityHistory("Fixed type on "&amp;count3.String&amp;" TITransaction.", false, false);
			endif;
			aClass := CM_TempReading;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_TempReading then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Find orphaned TempReading", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_TempReading;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				tempReading := obj.CM_TempReading;
				if tempReading.myContainer = null and
				   tempReading.myTemperatureReading = null and
				   tempReading.myReeferProperties = null then //orphaned there are other orpahedto be identified
					tempReading.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" TempReading.", false, false);
			aClass := CM_CamTaskHistory;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_CamTaskHistory then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Find orphaned CamTaskHistory", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_CamTaskHistory;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
		
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				camTaskHistory := obj.CM_CamTaskHistory;
				if camTaskHistory.camProtocol = null then
					camTaskHistory.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" CamTaskHistorys.", false, false);
		
			self.createActivityHistory("Find and purge orphaned Dictionaries", false, false);
			beginTransaction;
			CM_TISet.deleteAllInstances;
			if self.abort() then
				return false;
			endif;
			app.cmsCommitTransaction(app.myPassport);
		
			beginTransaction;
			CM_TIArray.deleteAllInstances;
			if self.abort() then
				return false;
			endif;
			app.cmsCommitTransaction(app.myPassport);
		
			beginTransaction;
			CM_TIByIdDict.deleteAllInstances;
			if self.abort() then
				return false;
			endif;
			app.cmsCommitTransaction(app.myPassport);

			beginTransaction;
			CM_TIByIdReversedDict.deleteAllInstances;
			if self.abort() then
				return false;
			endif;
			app.cmsCommitTransaction(app.myPassport);
	
	//		beginTransaction;
	//		CM_BayDefnArray.deleteAllInstances;
	//		if self.abort() then
	//			return false;
	//		endif;
	//		app.cmsCommitTransaction(app.myPassport);
	
			aClass := CM_DiscrepancyArray;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_DiscrepancyArray then
			count1 := 1;
			count2 := 0;
			create objArray transient;
			self.createActivityHistory("Find orphaned discrepancy arrays.", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				dict := str.asOid.CM_DiscrepancyArray;
				if global.isValidObject(dict) then
					continue;
				endif;
				dictUsed := false;
				foreach term in CM_Terminal.instances do
					if term.discrepancies.includes(dict) then
						dictUsed := true;
						break;
					endif;
				endforeach;
				if not dictUsed then
					objArray.add(dict);
				endif;
			endforeach;
			if objArray.size &gt; 0 then
				beginTransaction;
				foreach obj in objArray do
					count2 := count2 + 1;
					if count2 mod Commit_Block_Size_Large = 0 then
						if self.abort() then
							return false;
						endif;
						self.myBGPRequest.setSundryCurrentObject(obj);
						app.cmsCommitTransaction(app.myPassport);
			
						if count2 mod self.Activity_Progress_Count_Large = 0 then
							size := count2 + (lastInstId - idx);
							self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
						endif;
						beginTransaction;
					endif;
					if global.isValidObject(obj) then
						delete obj;
					endif;
				endforeach;
				if self.abort() then
					return false;
				endif;
				self.myBGPRequest.setSundryCurrentObject(obj);
				app.cmsCommitTransaction(app.myPassport);
		
			endif;
			self.createActivityHistory("Purged "&amp;objArray.size.String&amp;" discrepancy arrays.", false, false);
			delete objArray;
			aClass := CM_TIRequest;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_TIRequest then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Fix invalid tiRequests", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_TIRequest;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_TIRequest.trackedItem &lt;&gt; null and
				   not global.isValidObject(obj.CM_TIRequest.trackedItem) then
					obj.CM_TIRequest.setPropertyValue("trackedItem", null);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Fixed "&amp;count1.String&amp;" invalid tiRequests.", false, false);
			aClass := CM_TISnapShot;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		if aClass = CM_TISnapShot then
			count1 := 0;
			count2 := 0;
			self.createActivityHistory("Fix invalid tiSnapShots", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_TISnapShot;
				if not global.isValidObject(obj) then
					continue;
				endif;
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_TISnapShot.snapShotCreatedBy &lt;&gt; null and
				   not global.isValidObject(obj.CM_TISnapShot.snapShotCreatedBy) then
					obj.CM_TISnapShot.setPropertyValue(CM_TISnapShot::snapShotCreatedBy.name, null);
					count1 := count1 + 1;
				endif;
			endforeach; 
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Fixed "&amp;count1.String&amp;" invalid tiSnapShots.", false, false);
			aClass := CM_LongString;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		
		
		if aClass = CM_LongString then
			self.createActivityHistory("Find orphaned Long Strings ", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_LongString;
				if not global.isValidObject(obj) then
					continue;
				endif;
				errTxt := null;
				self.doInitiateProcess();
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_LongString.myObject = null then
					obj.CM_LongString.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
				// Will get here if trx has been unsuccessful due to abort.
				rtnCode := self.isToAbort or self.abort();
				if rtnCode then
					return false;
				endif;
				if errTxt &lt;&gt; null then
					self.allErrors.add(errTxt);
				endif;
				self.doCheckForError();
			endforeach;
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" LongStrings.", false, false);
		endif;
		beginTransaction;
		app.myRoot.setConfig(DBPurgeSundryVersion, version, true);
		commitTransaction;
	endif;
	if version = 1 then // this will be the second run
		version := 2;
		self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Sundry)&amp;" objects for version 2.", false, false);
	
		if self.myBGPRequest.currentSundryObject &lt;&gt; null then
			// need to establish where we were up to
			aClass := self.myBGPRequest.currentSundryObject.class;
			global.getOidStringForObject(self.myBGPRequest.currentSundryObject).oidStringToClassAndInstanceId(classId, instId);
			// now we have a class num  and inst num to restart from we just go for it 
		else
			// not restart so setup restart to first class and first inst of that class
			aClass := CM_SOHLocationExtLog;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
	
		if aClass = CM_SOHLocationExtLog then
			self.createActivityHistory("Find orphaned Stock on Hand Extension records ", false, false);
			lastInstId := self.getInstanceIdForObject64(aClass.lastInstance).Integer;
			size := lastInstId - instId;
			beginTransaction;
			foreach idx in instId to lastInstId do
				str := (classId.String&amp;"."&amp;idx.String);
				obj := str.asOid.CM_SOHLocationExtLog;
				if not global.isValidObject(obj) then
					continue;
				endif;
				errTxt := null;
				self.doInitiateProcess();
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
			
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						size := count2 + (lastInstId - idx);
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of about "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_SOHLocationExtLog.myStockOnHand = null then
					obj.CM_SOHLocationExtLog.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
				// Will get here if trx has been unsuccessful due to abort.
				rtnCode := self.isToAbort or self.abort();
				if rtnCode then
					return false;
				endif;
				if errTxt &lt;&gt; null then
					self.allErrors.add(errTxt);
				endif;
				self.doCheckForError();
			endforeach;
			if self.abort() then
				return false;
			endif;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
		
			self.createActivityHistory("Purged "&amp;count1.String&amp;" Stock on Hand Extension records.", false, false);
			aClass := CM_Strings;
			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId);
		endif;
		if aClass = CM_Strings then
	// cnwrs1 July 2006 this dosnt allow for any new CM_Edits while the process go on
	/*		self.createActivityHistory("Find orphaned Strings ", false, false);
			create objArray transient;
			CM_Strings.allInstances(objArray, 0, false);
			create objArray2 transient;
			CM_Edit.allInstances(objArray2, 0, true);
			foreach obj in objArray2 do
				if objArray.includes(obj.CM_Edit.fieldsValues) then
					objArray.remove(obj.CM_Edit.fieldsValues);
				endif;
			endforeach;
			delete objArray2;
			size := objArray.size;
			beginTransaction;
			foreach obj in objArray do
				errTxt := null;
				self.doInitiateProcess();
				count2 := count2 + 1;
				if count2 mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					self.myBGPRequest.setSundryCurrentObject(obj);
					app.cmsCommitTransaction(app.myPassport);
					
					if count2 mod self.Activity_Progress_Count_Large = 0 then
						self.createActivityHistory("Processed "&amp;count2.String&amp;" of "&amp;size.String, false, true);
					endif;
					beginTransaction;
				endif;
				if obj.CM_Strings.myObject = null then
					obj.CM_Strings.erase(NORMAL_ERASE);
					count1 := count1 + 1;
				endif;
				// Will get here if trx has been unsuccessful due to abort.
				rtnCode := self.isToAbort or self.abort();
				if rtnCode then
					return false;
				endif;
				if errTxt &lt;&gt; null then
					self.allErrors.add(errTxt);
				endif;
				self.doCheckForError();
			endforeach;
			if self.abort() then
				return false;
			endif;
			delete objArray;
			self.myBGPRequest.setSundryCurrentObject(obj);
			app.cmsCommitTransaction(app.myPassport);
			
			self.createActivityHistory("Purged "&amp;count1.String&amp;" Strings.", false, false);
	*/		aClass := null;
//			global.getOidStringForObject(aClass.firstInstance).oidStringToClassAndInstanceId(classId, instId); //cnwrs1 june 2008 was missing which caused next section to fail
		endif;
		beginTransaction;
		app.myRoot.setConfig(DBPurgeSundryVersion, version, true);
		commitTransaction;
	endif;
	self.createActivityHistory(null, false, false);
	beginTransaction;
	self.myBGPRequest.setSundryCurrentObject(null);
	commitTransaction;
	return true;
epilog
	delete objArray;		// PAR #27874
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeVehicleBookings" id="30427c2a-f079-4b19-94b2-2d0e4da89e80">
        <updating/>
        <source>doPurgeVehicleBookings() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation	Par 31393
04/03/2015		cnwmh5	Transient Leaks
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
*/

vars

	bookingSlot	: CM_VehicleBookingTimeSlot;
	errCode	: Integer;
	errTxt	: String;
	count, theSize : Integer;
	purgeBeforeDays : Integer;
	purgeBeforeDate : Date;
	msg : String;
	iter : Iterator;
	coll : CM_VehicleBookingByTs;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	purgeBeforeDays := self.myTerminal.getConfig( VsPurgeSlotsOlderThan ).Integer;
	purgeBeforeDate := (app.actualTimeServer.Date - purgeBeforeDays);			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if purgeBeforeDays &lt; 1 then
		msg := app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Vehicle_schedul_booking_slot) &amp; " not started, " &amp; ETRow_VsPurgeSlotsOlderThan &amp; 
							" must be greater than 1. [Gate tab of Terminal Config]";
		self.createActivityHistory( msg, false, false );
		return true;	//not false we done want the garbage collection to abort
	endif;
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Vehicle_schedul_booking_slot), false, false);
	
	iter := self.myTerminal.myVehicleBookingTerminal.allBookingsByTS.createIterator;
	create coll transient;
	while iter.next(bookingSlot) do
		if bookingSlot.bookingTSstart.Date &gt;= purgeBeforeDate then
			break;
		endif;
		coll.add(bookingSlot);
	endwhile;
	
	theSize := coll.size;
	foreach bookingSlot in coll do
		count := count + 1;
			if count mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;

				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteVehicleBooking(bookingSlot, app.myPassport);
		if self.abort() then
			return false;
		endif;
		self.createActivityHistory(null, false, false);
		self.setStats(null);
	endforeach;
	
	self.createActivityHistory("Purged "&amp;theSize.String&amp;' '&amp;app.getErrorString(Vehicle_schedul_booking_slot), false, false);
	return true;
	
epilog
	delete coll;
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeVehicleVisitRecords" id="d4d0bf0b-774d-4c31-a12a-94aeaa75720b">
        <updating/>
        <source>doPurgeVehicleVisitRecords() : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars

	vehicle	: CM_Vehicle;
	errCode	: Integer;
	errTxt	: String;
	count, theSize : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Vehicle_visit_records), false, false);
	theSize := self.myTerminal.vehicles.size;
	foreach vehicle in self.myTerminal.vehicles do
		count := count + 1;
			if count mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;

				if count mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
				endif;
			endif;
//		self.createActivityHistory(app.getErrorString(Vehicle) &amp; ' ' &amp; vehicle.id, false, false);
		app.myTrxDA.trxDeleteDBPurgeVehicleVisits(vehicle, self.date.TimeStamp, self, app.myPassport);
		if self.abort() then
			return false;
		endif;
		self.createActivityHistory(null, false, false);
		//PAR18151 - cnwsh3 Reset the stats so only vehicles that had visit records deleted will be logged.  Prevents unecessary logging.
		self.setStats(null);
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;' '&amp;app.getErrorString(Vehicle_visit_records), false, false);
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeVisitPhotos" id="21f3bc26-ba36-427f-8e35-598cab46197d">
        <updating/>
        <source>doPurgeVisitPhotos(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	date 		: TimeStamp;
	terminal 	: CM_Terminal;
	vvr 		: CM_VehicleVisitRecord;
	photo		: CM_Attachment;
	iter		: Iterator;
	count,
	theSize 	: Integer;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Visit_photos), false, false);

	date := self.date.TimeStamp;
	terminal := self.myTerminal;
	
	iter := terminal.allVehicleVisits.createIterator();
	theSize := terminal.allVehicleVisits.size;
	while iter.next(vvr) do
		if vvr.allAttachments.isEmpty then
			continue;
		endif;
		
		foreach photo in vvr.allAttachments do
			if photo.type &lt;&gt; CM_Attachment.Type_Photo then
				continue;
			endif;
			
			if photo.createdTime &lt; date then
				count := count + 1;
				if count mod Commit_Block_Size_Large = 0 then
					if self.abort() then
						return false;
					endif;
					if count mod self.Activity_Progress_Count_Large = 0 then
						self.createActivityHistory("Processed Visit Photos "&amp; count.String &amp; " of " &amp; theSize.String, false, true);
					endif;
				endif;
				app.myTrxDA.trxDeleteVisitPhoto(photo.CM_Photo,app.myPassport);
			endif;
			if self.abort() then
				return false;
			endif;
		endforeach;
	endwhile;
	
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; count.String &amp; " Visit Photos.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeWorkOrderJobSheets" id="bbe7f241-cc08-4ee8-a8f1-9a5eb02b7dec">
        <updating/>
        <source>doPurgeWorkOrderJobSheets(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jul 2023	navhl20	ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/

vars
	date 		: TimeStamp;
	terminal 	: CM_Terminal;
	jobSheet 	: CM_WorkPointJobSheet;
	job			: CM_Job;
	iter		: Iterator;
	countJob,
	countJobSheet,
	theSize 	: Integer;
	history		: String;
begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Workorder_sheets), false, false);

	date := self.date.TimeStamp;
	terminal := self.myTerminal;
	
	iter := terminal.allJobSheetsForWorkPoints.createIterator();
	theSize := terminal.allJobSheetsForWorkPoints.size;
	while iter.next(jobSheet) do
		if jobSheet.createdTime &lt; date or (app.isJMTUnitTest and jobSheet.startDateTime &lt; date) then
			foreach job in jobSheet.allJobsByPriorityRequiredDT do
				if job.canBeDeletedByGC() then
					countJob := countJob + 1;
					app.myTrxDA.trxDeleteJob(job, app.myPassport);
					
					if countJobSheet mod Commit_Block_Size_Large = 0 then
						if self.abort() then
							return false;
						endif;
						if countJob mod self.Activity_Progress_Count_Large = 0 then
							self.createActivityHistory("Processed Work order jobs "&amp; countJob.String &amp; " of " &amp; theSize.String, false, true);
						endif;
					endif;
				endif;
			endforeach;
			if jobSheet.allJobsByPriorityRequiredDT.size &gt; 0 then
				continue;
			endif;
			countJobSheet := countJobSheet + 1;
			if countJobSheet mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				if countJobSheet mod self.Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp; countJobSheet.String &amp; " of " &amp; theSize.String, false, true);
				endif;
			endif;
			app.myTrxDA.trxDeleteWorkPointJobSheet(jobSheet, app.myPassport);
		endif;
	endwhile;
		
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	self.createActivityHistory("Purged " &amp; countJob.String &amp; " WorkOrder Jobs.", false, false);
	self.createActivityHistory("Purged " &amp; countJobSheet.String &amp; " WorkOrder Job Sheet records.", false, false);
	return not self.isToAbort;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeXlations" id="cf62857f-d7fd-4c10-8964-74679fe278f0">
        <updating/>
        <source>doPurgeXlations() : Boolean protected, updating;
// -------------------------------------------
// Created Spetember 2006 by cnwrs1
// -------------------------------------------
vars

begin
	self.doInitiateProcess();
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Translations", false, false);
	app.myTrxDA.trxDeleteDBPurgeXlations(self.myTerminal, self.date.TimeStamp, self, app.myPassport);
	// Get stats if any.
	self.createActivityHistory(null, false, false);
	self.doCheckForError();
	return not self.isToAbort;	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveZombieRefs" id="93f408dc-8ed5-4faf-b8f1-e94556dc466a">
        <updating/>
        <source>doRemoveZombieRefs( _release : PortSchemaRelease ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2021	jlgndl1	Initial creation	TFS 50761
24 Sep 2021	navdap1	TFS 52072 AAT Customs Stops Removed from Voyage BOLs
*/

constants

	MilisPerMinute : Integer = 60000;

vars

	zombieEndTime : TimeStamp;
	zombieInterval : TimeStampInterval;
	stopTable : CM_StopsTable;
	stop : CM_Stops;
	aborting : Boolean;
	now : TimeStamp;
	ti : CM_TrackedItem;
	edition : Integer;
	objsToDelete : ObjectSet;
	objsCount : Integer;
	invalidTi: Boolean;
	tryLockCount : Integer;
	moreToDo : Boolean;

begin

	self.createActivityHistory("MTN Internal Housekeeping - Clearing merged stops, starting...", false, false);
	
	now := app.actualTimeServer;
	zombieInterval.set( 0, (10 * MilisPerMinute) ); // 10 minutes - Max Time to run the zombie clean-up per run
	zombieEndTime := now + zombieInterval;
	
	create objsToDelete transient;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	
	foreach stopTable in app.myRoot.allStopsTable discreteLock do
		
		objsToDelete.clear();
		objsCount := 0;
		tryLockCount := 0;
		
		//find the stops we need to delete, i.e. linked to nothing, or linked to zombies.
		//stop when we get to 20,000
		foreach stop in stopTable.allStops discreteLock do
			if objsCount &gt; 20000 then
				moreToDo := true; // Don't want to bite off, too many for the delete.
				break;
			endif;
			if stop.myBOL &lt;&gt; null then			// TFS 52072
				continue;						// TFS 52072
			endif;								// TFS 52072
			ti := stop.myTrackedItem;
			if ti = null then
				//should never get this, but if we do, then clean it up too
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
				continue;
			endif;
			edition := ti.edition;
			if invalidTi then
				//should never get this, but if we do, then clean it up too
				invalidTi := false;
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
				continue;
			elseif ti.hasBeenMerged then
				//its a zombie, clean it up
				objsToDelete.add( stop );
				objsCount := objsCount + 1;
			endif;
		endforeach;
		
		//Actually do the deletes of teh ones we found - if we can get the lock.
		if not objsToDelete.isEmpty then	
			while tryLockCount &lt; 3 do
				tryLockCount := tryLockCount + 1;
				if tryLock( stopTable, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate ) then
					app.sendHeartbeatIfRequired();
					beginTransaction;
					objsToDelete.purge();
					commitTransaction;
					self.createActivityHistory("Clearing " &amp; objsCount.String &amp; " merged stops for '" &amp; stopTable.code &amp; "'", false, false);
					tryLockCount := 0;
					break;
				else
					process.sleep(500); //sleep for half a second
				endif;
			endwhile;
			
			if tryLockCount &gt; 0 then
				self.createActivityHistory(objsCount.String &amp; " merged stops in '" &amp; stopTable.code &amp; "' locked, not cleared", false, false);
				moreToDo := true;
			endif;
		
		endif;
		
		//check to see if we have time to do more
		now := app.actualTimeServer;
		if self.myBGPRequest &lt;&gt; null and self.myBGPRequest.maxDurationMinutes &gt; 0 and now &gt;= self.finishTimeStamp then
			//The generic version of the Garbage Collect has been running long enough, bail
			aborting := true;
			moreToDo := true;
			break;
		elseif zombieEndTime &lt; now then
			//The Local MTN Housekeeping , I've been running more than 10 minutes, time to stop looking for now..
			aborting := true;
			moreToDo := true;
			break;
		endif;
		
	endforeach;

	if aborting or moreToDo then
		self.createActivityHistory("'Clearing merged stops', part performed, will continue next Garbage Collect", false, false);
		return true;
		
	else
		//We are all done forever, no need to run again.
		self.createActivityHistory("MTN Internal Housekeeping - 'Clearing merged stops', complete.", false, false);
	//	beginTransaction;	//12 Mar 2021	NDL	found in unit test
		_release.addScriptRun(method.name);
	//	commitTransaction;
		return true;
		
	endif;

epilog

	delete objsToDelete;
	abortTransaction;

end;</source>
        <Parameter name="_release" type="PortSchemaRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTruncateEDIInfoXML" id="90c2c085-dc14-4acc-9c5b-4ff065f68f06">
        <updating/>
        <source>doTruncateEDIInfoXML():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2021	navndl1	Initial creation	TFS 51718

*/

constants

	MilisPerMinute : Integer = 60000;

vars

	tiTrx : CM_TITransaction;
	edition : Integer;
	invalid : Boolean;
	iter : Iterator;
	ediInfoSent : CM_InfoEDISent;
	latestTruncated : CM_InfoEDISent;
	count : Integer;
	now : TimeStamp;
	forcedEndTime : TimeStamp;
	maxRunTime : TimeStampInterval;
	completeToDate : Date;
	errCode : Integer;
	errTxt : String;

begin

	self.createActivityHistory(app.getErrorString(Database_Purging) &amp; ' ' &amp; app.getErrorString(Truncate_EDIInfo_XML), false, false);
	self.doInitiateProcess();
	
	now := app.actualTimeServer;
	maxRunTime.set( 0, (20 * MilisPerMinute) ); // 20 minutes - Max Time to run the truncation code per run (about 1 month worth across the AAT terminals)
	forcedEndTime := now + maxRunTime;
	
	//find the most recent truncated EDI Info Sent object
	ediInfoSent := self.myTerminal.getConfig( LatestTruncatedEDIinfo ).CM_InfoEDISent;
	
	on Exception do app.handleDeletedObject( exception, ediInfoSent, invalid );
	if ediInfoSent &lt;&gt; null then
		edition := ediInfoSent.edition;
		if invalid then
			//could happen if real archiving of trackeditems occurs.
			ediInfoSent := null;
		endif;
	endif;
	if ediInfoSent = null then
		tiTrx := self.myTerminal.allTITransactionsByTypeDate.getAtKeyGeq( TRANS_TYPE_INFO_EDI_SENT, null );
		if tiTrx &lt;&gt; null and tiTrx.isKindOf( CM_InfoEDISent ) then
			ediInfoSent := tiTrx.CM_InfoEDISent;
			edition := ediInfoSent.edition;
			if invalid then
				ediInfoSent := null;
			endif;
		endif;
	endif;
	
	completeToDate := self.date;
	
	if ediInfoSent = null or ediInfoSent.dateTime.date &gt; self.date then
		//nothing to do.
		return false;
	endif;
	
	on Exception do null;
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	on Exception do app.handleDeletedObject( exception, tiTrx, invalid );
	
	iter := self.myTerminal.allTITransactionsByTypeDate.createIterator;
	iter.startAtObject( ediInfoSent );
	
	beginTransaction;
	
	while iter.next( tiTrx ) do
		if tiTrx.type &lt;&gt; TRANS_TYPE_INFO_EDI_SENT then
			//wrong trx type, we must be done
			break;
		endif;
		if invalid then
			invalid := false;
			continue;
		endif;
		if tiTrx.dateTime.date &gt; self.date then
			//too new, we must be done
			break;
		endif;
		
		count := count + 1;
		if count mod 50 = 0 then // testing shows we process about 100 per second, so lets break transaction state every 1/2 second or so.
	
			if latestTruncated &lt;&gt; null then
				//record the latest one we updated so we know where to start from next time.
				self.myTerminal.setConfig( LatestTruncatedEDIinfo, latestTruncated );
				completeToDate := latestTruncated.dateTime.Date;
				latestTruncated := null;
			endif;
			commitTransaction;
			
			now := app.actualTimeServer;
			app.sendHeartbeatIfRequired();
			
			beginTransaction;
			
			if ( self.myBGPRequest &lt;&gt; null and self.myBGPRequest.maxDurationMinutes &gt; 0 and now &gt;= self.finishTimeStamp )
			or ( forcedEndTime &lt; now )
			then
				//Either the user has given us a max time, and its done, or we have been running for 20 minutes.
				break;
			endif;
				
		endif;
		
		ediInfoSent := tiTrx.CM_InfoEDISent;
		if ediInfoSent.doXmlInfoDataTruncationForAAT() then
			//we updated it, keep track of the most recent one we have updated
			latestTruncated := ediInfoSent;
		endif;
		
	endwhile;
	
	if latestTruncated &lt;&gt; null then
		//record the latest one we updated so we know where to start from next time.
		self.myTerminal.setConfig( LatestTruncatedEDIinfo, latestTruncated );
		completeToDate := latestTruncated.dateTime.Date;
	endif;
	
	commitTransaction;

	return false;

epilog

	if errCode &gt; 0 or errTxt &lt;&gt; null then
		self.createActivityHistory(app.getErrorString(Database_Purging) &amp; ' ' &amp; app.getErrorString(Truncate_EDIInfo_XML) &amp; " complete up to " &amp; completeToDate.asStringJMT, false, false);
	else
		self.createActivityHistory(app.getErrorString(Database_Purging) &amp; ' ' &amp; app.getErrorString(Truncate_EDIInfo_XML) &amp; " complete up to " &amp; completeToDate.asStringJMT, false, false);
	endif;
	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLatestPortSchemaRelease" id="fef41d59-ea01-42c6-b4d0-6c5d13b4e060">
        <source>findLatestPortSchemaRelease():PortSchemaRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2021	jlgndl1	Initial creation	TFS	50761 

*/

vars

	objArray : ObjectArray;

begin

	create objArray transient;
	PortSchemaRelease.allInstances( objArray, 0, true );
	if objArray = null then
		return null;
	endif;
	return objArray.last.PortSchemaRelease;

epilog

	delete objArray;

end;</source>
        <ReturnType type="PortSchemaRelease"/>
    </JadeMethod>
    <JadeMethod name="getArchivedVoyagesOldThanDate" id="67a7cf25-bcc2-48d1-89c8-4e6cfa3fe3a7">
        <source>getArchivedVoyagesOldThanDate(_allVoyagesToPurge : DynaDictionary input) protected;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars
	iter	: Iterator;
	voyage	: CM_Voyage;
	theDate	: TimeStamp;
begin
	_allVoyagesToPurge.clear();
	theDate := self.date.TimeStamp.cnEcAddDays(1);

	iter := self.myTerminal.allVoyagesArchived.createIterator();
	while iter.next(voyage) do
		if voyage.archivedDT &lt;= theDate then
			_allVoyagesToPurge.add(voyage);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_allVoyagesToPurge" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataOldThanDate" id="f6e58eba-a706-49ac-bfcb-f62f733548ed">
        <source>getEDIDataOldThanDate(_allEDIDataToPurge: DynaDictionary input) protected;
// -------------------------------------------
// Created Apr 2005 by cnwrs1
// -------------------------------------------
// Changed On	By			Reason
// ----------	---------	-----------------------------------------------------
// 28/07/2016	cnwdap1		C3 TFS #2211 - purge Unprocessed EDI files as well as Loaded
vars
	ediData		: CM_EDIData;
	theDate		: TimeStamp;
	objArray	: ObjectArray;
	obj			: Object;
	
begin
	_allEDIDataToPurge.clear();
	theDate := self.date.TimeStamp.cnEcAddDays(1);
	
	create objArray transient;
	CM_EDIData.allInstances(objArray, 0, true);
	
	foreach obj in objArray do
		ediData := obj.CM_EDIData;
		
		if ediData.createdTime &lt;= theDate then
			//if ediData.status = CM_EDIFile.EDI_STATUS_LOADED and //or  //PAR24852 - cnwsh3 2/07/2010 - EDI Data for customs stops etc. // TFS #2211
			if (ediData.status = CM_EDIFile.EDI_STATUS_LOADED or ediData.status = CM_EDIFile.EDI_STATUS_UNPROCESSED) and 				// TFS #2211
			(ediData.isKindOf(CM_EDIDataBOLOutLog)
			or ediData.isKindOf(CM_EDIDataCustomStop)
			or ediData.isKindOf(CM_EDIDataOperatorStop)
			or ediData.isKindOf(CM_EDIDataOutwardRail))
			then
				_allEDIDataToPurge.add(ediData);
			endif;
		endif;
	endforeach;
epilog
	delete objArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_allEDIDataToPurge" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInfoTransactionOldThanDate" id="372ef17e-b8d1-4805-a633-f2224a0f6565">
        <source>getInfoTransactionOldThanDate( _allTransactionsToPurge : DynaDictionary input; _description : String ) protected;
// -------------------------------------------
// Created May 2008 by cnwrs1 par16530
// cnwrl1 09/06/2009 PAR 19328 - change to also match the description
// -------------------------------------------
vars

	infoTransaction: CM_Information;
	theDate: TimeStamp;
	objArray: ObjectArray;
	obj: Object;
begin

	_allTransactionsToPurge.clear();
	theDate := self.date.TimeStamp.cnEcAddDays(1);

	create objArray transient;
	CM_Information.allInstances(objArray,0,true);
	
	if _description = IsYardAllocationInfo then	//29 Nov 2013	NDL	Par 32991
		foreach obj in objArray do
			infoTransaction := obj.CM_Information;
			if infoTransaction.createdTime &lt;= theDate and infoTransaction.isYAPlanInformation then
				_allTransactionsToPurge.add(infoTransaction);
			endif;
		endforeach;
	
	else
		foreach obj in objArray do
			infoTransaction := obj.CM_Information;
	//		if infoTransaction.createdTime &lt;= theDate then	// cnwrl1 09/06/2009 PAR 19328 - what it was
			if infoTransaction.createdTime &lt;= theDate and infoTransaction.description = _description then
				_allTransactionsToPurge.add(infoTransaction);
			endif;
		endforeach;
	
	endif;
epilog
	delete objArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_allTransactionsToPurge" type="DynaDictionary" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
