    <JadeMethod name="addRORORequest" id="d7dc03f1-5bf9-4596-aaa3-a51e55566cb6">
        <updating/>
        <source>addRORORequest(_roroRequest : CM_RORORequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	wleSize : Integer;
	isReefer,
	isDischarge : Boolean;
	isLoad : Boolean;
	theTI : CM_TrackedItem;
	 
begin
	if _roroRequest = null then
		return;
	endif;
	
	if _roroRequest.moveType = NULL_MOVETYPE then
		return;
	endif;
	
	self.allRORORequests.addNoDuplicates(_roroRequest,false);
	
	wleSize := _roroRequest.allWorkListEntries.size;
	
	isDischarge := (_roroRequest.moveType = DISCHARGE_MOVETYPE);
	isLoad := (_roroRequest.moveType = LOAD_MOVETYPE);
	
	theTI := _roroRequest.getTrackedItem();
	if theTI &lt;&gt; null then
		if (theTI.isReefer or theTI.getCoolingType = ContainerWaterCooled)
		and theTI.requiresTemperature
		and not theTI.isChilled then
			isReefer := true;
		endif;
	else
		isReefer := _roroRequest.getAttrPowerRequired();
	endif;
	
//	is40 := _roroRequest.getAttrIs40 or _roroRequest.getAttrIs30() or _roroRequest.getAttrIs53() or _roroRequest.getAttrIs45(); // PAR 16415 CCMS 1029
	is40 := _roroRequest.getAttrIsNOT20(); // PAR 30253
	if isDischarge then
		if self.is40 then
			self.discIMP40 := self.discIMP40 + wleSize;
		else
			self.discIMP20 := self.discIMP20 + wleSize;
		endif;
		
		if _roroRequest.isKindOf(CM_ROROGCRequest) then
			self.discGC:=self.discGC + wleSize;
		endif;
	elseif isLoad then
		if self.is40 then
			self.loadEXP40 := self.loadEXP40 + wleSize;
		else
			self.loadEXP20 := self.loadEXP20 + wleSize;
		endif;
		if _roroRequest.isKindOf(CM_ROROGCRequest) then
			self.loadGC:=self.loadGC + wleSize;
		endif;
	elseif _roroRequest.isSoB then
		if _roroRequest.isDischarge then // DISCHARGE
			if self.is40 then
				self.discSOB40 := self.discSOB40 + wleSize;
			else
				self.discSOB20 := self.discSOB20 + wleSize;
			endif;
		endif;
	elseif _roroRequest.isRehandle then
		if _roroRequest.isDischarge then // DISCHARGE
			if self.is40 then
				self.discDLR40 := self.discDLR40 + wleSize;
			else
	
				self.discDLR20 := self.discDLR20 + wleSize;
			endif;
		else
			if self.is40 then
				self.loadDLR40 := self.loadDLR40 + wleSize;
			else
				self.loadDLR20 := self.loadDLR20 + wleSize;
			endif;
		endif;	
	endif;
	if not (_roroRequest.isSoB and _roroRequest.isLoad) then
		if isReefer then
			if self.is40 then
				self.discREF40 := self.discREF40 + wleSize;
			else
				self.discREF20 := self.discREF20 + wleSize;
			endif;
		endif;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_roroRequest" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="calculateNumberOfLifts" id="aae8d599-2af0-4c5a-9d8d-fd5ec0d4ba28">
        <source>calculateNumberOfLifts() : Real;
// ---------------------------------------------------------------------------
// Created:		29 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	sr : CM_RORORequest;
	vwle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	done, notDone : Real;
begin
	foreach sr in self.allRORORequests discreteLock do
		foreach wle in sr.allWorkListEntries discreteLock do
			wle.CM_VoyageWLE.getLiftTotals(done, notDone);
		endforeach;
	endforeach;
	return done + notDone;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clear" id="3b343b60-6adb-4f6e-82a1-39e282c426bd">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();
	
	self.discDLR20 := null;
	self.discIMP20 := null;
	self.discREF20 := null;
	self.discSOB20 := null;
	

	self.loadDLR20 := null;
	self.loadEXP20 := null;
	self.loadREF20 := null;
	self.loadSOB20 := null;

	self.discDLR40 := null;
	self.discIMP40 := null;
	self.discREF40 := null;
	self.discSOB40 := null;

	
	
	self.allRORORequests.clear;
		

end;</source>
    </JadeMethod>
    <JadeMethod name="getCellularVoyageStructure" id="4d16d21a-0347-4ef8-8873-28e93e6664e6">
        <source>getCellularVoyageStructure(): CM_CellularVoyageStructure;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyage : CM_Voyage;
begin

	if self.myDeck = null then
		return inheritMethod();
	endif;
	
	voyage:=self.myDeck.getVoyage;
	if voyage &lt;&gt; null then
		return voyage.myCellularVoyageStructure;
	endif;
	
epilog

end;</source>
        <ReturnType type="CM_CellularVoyageStructure"/>
    </JadeMethod>
