    <JadeMethod name="createNextPage" id="3fa0cc8c-1aa8-4aad-8d26-f93475e04a48">
        <updating/>
        <source>createNextPage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	nextPage : CMUI_AjmanCashRec;

begin

	//create nextPage transient;
	nextPage := CMUI_AjmanCashRec.createPrintForm;
	nextPage.initiateForm( self.baseLeftOffset, self.baseTopOffset );
	self.myNextPage := nextPage;
	nextPage.myPopulatingObject := self.myPopulatingObject;
	nextPage.myDebtor := self.myDebtor;
	nextPage.pageNo := self.pageNo + 1;
	
	nextPage.lblA.caption := self.lblA.caption;
	nextPage.lblB.caption := self.lblB.caption;	
	nextPage.lblC.caption := self.lblC.caption;	
	nextPage.lblD.caption := self.lblD.caption;
	nextPage.lblE.caption := self.lblE.caption;
	
	if self.myPopulatingObject = null or not self.myPopulatingObject.isKindOf( CM_CashReceipt ) then
		nextPage.lblF.caption := self.lblF.caption;
		nextPage.lblG.caption := self.lblG.caption;
	endif;
	nextPage.lblH.caption := self.lblH.caption;
	nextPage.lblI.caption := self.lblI.caption;
	nextPage.lblJ.caption := self.lblJ.caption;
	nextPage.lblK.caption := self.lblK.caption;
	nextPage.lblL.caption := self.lblL.caption;
	nextPage.lblM.caption := self.lblM.caption;
	nextPage.lblN.caption := self.lblN.caption;
	nextPage.lblO.caption := self.lblO.caption;
	
	self.labelFStringArray.copy( nextPage.labelFStringArray );
	self.labelGStringArray.copy( nextPage.labelGStringArray );
	self.labelFStringArray.copy( nextPage.preProcFArray );
	self.labelGStringArray.copy( nextPage.preProcGArray );
	
	nextPage.setParticularsAndAmountsDetail( true );	// populates 'f' &amp; 'g' for CM_CashReceipt data
	if not nextPage.labelFStringArray.isEmpty then 
		nextPage.createNextPage();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessLabelContents" id="b6278d59-e75d-47ae-994b-ae4f6d5222ef">
        <updating/>
        <source>doProcessLabelContents(_label: CMUI_Label input): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars
	
	invLine : CM_InvoiceLine;
	
	invLineNum : String;
	tiString : String;
	dateStr : String;
	desc : String;
	str : String;
	
	top : Integer;
	lineHeight : Integer;
	
	line1Str : String;
	line2Str : String;
	pos : Integer;
	
	tempStrings : CM_StringDict;

begin

	if _label = self.lblC then	// name and address details;
		if not _label.caption = null then
			//allow test line up data to work.
			return inheritMethod(_label);
		endif;
		
		create tempStrings transient;
		top := ( _label.top + 1 ).Integer;
		lineHeight := _label.getTextHeight( "X" );
		
		if self.myDebtor &lt;&gt; null then
			self.createTempSubLabelText( _label, self.myDebtor.name, top, tempStrings, 0 );
			foreach str in self.myDebtor.billingAddress do
				if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
					self.createTempSubLabelText( _label, str, top, tempStrings, 0 );
				else
					// truncation of address details is probably ok. and shouldn't ever happen.
					break;
				endif;
			endforeach;
			if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
				// if it doesn't fit too bad..
				self.createTempSubLabelText( _label, self.myDebtor.decfinName.String, top, tempStrings, 0 );
			endif;
			
			self.addMultiplePrintLines( tempStrings );
			
		endif;
		return true;
	
	//31 Jan 2014	NDL	Par 33181 then	//28 Jan 2014	NDL	Par 33181
	elseif ( _label = self.lblF or  _label = self.lblG )
		and ( self.myPopulatingObject &lt;&gt; null and self.myPopulatingObject.isKindOf( CM_CashReceipt ) )
		then
		if _label = self.lblF then
			//handles G at the same time
			self.setParticularsAndAmountsDetail( false );
		endif;
		return true;
		
	elseif _label = self.lblH then
	
		pos := _label.caption.pos(CrLf,1);
		if pos &lt; 1 then
			return inheritMethod(_label);
		endif;
		
		line1Str := _label.caption[ 1 : pos - 1 ];
		line2Str := _label.caption[pos + 2 : end ];
		
		create tempStrings transient;
		top := _label.top.Integer;
		
		self.createTempSubLabelText( _label, line1Str, top, tempStrings, 0 );
		self.addMultiplePrintLines( tempStrings );
		
		lineHeight := getCramTextLineHeight( _label );
		top := ( _label.top + lineHeight ).Integer;
		return self.doProcessLabelContentsTooLong( _label, line2Str, top );
		
	else
		return inheritMethod(_label);
		
	endif;

epilog

	if tempStrings &lt;&gt; null then
		if not tempStrings.isEmpty then
			tempStrings.purge();
		endif;
		delete tempStrings;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCramTextLineHeight" id="cddb8ae6-a243-434a-a6fc-a496d443a586">
        <source>getCramTextLineHeight(_label: CMUI_Label): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	textPrintHeight : Integer;

begin

	if _label = self.lblH then
		return _label.getTextHeight( "X" ) - 5;
	endif;
	return inheritMethod(_label);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPageHeight" id="21c96cdf-0cd4-4bce-97c4-95135e76814e">
        <source>getPageHeight(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

begin

	if app.isDevelopmentSystem and app.printer.getPrinterName[1:5].toUpper &lt;&gt; "EPSON" then
		return inheritMethod();
	endif;

	return 2790;	//	279.0 mm

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="c1b4b777-dc5e-47c1-a7a1-14e3004aa26a">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

begin

	self.allLabelsArray.add( self.lblA );
	self.allLabelsArray.add( self.lblB );
	self.allLabelsArray.add( self.lblC );
	self.allLabelsArray.add( self.lblD );
	self.allLabelsArray.add( self.lblE );
	self.allLabelsArray.add( self.lblF );
	self.allLabelsArray.add( self.lblG );
	self.allLabelsArray.add( self.lblH );
	self.allLabelsArray.add( self.lblI );
	self.allLabelsArray.add( self.lblJ );
	self.allLabelsArray.add( self.lblK );
	self.allLabelsArray.add( self.lblL );
	self.allLabelsArray.add( self.lblM );
	self.allLabelsArray.add( self.lblN );
	self.allLabelsArray.add( self.lblO );
	
	self.lblA.alignment := Label.Alignment_Left_Top;
	self.lblB.alignment := Label.Alignment_Left_Top;
	self.lblC.alignment := Label.Alignment_Left_Top;
	self.lblD.alignment := Label.Alignment_Left_Top;
	self.lblE.alignment := Label.Alignment_Left_Top;
	self.lblF.alignment := Label.Alignment_Left_Top;
	self.lblG.alignment := Label.Alignment_Right_Top;
	self.lblH.alignment := Label.Alignment_Left_Top;
	self.lblI.alignment := Label.Alignment_Right_Top;
	self.lblJ.alignment := Label.Alignment_Center_Top;
	self.lblK.alignment := Label.Alignment_Center_Top;
	self.lblL.alignment := Label.Alignment_Center_Top;
	self.lblM.alignment := Label.Alignment_Center_Top;
	self.lblN.alignment := Label.Alignment_Center_Top;
	self.lblO.alignment := Label.Alignment_Left_Top;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateLineUp" id="af5d8fcd-c457-4b5e-b7f8-200641c6fabc">
        <updating/>
        <source>populateLineUp():String protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

	xxString : String;
	repDetails : String;

begin

	repDetails := inheritMethod();
	
	xxString := self.lblO.caption;
	
	self.lblO.caption := "XX  '" &amp; repDetails &amp; "'  " &amp; xxString;
	
	return repDetails;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionLabels" id="2bd43667-b886-46ed-9861-79a39e2c705f">
        <source>repositionLabels() protected;
