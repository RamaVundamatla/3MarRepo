end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombobox" id="eb77c9df-420b-433b-8424-2389e9e70124">
        <source>loadCombobox(pComboboxObj:CnEcComboBox io; pAllAddressesObj:CnEcDualStringArray) protected;
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Populates the specified combobox with the names and email addresses
//				in the supplied two-dimensional array.
//
// Parameters:	pComboboxObj - The combobox to populate.
//				pAllAddressesObj - A two-dimensional string array containing the person
//					names and their corresponding email addresses.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	addresseeName	: String;
	emailAddress	: String;
	addressIndex	: Integer;
	arraySize		: Integer;
	arrayIndex		: Integer;
	
begin
	foreach addresseeName in pAllAddressesObj do
		pComboboxObj.addItem(addresseeName);
	endforeach;
	
	arraySize	:=	pAllAddressesObj.size();
	
	foreach arrayIndex in 1 to arraySize do
		pAllAddressesObj.cnEcGet(addresseeName, emailAddress, arrayIndex);
		addressIndex	:=	pComboboxObj.findStringExact(1, addresseeName);
		pComboboxObj.setItemValueString(addressIndex, emailAddress);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pComboboxObj" type="CnEcComboBox" usage="io"/>
        <Parameter name="pAllAddressesObj" type="CnEcDualStringArray"/>
    </JadeMethod>
    <JadeMethod name="loadEmailAddresses" id="c720b4e0-74e6-4988-87d8-28ba229801e7">
        <updating/>
        <source>loadEmailAddresses() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 August 2000 by cnwdad1
//
// Purpose:		Fetches a list of email addresses from the LDAP server for "CCO".
//
// Parameters:	pEmailArray (StringArray) - A string array of email addresses.
//
// Returns:		The I/O array of email addresses.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	ldapConnectObj	: CnLdapConnection;
	ldapEntryObj	: CnLdapEntry;
	ldapSearchObj	: CnLdapSearch;
	replyValue		: Integer;
	surname			: String;
	givenName		: String;
	mailAddress		: String;
	allAddressesObj	: CnEcDualStringArray;
	
begin
	on CnLdapException do self.xHandlerLdap(exception);
	
	// Create the LDAP object.
	
	create ldapConnectObj transient;
	
	// Open an anonymous (unauthenticated) connection to the LDAP server.
	
	ldapConnectObj.cnOpen(self.SERVER_LDAP, null, null);
	
	// Now do the search.
	
	create ldapSearchObj transient;

	// Specify the mail attributes that we just want.
	
	ldapConnectObj.cnSetSearchAttribute(self.LDAP_SURNAME);		// Want the surname.
	ldapConnectObj.cnSetSearchAttribute(self.LDAP_GIVENNAME);		// Want the given name.
	ldapConnectObj.cnSetSearchAttribute(self.LDAP_MAIL);			// Want the email address.
	
	// Look for all email addresses, filtering out all but our people.
	
	ldapConnectObj.cnSearchAsync(self.LDAP_BASE, self.LDAP_FILTER, ldapSearchObj);
	
	// Poll to see if an entry is available.
	
	create allAddressesObj transient;
	
	while true do
		replyValue := ldapConnectObj.cnPollSearchAsync(ldapSearchObj);
		
		if replyValue = ldapConnectObj.ENTRY_AVAILABLE then
			// Get latest entry and add it to the array of email addresses.
			ldapSearchObj.cnGetNextEntry(ldapEntryObj);
			surname		:=	ldapEntryObj.cnGetAttributeValue(self.LDAP_SURNAME).String;
			givenName	:=	ldapEntryObj.cnGetAttributeValue(self.LDAP_GIVENNAME).String;
			mailAddress	:=	ldapEntryObj.cnGetAttributeValue(self.LDAP_MAIL).String;
			
			allAddressesObj.cnEcAdd(givenName &amp; " " &amp; surname, mailAddress);
		elseif replyValue = ldapConnectObj.NO_MORE_ENTRIES then
			// No more results: close the connection.
			break;
		endif;	
	endwhile;
	
	self.loadCombobox(cmbAddressFrom, allAddressesObj);
	self.loadCombobox(cmbAddressTo, allAddressesObj);
	
	// Close the connection to the LDAP server.
	
	ldapConnectObj.cnClose();
epilog
	delete ldapSearchObj;
	delete ldapConnectObj;
	delete allAddressesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
