    <JadeMethod name="btnClearToDo_click" id="8fc13713-a562-4643-97b7-81e958e1d363">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearToDo_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
begin

	self.doToDoClear();
	
	str := 'Cleared';

	if self.txtTDEnquiry.text = null then
		self.txtTDEnquiry.text := str;		
	else
		self.txtTDEnquiry.text := self.txtTDEnquiry.text &amp; CrLf &amp; str;	
	endif;

	self.lblShowQtyTD.caption := (self.lblShowQtyTD.caption.Integer+1).String;			

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
