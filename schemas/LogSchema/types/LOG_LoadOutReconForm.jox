    <JadeMethod name="selectDeselectAll" id="84c74379-eb4e-4fa0-83b3-1d1d51bc5673">
        <source>selectDeselectAll(_all : Boolean);
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	row	: Integer;
	id	: String;
begin

	foreach row in 2 to self.tblLogError.rows do
		self.tblLogError.accessCell(row, 1).text := _all.Integer.String;
	endforeach;	

	if self.optEdit.value then
		self.tblData.setValueByName(ETRow_LogId, id);
	endif;
	
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectTblLogErrorRow" id="62d76b31-6c9e-4572-8456-10385de8d363">
        <source>selectTblLogErrorRow();
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.tblLogError.row &lt;= self.tblLogError.fixedRows then
		return;
	endif;
	if self.tblLogError.accessCell(self.tblLogError.row, 1).text = true.Integer.String then
		if self.optEdit.value then
			self.tblData.setValueByName(ETRow_LogId, self.tblLogError.accessCell(self.tblLogError.row, 2).text);
		endif;
	endif;

end;</source>
    </JadeMethod>
