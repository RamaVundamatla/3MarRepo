    <JadeMethod name="convertBaseToTarget" id="89f01b3c-a8df-4585-9cd1-ed3991b64414">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;

begin
	if pUnitTo = self.DENIER then
		convertedMeasure	:=	pMeasure * 9000000;

	elseif pUnitTo = self.DREX then
		convertedMeasure	:=	pMeasure * 10000000;
	
	elseif pUnitTo = self.GRAMS_PER_CENTIMETRE then
		convertedMeasure	:=	pMeasure * 10;
	
	elseif pUnitTo = self.GRAMS_PER_KILOMETRE then
		convertedMeasure	:=	pMeasure * 1000000;
	
	elseif pUnitTo = self.GRAMS_PER_METRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.GRAMS_PER_MILLIMETRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.KILOGRAMS_PER_KILOMETRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.KILOGRAMS_PER_METRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_CENTIMETRE then
		convertedMeasure	:=	pMeasure * 10000;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_MILLIMETRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.OUNCES_PER_FOOT then
		convertedMeasure	:=	pMeasure / 0.09301;
	
	elseif pUnitTo = self.OUNCES_PER_INCH then
		convertedMeasure	:=	pMeasure / 1.116125;
	
	elseif pUnitTo = self.POUNDS_PER_FOOT then
		convertedMeasure	:=	pMeasure / 1.488164;
	
	elseif pUnitTo = self.POUNDS_PER_INCH then
		convertedMeasure	:=	pMeasure / 17.858;
	
	elseif pUnitTo = self.POUNDS_PER_MILE then
		convertedMeasure	:=	pMeasure / 0.000281849;
	
	elseif pUnitTo = self.POUNDS_PER_YARD then
		convertedMeasure	:=	pMeasure / 0.496055;
	
	elseif pUnitTo = self.TEX then
		convertedMeasure	:=	pMeasure * 1000000;
	
	elseif pUnitTo = self.TONNES_PER_KILOMETRE then
		convertedMeasure	:=	pMeasure / 1;
	
	elseif pUnitTo = self.TONS_UK_PER_MILE then
		convertedMeasure	:=	pMeasure / 0.631342;
	
	elseif pUnitTo = self.TONS_US_PER_MILE then
		convertedMeasure	:=	pMeasure / 0.563698;
	
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Line Density to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="df6f5261-111a-4da2-a29e-e61b36b2ced5">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.DENIER then
		convertedMeasure	:=	self.measure / 9000000;

	elseif pUnitFrom = self.DREX then
		convertedMeasure	:=	self.measure / 10000000;
	
	elseif pUnitFrom = self.GRAMS_PER_CENTIMETRE then
		convertedMeasure	:=	self.measure / 10;
	
	elseif pUnitFrom = self.GRAMS_PER_KILOMETRE then
		convertedMeasure	:=	self.measure / 1000000;
	
	elseif pUnitFrom = self.GRAMS_PER_METRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.GRAMS_PER_MILLIMETRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_KILOMETRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_METRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_CENTIMETRE then
		convertedMeasure	:=	self.measure / 10000;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_MILLIMETRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.OUNCES_PER_FOOT then
		convertedMeasure	:=	self.measure * 0.09301;
	
	elseif pUnitFrom = self.OUNCES_PER_INCH then
		convertedMeasure	:=	self.measure * 1.116125;
	
	elseif pUnitFrom = self.POUNDS_PER_FOOT then
		convertedMeasure	:=	self.measure * 1.488164;
	
	elseif pUnitFrom = self.POUNDS_PER_INCH then
		convertedMeasure	:=	self.measure * 17.858;
	
	elseif pUnitFrom = self.POUNDS_PER_MILE then
		convertedMeasure	:=	self.measure * 0.000281849;
	
	elseif pUnitFrom = self.POUNDS_PER_YARD then
		convertedMeasure	:=	self.measure * 0.496055;
	
	elseif pUnitFrom = self.TEX then
		convertedMeasure	:=	self.measure / 1000000;
	
	elseif pUnitFrom = self.TONNES_PER_KILOMETRE then
		convertedMeasure	:=	self.measure * 1;
	
	elseif pUnitFrom = self.TONS_UK_PER_MILE then
		convertedMeasure	:=	self.measure * 0.631342;
	
	elseif pUnitFrom = self.TONS_US_PER_MILE then
		convertedMeasure	:=	self.measure * 0.563698;
	
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Line Density to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
