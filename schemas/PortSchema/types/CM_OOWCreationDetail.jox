    <JadeMethod name="makeSeperateJobFor20And40ByBay" id="6c444ac9-6461-413d-9d94-8ba889dcf57b">
        <source>makeSeperateJobFor20And40ByBay(_bay : CM_BayVoyage) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2014	cnwmc5	Initial creation	PAR 34455

*/

vars
	
begin

	if self.ordinalDeck = DeckOnDeck then
		if not _bay.isTwinLiftOD then
			return true;
		endif;
	elseif self.ordinalDeck = DeckUnderDeck then
		if not _bay.isTwinLiftUD then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e95fb05b-fbc2-4f93-b8a9-37e314a6e630">
        <updating/>
        <source>setForCreate(_pxyMe: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	props : PropertyNDict;
	attrib : Property;
begin

	inheritMethod(_pxyMe);

	props := CM_OOWCreationDetail.getProperties();
	
	// ## this should set all the attributes on this class
	foreach attrib in props do
		self.setPropertyValue(attrib.name,_pxyMe.getPropertyValue(attrib.name));
	endforeach;
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForMerge" id="ae859892-cfec-4772-8ebe-14277bab0a33">
        <updating/>
        <source>setForMerge(_twinMe: SelfType input) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	props : PropertyNDict;
	attrib : Property;
	amt : Integer;
	twinMe: SelfType;
	type : Type;
	slotReq : CM_SlotRequest;
begin


	props := CM_OOWCreationDetail.getProperties();
	
	// ## this should set all the attributes on this class
	foreach attrib in props do
	//	if attrib.name = CM_OOWCreationDetail::twinLift.name then
	//		continue;
	//	endif;
		
		//28 Jan 2011	NDL	Par 26317
		type := attrib.type; 
		if type = Real or type = Integer then
		
			amt := self.getPropertyValue(attrib.name).Integer;
			amt := amt + _twinMe.getPropertyValue(attrib.name).Integer;
			self.setPropertyValue(attrib.name,amt);
		
		elseif attrib.name = CM_OOWCreationDetail::allSlotRequests.name then
		
			foreach slotReq in _twinMe.allSlotRequests do
				self.allSlotRequests.addNoDuplicates(slotReq,false);
			endforeach;
		
		endif;
		
	endforeach;
	
	self.orderType := 1;
	self.mySplitSelf := null;
	
	twinMe := _twinMe;
	delete twinMe;
end;</source>
        <Parameter name="_twinMe" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="99f777a4-6f33-4e2b-b088-da4839f10154">
        <updating/>
        <source>setForUpdate(_pxyMe: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	props : PropertyNDict;
	attrib : Property;
begin

	inheritMethod(_pxyMe);

	props := CM_OOWCreationDetail.getProperties();
	
	// ## this should set all the attributes on this class
	foreach attrib in props do
		self.setPropertyValue(attrib.name,_pxyMe.getPropertyValue(attrib.name));
	endforeach;
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromSlotRequest" id="d93ac82c-f54f-47e9-a59f-21c246524967">
        <updating/>
        <source>setFromSlotRequest(_sr : CM_SlotRequest; _get40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    28MAY2008     PAR 16415 CCMS 1029 30,45,53s
//		 DMP	15122009	  CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// ---------------------------------------------------------------------------
vars
	wleSize : Integer;
	theTI : CM_TrackedItem;
	theCon : CM_Container;
	isDischarge, isLoad : Boolean;
	is40, isReefer, isTranship : Boolean;
begin
	if _sr = null then
		return;
	endif;
	
	if _sr.unavailable then
		return;
	endif;
	
	if _sr.mySlotDefinition &lt;&gt; null and _sr.mySlotDefinition.unavailable then
		return;
	endif;
	if _sr.getAttrIsBackend() then // PAR 21746
	// PAR 21746 if _sr.fortyBack or _sr.isBackend then // PAR 16415 CCMS 1029
		return;
	endif;

	if _sr.moveType = NULL_MOVETYPE then
		return;
	endif;
	
	self.allSlotRequests.addNoDuplicates(_sr, false);
	
	wleSize := _sr.allWorkListEntries.size;
	if wleSize = 0 then
		wleSize := 1;
	endif;

	self.ordinalDeck := _sr.ordinalDeck;
	isDischarge := (_sr.moveType = DISCHARGE_MOVETYPE);
	isLoad := (_sr.moveType = LOAD_MOVETYPE);
	
	theTI := _sr.getTrackedItem();
	if theTI &lt;&gt; null then
		isTranship := theTI.isTranshipItem;
		if theTI.isKindOf(CM_Container) then
			theCon := theTI.CM_Container;
			if theCon.isFull 
			and (theCon.isReefer or theCon.isPortHole or theCon.isIntegral or theCon.getCoolingType = ContainerWaterCooled)
			and theCon.requiresTemperature 
			and not theCon.isChilled then
				isReefer := true;
			endif;
		elseif (theTI.isReefer or theTI.getCoolingType = ContainerWaterCooled)
		and theTI.requiresTemperature
		and not theTI.isChilled then
			isReefer := true;
		endif;

	else
		isReefer := _sr.getAttrPowerRequired();
	endif;	
	
	is40 := _sr.getAttrIs40() or _sr.getAttrIs30() or _sr.getAttrIs53() or _sr.getAttrIs45(); // PAR 16415 CCMS 1029
	
	if isDischarge then
		if is40 then
			if _get40 then
				self.discIMP40 := self.discIMP40 + wleSize;
			endif;
		else
			if not _get40 then
				self.discIMP20 := self.discIMP20 + wleSize;
			endif;
		endif;
		if isTranship then
			if is40 then
				if _get40 then
					self.discTSH40 := self.discTSH40 + wleSize;
				endif;
			else
				if not _get40 then
					self.discTSH20 := self.discTSH20 + wleSize;
				endif;
			endif;
		endif;

	elseif _sr.moveType = LOAD_MOVETYPE then
		if is40 then
			if _get40 then
				self.loadEXP40 := self.loadEXP40 + wleSize;
			endif;
		else
			if not _get40 then
				self.loadEXP20 := self.loadEXP20 + wleSize;
			endif;
		endif;
		if isTranship then
			if is40 then
				if _get40 then
					self.loadTSH40 := self.loadTSH40 + wleSize;
				endif;
			else
				if not _get40 then
					self.loadTSH20 := self.loadTSH20 + wleSize;
				endif;
			endif;
		endif;
	elseif _sr.isSOB then
		if _sr.isDischarge then // DISCHARGE
			if is40 then
				if _get40 then
					self.discSOB40 := self.discSOB40 + wleSize;
				endif;
			else
				if not _get40 then
					self.discSOB20 := self.discSOB20 + wleSize;
				endif;
			endif;
		endif;
	elseif _sr.isRehandle then
		if _sr.isDischarge then // DISCHARGE
			if is40 then
				if _get40 then
					self.discDLR40 := self.discDLR40 + wleSize;
				endif;
			else
				if not _get40 then
					self.discDLR20 := self.discDLR20 + wleSize;
				endif;
			endif;
		else
			if is40 then
				if _get40 then
					self.loadDLR40 := self.loadDLR40 + wleSize;
				endif;
			else
				if not _get40 then
					self.loadDLR20 := self.loadDLR20 + wleSize;
				endif;
			endif;
		endif;	
	endif;
	if not (_sr.isSOB and _sr.isLoad) then
		if isReefer then
			if is40 then
				if _get40 then
					self.discREF40 := self.discREF40 + wleSize;
				endif;
			else
				if not _get40 then
					self.discREF20 := self.discREF20 + wleSize;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <Parameter name="_get40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setJobs" id="1edd2ab3-4f98-4dcc-87d8-138d39df02b8">
        <updating/>
        <source>setJobs() updating;
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aReq : CM_SlotRequest;
	aWLE : CM_WorkListEntry;
	done, notDone : Real;
begin
	self.allJobs.clear;
	foreach aReq in self.allSlotRequests discreteLock do
		if aReq.myJob = null then // PAR 15565
			continue;
		endif;
		self.allJobs.addNoDuplicates(aReq.myJob.CM_VoyageJob, false);
		foreach aWLE in aReq.allWorkListEntries discreteLock do
			aWLE.CM_VoyageWLE.getLiftTotals(done, notDone);
		endforeach;
	endforeach;
	
	self.numberOfLifts := (done + notDone);
end;</source>
    </JadeMethod>
    <JadeMethod name="setNumLifts" id="ac99bf14-1df7-4f5a-a658-48f6f6adad55">
        <updating/>
        <source>setNumLifts(_num : Real) updating;
// ---------------------------------------------------------------------------
// Created:		29 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.numberOfLifts := _num;
end;</source>
        <Parameter name="_num" type="Real"/>
    </JadeMethod>
