    <JadeMethod name="validateForUpdate" id="d1d9222f-f626-4397-a449-c37311369392">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ID', ETRow_Id, null);
		app.raiseCMException(Input_required_field_Id, ETRow_Id, null); // cnwdb2	PAR 35364
	endif;
	
	if self.terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
	endif;

end;</source>
