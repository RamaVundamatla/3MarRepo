    <JadeMethod name="setControlsForAddEdit" id="d2b475ce-0e36-4928-9263-4ff7e90bdbd4">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();	
		theForm.mulSelect1.setSelected(null);		
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.	
		theForm.fldInput.initSheetBackColors();						
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Stevedore);
		// cannot update code		

		
	endif;
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);//04.Mar.24 navsp1 TFS 57177
	self.enableMulSelect1Contents();


end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="81d1fd46-307d-45be-b725-3e15717e6aaf">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.showRowByName(ETRow_NotAvailableForEntry, false);				  

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="7aaf0952-ec6c-4246-9f80-36aa374df1a2">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
begin
  
 	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_StevedoreTbl);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_StevedoreMaint);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5b8623e7-8fb4-40a9-a6f0-0fa4e0e96d3a">
        <updating/>
        <source>showThumbnail(pStevedore : CM_Stevedore) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars

	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pStevedore.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pStevedore.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry,pStevedore.notAvailableForEntry);
	if pStevedore.myDebtor &lt;&gt; null then												// TFS 44554
		theForm.tblInput1.setValueByName(ETRow_Debtor, pStevedore.myDebtor.name);	// TFS 44554
		theForm.tblInput1.setValueByName(ETRow_FinancialId, pStevedore.myDebtor.code); //04.Mar.24 navsp1 TFS 57177
	endif;																			// TFS 44554
	theForm.cmbDebtor.setObject(pStevedore.myDebtor);								// TFS 44554
	theForm.mulSelect1.setSelected(pStevedore.allContacts);		
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pStevedore" type="CM_Stevedore"/>
    </JadeMethod>
</Class>
