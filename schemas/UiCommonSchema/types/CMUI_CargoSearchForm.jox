        <updating/>
        <source>mnuEnquire_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwrd1	Initial creation

*/

vars

begin

	if menuItem.userObject = null then
		return;
	endif;
	
	if not menuItem.userObject.isKindOf(CM_DataTable) then
		return;
	endif;
	
	self.doMnuEnquire( menuItem.userObject.CM_DataTable );
	
epilog

end;</source>
