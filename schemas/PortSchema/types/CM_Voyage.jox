    <JadeMethod name="getMaxCellsTiers" id="9fa3e0a8-5660-4e6c-852a-bfc400528e46">
        <source>getMaxCellsTiers(_cells, _tiers : Integer io; _bays: CM_BayVoyageByOrdinalBayDict; _onDeck, _underDeck: Boolean);
/*
Purpose:	PAR 37240		
Date		Who		Reason
11 December 2015	cnwab1	Initial creation
30/11/2017	MAP		TFS7494
*/

vars
	bay : CM_BayVoyage;
//	cells, tiers : Integer;
begin

	foreach bay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do // where _bays.includes(bay) do
			_cells := _cells.max(bay.getTotalCells());
 			_tiers := _tiers.max(bay.getTotalTiers(_onDeck, _underDeck));
 
	endforeach;

epilog

end;</source>
        <Parameter name="_cells" type="Integer" usage="io"/>
        <Parameter name="_tiers" type="Integer" usage="io"/>
        <Parameter name="_bays" type="CM_BayVoyageByOrdinalBayDict"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
