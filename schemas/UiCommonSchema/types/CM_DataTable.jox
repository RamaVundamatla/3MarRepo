    </JadeMethod>
    <JadeMethod name="setMaxSortColumns" id="58a91bf2-5134-4693-a0f0-140d34833f1e">
        <updating/>
        <source>setMaxSortColumns(_maxSort : Integer) updating, protected;
//--------------------------------------------------
// Created:	12 September 2005 By: cnwgd1
//--------------------------------------------------
// 14/10/2009	cnwcs5	par 21171 - sorting issues
constants
	// dynaDict key limit is 512 characters
	// Key length is 30 (30X15=450)
	Limit = 15;
vars

begin

	if _maxSort &lt;= Limit then
		if _maxSort &gt; 0 then
			self.maxSortColumns := _maxSort;
		else
			// Jade standard
			self.maxSortColumns := self.MaxJadeSortColumns;	// par 21171
		endif;
	else
		// dynaDict key Limit is 512 characters
		self.maxSortColumns := Limit;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_maxSort" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="f7c43ec1-e7f4-4109-97cb-fcc3aee0cb4f">
        <updating/>
        <source>setMyDataClass(_class : Class) updating;
//--------------------------------------------------------------
//Created: 12 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.myDataClass := _class;
	
	self.myDynaDict.setMembership(self.myDataClass);
	
end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setMyEntTableDef" id="98a5c785-bcd6-4383-aa99-3be4efdc4242">
        <updating/>
        <source>setMyEntTableDef(_entTableDef : EntTableDef) updating;
//--------------------------------------------------
// Created:	20 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myEntTableDef := _entTableDef;
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setMyEntTableView" id="c2c7c162-d274-41ee-be1e-03fdd1fd5b3a">
        <updating/>
        <source>setMyEntTableView(_entTableView : EntTableView) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.myEntTableView := _entTableView;
	if self.myEntTableView &lt;&gt; null then
		
		self.allTblDataEntRows.clear;
		self.myEntTableView.allEntTableRows.copy(self.allTblDataEntRows);
	endif;
epilog

end;</source>
        <Parameter name="_entTableView" type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="setReadOnlyEntRows" id="3313d56a-f28a-4016-afaf-0ba8e96b4603">
        <updating/>
        <source>setReadOnlyEntRows() updating;
/*

Purpose:			Ensure non-default measurement columns not in EntDef have 'None' input type

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2019	jlgsl4	TFS 45974 - JMT - non-default measurement fields shouldn't be editable
*/

vars
	entTableRow : EntTableRow;
	measure	: CM_MeasurementType;
	rowName,
	measureType : String;	
begin
	foreach entTableRow in self.allTblDataEntRows where entTableRow.allEntTableDefs.isEmpty do
		entTableRow.name.getRowNameMeasureType(rowName, measureType);
		measure := app.myRoot.allMeasurementTypesByShortName[measureType];
		if not measure.isDefault then
			entTableRow.setInputType(Table.InputType_None);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowColorForPagination" id="c7acbaaf-cee8-4071-ad74-aa46153aadc7">
        <updating/>
        <source>setRowColorForPagination(_rowId: Integer; _form : CM_BaseForm) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"

*/

vars
	tblData	: CM_DataTable;
	accRow,
	color	: Integer;
begin
	if _form = null or _rowId &lt;= fixedRows or _rowId &gt; rows then
		return;
	endif;

	tblData := self;
	accRow := self.row;
	if _rowId - 1 &gt; self.fixedRows then
		color := self.accessRow(_rowId - 1).backColor;
	elseif _rowId + 1 &lt;= self.rows then
		color := self.accessRow(_rowId + 1).backColor;
	else
		color := _form.colorRow2;
	endif;

	if color = _form.colorRow1 then
		tblData.accessRow(_rowId).backColor := _form.colorRow2;
	else
		tblData.accessRow(_rowId).backColor := _form.colorRow1;
	endif;

	tblData.accessRow(accRow);
epilog

end;</source>
        <Parameter name="_rowId" type="Integer"/>
        <Parameter name="_form" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setSelectionStyle" id="066a38e7-8ae7-4861-88dc-44b1a599b6f7">
        <updating/>
        <source>setSelectionStyle(_rowPointer : Integer; _colPointer : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2008 by cnwdad1
//
// Purpose:		Sets the selection style of the specified table cell to "select all".
//
// Parameters:	_rowPointer - The row of the cell.
//				_colPointer - The column of the cell.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj 	: Control;
	
begin
	if (not self.cnEcIsValidRow(_rowPointer)) or (not self.cnEcIsValidColumn(_colPointer)) then
		return;
	endif;

	controlObj	:=	self.accessCell(_rowPointer, _colPointer).cellControl;
	
	if controlObj &lt;&gt; null then
		if TextBox.hasInstance(controlObj) then
			controlObj.TextBox.selectionStyle	:=	TextBox.SelectionStyle_SelectAll;
		elseif JadeEditMask.hasInstance(controlObj) then
		   	controlObj.JadeEditMask.selectionStyle	:=	JadeEditMask.SelectionStyle_Select;
		endif;
	endif;
end;</source>
        <Parameter name="_rowPointer" type="Integer"/>
        <Parameter name="_colPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSortColumnTableObjects" id="0394c8ba-3ae4-4b5c-aa36-8d46aa40fb32">
        <updating/>
        <source>setSortColumnTableObjects()updating;
//--------------------------------------------------
// Created:	16 September 2005 By: cnwgd1
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
//--------------------------------------------------
vars
	numRows,
	cnt	: Integer;
	obj : Object;
	tmpDynaDict : CM_ExtKeyDynaDictionary;
	invalidObject : Boolean;
begin

	tmpDynaDict := self.allTableObjects;
	
	if tmpDynaDict.noKeys() then
		// defintion incomplete
		//self.resort();				//13.03.2025 navnk30 JIRA 34245
		if self.isPaginated() then		//13.03.2025 navnk30 JIRA 34245
			self.resortForPagination(null);
		else
			self.resort;
		endif;
		return;
	else
		tmpDynaDict.clear();
	endif;
	
	// 28 Jan 2011	NDL	Par 26314 - implies it is possible for an object to be deleted during the 'addObject'
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	
	// populate the dynaDict with the tables item objects
	numRows := self.rows;
	cnt := 1;
	while cnt &lt;= numRows do

		obj := self.accessRow(cnt).itemObject;
		
		if CM_Object.hasInstance(obj) then
			tmpDynaDict.addObject(obj.CM_Object);
		endif;
		cnt := cnt+1;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSortColumns" id="504155bf-0253-48f3-a76f-a3ada19b44aa">
        <updating/>
        <source>setSortColumns() updating, protected;
//--------------------------------------------------------------
//Created: November 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	// If there are no sort columns then sort by the first one.
	if self.allTblDataSortColumns.isEmpty and (not self.allTblDataEntRows.isEmpty) then
		self.zAddSortColumn(self.allTblDataEntRows.first.name, false);
	endif;
	
	self.setSortColumnsForMaxNumCols();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSortColumnsForMaxNumCols" id="6bed114f-97ff-482b-bdfe-11f1ec43e876">
        <updating/>
        <source>setSortColumnsForMaxNumCols()updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
// 15/10/2009	cnwcs5	par 21171 - sorting issues
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
vars
	idx,
	tmpCol,
	numSortCols		: Integer;
	rowName			: String;
	descend			: Boolean;
	entRow			: EntTableRow;
begin
	
	if 	self.disallowColumnSorter then
		return;
	endif;
	
	numSortCols := self.allTblDataSortColumns.size;
	if numSortCols &gt; self.maxSortColumns then
		numSortCols := self.maxSortColumns;
	endif;
	
	if self.columns &gt; 0 and self.fixedRows &gt; 0 then
		tmpCol := self.sortColumn[1];
		if tmpCol &gt; 0 and tmpCol &lt;= self.columns then
			self.accessCell(self.fixedRows, tmpCol).fontBold := false;
		endif;
	endif;

	if numSortCols &gt; self.MaxJadeSortColumns then	// par 21171
		self.clearSort();
		// use dynaDict to sort the table
		// add the membership keys
		if not self.addTableObjectsMemberKeys() then
			return;
		endif;
		// populate the dynaDict with the tables item objects
		self.setSortColumnTableObjects();
	else		
		// Jade can only sort upto 6 columns
		idx := 1;
		while idx &lt;= numSortCols do

			if idx &gt; self.MaxJadeSortColumns then	// par 21171
				// Jade can only sort up to 6 columns
				break;
			endif;
						
			tmpCol := 0;
			rowName := self.allTblDataSortColumns[idx];
			descend := self.allTblDataSortDescending[idx];
			entRow := self.getEntRowColumnByRowName(rowName, tmpCol);

			if entRow &lt;&gt; null then
				// valid row, set sort order					
				self.sortColumn[idx] := tmpCol;    
				self.sortAsc[idx] := (not descend);
				self.sortCased[idx]	:= false;
				self.sortType[idx] := self.convertInputTypeToSortType(entRow.inputType);
				
			endif;
		
			idx := idx + 1;
			
		endwhile;

		if self.isPaginated() then		//13.03.2025 navnk30 JIRA 34245
			self.resortForPagination(null);
		else
			self.resort;
		endif;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSortOrderFormXMLStr" id="f8b007b1-3a46-4f07-9279-4cac9499b90a">
        <updating/>
        <source>setSortOrderFormXMLStr(_xmlStr : String)updating, protected;
//--------------------------------------------------
// Created:	28 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	col,
	maxCol,
	pos : Integer;
	ascend : Boolean;
	tmpStr,
	colName,
	tmpSortOrder : String;
	tmpSortType : Integer;
	tmpArray : StringArray;	
begin

	if _xmlStr = null then
		return;
	endif;
	maxCol := self.columns;

	if maxCol = 0 then
		return;
	endif;
	
	pos := 1;
	tmpSortOrder := _xmlStr.cnEcGetNextTagValueOfName(XMLTag_SortOrder, pos);

	if tmpSortOrder = null then
		return;
	endif;
	
	self.allTblDataSortDescending.clear();
	self.allTblDataSortColumns.clear();	
	
	create tmpArray transient;
	tmpSortOrder.getTokensForDelimiter(',', tmpArray);

	foreach tmpStr in tmpArray do
		pos := 1;
		colName := tmpStr.scanUntil(Tab, pos);
		pos := pos+1;
		col := 	tmpStr.scanUntil(Tab, pos).Integer;
		if col &gt; maxCol then
			break;
		endif;
		pos := pos+1;				
		ascend := tmpStr.scanUntil(Tab, pos).Boolean;
		// add all sorts columns
		self.zAddSortColumn(colName, not ascend);		
	endforeach;
	
	// Jade sort limit handled in here
	self.setSortColumns();

epilog
	delete tmpArray;
end;</source>
        <access>protected</access>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTablePosFromXMLStr" id="e118ef08-94e8-4907-8f97-84252f187f22">
        <updating/>
        <source>setTablePosFromXMLStr(_inputStr : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	array: StringArray;
	str : String;
	parentName : String;
	controlIdx : Integer;
	control, parent : Control;

begin
	create array transient;
	_inputStr.getTokensForDelimiter(",", array);
	
	// array should now have 5 entries - parent, left, top, width, height
	parentName := array[1];
	foreach controlIdx in 1 to self.form.controlCount do
		control := self.form.controls(controlIdx);
		if control.name = parentName then
			parent := control;
			break;
		endif;
	endforeach;
	
	if parent &lt;&gt; null then
		self.parent := parent;
	endif;
	self.move(array[2].Real, array[3].Real, array[4].Real, array[5].Real);

epilog
	delete array;
end;</source>
        <Parameter name="_inputStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsArray" id="6e6be3de-5ea5-4dd4-ba4f-151cee26b100">
        <updating/>
        <source>setTblDataEntRowsArray(_entTableDef : EntTableDef; _addRowArray : EntTableRowArray ; _xmlStr : String) updating;
//--------------------------------------------------------------
//Created: November 2003 By: cnwgd1
//--------------------------------------------------------------
//Use this method if rows are added on the fly and not part of the def
//
//	25/02/2010	cnwcs5	par 21894 - if xml pass in use that instead of userwindow
vars

begin
	
	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	endif;
	
	if _xmlStr &lt;&gt; null and _entTableDef = self.myEntTableDef then
		if self.setColumnsFromXMLStr(_xmlStr) then
			return;
		endif;
	endif;

	self.myEntTableDef := _entTableDef;

	self.allTblDataEntRows.clear();
	self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	if _addRowArray &lt;&gt; null then
		_addRowArray.copy(self.allTblDataEntRows);
	endif;
	
	// if _xml passed then use those columns instead of user window
	if _xmlStr &lt;&gt; null then							// 25/02/2010 cnwcs5
		if self.setColumnsFromXMLStr (_xmlStr) then	// 25/02/2010 cnwcs5
			return;									// 25/02/2010 cnwcs5
		endif;
	endif;											// 25/02/2010 cnwcs5
	
	// Set from user defined view if there is one
	if self.setColumnsFromUserWindow() then
		return;
	endif;

	//If we get to here then No user defined view so use default instead
	self.setColumnsFromDefault(_addRowArray);
	self.setColumns(true);

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_addRowArray" type="EntTableRowArray"/>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsByDefUserView" id="e79c2f47-6495-444c-b69b-b928d460ea88">
        <updating/>
        <source>setTblDataEntRowsByDefUserView( _entTableDef : EntTableDef; _viewName : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261  First off uses the users saved table settings, otherwise trys
											the supplied then defau;t view, otherwise loads the all columns.

*/

vars

	view : EntTableView;
	
begin

	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	else
		self.myEntTableDef := _entTableDef;
	endif;
	
	self.allTblDataEntRows.clear();
	
	if self.setColumnsFromUserWindow() then
		//We had a user defined set for this table, so we have used those.
		return;
	endif;

	if _viewName.trimBlanks &lt;&gt; null then
		//We have a view name, try and find this view
		view := self.myEntTableDef.allEntTableViews[_viewName];
	endif;

	if view = null then
		//No view, so try the system default ones	
		self.setColumnsFromDefault(null);
	else
		//We were given a view, and found one, so use it.
		view.allEntTableRows.copy(self.allTblDataEntRows);
	endif;
	
	self.setColumns(true);
	
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsFromDef" id="01565118-1ea9-4e4f-b658-c1c4f8d41f41">
        <updating/>
        <source>setTblDataEntRowsFromDef(_entTableDef : EntTableDef) updating;
//--------------------------------------------------------------
//Created: July 02 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setTblDataEntRowsFromDefUser(_entTableDef, true);
	
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsFromDefUser" id="de0edbc7-3f82-496a-8135-d24ed1347c09">
        <updating/>
        <source>setTblDataEntRowsFromDefUser(_entTableDef : EntTableDef; _setFromUserWindow : Boolean) updating;
// copied from setTblDataEntRowsFromDef to add the option to not call setColumnsFromUserWindow
//  so that extra columns can be added to the table when a column organiser is not used.
vars

begin

	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	else
		self.myEntTableDef := _entTableDef;
	endif;
	
	//////////////////////////////////////////////////////////////////////
	//cnwmc5 - par 16523 - was breaking auto-resizing on columns
	self.allTblDataEntRows.clear();
	self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);	
	//////////////////////////////////////////////////////////////////////

	if _setFromUserWindow then
		//Set from user defined view if there is one
		if self.setColumnsFromUserWindow() then
			return;
		endif;
	endif;

	//If we get to here then No user defined view so use default instead
	self.setColumnsFromDefault(null);
	self.setColumns(true);

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_setFromUserWindow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsFromView" id="4ed38d7e-ec67-45ea-a17e-6f3a79b53c28">
        <updating/>
        <source>setTblDataEntRowsFromView(_entTableDef : EntTableDef; _viewName: String) updating;
//----------------------------------------------------------------
//	Created:	02 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 12/08/2009	cnwcs5	ccms1061 - moved code to get view to seperate method
vars
	entTblView	: EntTableView;
begin

	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	else
		self.myEntTableDef := _entTableDef;
	endif;
	
	self.allTblDataEntRows.clear();
	
	entTblView := self.getETViewForETDef (_viewName, self.myEntTableDef);	// 12/08/2009 cnwcs5 ccms 1061
	self.setMyEntTableView(entTblView);
	if entTblView = null then
		//No view so use all rows for def instead	
		self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	endif;
	
	//Set from user defined view if there is one
	if self.setColumnsFromUserWindow() then
		return;
	endif;

	self.setColumns(true);

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsFromXML" id="a2443ed3-74aa-4f92-b8f0-cd8e82405a93">
        <updating/>
        <source>setTblDataEntRowsFromXML(_entTableDef : EntTableDef; _xmlStr : String) updating;
//--------------------------------------------------------------
//Created: July 02 By: cnwgd1
//--------------------------------------------------------------
vars
begin

	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	endif;

	self.myEntTableDef := _entTableDef;	
	
	if _xmlStr = null then
		self.setTblDataEntRowsFromDef(_entTableDef);
		return;
	endif;
	
	
	self.allTblDataEntRows.clear();
	self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);	

	//Use user defined view if set
	if self.setColumnsFromXMLStr(_xmlStr) then
		return;
	endif;

	//If we get to here then No user defined view so use default instead
	self.setColumnsFromDefault(null);
	self.setColumns(true);

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblEntRowsFromView" id="6c1670b0-ad9d-45a8-8f92-70ea5576924d">
        <updating/>
        <source>setTblEntRowsFromView(_entTableDef : EntTableDef; _viewName: String; _xmlStr : String) updating;
/*

Purpose: This method will load rows of view without using xml string			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navhl20	Initial creation
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
18 Sep 2025 navhl20 Bug MTN-36084: MTN | Work Order Operations Pagination column issue with view
*/
vars
	entTblView	: EntTableView;
begin

	if _entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def passed in');
		return;
	else
		self.myEntTableDef := _entTableDef;
	endif;
	
	self.allTblDataEntRows.clear();
	
	entTblView := self.getETViewForETDef (_viewName, self.myEntTableDef);
	self.setMyEntTableView(entTblView);
	
	if entTblView = null then
		//No view so use all rows for def instead	
		self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	endif;
	
	if self.setColumnsFromXMLStr(_xmlStr) then
		return;
	endif;

	self.setColumns(true);

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setXMLStrForTblColumns" id="511209c0-4cea-4a9d-9dd5-56550bcded82">
        <updating/>
        <source>setXMLStrForTblColumns(_includeColumnWidths : Boolean; _xml :String io) updating;
/*--------------------------------------------------
// Created:	13 November 2003 By: cnwgd1
//--------------------------------------------------
// 25/02/2010 	cnwcs5	par 21894 - replaced incorrect use of scanWhile with pos method
//								 	method now inserts new entTableDef settings prior to the &lt;/tablename=&lt;name&gt; tag
//									instead of at the beginning
// 04/03/2013	cnwcs5	par 31087 - add parameter for string containing XML.  Now we can use this method for other tables e.g. CMUI_EDIForm::tblEDITI etc
12 Mar 2013 copied method from CM_TableViewForm
*/
vars
	tagPrefix, tagSuffix, tmpStr, defName, replaceStr,	tmpDefStr,
	tmpXMLStr 	: String;
	startPos	: Integer;
begin
	// Get XML for the table as it is being displayed now
	tmpXMLStr := self.getXmlStrForColumns(_includeColumnWidths);
	
	if _xml = null then
		_xml := tmpXMLStr;
		return;
	endif;
	
	defName 	:= self.myEntTableDef.name;
	tagPrefix 	:= J_key_LessThan.Character &amp; self.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
	tagSuffix 	:= global.formatAsXMLSuffix(self.XMLTag_EntTblDef &amp; defName).trimBlanks;

	startPos 	:= 1;
	tmpDefStr 	:= _xml.cnEcGetNextTagValueOfName(self.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		// there is already xml for the table/entTableDef combination
		startPos 	:= 1;
		tmpStr 		:= tmpXMLStr.cnEcGetNextTagValueOfName(self.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;
		replaceStr	:= tagPrefix &amp; tmpStr &amp; tagSuffix;
		startPos 	:= 1;
		tmpDefStr 	:= tagPrefix &amp; _xml.cnEcGetNextTagValueOfName(self.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		_xml 		:= _xml.replaceString(tmpDefStr, replaceStr);
	else
		// adding a new table/entTableDef combination - find the value to put between the prefix 7 suffix tage
		startPos 	:= 1;
		tmpDefStr 	:= tagPrefix &amp; tmpXMLStr.cnEcGetNextTagValueOfName(self.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		// we want to insert it before the &lt;/table name = &lt;name&gt;&gt; tag
		startPos 	:= 1;
		//self.xmlStrTblData.scanWhile('&lt;'&amp; _table.XMLTag_Table &amp; _table.name &amp; '&gt;', startPos);
		startPos 	:= _xml.pos('&lt;/'&amp; self.XMLTag_Table &amp; self.name &amp; '&gt;', startPos);
		
		if startPos &lt;&gt; 0 then
			_xml := _xml.cnEcInsertInto(tmpDefStr, startPos, startPos);
		else
			// should not happen but if it does we will append at the end
			_xml := tmpDefStr;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_includeColumnWidths" type="Boolean"/>
        <Parameter name="_xml" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showColumnByColHeading" id="c2d63322-b91f-428e-a4fb-e5d145b25e46">
        <updating/>
        <source>showColumnByColHeading(_heading : String) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx		: Integer;
	str		: String;
	entRow : EntTableRow;
begin

	foreach entRow in self.allTblDataEntRows do
//	foreach str in self.allTblDataColPropertyNames do
		idx := idx + 1;
		if entRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale).trimBlanks = _heading.trimBlanks then
			self.accessColumn(idx).visible := true;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="showColumnByColName" id="8b528166-df7c-4880-b9d3-3f2e0111adea">
        <updating/>
        <source>showColumnByColName(_name : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  CNWTH2 Reason: now returns row made visible
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx		: Integer;
	str		: String;
	entRow : EntTableRow;
begin

	foreach entRow in self.allTblDataEntRows do
		idx := idx + 1;
		if entRow.name.trimBlanks = _name.trimBlanks then
			self.accessColumn(idx).visible := true;
			return idx;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrgSizesForm" id="c9e0c342-a729-4a67-b5c8-1c2bad4b92d4">
        <updating/>
        <source>showColumnOrgSizesForm(_terminal : CM_Terminal; _additionalRows : EntTableRowArray)updating;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	colOrgForm	: CMUI_ColumnOrgSizesForm;
	table : CM_DataTable;
	hideSaveAsSysDefault : Boolean;	//09 May 2018	NDL	TFS 38460
begin
	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null self.myEntTableDef');
		return;
	endif;
	
	hideSaveAsSysDefault := self.form.CM_BaseForm.hideColOrgSaveAsSysDefauilt( self );	//09 May 2018	NDL	TFS 38460
		
	create colOrgForm transient;
	colOrgForm.setMyTerminal(_terminal);
	colOrgForm.setMyDataTable(self);

	colOrgForm.hideSaveAsSysDefault := hideSaveAsSysDefault;		//09 May 2018	NDL	TFS 38460

	colOrgForm.centreWindow();
	colOrgForm.showModal();
	
	if colOrgForm.modalResult = IDOK then
		self.form.CM_BaseForm.setTableDataFromOrganiser(self);
	endif;
	
	if colOrgForm.columnFiltersUpdated then
		table := self;
		self.form.CM_BaseForm.applyColumnFilter( table );
	endif;
	
epilog
	delete colOrgForm;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_additionalRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiserFrm" id="b34061fa-95bb-4173-a7a6-260ea9d5e3e0">
        <updating/>
        <source>showColumnOrganiserFrm(_terminal : CM_Terminal; _additionalRows : EntTableRowArray)updating;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	colOrgFrm : CMUI_ColumnOrganiserForm;
	hideSaveAsSysDefault : Boolean;	//09 May 2018	NDL	TFS 38460
	userWindow: CM_UserWindow;
	xml,
	tableText: String;	
begin

	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null self.myEntTableDef');
		return;
	endif;
	
	hideSaveAsSysDefault := self.form.CM_BaseForm.hideColOrgSaveAsSysDefauilt( self );	//09 May 2018	NDL	TFS 38460

	// 30/10/18 MAP TFS41134	get up to date XML, in case another instance of the same window has changed it
	userWindow := app.getUserWindow(self.form.name, false);
//	if self.form.isKindOf(CM_TableViewForm) and userWindow &lt;&gt; null then
	if self.form.isKindOf(CM_ContainerEnqForm) and userWindow &lt;&gt; null then	//14 Mar 2019	NDL	TFS 43631
		tableText := self.XMLTag_Table &amp; self.name;
		xml := global.formatAsXMLPrefix(tableText) &amp; userWindow.xmlInfo.cnEcGetTagValueOfName(tableText).trimBlankCharacters() &amp; CrLf &amp; global.formatAsXMLSuffix(tableText);
		self.form.CM_TableViewForm.setXML(xml);
	endif;

	create colOrgFrm transient;

	colOrgFrm.setMyTerminal(_terminal);
	colOrgFrm.setMyDataTable(self);
	
	colOrgFrm.hideSaveAsSysDefault := hideSaveAsSysDefault;		//09 May 2018	NDL	TFS 38460

	if _additionalRows &lt;&gt; null then
		_additionalRows.copy(colOrgFrm.allTblDataEntRows);
	endif;
	
	colOrgFrm.centreWindow;
	colOrgFrm.showModal;

	if colOrgFrm.modalResult = IDOK then
		self.form.CM_BaseForm.setTableDataFromOrganiser(self);
		// table has been rebuilt  - need to reapply filters if we were using them.
		if colOrgFrm.myDataTable &lt;&gt; null and colOrgFrm.myDataTable.allowsColumnFilters then
			self.form.CM_BaseForm.applyColumnFilter( colOrgFrm.myDataTable );
		endif;
	elseif colOrgFrm.columnFiltersUpdated then
		self.form.CM_BaseForm.applyColumnFilter( colOrgFrm.myDataTable );
	endif;
	
epilog

	delete colOrgFrm;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_additionalRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="showSelectorColumnOrganiserFrm" id="fed410bf-3160-4031-aae5-f78e23f2221b">
        <updating/>
        <source>showSelectorColumnOrganiserFrm(	_terminal : CM_Terminal;
								_cargoBOLType : CM_CargoBOLType;
								_menuAction : CMUI_MenuAction;
								_selectorMode : Integer;
								_selectorType : Integer	//29 Mar 2019	NDL	TFS 44100
								)updating;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------
// 24/05/2013	cnwdap1		PAR #31486 new parameter to set selectorMode attribute on column organiser form
//							(to differentiate between tracked item and user-defined modes)
vars
	colOrgFrm : CMUI_SelectorColOrganiserForm;
begin

	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null self.myEntTableDef');
		return;
	endif;

	create colOrgFrm transient;
	colOrgFrm.setMyTerminal(_terminal);

	colOrgFrm.myDataTable := self;
	colOrgFrm.myCargoBOLType := _cargoBOLType;
	colOrgFrm.selectorMode := _selectorMode;				// PAR #31486
	colOrgFrm.selectorType := _selectorType;	//29 Mar 2019	NDL	TFS 44100
	colOrgFrm.centreWindow;
	colOrgFrm.showModal;

	if colOrgFrm.modalResult = IDOK then
		self.form.CM_BaseForm.setTableDataFromOrganiser(self);
	endif;

epilog
	delete colOrgFrm;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="_selectorMode" type="Integer"/>
        <Parameter name="_selectorType" type="Integer"/>
    </JadeMethod>
