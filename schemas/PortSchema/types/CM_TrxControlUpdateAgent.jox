    <JadeMethod name="trxUpdateVVRRoadExit" id="5230dd9c-6085-4c29-962c-2c30e40b8aa0">
        <updating/>
        <source>trxUpdateVVRRoadExit(_vvr : CM_VehicleVisitRecord input; _effectiveTimeStamp : TimeStamp; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189
31/05/2022		jlier1	TFS 53650 - refactored schedule packages now called from vvr.departureProcess
*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	if _vvr = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, app.getErrorString(Vehicle_visit_record), null, null);
		return;
	endif;
	
	if not _vvr.myTerminal.roadProcessIsASPA then
		if _vvr.myTerminal.getMyRoadProcess &lt;&gt; null then 
			app.raiseCMException2(Road_opera_form_not_suppo_term, _vvr.myTerminal.getMyRoadProcess.code, method.qualifiedName, null, null); 
		else
			app.raiseCMException2(Road_opera_form_not_suppo_term, "&lt;" &amp; app.getErrorString(NoneSelected) &amp; "&gt;", method.qualifiedName, null, null); 
		endif;
		return;
	endif;
	
		
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;

	beginTransaction;
	
	_vvr.departureProcess( null, _effectiveTimeStamp );
	
	if _passport.hasErrors then
		return;
	endif;
	
	app.myUtilityUA.utlUpdateVVRRoadExit( _vvr,  _passport);

epilog

	self.finaliseActivityWithPassport(_passport);
	

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_effectiveTimeStamp" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
