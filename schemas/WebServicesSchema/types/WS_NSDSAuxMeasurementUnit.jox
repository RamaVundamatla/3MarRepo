    <JadeMethod name="setProxyObject" id="ec0fb23d-1061-430d-a3ed-1aa3d168ae7f">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
20MAY2022	NAVAB1	TFS 53105
*/

vars
	helper 	: CMIF_AuxMeasurementUnit;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.facility_id 	:= helper.facility_id;
	self.id 		:= helper.id;
	self.name := helper.name;
	self.measurement_type	:= helper.measurement_type;
	self.mu_gkey	:= helper.mu_gkey;
	self.mu_id_unit	:= helper.mu_id_unit;
	self.default	:= helper.default;

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
