    </JadeMethod>
    <JadeMethod name="translateForm" id="f8b90082-4864-4814-b824-c040c0bc0aac">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006316, locale);
	btnClose.translateCaption(Xlat_0002399, locale);
	btnDeleteDocket.translateCaption(Xlat_0002394, locale);
	btnLoadDocket.translateCaption(Xlat_0002395, locale);
	btnSelectAll.translateCaption(Xlat_0002397, locale);
	btnUpdate.translateCaption(Xlat_0002400, locale);
	grpUpdate.translateCaption(Xlat_0002401, locale);
	lblVoyage.translateCaption(Xlat_0002402, locale);
	mnuContext.translateCaption(Xlat_0006317, locale);
	mnuContextInspectObj.translateCaption(Xlat_0006318, locale);
	optAcceptAll.translateCaption(Xlat_0002398, locale);
	optAssign.translateCaption(Xlat_0002403, locale);
	optChangeToNN.translateCaption(Xlat_0002396, locale);
	optDelete.translateCaption(Xlat_0002404, locale);
	optEdit.translateCaption(Xlat_0002405, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateLogError" id="4b9fac3d-94a2-4669-9b44-634d16f6cd08">
        <updating/>
        <source>updateLogError()updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	logError			: CM_LogLoadError;
	intFaceLoadOut		: CMIF_LogLoadOutReconDtl;
	invalidSelection	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myCurrentLogVoyage &lt;&gt; null and
	   self.myCurrentLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myCurrentLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return;
	endif;

	if self.updateMode = null then
		app.msgBox('You must select an update option for the log(s)','No option selected', 0);
		return;
	endif;
	
	//grab collection of selected logLoadErrors from table 
	app.mousePointer := MousePointer_HourGlass;
	
	create intFaceLoadOut transient;
	intFaceLoadOut.mode := self.updateMode;
	if intFaceLoadOut.mode &lt;&gt; intFaceLoadOut.Mode_ChangeToNoNumber and
		intFaceLoadOut.mode &lt;&gt; intFaceLoadOut.Mode_DeleteSelected then
		if not self.validateOneSelected() then
			return;
		endif;
	endif;
	
	self.getSelectedErrors(intFaceLoadOut);
	if intFaceLoadOut.mode = intFaceLoadOut.Mode_AcceptSpec or
		intFaceLoadOut.mode = intFaceLoadOut.Mode_AcceptAllFromLocation then
		if intFaceLoadOut.myMasterLoadError &lt;&gt; null then
			if intFaceLoadOut.myMasterLoadError.myLog = null then
				invalidSelection := true;	
			endif;
		endif;
		intFaceLoadOut.allLogLoadErrors.clear();
		if invalidSelection then
			app.msgBox('The selected error(s) has no log associated with it. This is' &amp; CrLf &amp;
					'not allowed for this option.','Error', 0);
			return;
		endif;
	endif;
	if intFaceLoadOut.mode = intFaceLoadOut.Mode_EditID then
		intFaceLoadOut.newID := self.tblData.getValueByName(ETRow_LogId).String;
	endif;	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateLogLoadOutRecon(intFaceLoadOut, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentLogLoadError := null;
	self.loadBOLExtensions();

epilog
	delete intFaceLoadOut;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="validateOneSelected" id="19cb7379-142e-4abf-8141-0d77b2ef12ac">
        <source>validateOneSelected() : Boolean;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	checkCount,
	row			: Integer;
	table		: CM_DataTable;
begin
	table := self.tblLogError;
	foreach row in 2 to table.rows do
		if table.accessCell(row,1).text = Row_Checked then
			checkCount := checkCount + 1;
		endif;	
	endforeach;
	
	if (checkCount = 0) or
		(checkCount &gt; 1) then
		app.msgBox('One log must be selected for this update option','Error', 0 );
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSortColumn" id="d11321bc-5897-4ef3-a378-d6149df21176">
        <source>validateSortColumn(_colName: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if _colName = null or
		_colName = ETRow_Supplier or
		_colName = ETRow_DocketNo then
		return true;
	
	endif;

	return false;	
end;</source>
        <Parameter name="_colName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
