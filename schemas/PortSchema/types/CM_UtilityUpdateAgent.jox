	self.updateObjectEdition(_reserveSelection);
	if _reserveSelection.myReserveHeader &lt;&gt; null then
		_reserveSelection.myReserveHeader.createAssignedTransaction(_ti, true);//11 Dec 2015	NDL	Par 37288
		self.updateObjectEdition(_reserveSelection.myReserveHeader);
	endif;

epilog

end;</source>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection" usage="input"/>
