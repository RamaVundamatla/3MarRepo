        <updating/>
        <source>click() updating;
//-----------------------------------------
//
// Created : by cnwaer1 21 August 2008
//-----------------------------------------
vars

begin
	if self.frmOpDiscPorts.visible = true then
		self.closeLstAndTxtOptDischPort;
	endif;
	if self.frmHazards.visible = true then
		self.closeLstAndDisplayTxtHazards();
