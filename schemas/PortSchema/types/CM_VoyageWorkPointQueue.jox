    <JadeMethod name="setForUpdate" id="2564c7f2-2e8d-4f35-b95e-a3624f8ed979">
        <updating/>
        <source>setForUpdate(_pxyRTQueue: CM_VoyageWorkPointQueue;  _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_pxyRTQueue,  _passport);
	
	self.myWorkPoint := _pxyRTQueue.myWorkPoint;
	self.dischargeMachinesMode:=_pxyRTQueue.dischargeMachinesMode;
	self.loadMachinesMode:=_pxyRTQueue.loadMachinesMode;
	
epilog

end;</source>
        <Parameter name="_pxyRTQueue" type="CM_VoyageWorkPointQueue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkPointQueue" id="362448cc-04b6-4e57-aa7f-a51609c74855">
        <updating/>
        <source>setProxyWorkPointQueue( _id : String;
						_parentQ : CM_VoyageQueue;
						_workPoint : CM_WorkPoint;
						_loadMachineHandoverMode,
						_dischargeMachineHandoverMode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.id:=_id;
	self.myParentQueue:=_parentQ;
	self.myWorkPoint:=_workPoint;
	self.loadMachinesMode:=_loadMachineHandoverMode;
	self.dischargeMachinesMode:=_dischargeMachineHandoverMode;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_parentQ" type="CM_VoyageQueue"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_loadMachineHandoverMode" type="Integer"/>
        <Parameter name="_dischargeMachineHandoverMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="56cfd963-4c82-4e4e-a9d7-b44bf51f9af0">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	realSelf,
	wpQ : CM_VoyageWorkPointQueue;
begin

	inheritMethod(_passport);
	
	if self.myWorkPoint = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Work Point",null,null);
		app.raiseCMException(Input_required_field_workPoint,null,null); // cnwdb2	PAR 35364
		return;
	endif;

	realSelf:=self.pxyGetRealObject;
	foreach wpQ in self.myWorkPoint.allVoyageWorkPointQueues discreteLock do
		if wpQ.myParentQueue = self.myParentQueue and wpQ &lt;&gt; realSelf then
			app.raiseCMException2(VoyageQ_already_has_WorkpointQ, self.myParentQueue.id, self.myWorkPoint.code, null, self);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
