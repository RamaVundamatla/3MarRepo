    <JadeMethod name="copyFrom" id="2680eae3-24c2-4bda-88fd-97b041c0010a">
        <updating/>
        <source>copyFrom(_map : CM_ImexServiceMap; _imexStatus : Integer; _parent : CM_ProductMap) updating;
// 32311 set up self from the parameter plus the new imex status, copy all of the parameter map children under self.
vars
	csn			: CM_ContentsMap;
	newChild	: CM_ContentsMap;
begin
	self.imexStatus := _imexStatus;
	if _parent = null then
		self.myProductMap := _map.myProductMap;
	else
		self.myProductMap := _parent;
	endif;
	foreach csn in _map.contentsMaps do
		create newChild persistent;
		newChild.copyFrom(csn, csn.contentsType, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_ImexServiceMap"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_parent" type="CM_ProductMap"/>
    </JadeMethod>
