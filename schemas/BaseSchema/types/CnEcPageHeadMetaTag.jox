    <DbClassMap file="basehtml"/>
    <PrimAttribute name="metaContent" id="ffb3c1ee-e570-48f2-ae63-dcd45be17df5">
        <type name="String"/>
        <text>Assigns values to the HTTP header field.  When using the REFRESH HTTP
header, assign a number along with a URL to the CONTENT=attribute;
the browser then loads the specified URL after the specified number
of seconds.  For example:

&lt;META HTTP-EQUIV="Refresh" CONTENT="2;URL=nextpage.html"&gt;</text>
    </PrimAttribute>
    <PrimAttribute name="metaHttpEquiv" id="968fd0a7-a190-4769-8457-f067094ca4db">
        <type name="String"/>
        <text>Indicates the HTTP header value you want to define, such as Refresh, Expires,
or Content-Language.  Other header values are listed in RFC2068.  For example:

&lt;META HTTP-EQUIV="Expires" CONTENT="Tue, 04 Nov 2001 22:39:22 GMT"&gt;</text>
    </PrimAttribute>
    <PrimAttribute name="metaName" id="5a977064-4887-4018-a01e-1ccf9a9804f7">
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myHead" id="fd02d83d-1c22-494d-8d5b-e5e1c030081a">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcPageHead"/>
        <access>readonly</access>
        <Inverse name="CnEcPageHead::myMetaTag"/>
    </ExplicitInverseRef>
    <JadeMethod name="buildTagBody" id="eeaf5004-5018-4d21-bde6-dbc10e6f449b">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.metaName &lt;&gt; null then
		htmlString	:=	htmlString &amp; 'NAME="' &amp; self.metaName &amp; '"';
	endif;
	
	if self.metaHttpEquiv &lt;&gt; null then
		htmlString	:=	htmlString &amp; 'HTTP-EQUIV="' &amp; self.metaHttpEquiv &amp; '"';
	endif;
	
	if self.metaContent &lt;&gt; null then
		htmlString	:=	htmlString &amp; 'CONTENT="' &amp; self.metaContent &amp; '"';
	endif;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="aee1b0fe-89a4-43d1-b19f-0256e6382d3e">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;META ' &amp; self.buildTagBody() &amp; '&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRefresh" id="89829e56-fb39-4575-807f-f78e530b6a7c">
        <updating/>
        <source>setRefresh(pSeconds:Integer; pUrlAddress:String) updating;
// -----------------------------------------------------------------------------
// Created:		05 December 2001 by cnwdad1
//
// Purpose:		Sets the refresh setting for the HTML page.
//
// Parameters:	pSeconds - The number of seconds between auto-refresh.
//				pUrlAddress - The URL of the page to refresh.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.metaHttpEquiv	:=	"Refresh";
	self.metaContent	:=	pSeconds.String &amp; ';URL=' &amp; pUrlAddress;
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
        <Parameter name="pUrlAddress" type="String"/>
    </JadeMethod>
</Class>
