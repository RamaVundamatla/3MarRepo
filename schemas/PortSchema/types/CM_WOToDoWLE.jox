    <JadeMethod name="createTiToDoTask" id="d8fea268-c6ce-4878-be32-3cf36cacf44b">
        <updating/>
        <source>createTiToDoTask() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
*/


vars
	toDoDesc 			: CM_ToDoTaskDesc;
	task , tiTask 		: CM_ToDoTask;
	passport 			: CM_Passport;
	trans : CM_TITransaction;
begin

	if self.myTrackedItem = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;
	
	foreach task in self.myTrackedItem.allToDoTasksToDo where task.toDoTaskDescDesc.trimBlanks = toDoDesc.description.trimBlanks do
		tiTask := task;
	endforeach;

	if tiTask = null then //add task
		tiTask := self.myTrackedItem.addToDoTask( toDoDesc.description.trimBlanks , passport );
		

	endif;
	
	// if task = null then for some reason we cant add, return
	if tiTask &lt;&gt; null then
		
		if tiTask.myWOToDoWLE = null then		
		self.myToDoTask := tiTask.CM_TiToDoTask; // inverse to todotask.myToDoWLE		
			if self.job.myWODtl &lt;&gt; null then		
				tiTask.setMyWodToDo ( self.job.myWODtl.CM_WodToDo );
			endif;
			
		endif;
		
	endif;
	
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	trans := self.myTrackedItem.getLastTransOfType(toDoDesc.trxTypeOnCreation);
	if trans &lt;&gt; null 
	and self.job.myWODtl &lt;&gt; null then
		trans.setContractId(self.job.myWODtl.contractId);
	endif;
	

epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="createWOToDoTask" id="0191a842-faad-46e0-9ada-791cadf3c959">
        <updating/>
        <source>createWOToDoTask() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 May 2023 navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
*/


vars
	toDoDesc 			: CM_ToDoTaskDesc;
	task				: CM_ToDoTask;
	passport 			: CM_Passport;
	taskDesc			: String;
	found               : Boolean;
	tiTask              : CM_TiToDoTask;
	
begin
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;
	
	taskDesc := toDoDesc.description.trimBlanks;
	
	//Check that we do not already have this task assigned to us
	/*foreach task in self.allToDoTasksToDo where task.toDoTaskDescDesc.trimBlanks = taskDesc do
		return task;		//Not an error
	endforeach;*/
	
	//Find the applicable task Description	
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions
	where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then
		if (not toDoDesc.canUserAdd(app.myPassport)) then		
			return;
		endif;
			
		//ti could be just a proxy, in which case we want to create
		//proxy toDoTasks - persistent object can't reference transients
		if self.isTransient then
			create tiTask transient;
		else
			create tiTask persistent;
		endif;
		
		tiTask.setForCreate(STATUS_TODO,toDoDesc, null, app.myPassport, null); // ADD
		self.updateObjectEdition(self);
		
	else
		app.setContinueCMExceptions(false);
		if taskDesc &lt;&gt; "" then
			app.raiseCMException1(ERR_INVALID_LABEL, taskDesc &amp; " (task Description)", null, null);
		else
			app.raiseCMException1(ERR_INVALID_LABEL, "(No task Description)", null, null);
		endif;
	endif;
	
	// if task = null then for some reason we cant add, return
	if tiTask &lt;&gt; null then
		
		if tiTask.myWOToDoWLE = null then		
		self.myToDoTask := tiTask.CM_TiToDoTask; // inverse to todotask.myToDoWLE		
			if self.job.myWODtl &lt;&gt; null then		
				tiTask.setMyWodToDo ( self.job.myWODtl.CM_WodToDo );
			endif;
			
		endif;
		
	endif;
	

epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a4d1587c-0201-4ff0-9122-8e0312041675">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
02 Jul 2024 navbs1  CR 64901 Task 65016: UI- Show Cargo Ids in Job Details in WorkOrder Operations screen
20 Aug 2024 navlc30 Task 65695: Jade - Show same WLE for each TI
04 Dec 2024 navlc30 JIRA 32992 EUP | VAS WO - Show Each TI for WO To Do Job - Refinement
27 Jun 2025	navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes

*/

vars
	ti : CM_TrackedItem;
	//tiStr 			: String;
begin
	if  _attrName = ETRow_Commodity			or
		_attrName = ETRow_CargoGroupId		or 
		_attrName = ETRow_CargoTypeDescr	or
		_attrName = ETRow_CargoSubType		or
		_attrName = ETRow_TotalQuantity			//04.12.2024 navlc30 #32992
	then
		ti := self.myTrackedItem;				//04.12.2024 navlc30 #32992
		if ti = null then 						//04.12.2024 navlc30 #32992
			ti := self.getTi();
		endif;	
		if ti &lt;&gt; null then
			return ti.getDisplayStringForAttribute(_attrName,_short);
		endif;
	endif;

	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="9d2471a1-a329-4919-b483-c028feff1401">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jan 2023	navcs2	ChangeRequest 56822:[56823] EUP - VAS Voyage Work Order

*/

vars
	block   		: CM_DataContainerBlock;
	toDoTaskDesc	: CM_ToDoTaskDesc;
begin
	inheritMethod(_dataContainer);
	
	block 	:= _dataContainer.addNewBlock;
	
	if self.myToDoTask &lt;&gt; null  then
		toDoTaskDesc := self.myToDoTask.toDoTaskDesc;
		if toDoTaskDesc &lt;&gt; null then
			block.addNewItem('ToDo Task Desc ', DC_Label, 1, self);
			block.addNewItem(toDoTaskDesc.description, DC_Data, 1, self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstruction" id="6127f601-ae2c-468e-97c7-4bdbdae8bf53">
        <source>getInstruction():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
06 Mar 2025		navah1	Bug 34283: EUP | Additional Operational Instructions - further issues
*/

vars
	instruction : CM_InstructionsIssued;
begin
	if self.myToDoTask &lt;&gt; null then
		instruction := self.myToDoTask.getInstructions();
	endif;
	if instruction &lt;&gt; null then	
		//return instruction.internalInstructions; //10.03.2025 navah1 #34283
		return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
	endif;
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="965b6211-bb60-44e3-af10-71825c78d933">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
*/

vars

begin

	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeDesc" id="1c6ba705-e877-4845-b351-bd17a6c37875">
        <source>getTaskTypeDesc(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
*/

vars

begin

	if self.myToDoTask &lt;&gt; null then
		return self.myToDoTask.toDoTaskDescDesc ;
	else
		if self.job &lt;&gt; null then
			if self.job.CM_WOToDoTaskJob.myToDoTaskDesc &lt;&gt; null then
				return  self.job.CM_WOToDoTaskJob.myToDoTaskDesc.description;
			endif;
		endif;
	endif;

	return '';
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTi" id="64dc2b4b-ae60-4921-be62-2f15eef222ac">
        <source>getTi(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]

*/

vars
	wod		: CM_WorkOrderTIDtl;
begin
	if self.myTrackedItem = null then 
		if self.job &lt;&gt; null then
			wod := self.job.myWODtl;
			if wod &lt;&gt; null and wod.allSelectedTIs.isNotEmpty() then
				return wod.allSelectedTIs.first;
			endif;
		endif;
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getToDoTask" id="57365678-4f97-48ba-9b7f-6f9a7c809c7f">
        <source>getToDoTask() : CM_ToDoTask;
/*

Purpose:			Gets a to do task

Parameters:			NONE

Return Value:		CM_ToDoTask	Represents a to do task on a ti

Date		Who		Reason
07 May 2024	navpw1	Initial creation TFS: TFS 63920 (63924)

*/

vars
	task			: CM_ToDoTask;
	toDoTask		: CM_ToDoTask;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	
begin
	toDoTask := self.myToDoTask;

	if toDoTask = null then
		if self.job = null then
			return null;
			
		endif;
		
		toDoTaskDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		
		if toDoTaskDesc = null then
			return null;
			
		endif;
		
		foreach task in self.myTrackedItem.allToDoTasksToDo where task.toDoTaskDesc = toDoTaskDesc do
			toDoTask := task;
			break;
			
		endforeach;
		
	endif;
	
	return toDoTask;
	
end;</source>
        <ReturnType type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTIDtl" id="8315efdc-0d5c-4c3e-8128-1fa9f519a6df">
        <source>getWorkOrderTIDtl(): CM_WodToDo;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// -----------------------------------------------------------------------------

vars

begin
	return inheritMethod().CM_WodToDo;

epilog

end;</source>
        <ReturnType type="CM_WodToDo"/>
    </JadeMethod>
    <JadeMethod name="isCompleteForJob" id="7277ecae-f0b0-440c-8e51-24e95bd74ffb">
        <source>isCompleteForJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
*/

vars

	tmpReq : CM_Request;
begin

	tmpReq := self.myRequest;

	if tmpReq = null or (not tmpReq.isKindOf(CM_WOToDoRequest)) then
		return false;
	endif;
	
	if tmpReq.CM_WOToDoRequest.isComplete then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForToDoWOTransaction" id="e7f6c5e8-b9c2-4726-b2c2-e30705d99ded">
        <source>isForToDoWOTransaction() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks

*/

vars
	toDoTask 	 : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	transType    : CM_TransactionType;
begin
	toDoTask := self.myToDoTask;
	if toDoTask &lt;&gt; null then
		toDoTaskDesc := toDoTask.toDoTaskDesc;
		if toDoTaskDesc &lt;&gt; null then
			transType := toDoTaskDesc.myTransactionType;
			if transType &lt;&gt; null then
				return transType.isForWorkOrder();
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="2965326b-263a-4e00-bd8c-606d2e9a1d11">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
24 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
*/

vars
	todoDesc 	: CM_ToDoTaskDesc;
	trxType     : CM_TransactionType;
begin
	
	self.myTrackedItem := _ti;
	
	//Start 24.09.2024 navhl20 #62456:[66078]
	//self.createTiToDoTask(); 			// create the todo on the tracked item if we dont have one already
	if self.myTrackedItem &lt;&gt; null then
		todoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		trxType := todoDesc.myTransactionType; 	//This is the trxTypeOnCompletion.
		if trxType &lt;&gt; null and not trxType.isForWorkOrder() then
			self.createTiToDoTask(); 			// create the todo on the tracked item if we dont have one already
		endif;
	endif;
	//End 24.09.2024 navhl20 #62456:[66078]
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
