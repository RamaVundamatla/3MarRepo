    <JadeMethod name="utlUpdateGeneratePin" id="8cd1d7f5-75d7-488e-8db7-b67c1b7b0c12">
        <source>utlUpdateGeneratePin(_tiSet : CM_TISet; _carrierEmail: CM_PINObjectDefaultEmail; _warningsOff : Boolean; _passport : CM_Passport input);
//-----------------------------------------
// Created: December 2003 By: cnwgd1
//-----------------------------------------
vars
	realTI			: CM_TrackedItem;
	carrier			: CM_Carrier;
	tmpCarrierEmail	: CM_PINObjectDefaultEmail;
	
begin

	self.initialiseActivity();
		
	tmpCarrierEmail := _carrierEmail;
	
	foreach realTI in _tiSet do
		exclusiveLock(realTI);
	
		carrier := realTI.getCarrierRelease;
		
		if carrier = null then
			//PIN generation and no real carrier - raise warning - should never happen (maybe for a long stay import box)
			app.raiseCMWarning2(PIN_NO_CARRIER, realTI.releaseCarrier, realTI.id, 'releaseCarrier', null, realTI);
		endif;
			
		// Par 12597 We want an exception please
		if realTI.customsEntryNumber = null and not realTI.isCoastalInbound then //cnwrd1 par 27473 added check for coastal imports, can pass the warning.
			app.raiseCMWarning(PIN_NO_CUSTOMS_NUMBER, null, null, realTI);
		endif;

		//If a full import release has stops then don't allow a pin number. Par	
		if realTI.hasStops and realTI.isImport and realTI.isFull then
			if not realTI.hasStopExcludedForPinGen() then	// ### TFS 62568 (62569) 22Feb2024 NAVPW1
				app.raiseCMException1(VB_STOPS_EXIST, realTI.id,  null, realTI);
				return;
			endif;
		endif;

		
		//don't raise the warning if the message isn't enabled  PAR 11688
		if tmpCarrierEmail &lt;&gt; null and carrier &lt;&gt; null then
			if tmpCarrierEmail.enabled and carrier.allPINNotifyEmailAddresses.isEmpty then
				app.raiseCMWarning1(PIN_CARRIER_NO_EMAIL, carrier.code, 'releaseCarrier', null, realTI);
			endif;
		endif;
		
		//epr TFS 2011 7/6/16  refactored 
		realTI.generatePIN(tmpCarrierEmail,not _passport.warningsAcknowledged,_passport);
				
	endforeach;

epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_warningsOff" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGeneratePinBR" id="88c109eb-fc5c-493a-8405-6121208c411a">
        <source>utlUpdateGeneratePinBR(_brSet : CM_BulkReleaseSet; _carrierEmail: CM_ObjectEmail; _passport : CM_Passport input);
//-----------------------------------------
// Created: 09 January 2006 By: cnwgd1
//-----------------------------------------
// 13/02/2012	cnwcs5	par 28756 - changed methode signature (noPINforHazardousODProcess)
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	realBR			: CM_BulkRelease;
	tmpPinNo		: CM_PinNo;
begin

	self.initialiseActivity();

	// validation - no PIN generation for release request with hazard or over dimension cargo attached. ccms1676, Feb 2009
	foreach realBR in _brSet do
		app.myValUA.valBulkReleaseForPIN(realBR, realBR.myPinNo, _passport);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// processing PINs
	foreach realBR in _brSet do

		exclusiveLock(realBR);
		if realBR.status &lt;&gt; BR_ACTIVE then
			continue;
		endif;
		
		// no PIN generation for release request with hazard or over dimension cargo attached. ccms1676, Feb 2009
		// the procdure deletes existing PIN. No PIN Generation setuo in Terminal Config / Gate
		if realBR.noPINforHazardousODProcess(realBR.myPinNo, _passport) then
			continue;
		endif;
		
		// audit before text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realBR, true);
		endif;
		
		if realBR.myPinNo &lt;&gt; null then
			// 18/05/2009 cnwar2 CCMS1723/#???
			if realBR.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then
				realBR.embargoPIN(null);
			else
				realBR.myPinNo.erasePIN(null);	//deleting old, force the use of the default email by passing in null
			endif;
		endif;
		
		if (not app.generatePinNo(tmpPinNo, realBR.getDescription(true), _passport.myTerminal)) then
			//app.raiseCMException1(CANNOT_GENERATE_PIN, 'Pre-Note ' &amp; self.id, null, null);
			return;
		endif;
		tmpPinNo.addItem(realBR, _carrierEmail);

		// audit after text
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realBR, false);
		endif;
		
		self.updateObjectEdition(realBR);	// par 30292
			
		tmpPinNo := null;
	endforeach;


end;</source>
        <Parameter name="_brSet" type="CM_BulkReleaseSet"/>
        <Parameter name="_carrierEmail" type="CM_ObjectEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGraphicCommands" id="7840d76e-73ee-4908-8625-2d3c17405beb">
        <source>utlUpdateGraphicCommands(_theController : CMIF_GraphicCommandController input;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
