    <DbClassMap file="unitTest"/>
    <JadeMethod name="addOnshipCargoForId" id="fc9099c7-dd4c-4ccc-9448-f64d8088823e">
        <source>addOnshipCargoForId(_tiid : String; _locn : CM_LocationsController; _voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2018	NAVAB1	Initial creation

*/

vars
	ti  : CM_TrackedItem;
begin
	ti := self.addContainerAtLocnDisch(_tiid, "2200", "GENL", TI_IMEX_STATUS_IMPORT, _locn, 
	app.myRoot.allPorts["NZAKL"], _voyage);
	self.assertNotNull(ti);

epilog

end;</source>
        <Parameter name="_tiid" type="String"/>
        <Parameter name="_locn" type="CM_LocationsController"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addOnsiteCargoForId" id="8962c84b-0409-4265-bf08-1ce016d5255a">
        <updating/>
        <source>addOnsiteCargoForId(_id : String; _location: Any; _operator : CM_Operator; _createWash : Boolean; _daysBack : Integer) : CM_TrackedItem updating, protected;

/*

Purpose:		Add onsite cargo with the given id, in the given location, with an optional Washed transaction so there is an existing charge
					also optionally back-date the transacitons to get storage charges
Parameters:			

Return Value:		


Date		Who		Reason
22 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	baseDate,
	now		: Date;
	ti : CM_TrackedItem;
	washTxCont : CMIF_TITransactionController;

begin

	ti := self.addContainerAtLocation( _id, _operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, _location);
	
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "4000".Decimal );
	
	if _createWash then
		create washTxCont transient;
		washTxCont.type := TRANS_TYPE_WASH;
		washTxCont.noCharge := false;

		ti.createTransaction(washTxCont, app.myPassport);
	endif;
	commitTransaction;
	
	// set transaction dates back the given number of days
	if _daysBack &lt;&gt; 0 then
		baseDate := now - _daysBack;	// cargo create date
		self.setTransactionDate(ti, baseDate);
	endif;

	return ti;

epilog
	delete washTxCont;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_location" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_createWash" type="Boolean"/>
        <Parameter name="_daysBack" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addVesselVoyage" id="fe106ca2-c44e-463f-b023-459936874fe3">
        <source>addVesselVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2018	NAVAB1	Initial creation

*/

constants
	VoyageName = 'PEL10001';
	BoatName = 'PELVESSEL1';
	
vars
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	text		: String;
	tempStr		: String;
	mtCmdty		: String;
	defCmdty	: String;
	refCmdty	: String;
	hazCmdty	: String;
	container	: CM_Container;
	operator	: CM_Operator;
	passport	: CM_Passport;
	now, arrival : TimeStamp;
begin
	app.getTerminalDefCmdty( mtCmdty, defCmdty, refCmdty, hazCmdty );
	
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);	
	
	operator:=self.getOperator("MSK");
	passport := app.myPassport;
	
	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
												BoatName,
												"MSK", 
												self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; BoatName.display &amp; ' failed');

	beginTransaction;
	arrival := now.addDays(-20);
	voyage.setArrivalDT(arrival);
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createGCOnVoyage" id="cdb22d24-af9e-4f82-a974-36939e7b9355">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer; _volume : Decimal; _quantity : Integer) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 65740 21AUG2024 NAVAB1
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.getProductFromCode("12POUNDER-12");
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage, _voyage.myOperator, _quantity, null).CM_Cargo;
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight);
	self.opts.addAssoc(UTTI_CustomsAgent, "UTCA1"); // ### TFS CR 58263 TASK 58264 07FEB2024 NAVAB1
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createImportStorage3" id="4b194f9f-2e23-4aa4-84ff-8e2d81249820">
        <source>createImportStorage3(_voyage : CM_Voyage; _createExtraStorage : Boolean);
// create storage transactions for the current date, and optionally for two days back as well
vars
	now	   : Date;
	cargo	: CM_TrackedItem;
begin
	foreach cargo in _voyage.allImportTIs do
		self.createStorageTransactions22(cargo, now, _createExtraStorage);
	endforeach;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_createExtraStorage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTFS7032TransMapStuff" id="ba061f2b-49e9-4eb3-a626-ea1db8d931be">
        <source>createTFS7032TransMapStuff( _index : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2017	jlgndl1	Initial creation

*/

vars

	cargoMap	: CM_TranMap;
	services : CM_ServiceByNameDict;
	invType : CM_InvoiceDesc;
	calType1 : CM_CalculationType;
	service100 : CM_Service;
	service50 : CM_Service;
	service150 : CM_Service;
	invLineType100 : CM_InvoiceLineDesc;
	invLineType50 : CM_InvoiceLineDesc;
	invLineType150 : CM_InvoiceLineDesc;
	debtor : CM_DebtorNode;
	
	fileContent : String;
	fileName : String;
	mapName : String;
	bank : CM_Bank;

begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_7032');
	self.deleteInvoiceType("UT_InvType7032");

	self.deleteInvoiceService("UT_Service7032_50", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service7032_100", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service7032_150", FORCED_ERASE);
	
	self.deleteInvoiceLineType("UT_LineType7032_100", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineType7032_50", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineType7032_150", FORCED_ERASE);
	
	invType := self.createInvoiceType("UT_InvType7032", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvType7032 not created");
	
	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	service100 := self.createInvoiceService("UT_Service7032_100","Unit test for TFS 7032", calType1, null);
	self.assertNotNullMsg(service100, "UT_Service7032_100 not created");
	service50 := self.createInvoiceService("UT_Service7032_50","Unit test for TFS 7032", calType1, null);
	self.assertNotNullMsg(service50, "UT_Service7032_50 not created");
	service150 := self.createInvoiceService("UT_Service7032_150","Unit test for TFS 7032", calType1, null);
	self.assertNotNullMsg(service150, "UT_Service7032_150 not created");
	
	beginTransaction;
	delete service100.debtorNodeRates.first.rateEntries.first;
	delete service50.debtorNodeRates.first.rateEntries.first;
	delete service150.debtorNodeRates.first.rateEntries.first;
	commitTransaction;
	
	debtor := CM_RootDebtorGroup.firstInstance;
	self.setServiceRate(service100, debtor, "02/01/2017".Date, 100.00);
	self.setServiceRate(service50, debtor, "02/01/2017".Date, 50.00);
	self.setServiceRate(service150, debtor, "02/01/2017".Date, 150.00);
	
	create services transient;
	
 	services.add(service100);
	invLineType100 := self.createInvoiceLineType("UT_LineType7032_100", calType1, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType100, "UT_LineType7032_100 not created");
	services.clear();
	
	services.add(service50);
	invLineType50 := self.createInvoiceLineType("UT_LineType7032_50", calType1, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType50, "UT_LineType7032_50 not created");
	services.clear();
	
	services.add(service150);
	invLineType150 := self.createInvoiceLineType("UT_LineType7032_150", calType1, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType150, "UT_LineType7032_150 not created");
	services.clear();
	
	// Need to map to above invoice line types
	fileName := "CargoLoaded";
	mapName := "UT_7032";
	
	if _index = 1 then
		fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),(Default) ›,(Default),,,All,UT_LineType7032_100' &amp; CrLf;
	elseif _index = 2 then
		fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,0 to 3,,,All,UT_LineType7032_50' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,4 to 6,,,All,UT_LineType7032_100' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,7 to MAX,,,All,UT_LineType7032_150' &amp; CrLf;
	endif;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);


epilog

	delete services;

end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayDetails" id="b67ad264-9fe4-42e7-844d-249a4135b5e8">
        <source>displayDetails(_voyage : CM_Voyage) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
*/
vars
	tiCount,
	tranCount,
	invCount	: Integer;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	calcType	: CM_CalculationType;
	calcStr	: String;
	id, id2		: String;
	done	: Boolean;
begin

write "EXPORTS";
	foreach ti in _voyage.allExportTIs do
		tiCount := tiCount+1;
		id := ti.id &amp; " " &amp; ti.commodity;
		done := false;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				tranCount:= tranCount+1;
				done := false;
				id2 := " storage " &amp; trans.dateTime.String;
				foreach invLine in trans.allInvoiceLines do
					invCount:= invCount+1;
					calcType := invLine.getCalcType();
					if calcType = null then
						calcStr := "no calc type";
					else
						//calcStr := calcType.calculationType.String &amp;" " &amp; calcType.getCalcTypeDesc(); //11/09/2017 cnwma1 TFS #6897
						calcStr := calcType.calculationType.String &amp;" " &amp; calcType.description;   //11/09/2017 cnwma1 TFS #6897
					endif;
					write id &amp; id2 &amp; " invoice line quantity " &amp; invLine.quantity.String &amp; " calc type " &amp; calcStr;
					done := true;
				endforeach;
				if not done then
					write id &amp; id2 &amp; " no invoice lines";
					done := true;
				endif;
			endif;
		endforeach;
		if not done then
			write id &amp; " no storage";
		endif;
	endforeach;
write tiCount.String&amp;" tracked items, "&amp;tranCount.String&amp;" storage transactions, "&amp;invCount.String&amp;" invoice lines";

write "";write "IMPORTS";
	tiCount:=0;tranCount:=0;invCount:=0;
	foreach ti in _voyage.allImportTIs do
		tiCount:= tiCount+1;
		id := ti.id &amp; " " &amp; ti.commodity;
		done := false;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				tranCount:=tranCount+1;
				done := false;
				id2 := " storage " &amp; trans.dateTime.String;
				foreach invLine in trans.allInvoiceLines do
					invCount:=invCount+1;
					calcType := invLine.getCalcType();
					if calcType = null then
						calcStr := "no calc type";
					else
						//calcStr := calcType.calculationType.String &amp;" " &amp; calcType.getCalcTypeDesc(); //11/09/2017 cnwma1 TFS #6897
						calcStr := calcType.calculationType.String &amp;" " &amp; calcType.description;       //11/09/2017 cnwma1 TFS #6897
					endif;
					write id &amp; id2 &amp; " invoice line quantity " &amp; invLine.quantity.String &amp; " calc type " &amp; calcStr;
					done := true;
				endforeach;
				if not done then
					write id &amp; id2 &amp; " no invoice lines";
					done := true;
				endif;
			endif;
		endforeach;
		if not done then
			write id &amp; " no storage";
		endif;
	endforeach;
write tiCount.String&amp;" tracked items, "&amp;tranCount.String&amp;" storage transactions, "&amp;invCount.String&amp;" invoice lines";
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getAllStorageTriggers" id="1701af45-9411-4deb-87b2-0d64f9504651">
        <source>getAllStorageTriggers(_triggers : CM_StorageTriggerByType input) protected;
// free storage days, create all possible storage triggers
vars
	pxyStorageTrigger : CM_StorageTrigger;
begin
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_ST, false, null);
	_triggers.add(pxyStorageTrigger);
	 
//	create pxyStorageTrigger transient;
//	pxyStorageTrigger.setProxy( IMEX_EX_TO_TR, false, null);
//	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_ST, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_TR, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_EX, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_IM, false, null);
	_triggers.add(pxyStorageTrigger);
	 
//	create pxyStorageTrigger transient;
//	pxyStorageTrigger.setProxy( IMEX_ST_TO_TR, false, null);
//	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_EX, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_IM, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_ST, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( PackAsChild, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( PackAsParent, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( PackCompleteAsParent, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageDebtor, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( SubTerminal, false, null);
	_triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( UnpackAsChild, false, null);
	_triggers.add(pxyStorageTrigger);
	
	create pxyStorageTrigger transient;
	 pxyStorageTrigger.setProxy( VoyageChange, false, null);
	 _triggers.add(pxyStorageTrigger);

	// PAR 36472
	create pxyStorageTrigger transient;
	 pxyStorageTrigger.setProxy( CargoSplitMerge, false, null);
	 _triggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageTAGroup, false, null);
	_triggers.add(pxyStorageTrigger);
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_triggers" type="CM_StorageTriggerByType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="importExportStorage2" id="ec0013f3-3d53-4061-ad0a-629da288580b">
        <updating/>
        <source>importExportStorage2(_include : Boolean; _storageConfig : CM_StorageConfig) updating, protected;
// cnwjre1
// copy of UT_Invoicing  firstLastStorage
/*	Test CCMS 1295 free storage days
	A transaction map is loaded and set active, with invoice line descriptions and services using the new DAYSINCE_SHIP_ST and DAYSINCE_SHIP_EN
		calculation types.
	Using code from the UT_KPIVoyage tMain test, cargo is created both on-site and on-ship.  The on-site transaction dates are then set back 20 days.
	Cargo is loaded and discharged.
	The transaction dates are then set back such that the first half of the unloads are 11 days old and the second half are 10 days old.
	This simulates an unload starting 11 days ago and taking two days.
	The transaction dates are then set back such that the first half of the loads are 9 days old and the second half are 8 days old.
	This simulates a load starting 9 days ago and taking two days.
	Storage transactions are automatically created from the load.
	The voyage ship exchange dates are also set to the start of unload (11 days ago) and end of load (8 days ago).
	Storage transactions are created for the imported cargo and the export storage transactions are re-evaluated.
	The import storage invoice lines should all be for 11 days, being the difference betwen the current date and start of unload.
	The export storage invoice lines should be re-evaluated to be all for 12 days, being the difference between the start date 20 days ago
		and the end of load (8 days ago).
	Test CCMS 2109 par 26108 - this method is called twice, once with the parameter false for the regular exclusive date range processing and 
								again with the parameter true for the inclusive date range processing.
								In the second case the invoice line quantities should all be one more than the values given above.
	THIS IS USED BUT WILL PROBABLY BE REPLACED BY importExportStorage3 which is the active test development as at 15/10/2012
*/
vars
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
	ti : CM_TrackedItem;
begin

	self.tranMapLoadFirstLast();

	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 4);
	self.createCargoOnSite(voyage, 4, 20);
	
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	
	self.loadStart := null;
	self.unloadEnd := null;
	self.setExportTransDates(voyage);
	self.setImportTransDates(voyage);
	beginTransaction;
	voyage.setPropertyValue("shipExchangeDate", self.loadStart);
	voyage.setPropertyValue("shipExchangeCompleteDT", self.unloadEnd);
	commitTransaction;
	
	self.createImportStorage(voyage);
	self.reevalExportStorage(voyage);
	
	// tests with free days are different
	if _storageConfig &lt;&gt; null and
	   _storageConfig.allStorageDetails.size &gt; 1 then
		//self.validateFSDImports1(voyage, _include);
		self.validateFSDExports1(voyage, _include);
	else
		self.validateFirstLastImports(voyage, _include);
		self.validateFirstLastExports(voyage, _include);
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_include" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="importExportStorage3" id="178d6131-15f2-43f7-afc8-aae7e96d9a3b">
        <updating/>
        <source>importExportStorage3(_storageConfig : CM_StorageConfig) updating, protected;
// cnwjre1
// copy of UT_Invoicing  firstLastStorage
/*	Test is CCMS 1295 free storage days.  Base test was CCMS 2109 and 2020 which still need to be covered here.
	A transaction map is loaded and set active, with invoice line descriptions and services using each of the per-day calculation types.
	Cargo is created both on-site and on-ship.  The on-site transaction dates are then set back 20 days.
	Cargo is loaded and discharged.
	The transaction dates are then set back such that the first half of the unloads are 11 days old and the second half are 10 days old.
	This simulates an unload starting 11 days ago and taking two days.
	The transaction dates are then set back such that the first half of the loads are 9 days old and the second half are 8 days old.
	This simulates a load starting 9 days ago and taking two days.
	Storage transactions are automatically created from the load.
	The voyage ship exchange dates are also set to the start of unload (11 days ago) and end of load (8 days ago).
	Storage transactions are created for the imported cargo and the export storage transactions are re-evaluated.
	The import storage invoice lines should all be for 11 days, being the difference betwen the current date and start of unload.
	The export storage invoice lines should be re-evaluated to be all for 12 days, being the difference between the start date 20 days ago
		and the end of load (8 days ago).
	This method is called multiple times with different storage config options (include first/last days, calendar and working days, free days and no free days)
		and even no storage config to get base comparison figures.
	The storage config is passed in so it can be used in the validation.
	THIS IS AN ACTIVE TEST as at 15/10/2012
*/
vars
	voyage : CM_Voyage;
	ti	: CM_TrackedItem;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
begin

	self.loadTranMap1();

	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 14);	// limit to get all non-reefers and one each 20, 40 ft reefer
	self.createCargoOnSite(voyage, 19, 20);	// limit to 19 all non-reefers and one each 20, 40 ft reefer; days back=20
	//  assign a different commodity to each non-reefer to match the transaction map loaded above, to get a range of invoice line types
	//	and hence calculation types, for each day-related calc type.
	self.setVoyageCargoCommodity(voyage);
	
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	app.myPassport.clearErrorsWarnings();	// not all jobs got across ...
	
	self.loadStart := null;
	self.unloadEnd := null;
	self.setExportTransDates(voyage);
	self.setImportTransDates(voyage);
	
	beginTransaction;
	voyage.setPropertyValue("shipExchangeDate", self.loadStart);
	voyage.setPropertyValue("shipExchangeCompleteDT", self.unloadEnd);
	commitTransaction;
	
	self.createImportStorage3(voyage, false);	// 'false' means just one lot of storage per container
	self.reevalExportStorage(voyage);
	
	//self.displayDetails(voyage);
	self.validateImportExportStorage(voyage, _storageConfig);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="importStorage" id="ac87cbc1-2ce3-48d6-8704-1f9cdcab00f8">
        <updating/>
        <source>importStorage(_first : Boolean; _last : Boolean) updating, protected;
// cnwjre1 from 31932
// Two cargo items received 10 days ago with free storage 7 days, include first day and include last from input parameters
//	Calculation type Days Since Receival
//10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
//28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors

constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';

vars
	bs: CM_BlockStack;
	voyage : CM_Voyage;
	cargo1,
	cargo2	: CM_TrackedItem;
	operator	: CM_Operator;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	tran			: CM_TITransaction;
	trans			: CM_TITransaction;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
	tranDate		: Date;
	tranTime		: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	msg				: String;
	now				: Date;
	tranDate1, tranDate2	: Date;
	invLineQty		: Integer;
begin
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	includeFirstDay := _first;
	includeLastDay := _last;
	// import days = 7, export days (not used here) = 10
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking,
						deriveDebtorFrom, triggers, true, 7, 10, 0);			// TFS 2570

	bs:= self.addBlockStack("UBS1", 100, null);
	operator := self.getOperator(TestOperator);
	
	voyage := self.createNamedVesselVoyage(ShipName, VoyageName, operator.code);
	// set up all required invoicing, storage transactions using UT_ILTFSD5, Days since receival
	self.loadTranMapDaysSinceReceival();
	
	// add two import general containers onsite
	cargo1 := self.addOnsiteCargoForId("MRKU0910410", bs.allLocationsControllers.first, operator, false, 0);
	cargo2 := self.addOnsiteCargoForId("MRKU0910420", bs.allLocationsControllers.first, operator, false, 0);
	beginTransaction;
	cargo1.setMyVoyage(voyage, app.myPassport);
	cargo2.setMyVoyage(voyage, app.myPassport);
	foreach trans in cargo1.allTransactions do
		trans.setPropertyValue("voyage", voyage);
		trans.setPropertyValue("voyageCode", voyage.code);
		trans.setPropertyValue("myVoyageRelivant", voyage);
	endforeach;
	foreach trans in cargo2.allTransactions do
		trans.setPropertyValue("voyage", voyage);
		trans.setPropertyValue("voyageCode", voyage.code);
		trans.setPropertyValue("myVoyageRelivant", voyage);
	endforeach;
	commitTransaction;
	
	// back-date cargo1 transactions to 10 days ago and the times all plus 1 hour (the container left earlier in the day than the arrival)
	// back-date cargo2 transactions to 10 days ago and the times all minus 1 hour (the container left later in the day than the arrival)
	//  In the original code this gave different results for the two containers - here they should give the same 
	tranDate := tranDate - 9;		// -9 so that first day is relative day 1 and last is day 10
	
	tranTS.setDate(tranDate);
	foreach tran in cargo1.allTransactions do
		tranTime := tran.dateTime.time.addHours(-1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	foreach tran in cargo2.allTransactions do
		tranTime := tran.dateTime.time.addHours(1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	//10 September 2023 navmv20 CR 58250 Task 58252 - start
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	cargo1.evaluateFreeStorageDays(null,true);				//28.05.2024 navma1 #64224
	cargo2.evaluateFreeStorageDays(null,true);				//28.05.2024 navma1 #64224
	commitTransaction;
	//10 September 2023 navmv20 CR 58250 Task 58252 - end
	
	// do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");	// to prevent more stops being added at release
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo2.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check the storage transaction and invoicing
	// set expected values
	tranDate2 := now;
	if includeFirstDay then
		if includeLastDay then
			tranDate1 := now - 3;
			invLineQty := 3;
		else
			tranDate1 := now - 3;
			invLineQty := 2;
		endif;
	else
		if includeLastDay then
			tranDate1 := now - 2;
			invLineQty := 2;
		else
			tranDate1 := now - 2;
			invLineQty := 1;
		endif;
	endif;
	msg := "Road exit, 1";
	self.validateImportStorage(msg, cargo1, tranDate1, tranDate2, invLineQty);
	msg := "Road exit, 2";
	self.validateImportStorage(msg, cargo2, tranDate1, tranDate2, invLineQty);
	
	self.reevalStorageTrans(cargo1);
	self.reevalStorageTrans(cargo2);
	
	msg := "After re-eval, 1";
	self.validateImportStorage(msg, cargo1, tranDate1, tranDate2, invLineQty);
	msg := "After re-eavl, 2";
	self.validateImportStorage(msg, cargo2, tranDate1, tranDate2, invLineQty);

epilog

	self.resetDefaultTranMap();	
	delete triggers;
end;</source>
        <access>protected</access>
        <Parameter name="_first" type="Boolean"/>
        <Parameter name="_last" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTranMap1" id="790ff859-d476-4055-8e15-2fe8ccd8762b">
        <source>loadTranMap1() protected;
// cnwjre1 load cargo transaction map with each of the storage-related calculation types, by specific commodities
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CargoStorage";
	mapName := "UT_Storage2";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_A,Storage,,(Default),CCT35 Days Since Receival TEU ›,(Default),UT_ILTFSD1' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_B,Storage,,(Default),CCT109 Days Since Last Load ›,(Default),UT_ILTFSD2' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_C,Storage,,(Default),CCT108 Days Since First Discharge ›,(Default),UT_ILTFSD3' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_D,Storage,,(Default),CCT07 Days Onsite At ›,(Default),UT_ILTFSD4' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_E,Storage,,(Default),CCT06 Days Since Receival ›,(Default),UT_ILTFSD5' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_F,Storage,,(Default),CCT106 Days Onsite By Volume ›,(Default),UT_ILTFSD6' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_G,Storage,,(Default),CCT105 Days Onsite By Weight Kilos ›,(Default),UT_ILTFSD7' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),UT_H,Storage,,(Default),CCT09 Days Connected ›,(Default),UT_ILTFSD8' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),REEF,Storage,,(Default),CCT09 Days Connected ›,(Default),UT_ILTFSD8' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
