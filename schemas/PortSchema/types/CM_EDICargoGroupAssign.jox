<Class name="CM_EDICargoGroupAssign" id="271188e4-b3f6-4405-8549-7398b6e86ea1">
    <superclass name="CM_EDITrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <CompAttribute name="allCargoIds" id="09708b36-db65-49ac-ac35-7957c0ef006e">
