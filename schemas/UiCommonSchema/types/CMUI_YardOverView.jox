    <JadeMethod name="doResize" id="9626bb34-3012-4b36-87b3-3c754b4157d6">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theSDF, theBSDF : CMUI_ScrollableDrawingFrame;
	theRightBtn : Button;
begin
	theSDF := self.mySDF;
	theBSDF := self.mySDFBackground;
	self.sptMain.move(0,self.frmToolbar.clientHeight,self.clientWidth, self.clientHeight - self.frmToolbar.clientHeight);
	self.doSetWidthHeight(); // set width &amp; height on SDFs
	theSDF.repositionAfterResize();
	// this frame is disabled and in the background, make it the same as our interactive drawing frame on the SDF
	theBSDF.repositionAfterResize();
	self.frmToolbar.positionToolbarControls();
	self.sptMain.cnEcResizeContents();
	self.frmLegend.doResize();
	self.doZOrder();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2ec1e194-1220-4f2d-87ac-e81a62f3cec5">
        <updating/>
        <source>doSave(_confirmSave : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theGraphics : CMIF_LayoutGraphics;
	pntX, pntY, theReturn : Integer;
	aPoint,tmpPoint : Point;
	aPointArray,tmpPointArray : PointArray;
	theFrame : CMUI_PointDrawingFrame;
	anObject : Object;
	aLayoutGraphic : CM_LayoutGraphic;
	theScaleFactor : Real;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin			
	theScaleFactor := (TWIPsPerPixel / self.xmlScaleFactor);

	if self.mode &lt;&gt; self.Mode_Edit then
		return;
	endif;
	
	if _confirmSave then
		theReturn := app.msgBox("Are you sure that you want to save the" &amp; Cr &amp; "changes to the Terminal Area positions?", "Confirm Save",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;		
	theFrame := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame;
	
	create theGraphics transient;
	
	self.allAreaObjects.copy(theGraphics.allObjects);
	
	// these will have the scale factor applied to them so remove it
	foreach anObject in theFrame.allPointGraphics do
		aLayoutGraphic := anObject.CM_LayoutGraphic;
		
		create tmpPointArray transient;
		foreach aPoint in aLayoutGraphic.pointsPolygon do
			pntX := (aPoint.x * theScaleFactor).Integer;
			pntY := (aPoint.y * theScaleFactor).Integer;
			tmpPoint.set(pntX,pntY);
			tmpPointArray.add(tmpPoint);
		endforeach;
		
		theGraphics.allPointPolygons.add(tmpPointArray);
	endforeach;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTerminalAreasGraphic(theGraphics,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.dataChanged := false;
			break;
		else
			theResult := app.showErrorWarningDialog('Update Terminal Area Positions', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	if theGraphics &lt;&gt; null then	//when press Cancel instead of Save, theGraphics = null (cnwvu1)
		theGraphics.allPointPolygons.purge;
	endif;
	delete theGraphics;
	
end;</source>
        <Parameter name="_confirmSave" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetWidthHeight" id="0ceead55-7858-4ee2-8c8c-6a1e0b11b2ff">
        <updating/>
        <source>doSetWidthHeight() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin
	self.mySDF.left := 0;
	self.mySDF.top := 0;
	self.mySDFBackground.left := 0;
	self.mySDFBackground.top := 0;
	
//	self.mySDF.width := self.clientWidth;
//	self.mySDFBackground.width := self.clientWidth - 20;
//	self.mySDF.height := self.clientHeight;
//	self.mySDFBackground.height := self.clientHeight - 20;
	self.mySDF.resizeDrawingFrame(self.frameWidth, self.frameHeight);
	self.mySDFBackground.resizeDrawingFrame(self.frameWidth - 20, self.frameHeight);
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowArea" id="4f9865a0-1754-4cc7-be9c-646323152345">
        <updating/>
        <source>doShowArea(_theArea : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminalArea : CM_GridArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theArea : CM_TerminalArea;
begin

	if _theArea &lt;&gt; null then
		if _theArea.isKindOf(CM_GridArea) then
			theTerminalArea := _theArea.CM_GridArea;
			
			menuAction := app.myController.createMenuAction(PmYardAreaView, null, self.myMasterMenuAction, self.myTerminal);
			
			
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithTI",theTerminalArea,null,null);
			aForm.show;	
		elseif _theArea.isKindOf(CM_Rail) then
			theArea := _theArea.CM_TerminalArea;
			menuAction := app.myController.createMenuAction(PmAdmRailopsView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithObject",theArea);
			aForm.show;	

		elseif _theArea.isKindOf(CM_Pack) then
		
			theTerminalArea := _theArea.CM_GridArea;
			menuAction := app.myController.createMenuAction(PmAdmLclpackView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
//			aForm.sendMsgWithParams("doInitializeWithObject",theTerminalArea);
			aForm.show;	
		elseif _theArea.isKindOf(CM_Building) then
		elseif _theArea.isKindOf(CM_IrregularBlockArea) then
			theArea := _theArea.CM_IrregularBlockArea;

			menuAction := app.myController.createMenuAction(PmGCGraphicalView, null, self.myMasterMenuAction, self.myTerminal);
	
			
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithTI",theArea,null,null);
			aForm.show;	
		elseif _theArea.isKindOf(CM_LogArea) then
			//YRD_GridAreaForm logs
			
			theArea := _theArea.CM_LogArea;

			menuAction := app.myController.createMenuAction(PmLogAreaGraphicalView, null, self.myMasterMenuAction, self.myTerminal);

			
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("doInitializeWithTI",theArea,null,null);
			aForm.show;	
			
		else		
		
			theArea := _theArea.CM_TerminalArea;
			menuAction := app.myController.createMenuAction(PmYardLocationEnqView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			aForm.sendMsgWithParams("showWithObject",theArea,false,false);
		endif;
		
	endif;

end;</source>
        <Parameter name="_theArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doShowToolTip" id="9d059f3a-ad99-44b1-9ecd-1b047c0344d2">
        <source>doShowToolTip(_theString : String;theX, theY : Integer);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.lblToolTip.caption := _theString;
	
	self.lblToolTip.left := theX;
	self.lblToolTip.top := theY;
	self.lblToolTip.height := 15;
	self.lblToolTip.width := _theString.trimBlanks.length * 7;
