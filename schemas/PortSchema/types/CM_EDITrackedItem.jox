    <JadeMethod name="getConsign" id="ba2bcaf6-0b93-4f4a-8821-c09795ba2f60">
        <source>getConsign(_consignStr : String) : CM_ConsigneeConsignor;
/*
----------   ----------  --------------------------------------------------
Created:	18 August 2006 By cnwth2

Purpose:	Search consignee/consignors using the _consignStr and attempt
			to match a single object to it.
			Makes the most obvious check using a direct key check and then 
			will try and find it by other means if nothing is directly matched.
			
Changed On   Changed By  Reason
23/12/2008   cnwsh3		 PAR18439 - Client encountered a problem with a non matching consignee.	
----------   ----------  --------------------------------------------------
*/
vars
	consign			: CM_ConsigneeConsignor;
	consignDict		: CM_ConsignByCodeDict;
	conCode,
	conCodeUpper,
	conDes			: String;	
	iter 			: Iterator;
	objSet			: ObjectSet;
	iterCode 		: String;
	
begin
	create objSet transient;
	
	if _consignStr = null then
		return null;
	endif;
	
	consignDict := app.myRoot.allConsigneeConsignors;
	consign := consignDict[_consignStr];
	if consign &lt;&gt; null then
		return consign;
	endif;
	
	//PAR18439 starts
	//Just in case we don't have an upper match.
	conCodeUpper := _consignStr.toUpper();
	
	iter := consignDict.createIterator();
	while iter.next(consign) do
		conCode := consign.code.toUpper();
		conDes := consign.description.toUpper();
		
		if conCode = conCodeUpper or
		   conDes = conCodeUpper or
		   conCode.startsWith(conCodeUpper) or
		   conDes.startsWith(conCodeUpper) then
				objSet.add(consign);
		endif;
		
		//No point in continuing if we have more than 1 consignee.
		if objSet.size &gt; 1 then
			break;
		endif;
	endwhile;
	
	if objSet.size = 1 then
		return objSet.first.CM_ConsigneeConsignor;
	endif;
	
	return null;
	//PAR18439 ends
		
/* REPLACED THE FOLLOWING CODE WITH THE ABOVE CODE TO AS BEST AS POSSIBLE, FIND A CONSIGNOR THAT IS SUITABLE. PAR18439 CNWSH3 23/12/2008
	foreach consign in consignDict do
		//©phuzzy logic inc.
		if _consignStr.toUpper.cnContains(consign.description.toUpper) then
			return consign;
		endif;
	endforeach;

	return null;*/
epilog
	delete objSet;
	delete iter;			// leaking transient
	
end;


</source>
        <Parameter name="_consignStr" type="String"/>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getContRange" id="8c177558-a847-45f8-8bad-e3ef2dcae7f0">
        <source>getContRange():CM_ContRange;

//	7/11/2018 	JLGNS1	Bug 41591: PEN - ISO Error on upload

vars
	contRange: CM_ContRange;
	trimedID : String;
begin
	
	//If I am not a container then don't return this stuff
	if self.cargoType &lt;&gt; TI_CargoType_Container and	 self.cargoType &lt;&gt; TI_CargoType_Null  then
		return null;
	endif;
	
	trimedID := self.id.trimBlanks;
	
	contRange := app.myRoot.allContainerRanges.getAtKeyLeq(trimedID);
	if contRange &lt;&gt; null then
		if trimedID &lt; contRange.lower or
		   trimedID &gt; contRange.upper then
			contRange := null;
		endif;
	endif;
		
	
			
	return contRange;
end;</source>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
