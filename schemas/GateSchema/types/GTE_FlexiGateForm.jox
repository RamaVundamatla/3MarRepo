    <JadeMethod name="restoreChassisInDetails" id="55ae9fcb-106c-47c3-aac8-1af012d49885">
        <updating/>
        <source>restoreChassisInDetails(_chassis : CMGTE_TILC; _vvr : CM_VehicleVisitRecord) updating;
/*
Date		Who		Reason
15/05/2009	cnwjk3	Initial creation
26/09/2013	cnwdap1	PAR #32536 Tare Weight In field is now a measurement table
21/08/2018 	jlgns1	Bug 39807: PEN - Clip On Unit disappears from a container when a chassis is received at the same time
*/
vars
	obj 	: Object;
begin
	if _chassis &lt;&gt; null then 
		self.txtChassisIDIn.text := _chassis.id;
		
		obj := app.myRoot.allOperators[_chassis.operatorCode];
		
		self.cmbOperatorIn.setObject(obj);
		if obj = null and self.myTerminal.roadProcessIsASPA then	//28 Oct 2020	NDL	TFS S50113
			self.cmbOperatorIn.setObject( self.myTerminal.getConfig(DefRecTrailOper).CM_Operator );
		endif;
		
		if _chassis.myTILCType &lt;&gt; null then
			obj := app.myRoot.allTILCTypes[_chassis.myTILCType.myCargoTypeExtTILC, _chassis.myTILCType.code];
			// cnwjk3 13/10/09 PAR 21224
			self.cmbTrlrTypeIn.listObject := obj;
		endif;

		if _chassis.weightTare &gt; 0 then
			self.txtTareChassIN.setValues(_chassis.weightTare.asStringJMT &amp; Space &amp; app.getDefaultMeasurementForType(Type_Weight).shortName  );	// PAR #32536
		endif;
		
		if _chassis.imexStatus &lt;&gt; 0 then														//Bug 39807
			self.cmbTrailIMEX.listObject := app.myRoot.allImexStatuses[_chassis.imexStatus];	//Bug 39807
		endif;																					//Bug 39807
		
	endif;
	
epilog

end;</source>
        <Parameter name="_chassis" type="CMGTE_TILC"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="restoreChassisOutByIdDetails" id="2f645bec-f0ec-4c82-9d79-997acc9bf5ff">
        <source>restoreChassisOutByIdDetails(_chassis : CMGTE_Release) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2009	cnwjk3	Initial creation

*/

vars
	locText :	 String;
	theTrailer : CM_TILC; 
begin
	if _chassis &lt;&gt; null and _chassis.isReleaseById then
		self.txtChassisIDOut.text := _chassis.id;
		theTrailer := self.getChassisLocation(_chassis.id,  locText);
		self.displayChassisOutLoc(locText);
		if theTrailer &lt;&gt; null then 
			setFieldsFromChassisOut(theTrailer);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_chassis" type="CMGTE_Release"/>
    </JadeMethod>
    <JadeMethod name="restoreChassisOutByTypeDetails" id="aff13c10-5bc6-49d1-b353-f8f1c0ed3909">
        <source>restoreChassisOutByTypeDetails(_chassis : CMGTE_Release) protected;
/*
Date		Who		Reason
15 May 2009	cnwjk3	Initial creation

*/
vars
	obj 	: Object;
	avGradeObj : CM_MTGrade;
	avGrade : Integer;
	avGrades  : String;
begin
	if _chassis &lt;&gt; null and not _chassis.isReleaseById then 
		obj := app.myRoot.allOperators[_chassis.operatorCode];
		
		self.cmbOperatorOut.setObject(obj);
		
		if _chassis.myTILCType &lt;&gt; null then
			obj := app.myRoot.allTILCTypes[_chassis.myTILCType.myCargoTypeExtTILC, _chassis.myTILCType.code];
			// cnwjk3 13/10/09 PAR 21224
			self.cmbTrlTypeOut.listObject := obj;
		endif;
		
		if _chassis.allAvailabilityGrades.size &gt; 0 then
			foreach avGrade in _chassis.allAvailabilityGrades do
				avGradeObj:=app.myRoot.allAvailabilityGrades[avGrade];
				if avGradeObj &lt;&gt; null then
					if avGrades = null then
						avGrades:=avGradeObj.description;
					else
						avGrades:=avGrades &amp; ", " &amp; avGradeObj.description;
					endif;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_chassis" type="CMGTE_Release"/>
    </JadeMethod>
    <JadeMethod name="saveGateEntity" id="e1f01b5e-6b1b-4667-90a5-c9c021bdda29">
        <updating/>
        <source>saveGateEntity(_isUpdate : Boolean; _pxyGTE : Object input; _validationOnly : Boolean; warningsToIgnore : IntegerArray) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Parameters: _pxyGTE is either an CMGTE_Entity (individual) or an CMGTE_EntityArray (multiple CMGTE_Entity for create).
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20 FEB 2023      NAVSA20         Bug 56328: EUP Testing | Object Not Found error in Road Gate when saving a Booking
// 21 Feb 2025		naviv1			JIRA-29374- EUP | Transaction Instrumentation - Gate
// 19/6/2025   		jlier1 			MTN-34221 refactoring validation so is before trx - validation only never set so removed
// 21 May 2025 		navlc30 		JIRA 34913 - TPT | Vehicle Truck Booking - Early Arrivals
// 14 Jan 2026 		navhl20 		Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------

vars
	result 				: Integer;
	vvRec 				: CM_VehicleVisitRecord;
	gte 				: CMGTE_Entity;
	realEntities 		: CMGTE_EntityArray; 
	// 20.02.2023 NAVSA20 TFS 56328 START
	cargoGroupTypeCount : Integer;
	iter 				: Iterator;
	obj 				: Object;
	msg 				: String;
	cargoGroupID 		: String;
	cargoGroupType 		: CM_CargoType;
	existingTI 			: CM_TrackedItem;
	pxyTI 				: CM_TrackedItem;
    // 20.02.2023 NAVSA20 TFS 56328 END
	vbsts				: CM_VehicleBookingTimeSlot;
	bulkRelease			: CM_BulkRelease;
	gteEntity			: CMGTE_Entity;	
begin
	vvRec := self.myRealVVR;
	if vvRec = null then	//22 Dec 2016	NDL	TFS 3134/2683 - can be null if called directly from CMUI_Picker
		if self.isOKToProceed() then
			vvRec := self.myRealVVR;
		endif;
	endif;
	
	// 20.02.2023 NAVSA20 TFS 56328 START
	
	//if _pxyGTE.CMGTE_Entity.cargoGroupId &lt;&gt; null then
	if _pxyGTE.isKindOf(CMGTE_Entity) and _pxyGTE.CMGTE_Entity.cargoGroupId &lt;&gt; null then	// ### TFS 56825 27Feb2023 NAVPW1
		cargoGroupTypeCount:=0;
		iter:=self.myTerminal.allCargoBOLTypes.createIterator;
		while iter.next(obj) do
			if not obj.isKindOf(CM_CargoType) then
				continue;
			endif;
			if obj.CM_CargoType.productType = ProductType_CargoGroup then
				cargoGroupType := obj.CM_CargoType;
				cargoGroupTypeCount := cargoGroupTypeCount+1;
			endif;
			if cargoGroupTypeCount &gt; 1 then
				break;
			endif;
		endwhile;
		if cargoGroupTypeCount = 1 then
			cargoGroupID := _pxyGTE.CMGTE_Entity.cargoGroupId;
			existingTI := self.myTerminal.allCargoGroupsByCargoTypeId.getAtKey( cargoGroupType.id, cargoGroupID );
				if existingTI = null then
				pxyTI := self.myTerminal.createTI(cargoGroupType, true);
				pxyTI.zSetPxyTerminal(self.myTerminal);
				pxyTI.setCargoType(cargoGroupType.id);
				pxyTI.zSetPxyId( cargoGroupID );
				pxyTI.setMyOperator(app.myRoot.allOperators[_pxyGTE.CMGTE_Entity.operatorCode]); //Get operator from the receive cargo form
				pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);
				pxyTI.zSetPxyCompany(self.myTerminal.getDefaultCompanyBank);
				while true do
					app.myTrxCA.trxCreateCargoGroup(pxyTI, existingTI, app.myPassport);
					msg := app.myPassport.getErrorsAndWarningsAsString;
					if app.myPassport.hasErrorsOrWarnings then
						result := app.showErrorWarningDialog(app.getErrorString(GateInOut),app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if result &lt;&gt; IDOK then
							return false;
						else 
							app.myPassport.warningsAcknowledged := true;
							continue;
						endif;
					endif;
					break;
				endwhile;
				endif;
				_pxyGTE.CMGTE_Receival.setMyCargoGroup(existingTI.CM_CargoGroup);
		endif;
	endif;
	
	
	// 20.02.2023 NAVSA20 TFS 56328 END


	while true do
		if _validationOnly then
			app.myValCA.valTrackedItemAttachment(_pxyGTE, app.myPassport);
		elseif _isUpdate then
			gte:=_pxyGTE.CM_Object.pxyGetRealObject.CMGTE_Entity;
			app.myTrxUA.trxUpdateInOutFlexiGateEntity(vvRec, _pxyGTE.CMGTE_Entity, app.myPassport);
		else
			if _pxyGTE.isKindOf(CMGTE_EntityArray) then
				app.myTrxCA.trxCreateInOutFlexiGateEntitys(vvRec, _pxyGTE.CMGTE_EntityArray, realEntities, false, app.myPassport);
			else
				app.myTrxCA.trxCreateInOutFlexiGateEntity(vvRec, _pxyGTE.CMGTE_Entity, gte, app.myPassport);
			endif;
		endif;
		
		if app.myPassport.trxCompletedOK  then
			//epr changes for CCMS 1386 ROB gate cargo
			if realEntities &lt;&gt; null then
				foreach gteEntity in realEntities do									//21.05.2025 navlc30 #34913
					if gteEntity.isCMGTE_Release() then
						bulkRelease := gteEntity.CMGTE_Release.myBulkRelease;						
						if bulkRelease &lt;&gt; null then					//only if it has a bulk release
							vbsts := bulkRelease.getVBTimeSlot();
							self.doVvrAssocToVbts(vbsts);
							self.setTxtPinToNullOrVbsId();
						endif;
					else
						break;
					endif;	
				endforeach;		
				
				foreach gte in realEntities do
					self.updateTruckLayoutFrame(gte);
				endforeach;
			else
				if gte &lt;&gt; null and gte.isCMGTE_Release() then											//21.05.2025 navlc30 #34913
					bulkRelease := gte.CMGTE_Release.myBulkRelease;
					if bulkRelease &lt;&gt; null then					//only if it has a bulk release
						vbsts := bulkRelease.getVBTimeSlot();
						self.doVvrAssocToVbts(vbsts);
						self.setTxtPinToNullOrVbsId();
					endif;
				endif;	
				
				self.updateTruckLayoutFrame(gte);
			endif;
				
             break;
		else
		
			//18 Nov 2011	NDL	Par 28527
			result := IDOK;
			app.myPassport.deleteWarningsFor( warningsToIgnore );
			if app.myPassport.hasErrorsOrWarnings then
				result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			
			//result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged := true;
				 continue;
			endif;
			return false;
		endif;
	
		return true;
	endwhile;
	
	//epr 8/8/12 so acknowledged warnings are suppressed on BIG SAVE from an update and not just the create
	//if not _validationOnly and  _pxyGTE.isKindOf(CMGTE_Entity) then
	if gte = null and not _validationOnly and  _pxyGTE.isKindOf(CMGTE_Entity) then	//16 Oct 2012	NDL	Par 30509
		gte:= _pxyGTE.CMGTE_Entity.pxyGetRealObject();
	endif;
	
	if  gte &lt;&gt; null then
		self.saveWarningsForObject(app.myPassport, gte, true /*true = clear out existing warnings*/);
	endif;

	return true;
epilog
	app.myPassport.clearErrorsToIgnore(); // PAR 17703 AKB2008SEP
	
	delete realEntities;
end;</source>
        <Parameter name="_isUpdate" type="Boolean"/>
        <Parameter name="_pxyGTE" type="Object" usage="input"/>
        <Parameter name="_validationOnly" type="Boolean"/>
        <Parameter name="warningsToIgnore" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveProxyVVR" id="e22ec9fc-de81-4d3b-82bc-e6db6d1f7474">
        <source>saveProxyVVR(_pxyVVR : CM_VehicleVisitRecord input):Boolean;
// ---------------------------------------------------------------------------
// Created:     08 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21/09/2009		cnwcs5			Handle default lane where gate area has no lanes
// 15/11/2012		cnwmh5			#30733 - Change to use updated method for queuing of receive / release non GC
// 15/04/2014		cnwdap1			PAR #33967 Prevent vehicle visit number being overwritten by a BAT number
// 04/05/2015		cnwdap1			PAR #36079 Extra logging to establish how bat number is overwriting vvr number
//	24 Feb 2021	NDL	TFS 50849 - Remove deug messages relative to Par 36079
// 10/01/2022		navdap1			TFS 52268 AAT 1-Stop VBS Integration
//	13/05/2022	 	navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
//	08 Feb 2024 	navhl20 		ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
// 13/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// ---------------------------------------------------------------------------

vars	
	ta				: CM_TerminalArea;				// cnwjk3 ccms 1071 18/02/10
	interchangeArea,								// cnwjk3 ccms 1071 18/02/10
	state,
	carrier,
	subCarrier,										//13/05/2022 navhl20 TFS 53430
	regNumber,
	driverCode,
	driverName: String;
	showTrouble		: Boolean;
	ownerTrailerID	: String;
	pxyGTE 		: CMGTE_Entity;
	gate			: CM_Gate;						// cnwcs5 21/09/2009
	aGate			: CM_GateArea;					// cnwcs5 21/09/2009
	lane			: CM_GateAreaLaneController;	// cnwcs5 21/09/2009
	realVVR			: CM_VehicleVisitRecord;		// cnwjk3 PAR 22828 16/03/2010
	bat				: CM_RFIDTag;					// PAR #33967
	timeOut 		: TimeStamp;					// ### TFS 52631 10Jan2022 NAVPW1
begin

	showTrouble := false;
	
//	app.writeLog(method.qualifiedName &amp; " proxy vvr number at start is " &amp; _pxyVVR.visitNumber, LogERROR);				// PAR #36079
//	app.writeLog(method.qualifiedName &amp; " txtVisitNumber at start is '" &amp; self.txtVisitNumber.text &amp; "'", LogERROR);	// PAR #36079
	
	// TFS 52268 check for 1-Stop VBS integration
	if self.myTerminal.is1STOPVBS and not self.myTerminal.is1STOPVBSConfigured then
		app.raiseCMException(OneStop_VBS_not_configured, null, null);
		return false;
	endif;
	// TFS 52268 end
	
	ta := self.cmbInterchange.listObject.CM_TerminalArea;	// cnwjk3 ccms 1071 18/02/10
	if ta &lt;&gt; null then										// cnwjk3 ccms 1071 18/02/10
		interchangeArea := ta.id;							// cnwjk3 ccms 1071 18/02/10
	endif;													// cnwjk3 ccms 1071 18/02/10
		
	// ### Set Proxy
	if self.cmbCarrier.listObject &lt;&gt; null then
		carrier := self.cmbCarrier.listObject.CM_Carrier.code;
	endif;
	
	//Start 13/05/2022 navhl20 TFS 53430
	if self.cmbSubCarrier.listObject &lt;&gt; null then
		subCarrier := self.cmbSubCarrier.listObject.CM_Carrier.code;
	endif;
	//End 13/05/2022 navhl20 TFS 53430
	
	//epr CCMS GHA 2369 26/11/14
	if self.txtRegno.visible then
		regNumber := self.txtRegno.text.trimBlanks();
	else
		regNumber:= self.cmbRegNo.text.trimBlanks();
	endif;
	state := self.txtState.text.trimBlanks();
	if self.chkAutoComplete.enabled and self.chkAutoComplete.value then
		_pxyVVR.setAutoComplete(true);	
		_pxyVVR.setTimeIn(self.txtDateIn.getDate(),self.txtTimeIn.getTime());
		timeOut.setDate(self.txtDateIn.getDate()); 	// ### TFS 52631 10Jan2022 NAVPW1
		timeOut.setTime(self.txtTimeIn.getTime()); 	// ### TFS 52631 10Jan2022 NAVPW1
		_pxyVVR.setTimeOut(timeOut); 				// ### TFS 52631 10Jan2022 NAVPW1
	elseif self.myTerminal.roadProcessIsASPA then	//01 Oct 2020	NDL	TFS 49189
		_pxyVVR.setAutoComplete(false);
		_pxyVVR.setTimeIn(self.txtDateIn.getDate(),self.txtTimeIn.getTime());
	else
		//+cnwml2 PAR24842
		_pxyVVR.setAutoComplete(false);
		_pxyVVR.setTimeIn(null, null);
	endif;///autocompletecnwas3
	
	if self.chkOpsRetrospective.visible and self.chkOpsRetrospective.value then				//08.02.2023 navhl20 #62084[62379]
		_pxyVVR.setTimeIn(self.txtDateIn.getDate(),self.txtTimeIn.getTime());
	endif;
	
	//cnwas3 begin
	//_pxyVVR.setIsUpdatable(false); //cnwas3
	self.setDoorsDirectionForContainers(_pxyVVR);	// // Set the door directions. #25789 12/10/2010
	//epr changes for CCMS 1386 ROB gate cargo
	
	//  if the a-gate does not have lanes then we don't show them in the lane combo and we 
	//	use the default inward lane for the gate area
	gate := self.cmbGate.listObject.CM_Gate;						// cnwcs5 21/09/2009
	
	if gate &lt;&gt; null then											// cnwcs5 21/09/2009
		aGate := gate.getFirstAGate_IN;								// cnwcs5 21/09/2009
	endif;															// cnwcs5 21/09/2009
	
	if aGate &lt;&gt; null and 											// cnwcs5 21/09/2009
		aGate.laneCount = 0 then									// cnwcs5 21/09/2009
		lane := aGate.getDefaultLane_IN;							// cnwcs5 21/09/2009
	else															// cnwcs5 21/09/2009
		lane := self.cmbGateLanes.listObject.CM_GateAreaLaneController;	// cnwcs5 21/09/2009
	endif;															// cnwcs5 21/09/2009
	
	//epr CCMS GHA 2369 26/11/14
	if self.cmbDriver.visible then
		if self.cmbDriver.listObject &lt;&gt;  null then	
			driverCode := self.cmbDriver.listObject.CM_DriverDetails.code;
			driverName:= self.cmbDriver.listObject.CM_DriverDetails.name;
		endif;
	else
		driverName := self.txtDriverName.text;
		
		if self.cmbDriverCode.visible then
			if self.cmbDriverCode.listObject &lt;&gt; null then	
				driverCode := self.cmbDriverCode.listObject.CM_DriverDetails.code;
			endif;
			
			if driverName &lt;&gt; null and driverCode = null then
				//  make sure a code is selected if a name with a duplicate is entered 
				app.raiseCMException(Input_require_driver_code, null, null);
				self.cmbDriverCode.setFocus();
				return false;
			endif;
			
		else
			driverCode := self.txtDriverCode.text;
		endif;
	endif;
		
	
	// cnwjk3	09/10/09 PAR 21026 
	//_pxyVVR.setProxyFlexiGate(driverCode, driverName, carrier, regNumber, state, interchangeArea, self.myTerminal, gate, lane, ownerTrailerID);			//13/05/2022 navhl20 TFS 53430
	_pxyVVR.setProxyFlexiGate(driverCode, driverName, carrier, subCarrier, regNumber, state, interchangeArea, self.myTerminal, gate, lane, ownerTrailerID);	//13/05/2022 navhl20 TFS 53430
				
				
	//14 Oct 2020	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		//ASPA road process MUST have a trailer, if no number use the VVR number
		_pxyVVR.setVisitNumber(self.txtVisitNumber.text);	//11 Nov 2020	NDL	TFS 50329
		if self.txtChassisIDIn.text.trimBlanks = null then
			self.txtChassisIDIn.text := _pxyVVR.visitNumber;
		endif;
	endif;
	
	// TFS 52268 attach booking slots to proxy VVR
	if self.myTerminal.roadProcessIs1StopVBS() then
		_pxyVVR.setProxyBookingSlots(self.all1StopVBSDetails);
	endif;
	// TFS 52268 end of this bit
	
	if self.txtChassisIDIn.text &lt;&gt; null then	// we have in-chassis details.
		// Only create IN trailer GTE if not owned, otherwise we are just storing the 
		// owned trailer id on the VVR 
		if ownerTrailerID = null then
			// save chassis in info as proxy on vvr record
			self.createPxyChassisIN(self.txtChassisIDIn.text, _pxyVVR);
		else																												// cnwjk3 PAR 22828 16/03/2010
			// See if the id has changed since we created the real object													// cnwjk3 PAR 22828 16/03/2010
			realVVR := _pxyVVR.pxyGetRealObject();																			// cnwjk3 PAR 22828 16/03/2010
			if realVVR &lt;&gt; null then																							// cnwjk3 PAR 22828 16/03/2010
				if realVVR.myInCMGTE_Chassis &lt;&gt; null and realVVR.myInCMGTE_Chassis.id = _pxyVVR.myInCMGTE_Chassis.id then	// cnwjk3 PAR 22828 16/03/2010
					// we have the same trailer id as before, but now the "own trailer" checkbox is checked					// cnwjk3 PAR 22828 16/03/2010
					pxyGTE :=  _pxyVVR.myInCMGTE_Chassis;																	// cnwjk3 PAR 22828 16/03/2010
					delete pxyGTE;																							// cnwjk3 PAR 22828 16/03/2010
				endif;																										// cnwjk3 PAR 22828 16/03/2010
			endif;																											// cnwjk3 PAR 22828 16/03/2010
		endif;
	elseif _pxyVVR.myInCMGTE_Chassis &lt;&gt; null then
		// delete the pxy IN chassis, as there was one before but now it has been removed from the GUI
		pxyGTE :=  _pxyVVR.myInCMGTE_Chassis;
		delete pxyGTE;
	endif;

	if self.optChassisRelID.value and self.txtChassisIDOut.text &lt;&gt; null
	or self.optChassisRelTyp.value and self.cmbTrlTypeOut.listObject &lt;&gt; null
	or ( self.txtChassisIDIn.text &lt;&gt; null and self.cmbTrailIMEX.listObject &lt;&gt; null and self.cmbTrailIMEX.listObject = app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD])	//09 Apr 2018	NDL	TFS 37594
	then	// we have in-chassis details.
		// save chassis out info as proxy on vvr record
		if grpTrailerOut.enabled then
			if _pxyVVR.myInCMGTE_Chassis = null or _pxyVVR.myInCMGTE_Chassis.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then	//08 Aug 2017	NDL	TFS 5741
				self.createPxyChassisOUT( _pxyVVR);
			endif;
		endif;
	elseif _pxyVVR.myOutCMGTE_Chassis &lt;&gt; null then
		pxyGTE :=  _pxyVVR.myOutCMGTE_Chassis;
		delete pxyGTE;
	endif;
	if not self.myTerminal.getConfig(GateInAutoVisitNo).Boolean then
		// PAR #33967 If we are configured to use a security gate, and txtVisitNumber contains 	// PAR #33967
		// a bat number, don't update the visit number											// PAR #33967
//		app.writeLog(method.qualifiedName &amp; " Looking for a bat number of '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);	// PAR # 36079
		bat := self.myTerminal.allRFIDTagsByCode[self.txtVisitNumber.text];						// PAR #33967
		if self.myTerminal.getConfig(SiteHasSecurityGate).Boolean and bat &lt;&gt; null then			// PAR #33967
//			app.writeLog(method.qualifiedName &amp; " Found a bat  '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);				// PAR # 36079
//			app.writeLog(method.qualifiedName &amp; " Leaving '" &amp; _pxyVVR.visitNumber &amp; "' on the proxy vvr", LogINFO);		// PAR # 36079
		else																					// PAR #33967
//			app.writeLog(method.qualifiedName &amp; " Didnt find a bat for '" &amp; self.txtVisitNumber.text &amp; "', setting vvr", LogINFO);	// PAR # 36079
			_pxyVVR.setVisitNumber(self.txtVisitNumber.text);
		endif;																					// PAR #33967
//	else
//		app.writeLog(method.qualifiedName &amp; " self.myTerminal.getConfig(GateInAutoVisitNo) is true", LogINFO);			// PAR # 36079
	endif;
	
	//16 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		if not _pxyVVR.timeIn.isValid then
			app.raiseCMException(Date_Enter_Valid, null, null);
			return false;
		endif;
		if self.cmbTrlrTypeIn.listObject = null then
			app.raiseCMException1(Must_select_type_trailer, null, null, null);
			self.cmbTrlrTypeIn.setFocus();
			return false;
		endif;
	endif;
	
	return true;
	
epilog
	
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveWarningsForObject" id="b05c7aaf-bd47-4531-8f39-f63288dea5ce">
        <updating/>
        <source>saveWarningsForObject(_passport : CM_Passport; _realObj : CM_Object; _clearExistingWarnings : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwjk3	PAR 23206

*/

vars
	warning 	: CM_Error;
	realObj 	: Any;
	arrWarnings	: HugeStringArray;
begin

	if _realObj = null then
		return;
	endif;
		
	if _realObj.isTransient then 
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting real object but was passed a transient.");
		return;
	endif;
		
	// See if we already have saved warnings for this particular object
	arrWarnings := self.allWarningsByOid[_realObj.getOidString()].HugeStringArray;
	
	if arrWarnings = null then
		
		// we haven't had warnings for this instance beforem,  so we need to create an array to hold them 
		create arrWarnings transient;
		// Now key it into the collection
		self.allWarningsByOid[_realObj.getOidString()] := arrWarnings;
	elseif _clearExistingWarnings then
		arrWarnings.clear();
	endif;
	
	// Now add the warnings to the array for the object
	foreach warning in _passport.allErrorWarnings do
		arrWarnings.add(warning.text);
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_realObj" type="CM_Object"/>
        <Parameter name="_clearExistingWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set1StopBookingSlotsOnVVR" id="c6b6952d-f0ef-4f22-b794-8020091c2fc2">
        <source>set1StopBookingSlotsOnVVR(_idToMatch : String; _response : CMIF_1StopBookingResponse);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 07/08/2023   navma1		Bug 57593: MTN - Road Process 1Stop null Voyage Issue
//
vars
	detailsToDelete : ObjectArray;
	detail 			: Object;
	booking 		: CMIF_1StopBookingData;

begin
	create detailsToDelete transient;
	
	foreach booking in self.all1StopVBSDetails do
		if booking.id &lt;&gt; null then
			if booking.id = _idToMatch or booking.id.cnContains(":" &amp; _idToMatch) then
				detailsToDelete.add(booking);
			endif;
		endif;
	endforeach;
	
	foreach detail in detailsToDelete do
		self.all1StopVBSDetails.remove(detail.CMIF_1StopBookingData);
	endforeach;
	
	detailsToDelete.purge;
	
	if _response &lt;&gt; null then									//07.08.2023 navma1 #57593	
		_response.data.copy(self.all1StopVBSDetails);
	endif;
epilog
	
	delete detailsToDelete;
end;</source>
        <Parameter name="_idToMatch" type="String"/>
        <Parameter name="_response" type="CMIF_1StopBookingResponse"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="efadc771-a49e-44c1-87bd-144e608203ae">
        <updating/>
        <source>setCaption(_caption: String) updating;
//09 September 2009	cnwml2


vars
	caption : String;
begin

	caption := "Road Gate";
	inheritMethod(caption);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setChassisInFieldsFromMaster" id="60a61273-4932-45db-8f2d-80e805f2144e">
        <source>setChassisInFieldsFromMaster(_trailer : CM_TIMasterTILC) protected;
/*
Date		Who		Reason
04/09/2009	cnwjk3	Initial creation
26/09/2013	cnwdap1	PAR #32536 Tare Weight In field is now a measurement table
*/
vars
	measure : CM_MeasurementType;							// PAR #32536

begin
	if self.myAssistant.validateMasterTILCType(_trailer.myTILCType, self.cmbTrlrTypeIn.listObject.CM_TILCType) = MsgBox_Return_OK then
		// cnwjk3 13/10/09 PAR 21224
		self.cmbTrlrTypeIn.listObject := _trailer.myTILCType ;
	endif;

	if self.myAssistant.validateMasterOperator(_trailer.myOperatorNew, self.cmbOperatorIn.listObject.CM_Operator) = MsgBox_Return_OK then
		self.cmbOperatorIn.setObject(_trailer.myOperatorNew);
	endif;
	
	//self.txtTareChassIN.text := _trailer.tWeight.asStringWeightJMT();																	// PAR #32536
	measure := app.getDefaultMeasurementForType(Type_Weight);																			// PAR #32536
	self.txtTareChassIN.setValues(app.convertMeasurementForDisplay(measure.shortName, _trailer.tWeight) &amp; Space &amp; measure.shortName);	// PAR #32536
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trailer" type="CM_TIMasterTILC"/>
    </JadeMethod>
    <JadeMethod name="setDefaultGate" id="4e0c1f4e-c77d-4570-bbf3-e807f8493878">
        <updating/>
        <source>setDefaultGate() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwjk3	PAR 23184

*/

vars

	gate : CM_Gate;
	localXML : String;
	
begin

	localXML := self.xmlForReceiveTrailer;	//21 Jan 2018	NDL	TFS 42951 - because 'getXMLSettingsForSetup' clobbers whatever the user has setup in this session.

	self.getXMLSettingsForSetup();
	
	if localXML &lt;&gt; null then
		self.setTrailerReceiveDefs( localXML, true );	//21 Jan 2018	NDL	TFS 42951 - because 'getXMLSettingsForSetup' above clobbers whatever the user has setup in this session.
	endif;
	
	gate := self.getDefaultGate();									
	if gate &lt;&gt; null and self.cmbGate.findObject(gate) &lt;&gt; -1 then	
		self.doChangeGate(gate);									
	else															
		self.cmbGate.setIndex(1);
		self.doChangeGate(self.cmbGate.listObject.CM_Gate);			
	endif;
	
	//epr TFS 5328 31/7/17 
	gate := self.cmbGate.listObject.CM_Gate;
	if gate &lt;&gt; null then	
		if self.cmbInterchange.visible and  self.myTerminal.getConfig(GateDefaultInterchange).Boolean then
			self.doChangeInterChanArea(gate);																		//+TFS4311
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetailsChanged" id="c8f0f0a2-a8f8-4a72-87ee-40257bb84f1f">
