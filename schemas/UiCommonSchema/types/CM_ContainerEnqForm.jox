    <JadeMethod name="initForCurrentObject" id="9c92c68e-7ab3-4668-9701-3f7a95fd2296">
        <updating/>
        <source>initForCurrentObject() updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myCurrentObject = null then
		return;
	endif;
	//epr TFS 47132 30/12/19
	if not self.useSelectorTable then
	
		if self.myCurrentObject.isKindOf(CM_TrackedItem) then
			self.initForTrackedItem(self.myCurrentObject.CM_TrackedItem);		// 32673
		elseif self.myCurrentObject.isKindOf(CM_SOHLocation) then
			self.initForSOHLocation(self.myCurrentObject.CM_SOHLocation);
		elseif self.myCurrentObject.isKindOf(CM_LogController) then
			self.initForLocationsController(self.myCurrentObject.CM_LogController);
		endif;
	endif;
	
	self.setFilterValues();
end;</source>
    </JadeMethod>
    <JadeMethod name="initForLocationsController" id="4af0ee5d-4320-4bce-9fe3-87f2b07cc1fb">
        <updating/>
        <source>initForLocationsController(_theLocation : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTi	: CM_TrackedItem;
	tmpType	: Integer;
	idx : Integer;		// cnwrd1 4.7.2008 par #17447 ++

begin

	if _theLocation = null then
		return;
	endif;
	
	tmpTi := _theLocation.allTrackedItems.first;
	if tmpTi &lt;&gt; null then
		self.myCurrentCargoBOLType := tmpTi.myCargoType;
		self.myAssistant.comboBoxCargoBolType(cmbFiltTiType, tmpTi.cargoType, true, true, true, true);
	else
		tmpType := self.getDefaultTiType(self.myCurrentCargoBOLType);
		self.myAssistant.comboBoxCargoBolType(cmbFiltTiType, tmpType, true, true,true, true);
	endif;
	
	if self.useSelectorTable then
		//epr TFS 47132 14/11/19
		self.createDefaultCritLineHolder(self.myCurrentCargoBOLType,_theLocation);
		return;
	endif;
	
	self.cmbFiltTiType.lostFocus(cmbFiltTiType);	
	self.cmbFiltTiType.click(cmbFiltTiType);	
	
//  CCMS1235 new combobox object. 	
//	self.myAssistant.comboBoxSupplier(cmbFiltOperator, null);
//par 11124	 rs1 dec 2005
	self.tblSearch.setValueByName(ETRow_FilterId, null);
	self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, null);
	self.tblSearch.setValueByControlName(cmbFiltVoyage.name, null);
	if _theLocation.myTerminalArea &lt;&gt; null then
		self.myAssistant.comboBoxTAType(cmbFiltTAType, _theLocation.myTerminalArea.myType, false);	
		tblSearch.setValueByControlName(cmbFiltTAType.name, cmbFiltTAType.text);
	
		self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, _theLocation.myTerminalArea.myType.type, _theLocation.myTerminalArea);	
			
		self.cmbFiltTermArea.lostFocus(cmbFiltTermArea);
		self.setFilterTerminalArea(_theLocation.myTerminalArea);
	
		if self.filterTerminalArea.isKindOf(CM_IrregularBlockArea) then	//  Par 32308
//				self.allLCsSet.clear(); // PAR 32308 getting a collection deleted error on combobox
		//		self.filterTerminalArea.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.);
		//		self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
			self.myAssistant.comboBoxLocationControllers(cmbFiltYardLocn, self.filterTerminalArea.getLCsCollectionForDisplay(), false);
		else
			self.myAssistant.comboBoxLocationControllers(cmbFiltYardLocn, self.filterTerminalArea.getLCsCollectionForDisplay(), false);
		endif;
		
		self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, _theLocation.displayEntry());
		cmbFiltYardLocn.listObject := _theLocation;
		self.filterYardLocation := _theLocation;
	elseif _theLocation.isKindOf(CM_LogVoyageController) then	//par 11124	 rs1 dec 2005
//		self.tblSearch.setValueByControlName(cmbFiltVoyage.name, _theLocation.CM_LogVoyageController.myLogVoyage.displayEntry());
		self.tblSearch.setValueByControlName(cmbFiltVoyage.name, _theLocation.CM_LogVoyageController.myVoyage.displayEntry());
//		cmbFiltVoyage.listObject := _theLocation.CM_LogVoyageController.myLogVoyage;

		idx := self.cmbFiltVoyage.findObject(_theLocation.CM_VoyageController.myVoyage);  // cnwrd1 4.7.2008 par #17447 ++
		if idx &gt; 0 then
			cmbFiltVoyage.listObject := _theLocation.CM_VoyageController.myVoyage;	
		endif;																				// cnwrd1 4.7.2008 par #17447 ++
		
		//cmbFiltVoyage.listObject := _theLocation.CM_VoyageController.myVoyage; // cnwrd1 4.7.2008 par #17447 --
		
//		self.filterVoyage := _theLocation.CM_LogVoyageController.myLogVoyage;
		self.filterVoyage := _theLocation.CM_VoyageController.myVoyage;
	endif;
end;</source>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="initForSOHLocation" id="5bfe510c-0b3c-43db-918f-686f1f42ca82">
