    <JadeMethod name="tblSrchResults_queryRowColChg" id="18210da1-9316-4dca-8d7b-31fb9109b95d">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSrchResults_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//-----------------------------------------
//Created: August 2002 By: cnwgd1
//-----------------------------------------
vars
	str		: String;
	cntrl	: Control;
begin

	if table.row &lt;= table.fixedRows then
		return true;
	endif;
	
	str := table.accessCell(table.row, table.columns).text;
	if str &lt;&gt; null then
		if str[1].toUpper = 'A' then
			table.accessCell(table.row, table.columns).text := 'All';

		endif;
		if str[1].toUpper = 'R' then
			table.accessCell(table.row, table.columns).text := 'Remaining';
		endif;
	endif;

	cntrl := table.accessCell(table.row, table.columns).cellControl;
	if cntrl &lt;&gt; null then
		cntrl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		cntrl.TextBox.case := TextBox.Case_None;
	endif;
	
	return true;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblSrchResults_rowColumnChg" id="c95c1a08-f6bd-45b4-a4e8-492da507ae9c">
