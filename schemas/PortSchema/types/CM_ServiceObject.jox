    <JadeMethod name="validateDuplicates" id="50dc7a44-bf55-4930-a329-4d0c30092dea">
        <source>validateDuplicates();
// ---------------------------------------------------------------------------
// Created:		24 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/12/2014   cnwdb2	PAR #35364
// ---------------------------------------------------------------------------
vars
begin
	if self.bank.serviceObjects.includesKey(self.name) then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Service",self.name,null,null,null);
		app.raiseCMException1(Already_exists_service,self.name,null,null); //cnwdb2	PAR 35364
  
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a4f4f0b8-c977-4a6d-a33d-df63bd440a3a">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/12/2014   cnwdb2	PAR #35364
// ---------------------------------------------------------------------------

vars
	temObject : CM_Object;
	temServiceGroup : CM_ServiceGroup;
begin
	if self.name = null then // cnwrs1 mar 2006
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
	endif;
	if self.genLCode &lt;&gt; null then
		if self.genLCode.services[self.name] &lt;&gt; null then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Service",self.name,"GL Code " &amp; self.genLCode.code &amp; " Already used this service",null,null);
			app.raiseCMException2(Already_exists_service_glCode,self.name,self.genLCode.code,null,null); //cnwdb2	PAR 35364
		endif;
	endif;
	self.validateDuplicates();

end;</source>
    </JadeMethod>
