<Class name="CM_RemoteRejectDtl" id="f066e7de-f9fc-4d79-9707-fd4b4208d96b">
    <superclass name="CM_RemoteDataDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="reasonCode" id="db502b46-2af2-4c8c-88a5-160571a659ec">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="recoveryCode" id="5d949e6a-6417-40d0-8153-50eb379aca77">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="tagAttribute" id="bfb615be-cab9-4937-b984-aca17be01361">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doRejection" id="51f78fe2-041c-4e70-9a64-88675005fd36">
        <source>doRejection(_errorSet : CM_ErrorSet input);

vars

	terminal			: CM_Terminal;
	remoteRejectExtra	: CM_RemoteRejectExtra;
	iter				: Iterator;
	class				: Integer;
	tiSet				: CM_TISet;
	remoteDtl			: CM_RemoteDataDtl;	
	taType				: Integer;		

begin

	self.getLogConstant(self.tagAttribute, class, taType);
	if class = 0 then
		app.raiseCMException1(Err_InvalidClass, self.tagAttribute, null, null);
	endif;
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, self.myRemoteDataHdr.terminal, null, null);
	endif;
	create tiSet transient;
	iter := self.allRemoteDataExtra.createIterator;
	while iter.next(remoteRejectExtra) do
		remoteRejectExtra.doRejection(terminal, class, _errorSet, tiSet);
	endwhile;
	if tiSet.size &gt; 0 then
		app.myTrxUA.trxRejectTrackedItems(tiSet, self.reasonCode, 
									self.recoveryCode, null, 'BGP', app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			_errorSet.copyErrors(app.myPassport.allErrorWarnings);
		else
			_errorSet.copyErrors(app.myPassport.allWarnings);
			remoteDtl := self;
			app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDtl, true, app.myPassport);
		endif;
	endif;

epilog

	delete tiSet;
	delete iter;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="2bf8e9bd-50d1-4c25-befd-72f62a09ac60">
        <source>getDescription(): String;

vars

begin
	return 'Rejections detail (' &amp; self.allRemoteDataExtra.size.String &amp; ')';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="dbda31fe-2ff0-48ae-9f4c-4a2ec0f38b64">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteRejectDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

vars

	pxyRemoteDataExtra		: CM_RemoteDataExtra;
	realRemoteRejectExtra	: CM_RemoteRejectExtra;

begin

	inheritMethod(_proxy, _realRemoteHdr);
	self.reasonCode		:= _proxy.reasonCode;
	self.recoveryCode	:= _proxy.recoveryCode;
	self.tagAttribute	:= _proxy.tagAttribute;
	
	foreach pxyRemoteDataExtra in _proxy.allRemoteDataExtra do
		create realRemoteRejectExtra persistent;
		realRemoteRejectExtra.setForCreate(pxyRemoteDataExtra.CM_RemoteRejectExtra, self);
	endforeach;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteRejectDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForReject" id="2c5d2831-9f6a-4b3a-91e9-39e624cbc879">
        <updating/>
        <source>setProxyForReject(_remoteHdr : CM_RemoteDataHdr; _reasonCode, _recoveryCode, _class : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.reasonCode		:= _reasonCode;
	self.recoveryCode	:= _recoveryCode;
	self.tagAttribute	:= _class;
	self.setProxy(_remoteHdr);

end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_reasonCode" type="String"/>
        <Parameter name="_recoveryCode" type="String"/>
        <Parameter name="_class" type="String"/>
    </JadeMethod>
</Class>
