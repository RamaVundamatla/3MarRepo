    <JadeMethod name="doHandleNotification" id="023c8d7d-9a1c-4b2f-ab1a-de1d4d136657">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	msg : String;

begin

	if eventType = Object_Delete_Event then
		if theObject = self.myDutyDoc or theObject = self.myDutyDocItem then
			if theObject = self.myDutyDoc then
				msg := app.getErrorString1(Editi_been_delet_anoth_user_th,"Duty Document");
			else
				msg := app.getErrorString1(Editi_been_delet_anoth_user_th,"Duty Document Item");
			endif;
			app.msgBox(msg, app.getErrorString(Warning),MsgBox_OK_Only);
			self.unloadForm();
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
