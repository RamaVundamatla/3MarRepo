    <JadeMethod name="doCancelTask" id="db366b09-dd8b-4def-825f-8d55386fbb0f">
        <updating/>
        <source>doCancelTask(rtQueueEntry : CM_RTQueueEntry input; 
			_restore : Boolean;
			_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:	//set task status unassigned
			//if the task has been moved move it back


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
04 December 2009	conkc1	Handle deadlock replay 	PAR 20338 18807

*/
vars

	result     : Boolean;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		doCancelTaskBody(rtQueueEntry,	_restore, _errorMsgs);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		// No point trying again if we've encountered an error
		if app.myPassport.hasErrors() then		// TFS 42848 jlgmd1 10/01/2019
			break;								// TFS 42848 jlgmd1 10/01/2019
		endif;									// TFS 42848 jlgmd1 10/01/2019
	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_restore" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancelTaskBody" id="1a4f98ea-59c5-40a1-81cb-7fc7ff995d66">
        <updating/>
        <source>doCancelTaskBody(rtQueueEntry : CM_RTQueueEntry input; 
			_restore : Boolean;
			_errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:	//set task status unassigned
			//if the task has been moved move it back

Return Value:	

Date				Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
09 December 2009	conkc1	Created to allow deadlock replay PAR 20338 18807 
*/
vars
	allTasks			: CM_RTQueueTaskArray;
	rtQueueTask			: CM_RTQueueTask;
	error : CM_Error;
	invalidObject,
	result	: Boolean;
begin
	
	
	if rtQueueEntry = null then
		rtQueueTask:=self.getCurrentTask ;
		if rtQueueTask = null then
		//presume its been deleted so return don't give error
			return;
		endif;
	else
		on Exception do app.handleDeletedObject(exception, rtQueueEntry, invalidObject);
		
		if rtQueueEntry.allTasks.size &gt; 0 and not invalidObject then
			rtQueueTask	:=rtQueueEntry.allTasks.first;
		endif;
		if invalidObject then
			return;
		endif;
	endif;
	
	create allTasks transient;
	allTasks.add(rtQueueTask);
	
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		//epr TFS 995 16/5/17 
		app.myTrxUA.trxMachineRejectTasks(self.myMachine,allTasks,false,app.myPassport);
	//	app.myTrxRT.trxCancelTasks(allTasks,self.myMachine,app.myPassport,false);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	
	if overstowTI &lt;&gt; null then
		overstowTI := null;
	endif;
	
epilog
	delete allTasks;
end;</source>
        <access>protected</access>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_restore" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancelTasks" id="44897230-ce3e-4f39-976e-7bd48cac7042">
        <updating/>
        <source>doCancelTasks(_rtQueueTasks : CM_RTQueueTaskArray input; 
			_restore,
			_addToRejectList :  Boolean;
			_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:	//set task status unassigned
			//if the task has been moved move it back


Return Value:		

Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
04 December 2009	conkc1	Handle deadlock replay 	PAR 20338 18807
*/
vars

	result     : Boolean;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		doCancelTasksBody(_rtQueueTasks, _restore,_addToRejectList, _errorMsgs);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_restore" type="Boolean"/>
        <Parameter name="_addToRejectList" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancelTasksBody" id="aa28ee23-037e-4b8c-9d6c-5270f1899070">
        <updating/>
        <source>doCancelTasksBody(_rtQueueTasks : CM_RTQueueTaskArray input; 
			_restore,
			_addToMachineRejectList: Boolean;
			_errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:	//set task status unassigned
			//if the task has been moved move it back
			_addToMachineRejectList set to true  if you want yo explicitly reject

Return Value:		


Date				Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
09 December 2009	conkc1	Created to allow deadlock replay PAR 20338 18807 

*/
vars
	rtQueueTask			: CM_RTQueueTask;
	error : CM_Error;
	result,
	invalidObject : Boolean;
	allRTQueueTasks : CM_RTQueueTaskArray;
	 	
begin
	
	
	create allRTQueueTasks transient;
	// can only cancel tasks that are cancel all accepted rt entries
	if _rtQueueTasks = null then
		
		if self.myMachine.allCurrentWorkingQueueTasks.size = 0 then
			return;
		endif;
		
		self.myMachine.allCurrentWorkingQueueTasks.copy(allRTQueueTasks);
		
	else
		_rtQueueTasks.copy(allRTQueueTasks);
		
	endif;
	
	
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		
		//epr 16/5/17 tfs 995
		app.myTrxUA.trxMachineRejectTasks(self.myMachine,allRTQueueTasks,_addToMachineRejectList,app.myPassport);
		
		//app.myTrxRT.trxCancelTasks(allRTQueueTasks,self.myMachine,app.myPassport,_addToMachineRejectList);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
			
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
		
	endwhile;
	
	if overstowTI &lt;&gt; null then
		overstowTI := null;
	endif;
	
epilog
	delete allRTQueueTasks;

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_restore" type="Boolean"/>
        <Parameter name="_addToMachineRejectList" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doChangeQueue" id="05c27575-7d5d-4942-aa58-b96fcfc24a83">
        <updating/>
        <source>doChangeQueue(_queue : CM_RadioTelemetryQueue input; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
15 Jan 2013	NDL	Par 30920 - code moved to doChangeQueueBody, and dead lock handler added.

*/
vars

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doChangeQueueBody( _queue, _errorMsgs );
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;
	
/*
vars
	proxyMachine : CM_Machine;
	error : CM_Error;
	//queue : CM_RadioTelemetryQueue;
	loadStateSet : Boolean;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	if self.myTerminal.radioTelemetry = null then
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Terminal radioTelemetry is null"),_errorMsgs);
		return;
	endif;
	if self.myTerminal.radioTelemetry.masterQueue = null then
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Terminal master queue is null"),_errorMsgs);
		return;
	endif;
	
	//queue:= self.myTerminal.radioTelemetry.masterQueue.allSubQueuesById[_queueId];
	if _queue = null then
		self.addError(Err_InvalidQueue,app.getErrorString1(Err_InvalidQueue,null),_errorMsgs);
		return;
	endif;
	
	if _queue = self.myRTQueue then
		//already in this queue
		return;
	endif;
	
	if self.myMachine.currentQueueTask &lt;&gt; null then
		self.addError(Change_queue_working_task,app.getErrorString(Change_queue_working_task),_errorMsgs);
		return;
	endif;
	app.cmsBeginLoad(loadStateSet);
	proxyMachine := self.myMachine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	app.myTrxUA.trxUpdateMachineQueue(proxyMachine, _queue,app.myPassport);
	if self.createErrorsFromPassport(_errorMsgs) then
		return;
	endif;
	
	//epr par 25880 there is the potential that the queue may not change but the trx completed ok
	// i.e. if machine is working it will just queue up to move the machine after the completed task
	self.myRTQueue:=self.myMachine.myPrimaryQueue;
	self.resetNotes();
	

epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	delete proxyMachine;
end;

*/</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doChangeQueueBody" id="e8b885f6-6cbc-4d89-b855-5883dfd84830">
        <updating/>
        <source>doChangeQueueBody(_queue : CM_RadioTelemetryQueue input; _errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920

*/

vars
	proxyMachine : CM_Machine;
	error : CM_Error;
	loadStateSet : Boolean;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	if self.myTerminal.radioTelemetry = null then
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Terminal radioTelemetry is null"),_errorMsgs);
		return;
	endif;
	if self.myTerminal.radioTelemetry.masterQueue = null then
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Terminal master queue is null"),_errorMsgs);
		return;
	endif;
	

	if _queue = null then
		self.addError(Err_InvalidQueue,app.getErrorString1(Err_InvalidQueue,null),_errorMsgs);
		return;
	endif;
	
	if _queue = self.myRTQueue then
		//already in this queue
		return;
	endif;
	
	if self.myMachine.currentQueueTask &lt;&gt; null then
		self.addError(Change_queue_working_task,app.getErrorString(Change_queue_working_task),_errorMsgs);
		return;
	endif;
	app.cmsBeginLoad(loadStateSet);
	proxyMachine := self.myMachine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	app.myTrxUA.trxUpdateMachineQueue(proxyMachine, _queue,app.myPassport);
	
	if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
		return;
	endif;
		
	if self.createErrorsFromPassport(_errorMsgs) then
		return;
	endif;
	
	//epr par 25880 there is the potential that the queue may not change but the trx completed ok
	// i.e. if machine is working it will just queue up to move the machine after the completed task
	self.myRTQueue:=self.myMachine.myPrimaryQueue;
	self.resetNotes();
	

epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	delete proxyMachine;
end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
