    <JadeMethod name="verifyEDIDataTIs" id="4f549108-66d6-434b-ac19-27ec81859b79">
        <updating/>
        <source>verifyEDIDataTIs( _passport : CM_Passport input ) : Integer updating;

/*
Purpose:	To verify the EDI Data loaded.

Changes

Date		Name	TFS#		Description
============================================================================
28 Sep 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions( true );	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal;
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1( Err_InvalidTerminal, null, null, null );
		return passport.allErrorWarnings.size;
	endif;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException( UnknownUser, null, null );
		return passport.allErrorWarnings.size;
	endif;
	
	progressStr	:= app.getString( Verifying_Loaded_Details, partsInJob.display );
	progressTS	:= app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do : ediTI_loop
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
		// now validate each ediTrackedItem
		self.zValidateEdiData( ediTI.CM_EDITrainTI, terminal, passport );
	endforeach ediTI_loop;
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	return passport.allErrorWarnings.size;
	
epilog
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLoadDB" id="729f17ec-2d1b-4b78-858c-162b188823aa">
        <updating/>
        <source>zLoadDB(_ediTrainTI	: CM_EDITrainTI input;
		_terminal	: CM_Terminal input;
		_passport	: CM_Passport input ) updating;
	
/*
Purpose:	This method will do the required action for this EDI Train data.

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 4

	
vars
	ediTrainTI			: CM_EDITrainTI;
	realTrain			: CM_Train;
	prxyTrain			: CM_Train;
	foundTrain			: CM_Train;
	
begin
	ediTrainTI	:= _ediTrainTI;		// to reduce dereferencing set a local variable
	
	// the train is unique for a code and arrival date/time.
	foundTrain	:= self.getRealTrain(_terminal, ediTrainTI.trainCode, ediTrainTI.scheduledArrivalDT);
	
	if ediTrainTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		app.myUtilityDA.utlDeleteTrain(foundTrain, null, false, false, true, _passport);
		return;
	endif;
	
	// does not exist create it
	if foundTrain = null  then
		create prxyTrain as CM_Train transient;
		ediTrainTI.setTrainProxy(prxyTrain);
		app.myUtilityCA.utlCreateTrain(prxyTrain, realTrain, false, true, _passport);
		return;
	endif;
	
	// else update it.
	prxyTrain	:= app.createUpdateProxy(foundTrain).CM_Train;
	ediTrainTI.setTrainProxy(prxyTrain);
	app.myUtilityUA.utlUpdateTrain(prxyTrain, false, true, _passport);
epilog
	delete prxyTrain;
end;</source>
        <Parameter name="_ediTrainTI" type="CM_EDITrainTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zValidateEdiData" id="e9f663cf-1fbf-495b-a10e-fa5447fe4c9a">
        <source>zValidateEdiData(	_ediTrainTI	: CM_EDITrainTI input;
					_terminal	: CM_Terminal input;
					_passport	: CM_Passport input ) protected;

/*
Purpose:	Do the required validation for the EDI Train data.
			This checks that certain required fields are filled in thoses that the CM_Train validation does not check.
			
			Note: This method assumes that the terminal has already been checked to see that it exists.

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
	
vars
	action				: String;
	foundTrain			: CM_Train;
	prxyTrain			: CM_Train;
	ediTrainTI			: CM_EDITrainTI;
	
begin
	app.setContinueCMExceptions(true);		// get as many error messages in 1 go as possible
	
	ediTrainTI	:= _ediTrainTI;				// to reduce dereferencing set a local variable
	
	// check that the action is valid
	action	:=  ediTrainTI.messageMode;
	
	if action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_TrainAction, ediTrainTI);
		return;
	endif;
	
	// the train is unique for a code and arrival date/time.
	foundTrain	:= self.getRealTrain(_terminal, ediTrainTI.trainCode, ediTrainTI.scheduledArrivalDT);
	
	if action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if foundTrain = null then
			app.raiseCMException2(	Delete_Train_Does_Not_Exists,
									ediTrainTI.trainCode,
									ediTrainTI.scheduledArrivalDT.cnEcShortFullFormat, //cnwgb1 PAR 22911 8.3.10
									ETRow_Train,
									ediTrainTI );
			return;
		endif;
		
		app.myValDA.valTrain(foundTrain, false, null);
		return;
	endif;
	
	// now an action of Add or Update are treated as if it is the "correct" one
	// ie we do not care what action the user entered we only care if the train exists or not.
	if foundTrain = null then
		create prxyTrain as CM_Train transient;
		ediTrainTI.setTrainProxy(prxyTrain);
		app.myValCA.valTrain(prxyTrain);
		return;
	endif;
	
	prxyTrain	:= app.createUpdateProxy(foundTrain).CM_Train;
	ediTrainTI.setTrainProxy(prxyTrain);
	app.myValUA.valTrain(foundTrain, prxyTrain);
epilog
	delete prxyTrain;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTrainTI" type="CM_EDITrainTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
