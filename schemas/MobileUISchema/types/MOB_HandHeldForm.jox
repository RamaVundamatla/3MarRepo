    <JadeMethod name="popWithCraneWorkPointLanes" id="11dea12a-8779-45c8-9f4d-95fa58336285">
        <source>popWithCraneWorkPointLanes(	_cmbTermArea : ComboBox; _cmbLane : ComboBox input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29745

*/

vars

	preLane : CM_LocationsController;
	termArea : CM_TerminalArea;
	craneTa : CM_CraneTransferArea;
	lane : CM_LocationsController;
	locationsController : CM_LocationsController; 
	interChangeArea : CM_InterchangeArea;
	index : Integer;
	wpointTa : CM_WorkPointInterchangeArea;
	wpDischargeLanes : CM_LCArray;

begin

	preLane := _cmbLane.listObject.CM_LocationsController;
	
	_cmbLane.clear();
	
	termArea := _cmbTermArea.listObject.CM_TerminalArea; 
	if termArea &lt;&gt; null then
		if termArea.isKindOf(CM_CraneTransferArea) then
			craneTa := termArea.CM_CraneTransferArea;
			foreach locationsController in craneTa.dischargeLanes do
				_cmbLane.itemObject[ _cmbLane.addItem( locationsController.getID ) ] := locationsController;
			endforeach;
			
		elseif termArea.isKindOf(CM_WorkPointInterchangeArea) then
			wpointTa := termArea.CM_WorkPointInterchangeArea;
			create wpDischargeLanes transient;
			wpointTa.getLanes(wpDischargeLanes);
			foreach locationsController in wpDischargeLanes do
				_cmbLane.itemObject[ _cmbLane.addItem( locationsController.getFullId ) ] := locationsController;
			endforeach;
			
		elseif termArea.isKindOf(CM_InterchangeArea) then
			interChangeArea := termArea.CM_InterchangeArea;
			locationsController := interChangeArea.getDefaultLane;
			if locationsController &lt;&gt; null then
				_cmbLane.itemObject[ _cmbLane.addItem( locationsController.getID ) ] := locationsController;
			endif;
		endif;
	endif;
	
	if _cmbLane.listCount = 0 then
		if termArea &lt;&gt; null then
			_cmbLane.addItem( app.getErrorString(No_Discharge_lanes_found) );
		else
			_cmbLane.addItem( _cmbTermArea.text );
		endif;
		
	else
		_cmbLane.listIndex := 1;
		
	endif;
	
	if preLane &lt;&gt; null then
		index := _cmbLane.findObject(preLane);
		if index &gt; 0 then
			_cmbLane.listIndex := index;
		endif;
	endif;

epilog

	delete wpDischargeLanes;

end;</source>
        <access>protected</access>
        <Parameter name="_cmbTermArea" type="ComboBox"/>
        <Parameter name="_cmbLane" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="popWithCraneWorkPointTermAreas" id="a7b349a0-22dd-4af4-ab46-d8bb1b85fd9f">
        <source>popWithCraneWorkPointTermAreas( _voyage : CM_Voyage; _cmb : ComboBox input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29745

*/

vars

	objSet : CM_ObjectSetActual;
	obj : CM_Object;

begin

	_cmb.clear();
	
	if _voyage &lt;&gt; null then
	
		// 18 June 2012	NDL	Par 29745
		create objSet transient;
		_voyage.findAllMyCranesAndWorkpoints( objSet );
		foreach obj in objSet do
			self.addInterChgToCmbFromObject( obj, _cmb );
		endforeach;
		
	endif;
	
	if _cmb.listCount = 0 then
		_cmb.addItem( app.getErrorString(No_valid_term_areas_found) );
		
	else
		_cmb.listIndex := 1;
		
	endif;
	
epilog

	delete objSet;

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
