    <JadeMethod name="getExtraInfo" id="87af24f3-7407-4df0-a0ac-248daa59a9c0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*
Date		Who		Reason
24 May 2012	cnwar2	#28398

*/
vars
	block	: CM_DataContainerBlock;
	count 	: Integer;
	tmpStr	: String;
	aCA 	: CM_CustomsAgent;
	anOP 	: CM_Operator;
	anCON 	: CM_ConsigneeConsignor;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Remarks", DC_Label, 1, self);
	block.addNewItem(self.remarks, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Bad Credit", DC_Label, 1, self);
	block.addNewItem(self.badDebtor.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;

	block.addNewItem("Zero Rated Tax", DC_Label, 1, self);

	block.addNewItem(self.isZeroRatedTax.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Suspended", DC_Label, 1, self);
	block.addNewItem(self.isSuspended.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Purchase Order Mandatory", DC_Label, 1, self);
	block.addNewItem(self.isPurchaseOrderMandatory.cnEcGetYesNo(), DC_Data, 1, self);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
