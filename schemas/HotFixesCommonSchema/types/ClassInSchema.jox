<Class name="ClassInSchema" id="d064f477-03c5-4848-a8fe-a05cf162e731">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <ExplicitInverseRef name="allMethodsInClass" id="2e247ec0-153f-4a70-856e-0745ff620db6">
        <updateMode>automatic</updateMode>
        <type name="MethodInClassDictionary"/>
        <Inverse name="MethodInClass::myClassInSchema"/>
    </ExplicitInverseRef>
    <PrimAttribute name="dateOfLastEdition" id="40c9fbba-bff7-413d-9e0f-a3039aa39187">
        <embedded/>
        <type name="TimeStamp"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="extractSubClassesWhenExtrClass" id="a68efedd-b4ec-4c27-958c-b9c561c84a3f">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>extractSubClassesWhenExtrClass = true when extractWholeClass = true.

There are operators in UNL:

1. Extract whole class:
Class &lt;className&gt;
IN this case
extractWholeClass = true
extractSubClassesWhenExtrClass = false

1. Extract whole class and all sub-classes:
Class &lt;className&gt;...
IN this case
extractWholeClass = true
extractSubClassesWhenExtrClass = true

Related constant RootHotFixes :: EXTRACT_SUB_CLASSES_STR : "..."</text>
    </PrimAttribute>
    <PrimAttribute name="extractWholeClass" id="60b34a99-ca3e-4555-a552-9c6791723a0d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="mySchemaInPatch" id="9c50001c-d163-4a89-b420-1550d6819dad">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="SchemaInPatch"/>
        <access>protected</access>
        <Inverse name="SchemaInPatch::allClassesInSchema"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="ec94692f-d474-4638-a383-e487b6148372">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="createMyMethod" id="533527f0-18e8-4455-b436-2c3944b6d512">
        <source>createMyMethod( _methodName: String );
// created by cnwvu1 on 11/03/2007
vars
	mth : MethodInClass;
begin

	if self.extractWholeClass then
		return;
	endif;

	beginTransaction;
	create mth;
	mth.setForCreate( _methodName, self );
	commitTransaction;

end;
</source>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassInJADE" id="b38226d2-1c14-4b8b-84c3-c5461d050836">
        <source>getClassInJADE( _primitiveTypeFound	: Boolean output ) : Class;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	schema	: Schema;
	class	: Class;
	scm		: SchemaInPatch;
	
begin

	scm := self.mySchemaInPatch;
	schema := scm.getSchemaInJADE();
	if schema = null then
		return null;
	endif;

	class := schema.getClass( self.name );
	if class = null then
		self.validatePrimitiveType( schema, _primitiveTypeFound );
		if not _primitiveTypeFound then	// if class not found then check whether it is priitive type
			app.msgBox('The class not found - ' &amp; self.name, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return null;
		endif;
	endif;

	return class;

end;
</source>
        <Parameter name="_primitiveTypeFound" type="Boolean" usage="output"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMethodInClass" id="9aca80bc-f057-4eff-8561-f368eec793d9">
        <source>getMethodInClass( _mtdName: String ) : MethodInClass;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	returns ClassInSchema as object by _clsName
----------------------------------------------------------------------
*/

vars
	scm		: SchemaInPatch;
	patch	: Patch;	
begin
	
	scm := self.mySchemaInPatch;
	patch := scm.myPatch;
	
	return self.allMethodsInClass[ _mtdName, self.name, scm.name, patch.parNo ];
	
end;
</source>
        <Parameter name="_mtdName" type="String"/>
        <ReturnType type="MethodInClass"/>
    </JadeMethod>
    <JadeMethod name="getMySchemaInPatch" id="7c4c0637-0de9-47a5-bf7e-73408fba680d">
        <source>getMySchemaInPatch() : SchemaInPatch;
/* ---------------------------------------------------------------------------
Created:	28 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return self.mySchemaInPatch;

end;</source>
        <ReturnType type="SchemaInPatch"/>
    </JadeMethod>
    <JadeMethod name="set" id="2ac5473f-b249-4291-8bb8-d72d193cdc0c">
        <updating/>
        <source>set( name : String; _extractWholeClass, _extractSubClassesWhenExtrClas: Boolean ) updating;
// created by cnwvu1 on 11/03/2007
vars

begin

	self.name							:= name;
	self.extractWholeClass				:= _extractWholeClass;
	self.extractSubClassesWhenExtrClass	:= _extractSubClassesWhenExtrClas;
	self.dateOfLastEdition				:= app.actualTimeServer();

end;
</source>
        <Parameter name="name" type="String"/>
        <Parameter name="_extractWholeClass" type="Boolean"/>
        <Parameter name="_extractSubClassesWhenExtrClas" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0fa742fe-556d-441e-9192-91c5d1cc4367">
        <updating/>
        <source>setForCreate( _name: String; _extractWholeClass, _extractSubClassesWhenExtrClas : Boolean; _schema : SchemaInPatch ) updating;
// created by cnwvu1 on 10/03/2007
vars

begin

	self.set( _name, _extractWholeClass, _extractSubClassesWhenExtrClas );
	self.mySchemaInPatch	:= _schema;

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_extractWholeClass" type="Boolean"/>
        <Parameter name="_extractSubClassesWhenExtrClas" type="Boolean"/>
        <Parameter name="_schema" type="SchemaInPatch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5d384d9f-7904-426e-aac7-b349dfe5fc96">
        <source>validate() : Boolean;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	mth : MethodInClass;
	class	: Class;
	scm		: SchemaInPatch;
	isPrimitiveType : Boolean;
	
begin

	if self.extractWholeClass then
		if self.allMethodsInClass.size &gt; 0 then
			app.msgBox('There are methods for the class ' &amp; self.name &amp; ' . However, the whole class to be exported.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	else
		if self.allMethodsInClass.size = 0 then
			app.msgBox('There are no methods for the class ' &amp; self.name, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	endif;
	
	class := self.getClassInJADE( isPrimitiveType );
	if class = null and not isPrimitiveType then
		app.writeLogMessage('Class  ' &amp; self.name &amp; ' - not found.');
		return false;
	else
		app.writeLogMessage('Class  ' &amp; self.name &amp; ' - ok.');
	endif;

	foreach mth in self.allMethodsInClass do
		if not mth.validate( isPrimitiveType ) then
			return false;
		endif;
	endforeach;
	
	return true;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePrimitiveType" id="e3e26ba1-21c9-417b-a339-927d1a18e41e">
        <source>validatePrimitiveType( _schema : Schema; _primitiveTypeFound : Boolean output ) protected;
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	if class is not found - to check whether it is primitive type 
				with its own list of methods
				
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	primNamesDict : PrimTypeNDict;

begin

	//Method String csvToStringArray

	primNamesDict := _schema.getPropertyValue("primitives").PrimTypeNDict;
	
	_primitiveTypeFound := primNamesDict[self.name] &lt;&gt; null;

end;</source>
        <access>protected</access>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_primitiveTypeFound" type="Boolean" usage="output"/>
    </JadeMethod>
</Class>
