    <JadeMethod name="doMoveCargo" id="58a1d2b9-ba2e-49ac-ae77-024031df4d9c">
        <updating/>
        <source>doMoveCargo(_moveMode : Integer; _loadTargetLocation : CM_LocationsController input)updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	result 	: Integer;
	firstTI : CM_TrackedItem;
	tiSet 	: CM_TISet;
	ta		: CM_TerminalArea;
	targetLocn : CM_LocationsController;
	moveController : CMIF_MoveController;
	table 	: CM_DataTable;
	obj		: Object;
	doLoad	: Boolean;
	effectiveTimeStampOverride : TimeStamp;
	wle : CM_WorkListEntry;
	job : CM_Job;

begin

	app.mousePointer := MousePointer_HourGlass;		
	table := self.getTopTable();
	
	effectiveTimeStampOverride := null;
	
	create tiSet transient;
	if self.optBOL.value then
		foreach obj in table.allSelectedObjects do
			if CM_BOL.hasInstance(obj) then
				obj.CM_BOL.allTrackedItems.copy(tiSet);
			endif;
		endforeach;
	else
		table.allSelectedObjects.copy(tiSet);
	endif;
		
	if tiSet.isEmpty then
		app.msgBox('Please select an item from the table.', app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);	
		return;
	endif;
	
	if (_moveMode = REAL_MODE and _loadTargetLocation = null) then
		// they are discharging cargo, warn them first
		if app.msgBox('Are you sure you want to disharge the selected item(s)', 'Discharge Cargo', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	if _moveMode = PLANNING_MODE or (_moveMode = REAL_MODE and _loadTargetLocation &lt;&gt; null) then
		//targetLocn := self.getTargetLocation(); not implemented
		firstTI := tiSet.first;
		tiSet.remove(firstTI);		
		create moveController transient;
		moveController.setMyTrackedItem(firstTI);
		moveController.setMoveMode(_moveMode);
		moveController.setAllOtherTrackedItems(tiSet);
	//	moveController.transferType := self.chkRORO.value.Integer; // 0 = LOLO 1 = RORO 
		moveController.setMyOriginatingLocation(firstTI.myPrimaryActualLocation);
		if _moveMode = PLANNING_MODE then
			moveController.setMyToPrimaryLocation(targetLocn);
			moveController.isFullyUnplan := targetLocn = null; //unplanning cargo
		else
			moveController.setMyToPrimaryLocation(_loadTargetLocation);
			doLoad := true;
		endif;
		
		//12 Mar 2018	NDL	TFS 37444
		job := null;
		wle := firstTI.getVoyageWLEUnactioned( doLoad );
		if wle &lt;&gt; null then
			job := wle.job;
		endif;
		moveController.setTransferTypeFromJob( job, self.chkRORO.value.Integer );	//12 Mar 2018	NDL	TFS 37444
		
	endif;

	while true do
		
		// If real mode and not loading then do planned stuff.
		if _moveMode = REAL_MODE and not doLoad then
			if self.myCurrentGCVoyage.myVoyage.nonPlannedEffectiveDT.isValid and self.chkRetroSpec.value then
				effectiveTimeStampOverride := self.myCurrentGCVoyage.myVoyage.nonPlannedEffectiveDT;
			endif;
			app.myTrxUA.trxMoveTrackedItemsToPlannedLC(tiSet, _moveMode, effectiveTimeStampOverride, app.myPassport,VESSEL_TYPE_LOLO); // CNWAB1 MAY17 0); TFS 4435
		elseif moveController.isFullyUnplan then
			app.myTrxUA.trxUpdateMoveTIUndo(moveController, app.myPassport);				
		// If planning mode of load then do move.
		elseif _moveMode = PLANNING_MODE or doLoad then
			if _moveMode = REAL_MODE and (self.myCurrentGCVoyage.myVoyage.nonPlannedEffectiveDT.isValid and self.chkRetroSpec.value) then
				moveController.setEffectiveTimeStampOverride(self.myCurrentGCVoyage.myVoyage.nonPlannedEffectiveDT);
			endif;
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		else
			return;
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// DVB this form has become redundant. 
			//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete moveController;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_loadTargetLocation" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveIt" id="d548cf9c-ab88-479c-9ace-d3a61698b899">
        <updating/>
        <source>doMoveIt(_moveMode : Integer) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tiArray	: CM_TIArray;
	tmpTable : CM_DataTable;
	obj : Object;
	tmpBOL : CM_BOL;
	theTI : CM_TrackedItem;
begin
	
	tmpTable := self.getTopTable();
	
	create tiArray transient;
	
	if tmpTable.myDataClass = CM_TrackedItem then
		// get selected ti's
		tmpTable.allSelectedObjects.copy(tiArray);
	else
		// The table is populated with BOLs, get the ti's for each BOL selected
		foreach obj in tmpTable.allSelectedObjects do
			tmpBOL := obj.CM_BOL;
			foreach theTI in tmpBOL.allTrackedItems do
				if theTI.site = TI_SITE_ONSHIP then
					tiArray.add(theTI);
				endif;
			endforeach;
			
		endforeach;
	
	endif;
	
	self.myAssistant.showMoveItForm(tiArray, _moveMode);
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="acd6d305-3dd1-4af8-ba17-63a4761bb925">
        <updating/>
        <source>doPrint() updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars

	topTable : CM_DataTable;
begin

	topTable:=self.getTopTable;
	if topTable = null then
		return;
	endif;
	//refactored code is now in CM_DataTable::printTable
	topTable.printTable(self.caption);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="7128580a-4bd8-42a7-95f4-04d2c38558ac">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	03 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
	obj : Object;
	tmpTable : CM_DataTable;
begin
	inheritMethod();
	tmpTable := self.getTopTable();
	if tmpTable.row &gt; tmpTable.fixedRows
	and tmpTable.row &lt;= tmpTable.rows then
		obj := tmpTable.accessRow(tmpTable.row).itemObject;
	endif;

	self.doSearch();
	
	tmpTable.findObjectInRow(obj, idx);
	tmpTable.selectTheCurrentRow(idx);
	tmpTable.selectRow(idx, false);
		
	if CM_TrackedItem.hasInstance(obj) then
		
		self.displayExtraInfoForTI(self.getBottomTable(), obj.CM_TrackedItem);

	elseif CM_BOL.hasInstance(obj) then
		
		self.displayExtraInfoForBOL(self.getBottomTable(), obj.CM_BOL);			
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="50828553-a399-4521-ac77-7aa066b7c379">
        <source>doResetSearch(_clear : Boolean);
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	self.resetCargoTypeLst();
	self.lstOperators.setSelected(null);
	self.lstPorts.setSelected(null);
		
	if _clear then
		self.chkNNCargo.value := false;
		self.chkOnShip.value := false;
		self.chkOnSite.value := false;
		self.chkPlanned.value := false;
		self.chkNonPlanned.value := false;
	else
	
		self.chkNNCargo.value := true;
		self.chkOnShip.value := true;
		self.chkOnSite.value := true;
		self.chkPlanned.value := true;
		self.chkNonPlanned.value := true;
	endif;

	self.cmbVoyage.setObject(null);				
		
end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="3d3e0269-2d6c-41de-83fa-66a2141e9473">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.fldSearch.top := self.frmSearchToolbar.height;			

	self.frmToolbar2.top := self.frmToolbar.height;
	self.topMargin := self.frmToolbar2.top + self.frmToolbar2.height + 1;
	self.fldMain.top := self.topMargin;
	self.fldMain.repositionAfterResize();
	self.doResizeInfoTables();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeInfoTables" id="c425eaf4-9f9d-4aa4-9765-c47126aadada">
        <source>doResizeInfoTables();
//--------------------------------------------------
// Created:	03 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.optBOL.value then
		return;
	endif;
	
	if self.tblNNCargoInfo.columns &gt; 0 then
		self.setLastColumnMaxWidth(self.tblNNCargoInfo);
		self.doResizeColumnWidths(self.tblNNCargoInfo, true);
	endif;

	if self.tblNonPlannedInf.columns &gt; 0 then
		self.setLastColumnMaxWidth(self.tblNonPlannedInf);
		self.doResizeColumnWidths(self.tblNonPlannedInf, true);
	endif;

	if self.tblOnShipInfo.columns &gt; 0 then
		self.setLastColumnMaxWidth(self.tblOnShipInfo);
		self.doResizeColumnWidths(self.tblOnShipInfo, true);
	endif;

	if self.tblOnSiteInfo.columns &gt; 0 then
		self.setLastColumnMaxWidth(self.tblOnSiteInfo);
		self.doResizeColumnWidths(self.tblOnSiteInfo, true);
	endif;

	if self.tblPlannedInfo.columns &gt; 0 then
		self.setLastColumnMaxWidth(self.tblPlannedInfo);
		self.doResizeColumnWidths(self.tblPlannedInfo, true);
	endif;				
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRetrospective" id="fba0ef6a-9c50-41ca-870b-a9ee4f03f016">
        <updating/>
        <source>doRetrospective(_dateTime : TimeStamp)updating;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Note: _dateTime can be null.
vars
	now			: TimeStamp;
	voyage		: CM_Voyage;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentGCVoyage = null then
		return;
	endif;

	voyage := self.myCurrentGCVoyage.myVoyage;

	if voyage.nonPlannedEffectiveDT = _dateTime then
		return;
	endif;
	
	now := self.systemToLocalTime(app.actualTimeServer);// 17 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	
	if self.chkRetroSpec.value and _dateTime &gt; now then
		app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective DateTime', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;	

	app.mousePointer := MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageNonPEffectiveDT(voyage, _dateTime, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Effective DateTime', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doRetrospectiveClick" id="27fd08cd-2ac3-42f9-84b2-2888cc01c3ed">
        <updating/>
        <source>doRetrospectiveClick()updating;
//--------------------------------------------------
// Created:	21 October 2003 By: cnwgd1
//--------------------------------------------------
// 17 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	dateTime,
	now : TimeStamp;
begin
	now := self.systemToLocalTime(app.actualTimeServer);// 17 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.chkRetroSpec.value then
		self.txtDate.enabled := true;
		self.txtTime.enabled := true;
		dateTime.setDate(self.txtDate.getDate());
		dateTime.setTime(self.txtTime.getTime());
		if dateTime &gt; now then
			app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective Date', MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	else
		self.txtDate.setDate(now.date);
		self.txtTime.setTime(now.time);
		self.txtDate.enabled := false;
		self.txtTime.enabled := false;
		self.doRetrospective(null); 
	endif;		
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="7ac880a9-6dff-47cc-9cee-67e4a3e68aad">
        <updating/>
        <source>doSearch()updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	errorMess : String;
begin
	
	if self.cmbVoyage.myObject = null then
		errorMess := app.getErrorString(SHP_Please_Select_A_Voyage);
	endif;

	// check that a voyage and at least one sheet has been selected
	if self.chkNNCargo.value = false
	and self.chkOnShip.value = false
	and self.chkOnSite.value = false
	and self.chkPlanned.value = false		
	and self.chkNonPlanned.value = false then
		if errorMess &lt;&gt; null then
			errorMess := errorMess &amp; ' And at least one sheet to display.';
		else
			errorMess := 'You must select at least one sheet to display.';
		endif;
	endif;
	
	// cannot filter
	if errorMess &lt;&gt; null then
		app.msgBox(errorMess, app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;		

	app.mousePointer := Window.MousePointer_HourGlass;	
	
	// hide/show sheets for user selection
	self.shtOnShip.visible := self.chkOnShip.value;
	self.shtOnSite.visible := self.chkOnSite.value;
	self.shtPlanned.visible := self.chkPlanned.value;
	self.shtNonplanned.visible := self.chkNonPlanned.value;
	self.shtNNCargo.visible := self.chkNNCargo.value;
	
	// set the voyage, does the filtering and populates the tables with the filtered data
	self.setMyCurrentGCVoyage(self.cmbVoyage.myObject.CM_Voyage.myGeneralCargoVoyage);
	
	if self.myCurrentGCVoyage &lt;&gt; null then
		self.frmSearch.visible := false;
		self.btnPrint.enabled := true;
		self.btnReportOptions.enabled := true;
		self.btnShowSearch.enabled := true;
		self.btnVoyageDefin.enabled := true;
		self.btnSelectAll.enabled := true;
		self.btnMoveIt.enabled := true;
		self.btnImportTasks.enabled := true;
		self.btnCreateCargo.enabled := true;
		self.btnDelete.enabled := true;				
	endif;

	// display the sheet caption to include the number of items in the table
	self.displaySheetCaptions();

epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="4df33884-a5dc-4571-b00c-40faae045c05">
