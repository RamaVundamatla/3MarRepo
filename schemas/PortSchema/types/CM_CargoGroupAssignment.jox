    <JadeMethod name="isPreAssigned" id="92f03d5b-b416-4828-b830-79b087ce07e8">
        <source>isPreAssigned():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 37882
02 Oct 2018	NDL	TFS 39186

*/

vars

	cargoGroup : CM_TrackedItem;
	cgn : CM_NotifiedCargoGroup;

begin

	cargoGroup := self.allCargoGroupsByIdDict.first;
	if cargoGroup &lt;&gt; null then
		return cargoGroup.CM_CargoGroup.isPreAssigned;
	else
		cgn := self.allNotifiedCargoGroupByIdDict.first;
		if cgn &lt;&gt; null then
			return cgn.isPreAssigned;
		endif;
	endif;
	
	return false;

epilog

end;</source>
