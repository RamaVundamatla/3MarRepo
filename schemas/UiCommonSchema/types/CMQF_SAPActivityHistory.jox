<Class name="CMQF_SAPActivityHistory">
    <JadeMethod name="setFromAgent" id="90626e7d-dc99-4157-bd48-06fee8478169">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars

begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_Debtor) then
		self.myDebtor := _agent.getSelectedDebtor;
	endif;
	
	if _agent.isRowIncluded(ETRow_SapStatus) then
		self.sapStatus := _agent.getValueByNameIfVisible(ETRow_SapStatus).String;
		if self.sapStatus = app.getErrorString(AnyString) then
			self.sapStatus := null;
		elseif self.sapStatus = "1" then
			self.sapStatus := app.getErrorString(SAP_Hold);
		elseif self.sapStatus = "2" then
			self.sapStatus := app.getErrorString(Debit);
		elseif self.sapStatus = "3" then
			self.sapStatus := app.getErrorString(Cancelled);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_Transaction) then
		self.sapTransaction := _agent.getValueByNameIfVisible(ETRow_Transaction).String;
		if self.sapTransaction = app.getErrorString(AnyString) then
			self.sapTransaction := null;
		elseif self.sapTransaction = "1" then
			self.sapTransaction := "Vessel";
		elseif self.sapTransaction = "2" then
			self.sapTransaction := "Cargo";
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
