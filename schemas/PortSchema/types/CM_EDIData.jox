    <JadeMethod name="getXlationOperator" id="aaa053a4-ff26-4149-8c85-d53dd08aeca3">
        <source>getXlationOperator() : CM_Operator;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//10 Jun 2016	cnwrs1	TFS 2150 - fixup
//18 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

vars
	xlationOperator 	: CM_Operator;
	xlationOperatorCode : String;
begin
	
	//global.getExtraData(self.allExtraData, ETRow_XlateOperatorCode, xlationOperatorCode);		//18.11.2022 navma1 #55424
	xlationOperatorCode := self.xlationOperatorCode;											//18.11.2022 navma1 #55424
	xlationOperator 	:= app.myRoot.allOperators[xlationOperatorCode];
	
	if xlationOperator = null then
		xlationOperator := self.myOperator;
	endif;
	
	if xlationOperator = null and  self.operatorCode &lt;&gt; null then
		xlationOperator := app.myRoot.allOperators[self.operatorCode];
	endif;
	
	return xlationOperator;
end;
</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="hasEDITIofType" id="3f66a1f5-84c1-4c0b-950a-90312ffebf3c">
        <source>hasEDITIofType( _type : Class) : Boolean;
/*

Date		Who		Reason
20 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems discreteLock do
		if ediTI.isKindOf(_type) then
			return true;
		endif;
	endforeach;
	
	return false;
		
epilog

end;</source>
        <Parameter name="_type" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOnlyLockErrors" id="25ef3e72-57ce-4f17-8632-86d427606d0b">
        <source>hasOnlyLockErrors(_passport : CM_Passport) : Boolean;
/*

Purpose:
    Returns true if the passport contains only lock-related errors (System_Lock_Error_Code), 
    and false if it contains any other errors or no errors at all.

Parameters:
    _passport : CM_Passport - the passport object containing EDI processing errors.

Return Value:
    Boolean - true if all errors are lock errors, false otherwise.

Date        Who       Reason
14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations

*/
vars
    error : CM_Error;
begin
    if _passport.noErrors() then
        return false;
    endif;

    foreach error in _passport.allErrors do
        if error.errorCode &lt;&gt; System_Lock_Error_Code then
            return false;
        endif;
    endforeach;

    return true;
epilog

end;
</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
