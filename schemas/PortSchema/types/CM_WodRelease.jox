    <JadeMethod name="getExtraInfo" id="d4675db5-d30b-4f8f-b0dc-73f6e7798163">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2019	jlgndl1	Initial creation
01 Jun 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
19 Jul 2022 navcs2  ChangeRequest 53932: MTN - Jobs Changes
04 Jul 2023 namva1	Bug 58976: MTN - Error 14008 when opening Release Rail Work orders
15 Aug 2023	ChangeRequest 59218: EUP | Handle Work order for Release Rail by Type
*/

vars

	block 				: CM_DataContainerBlock;
	extension 			: CM_WorkOrderDtl;
	latestApprovedExt 	: CM_WorkOrderDtl;
	latestUnApprovedExt : CM_WorkOrderDtl;
	cargoGroup			: CM_TrackedItem;
	pinNum				: String;

begin
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Expiry_date), DC_Label, 1, null);
	block.addNewItem(self.getMyParent.approvalExpiryTS.asStringJMT, DC_Data, 1, null);
	
	//1.6.2022 navma1 #52351
	if self.myReleaseRequest &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Release_request), DC_Label, 1, self.myReleaseRequest);
		block.addNewItem(self.myReleaseRequest.code, DC_Data, 1, self.myReleaseRequest);	
	endif;
	
	if self.myTrain &lt;&gt; null then											//04.07.2023 navma1 #58976
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_Label, 1, null);
		block.addNewItem(self.myTrain.code, DC_Data, 1, self.myTrain);	
	endif;
	
	if self.myVoyage &lt;&gt; null then											//04.07.2023 navma1 #58976
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage), DC_Label, 1, self.myVoyage);
		block.addNewItem(self.myVoyage.code, DC_Data, 1, self.myVoyage);	
	endif;
	
	if not allExtensionWorkOrders.isEmpty then
		extension := allExtensionWorkOrders.last;
		if extension.requiredByDT = self.getMyParent.approvalExpiryTS then
			//latest extension, has been approved
			latestApprovedExt := extension;
		else
			//latest extension, waiting to be approved
			latestUnApprovedExt := extension;
		endif;
		if latestApprovedExt = null and allExtensionWorkOrders.size &gt; 1 then
			extension := allExtensionWorkOrders[ allExtensionWorkOrders.size - 1 ];
			if extension.requiredByDT = self.getMyParent.approvalExpiryTS then
				// latest approved extension
				latestApprovedExt := extension;
			endif;
		endif;
	
		if latestApprovedExt &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Expiry_extended), DC_Label, 1, null);
			block.addNewItem(latestApprovedExt.getMyParent.id, DC_Data, 1, null);
		endif;
		
		if latestUnApprovedExt &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(New_Extension_requested), DC_Label, 1, null);
			block.addNewItem(latestUnApprovedExt.getMyParent.id, DC_Data, 1, null);
		endif;
	
	endif;
	
	// TFS 53932 NAVCS2 19/07/2022
	pinNum := self.getPINNumber;
	if pinNum &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Pin_no), DC_Label, 1, null);
		block.addNewItem(pinNum, DC_Data, 1, null);
	endif;
	
	if self.myReserveDetail&lt;&gt; null then									//15.08.2023 navma1 #59218
		cargoGroup := self.myReserveDetail.myCargoGroup;
		if cargoGroup &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CargoGroup), DC_Label, 1, cargoGroup);
			block.addNewItem(cargoGroup.id, DC_Data, 1, cargoGroup);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstructions" id="5421d2cd-afb4-4e46-a7de-d556533442f8">
        <source>getInstructions(): CM_InstructionsIssued;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2023	navma1	Defect 58687: MTN - Job's Cargo details are not populating correctly on the Work Order Operations form

*/

vars

begin
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.myInstructions;
	elseif self.myReleaseRequest &lt;&gt; null then
		return self.myReleaseRequest.myInstructions;
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="CM_InstructionsIssued"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="9ae70e03-9569-491b-bcbb-5828a3ed97bc">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	bookingRef		: CM_BookingRef;
	bookingRefItem	: CM_BookingRefItem;
	releaseReq		: CM_BulkRelease;
begin
	inheritMethod(_instructions, _passingObject, _context);
	
	bookingRef := self.myBookingRef;
	bookingRefItem := self.myBookingRefItem;
	releaseReq := self.myReleaseRequest;
	
	if bookingRef &lt;&gt; null then
		bookingRef.getInstructionsForContext(_instructions, _passingObject, _context);
	endif;
	
	if bookingRefItem &lt;&gt; null then
		bookingRefItem.getInstructionsForContext(_instructions, _passingObject, _context);
	endif;
	
	if releaseReq &lt;&gt; null then
		releaseReq.getInstructionsForContext(_instructions, _passingObject, _context);
	endif;
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyReleaseRequest" id="99c79c76-36c7-4008-8a0e-4cc0650c7023">
        <source>getMyReleaseRequest():CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
1/04/2019 	JLGNS1	Initial creation	Bug 44134
//1/04/2019 JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
*/

vars

	invalid : Boolean;
	edition : Integer;
	relReq : CM_BulkRelease;

begin

	on Exception do app.handleDeletedObject( exception, relReq, invalid );

	relReq := self.myReleaseRequest;	
	if relReq &lt;&gt; null then
		edition := relReq.edition;
		if not invalid then
			return relReq;
		endif;
	endif;
		
	return null;

epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getMyReserveDetail" id="6da1ee4f-e4d8-49d2-a912-3739bf02d3fd">
        <source>getMyReserveDetail(): CM_ReserveDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars

	invalid 		: Boolean;
	edition 		: Integer;
	reserveDetails 	: CM_ReserveDetail;

begin

	on Exception do app.handleDeletedObject( exception, reserveDetails, invalid );

	reserveDetails := self.myReserveDetail;	
	if reserveDetails &lt;&gt; null then
		edition := reserveDetails.edition;
		if not invalid then
			return reserveDetails;
		endif;
	endif;
		
	return null;

epilog

end;</source>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="d74e864e-54ca-41b0-9d38-c06a777343ba">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2019	jlgndl1	Initial creation	TFS 43019
01 Apr 2019 JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
02 Feb 2024	navma1  Bug 62220: MTN - work order enquiry doesn't seem to search as expected App
*/
vars

	invalid : Boolean;
	edition : Integer;
	voyage	: CM_Voyage;
	relReq  : CM_BulkRelease;
begin
	
	relReq := self.getMyReleaseRequest();	//Bug 44134
	
	if relReq &lt;&gt; null then					//Bug 44134
		voyage := relReq.myVoyage;
	elseif self.myVoyage &lt;&gt; null  then		//02.02.2023 navma1 #62220
		voyage := self.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then
		edition := voyage.edition;
		if not invalid then	
			return voyage;
		endif;
	endif;
	

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getPINNumber" id="9af7097e-5848-4fad-9399-3e14a8d4e957">
        <source>getPINNumber() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2018	jlgab1	Initial creation
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
*/

vars
	relReq : CM_BulkRelease;
begin
	relReq := self.getMyReleaseRequest();				//Bug 44134
	if relReq  &lt;&gt; null and not relReq.isComplete() then	//Bug 44134
		if relReq.myPinNo &lt;&gt; null then					//Bug 44134
			return relReq.myPinNo.pinNo.String;			//Bug 44134
		endif;	
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProgressString" id="31ed2f4f-6e1d-4efb-a5a5-46956ea8795e">
        <source>getProgressString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2023	navma1	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
23 Nov 2023 navhl20 Bug 61242: EUP | Release Cargo Work order progress not based on the Total Quantity of the cargo items
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
*/

vars
	qty 		: Integer;
	required,
	completed 	: Any;
	cargoType	: CM_CargoType;
	ti			: CM_TrackedItem;
begin
	if self.getMyTerminal.isUseYardJobsForCargoWo then
		if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) then
			cargoType := self.myReserveDetail.CM_ReserveSelection.myCargoType;									//09.12.2024 navhl20 #33643
			if not cargoType.isBulk then																		//09.12.2024 navhl20 #33643
				required 	:= self.myReserveDetail.CM_ReserveSelection.totalRequested;
				completed	:= self.getTotalCompleted(true).Integer;
			else
				required 	:= self.myReserveDetail.CM_ReserveSelection.weightRequested;
				completed	:= self.getTotalCompleted(false);
			endif;
		else																									//23.11.2023 navhl20 #61242
			ti := self.allSelectedTIs.first;
			if ti &lt;&gt; null and ti.isBulkCargo then																				//09.12.2024 navhl20 #33643
				required	:= self.getTotalRequest(false);
				completed	:= self.getTotalCompleted(false);
			else
				required	:= self.getTotalRequest(true).Integer;
				completed	:= self.getTotalCompleted(true).Integer;
			endif;
		endif;
		return app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReference" id="8cc4678b-f64f-45fd-98ec-73554d5e5fa2">
