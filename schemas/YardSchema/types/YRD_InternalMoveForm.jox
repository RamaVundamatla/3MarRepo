    <JadeMethod name="displaySelectorResults" id="5c00a43f-cdaa-4795-8659-775261ca82c4">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwrd1	Initial creation

*/

vars
	tiArray : CM_TIArray;
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox( app.getErrorString1(ReqInternalMove_cant_display, _mode.String ),  app.getErrorString(Invalid_selector_mode) , MsgBox_Exclamation_Mark_Icon);
		
		return;
	endif;
	
	create tiArray transient;
	
	//self.allSelectedTIs.clear;
	
	_resultCollection.copy(tiArray);	
	tiArray.copyNoDuplicates(self.allSelectedTIs);
	self.displaySelectedTIs();
	
	self.txtNumRequested.setValue(_resultCollection.size);
	

epilog
	delete tiArray;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
