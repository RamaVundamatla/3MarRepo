                  "Remarks": "container 4 Repaired now"
                }
              ],
              "ResponsibleParty": "DP1",
              "Severity": "1",
              "Size": "0.0000",
              "Type": "BENT"
            }
          ],
          "Diameter": 0,
          "GrossWeightEffective": 4000,
          "ItemBarcode1": "",
          "ItemBarcode2": "",
          "ItemId": "CONU0100104",
          "Length": 0,
          "LengthUOM": "",
          "NettWeightEffective": 4000,
          "PiecesPerPack": 1,
          "ProductCondition": "Repaired",
          "QuantityEffective": 1,
          "RunningLength": 0,
          "RunningLengthUOM": "",
          "StorageLocation": "UT_BSTACK",
          "Thickness": 0,
          "Transport": {
            "MyTestRecordObject": null,
            "WarningsHaveBeenAcknowledged": false,
            "CarrierParty": {
              "MyTestRecordObject": null,
              "WarningsHaveBeenAcknowledged": false,
              "Code": "",
              "Name": ""
            },
            "DischargingPlace": "",
            "TransportationMode": "Unknown"
          },
          "VolumeEffective": 0.00,
          "VolumeUOM": "",
          "Warehouse": "UT_BSTACK",
          "WeightUOM": "",
          "Width": 0
        }
      ],
      "KeyMarks": "",
      "Length": 0,
      "LengthUOM": "",
      "LimitedQuantity": false,
      "LoadingPort": "NZPOE",
      "Mill": {
        "MyTestRecordObject": null,
        "WarningsHaveBeenAcknowledged": false,
        "Code": "",
        "Name": ""
      },
      "MillOrderLineNumber": "",
      "MillOrderNumber": "",
      "MovementType": "EXPORT",
      "NettWeightEffective": 4000,
      "OperatorVoyageNumber": "",
      "PackageType": "",
      "PackingGroup": "",
      "PiecesPerPack": 1,
      "ProductCondition": "Repaired",
      "Quality": "GENL",
      "QuantityEffective": 1,
      "Reference": "",
      "Remarks": "Created by unit test UT_EDICAMS::tTestDamageAndRepairEDICAMS\r\n",
      "StorageLocation": "On site",
      "StowageMode": "",
      "Thickness": 0,
      "Transport": {
        "MyTestRecordObject": null,
        "WarningsHaveBeenAcknowledged": false,
        "CarrierParty": {
          "MyTestRecordObject": null,
          "WarningsHaveBeenAcknowledged": false,
          "Code": "",
          "Name": ""
        },
        "DischargingPlace": "",
        "TransportationMode": "Unknown"
      },
      "UNCode": "",
      "UnloadingPort": "NZAKL",
      "VolumeEffective": 0.00,
      "Warehouse": "UT_BSTACK",
      "Width": 0
    }
  ]
}
';

	while true do
		pos2 := json.pos("MyTestRecordObject", 1);
		if pos2 = 0 then
			pos2 := json.pos("WarningsHaveBeenAcknowledged", 1);
			if pos2 = 0 then
				break;
			endif;
		endif;
		
		// Include the preceding tab in the chunk to skip
		if json[pos2-1:1] = Tab then
			pos2 := pos2 - 1;
		endif;
		// Also include the preceding '"' in the chunk to skip if there is one
		if json[pos2-1:1] = '"' then
			pos2 := pos2 - 1;
		endif;
		
		pos3 := pos2;
		json.scanUntil(CrLf, pos3);	// Jump to before the CrLf
		pos3 := pos3 + 2;				// Skip over the CrLf
		
		//write json[1:pos2-1] &amp; CrLf &amp; "_________________________________________" &amp; CrLf;
		//write json[pos3:end] &amp; CrLf &amp; "_________________________________________" &amp; CrLf;
		json := json[1:pos2-1] &amp; json[pos3:end];
	endwhile;
	
	write json;
end;</source>
    </JadeMethod>
    <JadeMethod name="jsonManipulation1" id="32a11320-3622-4860-a286-4f592ee7a93b">
        <source>jsonManipulation1();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21 February 2023	navdap1		Initial creation TFS 
//
constants
	RegExValue= '"(.*?)"';
	RegExDate= '\(\d+\)';
vars
	json : String;
	pos2, pos3 : Integer;
	x:JadeRegexMatch;
	valueMatch : JadeRegexMatch;
	dateMatch : JadeRegexMatch;
	
	jsonStringLength : Integer;
	i : Integer;
	valuePortion : Boolean;
	quotesNumber    : Integer;
	
	insideValueQuotes :Boolean;
	valueMatches : JadeRegexResult;
	dateMatches : JadeRegexResult;
	//matchCount:Integer;
	tagName, innerHtml : JadeRegexCapture;
	dateMatchCount :Integer;
	valueMatchCount:Integer;
	dateValue:String;
	
	
begin
	
json:='{"Header":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1676977983005)\/","Id":"id &lt;-- NEED TO FIX THIS","Number":"number &lt;-- NEED TO FIX THIS","Receiver":"MSK","Sender":"UT","Status":"CREATE","Type":"EUP Damage/Repair Activity"},"Goods":[{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"ADMTEffective":4000,"Blocked":true,"BlockingReason":"C,OSEM","BOLNumber":"123457","BOLReference":"UT_VOY1EUPDAMAGE","Buyer":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"CargoType":"ISO Container","Certificate":"","Colour":"","ContainerNumber":"","CountryOfOrigin":"","CustomerReference":"","Damages":null,"DangerousGoods":false,"Description":"","DestinationPort":"","Diameter":0,"FinalDestinationPort":"","Flashpoint":0.00,"ForwardingAgent":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"GoodsBarcode":"","GoodsOwner":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"MSK","Name":"MAERSK"},"Grade":"","Grammage":0.00,"GrossWeightEffective":4000,"Id":1,"IMOclass":"","Items":[{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"ADMTEffective":4000,"Blocked":true,"BlockingReason":"C,OSEM","ContainerNumber":"","Damages":[{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container1 damage1","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"BENT"},{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container1 damage2","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"DENT"},{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container1 damage3","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"HOLE"}],"Diameter":0,"GrossWeightEffective":4000,"ItemBarcode1":"","ItemBarcode2":"","ItemId":"CONU0100101","Length":0,"LengthUOM":"","NettWeightEffective":4000,"PiecesPerPack":1,"ProductCondition":"Damaged","QuantityEffective":1,"RunningLength":0,"RunningLengthUOM":"","StorageLocation":"UT_BSTACK","Thickness":0,"Transport":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"CarrierParty":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"DischargingPlace":"","TransportationMode":"Unknown"},"VolumeEffective":0.00,"VolumeUOM":"","Warehouse":"UT_BSTACK","WeightUOM":"","Width":0}],"KeyMarks":"","Length":0,"LengthUOM":"","LimitedQuantity":false,"LoadingPort":"NZPOE","Mill":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"MillOrderLineNumber":"","MillOrderNumber":"","MovementType":"EXPORT","NettWeightEffective":4000,"OperatorVoyageNumber":"","PackageType":"","PackingGroup":"","PiecesPerPack":1,"ProductCondition":"Damaged","Quality":"GENL","QuantityEffective":1,"Reference":"","Remarks":"Created by unit test UT_EDICAMS::tTestDamageAndRepairEDICAMS\r\n","StorageLocation":"On site","StowageMode":"","Thickness":0,"Transport":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"CarrierParty":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"DischargingPlace":"","TransportationMode":"Unknown"},"UNCode":"","UnloadingPort":"NZAKL","VolumeEffective":0.00,"Warehouse":"UT_BSTACK","Width":0},{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"ADMTEffective":4000,"Blocked":true,"BlockingReason":"C,OSEM","BOLNumber":"123457","BOLReference":"UT_VOY1EUPDAMAGE","Buyer":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"CargoType":"ISO Container","Certificate":"","Colour":"","ContainerNumber":"","CountryOfOrigin":"","CustomerReference":"","Damages":null,"DangerousGoods":false,"Description":"","DestinationPort":"","Diameter":0,"FinalDestinationPort":"","Flashpoint":0.00,"ForwardingAgent":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"GoodsBarcode":"","GoodsOwner":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"MSK","Name":"MAERSK"},"Grade":"","Grammage":0.00,"GrossWeightEffective":4000,"Id":2,"IMOclass":"","Items":[{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"ADMTEffective":4000,"Blocked":true,"BlockingReason":"C,OSEM","ContainerNumber":"","Damages":[{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container3 damage1","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"DENT"},{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container3 damage2","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"001"},{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Date":"\/Date(1672531200000)\/","Place":"DL1","Position":"All","Reason":"DR1","Refused":false,"Remarks":"container3 damage3","Repairs":null,"ResponsibleParty":"DP1","Severity":"1","Size":"0.0000","Type":"HOLE"}],"Diameter":0,"GrossWeightEffective":4000,"ItemBarcode1":"","ItemBarcode2":"","ItemId":"CONU0100103","Length":0,"LengthUOM":"","NettWeightEffective":4000,"PiecesPerPack":1,"ProductCondition":"Damaged","QuantityEffective":1,"RunningLength":0,"RunningLengthUOM":"","StorageLocation":"UT_BSTACK","Thickness":0,"Transport":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"CarrierParty":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"DischargingPlace":"","TransportationMode":"Unknown"},"VolumeEffective":0.00,"VolumeUOM":"","Warehouse":"UT_BSTACK","WeightUOM":"","Width":0}],"KeyMarks":"","Length":0,"LengthUOM":"","LimitedQuantity":false,"LoadingPort":"NZPOE","Mill":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"MillOrderLineNumber":"","MillOrderNumber":"","MovementType":"EXPORT","NettWeightEffective":4000,"OperatorVoyageNumber":"","PackageType":"","PackingGroup":"","PiecesPerPack":1,"ProductCondition":"Damaged","Quality":"GENL","QuantityEffective":1,"Reference":"","Remarks":"Created by unit test UT_EDICAMS::tTestDamageAndRepairEDICAMS\r\n","StorageLocation":"On site","StowageMode":"","Thickness":0,"Transport":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"CarrierParty":{"MyTestRecordObject":null,"WarningsHaveBeenAcknowledged":false,"Code":"","Name":""},"DischargingPlace":"","TransportationMode":"Unknown"},"UNCode":"","UnloadingPort":"NZAKL","VolumeEffective":0.00,"Warehouse":"UT_BSTACK","Width":0}]}

';



	write "orig:" &amp; CrLf &amp;json &amp;CrLf &amp;CrLf;
	json:=json.replace__('"WarningsHaveBeenAcknowledged":false,','',false);
	json:=json.replace__('"WarningsHaveBeenAcknowledged":false','',false);
	json:=json.replace__('"MyTestRecordObject":null,','',false);
	json:=json.replace__('"MyTestRecordObject":null','',false);
	
	
	write "stripped:" &amp; CrLf &amp;json &amp;CrLf &amp;CrLf;	
	
	
	
	valueMatchCount := JadeRegex@findAll(json, RegExValue, 
                                    true, true, valueMatches);
    foreach i in 1 to valueMatchCount do
	
		valueMatch := valueMatches.at(i);
		if valueMatch.value.pos('Date(',1) &lt;&gt; 0 then
			write valueMatch.value;
			dateMatchCount := JadeRegex@findAll(valueMatch.value, RegExDate, 
                                    true, true, dateMatches);
			if dateMatches.numMatches &gt;=1 then
				dateValue:=dateMatches.at(1).value;
				dateValue:=dateValue.cnRemoveChars('()');				
				
				write dateValue.Date.asStringJMT;
				json:=json.replace__(valueMatch.value,'"abcd"',false);
			endif;
		
		endif;	
        
    endforeach;
	
	write json;
end;</source>
    </JadeMethod>
