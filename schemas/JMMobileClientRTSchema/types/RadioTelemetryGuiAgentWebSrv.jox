    <JadeMethod name="placeOnHold" id="9a3df6a8-8a7f-444b-a5b6-8fbc62ae29fa">
        <source>placeOnHold(	_state 			: Integer io;
				_errorString	: String output;
				_warnings		: Boolean io) : Boolean;
// -------------------------------------------
// Created 02 February 2006 by cnwdvb1
// -------------------------------------------
vars

	request		: WebSrv_PlaceOnHold;
	response	: WebSrv_PlaceOnHoldResp;
	dtoStateOut	: WebSrv_DTO_StateInfo;
	rtnValue	: Boolean;

begin
	
	// Not implemented 
	return false;
	
	on Exception do xHandlerInterface(exception);
	
	create request transient;
	
	self.clearStateObject();
	
	self.myStateObjIn.warningsAcknowledged := _warnings;
	
	request.stateInfo		:= self.myStateObjIn;
	
	response			:=	self.myWebSrvProvider.placeOnHold(request);
	
	dtoStateOut			:= response.stateInfo;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := response.placeOnHoldResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	_warnings		:= dtoStateOut.hasWarningsOnly;
		
	return rtnValue;

epilog

	delete request;
	delete response;
	delete dtoStateOut;
end;</source>
