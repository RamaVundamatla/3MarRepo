    <JadeMethod name="tblSearch_cellInputReady" id="0659908b-5458-42f6-9007-e7b0c9350658">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSearch_cellInputReady(table: CM_EntryTable; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl	: CM_EntryTable;
begin

	if CMUI_ListTable.hasInstance(inputControl) then
		tbl := table;
		self.myAssistant.listTableCellInputReady(tbl, cheight, self.saveRowHeight);
		tbl.adjustHeight(300);
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="95ced4f4-f288-4a8d-b238-4b7189cc64d1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008928, locale);
	btnAdjustStock.translateBubbleHelp(Xlat_0010464, locale);
	btnAdjustStock.translateCaption(Xlat_0008929, locale);
	btnAreaSelectAll.translateBubbleHelp(Xlat_0004667, locale);
	btnAreaSelectAll.translateCaption(Xlat_0004668, locale);
	btnAreaTypes.translateBubbleHelp(Xlat_0004673, locale);
	btnAreaTypes.translateCaption(Xlat_0004674, locale);
	btnAreasClear.translateBubbleHelp(Xlat_0004671, locale);
	btnAreasClear.translateCaption(Xlat_0004672, locale);
	btnCloseSearch.translateCaption(Xlat_0004690, locale);
	btnDelete.translateCaption(Xlat_0004677, locale);
	btnEdit.translateCaption(Xlat_0004678, locale);
	btnFind.translateCaption(Xlat_0004679, locale);
	btnNew.translateCaption(Xlat_0004680, locale);
	btnPrint.translateCaption(Xlat_0004681, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0004688, locale);
	btnResetSearch.translateCaption(Xlat_0004691, locale);
	btnSelector.translateBubbleHelp(Xlat_0004676, locale);
	btnSelector.translateCaption(Xlat_0004682, locale);
	btnShowSearcher.translateBubbleHelp(Xlat_0004669, locale);
	btnShowSearcher.translateCaption(Xlat_0004670, locale);
	frmReport.translateCaption(Xlat_0004683, locale);
	lblReport.translateCaption(Xlat_0004684, locale);
	lblSearch.translateCaption(Xlat_0004685, locale);
	mnuAddLabRestriction.translateCaption(Xlat_0008930, locale);
	mnuColourLegend.translateCaption(Xlat_0008931, locale);
	mnuColumnOrg.translateCaption(Xlat_0008932, locale);
	mnuFlagLoadFrom.translateCaption(Xlat_0008933, locale);
	mnuFlagLoadTo.translateCaption(Xlat_0008934, locale);
	mnuRemoveLabRestrict.translateCaption(Xlat_0008935, locale);
	mnuSelector.translateCaption(Xlat_0008937, locale);
	mnuSetAutoAllocations.translateCaption(Xlat_0008938, locale);
	mnuTableContext.translateCaption(Xlat_0008939, locale);
	mnuYardAllocations.translateCaption(Xlat_0008940, locale);
	shtAreaTypes.translateCaption(Xlat_0004675, locale);
	shtCriteria.translateCaption(Xlat_0004686, locale);
	shtSummary.translateCaption(Xlat_0004687, locale);
end;</source>
