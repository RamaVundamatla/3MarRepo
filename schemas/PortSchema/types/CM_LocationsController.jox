    <JadeMethod name="getAutoMaskTIs" id="ae2c190a-5918-44ee-981d-e618d663e183">
        <source>getAutoMaskTIs(_dict : Collection input; _mode : Integer; _dischargePort, _commodityGroup, _voyageCode : String);
//--------------------------------------------------
// Created:	26 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	ti	: CM_TrackedItem;
	tmpArray : CM_TIArray;
	futMove	: CM_FutureMove;
begin
	if _dict = null or _mode = null then 
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Null Dict/mode passed to method. Contact Developer', null, null);
		return;
	endif;

	if _dischargePort = null and 
		_commodityGroup = null and 
		_voyageCode = null then
		return;
	endif;
	
	//----------------------------------------------------------
	//DO NOT CLEAR THE _dict AS COULD BE FILTERING TERMINAL AREA
	//----------------------------------------------------------
	
	//Filter by yard location (site/state ignored)
	create tmpArray transient;
	if _mode = DISPLAY_MODE_ACTUAL then
		self.allTrackedItemsById.copy(tmpArray);
	elseif _mode = DISPLAY_MODE_QUEUE then
		foreach futMove in self.allQueuedFutureMoves do
			tmpArray.add(futMove.getTrackedItem);
		endforeach;		
	elseif _mode = DISPLAY_MODE_PLAN then
		foreach futMove in self.allPlannedFutureMoves do
			tmpArray.add(futMove.getTrackedItem);
		endforeach;				
	endif;

	foreach ti in tmpArray do
		// must match discharge port
		if ti.dischargePort &lt;&gt; _dischargePort then
			continue;
		endif;
		// must match voyage
		if ti.voyageCode &lt;&gt; _voyageCode then
			continue;
		endif;
		// must match commodity
		if ti.commodityGroup &lt;&gt; _commodityGroup then
			continue;
		endif;		
		// we have a match, make sure it's not already in dict as 40' ti span two controllers
		if (not _dict.includes(ti)) then
			_dict.add(ti);
		endif;
	endforeach;

epilog
	delete tmpArray;
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_commodityGroup" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
