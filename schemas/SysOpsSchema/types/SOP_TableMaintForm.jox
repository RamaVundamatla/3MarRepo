    <JadeMethod name="cmbTable_closeup" id="89df0c16-3349-4cb3-8ca6-bb480ec7fad5">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTable_closeup(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		2 March 2010 by cnwjo3
//
// Purpose:		par 22729, moved here from click
//
begin
	app.mousePointer	:=	Busy;
	
	if combobox.listIndex &gt; 0 then
		self.setCurrentTableItem(cmbTable.listObject.SOP_TableMaintItem);
		self.doCurrentTableChange(self.isFirstActivateComplete);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
