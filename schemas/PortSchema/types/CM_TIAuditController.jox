    <JadeMethod name="addExtraAttrProps" id="e7e2d022-6f90-488b-91d9-b0700020e4e6">
        <source>addExtraAttrProps();
/*
Date		Who		Reason
11 Nov 2008	cnwrd1	Initial creation - hack for extradata attributes that arnt real properties or yet mapped
10 May 2010	cnwdap1	PAR #24193 Reefer properties for connect/disconnect transactions
08 Jan 2014	cmwer1	PAR 32291 there were reefer properties not being audited 
02 Oct 2019	JLGNS1	ChangeRequest 45790: JMT - Refactor - Seal Transactions
13 Oct 2023	navma1  ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement
16 Oct 2024 navhn30 MTN-19827 If seals are changed the Seal Recorded transaction is not showing 'from/to' values
*/

vars
	tmpAuditAttr	: CM_AuditAttribute;
	tmpClass		: Class;
	classes			: ClassColl;
	sealType 		: CM_SealType;
	reeferProps		: PropertyColl;
	reeferProp		: Property;
	hasSealType     : Boolean;
	ti				: CM_TrackedItem;
	root			: CM_Root;
	tiClass			: Class;
begin
	
	/*
	30.10.2023 navma1 #60841
	*/
	
	root 		:= app.myRoot;
	ti   		:= self.getTI();
	hasSealType := true;
	
	if ti &lt;&gt; null then
		hasSealType := ti.hasSealTypes();
		tiClass     := ti.class;
	endif;
	
	// Now do the subclasses
	create classes transient;
	
	if tiClass &lt;&gt; null then													//30.10.2023 navma1 #60841
		tiClass.allSuperclassesUpTo(classes,CM_TrackedItem);				//30.10.2023 navma1 #60841
		if tiClass &lt;&gt; CM_TrackedItem then			// 16.10.24	 navhn30	MTN 19827
			classes.add(tiClass);
		endif;
	else
		classes.add(CM_TrackedItem);
		CM_TrackedItem.allSubclasses(classes);
	endif;
	
	reeferProps	:= CM_TIReeferProperties.allPropertiesUpTo(CM_Object);		//epr par 32291 8/1/14 
	
	foreach tmpClass in classes do
		
		create tmpAuditAttr transient;
		tmpAuditAttr.initNoProp(OperatorImportReleasePIN, tmpClass, self ) ;
		
		create tmpAuditAttr transient;
		tmpAuditAttr.initNoProp(OperatorExportReleaseNumber, tmpClass, self ) ;
		
		//epr par 32291 8/1/14 
		foreach reeferProp in reeferProps do
			//epr TFS 2509 9/8/16 these are audited with there own transactions
			if  reeferProp = CM_TIReeferProperties::lastConnectDT    or
				reeferProp = CM_TIReeferProperties::lastDisconnectDT or
				reeferProp = CM_TIReeferProperties::firstConnectDT   then
				continue;
			endif;
			
			if self.allAuditAttributesByClsAttr[tmpClass,reeferProp.name] = null then
				create tmpAuditAttr transient;
				tmpAuditAttr.init(reeferProp, tmpClass, self);
			endif;		
		endforeach;
		
		//17 Jan 2020	NDL	TFS 48249
		if tmpClass = CM_BreakBulkGeneric then
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(CM_PalletDetailsTI::heatTreated.name, tmpClass, self );
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(CM_PalletDetailsTI::myPalletType.name, tmpClass, self );
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(CM_PalletDetailsTI::storeOnPallets.name, tmpClass, self );
		endif;

		if hasSealType then														 //30.10.2023 navma1 #60841
			//29 Sep 2010	NDL	Par 25608
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(PrevSealNum, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealDT, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNum, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNumCustoms, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNumShippers, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNumVent, tmpClass, self ) ;
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNumTerminalOperator, tmpClass, self ) ;	//ChangeRequest 45790
			create tmpAuditAttr transient;
			tmpAuditAttr.initNoProp(SealNumUnknown, tmpClass, self ) ;			//ChangeRequest 45790
			
			foreach sealType in root.allSealTypes do							//13.10.2023 navma1 #60841
				if sealType.isSystemSealType then
					continue;
				endif;
				create tmpAuditAttr transient;
				tmpAuditAttr.initNoProp(sealType.description, tmpClass, self ) ;
			endforeach;
		endif;
		
	endforeach;



epilog
	delete classes;			// KPD 30/04/2009 - prevent transient leak
	delete reeferProps;
end;</source>
    </JadeMethod>
    <JadeMethod name="copyBeforeAfterValues" id="56dd7680-2f6f-4094-9bed-66fdab1dbb0f">
        <updating/>
        <source>copyBeforeAfterValues(_sourceAudit : CM_TIAuditController) updating;
/* ---------------------------------------------------------------------------
Created:	16 November 2009	by cnwvu1

Purpose:	PAR 20048
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	attr,
	sourceAttr	: CM_AuditAttribute;
	
begin
	
	foreach sourceAttr in _sourceAudit.allAuditAttributesByAttrCls do
		attr := self.allAuditAttributesByAttrCls[sourceAttr.attrName, sourceAttr.myClass];
		if attr &lt;&gt; null then
			attr.setBeforeAfterValues(sourceAttr.beforeValue, sourceAttr.afterValue);
		endif;
	endforeach;

end;</source>
        <Parameter name="_sourceAudit" type="CM_TIAuditController"/>
    </JadeMethod>
    <JadeMethod name="delete" id="7c9d166e-0b42-433e-a666-af435f16ef25">
        <updating/>
        <source>delete() updating;
/* ---------------------------------------------------------------------------
Created:     29 June 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	delete self.mySubAuditController;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAuditChangedSeals" id="ee9329e0-8ba4-4047-bac9-6f70c3b7a69e">
        <source>doAuditChangedSeals( _realTI  :CM_TrackedItem input; _pxyTI : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2019	jlgns1	Initial creation
//ChangeRequest 45790: JMT - Refactor - Seal Transactions
*/

vars
	sealsEdit : CM_Edit;
begin

	if _realTI = null or _pxyTI = null then
		return;
	endif;
	
	create sealsEdit transient;
	
	//jlier1 17/4/25 MTN-34671
	self.setAuditSealValues(_realTI,true);
	self.setAuditSealValues(_pxyTI,false);	
	
	//self.setAuditAttributeValues(_realTI,true);
	//self.setAuditAttributeValues(_pxyTI,false);
		
	self.getChangedValuesAsStrings(_realTI, AuditUpdated, sealsEdit.fieldsValues,true);
		
	if sealsEdit.fieldsValues.numStrings &gt; 0 then
		_realTI.createSealTransForChangedSeals(SEAL_CHECK_RECORDED,sealsEdit);
	endif;	
		
		
	
epilog
	delete sealsEdit;
	
end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getCustomSealValues" id="a066970e-fb2e-4aa4-8f3d-03b4ad01ece1">
        <source>getCustomSealValues(_obj: CM_Object; _auditAttr: CM_AuditAttribute io) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation

*/

vars

	sealType : CM_SealType;
	
begin

	//auditing of user defined seal types...
	sealType := app.myRoot.getSealTypeByDescription(_auditAttr.attrName);
	if sealType &lt;&gt; null then
		return _obj.formatAuditText(_auditAttr.attrName, _obj.CM_TrackedItem.getSealValue(sealType) );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_auditAttr" type="CM_AuditAttribute" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="a64b765a-01e1-48b1-923d-bd24ef3a5991">
        <source>getTI(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2023	navma1 ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement

*/

vars

begin
	return self.myTrackedItem;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="init" id="fce4bee3-4ce3-4e42-87b4-3bf91fdb33aa">
        <source>init();
// ---------------------------------------------------------------------------
// Created:     04 March 2004	cnwth2
//
// Purpose:     
//13 Oct 2023	navma1		ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement		 
// ----------   ----------  --------------------------------------------------
vars
	clsProp	: CM_AuditedClassProperty;
	dict	: CM_ClassPropByClassPropDic;
	ls		: Boolean;
begin

	dict := app.myRoot.allAuditedClassProperties;
	app.cmsBeginLoad(ls);
	
	/*
	13.10.2023 navma1 #60841
	foreach clsProp in dict do
		self.allAuditedClassProperties.add(clsProp);
	endforeach;
	*/
	
	dict.copy(self.allAuditedClassProperties);							//13.10.2023 navma1 #60841
	
	self.createAttributesForClass(CM_TrackedItem);
	self.addExtraAttrProps(); 											//cnwrd1 10.11.08 CCMS JMT 1743/1764 
epilog
	app.cmsEndLoad(ls);

end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseTransaction" id="10ea1501-50fc-4411-9515-47e0935d619b">
        <updating/>
        <source>initialiseTransaction() updating;
/* ---------------------------------------------------------------------------
Created:     29 June 2010 by cnwrs2

Purpose:     PAR 24822 - ensure any sub-audit controller is deleted at start of transaction (RJS 29 Jun 2010) 
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	delete self.mySubAuditController;
	
	self.myTrackedItem := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isFor" id="dd0a7b2f-a318-46c3-add8-7bcb142be755">
        <source>isFor(_ti: CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2012	cnwndl1	Initial creation	Par 30594

*/

vars

begin

	return self.myTrackedItem = _ti;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditSealValue" id="7cc6e567-ce15-4b13-bae7-3fea02b10167">
        <source>setAuditSealValue(_attr : String; _class : Class; _value : String; _isBefore : Boolean  ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2025	jlier1	Initial creation MTN-34671

*/

vars
	tmpAuditAttr	: CM_AuditAttribute;
	value 				  : String;
	sealType 		: CM_SealType;
begin
	tmpAuditAttr := self.allAuditAttributesByAttrCls[_attr, _class];
	if tmpAuditAttr = null then
		create tmpAuditAttr transient;
		tmpAuditAttr.initNoProp(_attr, _class, self ) ;
	endif;
	value:=_attr &amp; AuditStringSeparator &amp; 
		   _value.length.String &amp; AuditStringSeparator &amp; 
		   _value &amp; AuditStringSeparator;
	if _isBefore then
		tmpAuditAttr.beforeValue := value;
	else
		tmpAuditAttr.afterValue  := value;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_isBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditSealValues" id="f8cf0e58-8d51-4957-83ed-58ce81f44eab">
        <source>setAuditSealValues(_obj : CM_TrackedItem; _isBefore : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2025	jlier1	Initial creation MTN-34671

*/

vars
	sealType 		: CM_SealType;
	iter : Iterator;
	sealTi : CM_SealTI;
	prevNum, sealDT : String;
begin
	sealTi := _obj.allSeals[ SealType_Operator] ;
	if sealTi &lt;&gt; null then
		prevNum:=sealTi.previousSeal;
		sealDT:=sealTi.sealedDT.asStringJMT;
	endif;
	self.setAuditSealValue(PrevSealNum, _obj.class, prevNum, _isBefore);
	self.setAuditSealValue(SealDT, _obj.class, sealDT, _isBefore);
	
	iter:=_obj.myCargoType.allSealTypes.createIterator;
	
	while iter.next(sealType) do
	
		self.setAuditSealValue(sealType.description, _obj.class, _obj.getSealValue(sealType), _isBefore);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_TrackedItem"/>
        <Parameter name="_isBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="12403fe9-e4ae-44ca-b8b3-efe7603ea224">
        <updating/>
        <source>setMyTrackedItem(_ti : CM_TrackedItem)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2023	navma1 ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement

*/

vars

begin
	self.myTrackedItem := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
