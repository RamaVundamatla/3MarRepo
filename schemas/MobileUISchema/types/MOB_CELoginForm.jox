    <JadeMethod name="setupForm" id="46f5c5a0-f2ac-4759-9be2-615934a006ef">
        <updating/>
        <source>setupForm()updating, protected;
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod;
	self.pic_Back.zOrder(0); //:= false;
// cnwgb1 prototyping for PNL CCMS 1872 temporary
//	self.maxButton := false;
//	self.minButton := false;
	self.adjustFormForDevice();
// end cnwgb1 prototyping for PNL CCMS 1872 temporary
	
	if not self.myMobileDataAgent.setClientConnectionDetails(hasWarningsOnly) then
		unloadForm;
		return;
	endif;
	app.myMobileGUIAgent.setStrDevice(self.myMobileDataAgent.strDevice);
epilog
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dd1171bc-5082-4c71-9a3b-c530b0a8f965">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017596, locale);
	btnCancel.translateCaption(Xlat_0012963, locale);
	btnOK.translateCaption(Xlat_0012964, locale);
	lblPassword.translateCaption(Xlat_0012965, locale);
	lblUserName.translateCaption(Xlat_0012966, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
