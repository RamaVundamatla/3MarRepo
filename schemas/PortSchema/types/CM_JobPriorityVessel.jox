<Class name="CM_JobPriorityVessel" id="aab0f52d-5a0d-43ac-966b-187312b0c99a">
    <superclass name="CM_JobPriority"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myVessel" id="7f84aa88-6b06-49bc-b01d-61116cecc553">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Vessel"/>
        <access>readonly</access>
        <Inverse name="CM_Vessel::allJobPriorities"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="f2c5dd9f-c8f3-4c3f-8cd8-a4fe4a3c9720">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	jp : CM_JobPriorityVessel;
	completedOK		: Boolean;
begin
	jp :=  inheritMethod();
	
	jp.myVessel := self.myVessel;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return jp;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete jp;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ae8c24aa-47eb-4e27-9e44-0c2a8cde55f8">
        <updating/>
        <source>setForCreate(_pxyPriority: CM_JobPriorityVessel) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_pxyPriority);
	self.myVessel := _pxyPriority.myVessel;

end;</source>
        <Parameter name="_pxyPriority" type="CM_JobPriorityVessel"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4b2f42c1-a2a1-46b7-b29c-d99168d847ef">
        <updating/>
        <source>setProxy(_ct: Integer; _jt: Integer; _p: Integer; _object: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_ct, _jt, _p, _object);
	
	self.myVessel := _object.CM_Vessel;

end;</source>
        <Parameter name="_ct" type="Integer"/>
        <Parameter name="_jt" type="Integer"/>
        <Parameter name="_p" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
</Class>
