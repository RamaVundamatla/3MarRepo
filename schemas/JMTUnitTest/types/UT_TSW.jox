              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST3 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST4 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 2 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 2 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 2 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 2 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 2 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' exists for cargo ' &amp; ti1.id &amp; '. It should not';
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), false, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 2 End - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 3 Start - Test Role Code that is GC. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINER1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINER2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	// add an import stop
	foreach ti1 in tiSet do
		self.addStopById(ti1, STOP_ID_TT);
	endforeach;
	
	foreach ti1 in tiSet do
		// check - cargo should have the TT stop
		tempStr	:= 'Test 3 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), true, tempStr);
		
	endforeach;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 6, "Test 3 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_GC &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20200122&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZTRG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;181&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;1C&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;Consignee&gt;
          
            &lt;Name&gt;ROHLIG NEW ZEALAND LTD&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;1953.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;79&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
            
              &lt;GrossMassMeasure unitCode="KGM"&gt;2737.3&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;137&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
          
            &lt;Name&gt;ROHLIG CHINA LIMITED NINGBO BRANCH&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
          
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINER1 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474138&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINER2 &amp; '&lt;/ID&gt;
            &lt;Seal&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;ID&gt;CN3474193&lt;/ID&gt;
            &lt;/Seal&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
          
            &lt;ID&gt;NZTRG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200120091629&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS &amp; '&lt;/NameCode&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 3 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 3 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 3 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 3 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been cleared
		tempStr	:= 'Test 3 - Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTableTT.heading.display &amp; ' still exists for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TT), false, tempStr);
		
	endforeach;
	
	/*
	**	Test 3 End - Test Role Code that is TT. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	//Delete TSW TT STOP
	stopsTableTT := self.getRoot.getStopTableForId(STOP_ID_TT);
	if stopsTableTT &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_TT);
		self.assertIsDeletedMsg(stopsTableTT, "stopsTableTT");
	endif;
	
	//Delete TSW GC STOP
	stopsTableGC := self.getRoot.getStopTableForId(STOP_ID_GC);
	if stopsTableGC &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_GC);
		self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
	endif;
	
	//Delete Customs Action TT
	realCustomsActionTT := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_TT];
	if realCustomsActionTT &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_TT, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionTT);
	endif;
	
	realCustomsActionTT := null;
	
	//Delete Customs Action GC
	realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
	if realCustomsActionGC &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_GC, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionGC);
	endif;
	
	realCustomsActionGC := null;
	
	completedOk := true;
	
epilog
	if not completedOk then
		//Delete TSW TT STOP
		stopsTableTT := self.getRoot.getStopTableForId(STOP_ID_TT);
		if stopsTableTT &lt;&gt; null then
			self.deleteStopsTable(STOP_ID_TT);
			self.assertIsDeletedMsg(stopsTableTT, "stopsTableTT");
		endif;
		
		//Delete TSW GC STOP
		stopsTableGC := self.getRoot.getStopTableForId(STOP_ID_GC);
		if stopsTableGC &lt;&gt; null then
			self.deleteStopsTable(STOP_ID_GC);
			self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
		endif;
		
		//Delete Customs Action TT
		realCustomsActionTT := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_TT];
		if realCustomsActionTT &lt;&gt; null then
			self.deleteEDIAction(CUSTOMS_ACTION_NAME_TT, null, EDIKeyField_Clearance);
			self.assertIsDeleted(realCustomsActionTT);
		endif;
		
		realCustomsActionTT := null;
		
		//Delete Customs Action GC
		realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
		if realCustomsActionGC &lt;&gt; null then
			self.deleteEDIAction(CUSTOMS_ACTION_NAME_GC, null, EDIKeyField_Clearance);
			self.assertIsDeleted(realCustomsActionGC);
		endif;
		
		realCustomsActionGC := null;
	endif;
	delete pxyStopsTableTT;
	delete pxyStopsTableGC;
	delete pxyCustomsActionTT;
	delete pxyCustomsActionGC;
	delete intArray;
	delete setArray;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWIM1StopsChanges" id="9782ae28-5042-4629-99d3-806108ee95c1">
        <source>tTSWIM1StopsChanges();
/*

Purpose:			To Test changes in 60223 (60381)
					Stops should be added/cleared from an IM1 all clear message if they are not currently on the ti or have not previously been cleared

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
13 September 2023	navpw1	Initial creation TFS: 60223 (60381)

*/

constants
	STOP_ID_CIDO_UBond					: Integer	= 903;
	CUSTOMS_ACTION_NAME_CIDO			: String	= "CIDO Underbond 819";
	CUSTOMS_ACTION_KEYWORD_819			: String	= "819";
	DECLARATION_PROCESSING_STATUS_819	: String	= '819';
	DECLARATION_PROCESSING_STATUS_C06	: String	= 'C06';
	OPERATOR_CODE						: String	= 'UTOP';
	BLOCKSTACK							: String	= 'UTB' &amp; DECLARATION_PROCESSING_STATUS_819;
	VESSEL								: String	= 'UTBOL' &amp; DECLARATION_PROCESSING_STATUS_819;
	VOYAGE								: String	= 'UT' &amp; self.TFS60223 &amp; '_' &amp; DECLARATION_PROCESSING_STATUS_819;
	CONTAINER_TEST_1					: String	= self.TFS60223 &amp; '-' &amp; DECLARATION_PROCESSING_STATUS_819 &amp; '-1';
	BOL1								: String	= 'BOL120N28100-3';
	USER_DEF_NAME						: String	= 'TSW';
	
vars
	pxyStopsTableCIDO_UBond,
	stopsTableCIDO_UBond				: CM_StopsTable;
	pxyStopTableTemplate_CIDO_UBond,
	stopTableTemplate_CIDO_UBond		: CM_StopTableTemplate;
	pxyCustomsAction819CIDO,
	realCustomsAction819CIDO			: CM_EDIAction;
	operator							: CM_Operator;
	blockStack							: CM_BlockStack;
	vessel								: CM_Vessel;
	voyage								: CM_Voyage;
	tiSet								: CM_TISet;
	ti1									: CM_TrackedItem;
	ediFile								: CM_EDIFile;
	ediTI								: CM_EDITrackedItem;
	ediStop								: CM_EDICustomStopTI;
	checkAreas,
	setArray,
	processAreasArray					: IntegerArray;
	importStops,
	found1								: Boolean;
	ediText,
	tempStr								: String;
	
begin
	importStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, false);
	
	//Get Operator
	operator := self.getOperator(OPERATOR_CODE);
	self.assertNotNull(operator);
	
	/*
		Delete/Tidy Up Previous Data
	*/
	//Delete Terminal Area
	self.deleteTerminalArea(BLOCKSTACK);
	
	//Delete Voyage
	self.deleteVoyage(VOYAGE);
	
	//Delete Vessel
	self.deleteVessel(VESSEL);
	
	//Delete CIDO Underbond Stop Config (Customs Import Stop) for UT Terminal
	stopsTableCIDO_UBond := self.getRoot.getStopTableForId(STOP_ID_CIDO_UBond);
	if stopsTableCIDO_UBond &lt;&gt; null then
		stopTableTemplate_CIDO_UBond := stopsTableCIDO_UBond.allStopTableTemplates[app.myPassport.myTerminal, stopsTableCIDO_UBond];
		if stopTableTemplate_CIDO_UBond &lt;&gt; null then
			beginTransaction;
			delete stopTableTemplate_CIDO_UBond;
			commitTransaction;
			self.assertIsDeletedMsg(stopTableTemplate_CIDO_UBond, "stopTableTemplate_CIDO_UBond");
		endif;
	endif;
	
	stopsTableCIDO_UBond := null;
	
	//Delete CIDO Underbond 819 Customs Action
	realCustomsAction819CIDO := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_CIDO];
	if realCustomsAction819CIDO &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_CIDO, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction819CIDO);
	endif;
	
	realCustomsAction819CIDO := null;
	
	/*
		Create Data
	*/
	//Create BlockStack
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Create Vessel
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR_CODE, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Create CIDO Underbond Stop Config (Customs Import Stop) for UT Terminal
	pxyStopsTableCIDO_UBond := app.createUpdateProxy(self.getRoot.getStopTableForId(STOP_ID_CIDO_UBond)).CM_StopsTable;
	
	create pxyStopTableTemplate_CIDO_UBond transient;
	pxyStopTableTemplate_CIDO_UBond.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableCIDO_UBond );
	
	create checkAreas transient; //Prevent Actions
	checkAreas.add(31);
	checkAreas.add(26);
	checkAreas.add(3);
	checkAreas.add(2);
	checkAreas.add(20);
	
	create setArray transient;
	create processAreasArray transient;
	
	pxyStopTableTemplate_CIDO_UBond.setProxy(checkAreas,
									setArray,
									processAreasArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	app.myTrxUA.trxUpdateStopsTable(pxyStopsTableCIDO_UBond, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyStopsTableCIDO_UBond;
	delete checkAreas;
	delete setArray;
	delete processAreasArray;
	
	//Set the real stop table again
	stopsTableCIDO_UBond := self.getRoot.getStopTableForId(STOP_ID_CIDO_UBond);
	
	//Create CIDO Underbond 819 Customs Action
	create pxyCustomsAction819CIDO transient;
	pxyCustomsAction819CIDO.setProxy(CUSTOMS_ACTION_NAME_CIDO, CUSTOMS_ACTION_KEYWORD_819, EDIKeyField_Clearance, EDIAction_Add, stopsTableCIDO_UBond, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction819CIDO, realCustomsAction819CIDO, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction819CIDO, "realCustomsAction819CIDO");
	
	delete pxyCustomsAction819CIDO;
	
	
	/*
	**	Test 1 Start - Test IM1 All Clear Adds/Removes Stops
	*/
	
	/*
	** Setup
	*/
	//Create Tracked item
	create tiSet transient;
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UTTI_DischargePort, "NZPOE");
	ti1 := self.addContainerAtLocation(CONTAINER_TEST_1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	tiSet.add(ti1);
	self.opts.purge;
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 1, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := '&lt;?xml version="1.0"?&gt;
&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
	&lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
	&lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
	&lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
	&lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
	&lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
	&lt;CommunicationMetaData&gt;
		&lt;Recipient&gt;
			&lt;ID&gt;51363182A&lt;/ID&gt;
			&lt;RoleCode&gt;GC&lt;/RoleCode&gt;
		&lt;/Recipient&gt;
	&lt;/CommunicationMetaData&gt;
	&lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
		&lt;IssueDateTime formatCode="204"&gt;20181116104137&lt;/IssueDateTime&gt;
		&lt;FunctionalReferenceID&gt;202&lt;/FunctionalReferenceID&gt;
		&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
		&lt;AdditionalInformation&gt;
			&lt;StatementDescription&gt;1 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
			&lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
		&lt;/AdditionalInformation&gt;
		&lt;OverallDeclaration&gt;
			&lt;Declaration&gt;
				&lt;ID&gt;9846485&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode="204"&gt;20181116104137&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;PNSN_IM1005_2&lt;/FunctionalReferenceID&gt;
				&lt;TotalGrossMassMeasure unitCode="KGM"&gt;10500&lt;/TotalGrossMassMeasure&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;JurisdictionDateTime formatCode="102"&gt;20181118&lt;/JurisdictionDateTime&gt;
				&lt;Submitter&gt;
					&lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;Agent&gt;
					&lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
				&lt;/Agent&gt;
				&lt;BorderTransportMeans&gt;
					&lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
					&lt;ID&gt;9326093&lt;/ID&gt;
					&lt;TypeCode&gt;1&lt;/TypeCode&gt;
					&lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Carrier&gt;
					&lt;Name&gt;NSA&lt;/Name&gt;
				&lt;/Carrier&gt;
				&lt;GoodsShipment&gt;
					&lt;Consignment&gt;
						&lt;TransportContractDocument&gt;
							&lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
							&lt;TypeCode&gt;BM&lt;/TypeCode&gt;
							&lt;Pointer&gt;
								&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
							&lt;/Pointer&gt;
							&lt;Pointer&gt;
								&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
								&lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
							&lt;/Pointer&gt;
						&lt;/TransportContractDocument&gt;
						&lt;TransportEquipment&gt;
							&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
							&lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
							&lt;ID&gt;' &amp; CONTAINER_TEST_1 &amp; '&lt;/ID&gt;
						&lt;/TransportEquipment&gt;
					&lt;/Consignment&gt;
				&lt;/GoodsShipment&gt;
				&lt;Importer&gt;
					&lt;Name&gt;EXT ONline Importer&lt;/Name&gt;
				&lt;/Importer&gt;
				&lt;Packaging&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;QuantityQuantity&gt;55&lt;/QuantityQuantity&gt;
					&lt;TypeCode&gt;VN&lt;/TypeCode&gt;
				&lt;/Packaging&gt;
				&lt;UnloadingLocation&gt;
					&lt;ID&gt;NZNSN&lt;/ID&gt;
				&lt;/UnloadingLocation&gt;
				&lt;ResponsibleGovernmentAgency&gt;
					&lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			&lt;/Declaration&gt;
		&lt;/OverallDeclaration&gt;
		&lt;Status&gt;
			&lt;EffectiveDateTime formatCode="204"&gt;20181116104137&lt;/EffectiveDateTime&gt;
			&lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS_819 &amp; '&lt;/NameCode&gt;
			&lt;ReleaseDateTime formatCode="204"&gt;20181116104137&lt;/ReleaseDateTime&gt;
			&lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			&lt;/Pointer&gt;
			&lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			&lt;/Pointer&gt;
			&lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			&lt;/Pointer&gt;
		&lt;/Status&gt;
	&lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	
	/*
		Assert
	*/
	//Check ti has had the stop CIDO Underbond
	self.assertTrueMsg(ti1.hasHadStop(STOP_ID_CIDO_UBond), 'Test 1 - Tracked Item (' &amp; ti1.id &amp; ') has not had Stop: ' &amp; STOP_ID_CIDO_UBond.display &amp; Space &amp; stopsTableCIDO_UBond.heading.display &amp; " set and cleared. Expected result is that it should be set and clerared.");
	
	//Check ti does not still have CIDO Underbond stop
	self.assertTrueMsg(ti1.getStop(STOP_ID_CIDO_UBond) = null, 'Test 1 - Tracked Item (' &amp; ti1.id &amp; ') still has Stop: ' &amp; STOP_ID_CIDO_UBond.display &amp; Space &amp; stopsTableCIDO_UBond.heading.display &amp; ". Expected result is that the stop should not be set.");
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 1 End - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	
	/*
	** Test 2 Start - 
		//Import edi message C06 message
		//Assert no stops added
	*/
	
	/*
	** Setup
	*/
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := '&lt;DocumentMetadata xmlns="urn:wco:datamodel:WCO:DM:1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"&gt;
	&lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
	&lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
	&lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
	&lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
	&lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
	&lt;CommunicationMetaData&gt;
		&lt;Recipient&gt;
			&lt;ID&gt;51363182A&lt;/ID&gt;
			&lt;RoleCode&gt;TT&lt;/RoleCode&gt;
		&lt;/Recipient&gt;
	&lt;/CommunicationMetaData&gt;
	&lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
		&lt;IssueDateTime formatCode="204"&gt;20230827160602&lt;/IssueDateTime&gt;
		&lt;FunctionalReferenceID&gt;4&lt;/FunctionalReferenceID&gt;
		&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
		&lt;AdditionalInformation&gt;
			&lt;StatementDescription&gt;MB MB987654331 - MOVEMENT APPROVED&lt;/StatementDescription&gt;
			&lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
		&lt;/AdditionalInformation&gt;
		&lt;OverallDeclaration&gt;
			&lt;Declaration&gt;
				&lt;ID&gt;98607617&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode="204"&gt;20230827160602&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;NSN_TT_1&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
					&lt;Name&gt;OfficerSubmissionClientCode&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
					&lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
					&lt;TypeCode&gt;1&lt;/TypeCode&gt;
					&lt;ArrivalDateTime formatCode="102"&gt;20230713&lt;/ArrivalDateTime&gt;
					&lt;FirstArrivalLocationID&gt;NZAKL&lt;/FirstArrivalLocationID&gt;
					&lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
					&lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
					&lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;AdditionalInformation&gt;
						&lt;StatementCode&gt;1O&lt;/StatementCode&gt;
						&lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
					&lt;/AdditionalInformation&gt;
					&lt;AssociatedTransportDocument&gt;
						&lt;ID&gt;MB987654331&lt;/ID&gt;
						&lt;TypeCode&gt;MB&lt;/TypeCode&gt;
					&lt;/AssociatedTransportDocument&gt;
					&lt;Consignee&gt;
						&lt;Name&gt;NZ Chemicals&lt;/Name&gt;
					&lt;/Consignee&gt;
					&lt;ConsignmentItem&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;GoodsMeasure&gt;
							&lt;GrossMassMeasure unitCode="KGM"&gt;1234&lt;/GrossMassMeasure&gt;
						&lt;/GoodsMeasure&gt;
						&lt;Packaging&gt;
							&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
							&lt;QuantityQuantity&gt;10&lt;/QuantityQuantity&gt;
							&lt;TypeCode&gt;DR&lt;/TypeCode&gt;
						&lt;/Packaging&gt;
					&lt;/ConsignmentItem&gt;
					&lt;Consignor&gt;
						&lt;Name&gt;CN Chemicals&lt;/Name&gt;
					&lt;/Consignor&gt;
					&lt;GoodsLocation&gt;
						&lt;Name&gt;PORTNZTRG&lt;/Name&gt;
					&lt;/GoodsLocation&gt;
					&lt;TransitDestination&gt;
						&lt;Name&gt;PORTNZNSN&lt;/Name&gt;
					&lt;/TransitDestination&gt;
					&lt;TransportContractDocument&gt;
						&lt;ID&gt;332211&lt;/ID&gt;
						&lt;TypeCode&gt;BM&lt;/TypeCode&gt;
					&lt;/TransportContractDocument&gt;
					&lt;TransportEquipment&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
						&lt;ID&gt;' &amp; CONTAINER_TEST_1 &amp; '&lt;/ID&gt;
					&lt;/TransportEquipment&gt;
					&lt;UnloadingLocation&gt;
						&lt;ID&gt;NZTRG&lt;/ID&gt;
					&lt;/UnloadingLocation&gt;
				&lt;/Consignment&gt;
				&lt;ResponsibleGovernmentAgency&gt;
					&lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			&lt;/Declaration&gt;
		&lt;/OverallDeclaration&gt;
		&lt;Status&gt;
			&lt;EffectiveDateTime formatCode="204"&gt;20230827160602&lt;/EffectiveDateTime&gt;
			&lt;NameCode&gt;' &amp; DECLARATION_PROCESSING_STATUS_C06 &amp; '&lt;/NameCode&gt;
			&lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			&lt;/Pointer&gt;
			&lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			&lt;/Pointer&gt;
			&lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			&lt;/Pointer&gt;
		&lt;/Status&gt;
	&lt;/Response&gt;
&lt;/DocumentMetadata&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
		Assert
	*/
	//Check ti does not have CIDO Underbond stop
	self.assertTrueMsg(ti1.getStop(STOP_ID_CIDO_UBond) = null, 'Test 2 - Tracked Item (' &amp; ti1.id &amp; ') still has Stop: ' &amp; STOP_ID_CIDO_UBond.display &amp; Space &amp; stopsTableCIDO_UBond.heading.display &amp; ". Expected result is that the stop should not be set.");
	
	/*
	** Test 2 End - 
	*/
	
	/*
		Delete/Tidy Up Previous Data
	*/
	//Delete Terminal Area
	self.deleteTerminalArea(BLOCKSTACK);
	
	//Delete Voyage
	self.deleteVoyage(VOYAGE);
	
	//Delete Vessel
	self.deleteVessel(VESSEL);
	
	//Delete Stops and Customs Actions
	//Delete CIDO Underbond Stop Config (Customs Import Stop) for UT Terminal
	stopsTableCIDO_UBond := self.getRoot.getStopTableForId(STOP_ID_CIDO_UBond);
	if stopsTableCIDO_UBond &lt;&gt; null then
		stopTableTemplate_CIDO_UBond := stopsTableCIDO_UBond.allStopTableTemplates[app.myPassport.myTerminal, stopsTableCIDO_UBond];
		if stopTableTemplate_CIDO_UBond &lt;&gt; null then
			beginTransaction;
			delete stopTableTemplate_CIDO_UBond;
			commitTransaction;
			self.assertIsDeletedMsg(stopTableTemplate_CIDO_UBond, "stopTableTemplate_CIDO_UBond");
		endif;
	endif;
	
	//Delete CIDO Underbond 819 Customs Action
	realCustomsAction819CIDO := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_CIDO];
	if realCustomsAction819CIDO &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_CIDO, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction819CIDO);
	endif;
	
	realCustomsAction819CIDO := null;
	
epilog
	delete pxyStopsTableCIDO_UBond;
	delete checkAreas;
	delete setArray;
	delete processAreasArray;
	delete pxyCustomsAction819CIDO;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWMultipleBills1Cont" id="7eccc4e5-018c-4702-ba60-203677bbcb5c">
        <source>tTSWMultipleBills1Cont();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/01/2020	jlgdap1		Initial creation TFS 48188 PNL TSW messages with multiple bills
//
constants
	BLOCKSTACK = 'UTBS2';
	BOL1 = "BOL120N28100-1";
	BOL2 = "BOL120N281118-2";
	CONTAINER = "BOCU6192613";
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME = 'TSW';

vars
	blockStack : CM_BlockStack;
	stopsTable : CM_StopsTable;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	found1, found2 : Boolean;
	
begin
	// get rid of stuff - block stack, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);

	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	// create cargo - one container
	ti := self.addContainerAtLocation(CONTAINER, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	// add an import stop
	self.addStopById(ti, TI_Stop_Customs);
	
	// check - cargo should have a stop
	// check - voyage allTisByHouseBol should have 1 entries
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 1, "Voyage has incorrect number of House BOL TIs");
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
	self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	
	// edi text
	ediText := 
'&lt;?xml version="1.0"?&gt;
&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20190822144049&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;456&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;1 FCL(S) SAID TO CONTAIN 70 PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;21038029&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20190822144049&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;NNIM100122AUGB&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM"&gt;10500&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode="102"&gt;20190827&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
        
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;
        
          &lt;Name&gt;MOL&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;GoodsShipment&gt;
        
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL2 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportEquipment&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
              &lt;ID&gt;' &amp; CONTAINER &amp; '&lt;/ID&gt;
              &lt;Pointer&gt;
              
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportEquipment&gt;
            &lt;TransportEquipment&gt;
              &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
              &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
              &lt;ID&gt;' &amp; CONTAINER &amp; '&lt;/ID&gt;
              &lt;Pointer&gt;
              
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportEquipment&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;
        
          &lt;Name&gt;EXT ONline Importer&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;50&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;20&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;
        
          &lt;ID&gt;NZNSN&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;
        
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20190822144049&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204"&gt;20190822144049&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';

	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 2 edi tracked items
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "BOL 1 has incorrect pack count");
		elseif ediStop.billOfLading = BOL2 then
			found2 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "BOL 2 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1 and found2, "BOL 1 or BOL 2 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the cargo for import stop
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
	self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWMultipleBillsBulk" id="70c43dbf-69f6-4a92-ada6-6f51d6492c8c">
        <source>tTSWMultipleBillsBulk();
//
// Purpose:			TSW message with 2 house bills and no master bill - the BOL numbers are set as house BOLs
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/01/2020	jlgdap1		Initial creation TFS 48188 PNL TSW messages with multiple bills 
//
constants
	BLOCKSTACK = 'UTBS2';
	BOL1 = "BOL120N28118-1";		// BOL 1 has 5 cargo items
	BOL2 = "BOL120N28118-2";		// BOL 2 has 3 cargo items
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME = 'TSW';

vars
	blockStack : CM_BlockStack;
	stopsTable : CM_StopsTable;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	allCargoForBol1, allCargoForBol2 : CM_TISet;
	ti : CM_TrackedItem;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	found1, found2 : Boolean;

begin
	// get rid of stuff - block stack, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);

	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	// create cargo
	create allCargoForBol1 transient;
	create allCargoForBol2 transient;
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR02", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR03", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR04", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR05", "Rebar", operator, blockStack.myLocationsController));
	
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR02", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR03", "Rebar", operator, blockStack.myLocationsController));
	
	// assign the bol numbers as House BOLs on the TIs, assign to the voyage and make Import
	beginTransaction;
	foreach ti in allCargoForBol1 do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	foreach ti in allCargoForBol2 do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL2);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	commitTransaction;
	// now add an import stop
	foreach ti in allCargoForBol1 do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	foreach ti in allCargoForBol2 do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	
	// check - cargo should all have a stop
	// check - voyage allTisByHouseBol should have 8 entries
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 8, "Voyage has incorrect number of House BOL TIs");
	foreach ti in allCargoForBol1 do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	foreach ti in allCargoForBol2 do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	
	// edi text - two BOLs
	// BOL 1 has a count of 5 (matches number of cargo items, should have all stops cleared)
	// BOL 2 has a count of 10 (does not match number of cargo items, should NOT have stops cleared)
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20190903101854&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;459&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;8 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;    
      &lt;Declaration&gt;
        &lt;ID&gt;51240547&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20190903101854&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;NNIM10022SEPA&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM"&gt;10500&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode="102"&gt;20190906&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;        
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;        
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;        
          &lt;Name&gt;MOL&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;GoodsShipment&gt;        
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL2 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;              
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;              
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;        
          &lt;Name&gt;EXT ONline Importer&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;10&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;CT&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;5&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;        
          &lt;ID&gt;NZNSN&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;        
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20190903101854&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204"&gt;20190903101854&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;      
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;      
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 2 edi tracked items
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "EDI Data has incorrect number of EDI tracked items");
	
	// EDI tracked item with BOL1 id should have pack count of 5, EDI tracked item with BOL2 id should have pack count of 3
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.id = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 5, "BOL 1 has incorrect pack count");
		elseif ediStop.id = BOL2 then
			found2 := true;
			self.assertEqualMsg(ediStop.packCount, 10, "BOL 2 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1 and found2, "BOL 1 or BOL 2 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the cargo for import stop
	foreach ti in allCargoForBol1 do
		// BOL 1 - stop should have been cleared
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	endforeach;
	foreach ti in allCargoForBol2 do
		// BOL 2 - stop should still be there
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	
epilog
	delete allCargoForBol1;
	delete allCargoForBol2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWMultipleBillsMasterCont" id="47fb2819-6d22-4d7f-98df-d7b9b7a90415">
        <source>tTSWMultipleBillsMasterCont();
//
// Purpose:			Master bill and house bill in the file, 2 containers associated with the house bill
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/01/2020	jlgdap1		Initial creation TFS 48188 PNL TSW messages with multiple bills
// 19/02/2020	jlgdap1		TFS 48610 Not dealing correctly with Master BOL and 2 House BOLs
//
constants
	BLOCKSTACK = 'UTBS2';
	MASTERBOL = "ACD0429920";
	HOUSEBOL = "S00778727";
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	CONTAINER1 = "CMAU0626088";
	CONTAINER2 = "TRHU1073588";
	USER_DEF_NAME = 'TSW';

vars
	blockStack : CM_BlockStack;
	stopsTable : CM_StopsTable;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	allCargoForBol : CM_TISet;
	ti : CM_TrackedItem;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	
begin
	// get rid of stuff - block stack, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_CustomsDocs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_CustomsDocs.display &amp; ' does not exist');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);

	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	// create cargo
	create allCargoForBol transient;
	allCargoForBol.add(self.addContainerAtLocation(CONTAINER1, operator, "22G1", "GENL", TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController));
	allCargoForBol.add(self.addContainerAtLocation(CONTAINER2, operator, "22G1", "GENL", TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController));
	
	// assign the house bol number and master bol number to the TIs, assign to the voyage and make Import
	beginTransaction;
	foreach ti in allCargoForBol do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, HOUSEBOL);
		ti.setPropertyValue(CM_TrackedItem::billOfLading.name, MASTERBOL);
		ti.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	// now add an import stop
	foreach ti in allCargoForBol do
		self.addStopById(ti, TI_Stop_CustomsDocs);
	endforeach;
	
	// check - cargo should all have a stop
	// check - voyage allTisByHouseBol should have 8 entries
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Voyage has incorrect number of House BOL TIs");
	foreach ti in allCargoForBol do
		tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_CustomsDocs), true, tempStr);
	endforeach;
	
	// edi text - one master BOL and one house BOL - house BOL has 2 containers associated with it
	ediText := 
'&lt;DocumentMetadata xmlns="urn:wco:datamodel:WCO:DM:1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESEX1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204" &gt;20190923112636&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;13300&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;2 FCL(S) SAID TO CONTAIN 5636 PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;24410951&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204" &gt;20190923112636&lt;/AcceptanceDateTime&gt;' &amp; 
        //&lt;FunctionalReferenceID&gt;S00778727&lt;/FunctionalReferenceID&gt;		// This was the same as a House BOL number which confused things
        '&lt;FunctionalReferenceID&gt;STHDIFF&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM" &gt;25700&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;Oceanbridge Shipping Limited&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
          &lt;Name&gt;Oceanbridge Shipping Limited&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9256389&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;
          &lt;Name&gt;ANL&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;Exporter&gt;
          &lt;Name&gt;Picot Productions Limited&lt;/Name&gt;
        &lt;/Exporter&gt;
        &lt;GoodsShipment&gt;
          &lt;ExitDateTime formatCode="102" &gt;20190927&lt;/ExitDateTime&gt;
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; MASTERBOL &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; HOUSEBOL &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportEquipment&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
              &lt;ID&gt;' &amp; CONTAINER1 &amp; '&lt;/ID&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Seal&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;ID&gt;B022051&lt;/ID&gt;
              &lt;/Seal&gt;
            &lt;/TransportEquipment&gt;
            &lt;TransportEquipment&gt;
              &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
              &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
              &lt;ID&gt;' &amp; CONTAINER2 &amp; '&lt;/ID&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Seal&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;ID&gt;B022041&lt;/ID&gt;
              &lt;/Seal&gt;
            &lt;/TransportEquipment&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;LoadingLocation&gt;
          &lt;ID&gt;NZNSN&lt;/ID&gt;
        &lt;/LoadingLocation&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;2640&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;2996&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204" &gt;20190923112636&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204" &gt;20190923112636&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetadata&gt;';
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 2 edi tracked items
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "EDI Data has incorrect number of EDI tracked items");
	
	// edi tracked items should have the house bol as their bol number
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		self.assertTrueMsg(ediStop.billOfLading = HOUSEBOL, "Container " &amp; ediTI.id &amp; " has the wrong bill of lading - " &amp; ediStop.billOfLading);
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the cargo for import stops - should have been cleared
	foreach ti in allCargoForBol do
		tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
	endforeach;
	
epilog
	delete allCargoForBol;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWMultipleBillsUnderMaster" id="a2d63223-1e25-498c-a0be-3a4cbf4e8d10">
        <source>tTSWMultipleBillsUnderMaster();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/01/2020	jlgdap1		Initial creation TFS 48188
//
constants
	BLOCKSTACK = 'UTBS2';
	BOL1 = "GC0738KW006";		// BOL 1 has 1 cargo item
	BOL2 = "GC0738KW007";		// BOL 2 has 3 cargo items
	BOL3 = "GC0738KW008";		// BOL 3 has 2 cargo items
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME = 'TSW';

vars
	blockStack : CM_BlockStack;
	stopsTable : CM_StopsTable;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	allCargoForBol1, allCargoForBol2, allCargoForBol3 : CM_TISet;
	ti : CM_TrackedItem;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	found1, found2, found3 : Boolean;

begin
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);

	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	// create cargo for the BOLs - will use rebar cargo type
	create allCargoForBol1 transient;
	create allCargoForBol2 transient;
	create allCargoForBol3 transient;
	allCargoForBol1.add(self.addCargoAtLocation("UT_BOL1REBAR01", "Rebar", operator, blockStack.myLocationsController));
	
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR02", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol2.add(self.addCargoAtLocation("UT_BOL2REBAR03", "Rebar", operator, blockStack.myLocationsController));
	
	allCargoForBol3.add(self.addCargoAtLocation("UT_BOL3REBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol3.add(self.addCargoAtLocation("UT_BOL3REBAR02", "Rebar", operator, blockStack.myLocationsController));
	
	beginTransaction;
	foreach ti in allCargoForBol1 do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	foreach ti in allCargoForBol2 do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL2);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	foreach ti in allCargoForBol3 do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL3);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	commitTransaction;
	// now add an import stop
	foreach ti in allCargoForBol1 do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	foreach ti in allCargoForBol2 do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	foreach ti in allCargoForBol3 do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	
	// check - voyage should have 6 cargo items in its house bol colletion, cargo should all have a stop
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 6, "Voyage has incorrect number of TIs with house BOLs");
	foreach ti in allCargoForBol1 do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	foreach ti in allCargoForBol2 do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	foreach ti in allCargoForBol3 do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	
	// edi text - one master BOL (which JMT ignores) and 3 house BOls
	// BOL 1 has a count of 1 (matches number of cargo items, should have all stops cleared)
	// BOL 2 has a count of 3 (matches number of cargo items, should have all stops cleared)
	// BOL 3 has a count of 2 (matches number of cargo items, should have all stops cleared)
	ediText :=
'&lt;DocumentMetadata xmlns="urn:wco:datamodel:WCO:DM:1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204" &gt;20191105082902&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;480&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;6 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;13332241&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204" &gt;20191105082902&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;PNSNIM155NOV1&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM" &gt;10500&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode="102" &gt;20191109&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;
          &lt;Name&gt;MOL&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;GoodsShipment&gt;
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;MOLU18000334451&lt;/ID&gt;
              &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp;BOL2 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; BOL3 &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;3&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;
          &lt;Name&gt;EXT ONline Importer&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;1&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;3&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;3&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;2&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;
          &lt;ID&gt;NZNSN&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204" &gt;20191105082902&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204" &gt;20191105082902&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetadata&gt;';
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 2 edi tracked items
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 3, "EDI Data has incorrect number of EDI tracked items");
	
	// EDI tracked item with BOL1 id should have pack count of 5, EDI tracked item with BOL2 id should have pack count of 3
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.id = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "BOL 1 has incorrect pack count");
		elseif ediStop.id = BOL2 then
			found2 := true;
			self.assertEqualMsg(ediStop.packCount, 3, "BOL 2 has incorrect pack count");
		elseif ediStop.id = BOL3 then
			found3 := true;
			self.assertEqualMsg(ediStop.packCount, 2, "BOL 3 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1 and found2 and found3, "BOL 1 or BOL 2 or BOL 3 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the cargo for import stop
	foreach ti in allCargoForBol1 do
		// BOL 1 - stop should have been cleared
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	endforeach;
	foreach ti in allCargoForBol2 do
		// BOL 2 - stop should have been cleared
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	endforeach;
	foreach ti in allCargoForBol3 do
		// BOL 3 - stop should have been cleared
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	endforeach;
	
epilog
	delete allCargoForBol1;
	delete allCargoForBol2;
	delete allCargoForBol3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWVoyageTranslations" id="f3971191-e522-4724-a0c2-d77e86435887">
        <source>tTSWVoyageTranslations();
//
// Purpose:			Test voyage translations - there are 2 sets of possible translations for TSW
//					- the voyage may have a translation for the voyage operator
//					- TSW also checks for a translation for the NZCS  "dummy" TSW operator
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2020	jlgdap1		Initial creation TFS 49328 CPL Customs Stops files for Motor Vehicles
//
constants
	BLOCKSTACK = "UTBS3";
	BILLOFLADING = "MOLU18001335940";
	VESSEL = "ORE";
	VOYAGE = "ORE014A";
	VOYAGETRANS = "14A";
	OPERATOR = "MSC";
	NZCSOPERATOR = "NZCS";
	CAR1 = "JHDFC2AG1XXX10286";
	CAR2 = "JHDFC2AG1XXX10292";
	CAR3 = "JHDFG8JP1XXX21485";
	CAR4 = "JHDFM8JL1XXX10244";
	CAR5 = "JHDFY1EULXXX10563";
	CAR6 = "JHHNCT2H40K012543";
	USER_DEF_NAME = 'TSW';
	
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	mscOperator, nzcsOperator : CM_Operator;
	blockStack : CM_BlockStack;
	bol : CM_BOLIn;
	car1, car2, car3, car4, car5, car6 : CM_Car;
	ediText : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	cargoType : CM_CargoType;
	mscTranslation, nzcsTranslation : CM_Xlation;
	criteria : String;
	opTerm : CM_OperatorTerminal;
	error : CM_EDIError;
	errors : String;

begin
	// delete block stack
	// delete voyage - leave vessel
	// delete cargo and BOL
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteBOL(BILLOFLADING, null);
	
	mscOperator := self.getOperator(OPERATOR);
	self.assertNotNull(mscOperator);
	nzcsOperator := self.getOperator(NZCSOPERATOR);
	self.assertNotNull(nzcsOperator);
	
	vessel := app.myRoot.allVessels[VESSEL];
	self.assertNotNull(vessel);
	
	// create voyage
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 2);
	self.assertNotNull(voyage);
	
	// create block stack
	blockStack := self.addBlockStack(BLOCKSTACK, 99, null);
	self.assertNotNull(blockStack);
	
	// create cargo on ship for the BOL
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Car];
	self.assertNotNull(cargoType);
	car1 := self.addCargoAtLocation(CAR1, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	car2 := self.addCargoAtLocation(CAR2, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	car3 := self.addCargoAtLocation(CAR3, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	car4 := self.addCargoAtLocation(CAR4, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	car5 := self.addCargoAtLocation(CAR5, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	car6 := self.addCargoAtLocation(CAR6, cargoType, mscOperator, blockStack.myLocationsController).CM_Car;
	
	// create BOL and add cargo to it
	bol := self.addBOLInForCars(BILLOFLADING, voyage, mscOperator, null, self.getMyTerminal);
	self.assertNotNull(bol);
	beginTransaction;
	car1.setMyVoyage(voyage, app.myPassport);
	car1.setMyReceivalBOL(bol);
	car1.setBOL(bol.number);
	car2.setMyVoyage(voyage, app.myPassport);
	car2.setMyReceivalBOL(bol);
	car2.setBOL(bol.number);
	car3.setMyVoyage(voyage, app.myPassport);
	car3.setMyReceivalBOL(bol);
	car3.setBOL(bol.number);
	car4.setMyVoyage(voyage, app.myPassport);
	car4.setMyReceivalBOL(bol);
	car4.setBOL(bol.number);
	car5.setMyVoyage(voyage, app.myPassport);
	car5.setMyReceivalBOL(bol);
	car5.setBOL(bol.number);
	car6.setMyVoyage(voyage, app.myPassport);
	car6.setMyReceivalBOL(bol);
	car6.setBOL(bol.number);
	commitTransaction;
	
	// Ccreate a voyage translation for MSC operator adn NZCS operator
	self.assertTrueMsg(self.createEDIXlation("14A", VOYAGE, XLATION_TYPE_VOYAGETERMINAL, false, mscOperator, cargoType, criteria), "MSC Voyage translation not created");
	foreach opTerm in mscOperator.allOperatorTerminals do
		if opTerm.myTerminal = self.getMyTerminal then
			mscTranslation := opTerm.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null].allInwardTranslations.first;
			break;
		endif;
	endforeach;
	self.assertNotNull(mscTranslation);
	self.assertTrueMsg(self.createEDIXlation("14A", VOYAGE, XLATION_TYPE_VOYAGETERMINAL, false, nzcsOperator, cargoType, criteria), "MSC Voyage translation not created");
	foreach opTerm in nzcsOperator.allOperatorTerminals do
		if opTerm.myTerminal = self.getMyTerminal then
			nzcsTranslation := opTerm.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null].allInwardTranslations.first;
			break;
		endif;
	endforeach;
	self.assertNotNull(nzcsTranslation);
	
	// load the EDI file
	ediText := '&lt;?xml version="1.0"?&gt;
&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;40522745C&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200408122822&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;62647&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;6 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;45007282&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200408122822&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;3079571-001&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM"&gt;35290&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode="102"&gt;20200421&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;DHL Global Forwarding (New Zealand) Limited&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
          &lt;Name&gt;DHL Global Forwarding (New Zealand) Limited&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;Orca Ace&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;14A&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;GoodsShipment&gt;
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;MOLU18001335940&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;
          &lt;Name&gt;Hino Distributors NZ Ltd&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;6&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VE&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;
          &lt;ID&gt;NZWLG&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20200408122822&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204"&gt;20200408122822&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item, and it should be a CM_EDICustomStopTI
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Phase 1 - EDI Data has incorrect number of EDI tracked items");
	self.assertTrueMsg(ediFile.ediData.allEDITrackedItems.first.isKindOf(CM_EDICustomStopTI), "Phase 1 - EDI TI is wrong kind");
	
	// verify the file - should be no warnings
	self.ediVerify(ediFile);
	foreach error in ediFile.ediData.allErrorWarnings do
		errors := errors &amp; error.text &amp; CrLf;
	endforeach;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, "Phase 1 - " &amp; errors);
	self.assertTrueMsg(ediFile.ediData.allErrorWarnings.isEmpty, "Phase 1 - " &amp; errors);
	
	// load to DB - edi customs stop should be DB Loaded
	self.ediDBLoad(ediFile);
	errors := null;
	foreach error in ediFile.ediData.allErrorWarnings do
		errors := errors &amp; error.text &amp; CrLf;
	endforeach;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Phase 1 - DBLoad failed " &amp; app.myPassport.getAllErrorsAndWarningsAsStr &amp; CrLf &amp; errors);
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.first.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Phase 1 - Customs Stop is not DBLoaded");
	
	// Phase 2 - delete the voyage translation for MSC operator and reload
	beginTransaction;
	mscTranslation.erase(NORMAL_ERASE);
	commitTransaction;
	
	// reload and verify and DB load the same edi file - result should be the same, no errors or warnings
	// and the Customs Stop EDi ti should be DB Loaded
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item, and it should be a CM_EDICustomStopTI
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Phase 2 - EDI Data has incorrect number of EDI tracked items");
	self.assertTrueMsg(ediFile.ediData.allEDITrackedItems.first.isKindOf(CM_EDICustomStopTI), "Phase 2 - EDI TI is wrong kind");
	
	// verify the file - should be no warnings
	self.ediVerify(ediFile);
	errors := null;
	foreach error in ediFile.ediData.allErrorWarnings do
		errors := errors &amp; error.text &amp; CrLf;
	endforeach;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, "Phase 2 - " &amp; errors);
	self.assertTrueMsg(ediFile.ediData.allErrorWarnings.isEmpty, "Phase 2 - " &amp; errors);
	
	// load to DB - edi customs stop should be DB Loaded
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Phase 2 - DBLoad failed " &amp; app.myPassport.getAllErrorsAndWarningsAsStr);
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.first.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Phase 2 - Customs Stop is not DBLoaded");	
	
	// Success!
epilog
	beginTransaction;
	delete nzcsTranslation;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWbol_OCR_C07" id="afe40819-d957-4ea5-88f6-4637f08b92f2">
        <source>tTSWbol_OCR_C07();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2019	jlgsl4	Further TSW UTs required - OCR
*/
constants
	BLOCKSTACK = 'UTBS2';
	CONTAINER = 'UTUT100011';
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME = 'TSW';
	BOL1 = "12345E";
vars
	blockStack : CM_BlockStack;
	container : CM_TrackedItem;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	stopsTable : CM_StopsTable;
	bol : CM_BOL;
	previousLogLevel	: Integer;
begin
	previousLogLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);

	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_CustomsDocs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	self.deleteContainer(CONTAINER);
	container := self.addContainerAtLocation(CONTAINER, null, '2100', 'GENL', TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController);
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	self.deleteVessel(VESSEL);
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	self.deleteVoyage(VOYAGE);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	self.deleteBOL(BOL1, bol);
	bol := self.addBOL(BOL1, voyage, operator, null, self.getTerminal());
	self.assertNotNull(bol);

	beginTransaction;	
	container.setMyVoyage(voyage, app.myPassport);
	bol.attachTI(container);
	commitTransaction;	

	ediText :=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESOCR&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;51365627A&lt;/ID&gt;
			  &lt;RoleCode&gt;N2&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20190115140615&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;960&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;62756699&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204' &gt;20190115140615&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;PPOE_OCR001&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; VESSEL &amp; "&lt;/Name&gt;
				  &lt;ID&gt;9876543&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;DepartureDateTime formatCode='102' &gt;20190115&lt;/DepartureDateTime&gt;
				  &lt;JourneyID&gt;" &amp; VOYAGE &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;AdditionalDocument&gt;
					&lt;ID&gt;88887777&lt;/ID&gt;
					&lt;TypeCode&gt;EDO&lt;/TypeCode&gt;
				  &lt;/AdditionalDocument&gt;
				  &lt;AssociatedTransportDocument&gt;
					&lt;ID&gt;" &amp; BOL1 &amp; "&lt;/ID&gt;
					&lt;TypeCode&gt;BM&lt;/TypeCode&gt;
				  &lt;/AssociatedTransportDocument&gt;
				&lt;/Consignment&gt;
				&lt;ExitOffice&gt;
				  &lt;ID&gt;NZPOE&lt;/ID&gt;
				&lt;/ExitOffice&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204' &gt;20190115140615&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;C07&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204' &gt;20190115140615&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container has no "CEDO" stop
	tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; CONTAINER;
	self.assertEqualMsg(container.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
epilog
	self.deleteContainer(CONTAINER);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteBOL(BOL1, bol);	
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	app.changeLogLevel(previousLogLevel);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_CRE_C06" id="3e712526-4f91-42da-abfc-e09cbfec2da7">
        <source>tTSWcntnr_CRE_C06();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2019	jlgsl4	Initial creation
23 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs
*/

constants
	BLOCKSTACK = 'UTBS2';
	CONTAINER = 'UTUT100011';
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME	= 'TSW';
vars
	blockStack : CM_BlockStack;
	container : CM_TrackedItem;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	stopsTable : CM_StopsTable;	
begin
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	self.assertNotNullMsg(blockStack, 'Add blockstack ' &amp; BLOCKSTACK &amp; ' failed');

	stopsTable := self.getRoot.getStopTableForId(TI_Stop_CustomsDocs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	self.deleteContainer(CONTAINER);
	container := self.addContainerAtLocation(CONTAINER, null, '2100', 'GENL', TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController);
	self.assertNotNullMsg(container, 'Add container ' &amp; CONTAINER &amp; ' failed');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	self.deleteVessel(VESSEL);
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	self.deleteVoyage(VOYAGE);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);

	beginTransaction;	
	container.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	ediText :=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESCRE&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;40048675B&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204'&gt;20180302084506&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;103&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;15875625&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204'&gt;20180302084506&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;CH020318_CRE5&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;CH Carriers&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; VESSEL &amp; "&lt;/Name&gt;
				  &lt;ID&gt;98765432&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;DepartureDateTime formatCode='102'&gt;20180301&lt;/DepartureDateTime&gt;
				  &lt;JourneyID&gt;" &amp; VOYAGE &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
				  &lt;GoodsStatusCode&gt;ITA&lt;/GoodsStatusCode&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;Consignee&gt;
					&lt;Name&gt;JLIP GROUP COMPANY LIMITED&lt;/Name&gt;
				  &lt;/Consignee&gt;
				  &lt;ConsignmentItem&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;GoodsMeasure&gt;
					  &lt;GrossMassMeasure unitCode='KGM'&gt;2000&lt;/GrossMassMeasure&gt;
					&lt;/GoodsMeasure&gt;
					&lt;Packaging&gt;
					  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					  &lt;QuantityQuantity&gt;1&lt;/QuantityQuantity&gt;
					  &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
					&lt;/Packaging&gt;
				  &lt;/ConsignmentItem&gt;
				  &lt;Consignor&gt;
					&lt;Name&gt;METHVEN LTD&lt;/Name&gt;
				  &lt;/Consignor&gt;
				  &lt;LoadingLocation&gt;
					&lt;ID&gt;NZNSN&lt;/ID&gt;
				  &lt;/LoadingLocation&gt;
				  &lt;TransportContractDocument&gt;
					&lt;ID&gt;BILL23456&lt;/ID&gt;
					&lt;TypeCode&gt;BN&lt;/TypeCode&gt;
				  &lt;/TransportContractDocument&gt;
				  &lt;TransportEquipment&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
					&lt;ID&gt;" &amp; CONTAINER &amp; "&lt;/ID&gt;
				  &lt;/TransportEquipment&gt;
				&lt;/Consignment&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204'&gt;20180302084506&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;C06&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204'&gt;20180302084506&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container has no "CEDO" stop
	tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; CONTAINER;
	self.assertEqualMsg(container.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
epilog
	self.deleteContainer(CONTAINER);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_EX1_807" id="3b07a24a-3791-437f-95c3-3d3d75da2f6c">
        <source>tTSWcntnr_EX1_807();
// jlgdap1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs
*/

constants
	BLOCKSTACK = 'UTBS2';
	CONTAINER = 'UTUT100011';
	VESSEL = 'UTV1';
	VOYAGE = 'UTV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME	= 'TSW';
vars
	blockStack : CM_BlockStack;
	container : CM_TrackedItem;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	stopsTable : CM_StopsTable;	
begin
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	self.assertNotNullMsg(blockStack, 'Add blockstack ' &amp; BLOCKSTACK &amp; ' failed');

	stopsTable := self.getRoot.getStopTableForId(TI_Stop_CustomsDocs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	self.deleteContainer(CONTAINER);
	container := self.addContainerAtLocation(CONTAINER, null, '2100', 'GENL', TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController);
	self.assertNotNullMsg(container, 'Add container ' &amp; CONTAINER &amp; ' failed');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	self.deleteVessel(VESSEL);
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	self.deleteVoyage(VOYAGE);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);

	beginTransaction;	
	container.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	ediText :=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESEX1&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;40015499G&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204' &gt;20180227152809&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;7&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;AdditionalInformation&gt;
			  &lt;StatementDescription&gt;1 FCL(S) SAID TO CONTAIN 10 PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
			  &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
			&lt;/AdditionalInformation&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;69383462&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204' &gt;20180227152809&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;CH270218_EX1&lt;/FunctionalReferenceID&gt;
				&lt;TotalGrossMassMeasure unitCode='KGM' &gt;1000&lt;/TotalGrossMassMeasure&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;Agent&gt;
				  &lt;Name&gt;CH Brokers&lt;/Name&gt;
				&lt;/Agent&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; VESSEL &amp; "&lt;/Name&gt;
				  &lt;ID&gt;987654321&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;JourneyID&gt;" &amp; VOYAGE &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Carrier&gt;
				  &lt;Name&gt;ANL LINE&lt;/Name&gt;
				&lt;/Carrier&gt;
				&lt;Exporter&gt;
				  &lt;Name&gt;CH Exporters&lt;/Name&gt;
				&lt;/Exporter&gt;
				&lt;GoodsShipment&gt;
				  &lt;ExitDateTime formatCode='102' &gt;20180228&lt;/ExitDateTime&gt;
				  &lt;Consignment&gt;
					&lt;TransportContractDocument&gt;
					  &lt;ID&gt;BILL123456&lt;/ID&gt;
					  &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportContractDocument&gt;
					&lt;TransportEquipment&gt;
					  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					  &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
					  &lt;ID&gt;" &amp; CONTAINER &amp; "&lt;/ID&gt;
					  &lt;Pointer&gt;
						&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					  &lt;Pointer&gt;
						&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
						&lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
					  &lt;/Pointer&gt;
					&lt;/TransportEquipment&gt;
				  &lt;/Consignment&gt;
				&lt;/GoodsShipment&gt;
				&lt;LoadingLocation&gt;
				  &lt;ID&gt;NZCHC&lt;/ID&gt;
				&lt;/LoadingLocation&gt;
				&lt;Packaging&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;QuantityQuantity&gt;10&lt;/QuantityQuantity&gt;
				  &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
				&lt;/Packaging&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204' &gt;20180227152809&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;807&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204' &gt;20180227152809&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container has no "CEDO" stop
	tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; CONTAINER;
	self.assertEqualMsg(container.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
	
	// Check that the container has 'EX1AllClear' set.
	tempStr	:= 'Container ' &amp; CONTAINER &amp; ' does not have EX1AllClear set';
	self.assertEqualMsg(container.hasTSWAllClear(TI_Stop_CustomsDocs), true, tempStr);

	// now test that CRE can't add 'CEDO' back b/c of EX1AllClear
	ediText :=
		"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
		  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
		  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
		  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
		  &lt;AgencyAssignedCustomizedDocumentName&gt;RESCRE&lt;/AgencyAssignedCustomizedDocumentName&gt;
		  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
		  &lt;CommunicationMetaData&gt;
			&lt;Recipient&gt;
			  &lt;ID&gt;40048675B&lt;/ID&gt;
			  &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
			&lt;/Recipient&gt;
		  &lt;/CommunicationMetaData&gt;
		  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
			&lt;IssueDateTime formatCode='204'&gt;20180302084506&lt;/IssueDateTime&gt;
			&lt;FunctionalReferenceID&gt;103&lt;/FunctionalReferenceID&gt;
			&lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
			&lt;OverallDeclaration&gt;
			  &lt;Declaration&gt;
				&lt;ID&gt;15875625&lt;/ID&gt;
				&lt;AcceptanceDateTime formatCode='204'&gt;20180302084506&lt;/AcceptanceDateTime&gt;
				&lt;FunctionalReferenceID&gt;CH020318_CRE5&lt;/FunctionalReferenceID&gt;
				&lt;VersionID&gt;1&lt;/VersionID&gt;
				&lt;Submitter&gt;
				  &lt;Name&gt;CH Carriers&lt;/Name&gt;
				&lt;/Submitter&gt;
				&lt;BorderTransportMeans&gt;
				  &lt;Name&gt;" &amp; VESSEL &amp; "&lt;/Name&gt;
				  &lt;ID&gt;98765432&lt;/ID&gt;
				  &lt;TypeCode&gt;1&lt;/TypeCode&gt;
				  &lt;DepartureDateTime formatCode='102'&gt;20180301&lt;/DepartureDateTime&gt;
				  &lt;JourneyID&gt;" &amp; VOYAGE &amp; "&lt;/JourneyID&gt;
				&lt;/BorderTransportMeans&gt;
				&lt;Consignment&gt;
				  &lt;GoodsStatusCode&gt;ITR&lt;/GoodsStatusCode&gt;
				  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				  &lt;Consignee&gt;
					&lt;Name&gt;JLIP GROUP COMPANY LIMITED&lt;/Name&gt;
				  &lt;/Consignee&gt;
				  &lt;ConsignmentItem&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;GoodsMeasure&gt;
					  &lt;GrossMassMeasure unitCode='KGM'&gt;2000&lt;/GrossMassMeasure&gt;
					&lt;/GoodsMeasure&gt;
					&lt;Packaging&gt;
					  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					  &lt;QuantityQuantity&gt;1&lt;/QuantityQuantity&gt;
					  &lt;TypeCode&gt;PK&lt;/TypeCode&gt;
					&lt;/Packaging&gt;
				  &lt;/ConsignmentItem&gt;
				  &lt;Consignor&gt;
					&lt;Name&gt;METHVEN LTD&lt;/Name&gt;
				  &lt;/Consignor&gt;
				  &lt;LoadingLocation&gt;
					&lt;ID&gt;NZNSN&lt;/ID&gt;
				  &lt;/LoadingLocation&gt;
				  &lt;TransportContractDocument&gt;
					&lt;ID&gt;BILL23456&lt;/ID&gt;
					&lt;TypeCode&gt;BN&lt;/TypeCode&gt;
				  &lt;/TransportContractDocument&gt;
				  &lt;TransportEquipment&gt;
					&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
					&lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
					&lt;ID&gt;" &amp; CONTAINER &amp; "&lt;/ID&gt;
				  &lt;/TransportEquipment&gt;
				&lt;/Consignment&gt;
				&lt;ResponsibleGovernmentAgency&gt;
				  &lt;ID&gt;NZCS&lt;/ID&gt;
				&lt;/ResponsibleGovernmentAgency&gt;
			  &lt;/Declaration&gt;
			&lt;/OverallDeclaration&gt;
			&lt;Status&gt;
			  &lt;EffectiveDateTime formatCode='204'&gt;20180302084506&lt;/EffectiveDateTime&gt;
			  &lt;NameCode&gt;C06&lt;/NameCode&gt;
			  &lt;ReleaseDateTime formatCode='204'&gt;20180302084506&lt;/ReleaseDateTime&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
			  &lt;/Pointer&gt;
			  &lt;Pointer&gt;
				&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
				&lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
				&lt;TagID&gt;G007&lt;/TagID&gt;
			  &lt;/Pointer&gt;
			&lt;/Status&gt;
		  &lt;/Response&gt;
		&lt;/DocumentMetadata&gt;";
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the container still has no "CEDO" stop
	tempStr	:= 'Stop ' &amp; TI_Stop_CustomsDocs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; CONTAINER;
	self.assertEqualMsg(container.isStopSet(TI_Stop_CustomsDocs), false, tempStr);
epilog
	self.deleteContainer(CONTAINER);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_ICR_B07" id="a5b89053-78c4-419b-a3dc-280efb338453">
        <source>tTSWcntnr_ICR_B07();
// jlgdap1
/*

Purpose:			Test ICR response against MAF stop.
					Loads a mock customs web service EDI message and confirms the messages loads successfully and the MAF container stops are removed
					Requires the JMTNzTswPlugin.dll to be loaded/available

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2019	jlgsl4	TFS 42426 - create TSW unit tests
26 Jun 2019 jlgmd1	Header tidied up and added a couple more asserts around some of the Stop assumptions
23 Sep 2019 jlgsl4	861.080 cut - add more TSW UTs
*/
constants
	USER_DEF_NAME	= 'TSW';
	VoyageName1		= 'PAR24050_1';
	BoatName1		= 'PAR24050Boat1';
	ContName		= 'UTUT1011011';
	TestOperator	= 'MSL';
vars
	tempStr			: String;
	billOfLadingStr	: String;
	ediText			: String;
	container		: CM_Container;
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	stopsTable		: CM_StopsTable;
	ediFile			: CM_EDIFile;
begin

	// Set up our required terminal config parameters (these are automatically set back after the test finishes)
	self.setTerminalConfig(GateInAutoBOLNumber, true);
    self.setTerminalConfig(NoImportStops, false);
	
	// Get our operator
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// Get our stops table
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_MAF);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_MAF.display &amp; ' does not exist');
	self.assertTrueMsg(stopsTable.isImportStop(self.getTerminal), "Expecting MAF Stop to be an Import stop");
	self.assertTrueMsg(stopsTable.isValidForFulls(false, self.getTerminal), "Expecting MAF stop 'Is Full' to be true");

	// delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName1);
	vessel	:= self.getVessel(BoatName1);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteCargo(ContName, self.getRoot.allCargoTypesById[TI_CargoType_Container]);
	container := self.getTrackedItem(ContName).CM_Container;
	self.assertIsDeleted(container);
	
	// Create the required voyage and vessel
	vessel := self.addVesselCellular(BoatName1, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed');
	
	voyage	:= self.addVoyageWithContainerStructur(VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	self.addVoyageToEDIProcessing(voyage); // 861.080	
	
	// finally add this cargo to the voyage
	/*self.opts.addAssocIfNotNull(ETRow_CargoType, TI_CargoType_Container); // --&gt; 861.080
	container := self.addContainerForExport(ContName,
										operator,
										"2200",
										null,					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;		// transhipToPort*/ // &lt;-- 861.080
	container := self.addContainerOnShip(ContName, // --&gt; 861.080
										operator,
										"2200",
										null,
										null,
										voyage,
										"NZPOE",
										VoyageName1).CM_Container; // &lt;-- 861.080
	tempStr	:= 'Adding container ' &amp; ContName.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	
	// Check that the container has "Customs Import Doc" stop on.
	tempStr	:= 'Stop ' &amp; TI_Stop_MAF.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_MAF), true, tempStr);
	
	// This gets set each time by the system - see CM_TrackedItem::setForCreate and Gate configuration form
	billOfLadingStr	:= container.billOfLading;
	tempStr	:= 'BillOfLading has not been set up';
	self.assertEqualMsg(billOfLadingStr &lt;&gt; null, true, tempStr);
	
	// This is an untransformed message similar to what we would get back from the customs web service
	ediText	:=
"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;40048675B&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
    &lt;IssueDateTime formatCode='204' &gt;20180418111543&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;505&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode='application/pdf' uri='idd_B641685B-E194-4E44-981D-0B7BFC1A92F3' filename='PDF7-91211711-2018-04-18-1104949015.pdf' &gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;MB 1478996 - MOVEMENT APPROVED&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;30041068&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode='204'&gt;20180418111543&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;ICR FAK&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;MPI Testing Org&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;" &amp; BoatName1 &amp; "&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode='102' &gt;20180425&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZAKL&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;" &amp; VoyageName1 &amp; "&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType='CLEARANCE' &gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType='MOVEMENT' &gt;HLD&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;MPI RELEASED&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;MCS&lt;/StatementTypeCode&gt;
            &lt;Pointer&gt;
              &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;28A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;&lt;![CDATA[seq:1,takenTo:'Mondiale Freight Services Limited, 77 Richard Pearse Drive, Auckland',for:'MPI APPROVAL TO MOVE TO ATF',by:'ACCREDITED PERSON',instructions:'MPI supervised unpacking required. Hold unopened. Contact local MPI office to arrange inspection..',issuedDate:'Wednesday, 18 April 2018 11:15:35 a.m.',issuedBy:'MPI SYSTEMS',transportEquipment:'TRIU1548990']]&gt;&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AssociatedTransportDocument&gt;
            &lt;ID&gt;1478996&lt;/ID&gt;
            &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
          &lt;/AssociatedTransportDocument&gt;
          &lt;Consignee&gt;
            &lt;Name&gt;Australian food Imports&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
              &lt;GrossMassMeasure unitCode='KGM'&gt;560&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;154&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;CT&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
            &lt;Name&gt;Food Exports&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransitDestination&gt;
            &lt;Name&gt;Mondiale Freight Services Limited&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;45878&lt;/ID&gt;
            &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;7&lt;/FullnessCode&gt;
            &lt;ID&gt;" &amp; ContName &amp; "&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
            &lt;ID&gt;NZNSN&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode='204' &gt;20180418111543&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;B07&lt;/NameCode&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetadata&gt;";

	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify( ediFile );
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// Check that container has "MAF" stop off.
	tempStr	:= 'Stop ' &amp; TI_Stop_MAF.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_MAF), false, tempStr);
epilog
	self.deleteContainer(ContName);
	self.deleteVoyage(VoyageName1);
	self.deleteVessel(BoatName1);	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_ICR_C06" id="b5793658-c117-4bfb-9977-e83a1bdbc941">
        <source>tTSWcntnr_ICR_C06();
// jlgdap1
/*

Purpose:			Test ICR response against Customs Import Doc stop. IM1 message will be similar
					but RESICR -&gt; RESIM1. Check stop can be removed then added back.
					Loads a mock customs web service EDI message and confirms the messages loads successfully and the Customs container stops are removed and added as required
					Requires the JMTNzTswPlugin.dll to be loaded/available
Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2019	jlgsl4	TFS 42426 - create TSW unit tests
26 Jun 2019 jlgmd1	Header tidied up and added a couple more asserts around some of the Stop assumptions
// 10 Sep 2019	cnwrs1	TFS 46030
23 Sep 2019	jlgsl4	861.080 cut - add more TSW UTs - not needed for wmast as BOL stop doesn't exist there
*/
constants
	USER_DEF_NAME	= 'TSW';
	VoyageName1		= 'PAR24050_1';
	BoatName1		= 'PAR24050Boat1';
	ContName		= 'UTUT1011011';
	TestOperator	= 'MSL';
	BOLSTOP			= 104;
vars
	tempStr			: String;
	billOfLadingStr	: String;
	ediText			: String;
	container		: CM_Container;
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	stopsTable		: CM_StopsTable;
	ediFile			: CM_EDIFile;
	isDoClearanceCheck,
	isNotAvailableForEntry : Boolean;
begin
	stopsTable := self.getRoot.getStopTableForId(BOLSTOP); // --&gt; 861.080
	if stopsTable &lt;&gt; null then
		isNotAvailableForEntry := stopsTable.isNotAvailableForEntry; // preserve for later
		if not isNotAvailableForEntry then
			beginTransaction;
			stopsTable.setNotAvailableForEntry(true); // set so test runs OK!
			commitTransaction;
		endif;
	endif; // &lt;-- 861.080
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// Set up our required terminal config parameters (these are automatically set back after the test finishes)
	self.setTerminalConfig(GateInAutoBOLNumber, true);
    self.setTerminalConfig(NoImportStops, false);
	
	// Get our operator
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// Get our stops table
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	self.assertTrueMsg(stopsTable.isImportStop(self.getTerminal), "Expecting Customs Import Docs Stop to be an Import stop");
	self.assertTrueMsg(stopsTable.isValidForFulls(true, self.getTerminal), "Expecting Customs Import Docs stop 'Is Full' and 'Is MT' to be true");	
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName1);
	vessel	:= self.getVessel(BoatName1);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteCargo(ContName, self.getRoot.allCargoTypesById[TI_CargoType_Container]);
	container := self.getTrackedItem(ContName).CM_Container;
	self.assertIsDeleted(container);
	
	// Create the required voyage and vessel
	vessel := self.addVesselCellular(BoatName1, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed');
	
	voyage	:= self.addVoyageWithContainerStructur(VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	
	// finally add this cargo to the voyage
	self.opts.addAssocIfNotNull(ETRow_CargoType, TI_CargoType_Container);
	container := self.addContainerForExport(ContName,
										operator,
										"2200",
										null,					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;		// transhipToPort
	tempStr	:= 'Adding container ' &amp; ContName.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	
	// Check that the container has "Customs Import Doc" stop on.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), true, tempStr);
	
	// This gets set each time by the system - see CM_TrackedItem::setForCreate and Gate configuration form
	billOfLadingStr	:= container.billOfLading;
	tempStr	:= 'BillOfLading has not been set up';
	self.assertEqualMsg(billOfLadingStr &lt;&gt; null, true, tempStr);
	
	// This is an untransformed message similar to what we would get back from the customs web service
	ediText	:=
"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51358641J&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
    &lt;IssueDateTime formatCode='204' &gt;20180718145109&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;354&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;99156761&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode='204' &gt;20180718145109&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;PW_ICR008&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt; " &amp; BoatName1 &amp; "&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode='102'&gt;20180720&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZWLG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;" &amp; VoyageName1 &amp; "&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType='CLEARANCE'&gt;statusText&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;Consignee&gt;
            &lt;Name&gt;Maersk Line&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;Consignor&gt;
            &lt;Name&gt;Maersk&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;1236467&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;4&lt;/FullnessCode&gt;
            &lt;ID&gt;" &amp; ContName &amp; "&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
            &lt;ID&gt;NZWLG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode='204'&gt;20180718145109&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;C06&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode='204' &gt;20180718145109&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetadata&gt;";

	// load the edi data, verify and load to database
	ediText := ediText.replace("statusText", "WOF"); // set message's GoodsStatusCode to write-off eg. clear stop
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify( ediFile );
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check that the container has "Customs Import Doc" stop off.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for container ' &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), false, tempStr);

	// now add the stop back using same message but &lt;GoodsStatusCode StatusType='CLEARANCE'&gt;HLD&lt;/GoodsStatusCode&gt;
	ediText := ediText.replace("WOF", "HLD");
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, "TSW" &amp; method.name);
	self.assertNotNull(ediFile);
	
	// Some common statuses are:
	// 3 = EDI_STATUS_VERIFIED, 14 = EDI_STATUS_VERIFIED_WARNINGS
	// 5 = EDI_STATUS_DBLOADED, 19 = EDI_STATUS_DBLOADED_PARTIAL
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);

	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// Check that the container has "Customs Import Doc" stop on.
	tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; " doesn't exist for container " &amp; ContName.display;
	self.assertEqualMsg(container.isStopSet(TI_Stop_Customs), true, tempStr);
epilog
	self.deleteContainer(ContName);
	self.deleteVoyage(VoyageName1);
	self.deleteVessel(BoatName1);
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	stopsTable := self.getRoot.getStopTableForId(BOLSTOP); // --&gt; 861.080 - reset the BOL stop
	if stopsTable &lt;&gt; null then
		beginTransaction;
		stopsTable.setNotAvailableForEntry(isNotAvailableForEntry);
		commitTransaction;
	endif; // &lt;-- 861.080
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWcntnr_ICR_MAF_FTXDIN_Stor" id="0ab9991b-da4e-4ee6-9a0b-c808c3f6383e">
        <source>tTSWcntnr_ICR_MAF_FTXDIN_Stor();
/*

Purpose:			Test ICR response against MAF stop for FTX+DIN, B07/B08 &amp; IMEX Storage.
					Loads a mock customs web service EDI message and confirms the messages loads successfully and the MAF container stops are removed
					Requires the JMTNzTswPlugin.dll to be loaded/available

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
02 October 2025	navpw1	Initial creation JIRA: MTN-35793

*/

constants
	UT_TFSNumber					: String	= "35793";
	UT_BlockStack					: String	= "UTB" &amp; UT_TFSNumber;
	UT_VesselCode					: String	= "UT" &amp; UT_TFSNumber;
	UT_VoyageCode					: String	= "UT_" &amp; UT_TFSNumber;
	UT_OperatorCode					: String	= "UTOP";
	UT_EDIUserDefName				: String	= "TSW";
	UT_StopCode						: String	= "TSWAB";
	UT_StopId						: Integer	= 188;
	UT_StopHeading					: String	= "TSW Awaiting BACC";
	
	UT_IntStopCode					: String	= "TSWI";
	UT_IntStopId					: Integer	= 109;
	UT_IntStopHeading				: String	= "TSW MPI Internal Inspect";
	
	UT_ExtStopCode					: String	= "EX6";
	UT_ExtStopId					: Integer	= 116;
	UT_ExtStopHeading				: String	= "MPI External Inspect - 6 sided";
	
	UT_BaccCustomsActionName		: String	= "TSW BACC " &amp; "B07";
	UT_BaccCustomsActionKeyword		: String	= "B07";
	UT_BaccB08CustomsActionName		: String	= "TSW BACC " &amp; "B08";
	UT_BaccB08CustomsActionKeyword	: String	= "B08";
	UT_IntCustomsActionName			: String	= "TSW ADD Internal";
	UT_IntCustomsActionKeyword		: String	= "INTERNAL";
	UT_ExtCustomsActionName			: String	= "TSW ADD External";
	UT_ExtCustomsActionKeyword		: String	= "EXTERNAL";
	
	UT_DefaultCAMpi					: String	= "MPI Import Stop";
	UT_DefaultCAMpiActionKeyword	: String = "MHLD";
	
	UT_Container1					: String = "UT" &amp; UT_TFSNumber &amp; "-1";
	UT_Container2					: String = "UT" &amp; UT_TFSNumber &amp; "-2";
	UT_Container3					: String = "UT" &amp; UT_TFSNumber &amp; "-3";
	UT_Container4					: String = "UT" &amp; UT_TFSNumber &amp; "-4";
	
vars
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	terminal						: CM_Terminal;
	systemUTHelper					: UT_HelperAdmSys;
	terminalUTHelper				: UT_HelperAdmTerm;
	pxyStopsTable,
	realStopsTableBacc,
	realStopsTableInt,
	realStopsTableExt,
	realStopsTableDefaultExt,
	realStopsTableDefaultInt,
	realStopsTableDefaultMpi		: CM_StopsTable;
	pxyStopsTableTemplate			: CM_StopTableTemplate;
	pxyStopCriteria					: CM_StopCriteria;
	tiSet							: CM_TISet;
	ti								: CM_TrackedItem;
	ediFile							: CM_EDIFile;
	pxyCustomsAction,
	realCustomsAction				: CM_EDIAction;
	cargoTypeSet,
	imexStatusSet					: CM_ObjectSet;
	ediText							: String;
	processAreasArr,
	setAreasArr,
	checkAreasArr					: IntegerArray;
	noImportStops,
	completedOk,
	ediEnforceVeslMatchExprt		: Boolean;
	jdo								: JadeDynamicObject;
	additionalDetails				: JadeDynamicObjectArray;
	header							: String;
	ti1,
	ti2,
	ti3,
	ti4								: CM_TrackedItem;
	allErrors						: StringArray;
	
begin
	/*
	** Global Setup
	*/
	self.logMessage("Global Setup: Started");
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal, "Global Setup - terminal");
	
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Global Setup - Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	ediEnforceVeslMatchExprt := self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean;
	self.setTerminalConfig(EDIEnforceVeslMatchExprt, true);
	self.assertTrueMsg(self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean, "Global Setup - Terminal Config -&gt; EDI Tab -&gt; 'Enforce Vessel Name Match for Customs EDI' should be set to true");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWcntnr_ICR_MAF_FTXDIN_Stor;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_TSW::tTSWcntnr_ICR_MAF_FTXDIN_Stor;
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Create BlockStack
	blockStack := self.addBlockStack(UT_BlockStack, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	self.logMessage("Added Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Get Operator
	operator := self.getOperator(UT_OperatorCode);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	self.logMessage("Found Operator: Id:'" &amp; UT_OperatorCode);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Vessel
	vessel := self.addVesselGeneralCargo(UT_VesselCode, operator, 5);
	self.assertNotNullMsg(vessel, "Global Setup - vessel");
	self.logMessage("Added Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, UT_VesselCode, UT_OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNullMsg(voyage, "Global Setup - voyage");
	self.logMessage("Added Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete TSW Awaiting BACC STOP
	realStopsTableBacc := self.getRoot.getStopTableForId(UT_StopId);
	if realStopsTableBacc &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(realStopsTableBacc, "Global Setup - realStopsTableBacc");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	//Create TSW Awaiting BACC STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, UT_StopCode, UT_StopHeading, UT_StopCode, null, UT_StopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTable);
	
	create processAreasArr transient;
	processAreasArr.add(StopProcessEmptyImport);
	processAreasArr.add(StopProcessImportStorage);
	
	create setAreasArr transient;
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	
	pxyStopsTableTemplate.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,
									false,
									true,
									false,
									true,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTableBacc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTableBacc, "Global Setup - realStopsTableBacc");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	
