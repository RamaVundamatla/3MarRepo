<Class name="CM_WOUnpackRequest" id="813bdfab-4fcc-48a6-ba68-802a6ae08115">
    <superclass name="CM_WORequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createWLE" id="93f2a301-cb4c-4c41-bf00-da1482c6088c">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	wle	: CM_WOUnpackWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="92bf5960-7f69-4aa5-bdf5-b67f066a345a">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_WOUnpackJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_WOUnpackJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="typeString" id="bb222787-a359-43ac-9e06-b699731c88cf">
        <source>typeString(): String;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
