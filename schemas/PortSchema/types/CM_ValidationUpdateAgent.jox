    <JadeMethod name="valWOTransportModeChange" id="4619bff8-df6b-4bfd-ab06-2204f31565a2">
        <source>valWOTransportModeChange(_tiArr : ObjectArray; _newTransportMode : String; _newTransport : CM_Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2023	navma1 Bug 60135: MTN - Error 1090 when using Transport Mode Change
30 Jan 2024 navlc30 Bug 62217 MTN - 1090 exception when changing the transport mode from Rail to Ship
*/

vars

begin
	if _tiArr.isEmpty then
		app.raiseCMException(ERR_WO_CHANGE_TRASNPORT_NOTIS,null,null);
	endif;
	
	if _newTransportMode = TI_TRANSMODE_SHIP_STR and _newTransport = null then												//30.01.2024 navlc30 #62217
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(New_Transport), null, null); 
	endif;
	
epilog

end;</source>
        <Parameter name="_tiArr" type="ObjectArray"/>
        <Parameter name="_newTransportMode" type="String"/>
        <Parameter name="_newTransport" type="CM_Object"/>
    </JadeMethod>
