    <JadeMethod name="getVoyageAllocationGroup" id="8ed0d66b-4392-405d-958f-ec3c28e65092">
        <source>getVoyageAllocationGroup() : String;
/*

Purpose:			Moved from CM_BulkRelease::getVoyageAllocationGroup

Parameters:			

Return Value:		

Date		Who		Reason
20/07/18	jlgmd1	Initial creation TFS #39261 SNO - Show Reserve Detail lines on Load List

*/

vars
	cargoType	: CM_CargoType;
	isoGroup	: CM_ISOTypeGroup;
	isoCode		: String;
	iso			: CM_ISOType;
	group		: String;

begin
	cargoType := self.getMyCargoType();
	if cargoType &lt;&gt; null then
		isoCode := self.getISOCode();
		if isoCode &lt;&gt; null then
			isoGroup := app.myRoot.allISOTypes[isoCode].myISOTypeGroup;
		else
			isoGroup := self.getISOGroup();
		endif;
	
		if isoGroup = null then
			iso := app.myRoot.allISOTypes[isoCode];	
			if iso = null or iso.myISOTypeGroup = null then
				group := "???";
			else
				group := iso.myISOTypeGroup.code;
			endif;
		else
			group := isoGroup.code;
		endif;
	endif;
	
	if not self.myReserveHeader.fullRelease then
		group := group &amp; "+";
	endif;
	
	return group[1:5];	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocationGroupDesc" id="1ec074f4-a1b4-45a6-93c0-8bc2db9eba22">
        <source>getVoyageAllocationGroupDesc() : String;
/*

Purpose:			Moved from CM_BulkRelease::getVoyageAllocationGroupDesc

Parameters:			

Return Value:		

Date		Who		Reason
20/07/18	jlgmd1	Initial creation TFS #39261 SNO - Show Reserve Detail lines on Load List

*/

vars
	desc		: String;
	iso			: CM_ISOType;
	isoGroup	: CM_ISOTypeGroup;

begin
	isoGroup := self.getISOGroup();
	
	if isoGroup = null then
		iso := app.myRoot.allISOTypes[self.getISOCode()];	
		if iso = null or iso.myISOTypeGroup = null then
			desc := "???";
		else
			desc := iso.myISOTypeGroup.code;
		endif;
	else
		desc := isoGroup.code;
	endif;	

	if not self.myReserveHeader.fullRelease then
		desc := desc &amp; ' ' &amp; app.getErrorString(SummaryDesc_Empty);
	endif;
	
	return desc;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="d3082a77-a332-4c0a-a8fc-2427d27eca72">
        <source>getVoyageCode():String;
/*
Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	voyage	:CM_Voyage;
	invalid	:Boolean;
begin
	if self.myReserveHeader &lt;&gt; null then
		voyage := self.myReserveHeader.myVoyage;
		
		if voyage &lt;&gt; null then
			on Exception do app.handleDeletedObject (exception, voyage, invalid);
			
			if voyage.code &lt;&gt; null then	// force exception if deleted object
				return voyage.code;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
