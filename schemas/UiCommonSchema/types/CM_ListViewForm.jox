    <JadeMethod name="translateForm" id="794d1973-9040-4922-bd87-aded8ea1c779">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008362, locale);
	btnDeleteTV.translateCaption(Xlat_0001239, locale);
	btnEditTV.translateCaption(Xlat_0001240, locale);
	btnNewChildTV.translateBubbleHelp(Xlat_0001238, locale);
	btnNewChildTV.translateCaption(Xlat_0001241, locale);
	btnNewTV.translateCaption(Xlat_0001242, locale);
	btnNextTV.translateCaption(Xlat_0001243, locale);
	btnPrintTV.translateCaption(Xlat_0001244, locale);
	mnuLstDataContext.translateCaption(Xlat_0008363, locale);
	mnuLstDataInspect.translateCaption(Xlat_0008364, locale);
	mnuLstDataViewAudits.translateCaption(Xlat_0008365, locale);
end;</source>
    </JadeMethod>
