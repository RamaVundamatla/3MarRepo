    <DbClassMap file="jssxml_document"/>
    <JadeMethod name="generateXmlString" id="d1ee6596-3c95-493d-9ded-9f768d0f4f0c">
        <source>generateXmlString(): String protected;
/*
*/
vars
	indentation: String;
	returnString: String;
begin
	indentation := self.generateIndentation();
	//	build the comment tag
	returnString := indentation &amp; "&lt;![CDATA[" &amp; self.tagValue  &amp; "]]&gt;";

	return(returnString);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="parseAttributes" id="a0837187-5ebf-4603-8391-f74960e17a50">
        <updating/>
        <source>parseAttributes(pTagString: String) updating, protected;
/*
*/
begin
//	CDATA doesn't have attributes
end;</source>
        <access>protected</access>
        <Parameter name="pTagString" type="String"/>
    </JadeMethod>
    <JadeMethod name="parseElement" id="41b8b78a-a183-43b2-855e-e8af74c0696e">
        <updating/>
        <source>parseElement(pXmlString: String; pPosition: Integer io) updating;
/*
*/
constants
	CDATA_TAG_START: String = "&lt;![CDATA[";
	CDATA_TAG_END: String = "]]&gt;";
vars
	pos: Integer;
	posEnd: Integer;
begin
	pos := pPosition + CDATA_TAG_START.length + 1;
	posEnd := pXmlString.pos(CDATA_TAG_END, pos);
	self.tagValue := pXmlString[pos:posEnd - pos];
end;</source>
        <Parameter name="pXmlString" type="String"/>
        <Parameter name="pPosition" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
