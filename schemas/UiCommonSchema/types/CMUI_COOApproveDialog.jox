    <JadeMethod name="doCancel" id="6d7820ea-fc0d-432d-ab64-9505ff06e88a">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	parent	: CM_BaseForm;
	failed	: Boolean;
begin

	parent := self.myParentForm;
	
	if parent = null then
		self.unloadForm();
	endif;
	
	failed := true;
	
	if parent.isKindOf(CMUI_OwnershipChangeEnquiry) then
		parent.CMUI_OwnershipChangeEnquiry.dialogFailed := failed;
	elseif parent.isKindOf(CMUI_OwnershipChangeMaint) then
		parent.CMUI_OwnershipChangeMaint.dialogFailed := failed;
	endif;
	
	self.unloadForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="576b49a8-cf1c-4d9a-ae27-957f8fb2f1f4">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	parent		: CM_BaseForm;
	terminal	: CM_Terminal;
	locationStr	: String;
	atHeight	: Integer;
	foundLC		: CM_LocationsController;
	failed		: Boolean;
begin
	
	parent := self.myParentForm;
	terminal := self.myTerminal;
	
	if parent = null or terminal = null then
		self.unloadForm();
	endif;
	
	failed := self.validateIDEntered();
	if failed then
		return;
	endif;
	
	failed := self.validateDuplicateID();
	if failed then
		return;
	endif;
	
	if parent.isKindOf(CMUI_OwnershipChangeEnquiry) then
		parent.CMUI_OwnershipChangeEnquiry.dialogFailed := failed;
		
	elseif parent.isKindOf(CMUI_OwnershipChangeMaint) then
		parent.CMUI_OwnershipChangeMaint.dialogFailed := failed;
	endif;
	
	self.unloadForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d8a860a8-0489-4f8a-b634-0e61049c66ff">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	cmifDetail	: CMIF_COODetails;
	cooDetail	: CM_OwnershipChangeDetail;
	ti			: CM_TrackedItem;
	cargoIdTable: CM_EntryTable;
	idGenerated	: StringArray;
	tmpId,
	id			: String;
begin
	inheritMethod();
	
	create idGenerated transient;
	
	cargoIdTable := self.tblCargoId;
	cargoIdTable.clear();
	
	cargoIdTable.addItem("Source ID" &amp; Tab &amp; "New ID");
	cargoIdTable.fixedRows := 1;	
	cargoIdTable.fixedColumns := 1;
	
	cargoIdTable.userInputEnabled := true;
	cargoIdTable.inputType := Table.InputType_TextBox;
	
	if self.myCmifCooAgent = null then
		return;
	endif;
	
	foreach cmifDetail in self.myCmifCooAgent.allCmifCooDetails do
		cooDetail := cmifDetail.myOwnershipChangeDetail;
		
		ti := cooDetail.myTrackedItem;
		
		self.txtLocationID.text := ti.locationId; // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
		
		id := ti.id;
		
		if id.length() &lt; 17 then
			
			tmpId := idGenerated.last();
			
			if tmpId = null then
				id := cooDetail.getNewIDForTI(id);
				idGenerated.add(id);
			else
				id := cooDetail.getNewIDForTI(tmpId);
				idGenerated.add(id);
			endif;
			
			cargoIdTable.addItemObject(cmifDetail, ti.id &amp; Tab &amp; id);
		else
			cargoIdTable.addItemObject(cmifDetail, ti.id);
		endif;
	endforeach;
	
epilog
	delete idGenerated;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ba54bfeb-82ba-4264-a6e2-e836f97fb962">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 January 2024 08:43:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026582, locale);
	btnCancel.translateCaption(Xlat_0026583, locale);
	btnOK.translateCaption(Xlat_0026584, locale);
	lblCargoId.translateCaption(Xlat_0026585, locale);
	lblLocationID.translateCaption(Xlat_0026586, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateDuplicateID" id="a86128df-6f71-43ea-87bd-59d1079702de">
        <source>validateDuplicateID() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	hasError		: Boolean;
	newId,
	errorsStr,
	locationStr		: String;
	terminal		: CM_Terminal;
	row,
	maxRows,
	atHeight		: Integer;
	foundLC			: CM_LocationsController;
	table			: CM_EntryTable;
	cmifDetail		: CMIF_COODetails;
	sourceTi,
	existingTi		: CM_TrackedItem;
	cooDetails		: CM_OwnershipChangeDetail;
begin

	locationStr := self.txtLocationID.text;
	terminal := self.myTerminal;
	
	table := self.tblCargoId;
	maxRows := table.rows;
	
	// We have a new location ID entered, check it actually exists
	if locationStr &lt;&gt; null then
		terminal.findLocationFromString(locationStr, false, foundLC, atHeight);
		
		if foundLC = null then
			hasError := true;
			app.msgBox(app.getErrorString1(ERR_INVALID_LOCN, locationStr), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return hasError;
		endif;
	endif;
	
	self.myCmifCooAgent.newLocation := locationStr;
	
	foreach row in table.fixedRows + 1 to maxRows do
		cmifDetail := table.accessRow(row).itemObject.CMIF_COODetails;
		cooDetails := cmifDetail.myOwnershipChangeDetail;
		sourceTi := cooDetails.myTrackedItem;
		
		// We dont have a new location ID entered, 
		if locationStr = null then
			terminal.findLocationFromString(sourceTi.locationId, false, foundLC, atHeight);
		endif;
		
		table.accessCell(row, 2);
		newId := table.accessedCell.text.trimBlanks();
		
		existingTi := foundLC.allTrackedItemsById[newId, sourceTi.cargoType];
		
		if existingTi &lt;&gt; null then
			table.accessedCell.backColor := LightRed;
			hasError := true;
			errorsStr &amp;= newId &amp; " already exist in the location " &amp; locationStr &amp; CrLf;
		endif;
	endforeach;
	
	if hasError then
		app.msgBox(errorsStr, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
	endif;
	
	return hasError;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateIDEntered" id="81bb03cd-1b4a-4bbb-be77-4f41bec6d08d">
        <source>validateIDEntered() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	table		: CM_EntryTable;
	row,
	maxRows		: Integer;
	newId		: String;
	hasError	: Boolean;
	cmifDetail 	: CMIF_COODetails;
begin
	
	table := self.tblCargoId;
	
	maxRows := table.rows;
	
	foreach row in table.fixedRows + 1 to maxRows do
		cmifDetail := table.accessRow(row).itemObject.CMIF_COODetails;
		
		table.accessCell(row, 2);
		table.accessedCell.backColor := White;
		
		newId := table.accessedCell.text.trimBlanks();
		
		if newId = null or newId.length() &gt; 20 then
			table.accessedCell.backColor := LightRed;
			hasError := true;
			continue;
		endif;
		
		cmifDetail.newId := newId;
		
	endforeach;
	
	if hasError then
		app.msgBox(app.getErrorString(INVALIDNEWIDFORSPLIT), "Error", MsgBox_Exclamation_Mark_Icon);
	endif;
	
	return hasError;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
