    <JadeMethod name="translateForm" id="b4b28a34-b8dc-4c51-97da-23df33efa569">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 13:33:30.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022886, locale);
	btnDoAdd.translateCaption(Xlat_0022233, locale);
	btnDoClose.translateCaption(Xlat_0022234, locale);
	btnDoDelete.translateCaption(Xlat_0022235, locale);
	btnDoSave.translateCaption(Xlat_0022236, locale);
	btnDoUpdate.translateCaption(Xlat_0022237, locale);
	lblCargoType.translateCaption(Xlat_0022238, locale);
	lblDailyHours.translateCaption(Xlat_0022239, locale);
	lblJobType.translateCaption(Xlat_0022240, locale);
	lblProduct.translateCaption(Xlat_0022308, locale);
	lblTargetQuantity.translateCaption(Xlat_0022242, locale);
	lblTargetVolume.translateCaption(Xlat_0022243, locale);
	lblTargetWeight.translateCaption(Xlat_0022244, locale);
	lblTransferType.translateCaption(Xlat_0022245, locale);
	mnuColumnOrg.translateCaption(Xlat_0022246, locale);
	mnuContext.translateCaption(Xlat_0022247, locale);
	mnuInspect.translateCaption(Xlat_0022248, locale);
end;</source>
    </JadeMethod>
</GUIClass>
