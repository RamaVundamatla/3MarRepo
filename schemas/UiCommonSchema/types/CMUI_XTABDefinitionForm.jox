    <JadeMethod name="enableDisableCtrsForHideShow" id="e51e8816-b617-45bb-9b22-b1a561ff4bd1">
        <updating/>
        <source>enableDisableCtrsForHideShow( _enable :Boolean ) updating, protected;

/*
	
Purpose:		Make certain buttons invisible/visible but still enabled via the context menu.
Parameters:		
Return Value:	

Date				Who		Reason
30 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	self.btnSaveDefn.visible	:= _enable;
	self.btnSaveAsDefn.visible	:= _enable;
	self.btnDeleteDefn.visible	:= _enable;
	self.btnHideDetails.visible	:= _enable;
	self.btnShowDetails.visible	:= not _enable;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findButtonForXTABElement" id="bd124ae7-4dfd-41ff-a2b5-b2870f635467">
        <source>findButtonForXTABElement(_element :CM_Object):Button protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	btn	:Object;
begin
	if _element.isKindOf (CM_XTABField) then
		foreach btn in self.allButtons_cells do
			if btn.Button.userObject = _element then
				return btn.Button;
			endif;
		endforeach;
	else
		foreach btn in self.allButtons_columns do
			if btn.Button.userObject = _element then
				return btn.Button;
			endif;
		endforeach;
		
		foreach btn in self.allButtons_rows do
			if btn.Button.userObject = _element then
				return btn.Button;
			endif;
		endforeach;
		
		foreach btn in self.allButtons_tabs do
			if btn.Button.userObject = _element then
				return btn.Button;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="CM_Object"/>
        <ReturnType type="Button"/>
    </JadeMethod>
