    <JadeMethod name="createEmail" id="e1fdbb19-8fdd-455e-b32d-0819a16f75bd">
        <updating/>
        <source>createEmail(pAllAttachmentsArray:StringArray;
			pBccList:String;
			pCcList:String;
			pContentType:String;
			pEncodingType:String;
			pMessageBody:String;
			pMessageHeader:String;
			pMyEmailBaseData:CnEcEmailBaseData;
			pSentTime:TimeStamp;
			pSentTo:String;
			pCnEcEmailNew : CnEcEmail output): String updating; 

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001
// It will create a CnEcEmail Object.

vars
	errorMessage	: String;
	vCnEcEmail	: CnEcEmail;

begin
	create vCnEcEmail;

	errorMessage := vCnEcEmail.initializeMe(
			pAllAttachmentsArray,
			pBccList,
			pCcList,
			pContentType,
			pEncodingType,
			pMessageBody,
			pMessageHeader,
			pMyEmailBaseData,
			pSentTime,
			pSentTo);

	pCnEcEmailNew := vCnEcEmail;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pAllAttachmentsArray" type="StringArray"/>
        <Parameter name="pBccList" type="String"/>
        <Parameter name="pCcList" type="String"/>
        <Parameter name="pContentType" type="String"/>
        <Parameter name="pEncodingType" type="String"/>
        <Parameter name="pMessageBody" type="String"/>
        <Parameter name="pMessageHeader" type="String"/>
        <Parameter name="pMyEmailBaseData" type="CnEcEmailBaseData"/>
        <Parameter name="pSentTime" type="TimeStamp"/>
        <Parameter name="pSentTo" type="String"/>
        <Parameter name="pCnEcEmailNew" type="CnEcEmail" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createEmailAddress" id="97fdc840-6ea5-47b9-9d9a-bf33001ac6ac">
        <updating/>
        <source>createEmailAddress(	pEmailAddress:String;
					pMyBaseData:CnEcEmailBaseData;
					pName:String;
					pCnEcEmailAddressNew : CnEcEmailAddress output): String updating; 

// This method created by JediMethodGenerator at 14:43:43 on 16 March 2001
// It will create a CnEcEmailAddress Object.

vars
	errorMessage	: String;
	vCnEcEmailAddress	: CnEcEmailAddress;

begin
	create vCnEcEmailAddress;

	errorMessage := vCnEcEmailAddress.initializeMe(
			pEmailAddress,
			pMyBaseData,
			pName);

	pCnEcEmailAddressNew := vCnEcEmailAddress;
epilog
	return errorMessage;
end;</source>
