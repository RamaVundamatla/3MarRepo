    <JadeMethod name="setCustomer" id="ebdbb602-97ad-4d5e-9cba-5b370d1028a7">
        <updating/>
        <source>setCustomer(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2025	naviv1	JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer

*/

vars

begin
