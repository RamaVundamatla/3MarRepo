    <JadeMethod name="getUNDGForIndex" id="18b451b3-4de0-4619-9e6a-169bcfa735f8">
        <source>getUNDGForIndex(_index : Integer) : String;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/


vars
	undgarray : StringArray;
begin
	create undgarray transient;
	self.undgCodes.csvToStringArray(undgarray,",");
	
	if undgarray.size &gt;= _index then
		return undgarray[_index];
	endif;
	
	return "";
epilog
	delete undgarray;
end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a044ce18-ff83-4e8f-aeb5-109c224eaf1f">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars

begin
	self.acidsBases := _pxy.acidsBases;
	self.code := _pxy.code;
	self.description := _pxy.description;
	self.flashpointTemperature := _pxy.flashpointTemperature;
	self.isMarinePollutant := _pxy.isMarinePollutant;
	self.limitedQuantity := _pxy.limitedQuantity;
	self.packingGroup := _pxy.packingGroup;
	self.undgCodes := _pxy.undgCodes;
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromTIHax" id="49b861b3-fb02-44f3-8988-6e3c320d5dc2">
        <updating/>
        <source>setFromTIHax(_tihaz : CM_TIHazard; _snapshot : CM_TISnapShot) updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	if _tihaz = null then
		return;
	endif;
	
	self.acidsBases := _tihaz.acidsBases;
	self.code := _tihaz.code;
	self.description := _tihaz.description;
	self.flashpointTemperature := _tihaz.flashpointTemperature;
	self.isMarinePollutant := _tihaz.isMarinePollutant;
	self.limitedQuantity := _tihaz.limitedQuantity;
	self.packingGroup := _tihaz.packingGroup;
	self.undgCodes := _tihaz.getUndgCodesAsString(false);	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
	
	self.myTISnapShot := _snapshot;
epilog

end;</source>
        <Parameter name="_tihaz" type="CM_TIHazard"/>
        <Parameter name="_snapshot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="setMyTISnapShot" id="866028a9-c841-4433-aae1-3f27c8b4347a">
        <updating/>
        <source>setMyTISnapShot(_snap : CM_TISnapShot) updating;
/*
Purpose:	TFS 40336		
