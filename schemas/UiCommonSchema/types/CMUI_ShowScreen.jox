    <JadeMethod name="getAppServerPort" id="e2ae7d46-a74e-4881-adca-7f77a0574694">
        <source>getAppServerPort(_str : String) : String protected;
// -------------------------------------------
// Created 02 August 2004 by cnwdvb1
// -------------------------------------------
constants

	Space = ' ';
vars

	i 		: Integer;

begin

	i := _str.pos('AppServerPort', 1);
	if i &gt; 0 then
		i := i + 14;
		return 'Port ' &amp; _str.scanUntil(Space,i);
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getComputerDetail" id="e880d01d-606a-4ee2-9843-431b816e8a43">
        <source>getComputerDetail(_node : Node) : String protected;
// -------------------------------------------
// Created 02 August 2004 by cnwdvb1
// -------------------------------------------
vars

	type,
	extras		: String;	

begin

	if _node.nodeType = 1 then
		type := app.getErrorString(Database_Server);
	elseif _node.nodeType = 2 then
		type := app.getErrorString(Thin_Client);
		extras := self.getAppServerPort(_node.getCommandLine);
	elseif _node.nodeType = 3 then
		type := app.getErrorString(Single_User_App_Server);
	elseif _node.nodeType = 4 then
		type := app.getErrorString(FatClient);
	elseif _node.nodeType = 5 then
		type := app.getErrorString(Single_User_Fat_Client);
	else
		type := app.getErrorString(Unknown);
	endif;

	return  _node.getComputerName() &amp; '  ' &amp; type &amp; ' ' &amp; extras;

end;</source>
        <access>protected</access>
        <Parameter name="_node" type="Node"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForProcess" id="6d4123a0-8324-46f9-8b27-9b0deb0f5822">
        <source>getDisplayStrForProcess(_process : Process) : String protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	user : CM_User;
	str : String;
begin
	
	if not global.isValidObject(_process) then
		return null;
	endif;

	user := app.myRoot.allUsers[_process.userCode];
	str := _process.userCode;
	if user &lt;&gt; null then 
		str := str &amp; ' - ' &amp; user.userName;
	endif;
	str := str &amp; Tab &amp; 
		   _process.persistentApp.name &amp; Tab &amp; 
		   _process.userInfo &amp; Tab &amp; 
		   _process.signOnTime.String;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleRequestCompletion" id="8743d61c-ffa8-4a63-8032-99eeebee917f">
        <updating/>
        <source>handleRequestCompletion(theRequest : NR_ShowScreenRequest input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Feb 2010	cnwkpd1	PAR #21603 - Set cachePicture to false to prevent App Server cache
					file overflow

*/

vars

begin

	if theRequest = null then
		return;
	endif;
	
	self.caption := 'Screen for ' &amp; theRequest.userName;
	
	if theRequest.screenShot &lt;&gt; null then
		self.picScreen.cachePictures := false;			// PAR #21603
		self.picScreen.picture := theRequest.screenShot;
		self.staMain.caption := 'Application : ' &amp; theRequest.appName &amp; '  ' &amp;
							' taken at ' &amp; theRequest.currentDateTime.shortCurrentLocaleFormat();
	else
		if theRequest.allLogEntries.isEmpty then
			self.staMain.caption := 'Error in retrieving screen shot';
		else
			self.staMain.caption := 'Error : ' &amp; theRequest.allLogEntries.last;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="theRequest" type="NR_ShowScreenRequest" usage="input"/>
    </JadeMethod>
