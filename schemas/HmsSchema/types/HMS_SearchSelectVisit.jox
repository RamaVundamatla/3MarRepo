  	// Setup 'Arrival Date' Column
	str := "Arrival" &amp; Tab &amp;
			"Ship Name" &amp; Tab &amp;
			"Ship Type" &amp; Tab &amp;
			"Shipping Line" &amp; Tab &amp;
			"Pilots (Arr,Shft,Dep)" &amp; Tab &amp; 
			"Agents (Arr,Shft,Dep)" &amp; Tab &amp;
			"Drafts (Arr,Shft,Dep)";
			
	tblMatchsFound.addItem(str);			
	tblMatchsFound.fixedRows := tblMatchsFound.rows;*/

end;</source>
