    </JadeMethod>
    <JadeMethod name="doAddTab" id="053cdad0-b7f7-4897-84f1-58a72454e36e">
        <updating/>
        <source>doAddTab() updating, protected;

vars
	idx		: Integer;
	tabForm : CMUI_CargoEnqConfigEditTab;
begin
	if self.myCargoType = null then
		return;
	endif;
	
	if self.tblTabs.rows &gt;= self.tblTabs.fixedRows + MaxTabs then
		return;
	endif;

	create tabForm transient;
	tabForm.centreWindow;
	// keep tabForm myUserConfigTab to indicate a new tab
	tabForm.myUserCargoType := self.myProxyUserCargoType;
	tabForm.myConfigForm := self;
	tabForm.showModal;
	
	if tabForm.cancelled then
		return;
	endif;

	if tabForm.myUserConfigTab &lt;&gt; null then
		idx := self.tblTabs.addItemObject(tabForm.myUserConfigTab, tabForm.myUserConfigTab.description &amp; Tab &amp; '0');
		self.tblTabs.accessCell(idx, 2).inputType := Table.InputType_CheckBox;
		self.setChanged();
		self.doTblTabsSelect();
		self.recolourTable(self.tblTabs);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAttributeAdd" id="53670e26-59b7-481e-9a77-e988b64157df">
        <updating/>
        <source>doAttributeAdd() updating, protected;
// all selected attributes
vars
	indx,
	row	: Integer;
	obj		: Object;
	attr,
	attr2	: CM_UserConfigAttribute;
	table	: CM_DataTable;
begin
	table := self.tblAllAttributes;
	foreach row in table.fixedRows to table.rows do
		if not table.accessRow(row).selected then
			continue;
		endif;
		obj := table.accessRow(row).itemObject;
		attr := obj.CM_UserConfigAttribute;
		// see if already attached to current tab
		if attr.myUserConfigTab = self.myUserConfigTab then
			continue;
		endif;
		attr.setup(self.myUserConfigTab, attr.myEntTableRow);		// attach to the current tab
		self.setChanged();
	
		indx := self.tblTabAttributes.addItemObject(attr, attr.getHeading(self.myCargoType, null, app.myCurrentLocale));
		self.tblTabAttributes.accessRow(indx).backColor := self.colorRow1;
	
		// update the all attributes table group
		self.tblAllAttributes.setCellText(row, 2, attr.getTabDescription());
		// restore the back colour after highlighting it when removing an attribute from a tab
		self.tblAllAttributes.accessCell(row, 2).backColor := self.tblAllAttributes.accessCell(row, 1).backColor;
	endforeach;

	self.recolourTable(self.tblTabAttributes);
	self.enableAttributesArrows();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAttributeDown" id="f7eadaa3-b929-45e0-a042-b1b754578d17">
        <updating/>
        <source>doAttributeDown() updating, protected;

vars
	row	: Integer;
	attr	: CM_UserConfigAttribute;
	table	: CM_DataTable;
begin
	table := self.tblTabAttributes;
	row := table.row;
	if row &lt; 1 or 
	   row &gt;= table.rows then
		return;
	endif;

	attr := table.accessRow(row).itemObject.CM_UserConfigAttribute;
	self.myUserConfigTab.moveAttribute(attr, false);
	
	self.moveAttributeItem(row, false);
	self.recolourTable(table);
	self.enableAttributesArrows();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAttributeRemove" id="b4e8d289-68ec-4a43-854a-a4b8db6872c0">
        <updating/>
        <source>doAttributeRemove() updating, protected;

vars
	row		: Integer;
	obj		: Object;
	ia		: IntegerArray;
	oa		: ObjectArray;
	attr,
	attr2	: CM_UserConfigAttribute;
	fromTable,
	toTable	: CM_DataTable;
begin
	create ia transient;
	create oa transient;

	fromTable := self.tblTabAttributes;
	toTable := self.tblAllAttributes;
	foreach row in fromTable.fixedRows to fromTable.rows do
		if not fromTable.accessRow(row).selected then
			continue;
		endif;
		obj := fromTable.accessRow(row).itemObject;
		oa.add(obj);
		ia.add(row);
	endforeach;
	if ia.size = 0 then
		return;
	endif;
	
	foreach row in ia reversed do
		fromTable.removeItem(row);
	endforeach;

	foreach obj in oa do
		attr := obj.CM_UserConfigAttribute;
		attr.setup(null, attr.myEntTableRow);		// detach from this tab
	
		// update the all attributes table group
		foreach row in toTable.fixedRows to toTable.rows do
			attr2 := toTable.accessRow(row).itemObject.CM_UserConfigAttribute;
			if attr2 = attr then
				toTable.setCellText(row, 2, ""	);
				// highlight this cell so the user is reminded to add the attribute back to another tab
				toTable.accessCell(row, 2).backColor := Red;
				break;
			endif;
		endforeach;
	endforeach;
	
	self.setChanged();
	self.recolourTable(fromTable);
	self.enableAttributesArrows();

epilog
	delete ia;
	delete oa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAttributeUp" id="d7ca7a7f-aa44-482a-8ed9-1164a0839bb0">
        <updating/>
        <source>doAttributeUp() updating, protected;

vars
	row	: Integer;
	attr	: CM_UserConfigAttribute;
	table	: CM_DataTable;
begin
	table := self.tblTabAttributes;
	row := table.row;
	if row &lt; 2 or 
	   row &gt; table.rows then
		return;
	endif;

	attr := table.accessRow(row).itemObject.CM_UserConfigAttribute;
	self.myUserConfigTab.moveAttribute(attr, true);
	
	self.moveAttributeItem(row, true);
	self.recolourTable(table);
	self.enableAttributesArrows();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="f83612e6-3451-4e8a-a5f5-df5ddfebd928">
        <updating/>
        <source>doCancel() updating;
// reset changed status and restore current cargo type from database
vars

begin
	self.isFormChanged := false;
	if self.myCargoType &lt;&gt; null then
		self.showTabsForCargoType(false);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCargoTypeClick" id="e54f621d-b647-485a-a043-781741ade4c0">
        <updating/>
        <source>doCargoTypeClick() updating, protected;

vars
	cargoType	: CM_CargoBOLType;
begin
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoBOLType;
	else
		cargoType := null;
	endif;
	if cargoType = self.myCargoType then
		return;
	endif;
	
	if self.isFormChanged then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		// restore the prior cargo type
			self.cmbCargoType.listIndex := self.cmbCargoType.findObject(self.myCargoType);
//			self.isFormChanged := false;
			return;
		endif;
	endif;

	self.myCargoType := cargoType;
	delete self.myProxyUserCargoType;
	self.isFormChanged := false;

	self.showTabsForCargoType(false);
	
	self.populateAllAttributes();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClose" id="2f0ca7d7-b483-4410-aa6b-b7f672554044">
        <updating/>
        <source>doClose() updating;

