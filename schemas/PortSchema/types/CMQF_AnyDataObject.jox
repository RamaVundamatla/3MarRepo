    <JadeMethod name="addCollectionData" id="5745ce43-556c-42ea-92b0-c72053683759">
        <source>addCollectionData( _set : Set);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	obj : Object;
	iter : Iterator;
	invalid : Boolean;
	edition : Integer;
	oidStr : String;

begin

	on Exception do app.handleDeletedObject( exception, obj, invalid );

	if _set &lt;&gt; null and not _set.isEmpty then
		iter := _set.createIterator;
		while iter.next( obj ) do
			invalid := false;
			if obj = null then
				continue;
			endif;
			edition := obj.edition;
			if not invalid then
				oidStr := obj.getOidAsString;
				self.allGroupingAttributes.add( oidStr );
			endif;
		endwhile;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_set" type="Set"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="048e3efa-a723-4038-81d1-d6d5f8b559b6">
        <updating/>
        <source>cloneReferences(_obj : CMQF_AnyDataObject; _transient : Boolean) updating;

// cnwdvb1 23 April 2003 

vars

begin
	inheritMethod(_obj, _transient);
	self.setMyDataObject( _obj.getMyDataObject );

end;</source>
        <Parameter name="_obj" type="CMQF_AnyDataObject"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
