    <JadeMethod name="getPxyBulkRelease" id="b35c1985-fe0e-41d0-a20d-be0f5b7f1d13">
        <source>getPxyBulkRelease(_bulkRelease : CM_BulkRelease; _realBRSet, _pxyBRSet : CM_BulkReleaseSet input) : CM_BulkRelease protected;
/* ---------------------------------------------------------------------------
Created:     09 March 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	pxyBR		: CM_BulkRelease;

begin
	if _realBRSet.includes(_bulkRelease) then
		pxyBR := _bulkRelease.pxyGetProxyObject();
	else
		_realBRSet.add(_bulkRelease);
		pxyBR := _bulkRelease.pxyCreateUpdateProxy();
		_pxyBRSet.add(pxyBR);
	endif;
	
	return pxyBR;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_realBRSet" type="CM_BulkReleaseSet" usage="input"/>
        <Parameter name="_pxyBRSet" type="CM_BulkReleaseSet" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="8c390f17-2da1-4f0c-aa08-ff29073a3c8f">
        <source>getTIProperties(_propArray: ObjectArray io);
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allPropsObj	: PropertyNDict;
	propertyObj	: Property;
	
begin
	inheritMethod(_propArray);
	allPropsObj	:=	CM_EDICargoFieldUpdateTI.getProperties();
	
	foreach propertyObj in allPropsObj do
		_propArray.add(propertyObj);
	endforeach;
end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleBulkReleaseChange" id="da95acb4-6e4c-4b52-b474-08de2025fbd6">
        <source>handleBulkReleaseChange(_ti : CM_TrackedItem input; _cargoTIObj : CM_EDICargoFieldUpdateTI;
			_realBRSet, _pxyBRSet : CM_BulkReleaseSet input) protected;
/* ---------------------------------------------------------------------------
Created:     09 March 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
03 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
------------------------------------------------------------------------------*/
vars
	bulkReleaseNumber	: String;
	realBR,
	pxyBR,
	tmpBR		: CM_BulkRelease;
begin

	bulkReleaseNumber := _cargoTIObj.fieldValue;

	if bulkReleaseNumber &lt;&gt; null then
		// Adding this TI to a bulk-release
		realBR := self.getMyTerminal.getBulkReleaseFromCode(bulkReleaseNumber);
		if realBR = null then
			app.raiseCMException1(Bulk_Release_Not_Found, bulkReleaseNumber, null, _cargoTIObj);
			return;
		else
			if _ti.allBulkReleasesAssigned.includes(realBR) then
				// TI already on this release so no work to do.
				return;
			endif;
			
			// 3.8.2017 cnwma1 TFS #5209
			if _ti.myConsignee &lt;&gt; null  then
				if _ti.myConsignee.isRestricted then 
					app.raiseCMException1(ERR_TI_CONSIGNEE_RESTRICTED,_ti.id ,null ,null);
					return;
				endif;
			endif;			
			// 3.8.2017 cnwma1 TFS #5209
			
			// Need to see if TI is already on a release request, so may have to
			// remove first (unless it is a bulk-release that is flagged for 
			// being assinged to multiple TIs
			foreach tmpBR in _ti.allBulkReleasesAssigned do
				if realBR.allowCargoOnMultipleReleases then
					if (not tmpBR.allowCargoOnMultipleReleases) then
						// need to remove the ti from this bulk-release
						self.removeTIFromBulkRelease(_ti, tmpBR, _cargoTIObj);
					endif;
				else
					self.removeTIFromBulkRelease(_ti, tmpBR, _cargoTIObj);
				endif;
			endforeach;
			
			pxyBR := self.getPxyBulkRelease(realBR, _realBRSet, _pxyBRSet);
			pxyBR.assignTIToBulkRelease(_ti, _cargoTIObj);
		endif;
	else
		// removing this TI from any bulk-releases it is assigned to
		foreach realBR in _ti.allBulkReleasesAssigned do
			self.removeTIFromBulkRelease(_ti, realBR, _cargoTIObj);
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_cargoTIObj" type="CM_EDICargoFieldUpdateTI"/>
        <Parameter name="_realBRSet" type="CM_BulkReleaseSet" usage="input"/>
        <Parameter name="_pxyBRSet" type="CM_BulkReleaseSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="9a522618-ede5-4d15-92d5-c58176b45aba">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Purpose:		Process the EDI records to load the data into the database proper.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
// --------------------------------------------------------------------------------
begin
	//self.doLoadDB(false, _passport);
	
	// Arm our base exception handlers
	on Exception do self.validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);	// Get as many error messages in 1 go as possible.

	app.myTrxUA.trxProcessEDICargoFieldUpdate(self, false, _passport);
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTIFromBulkRelease" id="a57c01bf-b6c8-408d-95af-654c46ffa498">
        <source>removeTIFromBulkRelease(_ti : CM_TrackedItem input; _bulkRelease : CM_BulkRelease input; _errLinkObject : Object) protected;
/* ---------------------------------------------------------------------------
Created:     09 March 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	_bulkRelease.removeTIAssigned(_ti);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_errLinkObject" type="Object"/>
    </JadeMethod>
