    <JadeMethod name="delete" id="9c171d6a-f955-4fed-beb4-bc454f217910">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	navhl20	Initial creation

*/

vars

begin
	if cargo.size &gt; 0 then
		self.cargo.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="54232447-910c-4d09-8c24-64ab5bbe3220">
        <updating/>
        <source>setProxyFromObject(_realScanRecord : CM_GenericGateScanRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 May 2022		navhl20	Initial creation
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	cargo 		: CM_CargoScanRecordData;
	wsCargo 	: WS_GAPICargo;
	truck		: WS_GAPITruck;
	driver		: WS_GAPIDriver;
	chassis		: WS_GAPIChassis;
	weight		: WS_GAPIWeight;
begin
	self.deviceId := _realScanRecord.deviceId;
	self.timestamp := _realScanRecord.timestamp.asLocalTimeStamp().asJSONFormat();
	
	if _realScanRecord.licenseNumber &lt;&gt; null or _realScanRecord.batNumber &lt;&gt; null or _realScanRecord.carrierCode &lt;&gt; null then
		create truck transient;
		truck.id 			:= _realScanRecord.licenseNumber;
		truck.batNumber		:= _realScanRecord.batNumber;
		truck.carrierCode	:= _realScanRecord.carrierCode;
		
		self.truck := truck;
	endif;
	
	if _realScanRecord.driverName &lt;&gt; null or _realScanRecord.driverCode &lt;&gt; null then
		create driver transient;
		driver.id 			:= _realScanRecord.driverCode;
		driver.name			:= _realScanRecord.driverName;
		
		self.driver := driver;
	endif;
	
	if _realScanRecord.chassisId &lt;&gt; null then
		create chassis transient;
		chassis.id			:= _realScanRecord.chassisId;
		
		self.chassis := chassis;
	endif;
	
	if _realScanRecord.scaleWeight &lt;&gt; null then
		create weight transient;
		weight.value := _realScanRecord.scaleWeight;
		
		self.weight := weight;
	endif;
	
	foreach cargo in _realScanRecord.allCargoItems as CM_CargoScanRecordData do
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);
		
		self.cargo.add(wsCargo);
	endforeach;
epilog

end;</source>
        <Parameter name="_realScanRecord" type="CM_GenericGateScanRecord"/>
    </JadeMethod>
</Class>
