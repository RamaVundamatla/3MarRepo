    <JadeMethod name="setDetailsFromCMIF" id="6fea2c27-2a75-4eec-8a22-10409344b094">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_EDIFileReceiveEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars

begin

	self.set(_cmifEventTrx.dateTimeReceived, _cmifEventTrx.fileNumber, _cmifEventTrx.fileType);
	
	// Keep this at the bottom so it calculate the charges after all details are entered
	inheritMethod(_eventType, _cmifEventTrx);
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_EDIFileReceiveEventCtrl"/>
