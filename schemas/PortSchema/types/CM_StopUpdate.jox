    <JadeMethod name="getDisplayStringForAttribute" id="5d0faf15-3d2d-48bf-a4a2-b991632afc41">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;

/*
Date			Who		Reason
24 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	returnStr	: String;
	
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			returnStr	:= 	app.getErrorString( TransType_162 ) &amp; ColonAndSpace &amp; self.stopDescription &amp; Space ;
			// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
			if self.custDocType &lt;&gt; null then
				returnStr := returnStr &amp;  "(" &amp; self.custDocType &amp; ")";
			endif;
			
			returnStr := returnStr &amp; Space &amp; Hyphen &amp; Space &amp; app.getString( Clearance_Expiry_Date ) &amp; Space &amp; CM_Edit.S_EDIT_THING &amp; Space;
			
			if self.clearanceExpiryDate = null then
				returnStr	:= returnStr &amp; app.getString( Null );
			else
				returnStr	:= returnStr &amp; self.clearanceExpiryDate.shortFormatJMT();
			endif;
			
			returnStr	:=	returnStr &amp; Space &amp; Hyphen &amp; Space &amp;
							app.getString( Stop_Overridden_Reason ) &amp; Space &amp; CM_Edit.S_EDIT_THING &amp; Space;
			
			if self.myStopOverrideReason = null then
				returnStr	:=	returnStr &amp; app.getString( Null );
			else
				returnStr	:=	returnStr &amp; self.myStopOverrideReason.description.display;
			endif;
			
			returnStr	:= returnStr &amp; Period &amp; Space &amp; self.remarks;
			return returnStr;
		endif;
	else
		return inheritMethod( _attrName, _short );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="7f3c4af7-ae05-4c52-8ac0-a555119c2da1">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= 	inheritMethod() &amp; Tab &amp;
					self.stopId.display &amp; Tab &amp;
					self.stopDescription;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTrackedItem.id;
	endif;
	
	if self.clearanceExpiryDate &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.clearanceExpiryDate.shortFormatJMT;
	endif;
	
	if self.myStopOverrideReason &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myStopOverrideReason.description.display;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopClearanceExpiryDate" id="e548a80d-e535-4c47-abef-e5c09194be03">
        <source>getStopClearanceExpiryDate() : String;

/*
Purpose:	This method will return a string of the entered ClearanceExpiryDate.
			This method is available for use in JRW so do not delete.

Date				Who		Reason
23 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	if self.clearanceExpiryDate &lt;&gt; null then
		self.clearanceExpiryDate.shortFormatJMT();
	endif;
	
	return null;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
