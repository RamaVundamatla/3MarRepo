    <JadeMethod name="doSave" id="2abae169-62a3-42a2-98c8-eb41f1ea8aa5">
        <updating/>
        <source>doSave(): Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description
 06/11/2023		navkc1		Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
****************************************************/

vars
	
	nafe					: Boolean;
	proxyDeliveryParty		: CM_DeliveryParty;
	lCode					: String;
	lName					: String;
	theForm					: SOP_TableMaintForm;	
	selectedTerminals 		: CM_TerminalSet;	
	
	realDeliveryParty		: CM_DeliveryParty;	
	term 					: CM_Terminal;	
	failedDAC  				: CM_DataAccessController;	
	address					: CM_Address;
	allAddress				: CM_AddressByCode;
begin
  
    theForm 	:= self.myForm;
	lCode 		:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lName 		:= theForm.tblInput1.getValueByName(ETRow_Name).String;	
	nafe		:= theForm.tblInput1.getValueByName(ETRow_Nafe).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DeliveryParty transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	
	create selectedTerminals transient;		
	theForm.mulSelect1.getSelected(selectedTerminals);		
	// Also need to include those terminals that were already selected, that this user doesn't have access to.
	// Because, we don't want them accidently removing someone elses data.
	
	realDeliveryParty := theForm.myCurrentObject.CM_DeliveryParty;
	if realDeliveryParty &lt;&gt; null then
		foreach term in realDeliveryParty.allTerminals do
			if not term.canUserAccessSelf( app.getMyUser(), failedDAC, app.myPassport) then
				if not selectedTerminals.includes(term) then
					selectedTerminals.add(term);
				endif;
			endif;
		endforeach; 
	endif;
		
	proxyDeliveryParty := theForm.myProxyObject.CM_DeliveryParty;
	proxyDeliveryParty.setProxy(lCode,
								lName,
								nafe,
								selectedTerminals);

	//default the first one to default if there is no default address
	if proxyDeliveryParty.allAddresses.first &lt;&gt; null then
		if proxyDeliveryParty.getDefaultAddress = null then
			proxyDeliveryParty.allAddresses.first.setIsDefault(true);
		endif;
	endif;
								
								
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDeliveryParty(proxyDeliveryParty, theForm.myCurrentObject,app.myPassport);
		// 06/11/2023	navkc1 Bug 61094 - Set the reference to null if got any errors/warnings, otherwise we'll get Invalid Object reference on the next save.
		if app.myPassport.hasErrorsOrWarnings() then
			theForm.myCurrentObject := null;
		endif;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDeliveryParty(proxyDeliveryParty, app.myPassport);
	endif;

epilog
	delete selectedTerminals;		
	delete allAddress;

	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAddress" id="229f177c-0bb9-48d2-81e5-812bda4890c4">
        <source>doSaveAddress() : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description
22 Sep 2022		navkc1		ChangeRequest 54564(54372.020): Alternate address for Debtor
1st May 2023 	navra1		TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
****************************************************/

vars
	realAddress,
	pxyAddress,
	address : CM_Address;
	code,
	description,
	address1,
	address2,
	address3,
	region,
	postCode,
	city,
	deliveryIns,
	countryCode			: String;
	
	isDefault,
	isAlternate			: Boolean;
	
	theForm				: SOP_TableMaintForm;	
	
begin
	theForm 	:= self.myForm;
	
	code 		:= theForm.txtAddrCode.text;
	description := theForm.txtAddrDescription.text;
	address1	:= theForm.txtAddrAdr1.text;
	address2	:= theForm.txtAddrAdr2.text;
	address3	:= theForm.txtAddrAdr3.text;
	region		:= theForm.txtAddrRegion.text;
	postCode	:= theForm.txtAddrPostCode.text;
	city 		:= theForm.txtAddrCity.text;
	deliveryIns := theForm.txtAddrDelIns.text;
	
	if theForm.cmbAddrCountry.listObject &lt;&gt; null then
		countryCode := theForm.cmbAddrCountry.listObject.CM_Country.code;
	endif; 
		
	isDefault := theForm.chkDefultAddess.value;	
	
	if self.myCurrentAddress &lt;&gt; null then
		realAddress := self.myCurrentAddress;
		pxyAddress  := realAddress;
	else
		create pxyAddress transient;
	endif;
	
	pxyAddress.setProxy(code,
						description,
						address1,
						address2,
						address3,
						region,
						postCode,
						countryCode,
						city,
						"",					//navra1 - TFS 57086 - 1st May 2023
						deliveryIns,
						isDefault,
						isAlternate, // 02/09/22	navkc1	#54564(54372.020)
						null);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DeliveryParty transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	if (realAddress = null) then
		theForm.myProxyObject.CM_DeliveryParty.allAddresses.add(pxyAddress);
	endif;	
	
	if isDefault then
		foreach address in theForm.myProxyObject.CM_DeliveryParty.allAddresses discreteLock do
			if address = pxyAddress then
				continue;
			endif;
			if address.isDefault then
				address.setIsDefault(false);
			endif;
		endforeach;
	endif;
	
	return true;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDisableAddressSheetObj" id="c90aed32-d9c2-4e9a-ac43-1d63f7fe112f">
        <updating/>
        <source>enableDisableAddressSheetObj(_enabled: Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars	
	theSheet	 : CMUI_Sheet;
	theForm 	 : SOP_TableMaintForm;
	isEnabled	 : Boolean;	
begin
	theForm := self.myForm;	
	isEnabled := _enabled;
	
	if self.sheetAddressMode = self.Mode_AddressView then
		isEnabled := false;			
	endif;

	theForm.cmbAddrCountry.enabled := isEnabled;
	theForm.chkDefultAddess.enabled := isEnabled;
	theForm.txtAddrAdr1.enabled := isEnabled;
	theForm.txtAddrAdr2.enabled := isEnabled;
	theForm.txtAddrAdr3.enabled := isEnabled;
	theForm.txtAddrCode.enabled := isEnabled;
	theForm.txtAddrDescription.enabled := isEnabled;
	theForm.txtAddrPostCode.enabled := isEnabled;
	theForm.txtAddrRegion.enabled := isEnabled;
	theForm.txtAddrCity.enabled := isEnabled;
	theForm.txtAddrDelIns.enabled := isEnabled;
		
end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
