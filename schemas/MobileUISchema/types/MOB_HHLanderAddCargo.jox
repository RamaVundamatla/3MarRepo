    <JadeMethod name="createNewTrackedItem" id="51b61e05-d31c-47d7-a6e1-0584bd12b172">
        <updating/>
        <source>createNewTrackedItem()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003
09/08/2011		cnwmh5	#27959 - Change to pass the Default MT Commodity for the commodity

*/

vars
	
	id : String;
	mess : String;
	ti : CM_TrackedItem;
	strArray : StringArray;
	location : CM_LocationsController;
	pxyTI : CM_TrackedItem;
	isoType : CM_ISOType;
	updController : CMIF_TIUpdateController;
	tiSet : CM_TISet;
	moveController : CMIF_MoveController;
	toDoTaskDesc : CM_ToDoTaskDesc;
	destPortCode : String;	
begin

	id := txtId.text.trimBlanks.toUpper;
	if id = null then
		mess := app.getErrorString( ERR_INVALID_TI_ID );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, false);
		btnOne.enabled := false;
		return;
	endif;
	
	//02 Mar 2015	NDL	Par 35766
	if id.length &gt; 20 then
		mess := app.getErrorString2(Field_Value_Too_Long, self.lblId.caption,"20");
		self.msgBox( mess, app.getErrorString(Error), MsgBox_OK_Only, false );
		btnOne.enabled := false;
		return;
	endif;
	
	// look to see if we can find an onsite container with this id.
	ti := self.findExistingCargo(id);
	if ti &lt;&gt; null then
		self.txtId.setFocus();
		return;
	endif;
	
	isoType := self.findIsoType(id);
	if isoType = null then
		self.txtIsoType.setFocus();
		return;
	endif;
	
	location := self.myVoyage.myNotNotifiedStack;
	if location = null then
		mess := app.getErrorString( Locatio_ship_not_found );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, false);
		return;
	endif;
	
	toDoTaskDesc := self.myTerminal.getConfig(DefNoInfoToDo).CM_ToDoTaskDesc;
	
	destPortCode := self.myTerminal.getConfig(PortDestCode).String;
		
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	
	// OK we are going to create one...		
		
	create pxyTI as CM_Container transient;	
	pxyTI.setPxyFromDefaultTI( app.myLogonAgent.myTerminal, TI_CargoType_Container, id, self.myTerminal.getDefaultEmptyCommodity(), null); 		// 09/08/2011 cnwmh5 #27959
	pxyTI.CM_Container.zSetPxyISOType(isoType.code);
	pxyTI.setSizeAndTypeAttibutesYA(isoType);
	pxyTI.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	pxyTI.CM_Container.setMyVoyage( self.myVoyage, app.myPassport );
	pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
	if toDoTaskDesc &lt;&gt; null then
		pxyTI.addToDoTask(toDoTaskDesc.description, app.myPassport);
	endif;
	pxyTI.setDischargePort(  destPortCode );

	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	create tiSet transient;
	tiSet.add(pxyTI);
	updController.setMyTransientTIs(tiSet);
	
	app.myPassport.clearErrorsWarnings;
	app.myPassport.setWarningsIgnored(false);
	
	while true do
		app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			ti := updController.allPersistentTIs.first;
			break;
		else
			mess := app.myPassport.getAllErrorsWarningsAsString;
			if self.showErrorMessage(mess, app.myPassport.hasErrors()) then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	endwhile;
	
	// now need to move ti location onto the ship.
	create moveController transient;
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation( location );
	moveController.isSystemMove := true;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	if (not app.myPassport.noErrors) then
		mess := app.getErrorString(ERR_MOVE_RT_ERR);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	self.myTrackedItem := ti;

//	if location &lt;&gt; null and app.myPassport.noErrors then
//		voyJob := self.createVoyageJob( location );
//	endif;

		
epilog

	delete pxyTI;
	delete updController;
	delete tiSet;
	delete strArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doIDLostFocus" id="3e8c2ace-9635-4820-93d0-5c9c3435febc">
        <updating/>
        <source>doIDLostFocus() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003

*/

vars

	id  : String;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	tiMaster : CM_TIMaster;
	tiMasterCont : CM_TIMasterContainer;
	defIsoType : CM_ISOType;

begin

	btnOne.enabled := true;

	id := txtId.text.trimBlanks.toUpper;
	if id = null then
		self.msgBox(app.getErrorString(ERR_INVALID_TI_ID), app.getErrorString(Error), MsgBox_OK_Only, false );
		btnOne.enabled := false;
		self.btnTwo.setFocus();
		return;
	endif;
	
	ti := self.findExistingCargo(id);
	
	ti := self.myVoyage.allOnshipTIsByCargoTypeId.getAtKey(TI_CargoType_Container,id);
	if ti &lt;&gt; null then
		btnOne.enabled := false;
		self.btnTwo.setFocus();
		return;
	endif;
	
	// Ok its not a duplicate.  See if we know about this container in a previous life...
	tiMaster := app.myRoot.allTiMasters.getAtKey(TI_CargoType_Container,id);
	if tiMaster &lt;&gt; null then
		if tiMaster.isKindOf(CM_TIMasterContainer) then
			tiMasterCont := tiMaster.CM_TIMasterContainer;
			if txtIsoType.text.trimBlanks = null then
				// we do so grab its iso type and populate he field on the form
				txtIsoType.text := tiMasterCont.isoType;
			endif;
		endif;
	endif;
	
	if txtIsoType.text.trimBlanks = null then
		defIsoType := self.myTerminal.getConfig(DefISOType).CM_ISOType;
		if  defIsoType &lt;&gt; null then
			// populate he field on the form using the no info default value.
			self.txtIsoType.text := defIsoType.code;
		endif;
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="bec597d0-9644-4c42-a4ce-528e5e818203">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	str : String;
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	left : Real;
	height : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	width := ( stdWidth / 3 ) - self.resizedMargin;
	if _initialSetup then
		self.lblId.setAndIncrementTabIndex( tabIndex );
		self.lblId.visible := true;
	endif;
	self.lblId.move(	stdLeft,
						top,
						width,
						stdHeight );
	
	left := self.lblId.left + self.lblId.width + self.resizedMargin;
	width := self.lblId.width * 2  - (self.resizedMargin + stdHeight );
	if _initialSetup then
		self.txtId.setAndIncrementTabIndex( tabIndex );
		self.txtId.visible := true;
	endif;
	self.txtId.move(	left,
						top,
						width,
						stdHeight );
	
	top := self.txtId.top + self.txtId.height + self.resizedMargin;
	width := self.lblId.width;
	if _initialSetup then
		self.lblIsoType.setAndIncrementTabIndex( tabIndex );
		self.lblIsoType.visible := true;
	endif;
	self.lblIsoType.move(	stdLeft,
							top,
							width,
							stdHeight );
							
	left := self.lblId.left + self.lblId.width + self.resizedMargin;
	width := self.txtId.width;
	if _initialSetup then
		self.txtIsoType.setAndIncrementTabIndex( tabIndex );
		self.txtIsoType.visible := true;
	endif;
	self.txtIsoType.move(	left,
							top,
							width,
							stdHeight );


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findExistingCargo" id="396a64aa-ea79-45bc-9ed1-36ac80b16394">
        <source>findExistingCargo( id : String ):CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 270003

*/

vars

	ti : CM_TrackedItem;
	voyage : CM_Voyage;

begin

	ti := self.myVoyage.allOnshipTIsByCargoTypeId.getAtKey(TI_CargoType_Container,id);
	if ti &lt;&gt; null then
		self.msgBox(app.getErrorString1(Unable_already_board,id), app.getErrorString(Error), MsgBox_OK_Only, false );
		return ti;
	endif;
	
	ti := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKey(TI_CargoType_Container,id);
	if ti &lt;&gt; null then
		self.msgBox(app.getErrorString1(Unable_already_term,id), app.getErrorString(Error), MsgBox_OK_Only, false );
		return ti;
	endif;

	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		//08/02/2011 cnwdz2 27936
		if voyage.status = Voyage_Status_Departed or voyage.status = Voyage_Status_Closed then
			continue;
		endif;
		
		ti := voyage.allOnshipTIsByCargoTypeId.getAtKey(TI_CargoType_Container,id);
		if ti &lt;&gt; null then
			self.msgBox(app.getErrorString2(Unable_already_board_voy,id,voyage.code), app.getErrorString(Error), MsgBox_OK_Only, false );
			return ti;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findIsoType" id="4106a540-bda7-48fe-8c3e-3c006bbae699">
        <source>findIsoType( id : String ):CM_ISOType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003

*/

vars

	isoText : String;
	mess : String;
	isoType : CM_ISOType;

begin

	isoText := self.txtIsoType.text.trimBlanks.toUpper;
	if isoText = null then
		mess := app.getErrorString( Unspecified_ISO_Type );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;

	isoType := app.myRoot.allISOTypes[isoText];
	if isoType = null then
		mess := app.getErrorString3( ERR_INVALID_ISOTYPE, isoText, null, id );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	return isoType;

epilog

end;</source>
        <Parameter name="id" type="String"/>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="236d6458-6502-4efc-b312-0b816c63647a">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 June 2011	cnwndl1	Initial creation	Par 27003

*/

vars

begin

	//create the cargo,
	self.createNewTrackedItem();
	
	if self.myTrackedItem &lt;&gt; null then
		self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
		self.doBackButtonClick();
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
