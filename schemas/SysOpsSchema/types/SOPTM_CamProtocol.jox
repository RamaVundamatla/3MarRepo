    <JadeMethod name="doUpdateHistoryStatus" id="f0a336e4-fc7f-4648-aab4-b7223b1c9b64">
        <updating/>
        <source>doUpdateHistoryStatus(_toStatus: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	camTaskHistory		: CM_CamTaskHistory;
	camProtocol			: CM_CamProtocol;
	row, answer			: Integer;
	table				: CM_DataTable;
	obj					: Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	

	camProtocol	:= self.myForm.myCurrentObject.CM_CamProtocol;
	
	if camProtocol = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'current protocol is null');
		return;
	endif;
	
	table := self.myForm.tblDataView1; 
	
	foreach obj in table.allSelectedObjects do
		camTaskHistory := obj.CM_CamTaskHistory;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateCamObjectStatus(camTaskHistory, _toStatus, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.refreshHistoryItem(camTaskHistory, table.row);
				break;
			else
				theResult := app.showErrorWarningDialog("Update Task History Status", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
		if not app.myPassport.trxCompletedOK then
			break;
		endif;
		
	endforeach;
	
	foreach row in 1 to table.rows do
		if row &lt;= table.fixedRows then
			continue;
		endif;
		table.accessRow(row);
		if table.accessedRow.selected then
			self.refreshHistoryItem(table.accessedRow.itemObject.CM_CamTaskHistory, table.row);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_toStatus" type="Integer"/>
    </JadeMethod>
