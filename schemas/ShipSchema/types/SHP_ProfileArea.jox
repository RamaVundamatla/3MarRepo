    <JadeMethod name="drawArrowDown" id="40cafb7b-1fc4-448c-98a0-82c34c8fd7e0">
        <source>drawArrowDown(_frame : Frame input;_theX,_theY : Real; _numberCC,_numberPln : Integer; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	colX1, colXC, colX2, topY, botY,cenY : Real;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533
	
begin
	if _numberCC = 0 then
		return;
	endif;
	
	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;
	
	self.tmpIntegerArray.clear;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
//	colXC := colX2 - ((colX2 - colX1) / 2);
	colXC := _theX;
	topY := _theY -2;
	cenY := topY + 18;
	botY := cenY + 5;
	
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(topY); // ## 1
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(topY); // ## 2
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(cenY); // ## 3
	self.tmpIntegerArray.add(colXC);self.tmpIntegerArray.add(botY); // ## 4
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(cenY); // ## 5
	
	_frame.drawFillColor := Blue;
	_frame.drawFilledPolygon(self.tmpIntegerArray,Black);
	_frame.drawTextAt(_numberCC.zeroNotAllowed,_theX,_theY - 3,White);
	_frame.drawTextAt(_numberPln.zeroNotAllowed,_theX,_theY + 6,White);

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_theX" type="Real"/>
        <Parameter name="_theY" type="Real"/>
        <Parameter name="_numberCC" type="Integer"/>
        <Parameter name="_numberPln" type="Integer"/>
        <Parameter name="_column" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="drawArrowDownDeck" id="321a0958-6f62-49cf-bf75-e56ddbd1aabe">
        <source>drawArrowDownDeck(_frame : CMUI_GridAreaFrame input;_theX,_theY : Real; _numberCC,_numberPln : Integer; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 28701 - Changed so that deck arrows are wider and the 2 numbers are next to each other rather than on top of each other.
//					29830 shrink font size for larger numbers
// ---------------------------------------------------------------------------

vars
	colX1, colXC, colX2, topY, botY,cenY : Real;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533
	fontSize		: Real;
	
begin
	if _numberCC = 0 then
		return;
	endif;
	
	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;
	
	self.tmpIntegerArray.clear;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
	colXC := _theX;
	topY := _theY;
	cenY := topY + 13;
	botY := cenY + 5;
	
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(topY); // ## 1
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(topY); // ## 2
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(cenY); // ## 3
	self.tmpIntegerArray.add(colXC);self.tmpIntegerArray.add(botY); // ## 4
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(cenY); // ## 5
	
	_frame.drawFillColor := Blue;
	_frame.drawFilledPolygon(self.tmpIntegerArray,Black);
	// from 29830 show larger values better
	fontSize := _frame.drawFontSize;
	if _numberCC &gt; 99 or _numberPln &gt; 99 then
		_frame.drawFontSize := fontSize - 1;
	endif;
	_frame.drawTextAt(_numberCC.zeroNotAllowed,_theX - 8,_theY,White);
	_frame.drawTextAt(_numberPln.zeroNotAllowed,_theX + 9,_theY,White);
	_frame.drawFontSize := fontSize;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX" type="Real"/>
        <Parameter name="_theY" type="Real"/>
        <Parameter name="_numberCC" type="Integer"/>
        <Parameter name="_numberPln" type="Integer"/>
        <Parameter name="_column" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="drawArrowUp" id="e1169941-7224-4091-bcf6-51be1db52b30">
        <source>drawArrowUp(_frame : Frame input;_theX,_theY : Real; _number,_numberPln : Integer; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	colX1, colXC, colX2, topY, botY,cenY : Real;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533

begin
	if _number = 0 then
		return;
	endif;

	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;

	self.tmpIntegerArray.clear;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
	colXC := colX2 - ((colX2 - colX1) / 2);
	topY := _theY - 5;
	cenY := _theY;
	botY := _theY + 20;
	
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(cenY); // ## 1
	self.tmpIntegerArray.add(colXC);self.tmpIntegerArray.add(topY); // ## 2
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(cenY); // ## 3
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(botY); // ## 4
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(botY); // ## 5
	
	_frame.drawFillColor := Green;
	_frame.drawFilledPolygon(self.tmpIntegerArray,Black);
	_frame.drawTextAt(_number.zeroNotAllowed,_theX,_theY - 2,_frame.drawFillColor.getInverseColour);
	_frame.drawTextAt(_numberPln.zeroNotAllowed,_theX,_theY + 8,_frame.drawFillColor.getInverseColour);

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_theX" type="Real"/>
        <Parameter name="_theY" type="Real"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_numberPln" type="Integer"/>
        <Parameter name="_column" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="drawArrowUpDeck" id="9f8a65a0-a7de-4cf1-b2a6-715de62903b0">
        <source>drawArrowUpDeck(_frame : CMUI_GridAreaFrame input;_theX,_theY : Real; _number,_numberPln : Integer; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 28701 - Changed so that deck arrows are wider and the 2 numbers are next to each other rather than on top of each other.
//					29830 shrink font size for larger numbers
// ---------------------------------------------------------------------------

vars
	colX1, colXC, colX2, topY, botY,cenY : Real;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533
	fontSize		: Real;

begin
	if _number = 0 then
		return;
	endif;

	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;

	self.tmpIntegerArray.clear;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
	colXC := colX2 - ((colX2 - colX1) / 2);
	topY := _theY - 5;
	cenY := _theY;
	botY := _theY + 12;
	
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(cenY); // ## 1
	self.tmpIntegerArray.add(colXC);self.tmpIntegerArray.add(topY); // ## 2
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(cenY); // ## 3
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(botY); // ## 4
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(botY); // ## 5
	
	_frame.drawFillColor := Green;
	_frame.drawFilledPolygon(self.tmpIntegerArray,Black);
	// from 29830 show larger values better
	fontSize := _frame.drawFontSize;
	if _number &gt; 99 or _numberPln &gt; 99 then
		_frame.drawFontSize := fontSize - 1;
	endif;
	_frame.drawTextAt(_number.zeroNotAllowed,_theX + 2,_theY - 2,White);
	_frame.drawTextAt(_numberPln.zeroNotAllowed,_theX + 19,_theY - 2,White);
	_frame.drawFontSize := fontSize;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
