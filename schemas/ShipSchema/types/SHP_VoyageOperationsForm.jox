    <JadeMethod name="moveToLocation" id="89fbc7d2-82c3-4122-a085-4b959c706de6">
        <updating/>
        <source>moveToLocation(pToLocation : CM_LocationsController ; _wle : CM_WorkListEntry; _mode : Integer) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	moveController	: CMIF_MoveController;
	result		: Integer;
begin
	
	create moveController transient;
	moveController.setMyTrackedItem(_wle.myTrackedItem);
	moveController.setMyToPrimaryLocation(pToLocation);
	moveController.setMyWorkListEntry(_wle);
	moveController.setJobForMove(_wle.job);
	moveController.setMoveMode(_mode);
	moveController.isForcedMove := true;
	
	// TFS 4435 CNWAB1 MAY17
	if moveController.myToPrimaryLocation &lt;&gt; null then
		//moveController.transferType := moveController.myToPrimaryLocation.getTransferType();
		moveController.setTransferTypeFromJob( _wle.job, moveController.myToPrimaryLocation.getTransferType() );	//12 Mar 2018	NDL	TFS 37444
	endif;

	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete moveController;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="pToLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItem" id="dbd1a12b-aa10-4730-b9fa-87750a38a341">
        <updating/>
        <source>moveTrackedItem(pToLocation : CM_LocationsController ; _wle : CM_WorkListEntry) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	moveController	: CMIF_MoveController;
	result		: Integer;
begin

	if app.myMoveController = null then
		return;
	endif;

	if pToLocation = null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, 'No Target Location found.', null, null);	
		return;
	endif;

	moveController := app.myMoveController;
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		moveController.setJobForMove(_wle.job);
	endif;

	moveController.setMyToPrimaryLocation(pToLocation);
	
	// TFS 4435 CNWAB1 MAY17
	if moveController.myToPrimaryLocation &lt;&gt; null then
	//	moveController.transferType := moveController.myToPrimaryLocation.getTransferType();
		moveController.setTransferTypeFromJob( _wle.job, moveController.myToPrimaryLocation.getTransferType() );	//12 Mar 2018	NDL	TFS 37444
	endif;
		
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.myMoveController := null;
	if moveController &lt;&gt; null then
		delete moveController;
	endif;
end;</source>
        <Parameter name="pToLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="queueTwinLiftsReversed" id="61abb2db-75ce-4dc6-972c-bc4b77a3b9fc">
        <source>queueTwinLiftsReversed(_wleArray : CM_WLEArray input) protected;

// Created by cnwdvb1 on 03 April 2007

vars

	wle 		: CM_WorkListEntry;
	lastVoyageWLE,
	voyageWLE	: CM_VoyageWLE;
	tmpArray	: CM_WLEArray;
	crane		: CM_Crane;

begin

	// Assuming that all wles are on the same job.
	
	if _wleArray.isEmpty() then
		return;
	endif;
	
	create tmpArray transient;
	
	lastVoyageWLE := null;
	
	// Take a look at all sorted wles. This is the order they are going to be queued as this moment.
	foreach wle in _wleArray do
		voyageWLE := wle.CM_VoyageWLE;
		
		// Not a twin lift so just add it back in.
		if not voyageWLE.isTwinLift then
			// Last wle was a twin lift. Handle this. Can happen if sub set of job is selected.
			if lastVoyageWLE &lt;&gt; null then
				// Put the last one back where it should be.
				tmpArray.add(lastVoyageWLE);
				// Clear reference for reset.
				lastVoyageWLE := null;
			endif;
			// Add this single lift in.
			tmpArray.add(wle);
			continue;
		endif;
		
		// We have a twin lift.
		// Is this the second or the first.
		if lastVoyageWLE &lt;&gt; null then
			// Add current wle.
			tmpArray.add(wle);
			// Add last wle
			tmpArray.add(lastVoyageWLE);
			// Reset reference.
			lastVoyageWLE := null;
		else
			// Just remember for next time.
			lastVoyageWLE := voyageWLE;
		endif;
		
	endforeach;
	
	// Copy new order back.
	_wleArray.clear();
	tmpArray.copy(_wleArray);
	
epilog	
	delete tmpArray;
end;</source>
        <access>protected</access>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rebuildJobStatus" id="bc7dcc67-8806-4807-8e09-8572a08942cb">
        <updating/>
        <source>rebuildJobStatus(_job : CM_Job input)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	oldStatus 	:	Integer;
	obj 		: Object;
	rtnValue 	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin	

	if _job = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	oldStatus := _job.status;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateJobStatus(_job, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Job Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	if oldStatus = _job.status then
		// no change, do a refresh instead
		self.tblWLEUpdateJob(_job, self.Mode_Update);
	endif;							
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
    </JadeMethod>
