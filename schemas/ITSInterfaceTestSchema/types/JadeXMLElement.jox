<Class name="JadeXMLElement">
    <JadeMethod name="setElementValue" id="dfc8e566-c1a4-4f72-8d30-1be1c851c857">
        <updating/>
        <source>setElementValue(_tagName : String; _value : String) updating;

/*

Purpose:			Unconditionally set the value of the child element of the receiver to
					the passed in value.  If the element does not exist, then create it

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	element			: JadeXMLElement;
	
begin
	element := self.getElementByTagName(_tagName);
	if element = null then
		element := self.addElement(_tagName);
	endif;
	
	element.setText(_value);
	
	
epilog

end;</source>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
