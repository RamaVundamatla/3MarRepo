    <JadeMethod name="getServiceManager" id="ba93d371-86a9-4ea6-89d8-2941dc329826">
        <source>getServiceManager() : JSSServiceManagerObject;

vars
	processObjectDict	: JSSProcessObjectDict;
	processObject		: JSSProcessObject;
	theObject			: Object;
	
begin
	processObjectDict	:=	JSSProcessObjectDict.firstInstance();
	
	if processObjectDict = null then
//monitor("processObjectDict not found");
		return (null);
	endif;
	
	processObject	:=	processObjectDict[process.getOidString()];
	
	if processObject = null then
		return (null);
//		self.raiseException(99999, "Process Object not found for this Application");
	else
//monitor("Found ServiceManagerObject for process " &amp; process.getOidString &amp; ", application " &amp; processObject.applicationOidAsString &amp; '[' &amp; app.computerName &amp; ']');

// cnwdad1 10/11/2002 - If the Database or Application Server crashes, when restarted, a JSSServiceManagerObject
// can be left behind, and picked up again when clients restart the peer schema (because process OIDs are recycled),
// but the applicationOidAsString will point to an invalid object, so we need to reset it.
//		return ((processObject.applicationOidAsString).asOid.JSSServiceManagerObject);
		
		if global.isValidObject(processObject) then
			on Exception do handleExceptionIgnore1266(exception, theObject);
			
			theObject	:=	processObject.applicationOidAsString.asOid();
			
			if theObject = null then
				return null;
			elseif global.isValidObject(theObject) then
				if theObject = null then
					return null;
				else
					return (theObject.JSSServiceManagerObject);
				endif;
			else
				return null;
			endif;
		else
			return null;
		endif;
	endif;
end;</source>
        <ReturnType type="JSSServiceManagerObject"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionIgnore1266" id="7d3a2eb7-b036-4209-82de-ba94f24c41b1">
        <source>handleExceptionIgnore1266(pException : Exception; pTheObject : Object io) : Integer;

begin
	if pException.errorCode = 1266 then
		pTheObject := null;
//self.monitor("$$$$$$$$$$ Exception 1266 has been ignored");
		return( Ex_Resume_Next );
	endif;
	return( Ex_Pass_Back );
end;</source>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pTheObject" type="Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isJSSException" id="6435970a-5157-4faf-b87e-37f7fbd53222">
        <source>isJSSException(pExceptionObj:Exception):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 July 2002 by cnwdad2
//
// Purpose:		This method is for application schemas exception handling.  In most
//				cases, peer schemas will raise exceptions of type JSSException to
//				report any detected errors.  For the application schema to easily
//				determine whether their exception is a peer schema one or not, they
//				can simply call this method, and then treat the error according to
//				the application's needs.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		True if the exception is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return JSSException.hasInstance(pExceptionObj);
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="monitor" id="c99ff91e-3680-4483-9685-a2621309a450">
        <source>monitor(pMessage : String);

begin
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</Class>
