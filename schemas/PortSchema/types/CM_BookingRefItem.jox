    <JadeMethod name="getDataForDefSpecial" id="7f422dfc-7074-4229-82ba-0ed1f32a07c3">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
/*
	Created on 11 January 2008 by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
17 Jun 2013	cnwcs5	par 31670
04 Apr 2019 jlgzm1	TFS43864 Booking screen performance
24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
*/


vars
	headingStr,
	tmpStr			: String;
	firstTime		: Boolean;
	hazard			: CM_Hazard;
	ti				: CM_TrackedItem;
	invalid 		: Boolean;
	prod			: CM_Product;
	prodDesc		: String;
	coll			: CM_TIArray;
begin	
	if _attrName = ETRow_MyOperator 
	or _attrName = ETRow_Voyage
	or _attrName = ETRow_ConsignorCode
	or _attrName = ETRow_ConsigneeCode
	or _attrName = ETRow_Vessel 
	or _attrName = ETRow_DischargePorts
	or _attrName = ETRow_MyVessel then
		return myBookingReference.getDataForBRItem(_attrName, _heading, _headings, _data);
		
	elseif _attrName = ETRow_IsoType then
		
		_headings.add(_heading);
		
		if self.myISOType &lt;&gt; null then
			_data.add(self.myISOType.getTableDisplay);
		else
			_data.add(null);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_AllTIHazards then 
		firstTime := true;
		
		foreach hazard in self.allTIHazards do
			if firstTime then
				firstTime := false;
				tmpStr := _heading;
			else
				tmpStr := ' ';
			endif;
			_headings.add(tmpStr);
			_data.add(hazard.getTableDisplay(false, true)&amp; " " &amp; hazard.description);		
		endforeach;
		
		return true;

	elseif _attrName = ETRow_WeightTotal then
		_headings.add(_heading);
		_data.add(self.weight.asStringWeightJMT());
		
		return true;
		
	elseif _attrName = ETRow_ShippingMarks then
		_headings.add(_heading);
		_data.add(self.shippingMarks);
		
		return true;

	elseif _attrName = ETRow_CargoType then
		_headings.add(_heading);
		_data.add(self.cargoTypeDescr);
		
		return true;
	
	elseif _attrName = ETRow_TiRecieved then//cnwyl1 changed it for par15152
		create coll transient;
		
		firstTime := true;
		
		// blank row before we show items received so far
		_headings.add(''); _data.add('');	
		
		//tfs43864
		if self.allTIs.size &gt; 1000 then
			return true;
		endif;
		
		self.getPrenotedTrackedItems (coll,null);

		foreach ti in coll do
			if firstTime then
				firstTime 	:= false;
				
				//_headings.add('Pre-Notified');
				_headings.add( app.getErrorString(PreNotified) );	//27 Sep 2013	NDL	Par 32582
			else		
				_headings.add(null); 
			endif;
			_data.add(ti.getOidAsString); // TFS 4052
		endforeach;
		
		firstTime 		:= true;
		
		coll.clear;
		self.getReceivedTrackedItems (coll);
		
		foreach ti in coll do
			if firstTime then
				firstTime 	:= false;
				_headings.add( app.getErrorString(ItemsReceived) );	//27 Sep 2013	NDL	Par 32582
			else		
				_headings.add(null); 
			endif;

			_data.add(ti.getOidAsString); // TFS 4052
		endforeach;
		
		return true;
		
	elseif _attrName = ETRow_MyProduct then
		prod := self.myProduct;
		if prod &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, prod, invalid);
			invalid := false;
			prodDesc := prod.description;
			if not invalid then
				_headings.add(_heading);
				_data.add(prod.description);
			endif;
		endif;
		return true;
	elseif _attrName = ETRow_MyQuantity then
		if self.myProduct &lt;&gt; null then
			_headings.add(_heading);
			_data.add(self.productQuantity.String);
		endif;
		return true;
	elseif 	_attrName = ETRow_MyLength or
			_attrName = ETRow_MyHeight or
			_attrName = ETRow_MyWidth or
			_attrName = ETRow_MyVolume or
			_attrName = ETRow_MyWeight or
			_attrName = ETRow_MyDensity or
			_attrName = ETRow_MyQuantity then

		if self.myProduct = null then
			return true;
		endif;
	elseif _attrName = ETRow_MyLengthString then
		if self.lengthString = null then
			return true;
		endif;
	elseif _attrName = ETRow_MyHeightString then
		if self.heightString = null then
			return true;
		endif;
	elseif _attrName = ETRow_MyWidthString then
		if self.widthString = null then
			return true;
		endif;
		if self.myProduct = null then
			return true;
		endif;
	elseif _attrName = ETRow_IsControlledAtmosphere then				// CCMS 1654 - slw 11/09/2008
		if self.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getIsControlledAtmosphere.getYesNo);
		endif;
		return true;
	elseif _attrName = ETRow_CarbonDioxide then							// CCMS 1654 - slw 11/09/2008
		if self.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getCarbonDioxide.asNullCarbonDioxide);
		endif;
		return true;
	elseif _attrName = ETRow_Oxygen then								// CCMS 1654 - slw 11/09/2008
		if self.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getOxygen.asNullOxygen);
		endif;
		return true;
	elseif _attrName = ETRow_CurtainsIn then							// CCMS 1654 - slw 11/09/2008
		if self.getIsControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getCurtainsIn.getYesNo);
		endif;
		return true;
	endif;
	
	return inheritMethod(_attrName, _heading, _headings, _data);
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultMeasurementForType" id="cc93eef1-a9ae-4f6e-b46a-fb510c0e8c01">
        <source>getDefaultMeasurementForType(_type: String): CM_MeasurementType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial measurements
*/
vars

begin
	if self.myProduct &lt;&gt; null then
		return self.myProduct.getDefaultMeasurementForType(_type);
	elseif self.myCargoType &lt;&gt; null and self.myCargoType.mySystemProductType &lt;&gt; null then
		return self.myCargoType.mySystemProductType.getDefaultMeasurementForType(_type);
	endif;
	
	return inheritMethod(_type);
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getDensity" id="240a014d-9653-4684-b4e6-64bbbb9d4877">
        <source>getDensity(): Decimal protected;
/*

Date		Who		Reason
23 September 2014	cnwer1	Initial creation PAR 34935

*/

vars

begin
	if self.myProduct &lt;&gt; null and self.myProduct.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
		return self.myProduct.getDensityValue;
	endif;
	if self.myCargoType &lt;&gt; null then
		if self.myCargoType.mySystemProductType &lt;&gt; null  then
			return self.myCargoType.mySystemProductType.getDensityValue;
		endif;
		
		return self.myCargoType.defaultDensity;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Decimal"/>
    </JadeMethod>
