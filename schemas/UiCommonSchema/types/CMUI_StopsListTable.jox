        <text>This is a collection of the stops that have been marked as being set for this TrackedItem
</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allStopsToBeUpdated" id="8b9f9422-ebd1-4e04-9f65-645e626ccaba">
        <memberTypeInverse/>
        <type name="CM_StopsByIdDict"/>
        <access>readonly</access>
        <text>This is a collection of all stops that have got an expiry date set against the TrackedItem.
This means the stops will be cleared BUT not physically be deleted from the TrackedItem.
</text>
    </ImplicitInverseRef>
