<Class name="CM_InterfaceMessage" id="2c2197f1-11ca-40f7-b9f1-4a0b6d87e2ce">
    <superclass name="CM_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>consw1 11/11/2009 PAR 21593 - CCMS MES 1014</text>
    <DbClassMap file="jmtinterface"/>
    <JadeMethod name="findXMLInteger" id="07728435-4ede-492c-9854-fee34743c669">
        <source>findXMLInteger(	_xmlDoc			: JadeXMLDocument;
				_tagName		: String;
				_validateFormat	: Boolean	) : Integer;

/*

Purpose:			Get Integer value from xml document.

Parameters:			_validateFormat - if true, an exception will be raised when non Integer value encountered.

Return Value:		Truncated value for tag from XML doc.


Date		Who		Reason
19 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	textValue	: String;
	xmlElement	: JadeXMLElement;

begin
	xmlElement := _xmlDoc.findElementByTagName(_tagName);
	
	if xmlElement = null then
		return 0;
	endif;
	
	textValue := xmlElement.text();
	
	if textValue = null then
		return 0;
	endif;
	
	if textValue.isInteger() then
		return textValue.Integer;
	endif;
	
	if _validateFormat then
		app.raiseCMException2(ERR_FIELD_VALUE, textValue, _tagName, null, null);
	endif;
	
	return 0;
	
epilog

end;</source>
        <Parameter name="_xmlDoc" type="JadeXMLDocument"/>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_validateFormat" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findXMLString" id="284dd3bc-cc63-4408-a9f5-cfbc80f247e7">
        <source>findXMLString(	_xmlDoc			: JadeXMLDocument;
				_tagName		: String;
				_maxLength		: Integer;
				_validateFormat	: Boolean	) : String;

/*

Purpose:			Get string value from xml document.

Parameters:			_maxLength is maximum length expected.
					_validateFormat - if true, an exception will be raised when maximum length exceeded.

Return Value:		Truncated value for tag from XML doc.


Date		Who		Reason
19 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	returnValue	: String;
	textValue	: String;
	xmlElement	: JadeXMLElement;

begin
	xmlElement := _xmlDoc.findElementByTagName(_tagName);
	
	if xmlElement = null then
		return null;
	endif;
	
	textValue := xmlElement.text();
	
	if _maxLength = 0 then
		return textValue;
	endif;
	
	returnValue := textValue[1:_maxLength];
	
	if _validateFormat and
	   returnValue &lt;&gt; textValue then
		app.raiseCMException2(ERR_FIELD_LENGTH, textValue, _tagName, null, null);
	endif;
	
	return returnValue;
	
epilog

end;</source>
        <Parameter name="_xmlDoc" type="JadeXMLDocument"/>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_maxLength" type="Integer"/>
        <Parameter name="_validateFormat" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleXMLException" id="a4767399-6d3e-46ce-8acb-75f32da97b6a">
        <source>handleXMLException(_exc : JadeXMLException; _invalidXML : Boolean io) : Integer;

/*

Purpose:			Exception handler to capture parser exception for invalid XML

Parameters:			None

Return Value:		None


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if _exc.errorCode = JadeXMLException.ParserError then
		_invalidXML := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_invalidXML" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
