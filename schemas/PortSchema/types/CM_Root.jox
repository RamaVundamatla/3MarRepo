    <JadeMethod name="getConfig_AutoFileDirectory" id="dd8562d0-a9ca-4aab-a2fe-e1c372d40dbc">
        <source>getConfig_AutoFileDirectory( _code : String ) : Any;

/*

Purpose:		This method is to be used to get the System Configuration "Auto Root EDI File Directory" setting.
				The addition to the normal use of getConfig is that the directory path can contain %MISCDIR% (any case)
				which will be interpreted at run time to be the correct miscellaneous directory and substituted in the
				directory path instead of the string %MiscDir%.
				This method is NOT to use app.cnGetClientMiscPath until JadeCare Start PAR 579 is fixed.

Date		Who		Reason
26 May 2009	cnwrl1	Initial creation as part of PAR 19732 - Get the AutoFileDirectory
22 Nov 2012	cnwcs5	par 30618 - replace CM_Root::substituteDirectory with String method

*/
	
vars
	fileDirectory	: String;
	
begin
	fileDirectory	:= self.getStateData( ConfigGrp_System, _code ).String;
	fileDirectory 	:= fileDirectory.substituteDirectory;	// par 30618 Nov 2012
	
	return fileDirectory;
epilog
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getCustomExportStops" id="1229763b-f1a1-429b-9204-bbfc44a51429">
        <source>getCustomExportStops(_stopTables : IntegerArray io; _terminal : CM_Terminal);
//----------------------------------------------------------------
//	Created:	Dec 2006	cnwrs1 par 13095
//----------------------------------------------------------------
vars
//	exportStops			: IntegerArray;
//	custClearedStops	: IntegerArray;
//	stopTableID			: Integer;
	stopTable : CM_StopsTable;
begin
//	create exportStops transient;
//	create custClearedStops transient;
	
//	self.getStopsForApplyArea(Stop_Set_Export, exportStops);
//	self.getStopsForProcessArea(Stop_Process_EDICustom_Export, custClearedStops);
//	cnwrs1 may 2007 PAR13378 Stops	
	foreach stopTable in self.allAvailableStopsTables do //cnwrs1 May 2007 Par 13378
		if stopTable.isCEDOStop(_terminal) then
			_stopTables.add(stopTable.id);
		endif;
	endforeach;
epilog
//	delete custClearedStops;
//	delete exportStops;
end;</source>
        <Parameter name="_stopTables" type="IntegerArray" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getCustomImportStops" id="2101cd61-a120-4cb3-82b9-34067b17320f">
        <source>getCustomImportStops(_stopTables : IntegerArray io; _cargoType : Integer; _terminal : CM_Terminal);
//----------------------------------------------------------------
//	Created:	06 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 01 Oct 2019	jlgrs1	TFS nnnn should only get those appliable for our cargo type
//
vars
//	importStops			: IntegerArray;
//	custClearedStops	: IntegerArray;
//	stopTableID			: Integer;
	stopTable : CM_StopsTable;
begin
//	create importStops transient;
//	create custClearedStops transient;
	
//	self.getStopsForApplyArea(Stop_Set_Import, importStops);
//	self.getStopTablesForProcessArea(Stop_Process_EDICustom_Import, custClearedStops);

//	cnwrs1 may 2007 PAR13378 Stops	
	foreach stopTable in self.allAvailableStopsTables do //cnwrs1 May 2007 Par 13378
		if stopTable.isCustomsEntryStop(_terminal) and
		   stopTable.isValidForCargoType(_cargoType) then
			_stopTables.add(stopTable.id);
		endif;
	endforeach;
epilog
//	delete custClearedStops;
//	delete importStops;
end;</source>
        <Parameter name="_stopTables" type="IntegerArray" usage="io"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getCustomsInspectionStops" id="b4caad05-3f51-4f25-84f0-bb5a7ba7f1f2">
        <source>getCustomsInspectionStops(_stopTables : IntegerArray io; _terminal : CM_Terminal);
//----------------------------------------------------------------
//	Created:	06 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	stopTable : CM_StopsTable;
begin
//	cnwrs1 may 2007 PAR13378 Stops	
	foreach stopTable in self.allAvailableStopsTables do //cnwrs1 May 2007 Par 13378
		if stopTable.isCustomsInspectionStop(_terminal) then
			_stopTables.add(stopTable.id);
		endif;
	endforeach;
end;</source>
