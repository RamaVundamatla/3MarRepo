    <JadeMethod name="addToolbarControls" id="863b2dd4-4d52-45e8-b343-e2105256b3a9">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	toolbar  : CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	self.btnSaveBase.visible := true;
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	self.btnCancelBase.enabled 	:= true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbExpVoyage_click" id="7389e423-f2ce-49c9-b56f-a3fe57e83629">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbExpVoyage_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.cmbExpVoyage.listObject = null then
		self.cmbDiscPort.setObjectFromCodeAndVoyage (self.cmbDiscPort.getCode(), null);
	else
 		self.cmbDiscPort.setObjectFromCodeAndVoyage (self.cmbDiscPort.getCode(), self.cmbExpVoyage.listObject.CM_Voyage);
 	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
