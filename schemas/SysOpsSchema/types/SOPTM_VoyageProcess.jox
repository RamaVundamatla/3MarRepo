    <JadeMethod name="delete" id="153affac-101a-47c9-85a3-bace052bb611">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin

