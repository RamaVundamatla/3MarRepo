    <JadeMethod name="sysNotify" id="83e3f12e-e632-4af0-9ec5-21a7303e266d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 22 Apr 2020  cnwma1       Bug 49078: MTN - UE Floods
// 13 Feb 2023	navcs2		 ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen)
// 27 Mar 2023  navma1 		 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
// -----------------------------------------------------------------------------


vars
	anObject 	: Object;
	theJob 		: CM_Job;
	aRequest 	: CM_Request; //cnwrd1 30.11.2010
	invalidWLE 	: Boolean;	
	aWLE 		: CM_WorkListEntry;
	edition     : Integer;

begin
	
	on Exception do app.handleDeletedObject(exception, anObject, invalidWLE); 
	

	inheritMethod(eventType, theObject, eventTag);
		
	anObject := theObject;
	
	if ( self.optViewWorkList.value	and anObject.isKindOf( CM_WorkListEntry) )	then
	
		aRequest := anObject.CM_WorkListEntry.myRequest; //cnwrd1 30.11.2010
		aWLE 	 := anObject.CM_WorkListEntry;
		
		// ### JIRA: MTN-36910 06Jan2026 NAVPW1
		if aRequest = null then
			return;
		endif;
		// ### JIRA: MTN-36910 06Jan2026 NAVPW1
		
		//21 Jul 2014	NDL	Par 33704 - need to de-reference to potentially set 'invalidWLE'
		if aWLE &lt;&gt; null then
			edition := aWLE.edition;	
		endif;
		
		if invalidWLE then 
			return;
		endif;
		
		if aRequest.myJob &lt;&gt; null then       //22.04.2020 cnwma1 #49078
			theJob := aRequest.myJob;
		endif;
		
		if theJob &lt;&gt; null and theJob.CM_Job.getMyTerminal() &lt;&gt; self.myTerminal then //cnwrd1 22.11.2010 - getting notes for other terminals WLE's and displaying them is bad.
			return;
		endif;
		
		if eventType = Object_Update_Event then
			self.tblWLEUpdateWle(aWLE, self.Mode_Update);				
		elseif eventType = Object_Create_Event then
			//self.tblWLEUpdateWle(anObject.CM_WorkListEntry, self.Mode_Add);		// 13 Feb 2023	navcs2 56318:[56319]
		elseif eventType = Object_Delete_Event then			
			self.tblWLEUpdateWle(aWLE, self.Mode_Delete);		
		endif;

	endif;
	
	if ( self.optViewJob.value and anObject.isKindOf( CM_Job) )	then
	
		theJob := anObject.CM_Job;
		
		if theJob.getMyTerminal() &lt;&gt; self.myTerminal then //cnwrd1 22.11.2010 - getting notes for other terminals WLE's and displaying them is bad.
			return;
		endif;
		
		if eventType = Object_Update_Event then
			if theJob.status = JOB_COMPLETE then
				self.tblDataSysNotifyDelete(eventType, theJob, eventTag);
			else
				self.tblDataSysNotifyUpdate(eventType, theJob, eventTag);
			endif;
		elseif eventType = Object_Create_Event then		
			self.tblDataSysNotifyCreate(eventType, theJob, eventTag);			
		elseif eventType = Object_Delete_Event then
			self.tblDataSysNotifyDelete(eventType, theJob, eventTag);
		endif;
	endif;
	
	//cnwrd1 par 24971 5.10.2010 - need to refresht he job info if we get wle notes
	if ( self.optViewJob.value and anObject.isKindOf( CM_WorkListEntry) )	then
		//may have to update the job view if we have it.
		theJob := anObject.CM_WorkListEntry.job;
		if not invalidWLE then
			self.tblDataSysNotifyUpdate(eventType, theJob, eventTag);
		endif;
	endif;

	// clean up the jobs WLE's
	if ( self.optViewWorkList.value and anObject.isKindOf( CM_Job) )then
		//may have to update the job view if we have it.
		theJob := anObject.CM_Job;
		if theJob.status = JOB_COMPLETE then
			/*
			27.03.2023 navma1 #56614:[56615]
			//need to remove all the jobs wle's
			self.clearJobWLELines(theJob);
			*/
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyCreate" id="a1daee50-f6f3-4b74-82c6-a9200e235e5c">
        <updating/>
        <source>tblDataSysNotifyCreate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation

*/

vars
	theTable : CM_DataTable;	
	include : Boolean;
	theRow	: Integer;
begin

	include := false;
	
	if self.optViewWorkList.value then
		theTable := self.tblWorkEntries;
		include := self.includeWLE(_theObject.CM_WorkListEntry);
		
		if include then
			self.addWLEtoTable(_theObject.CM_WorkListEntry);
			return;
		endif;
	else
		theTable := self.tblJobs;
		include := self.includeJob(_theObject.CM_Job);
	endif;	
	
	if not include then
		return;
	endif;

	if (not theTable.findObjectInRow(_theObject, theRow)) then				
		theTable.addItemObject( _theObject, self.displayRowForDataTable(_theObject.CM_Object , theTable ) );
	endif;


epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyDelete" id="a613c284-a4f7-41ff-be2d-cce6f2ec106e">
        <updating/>
        <source>tblDataSysNotifyDelete(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation

*/

vars

	theRow	: Integer;

	theTable : CM_DataTable;	
begin

	if self.optViewWorkList.value then
		theTable := self.tblWorkEntries;
	else
		theTable := self.tblJobs;
	endif;	

	theTable.findObjectInRow(_theObject, theRow);

	if theRow &gt; 0 then

		theTable.removeDeletedObject(_theObject);

	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyUpdate" id="9b48cf33-e26c-4ac1-ba1d-0dec0ffd32b8">
        <updating/>
        <source>tblDataSysNotifyUpdate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation

*/

vars

	theRow	: Integer;
	theTable : CM_DataTable;	
	invalidOject : Boolean;
begin
	//14/02/2011 cnwdz2 par26987
	on Exception do app.handleDeletedObject(exception, _theObject, invalidOject);
	
	if self.optViewWorkList.value then
		theTable := self.tblWorkEntries;
	else
		theTable := self.tblJobs;
	endif;	
	
	theTable.findObjectInRow(_theObject, theRow);

	if theRow &gt; 0 then
		theTable.accessCell(theRow, 1).text := _theObject.CM_Object.getAttributeStringForDefArray(theTable.allTblDataEntRows);	
	endif;
	
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblJobsChange" id="09c57e00-c841-494a-b73d-301de03d3365">
        <updating/>
        <source>tblJobsChange(_newRow : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	job : CM_Job;
begin
	self.myCurrentJob := null;		
	self.myCurrentWLE := null;		
	self.myCurrentTrackedItem := null;
	
	if _newRow &lt;= self.tblJobs.fixedRows then
		if CM_Object.hasInstance(self.myCurrentListObject) then
			if global.isValidObject(self.myCurrentListObject) then
				self.displayExtraInfoForObj(self.myCurrentListObject);
				self.setNavigator(self.myCurrentListObject);	
				self.setStatusBarCaption();
				self.tblJobs.clearAllSelected();
			else
				self.setMyCurrentListObjects(null);
			endif;
		endif;
		return;
	endif;
	
	job := self.tblJobs.accessRow(_newRow).itemObject.CM_Job;
	
	if not global.isValidObject(job) then
		return;
	endif;
	
	self.myCurrentJob := job;
	
	self.displayExtraInfoForObj(job);
	self.setStatusBarCaption();
	
	self.btnDeleteTV.enabled := true;
	
	if self.myCurrentJob.isPlanOnPickup then
		self.btnEdit.enabled := false;
		self.mnuEditInternalMove.enabled := false;
	else
		self.btnEdit.enabled := true;
		self.mnuEditInternalMove.enabled := false;
	endif;
	
	/*
	if job.isKindOf(CM_YardInternalJob) and job.getWorkOrder() = null then
		self.btnDeleteTV.enabled := true;
	else
		self.btnDeleteTV.enabled := false;
	endif;
	*/

end;
</source>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblJobs_contextMenu" id="d6c39463-357f-470d-9c87-9c879dfb3adc">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobs_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	xLeft : Real;
	yTop : Real;
	
begin


	self.doBuildMnuTblJobs( self.getCurrentJob() );
	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	self.mnuInspectJob.visible := app.isAllowedToInspect();	

	self.popupMenu(mnuJobs, xLeft.Integer, yTop.Integer);
	self.mnuColumnOrganiser.userObject := table;

	return false;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblJobs_dblClick" id="88db50d6-55fd-4aeb-b09b-f8269c891895">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobs_dblClick(table: Table input) updating;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	job : CM_Job;
	invalidJob : Boolean;
	
begin
	
	if self.tblJobs.row &lt;= self.tblJobs.fixedRows then
		self.resortTblJobs();
		return;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;


	on Exception do app.handleDeletedObject(exception, job, invalidJob);

	job := self.tblJobs.accessRow(tblJobs.row).itemObject.CM_Job;

	if not job.workListEntries.isEmpty() then
		if not invalidJob then
			self.showJobWLE(job);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblJobs_mouseDown" id="587ebf5b-b277-4e94-be66-836e8057411d">
