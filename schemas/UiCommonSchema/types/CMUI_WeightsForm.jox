    <JadeMethod name="populateCombos" id="6bb90012-18c7-442c-85f6-5cad71b31642">
        <updating/>
        <source>populateCombos() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation		Par 33268

*/

vars

	iter : Iterator;
	chassisType : CM_TILCType;
	gennyType : CM_GeneratorType;
	isoType : CM_ISOType;
	weighBridge : CM_WeighBridgeObj;

begin

	self.cmbWeighBridges.clear();
	self.cmbChassis.clear;
	self.cmbGenny.clear();
	
	//08 Jul 2019	NDL	TFS 44965
	weighBridge := self.myTerminal.allWeighBridges.getMyTwoReadingsWeighBridge();
	if weighBridge &lt;&gt; null then
		// default to 'TwoReadings' one if there is one
		self.setMyWeighBridge( weighBridge );
	endif;
	
	self.myAssistant.comboBoxWeighBridges( self.cmbWeighBridges, self.myTerminal, self.myWeighBridge );
	
	if self.myWeighBridge = null and self.cmbWeighBridges.listCount = 2 and self.cmbWeighBridges.listIndex &lt; 1 then
		self.cmbWeighBridges.listIndex := 2;
		self.setMyWeighBridge( self.cmbWeighBridges.listObject.CM_WeighBridgeObj);
	endif;
	if self.cmbWeighBridges.listIndex &lt; 1 then
		self.cmbWeighBridges.itemText[1] := app.getErrorString(No_Weigh_bridge_selected);
		self.cmbWeighBridges.listIndex := 1;
	endif;
	
	iter := app.myRoot.allTILCTypes.createIterator;
	self.cmbChassis.addItem( null );
	while iter.next( chassisType ) do
		if chassisType.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbChassis.itemObject[ self.cmbChassis.addItem( chassisType.description ) ] := chassisType;
	endwhile;
	delete iter;
	
	if self.myChassisType &lt;&gt; null then
		self.cmbChassis.listIndex := self.cmbChassis.findObject( self.myChassisType );	//22 Jul 2016	NDL	TFS 2331
	endif;
	
	iter := app.myRoot.allGeneratorTypes.createIterator;
	self.cmbGenny.addItem( null );
	while iter.next( gennyType ) do
		self.cmbGenny.itemObject[ self.cmbGenny.addItem( gennyType.description ) ] := gennyType;
	endwhile;
	delete iter;
	iter := app.myRoot.allISOTypes.createIterator;
	while iter.next( isoType ) do
		if not isoType.isGenerator then
			continue;
		endif;
		if isoType.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbGenny.itemObject[ self.cmbGenny.addItem( isoType.description ) ] := isoType;
	endwhile;
	delete iter;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="requestScaleWeight" id="aea375e1-10bc-4f60-9cf3-1affad007555">
        <updating/>
        <source>requestScaleWeight() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation		Par 33268

*/

vars

begin

	self.allowManualScaleEntry( false, null );	//11 Jul 2019	NDL	TFS 44965

	if self.myWeighBridge = null  then
		app.msgBox(app.getErrorString(No_Weigh_bridge_selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;	//should never get here
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// ### TFS 54311 25Oct2022 NAVPW1
	if self.myWeighBridge.isGenericScanAPI then
		//Get latest scan record
		self.myAssistant.getLatestScanRecord(self.tblScaleWeight);
		self.sendWeight(self.myAssistant.myCurrentGateScanRecord.scaleWeight);
		return;
	endif;
	// ### TFS 54311 25Oct2022 NAVPW1
	
	if self.myWeightController &lt;&gt; null and self.myWeightController.myConnection &lt;&gt; null  then			//has been set to trun in interface setup/ false when delete myTCPWeightInterfaceController
		self.myWeightController.closeConnection();					//to be sure that Connection is closed
		self.myWeightController.doOpen();
	endif;

epilog


	app.mousePointer := Window.MousePointer_Default;
	
	if self.tblScaleWeight.enabled then
		self.tblScaleWeight.setFocus();
	else
		self.txtReason.setFocus();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendWeight" id="41736407-0d49-4715-99d2-14e3030dab24">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_TCPWeightCallerInterface::sendWeight"/>
        </interfaceImplements>
        <updating/>
        <source>sendWeight(_newWeight : Decimal) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_TCPWeightCallerInterface interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2019	jlger1	Initial creation 44965

*/

vars

	msg : String;

begin
	
	//21 Dec 2020	NDL	TFS 50509
	if _newWeight &lt; 0 then
		msg := app.getErrorString1( Weigh_bridge_return_negati_wei, _newWeight.asStringJMT );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		return;
	endif;

	//weight is always returned in kgs set to the default weight
	self.tblScaleWeight.setValueDefault( _newWeight.String );
	
	self.updateScaleWeight(_newWeight);
epilog

end;</source>
        <Parameter name="_newWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="01c425c1-94cf-4d91-9feb-4137c22470c0">
        <updating/>
        <source>setBaseData( _objArray : ObjectArray; _tiId : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/03/2014	cnwndl1	Initial creation	Par 33268
15/08/2016	cnwdap1	TFS #2494 PEN Default Is certified if cargo type can be certified
01/11/2016	cnwma1	TFS #2886:PAR38305 PEN - Weigh Bridge Error
*/

vars

	obj : Object;
	isoType : CM_ISOType;
	msg : String;
	stackDump : CnStackDump;
	exObj : CM_Exception;
	cargoType : CM_CargoType;					// TFS #2494
	extraDebugText : String;
	dummyArray : ObjectArray;
	localWeighBridge : CM_WeighBridgeObj;	//26 Aug 2019	NDL TFS 46267

begin

//	self.setupControls();	//05 Aug 2019	NDL - found during testing.

	foreach obj in _objArray do
		if obj.isKindOf( CM_TILC ) then
			self.myChassis := obj.CM_TILC;
		elseif obj.isKindOf( CM_Generator ) then
			self.myGenerator := obj.CM_Generator;
		elseif obj.isKindOf( CM_Machine ) then
			self.myMachine := obj.CM_Machine;
		elseif obj.isKindOf( CM_Vehicle ) then
			self.myTruck := obj.CM_Vehicle;
		elseif obj.isKindOf( CM_VehicleVisitRecord ) then
			self.myVehicleVisitRecord := obj.CM_VehicleVisitRecord;
		elseif obj.isKindOf( CM_WeighBridgeObj ) then
			//self.setMyWeighBridge(  obj.CM_WeighBridgeObj);
			localWeighBridge := obj.CM_WeighBridgeObj;	//26 Aug 2019	NDL TFS 46267
		elseif obj.isKindOf( CM_TrackedItem ) then
			isoType := obj.CM_TrackedItem.getISOTypeObject;
			if isoType &lt;&gt; null and isoType.isGenerator then
				self.myGenerator := obj.CM_TrackedItem;
			else
				self.setMyTrackedItem (obj.CM_TrackedItem);
			endif;
		elseif obj.isKindOf( CMGTE_TILC ) then
			if obj.CMGTE_TILC.myTrackedItem &lt;&gt; null and obj.CMGTE_TILC.myTrackedItem.isChassis then
				self.myChassis := obj.CMGTE_TILC.myTrackedItem.CM_TILC;
			elseif obj.CMGTE_TILC.myTILCType &lt;&gt; null then
				self.myChassisType := obj.CMGTE_TILC.myTILCType;
			endif;
		elseif obj.isKindOf( CM_CargoType ) then
			self.myCargoType := obj.CM_CargoType;
		elseif obj.isKindOf( CM_Product ) then
			self.myProduct := obj.CM_Product;
		else
		endif;
	endforeach; 
	
	self.setupControls();	//26 Aug 2019	NDL TFS 46267 - moved down
	//26 Aug 2019	NDL TFS 46267
	if localWeighBridge &lt;&gt; null then
		self.setMyWeighBridge(  localWeighBridge );
	endif;
	
	if self.myTrackedItem = null then
		self.tiId := _tiId;
	endif;
	if self.myTruck &lt;&gt; null then
		self.txtTruck.text := self.myTruck.regNumber;
	endif;
		
	if self.myTrackedItem &lt;&gt; null then

	elseif self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( CMUI_ReceiveCargoForm ) then
		self.chkCertified.value := self.myParentForm.CMUI_ReceiveCargoForm.getIsWeightCertified; //epr tfs 2011 8/6/16
		if not self.chkCertified.value then																// TFS #2494
			if self.myParentForm.CMUI_ReceiveCargoForm.cmbISOType.visible then							// TFS #2494
				cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];						// TFS #2494
			elseif self.myParentForm.CMUI_ReceiveCargoForm.cmbType.getObject &lt;&gt; null then				// TFS #2494
				cargoType := self.myParentForm.CMUI_ReceiveCargoForm.cmbType.getObject.CM_CargoType;	// TFS #2494
			endif;																						// TFS #2494
			if cargoType &lt;&gt; null then																	// TFS #2494
				self.chkCertified.value := cargoType.canWeightBeCertified;								// TFS #2494
			endif;																						// TFS #2494
		endif;																							// TFS #2494
		
		//Re-instated 08 Jan 2018	NDL	TFS 36437
		if self.myTruck = null then  //TFS #2886 PAR #38305 
		
			if self.myVehicleVisitRecord &lt;&gt; null then
				create dummyArray transient;
				//'extraDebugText' will capture the reason that the truck was deemed not weighable.
				self.myVehicleVisitRecord.isWeighBridgeWeighable( dummyArray, extraDebugText );
			endif;
		
			msg := "No truck found during 'weigh' at gate." &amp; CrLf &amp; "Please wait while we create a log file for a developer..."; 
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
			create exObj transient;
			exObj.set(Debug_message, msg, true, null, null, null);
			create stackDump transient;
			stackDump.dumpStack(exObj);
			msg := "Thank you." &amp; CrLf &amp; "Please ask your administrator to raise a fault and attach the 'cn_dump_nnn[" &amp; Debug_message.String &amp; "].log' file that was just created.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
		endif;
		
	else
		self.chkCertified.value := false;
	endif;

epilog

	delete stackDump;
	delete exObj;
	delete dummyArray;

end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_tiId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setChassisWeightFromSelection" id="e5c4cdca-d2ee-4c2c-8fd5-7f433a49558c">
        <updating/>
        <source>setChassisWeightFromSelection( _weightType : CM_MeasurementType ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	chassisType : CM_TILCType;
	trailerTareKgs : Decimal [14,4]; 

begin
	
	if self.cmbChassis.listIndex &gt; 1 then
		// the user has selected an item in the combo
		obj := self.cmbChassis.itemObject[ self.cmbChassis.listIndex ];
		if obj &lt;&gt; null and obj.isKindOf( CM_TILCType ) then
			chassisType := obj.CM_TILCType;
		endif;
	endif;
		
	if chassisType &lt;&gt; null then
		trailerTareKgs := chassisType.tareWeight;
		if trailerTareKgs = 0 then
			trailerTareKgs := self.myTerminal.getConfig( DefWeightTrailer ).Decimal;
		endif;
		self.tblChassisTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, trailerTareKgs) &amp; Space &amp; _weightType.shortName);
		
	elseif self.myChassis &lt;&gt; null then
	//	if self.cmbChassis.itemText[1] &lt;&gt; self.myChassis.id then
		if self.cmbChassis.listCount &gt; 0 and ( self.cmbChassis.itemText[1] &lt;&gt; self.myChassis.id ) then	//23 Jan 2020	NDL	TFS 48271
			trailerTareKgs := self.myChassis.weightTare;
			if trailerTareKgs = 0 then
				trailerTareKgs := self.myTerminal.getConfig( DefWeightTrailer ).Decimal;
			endif;
			self.cmbChassis.itemText[1] := self.myChassis.id;
			self.cmbChassis.enabled := false;
			self.tblChassisTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, trailerTareKgs) &amp; Space &amp; _weightType.shortName);
		endif;
	else
		if self.cmbChassis.listCount &gt; 0 then
			self.cmbChassis.itemText[1] := null;
			self.tblChassisTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, 0) &amp; Space &amp; _weightType.shortName);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_weightType" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setExistingWtCaption" id="51d6a00d-18c9-4260-b67e-b01c598bc7b3">
        <source>setExistingWtCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

begin

	self.txtExistingWt.visible := self.myTrackedItem &lt;&gt; null;

	if self.myTrackedItem &lt;&gt; null then
		
		self.txtExistingWt.backColor := self.grpCargo.backColor;
		if self.myTrackedItem.isOnTruck then
			self.txtExistingWt.caption:= app.getErrorString(Cargo_on_truck) &amp; CrLf;
		else 
			self.txtExistingWt.caption:= app.getErrorString(Cargo_at_location) &amp; " " &amp; self.myTrackedItem.locationId &amp; CrLf;
		endif;
			
		self.txtExistingWt.caption := self.txtExistingWt.caption &amp; self.myTrackedItem.getDefaultTotalWeightDisplay() &amp; Tab;
		if self.myTrackedItem.isWeightCertified then
			self.txtExistingWt.caption := self.txtExistingWt.caption &amp; app.getErrorString(Certified);
		else
			self.txtExistingWt.caption := self.txtExistingWt.caption &amp; app.getErrorString(Not_certified);
	endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setGennyWeightFromSelection" id="b00790c0-2037-4fbb-8401-c1dfe67c68dc">
        <updating/>
        <source>setGennyWeightFromSelection( _weightType : CM_MeasurementType ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	gennyType : CM_GeneratorType;
	isoType : CM_ISOType;
	gennyKgs : Decimal [14,4]; 

begin

	if self.cmbGenny.listIndex &gt; 0 then
		obj := self.cmbGenny.itemObject[ self.cmbGenny.listIndex ];
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_GeneratorType ) then
				gennyType := obj.CM_GeneratorType;
			elseif obj.isKindOf( CM_ISOType ) then
				isoType := obj.CM_ISOType;
			endif;
		endif;
	endif;
	if gennyType &lt;&gt; null then
		gennyKgs := gennyType.defaultWeight;
		self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, gennyKgs) &amp; Space &amp; _weightType.shortName);
	elseif isoType &lt;&gt; null then
		gennyKgs := isoType.tareKilos;
		self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, gennyKgs) &amp; Space &amp; _weightType.shortName);
	elseif self.myGenerator &lt;&gt; null then
		gennyKgs := self.myGenerator.totalWeight;
		if gennyKgs = 0 then
			if self.myGenerator.CM_Generator.myGeneratorType &lt;&gt; null then
				gennyKgs :=  self.myGenerator.CM_Generator.myGeneratorType.defaultWeight;
			endif;
		endif;
		if self.cmbGenny.itemText[1] &lt;&gt; self.myGenerator.id then
			self.cmbGenny.itemText[1] := self.myGenerator.id;
			self.cmbGenny.enabled := false;
			self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, gennyKgs) &amp; Space &amp; _weightType.shortName);
		endif;
	else
		if self.cmbGenny.listCount &gt; 0 then
			self.cmbGenny.itemText[1] := null;
			self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(_weightType.shortName, 0) &amp; Space &amp; _weightType.shortName);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_weightType" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9920ed2d-a777-4045-b0c3-cef5902483be">
        <updating/>
        <source>setMyTrackedItem(_ti  : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.endNotification( self.myTrackedItem, Any_System_Event );		
	endif;
	
	self.myTrackedItem:=_ti;
	if self.myTrackedItem &lt;&gt; null then
		
		self.chkCertified.value := self.myTrackedItem.isWeightCertified;
		self.txtCargo.text := self.myTrackedItem.id;
		self.setExistingWtCaption();
	/*	self.txtExistingWt.visible := true;
		self.txtExistingWt.backColor := self.grpCargo.backColor;
		if self.myTrackedItem.isOnTruck then
			self.txtExistingWt.caption:= app.getErrorString(Cargo_on_truck) &amp; CrLf;
		else 
			self.txtExistingWt.caption:= app.getErrorString(Cargo_at_location) &amp; " " &amp; self.myTrackedItem.locationId &amp; CrLf;
		endif;
			
		self.txtExistingWt.caption := self.txtExistingWt.caption &amp; self.myTrackedItem.getDefaultTotalWeightDisplay() &amp; Tab;
		if self.myTrackedItem.isWeightCertified then
			self.txtExistingWt.caption := self.txtExistingWt.caption &amp; app.getErrorString(Certified);
		else
			self.txtExistingWt.caption := self.txtExistingWt.caption &amp; app.getErrorString(Not_certified);
		endif; */
		
		self.beginNotification( self.myTrackedItem, Any_System_Event, Response_Continuous, 0 );
		
		self.setupControls();
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyWeighBridge" id="88b77293-1f91-43c5-b644-8342b7d7e237">
        <updating/>
        <source>setMyWeighBridge(_weighBridge : CM_WeighBridgeObj) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 May 2019		jlger1	Initial creation 44965
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	weightIntefaceClass : Class;
	allTIs : CM_TISet;
	detailsChangeVehicle	: Boolean;

begin
	
	if self.myWeighBridge &lt;&gt; _weighBridge then
		self.myWeighBridge := _weighBridge;
		
		if self.myWeightController &lt;&gt; null then
			delete self.myWeightController;
		endif;
		
		if self.myWeighBridge &lt;&gt; null then
			weightIntefaceClass:=self.myWeighBridge.myWeighBridgeType.getWeightInterfaceClass;
			
			if weightIntefaceClass &lt;&gt; null then
				create self.myWeightController as weightIntefaceClass transient;
				self.myWeightController.setWeightCallerInterface(self.IF_TCPWeightCallerInterface);
				self.myWeightController.initializeWithWeighbridge(self.myWeighBridge);
			endif;
		endif;
		
		self.lblLastReading.visible:=false;
		self.allowManualScaleEntry( false, null);
		self.calculate( true, self.tblScaleWeight );
		
		//11 Jul 2019	NDL	TFS 44965
		if self.myWeighBridge &lt;&gt; null then
			self.lblManual.visible := false;
			self.txtPlusMinus.visible := false;
			self.tblAdjustmentW.visible := false;
			self.txtReason.visible := false;	//07 Aug 2019	NDL TFS 45944
		else
			//07 Aug 2019	NDL TFS 45944
			self.lblManual.visible := true;
			self.txtPlusMinus.visible := true;
			self.tblAdjustmentW.visible := true;
			self.txtReason.visible := true;
		endif;
		
		if self.myWeighBridge = null or self.myWeighBridge.isSingleReading then
		
			//enable fields;
			self.tblMachineTareW.enabled := true;
			self.tblTruckTareW.enabled := true;
			self.tblChassisTareW.enabled := true;
			self.tblGennyTareW.enabled := true;
			self.tblCargoTotalW.enabled := true;
			
			self.cmbChassis.enabled := true;
			self.cmbGenny.enabled := true;
			
			if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.isGenericScanAPI then
				// TFS 52777 Generic API /Gate Scan Data
				self.myAssistant.allAssociatedDevices.clear();
				self.myAssistant.allAssociatedDevices.putAtKey(self.myWeighBridge.deviceId, self.myWeighBridge);
				
				self.tblScaleWeight.enabled := true;
				self.myAssistant.populateScanData(false, false, detailsChangeVehicle, null, null, null, null, null, null, null, self.tblScaleWeight, null);
				self.tblScaleWeight.enabled := false;
			endif;
			
		elseif self.myWeighBridge.isTwoReadings then
		
			//disable fields
			self.tblMachineTareW.enabled := false;
			self.tblTruckTareW.enabled := false;
			self.tblChassisTareW.enabled := false;
			self.tblGennyTareW.enabled := false;
			self.tblCargoTotalW.enabled := false;
			
			self.cmbChassis.enabled := false;
			self.cmbGenny.enabled := false;
			
			if self.myVehicleVisitRecord &lt;&gt; null then
				self.lblLastReading.visible:=true;
				self.lblLastReading.left :=self.tblScaleWeight.left + self.tblScaleWeight.clientWidth + 10;
				if self.myVehicleVisitRecord.hasWeighInVVRD then									
					self.lblLastReading.caption:=app.getErrorString1(Last_weight_reading, app.getWeightForDefaultDisplay(self.myVehicleVisitRecord.getWeighBridgeWeight(VisitRecord_WeighBridgeIn)));
				else
					self.lblLastReading.caption:=app.getErrorString(No_Prior_reading);
				endif;
				
				if self.myTrackedItem = null then
					create allTIs transient;
					if  self.myVehicleVisitRecord.isOnlyReceivingCargo then
					
						self.myVehicleVisitRecord.getReceivedCargoInYard(allTIs);
						if allTIs.size = 1 then
							self.setMyTrackedItem(allTIs.first);
						endif;
					elseif self.myVehicleVisitRecord.isOnlyReleasingCargo then
						 self.setMyTrackedItem( self.myVehicleVisitRecord.allReleasedTrackedItems.first);
						
					endif;
				endif;
				
			endif;
		endif;
		
	endif;
epilog
	delete allTIs;
end;</source>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="setTareWeights" id="2c575706-133f-49f0-ad10-13201195a7ee">
        <updating/>
        <source>setTareWeights() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation		Par 33268

*/

vars

	weightType : CM_MeasurementType;
	obj : Object;
	truckTareKgs : Decimal [14,4]; 
	trailerTareKgs : Decimal [14,4]; 

begin
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	
	if self.myTruck &lt;&gt; null then
		if self.txtTruck.text &lt;&gt; self.myTruck.regNumber then
			self.txtTruck.text := self.myTruck.regNumber;
			truckTareKgs := self.myTruck.tareKilos;
			if truckTareKgs = 0 then
				truckTareKgs := self.myTerminal.getConfig( DefWeightTruck ).Decimal;
			endif;
			self.tblTruckTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, truckTareKgs) &amp; Space &amp; weightType.shortName);
		endif;
	else
		self.txtTruck.text := null;
		self.tblTruckTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, 0) &amp; Space &amp; weightType.shortName);
	endif;
	
	self.setChassisWeightFromSelection( weightType );
	
	self.setGennyWeightFromSelection( weightType );
	
	
	if self.myMachine &lt;&gt; null then
		if self.txtMachine.text &lt;&gt; self.myMachine.id then
			self.txtMachine.text := self.myMachine.id;
			self.tblMachineTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, self.myMachine.tareWeight) &amp; Space &amp; weightType.shortName);
		endif;
	else
		self.txtMachine.text := null;
		self.tblMachineTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, 0) &amp; Space &amp; weightType.shortName);
	endif;
	
	if self.tiId.trimBlanks &lt;&gt; null then
		self.txtCargo.text := self.tiId.trimBlanks;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setVVRWeighingProxy" id="a03a3ae5-2ed9-4f51-8799-8049e6246054">
        <source>setVVRWeighingProxy( _proxy : CM_VehicleVisitWeighing input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268	

*/

vars

	adjustmentIsAddingWeight : Boolean;
	adjustmentReason : String;
	chassisName : String;
	generatorName : String;
	cargoType : CM_CargoType;
	generator : CM_Generator;
	generatorType : CM_GeneratorType;
	isoType : CM_ISOType;
	product : CM_Product;
	trackedItem : CM_TrackedItem;
	trailer : CM_TILC;
	chassisType : CM_TILCType;
	vehicle : CM_Vehicle;
	weighBridge : CM_WeighBridgeObj;
	tiId : String;
	vehicleName : String;
	weighBridgeName : String;
	weighFromWeightBridge : Decimal [16,4];
	weightAdjustment : Decimal [16,4];
	weightCargo : Decimal [16,4];
	weightChassis : Decimal [16,4];
	weightGenerator : Decimal [16,4];
	weightIsCertified : Boolean;
	weightVehicle : Decimal [16,4];
	scaleMeasureType : CM_MeasurementType;
			
begin

	
	
	weightCargo := tblCargoTotalW.getConvertedValue;
	weightChassis := self.tblChassisTareW.getConvertedValue;
	weightGenerator := self.tblGennyTareW.getConvertedValue;
	if self.chkCertified.visible then
		weightIsCertified := self.chkCertified.value;
	endif;
	weightVehicle := self.tblTruckTareW.getConvertedValue;
	
	
	
	
	weighFromWeightBridge := self.tblScaleWeight.getConvertedValue;
	scaleMeasureType := self.tblScaleWeight.getMeasurementType;
	weighBridge := self.cmbWeighBridges.listObject.CM_WeighBridgeObj;
	weighBridgeName := self.cmbWeighBridges.text;
	
	weightAdjustment := self.tblAdjustmentW.getConvertedValue;
	if weightAdjustment &gt; 0 then
		adjustmentIsAddingWeight := (self.txtPlusMinus.text = self.AddingWeight);
		adjustmentReason := self.txtReason.text.trimBlanks;
	else
		adjustmentIsAddingWeight := true;
		if self.tblScaleWeight.enabled then	//10 Jul 2019	NDL	TFS 44965
			adjustmentReason := self.txtReason.text.trimBlanks;
		else
			adjustmentReason := null;
		endif;
	endif;
	
	if self.myTruck &lt;&gt; null then
		vehicle := self.myTruck;
		vehicleName := vehicle.regNumber;
	else
		vehicle := null;
		vehicleName := null;
	endif;
	
	if self.myChassis &lt;&gt; null then
		trailer := self.myChassis;
		chassisType := null;
		chassisName := self.myChassis.id;
	elseif self.cmbChassis.listObject &lt;&gt; null and self.cmbChassis.listObject.isKindOf(CM_TILCType) then
		trailer := null;
		chassisType := self.cmbChassis.listObject.CM_TILCType;
		chassisName := chassisType.description;
	else
		trailer := null;
		chassisType := null;
		chassisName := null;
	endif;
	
	if self.myGenerator &lt;&gt; null then
		generator := self.myGenerator.CM_Generator;
		generatorType := null;
		isoType := null;
		generatorName := self.myGenerator.id;
	elseif self.cmbGenny.listObject &lt;&gt; null and self.cmbGenny.listObject.isKindOf(CM_GeneratorType) then
		generator := null;
		generatorType := self.cmbGenny.listObject.CM_GeneratorType;
		isoType := null;
		generatorName := generatorType.description;
	elseif self.cmbGenny.listObject &lt;&gt; null and self.cmbGenny.listObject.isKindOf(CM_ISOType) then
		generator := null;
		generatorType := null;
		isoType :=  self.cmbGenny.listObject.CM_ISOType;
		generatorName := isoType.description;
	else
		generator := null;
		generatorType := null;
		isoType := null;
		generatorName := null;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
		cargoType := null;
		product := null;
		tiId := self.myTrackedItem.id;
	elseif self.myCargoType &lt;&gt; null then
		trackedItem := null;
		cargoType := self.myCargoType;
		product := null;
		tiId := self.txtCargo.text.trimBlanks;
	elseif self.myProduct &lt;&gt; null then
		trackedItem := null;
		cargoType := null;
		product := self.myProduct;
		tiId := self.txtCargo.text.trimBlanks;
	else
		trackedItem := null;
		cargoType := null;
		product := null;
		tiId := self.txtCargo.text.trimBlanks;
	endif;

	_proxy.setProxy(	adjustmentIsAddingWeight,	//_adjustmentIsAddingWeight : Boolean;
						adjustmentReason,	//_adjustmentReason : String;
						chassisName,	//_chassisName : String;
						generatorName,	//_generatorName : String;
						cargoType,	//_myCargoType : CM_CargoType;
						generator,	//_myGenerator : CM_Generator;
						generatorType,	//_myGeneratorType : CM_GeneratorType;
						isoType,	//_myISOType : CM_ISOType;
						product,	//_myProduct : CM_Product;
						trackedItem,	//_myTrackedItem : CM_TrackedItem;
						trailer,	//_myTrailer : CM_TILC;
						chassisType,	//_myChassisType : CM_TILCType;
						vehicle,	//_myVehicle : CM_Vehicle;
						weighBridge,	//_myWeighBridge : CM_WeighBridgeObj;
						tiId,	//_tiId : String;
						vehicleName,	//_vehicleName : String;
						weighBridgeName,	//_weighBridgeName : String;
						weighFromWeightBridge,	//_weighFromWeightBridge : Decimal;
						weightAdjustment,	//_weightAdjustment : Decimal;
						weightCargo,	//_weightCargo : Decimal;
						weightChassis,	//_weightChassis : Decimal;
						weightGenerator,	//_weightGenerator : Decimal;
						weightIsCertified,	//_weightIsCertified : Boolean;
						weightVehicle,	//_weightVehicle : Decimal;
						scaleMeasureType //_weighingMeasurementType : CM_MeasurementType
						);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleVisitWeighing" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="3797fcec-ec09-47b2-8774-8b0970f83393">
        <updating/>
        <source>setupControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation		Par 33268

*/

vars
	topIndex : Real;
begin

	self.btnOk.visible := false;

	self.grpMain.left := 0;
	self.grpMain.top := 0;
	self.grpMain.borderStyle := 0;
	topIndex := 1;
	
	self.grpScale.top := topIndex;
	self.grpScale.borderStyle := 0;
	topIndex := topIndex + self.grpScale.height + 10;
	
	if self.myTruck = null and self.myChassis = null and self.myGenerator = null then
		self.grpTruck.visible := false;
	else
		self.grpTruck.top := topIndex;
		self.grpTruck.borderStyle := 0;
		self.grpTruck.visible := true;
		topIndex := topIndex + self.grpTruck.height + 10;
	endif;
	if self.myMachine = null then
		self.grpMachine.visible := false;
	else
		self.grpMachine.top := topIndex;
		self.grpMachine.borderStyle := 0;
		self.grpMachine.visible := true;
		topIndex := topIndex + self.grpMachine.height + 10;
	endif;
	
	self.chkCertified.visible := false;
	if self.myTrackedItem = null and ( ( self.myCargoType = null and self.myProduct = null ) or self.tiId.trimBlanks = null ) then
		self.grpCargo.visible := false;
		self.chkCertified.value := false;
	else
		self.grpCargo.top := topIndex;
		self.grpCargo.borderStyle := 0;
		self.grpCargo.visible := true;
		topIndex := topIndex + self.grpCargo.height + 10;
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType &lt;&gt; null then
			if self.myTrackedItem.myCargoType.canWeightBeCertified then
				self.chkCertified.visible := true;
			endif;
		elseif self.myCargoType &lt;&gt; null then
			if self.myCargoType.canWeightBeCertified then
				self.chkCertified.visible := true;
			endif;
		elseif self.myProduct &lt;&gt; null and self.myProduct.myCargoType &lt;&gt; null  then
			if self.myProduct.myCargoType.canWeightBeCertified then
				self.chkCertified.visible := true;
			endif;
		else
			self.chkCertified.value := false;
		endif;
	endif;
	self.grpMain.height := topIndex;
	
	self.width := self.grpMain.width + 25;
	self.height := topIndex + 80;
	
	self.grpMain.parentAspect := 3;
	self.minimumWidth := self.width.Integer;
	self.minimumHeight := self.height.Integer;
	
	self.tblScaleWeight.setup(Type_Weight, self.backColor);
	self.tblScaleWeight.tabKey := J_key_Tab;
	self.tblScaleWeight.visible := true;
	
	self.tblTruckTareW.setup(Type_Weight, self.backColor);
	self.tblTruckTareW.tabKey := J_key_Tab;
	self.tblTruckTareW.visible := true;
	
	self.tblChassisTareW.setup(Type_Weight, self.backColor);
	self.tblChassisTareW.tabKey := J_key_Tab;
	self.tblChassisTareW.visible := true;
	
	self.tblGennyTareW.setup(Type_Weight, self.backColor);
	self.tblGennyTareW.tabKey := J_key_Tab;
	self.tblGennyTareW.visible := true;
	
	self.tblMachineTareW.setup(Type_Weight, self.backColor);
	self.tblMachineTareW.tabKey := J_key_Tab;
	self.tblMachineTareW.visible := true;
	
	self.tblAdjustmentW.setup(Type_Weight, self.backColor);
	self.tblAdjustmentW.tabKey := J_key_Tab;
	self.tblAdjustmentW.visible := true;
	self.lblManual.visible := true;	//11 Jul 2019	NDL	TFS 44965
	self.txtPlusMinus.visible := true;	//11 Jul 2019	NDL	TFS 44965
	
	self.tblCargoTotalW.setup(Type_Weight, self.backColor);
	self.tblCargoTotalW.tabKey := J_key_Tab;
	self.tblCargoTotalW.visible := true;
	
	//epr TFS 44965 3/7/19
	self.tblCargoTotalW.enabled := false;
	self.txtExistingWt.visible:=self.myTrackedItem &lt;&gt; null;
	self.lblLastReading.left :=self.tblScaleWeight.left + self.tblScaleWeight.clientWidth + 10;
	
	//11 Jul 2019	NDL	TFS 44965
	if self.myWeighBridge &lt;&gt; null then
		self.lblManual.visible := false;
		self.txtPlusMinus.visible := false;
		self.tblAdjustmentW.visible := false;	
	endif;
	
epilog

	self.calculate( true, null );

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="300d28f9-70bb-4e5a-85ea-b68015bdebae">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/03/2014	cnwndl1	Initial creation	Par 33268
01/08/2019	jlgdap1	TFS 45928 JMT Road Gate Error 14058 when clicking Total Weight button
						populateCombos was changed to call setMyWeighBridge, which eventually
						attempted to set measurement table that hadn't been set up yet (happens in
						setupControls). Reversed the order of these two method calls
*/

vars
	
begin

	self.handleMenusForModalDisplay();
	if self.myTerminal = null then
		self.myTerminal := app.getMyTerminalDO_NOT_USE;
	endif;

	inheritMethod();
	
	self.centreOverParent(1);
	
	self.setupControls();					// TFS 45928
	self.populateCombos();
	//self.setupControls();					// TFS 45928
	
	self.btnCancel.caption := app.getErrorString( Close );
	
	if self.myWeighBridge &lt;&gt; null then
		self.setupWeighButton();
		if self.myWeighBridge.autoRequest then
			self.beginTimer( 100, Timer_OneShot, self.TimerWeighRequest );
		endif;
	endif;
	
	self.beginClassNotification(CM_GenericGateScanRecord, false, Any_System_Event, Response_Continuous, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupWeighButton" id="6356bf50-5db2-4c3b-a84d-9491b92c33e7">
        <source>setupWeighButton();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars

begin
	if self.myWeighBridge = null then
		self.btnWeigh.visible := false;
	else
		if self.myWeighBridge.isGenericScanAPI then
			//self.btnWeigh.visible := false;		// TFS 52777
			self.btnWeigh.visible := true;			// ### TFS 54311 25Oct2022 NAVPW1
		else
			self.btnWeigh.visible := true;
		endif;
	endif;

epilog

end;</source>
