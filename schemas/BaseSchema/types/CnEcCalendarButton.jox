<GUIClass name="CnEcCalendarButton" id="84e36bf1-df30-4a91-a4db-77e990d431c9">
    <superclass name="Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
