    <JadeMethod name="csvAudit" id="0fb1b27b-42d1-4918-991a-cbe7d17b9294">
        <source>csvAudit(_audit : CM_FinAuditRateHistory; _serv : CM_Service; _quald : Boolean; _debtor : CM_DebtorNode; _defaultDebtor : CM_DebtorNode; _bank : CM_Bank) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwrd1	Initial creation
7 Sept 2010		cnwjre1 from qual, don't output rate values with separators and use 3 decimal places to match the screens
*/
vars
	aRE, dRE : CM_RateEntry;
	aRate : CM_Rate;
	oldR, newR, pcR : Real;
	decPlaces : Integer;
	isNew	: Boolean;
	dName : String;
	result : String;
	code,
	user,
	defRate,
	oldRate,	
	newRate,
	changed,
	edited,
	effective,
	debtorName,
	serviceName : String;
begin
	
	if _audit.isDeleted then
		return '';
	endif;

	if _debtor.isKindOf(CM_Debtor) then
		code := _debtor.CM_Debtor.decfinName;
	else
		code := null;
	endif;
	if _debtor.name = "RDG" then
		debtorName := "RDG";
	else
		debtorName := _debtor.remarks;
	endif;

	isNew := (_audit.status = CM_FinAuditRateHistory.Status_Create);
	aRE := _audit.getRateEntryObject(true);
	oldR := _audit.previousCost;
	newR := _audit.newCost;
	pcR := 100;
	if oldR &lt;&gt; 0 then
		pcR := (((newR/oldR) - 1) * 100);
	endif;
	
	dName := _debtor.name.removeTabCrLfs();
	
	if not _quald then
		dName := "U " &amp; dName;
	endif;
	decPlaces := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;
	
	if aRE &lt;&gt; null then
		user := aRE.userId;
		edited := _audit.createdTime.date.shortFormatJMT() &amp; " " &amp; _audit.createdTime.time.shortFormatJMT;
		effective := aRE.startTimestamp.date.shortFormatJMT() &amp; " " &amp; aRE.startTimestamp.time.shortFormatJMT();
		defRate := null;
		if _defaultDebtor &lt;&gt; null then
			aRate := _defaultDebtor.serviceRates[_serv];
			dRE := aRate.getTimeRate(_bank,aRE.startTimestamp);
			if dRE &lt;&gt; null then
				defRate := dRE.getDerivedCostPerUnit(aRE.startTimestamp).asStringJMTWithPrecision(decPlaces, false);
			endif;
		endif;
	else
		defRate := null;
		user := _audit.userId;
		edited := _audit.createdTime.date.shortFormatJMT() &amp; " " &amp; _audit.createdTime.time.shortFormatJMT;
		effective := null;
	endif;
	newRate  := newR.asStringJMTWithPrecision(decPlaces, false);
	// TFS 2069 don't show old rate as zero for consistency with new rates
	if oldR = 0 then
		oldRate := "";
	else
		oldRate := oldR.asStringJMTWithPrecision(decPlaces, false);
	endif;
	// TFS 2069 percentage doesn't mean much when either old or new rate is zero, don't extract it then
	if oldR = 0 or newR = 0 then
		changed := "";
	else
		changed := pcR.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, false);
	endif;
	serviceName :=  _serv.name;

	result := dName &amp; ',' &amp; code &amp; ',"' &amp; serviceName &amp; '",' &amp; defRate &amp; ',' &amp;  oldRate &amp; ',' &amp;  newRate &amp; ',' &amp; changed &amp; ',' &amp; user &amp; ',' &amp; edited &amp; ',' &amp; effective;
	
	return result;

epilog

end;</source>
        <Parameter name="_audit" type="CM_FinAuditRateHistory"/>
        <Parameter name="_serv" type="CM_Service"/>
        <Parameter name="_quald" type="Boolean"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_defaultDebtor" type="CM_DebtorNode"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfo" id="b78caf91-92b3-4a6a-8155-c9134d478427">
        <source>displayExtraInfo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	rateEntry : CM_RateEntry;
	dataContainer : CM_DataContainer;

begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	if self.mnuContextHide.caption = self.MNU_MACRO_SHOW then
		return;
	endif;
	
	rateEntry := self.tblData.accessedRow.itemObject.CM_RateEntry;
	
	if rateEntry &lt;&gt; null then
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
			
		rateEntry.getExtraInfo(dataContainer);
	endif;
	
	if dataContainer &lt;&gt; null then
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;
	
epilog

	delete dataContainer;
	
end;</source>
    </JadeMethod>
