    <JadeMethod name="setProxy" id="8d46e525-5029-4b41-8787-056ff3bfeda6">
        <updating/>
        <source>setProxy(_structure: CM_ROROVoyageStructure; _code: String; _desc: String; _remarks: String; _deckItemLayout: CM_DeckItemLayout; _deck: CM_Deck; _width: Decimal; _len: Decimal; _gap: Decimal; _ordinal: Integer; _deckLayerLayout: CM_DeckLayerLayout) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_structure, _code, _desc, _remarks, _deckItemLayout, _deck, _width, _len, _gap, _ordinal, _deckLayerLayout);
	
	self.myVoyageStructure := _structure;
	
	self.createLaneController();
epilog

end;</source>
