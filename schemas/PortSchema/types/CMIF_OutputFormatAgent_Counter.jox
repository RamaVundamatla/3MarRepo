    <JadeMethod name="setup_CapacityTable" id="64ec1bcd-b34f-4e68-8521-09e0d8971711">
        <source>setup_CapacityTable()protected;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd :DynaDictionary;
begin
	// keep track of all shifts/work points to display in the table
	// we will use this to display column headings
	dd := self.allColumnHeadings;
	
	if dd.isValid then
		dd.clear;
		dd.clearKeys;
	endif;
	
	dd.setMembership (CM_Object);						// deck/bay
	
	dd.addExternalKey (Integer, null, false, null);		// 1 = deck, 2 = bay
	dd.addExternalKey (String, 100, false, true);		// deck/bay code
	
	dd.endKeys (false);
	
	// now the collection to keep track of container KPI
	dd := self.allData_Containers;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);	// will be array containing discharge/load/dlr/sob/ts
	
	dd.addExternalKey (Integer, null, false, true);						// Length
	dd.addExternalKey (CM_Object, null, false, null);					// bay/deck
	
	dd.endKeys (false);
	
	// now the collection to keep track of general cargo KPI
	dd := self.allData_GeneralCargo;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);		// will be array of objectsets (membership CM_KPIVoyageMoveDtl) with one entry for discharge/load/dlr/sob/ts
	dd.addExternalKey (CM_CargoType, null, false, true);				// Cargo type
	dd.addExternalKey (CM_Object, null, false, null);					// bay/deck

	dd.endKeys (false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="unitTestGetNumbers" id="a13df036-fb78-4ad2-a0bb-2e76cce3b2ef">
        <updating/>
        <source>unitTestGetNumbers(_voyage :CM_Voyage;  _isActual :Boolean; 
						_contCount, _contTEU, _gcCount, _gcArea, _gcLM, _gcQty, _gcVolume, _gcWeight :Boolean;
						_cargoTypes :Collection; _doDelete : Boolean)updating;
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/
vars
	terminal	:CM_Terminal;
	showCont	:Boolean;					// PAR #35397
begin
	if _doDelete then
		self.allData_Containers.purge;
		self.allData_GeneralCargo.purge;
		return;
	endif;
	self.myVoyage	:= _voyage;
	terminal		:= _voyage.getMyTerminal;
	setup_CapacityTable();
	
	self.allCargoTypes.clear;
	_cargoTypes.copy (self.allCargoTypes);
	if self.allCargoTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then	// PAR #35397
		showCont := true;																		// PAR #35397
	endif;																						// PAR #35397
	
	self.mode		:= self.Mode_CapacityTable;
	self.isActual	:= _isActual;
	
	self.is30Included	:= terminal.getConfig (Is30IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is45Included	:= terminal.getConfig (Is45IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is53Included	:= terminal.getConfig (Is53IncludedForReports).Integer;	// par 30290 Sept 2012
	
	self.createData_CapacityTable (_voyage, _isActual);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isActual" type="Boolean"/>
        <Parameter name="_contCount" type="Boolean"/>
        <Parameter name="_contTEU" type="Boolean"/>
        <Parameter name="_gcCount" type="Boolean"/>
        <Parameter name="_gcArea" type="Boolean"/>
        <Parameter name="_gcLM" type="Boolean"/>
        <Parameter name="_gcQty" type="Boolean"/>
        <Parameter name="_gcVolume" type="Boolean"/>
        <Parameter name="_gcWeight" type="Boolean"/>
        <Parameter name="_cargoTypes" type="Collection"/>
        <Parameter name="_doDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCellCollection" id="e652ab4f-1e6a-4af8-b912-274bf14f1d51">
        <source>updateCellCollection(_table :Table input; _coll :Collection)protected;
/*
Date		Who		Reason
01 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	obj		:Object;
	coll	:Collection;
begin
	if _coll = null or _coll.size = 0 then 
		return;
	endif;
	
	obj := _table.accessedCell.itemObject;
	
	if obj = null then
		create coll as CM_TISet transient;
		
		_table.accessedCell.itemObject := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
				
	elseif obj.isKindOf (CM_TISet) then
		coll := obj.CM_TISet;
	endif;

	if coll = null then
		// should not happen :-)
		return;
	endif;
	
	_coll.copy (coll);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
</Class>
