    <JadeMethod name="create" id="e80d5c3a-2e57-4fab-8316-cdced85649cf">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:			26 March 2001 by cnwdwq1
// Purpose:			Create the role visibility object
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isTransient then 
		return;
	endif;
	if self.class = CM_SecurityRole then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This is now an abstract class');
		return;
	endif;
	create self.mySecurityRoleVisibility persistent;
end;</source>
    </JadeMethod>
