    </JadeMethod>
    <JadeMethod name="utlUpdateROROGraphics" id="81a8081d-1b3b-4902-a07a-b21fb2de728c">
        <updating/>
        <source>utlUpdateROROGraphics(pProxyROROVesselStructure:CM_ROROStructure; _passport : CM_Passport input) updating;

vars
	cancelSave,aOK:Boolean;
	realRORODefn : CM_ROROStructure;
	expectedEdition:Integer;
	pxyGraphic,realGraphic : CM_Graphic;
	theObjects:	ObjectSet;
	pxyDeck, realDeck : CM_ShipDeck;
	pxyLayer, realLayer : CM_ShipDeckLayer;
	tmpObj, tmpObj2 : Object;
	
begin
	
	// #####################
	// ROROVesselStructure GRAPHICS
	realRORODefn := pProxyROROVesselStructure.pxyGetRealObject();
	self.utlUpdateShipDecksForDefn(pProxyROROVesselStructure.allShipDecks, realRORODefn.allShipDecks, _passport);

	foreach tmpObj in pProxyROROVesselStructure.allShipDecks discreteLock do
		pxyDeck := tmpObj.CM_ShipDeck;
		realDeck := pxyDeck.pxyGetRealObject();
		// NOTE even created layers have a proxy copy link made in utlUpdateShipDeckLayersForDefn
		self.utlUpdateShipDeckLayersForDefn(pxyDeck.allDeckLayers, realDeck.allDeckLayers, _passport);
	
		foreach tmpObj2 in pxyDeck.allDeckLayers discreteLock do
			pxyLayer := tmpObj2.CM_ShipDeckLayer;
			realLayer := pxyLayer.pxyGetRealObject();
			
			/*
			if realLayer = null then
				realLayer := realDeck.allDeckLayers[pxyDeck.allDeckLayers.indexOf(pxyLayer)].CM_ShipDeckLayer;
			endif;
			*/
			self.utlUpdateROROGraphicDeck(pxyLayer, realLayer, _passport);
		endforeach;
		
		realDeck.matchOrderOfLayers(pxyDeck.allDeckLayers);
	endforeach;
	

epilog
	
end;</source>
        <Parameter name="pProxyROROVesselStructure" type="CM_ROROStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROLayerQuickDraw" id="90dc674b-0d41-47c8-b1de-ebc366cd3dd9">
        <updating/>
        <source>utlUpdateROROLayerQuickDraw(_pxyLayer:CM_DeckLayerLayout input;_startX, _startY : Integer; _numRows, _numCol : Integer; 
										_horiz : Boolean; _polytype : Integer; _scale : Decimal; 
										_newDeckItems : ObjectArray input;  _passport : CM_Passport input) updating;

vars
	_realDeckLayout : CM_DeckLayerLayout;
begin
	_pxyLayer.createPxyQuickDrawPolyArray(_startX, _startY,_numRows, _numCol, _horiz , _polytype, _scale, _newDeckItems );
	
	_realDeckLayout := _pxyLayer.pxyGetRealObject();
	_realDeckLayout.setForCreateImport(_pxyLayer,app.myPassport);

	
	_realDeckLayout.myDeckLayout.myDeck.setLabelsOnAllLocations();
	_realDeckLayout.myDeckLayout.myDeck.setLabelsOnAllLanes();

epilog
	
end;</source>
