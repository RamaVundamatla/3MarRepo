    <JadeMethod name="comboBoxRFIDTag" id="69de5c0c-ffc3-4d64-bcb5-e63749888285">
        <source>comboBoxRFIDTag(_cmb : ComboBox input; _terminal : CM_Terminal; _tag : CM_RFIDTag input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	rfidTag  : CM_RFIDTag;
	
begin
	_cmb.clear();
	_cmb.sorted := true;
	
	
		
	// can't assign tag to road job if is not available for entry or another vehicle has the rfid tag
	//_cmb.addItem(null);
	foreach rfidTag in _terminal.allRFIDTagsByCode do
		if (not rfidTag.isAvailable()) then
			if rfidTag &lt;&gt; _tag then
				continue;
			endif;
		
		endif;
		if _tag = null then
			if rfidTag.myMachine &lt;&gt; null or rfidTag.myRoadJob &lt;&gt; null then
				continue;
			endif;
		else
			if rfidTag.myMachine &lt;&gt; null then
				if _tag.myMachine &lt;&gt; rfidTag.myMachine then
					continue;
				endif;
			elseif  rfidTag.myRoadJob &lt;&gt; null then
				if _tag.myRoadJob &lt;&gt; rfidTag.myRoadJob then
					continue;
				endif;
			endif;
		endif;
		_cmb.itemObject[_cmb.addItem(rfidTag.code)] := rfidTag;
	endforeach;

	if _cmb.findObject(_tag) &gt; 0 then
		_cmb.listObject := _tag;
	endif;
	
epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_tag" type="CM_RFIDTag" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRFIDTagReaderContext" id="9de3d0a9-3853-4cbc-8224-400177cac328">
        <source>comboBoxRFIDTagReaderContext(_cmb : CMUI_ComboBox input; _context : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
11/09/2009	cnwcs5		ccms1061 - removed gate lane tag reader context
*/
vars
	tagReader		: CM_RFIDTagReader;
begin
	_cmb.clear();
	_cmb.sorted := false;
	
	_cmb.itemData[_cmb.addItem(TagReaderContext_Machine_Str)] := TagReaderContext_Machine;
	_cmb.itemData[_cmb.addItem(TagReaderContext_WindowsPC_Str)] := TagReaderContext_WindowsPC;
	_cmb.itemData[_cmb.addItem(TagReaderContext_LaneDevic_Str)] := TagReaderContext_LaneDevice;
	
	if _context = TagReaderContext_Machine then
		_cmb.listIndex := 1;
	elseif _context = TagReaderContext_WindowsPC then
		_cmb.listIndex := 2;
	elseif _context = TagReaderContext_LaneDevice then
		_cmb.listIndex := 3;
	endif;

end;


</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRFIDTagReaders" id="6cd66c9c-d211-4139-93df-488c1c93557a">
        <source>comboBoxRFIDTagReaders(_combo : CMUI_ComboBox input; _canAdd :Boolean; _value : String);
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  _combo		combobox to load
//				_canAdd		indicates whether to include the &lt;New RFID Tag Reader&gt; entry
//				_value 		value to select
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	lstIdx	: Integer;
	reader	: CM_RFIDTagReader;	
begin

	_combo.clear;
	_combo.addItem("");
	
	if _canAdd then
		_combo.addItem(app.getErrorString(NewReader));
	endif;
	
	foreach reader in self.myTerminal.allRFIDTagReadersByCode where reader.context = TagReaderContext_LaneDevice do
		idx := _combo.addItemObject(reader.description, reader);
		if reader.description = _value then
			lstIdx := idx;
		endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		_combo.listIndex := lstIdx;
	endif;
	
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_canAdd" type="Boolean"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
