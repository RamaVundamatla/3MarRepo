    <JadeMethod name="putGateScanData" id="cb51ec17-d854-4ff1-bfd0-d567b57ec5dd">
        <updating/>
        <source>putGateScanData(_request : WS_GAPIGateScanDataReq):WS_GAPIResponse updating;
/*

Purpose:		Update and existing Gate Scan Data record, clearing/removing any values not provided

Parameters:		DeviceId and Timestamp are mandatory params.
				Optional params are: Weight,Truck,Cargo,Driver,Chassis	

Return Value:		

Date			Who		Reason
15 March 2022	navgm20	Initial creation  TFS 52777
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	response 					: WS_GAPIResponse;
	terminal 					: CM_Terminal;
	pxyGateScanRecord,
	existingGateScanRecord 		: CM_GenericGateScanRecord;
	vvr 						: CM_VehicleVisitRecord;
	batNumber, chassisId,
	carrierCode, driverId,
	driverName, truckId			: String;
	weight 						: Decimal[23,6];
	newCargoItem,
	existingCargoRecord 		: CM_CargoScanRecordData;
	incomingCargoScanRecords	: WS_GAPICargoArray;
	newCSR			 			: WS_GAPICargo;
	genericIfaceAPIDevice 		: CM_Object;
	idx,
	numCargoRecs				: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response as WS_GAPIErrorResponse transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK or app.myPassport.hasErrors then
		//user has not validated
		self.httpStatusCode := HttpResponseUnauthorized;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	if not app.getMyUser.canDo(terminal, PmWebGenericScanRecord) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;

	//Do we have a GenericIfaceAPIDevice (CM_WeighBridgeObj or CM_ScanReaderObj) to match the Generic Scan Record to
	genericIfaceAPIDevice := app.myAlternateDict.getGnrcIfaceDvcById(_request.deviceId, terminal.code);
	if genericIfaceAPIDevice = null then //If we have no GenericIfaceAPIDevice then raise and exception
		app.raiseCMException2(WB_not_matched, _request.deviceId, terminal.code, null, null);
		self.httpStatusCode := HttpResponseClientError;
		return response;
	endif;
	
	if _request.truck &lt;&gt; null then
		batNumber := _request.truck.batNumber;
		carrierCode := _request.truck.carrierCode;
		truckId := _request.truck.id;
	endif;
	if _request.driver &lt;&gt; null then
		driverId := _request.driver.id;
		driverName := _request.driver.name;
	endif;
	if _request.weight &lt;&gt; null then
		weight := _request.weight.value;
	endif;
	if _request.chassis &lt;&gt; null then
		chassisId := _request.chassis.id;
	endif;
	if _request.cargo &lt;&gt; null then
		incomingCargoScanRecords := _request.cargo;
	endif;
	
	// Only Unassigned records can be updated
	existingGateScanRecord := terminal.allGenericScanRecsUnassigned[_request.deviceId,_request.timestamp];
	if existingGateScanRecord = null then
		app.raiseCMException3(Gate_Scan_Record_Not_Found, _request.deviceId,_request.timestamp.asLocalTimeStamp.asJSONFormat , terminal.code, null, null);
		self.httpStatusCode := HttpResponseClientError;
		return response;
	endif;
	
	pxyGateScanRecord := app.createUpdateProxy(existingGateScanRecord).CM_GenericGateScanRecord;
	if pxyGateScanRecord = null then
		// Exception already raised in app.createUpdateProxy
		self.httpStatusCode := HttpResponseClientError;
		return response;
	endif;

	pxyGateScanRecord.setProxyForUpdate(batNumber,carrierCode, chassisId,
										 driverId, driverName, truckId,
										 weight, vvr);
	
	foreach newCSR in incomingCargoScanRecords do : processCargoItems
		
		// Check if its a cargo item we already know about, and update it
		foreach existingCargoRecord in pxyGateScanRecord.allCargoItems as CM_CargoScanRecordData do
			
			// Just match on ID, as you can't change that, it will be treated as a new item otherwise
			if existingCargoRecord.id = newCSR.id then
				existingCargoRecord.setProxyForUpdate(newCSR.alternateId, newCSR.type, null, null);
				newCSR.populateSealCollections(existingCargoRecord.sealTypes, existingCargoRecord.sealValues);
				continue processCargoItems;
			else
				continue;
			endif;
			
		endforeach;
		
		// If we have not found the cargoId and type then create it
		create newCargoItem transient;
		newCargoItem.setProxyForCreate(newCSR.id, newCSR.alternateId, newCSR.type, null, null);
		newCSR.populateSealCollections(newCargoItem.sealTypes, newCargoItem.sealValues);
		pxyGateScanRecord.allCargoItems.add(newCargoItem);
	endforeach;
	
	// If we have not found the existing cargoId then delete it	
	numCargoRecs := pxyGateScanRecord.allCargoItems.size;
	foreach idx in 1 to numCargoRecs do : cargoFound
		newCargoItem := pxyGateScanRecord.allCargoItems[idx].CM_CargoScanRecordData;
		foreach newCSR in incomingCargoScanRecords do
			if newCSR.id = newCargoItem.id then
				continue cargoFound;
			endif;
		endforeach;
		pxyGateScanRecord.allCargoItems.remove(newCargoItem);
	endforeach;
	
	app.myPassport.warningsAcknowledged := true;
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	// Retrieve the actual information
	if app.myPassport.hasErrors or existingGateScanRecord = null then
		self.httpStatusCode := HttpResponseClientError;
		return response;
	endif;
	
	// All good so far, so delete the 'bad' response and return a 'good' one instead
	delete response;
	
	create response as WS_GAPIEmptyResponse transient;
	return response;
epilog
	if pxyGateScanRecord &lt;&gt; null then
		pxyGateScanRecord.allCargoItems.purge();
	endif;
	
	delete pxyGateScanRecord;
	
	self.finaliseResponseGeneric(response);
end;</source>
        <Parameter name="_request" type="WS_GAPIGateScanDataReq"/>
        <ReturnType type="WS_GAPIResponse"/>
    </JadeMethod>
    <JadeMethod name="reply" id="8bf3c29a-0559-41fc-9b15-8a5c823d5353">
        <source>reply(msg: String);
/*

Purpose:			Mangle the JSON response before it goes back to the client

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773
18 May 2022	navmd1	Strip the _type field from non-error responses

*/

constants
	JADE_TYPE_NAME		: String = "__type";
	JSON_STRING_DELIM	: String = '"';
	JSON_RECORD_DELIM	: String = ',';
vars
	response			: String;
	typePosStart,
	typePosEnd			: Integer;
	type 				: String;
begin
	response := msg;
	
	// To conform to the Generic API spec, the "__type" should be "Fault" in the event of an error
	if response.pos(WS_GAPIErrorResponse.name, 1) &gt; 0 then
		response := response.replace(WS_GAPIErrorResponse.name, self.Type_FAULT);
	else
		// Otherwise, strip the "__type" field entirely
		typePosStart := response.pos(JADE_TYPE_NAME, 1) - 1;
		if typePosStart &gt; 0 then
			typePosEnd := typePosStart;
			response.scanUntil(":", typePosEnd);						// Jump to the delimiter
			response.scanUntil(JSON_STRING_DELIM, typePosEnd);			// Jump past the delimiter and skip the first "
			typePosEnd += 1;
			response.scanUntil(JSON_STRING_DELIM, typePosEnd);			// Jump to the end "
			response.scanUntil(JSON_RECORD_DELIM, typePosEnd);			// Jump to the next ,
			if typePosEnd = 0 then
				typePosEnd := response.length;							// Jump to the last }
			else
				response.scanUntil(JSON_STRING_DELIM, typePosEnd);		// And finally, Jump to the next "
			endif;
			type := response[typePosStart:typePosEnd-typePosStart];
			response := response.replace(type, "");
		endif;
	endif;
	
	inheritMethod(response);

epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="d7ee96f2-ea8a-47a7-9086-c46882114fdc">
        <source>validateLicense(path: String): Boolean;
/*

Purpose:			Validates MTNGenericInterfaceAPI Subscription License

Parameters:			

Return Value:		

Date			Who		Reason
25 March 2022	navpw1	Initial creation TFS: 52773

*/

begin
	// MTN Generic Interface Service does not require a separate subscription license
	// root.canDo(PmWebServiceModule) is checked on application start in initJMTRestService
	return true;

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
