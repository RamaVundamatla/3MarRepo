    <JadeMethod name="getCarrierEmailDefaultsForType" id="5de781b5-08f6-4d2c-9f5e-a7fa212e27ef">
        <source>getCarrierEmailDefaultsForType( _type : Integer ) : CM_PINObjectDefaultEmail protected;

// use method(s) getEmailDefaultsSettings, getEmailDefaultCarrier or getEmailDefaultConsignee as appropriate.
// This should make it easier to do PAR 20399.
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	eDef	: CM_ObjectEmail;
	
begin
	// from release 7.7.3 onwards this method should not be used and deleted in a later release
	foreach eDef in self.allPINObjectEmailDefaults discreteLock do 
		if eDef.type = _type then
			return eDef.CM_PINObjectDefaultEmail;
		endif;
	endforeach;
	
end;</source>
