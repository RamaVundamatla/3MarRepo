    <JadeMethod name="isBulkByVolume" id="ec34a83b-a7f1-4da9-9248-7982880c0e8d">
        <source>isBulkByVolume() : Boolean;
/*

Date		Who		Reason
16 June 2014	cnwer1	Initial creation PAR 34406

*/

vars	
	ct : CM_CargoType;
begin
	if self.myProduct &lt;&gt; null then
		ct := self.myProduct.myCargoType;
	endif;
	
	if ct = null then
		ct:=self.myCargoType;
	endif;
	
	if ct = null then
		return false;
	endif;
	
	return ct.isBulkByVolume;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEDIMatch" id="c70ee5f8-b6c3-45ff-8b4a-e5f654c4cb4a">
        <source>isEDIMatch(_ediReleaseRequestTI: CM_EDIReleaseRequestTI; _isExact: Boolean): Boolean;
// --------------------------------------------------------------------------------
// Created:		14 October 2010
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
//
// 01/12/2010	cnwdad1		PAR #26392 - need to include BOL number in exact match.
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
// --------------------------------------------------------------------------------
vars
	rootObj			: CM_Root;
	cargoTypeObj	: CM_CargoType;
	productObj		: CM_Product;
	availGrades		: IntegerArray;
	avGrade			: Integer;
	maskIdStr		: String;
	maskString		: String;
	allMasks		: StringArray;
	
begin
	if not inheritMethod(_ediReleaseRequestTI, _isExact) then
		return false;
	endif;
	if _ediReleaseRequestTI.sequence &lt;&gt; null then
		if _ediReleaseRequestTI.sequence &lt;&gt; self.sequence then
			return false;
		endif;
	endif;
	rootObj	:=	app.myRoot;
	
	if not _ediReleaseRequestTI.releaseByType then //cnwrd1 par 27913 28.7.2011 - if we are changing from a release by type to a release by ID we want to make sure we do not match here!
		return false;
	endif;
	
	if _isExact then
		// It is important that the following details match.
		
		if self.myCargoType &lt;&gt; null and self.myCargoType &lt;&gt; _ediReleaseRequestTI.myCargoType then
			return false;
		endif;
		
		if self.myISOGroup &lt;&gt; null and self.myISOGroup &lt;&gt; rootObj.allISOTypeGroups[_ediReleaseRequestTI.isoTypeGroup] then
			return false;
		endif;
		
		if self.myISOType &lt;&gt; null and self.myISOType &lt;&gt; rootObj.allISOTypes[_ediReleaseRequestTI.isoType] then
			return false;
		endif;
		
		cargoTypeObj	:=	rootObj.getCargoTypeForID(_ediReleaseRequestTI.cargoType);
		
		if cargoTypeObj &lt;&gt; null then
			productObj	:=	cargoTypeObj.allProducts[_ediReleaseRequestTI.operatorCode, _ediReleaseRequestTI.cargoSubType];
		endif;
		
		if self.myProduct &lt;&gt; null and self.myProduct &lt;&gt; productObj then
			return false;
		endif;
		
// cnwdad1 01/12/2010 - PAR #26392.
		if self.myBOLIn &lt;&gt; null and _ediReleaseRequestTI.billOfLading &lt;&gt; null then
			if self.myBOLIn.number &lt;&gt; _ediReleaseRequestTI.billOfLading then
				return false;
			endif;
		endif;
		
		// The following details are not so important, but look for a match anyway.
		
		create availGrades transient;
		
		if not self.allAvailabilityGrades.isEmpty() then
			_ediReleaseRequestTI.getAllAvailabilityGrades(availGrades);
			
			foreach avGrade in availGrades do
				if not self.allAvailabilityGrades.includes(avGrade) then
					return false;
				endif;
			endforeach;
		endif;
		
		if self.clean and not _ediReleaseRequestTI.clean then
			return false;
		endif;
		
		if self.heavyRated and not _ediReleaseRequestTI.heavyDuty then
			return false;
		endif;
		
		if not _ediReleaseRequestTI.releaseByType then
			create allMasks transient;
			maskIdStr	:=	self.getIdsAsString();
			// For the Ids (aka ID Masks) because these id masks are comma seperated the user must include
			// them in quotes of some kind so need to remove any left over single or double quotes here.
			maskString	:=	_ediReleaseRequestTI.ids.trimBlanks();
			maskString	:=	maskString.replaceString(SingleQuote, null);
			maskString	:=	maskString.replaceString(DoubleQuote, null);
			maskString.convertToDelimitedArray(",", allMasks);
			
			if maskIdStr &lt;&gt; null and maskIdStr &lt;&gt; maskString then
				return false;
			endif;
		endif;
	else
		if self.myCargoType &lt;&gt; null and _ediReleaseRequestTI.myCargoType &lt;&gt; null then
			if self.myCargoType &lt;&gt; _ediReleaseRequestTI.myCargoType then
				return false;
			endif;
		endif;
		
		if self.myISOGroup &lt;&gt; null and _ediReleaseRequestTI.isoTypeGroup &lt;&gt; null then
			if self.myISOGroup &lt;&gt; rootObj.allISOTypeGroups[_ediReleaseRequestTI.isoTypeGroup] then
				return false;
			endif;
		endif;
		
		if self.myISOType &lt;&gt; null and _ediReleaseRequestTI.isoType &lt;&gt; null then
			if self.myISOType &lt;&gt; rootObj.allISOTypes[_ediReleaseRequestTI.isoType] then
				return false;
			endif;
		endif;
		
		if self.myProduct &lt;&gt; null and _ediReleaseRequestTI.cargoSubType &lt;&gt; null then
			cargoTypeObj	:=	rootObj.getCargoTypeForID(_ediReleaseRequestTI.cargoType);
			
			if cargoTypeObj &lt;&gt; null then
				productObj	:=	cargoTypeObj.allProducts[_ediReleaseRequestTI.operatorCode, _ediReleaseRequestTI.cargoSubType];
			endif;
			
			if self.myProduct &lt;&gt; productObj then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog
	delete availGrades;
	delete allMasks;
end;</source>
        <Parameter name="_ediReleaseRequestTI" type="CM_EDIReleaseRequestTI"/>
        <Parameter name="_isExact" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEDIMatchForISOTypeProduct" id="75e2151d-d097-4859-8087-43949faa4bc3">
        <source>isEDIMatchForISOTypeProduct(_ediTI : CM_EDIBookingRefTI) : Boolean;
/*
Created:	19 December 20127 By cnwdap1

Purpose:	Compares either ISOType/Group for containers/generators or product for non-containers
			Used when looking for a reserve selection to match an EDI request
			
			The rules for ISO Type/Group checking are (as user can enter ISO Type AND/OR ISO Type Group)
				1. if only have ISO Type, then must match ISO Type
				2. if only have ISO Group, then must match ISO Group
				3. if have ISO Type and Group, then check ISO Type first, if no match, then match ISO Group
				   (this is so preference can be given to match Type, but if none found, match group)

Changed On  By  		Reason
----------	--------	---------------------------------------------------------------------------------
19/12/2012	cnwdap1		PAR #30882 CCMS PNL 2244 Original creation
*/
vars
	tiISOType,
	tiISOGroupCode	: String;
	myISOGroup		: CM_ISOTypeGroup;
	
begin
	if _ediTI = null or self.myCargoType = null then
		return false;
	endif;
	
	if self.myISOType &lt;&gt; null then
		tiISOType := _ediTI.isoType;
		if self.myISOType.code = tiISOType then
			return true;
		elseif self.myISOGroup &lt;&gt; null then
			if self.myISOGroup.allISOTypes[_ediTI.isoType] &lt;&gt; null then
				return true;
			endif;
		endif;

		return false;
	endif;
	
	myISOGroup := self.getISOGroupObject();
	if myISOGroup &lt;&gt; null and self.myISOType = null then
		tiISOGroupCode := _ediTI.isoTypeGroup;
		if tiISOGroupCode = myISOGroup.code then
			return true;
		else
			return false;
		endif;
	endif;
	
	if self.myProduct &lt;&gt; null then
		return self.myProduct.code = _ediTI.product;
	else//how to compare just a product description??
		return _ediTI.description.toUpper.cnContains(self.productStr.toUpper);
	endif;
	
	return false;
epilog
	
end;


</source>
        <Parameter name="_ediTI" type="CM_EDIBookingRefTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEDIMatch_MTGrade" id="b430669e-e4b0-411d-953c-a736076845cf">
        <source>isEDIMatch_MTGrade(_ediTI :CM_EDIReleaseRequestTI):Boolean;
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	ediColl		:HugeStringArray;
	coll 		:IntegerArray;
	str			:String;
	int			:Integer;
begin 
	coll := self.allAvailabilityGrades;
	
	create ediColl transient;
	
	_ediTI.availabilityGrades.trimBlanks().getHugeTokensForDelimiter(Space.Character, ediColl);

	if coll.size &lt;&gt; ediColl.size then
		// cannot be the same
		return false;
	endif;
		
	if coll.size = 0 then
		// nothing in either coll
		return true;
	endif;
		
	foreach str in ediColl do 
		if not str.isInteger then
			// its invalid 
			return false;
		endif;
		
		if not coll.includes(str.Integer) then
			// grade in EDi but not on release
			return false;
		endif;
	endforeach;
	
	foreach int in coll do
		if not ediColl.includes(int.String) then
			// grade in EDi but not on release
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete ediColl;
end;</source>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFulfilled" id="4bcb3a56-9652-449f-b44c-ccba91699adc">
