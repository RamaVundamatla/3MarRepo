		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String; // this is the poisition on the track
		mnuChild.userObject := theRailLine;
*/
		/*foreach anObject  in allWagonClasses do
		
			create theMenuObjects transient;
			// add this in here so that we can clear them up later
			self.allTransientObjects.add(theMenuObjects);
			
			mnuIndex := mnuIndex + 1;
