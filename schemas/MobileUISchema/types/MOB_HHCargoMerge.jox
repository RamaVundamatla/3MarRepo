    <JadeMethod name="populateTrackedItem" id="e3c0784e-ac24-4ca6-9750-11cab084136f">
        <source>populateTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274	Break-bulk

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		
	endif;
	
	self.displayProspects();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="7cc2d2e7-8a5b-47c6-8de9-664d40180786">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if not ti.canMergeBreakBulk then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				if not ti.canMergeBreakBulk then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( true );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setCanMergeOnly(true);
		
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="00a1bd10-8765-4e9b-96f5-2de2586eefe2">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

	errorMess : String;

begin

	if _ti &lt;&gt; null then
		if not _ti.canMergeBreakBulk then
			errorMess := app.getErrorString1(Cargo_selecte_not_merged,_ti.id);
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, false);
			setMyTrackedItem( null );
			return;
		endif;
		
	endif;
	
	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
	self.displayProspects();
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="767cd4b6-4997-4c6a-b887-60e5f7950a82">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274	break-bulk

*/

vars

begin
	
	self.doResizeControls(true);
	
	self.populateTrackedItem();	
	self.txtCargoId.setFocus;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="14135306-b4ac-4288-b717-0870c57e4ee7">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

	ti : CM_TrackedItem;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myMobileGenericAgent.clearAll(); // to reset 'terminal' on the agent..

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Merge), app.getErrorString(Cancel), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="7903b2c3-d28b-4b59-84ce-bd2ef4189379">
        <source>setupTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

begin

	self.tblProspects.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblProspects.rows := 1;
	self.tblProspects.columns := 2;
	self.tblProspects.fixedColumns := 0;
	self.tblProspects.accessColumn(1).width := (self.tblProspects.width* 0.25).Integer;
	self.tblProspects.accessColumn(1).inputType := Table.InputType_CheckBox;
	self.tblProspects.accessColumn(1).alignment := Table.Alignment_Center_Top;
	self.tblProspects.accessCell(1,2).alignment := Table.Alignment_Center_Top;
	self.tblProspects.accessCell(1,1).text := app.getErrorString(Selected);
	self.tblProspects.accessCell(1,2).text := app.getErrorString(Cargo_ID);
	//self.tblTargets.accessRow(1).fontBold := true;
	self.tblProspects.selectMode := Table.SelectMode_None;
	self.tblProspects.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="07df6989-f178-4edc-b735-824b753e3710">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:48:54.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023413, locale);
	btnSelect.translateCaption(Xlat_0023414, locale);
	lblCargoId.translateCaption(Xlat_0023416, locale);
	lblFindInList.translateCaption(Xlat_0023415, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="849aaec4-0338-4afc-a7eb-d1c8fa1e0e9c">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="d9f9070d-c7b3-413b-9dd0-9d28ffe16489">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation		CCMS 2274 Break-bulk

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtFindInList_change" id="14c30670-b25d-4081-a97e-71d917615562">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFindInList_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwndl1	Initial creation

*/

vars

	str : String;
	index : Integer;
	ti : CM_TrackedItem;
	selectIndex : Integer;
	strLength : Integer;
	nearMatchIndex : Integer;

begin

	self.btnSelect.enabled := false;
	self.btnSelect.caption := "+";
	
	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	str := self.txtFindInList.text.toUpper.trimBlanks;
	if str = null or str = self.lblFindInList.caption.toUpper then
		self.tblProspects.topRow := self.tblProspects.fixedRows + 1;
		return;
	endif;
	strLength := str.length;
	
	if self.tblProspects.rows &gt; self.tblProspects.fixedRows then
		foreach index in self.tblProspects.fixedRows + 1 to self.tblProspects.rows do
			self.tblProspects.accessRow(index).selected := false;
			ti := self.tblProspects.accessRow(index).itemObject.CM_TrackedItem;
			if selectIndex = 0 then
				if ti.id = str and selectIndex = 0 then
					selectIndex := index;
				elseif nearMatchIndex = 0 and ti.id.length &gt; strLength and ti.id[1:strLength] = str then
					nearMatchIndex := index;
				endif;
			endif;
			
		endforeach;
	endif;
	
	if selectIndex &gt; 0 then
		self.btnSelect.enabled := true;
		self.tblProspects.accessRow(selectIndex).selected := true;
		self.tblProspects.topRow := selectIndex;
		if self.tblProspects.accessCell(selectIndex, 1).text = "1" then
			self.btnSelect.caption := "-";
		endif;
	elseif nearMatchIndex &gt; 0 then
		self.tblProspects.topRow := nearMatchIndex;
	else
		self.tblProspects.topRow := self.tblProspects.fixedRows + 1;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
