    <JadeMethod name="excludeField" id="2412272a-0199-4f1f-946c-db2c04514d50">
        <source>excludeField(_label : String) :Boolean;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 26 February 2004
//
// Fields that are not required for the report are included here by 
// caption.  
//
//********************************************************************
vars
	theLabel : String;
begin
	if _label = null then
		return false;
	endif;
	
	theLabel := _label;
	if 	   theLabel = Label_Mark 
		or theLabel = Label_COUType
		or theLabel = Label_TotalQuantity
		or theLabel = Label_Density
		or theLabel = Label_EIRNumber
		or theLabel = Label_IsHeavyDuty
		or theLabel = Label_COU
		or theLabel = Label_BillOfLading then
			return true;
	endif;  	
	return false;
end;</source>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initReport" id="1be10f1b-1e15-4ec4-a68f-d11fbcfc48f8">
        <updating/>
        <source>initReport() updating;
// ---------------------------------------------------------------------------
// Created:   May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.portteclogo.picture := app.getPicLogoProduct();
	self.picLogo.picture := app.getPicLogoPort();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initReportForLandscape" id="ef1594a9-fcf3-4fa8-856e-62ff3951d9d8">
        <source>initReportForLandscape();
//--------------------------------------------------
// Created:	29 March 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.picLogo.move((940-self.picLogo.width),self.picLogo.top, self.picLogo.width, self.picLogo.height);
	self.frHeader.width := 1050;
end;</source>
    </JadeMethod>
    <JadeMethod name="printDataFromTable" id="00c1aa3a-2f0b-45aa-9f8f-c2d189012417">
        <updating/>
        <source>printDataFromTable(_caption : String; _tbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:  May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	REPORT_HEADER = 1;
	REPORT_DETAIL = 2;
vars
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
	lLabel : String;
	lData : String;
	idx,
	numRows	: Integer;
	lFirst	: Boolean;
	
begin

	create self.allLabels transient;
	create self.allData transient;
	lLabel := "";
	lData := "";
	lFirst := true;
	self.printLine(_caption, "", "","", REPORT_HEADER);
	
	numRows := _tbl.rows;

	foreach idx in 1 to numRows do
		if lFirst = true then
			lLabel 	:= _tbl.accessCell(idx, _tbl.ColumnHeading).text;
			if self.excludeField(lLabel) or not _tbl.accessRow(idx).visible then // cnwrd1 par 19513 23.4.09
				continue;
			endif;
			lData 	:= _tbl.accessCell(idx, _tbl.ColumnValue).text;
			lFirst 	:= false;
		else
			if self.excludeField(_tbl.accessCell(idx, _tbl.ColumnHeading).text) or not _tbl.accessRow(idx).visible then // cnwrd1 par 19513 23.4.09
				continue;
			endif;
			self.printLine(lLabel, lData, 
						_tbl.accessCell(idx, _tbl.ColumnHeading).text, 
						_tbl.accessCell(idx, _tbl.ColumnValue).text, 
						REPORT_DETAIL);
			lLabel := "";
			lData := "";
			lFirst := true;
		endif;
	endforeach;		
	if lLabel &lt;&gt; "" then
		self.printLine(lLabel, lData, "", "",REPORT_DETAIL);
	endif;

/*	
	// now go through the arrays for this section and pass them 2 at a time to the print line method
	foreach i in 1 to self.allLabels.size do
		if lFirst = true then
			lLabel := self.allLabels[i];
			lData := self.allData[i];
			lFirst := false;
		else
			self.printLine(lLabel, lData, self.allLabels[i], self.allData[i],REPORT_DETAIL);
			lLabel := "";
			lData := "";
			lFirst := true;
		endif;
	endforeach;		
	if lLabel &lt;&gt; "" then
		self.printLine(lLabel, lData, "","",REPORT_DETAIL);
	endif;
*/
	
epilog
	delete self.allLabels;
	delete self.allData;
end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printLine" id="37c7c6f2-1a23-4399-b5a7-923781b286f5">
        <source>printLine(lLabel : String; lData : String; rLabel : String; rData : String; lType : Integer);
// ---------------------------------------------------------------------------
// Created:  May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	REPORT_HEADER = 1;
	REPORT_DETAIL = 2;

vars

begin

	if lType = REPORT_HEADER then
		// LEFT HAND SIDE
		self.lblLineHeaderL.caption := lLabel;
		self.lblLineDetailL.caption := lData;
		self.lblLineHeaderL.fontBold := true;
		self.lblLineHeaderL.backColor := Black;
		self.lblLineHeaderL.foreColor := White;

		// RIGHT HAND SIDE		
		self.lblLineHeaderR.caption := "";
		self.lblLineDetailR.caption := "";

		// BOXES
		self.frDetailLHeader.boundaryColor := Black;
		self.frDetailLDetail.boundaryColor := White;
		self.frDetailRHeader.boundaryColor := White;
		self.frDetailRDetail.boundaryColor := White;
		
	else
		// LEFT HAND SIDE
		self.lblLineHeaderL.caption := lLabel;
		self.lblLineDetailL.caption := lData;
		self.lblLineHeaderL.fontBold := true;
		self.lblLineHeaderL.backColor := White;
		self.lblLineHeaderL.foreColor := Black;
		
		// RIGHT HAND SIDE
		self.lblLineHeaderR.caption := rLabel;
		self.lblLineDetailR.caption := rData;
		self.lblLineHeaderR.fontBold := true;
		self.lblLineHeaderR.backColor := White;
		self.lblLineHeaderR.foreColor := Black;

		self.frDetailLHeader.boundaryColor := Black;
		self.frDetailLDetail.boundaryColor := Black;
		self.frDetailRHeader.boundaryColor := Black;
		self.frDetailRDetail.boundaryColor := Black;
	endif;
	app.printer.print(self.frDetail);

end;</source>
        <Parameter name="lLabel" type="String"/>
        <Parameter name="lData" type="String"/>
        <Parameter name="rLabel" type="String"/>
        <Parameter name="rData" type="String"/>
        <Parameter name="lType" type="Integer"/>
    </JadeMethod>
</GUIClass>
