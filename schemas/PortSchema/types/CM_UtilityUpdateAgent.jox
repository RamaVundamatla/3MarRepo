    <JadeMethod name="utlUpdateInterfaceDefinition" id="26f29546-d57e-435a-b0d6-b1e0df02056d">
        <source>utlUpdateInterfaceDefinition(_proxyObj:CM_TCPInterfaceDefinition; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Transaction to update a persistent Interface Definition object.
//
// Parameters:	_proxyObj - A reference to a proxy of the object to update.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realObject		: CM_TCPInterfaceDefinition;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_proxyObj, 'Interface Defintion');
	_proxyObj.pxyGetRealObjectAndEdition(realObject, expectedEdition);
	
	if realObject = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InterfaceDefinition.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valUpdateInterfaceDefinition(_proxyObj, realObject, _passportObj);

	if not self.checkValidationWithPassport(_passportObj) then
		return;
	endif;
	
	realObject	:=	self.getRealObjectAndEditionCheck(_proxyObj, 'Interface Definition', _passportObj).CM_TCPInterfaceDefinition;

	if _passportObj.noErrors() then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passportObj.noErrors() then
		// do updates
		realObject.setForUpdate(_proxyObj);
	endif;

	if _passportObj.noErrors() then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
end;</source>
        <Parameter name="_proxyObj" type="CM_TCPInterfaceDefinition"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInterfaceHistory" id="3e94a3bb-d576-4cdc-9c36-12c8a4eabd16">
