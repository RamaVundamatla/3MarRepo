	self.myOptSortOut.parentAspect		:=	Control.ParentAspect_None;
	self.myOptSortOut.setYAControl(self, false, true, false, false);
	self.form.addControl(self.myOptSortOut);
	self.myOptSortOut.move(55, myOptSortIn.top, 40, 21);
	
	create self.myBtnClearLocs transient;
	self.myBtnClearLocs.caption			:=	"Clear";
	self.myBtnClearLocs.parent			:=	self.myShtLocations;
	self.myBtnClearLocs.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnClearLocs.setYAControl(self, false, false, true, false, false, false, false);
	self.form.addControl(self.myBtnClearLocs);
	self.myBtnClearLocs.move((self.myLstLocations.left + self.myLstLocations.width - self.myBtnClearLocs.width), 280, 90, 25);
	
	create self.myLblOptionIn transient;
	self.myLblOptionIn.caption			:=	"Fill Option IN";
	self.myLblOptionIn.transparent		:=	true;
	self.myLblOptionIn.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblOptionIn.parent			:=	self.myShtLocations;
	self.myLblOptionIn.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblOptionIn);
