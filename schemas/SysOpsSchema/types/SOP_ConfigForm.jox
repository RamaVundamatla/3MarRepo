/* ---------------------------------------------------------------------------
Created:     25 February 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
21/07/2020	jlgdap1	TFS 49764 MTN Retire Basic Authentication to Exchange Online
------------------------------------------------------------------------------*/
vars
	str		: String;
begin

	str := app.emailLicenseType_EnumToStr(EmailLicenseType_0) &amp; Tab &amp;
		   app.emailLicenseType_EnumToStr(EmailLicenseType_1) &amp; Tab &amp;
		   app.emailLicenseType_EnumToStr(EmailLicenseType_3) &amp; Tab; 		// ### TFS 51526 23Feb2022 NAVPW1
	if _showOAuth then														// TFS 49764
		str := str &amp; app.emailLicenseType_EnumToStr(EmailLicenseType_2);	// TFS 49764
	endif;																	// TFS 49764

	self.tblConfig.setComboValuesByName(ETRow_EmailLicenseType, str);

epilog

end;</source>
