    <JadeMethod name="getDDTargetLocation" id="99acd4c4-d905-4b8c-9e01-ab0e496b3b20">
        <source>getDDTargetLocation():CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2013	cnwndl1	Initial creation

*/

vars

	targetWle : CM_WorkListEntry;
	lc : CM_LocationsController;

begin

	if self.myTrackedItem = null then
		return null;
	endif;
	if not self.myTrackedItem.directDelivery then
		return null;
	endif;
	
	lc := self.getTargetLocation;
	if lc &lt;&gt; null then
		return lc;
	endif;
	
	targetWle := self.myTrackedItem.getDirectDeliveryTargetWle(self);
	if targetWle &lt;&gt; null then
		lc := targetWle.getTargetLocation;
		if lc &lt;&gt; null then
			return lc;
		endif;
	endif;
	
	return null;

epilog

end;</source>
