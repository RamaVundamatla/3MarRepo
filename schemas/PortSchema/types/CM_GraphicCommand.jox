    <JadeMethod name="drawMe" id="e08800b7-1fe3-492e-b803-cb3e57bf8864">
        <source>drawMe(_frame : Frame input; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean;_maxX : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theX, theY : Integer;
	theX2, theY2 : Integer;
	theStartX, theEndX : Integer;
	theStartY, theEndY : Integer;
	maxX : Integer;
	drawWidth : Integer;
		shiftOver : Integer;
begin
	if self.type &lt;&gt; CM_GraphicCommand.TYPE_RECTANGLE
	and self.type &lt;&gt; CM_GraphicCommand.TYPE_LINE 
	and self.type &lt;&gt; CM_GraphicCommand.TYPE_ELIPSE 
	and	self.type &lt;&gt; CM_GraphicCommand.TYPE_ARC then
		return;
	endif;


	theX := (_scale * self.x1).Integer + (_scale * _offsetX).Integer;
	theY := (_scale * self.y1).Integer + (_scale * _offsetY).Integer;
	theX2 := (_scale * self.x2).Integer + (_scale * _offsetX).Integer;
	theY2 := (_scale * self.y2).Integer + (_scale * _offsetY).Integer;

	//epr 8/8/08 ccms 1045 update the chassis graphic
	theStartX:=(_scale * self.startX).Integer + (_scale * _offsetX).Integer;
	theEndX:=(_scale * self.endX).Integer + (_scale * _offsetX).Integer;
	
	theStartY:=(_scale * self.startY).Integer + (_scale * _offsetY).Integer;
	theEndY:=(_scale * self.endY).Integer + (_scale * _offsetY).Integer;

	maxX :=  (_scale * (_maxX + _offsetX)).Integer ;

	//cnwjo3, its the devils work!
	if _flippedH then
		theX := maxX - theX ;
		theX2 := maxX - theX2 ;
		
		theX := theX + _offsetX - _maxX;
		theX2 := theX2 + _offsetX - _maxX;
	endif;

	if self.type = CM_GraphicCommand.TYPE_RECTANGLE then
		_frame.drawFillColor := self.fillColour;
		_frame.drawFilledRectangle(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_ELIPSE then
		_frame.drawFillColor := self.fillColour;
		_frame.drawEllipse1(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_LINE then
		_frame.drawWidth := _scale.Integer;
		
	
		_frame.drawLine(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_ARC then
		//Used for drawing trailer graphic
		drawWidth := (_scale*2).Integer;
		if drawWidth &lt; 1 then
			drawWidth := 1;
		endif;
		_frame.drawWidth := drawWidth;
		_frame.drawArc(theX,theY, theX2,theY2,theStartX,theStartY,theEndX,theEndY,self.lineColour);

	endif;
end;
</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_maxX" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawMeRoRo" id="b509216e-3a3f-48a7-8388-bd351fb1967e">
        <source>drawMeRoRo(_frame : Frame input; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean;_maxX : Integer);
// ---------------------------------------------------------------------------
// Created:		9 March 2010 By cnwjo3
//
// Purpose:		direct copy of drawMe.  Revert some changes in drawme for ship
//
// ---------------------------------------------------------------------------

vars
	theX, theY : Integer;
	theX2, theY2 : Integer;
	theStartX, theEndX : Integer;
	theStartY, theEndY : Integer;
	maxX : Integer;
	drawWidth : Integer;
begin
	if self.type &lt;&gt; CM_GraphicCommand.TYPE_RECTANGLE
	and self.type &lt;&gt; CM_GraphicCommand.TYPE_LINE 
	and self.type &lt;&gt; CM_GraphicCommand.TYPE_ELIPSE 
	and	self.type &lt;&gt; CM_GraphicCommand.TYPE_ARC then
		return;
	endif;

	theX := (_scale * self.x1).Integer +  _offsetX;
	theY := (_scale * self.y1).Integer + _offsetY;
	theX2 := (_scale * self.x2).Integer +  _offsetX;
	theY2 := (_scale * self.y2).Integer + _offsetY;

	//epr 8/8/08 ccms 1045 update the chassis graphic
	theStartX:=(_scale * self.startX).Integer + _offsetX;
	theEndX:=(_scale * self.endX).Integer +  _offsetX;
	
	theStartY:=(_scale * self.startY).Integer +  _offsetY;
	theEndY:=(_scale * self.endY).Integer +  _offsetY;

	maxX:=_maxX;

	if _flippedH then
		theX := _offsetX + (_maxX - (_scale * self.x1)).Integer;
		theX2 := _offsetX + (_maxX - (_scale * self.x2)).Integer;
	endif;
	
	if self.type = CM_GraphicCommand.TYPE_RECTANGLE then
		_frame.drawFillColor := self.fillColour;
		_frame.drawFilledRectangle(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_ELIPSE then
		_frame.drawFillColor := self.fillColour;
		_frame.drawEllipse1(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_LINE then
		drawWidth := _scale.Integer;
		if drawWidth &lt; 1 then
			drawWidth := 1;
		endif;
		_frame.drawWidth := drawWidth;
//		_frame.drawWidth := _scale.Integer;
		_frame.drawLine(theX,theY, theX2,theY2,self.lineColour);
	elseif self.type = CM_GraphicCommand.TYPE_ARC then
		//Used for drawing trailer graphic
		drawWidth := (_scale*2).Integer;
		if drawWidth &lt; 1 then
			drawWidth := 1;
		endif;
		_frame.drawWidth := drawWidth;
		_frame.drawArc(theX,theY, theX2,theY2,theStartX,theStartY,theEndX,theEndY,self.lineColour);

	endif;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_maxX" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLData" id="fcc4361b-5be6-4d0d-bc33-9ffa8a0a89e3">
        <source>getXMLData() : String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
begin
	theXML := "&lt;CMD&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_FillColour &amp; "&gt;"  &amp; self.fillColour.String &amp;  "&lt;/" &amp; self.XMLTag_FillColour &amp; "&gt;" ;
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_Colour &amp; "&gt;"  &amp; self.lineColour.String &amp;  "&lt;/" &amp; self.XMLTag_Colour &amp; "&gt;" ;
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_Label &amp; "&gt;"  &amp; self.label &amp;  "&lt;/" &amp; self.XMLTag_Label &amp; "&gt;" ;
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_Type &amp; "&gt;"  &amp; self.type.String &amp;   "&lt;/" &amp; self.XMLTag_Type &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_X1 &amp; "&gt;"  &amp; self.x1.String &amp;   "&lt;/" &amp; self.XMLTag_X1 &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_X2 &amp; "&gt;"  &amp; self.x2.String &amp;   "&lt;/" &amp; self.XMLTag_X2 &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_Y1 &amp; "&gt;"  &amp; self.y1.String &amp;   "&lt;/" &amp; self.XMLTag_Y1 &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_Y2 &amp; "&gt;"  &amp; self.y2.String &amp;   "&lt;/" &amp; self.XMLTag_Y2 &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_StartX &amp; "&gt;"  &amp; self.startX.String &amp;   "&lt;/" &amp; self.XMLTag_StartX &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_EndX &amp; "&gt;"  &amp; self.endX.String &amp;   "&lt;/" &amp; self.XMLTag_EndX &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_StartY &amp; "&gt;"  &amp; self.startY.String &amp;   "&lt;/" &amp; self.XMLTag_StartY &amp; "&gt;";
	theXML := theXML &amp;  "&lt;" &amp; self.XMLTag_EndY &amp; "&gt;"  &amp; self.endY.String &amp;   "&lt;/" &amp; self.XMLTag_EndY &amp; "&gt;";
	theXML := theXML &amp; "&lt;/CMD&gt;";
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7a7dd45e-2a69-4b26-bc9c-f0b1d9e2d38f">
        <updating/>
        <source>setProxy(	_type, 
			_theX1, 
			_theY1, 
			_theX2, 
			_theY2, 
			_startX,
			_endX,
			_startY,
			_endY,
			_colour, 
			_fill  : Integer; 
			_label : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.label := _label;
	self.type := _type;
	self.x1 := _theX1;
	self.x2 := _theX2;
	self.y1 := _theY1;
	self.y2 := _theY2;
	self.startX:=_startX;
	self.endX:=_endX;
	self.startY:=_startY;
	self.endY:=_endY;
	self.lineColour := _colour;
	self.fillColour := _fill;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_theX1" type="Integer"/>
        <Parameter name="_theY1" type="Integer"/>
        <Parameter name="_theX2" type="Integer"/>
        <Parameter name="_theY2" type="Integer"/>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_endX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_endY" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_fill" type="Integer"/>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="setStartY" id="2e574542-c65c-4023-804d-8781b128d73f">
        <updating/>
        <source>setStartY(value: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	if startY &lt;&gt; value then 
		startY := value;
	endif;


epilog

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setXMLData" id="d45757ef-27b5-4322-b6f1-77309706aef6">
        <updating/>
        <source>setXMLData(_xmlData : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theType, theColour,theFill,theX1, theY1, theX2,theY2 : Integer;
	theStartX,theEndX,theStartY,theEndY: Integer;
	theLabel : String;
	xmlData : String;
begin
	xmlData := _xmlData;
	
	theColour := xmlData.cnEcGetTagValueOfName(self.XMLTag_Colour).Integer;
	theFill := xmlData.cnEcGetTagValueOfName(self.XMLTag_FillColour).Integer;
	theLabel := xmlData.cnEcGetTagValueOfName(self.XMLTag_Label);
	theType := xmlData.cnEcGetTagValueOfName(self.XMLTag_Type).Integer;
	theX1 := xmlData.cnEcGetTagValueOfName(self.XMLTag_X1).Integer;
	theX2 := xmlData.cnEcGetTagValueOfName(self.XMLTag_X2).Integer;
	theY1 := xmlData.cnEcGetTagValueOfName(self.XMLTag_Y1).Integer;
	theY2 := xmlData.cnEcGetTagValueOfName(self.XMLTag_Y2).Integer;
	theStartX := xmlData.cnEcGetTagValueOfName(self.XMLTag_StartX).Integer;
	theEndX := xmlData.cnEcGetTagValueOfName(self.XMLTag_EndX).Integer;
	theStartY := xmlData.cnEcGetTagValueOfName(self.XMLTag_StartY).Integer;
	theEndY := xmlData.cnEcGetTagValueOfName(self.XMLTag_EndY).Integer;
	
	self.label := theLabel;
	self.fillColour := theFill;
	self.lineColour := theColour;
	self.type := theType;
	self.x1 := theX1;
	self.y1 := theY1;
	self.x2 := theX2;
	self.y2 := theY2;
	self.startX:=theStartX;
	self.startY:=theStartY;
	self.endX:=theEndX;
	self.endY:=theEndY;

end;</source>
        <Parameter name="_xmlData" type="String"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="4f224153-ead9-42a1-b8b2-829641cd1719">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theType : String;
begin
	if set then
		return;
	endif;
	
	if self.type = CM_GraphicCommand.TYPE_DRAW then
		theType := CM_GraphicCommand.LABEL_DRAW;
	elseif self.type = CM_GraphicCommand.TYPE_ELIPSE then
		theType := CM_GraphicCommand.LABEL_ELIPSE;
	elseif self.type = CM_GraphicCommand.TYPE_FILL then
		theType := CM_GraphicCommand.LABEL_FILL;
	elseif self.type = CM_GraphicCommand.TYPE_RECTANGLE then
		theType := CM_GraphicCommand.LABEL_RECTANGLE;
	elseif self.type = CM_GraphicCommand.TYPE_LINE then
		theType := CM_GraphicCommand.LABEL_LINE;
	elseif self.type = CM_GraphicCommand.TYPE_STOP then
		theType := CM_GraphicCommand.LABEL_STOP;
	elseif self.type = CM_GraphicCommand.TYPE_STOP_FILL then
		theType := CM_GraphicCommand.LABEL_STOP_FILL;
	elseif self.type = CM_GraphicCommand.TYPE_TEXT_POS then
		theType := CM_GraphicCommand.LABEL_TEXT_POS;
	elseif self.type = CM_GraphicCommand.TYPE_CLEARWIDTH then
		theType := CM_GraphicCommand.LABEL_CLEARWIDTH;

	elseif self.type = CM_GraphicCommand.TYPE_STRETCHXY then
		theType := CM_GraphicCommand.LABEL_STRETCHXY;
	elseif self.type = CM_GraphicCommand.TYPE_FIRST_POINT then
		theType := CM_GraphicCommand.LABEL_FIRST_POINT;
	elseif self.type = CM_GraphicCommand.TYPE_CLEARHEIGHT then
		theType := CM_GraphicCommand.LABEL_CLEARHEIGHT;
	elseif self.type = CM_GraphicCommand.TYPE_LAST_POINT then
		theType := CM_GraphicCommand.LABEL_LAST_POINT;
	elseif self.type = CM_GraphicCommand.TYPE_ARC then
		theType := CM_GraphicCommand.LABEL_ARC;
	else
		theType := "Unknown";
	endif;		
	_value := theType;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
