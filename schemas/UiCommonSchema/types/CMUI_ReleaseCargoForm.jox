    <JadeMethod name="cmbISOType_hasLostFocus" id="fcac58c0-b6d6-47e9-aac0-bc830e069257">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*
Date			Who		Reason
27 August 2010	cnwar2	#25472
08/09/2010		cnwmh5	#25688 - Change as should default to null rather than isotype's group
								 change so filters iso group correctly
*/
vars
	obj			: Object;
	isoGroup 	: CM_ISOTypeGroup;
	isoType		: CM_ISOType;
begin
	
	obj := _fieldFrame.getObject();
	//cnwmc5 - PAR 32207 - 11 Sep 2013
	isoGroup := self.cmbISOGroup.getObject().CM_ISOTypeGroup;
	
	if obj = null then
		self.cmbISOGroup.listCollection(app.myRoot.allISOTypeGroups, true, 0 );
	else
		isoType := obj.CM_ISOType;
		self.cmbISOGroup.clear();
		self.cmbISOGroup.addItem(null);
		if isoType.myISOTypeGroup &lt;&gt; null then
			self.cmbISOGroup.addItemData(isoType.myISOTypeGroup.code.trimRight &amp; Tab &amp; isoType.myISOTypeGroup.description.trimRight, 1, isoType.myISOTypeGroup);
			//cnwmc5 - PAR 32207 - 11 Sep 2013
			if isoType.myISOTypeGroup = isoGroup then
				self.cmbISOGroup.setForObject(isoGroup);
			endif;
		endif;
	endif;
	
	/*
	obj := _fieldFrame.getObject();
	if obj &lt;&gt; null then
		self.cmbISOGroup.setForObject( obj.CM_ISOType.myISOTypeGroup );
	endif;
	*/
end;</source>
