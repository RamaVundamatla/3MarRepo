    <JadeMethod name="loadDB" id="c1428f61-997d-4dc2-a9fb-fb9f90a0f93c">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
// Sep 2015 36912 TFS 456 EDI queued move
// 12 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
// 05 Jun 2024	navdap1	TFS 64459 EUP - Lock when loading Move EDI file
// 13 Jun 2024  navhl20 Bug 64434: EUP -Planned Location getting updated twice.
vars
	terminal : CM_Terminal;
	mainTi	 : CM_TrackedItem;
	ti		 : CM_EDIMoveTI;
begin
	// TFS 64459 new trx for partial loading if terminal config is set
	terminal := self.getMyTerminal();
	if app.myRoot.isClientEuroPorts() or _passport.isVASEnabled then			//14.06.2024 navhl20 #64434 we will remove isVASEnabled. added for tetsing purpose.
		ti := self.allEDITrackedItems.first.CM_EDIMoveTI;
		if ti  &lt;&gt; null and ti.isCargoGroup and ti.plannedLocn &lt;&gt; null then
			mainTi := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq(ti.id, null);
			app.myTrxUA.trxUpdateMoveTIsUndoForMode(mainTi.CM_CargoGroup.allAssignedTrackedItems, PLANNING_MODE, app.myPassport);
		endif;
	endif;
	if terminal &lt;&gt; null and terminal.getConfig(EdiMoveAllowPartial).Boolean then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Using partial updates", LogINFO);
		app.myTrxUA.trxProcessEDIMoveDataPartial(self, true, _passport);
	else
		app.myTrxUA.trxProcessEDIData(self, false, true, _passport);
	endif;
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
