    <JadeMethod name="doCompleteBtn" id="e6a89fc4-790e-4224-8826-ee1fb21c4235">
        <source>doCompleteBtn():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	roroLane : CM_RoRoController;
	swapAreaLC : CM_LocationsController;
	msg : String;
	matches : Boolean;
	ti : CM_TrackedItem;
	rowIndex : Integer;
	reversedArray : CM_TIArray;	
	theReturn : Integer;

begin

	foreach rowIndex in 1 to self.tblVehicles.rows do
		ti := self.tblVehicles.accessRow(rowIndex).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			if not self.allConfirmedArray.includes( ti ) then
				msg := app.getErrorString3( Been_scann_not_confi_pleas_fir, ti.id, self.btnReset.caption, self.btnConfirm.caption);
				return false;
			endif;
		endif;
	endforeach;

	roroLane := self.myMobileGenericAgent.myLocationsController.CM_RoRoController;

	if roroLane = null then
		msg := app.getErrorString(NO_Location_selected);
		return false;
	endif;
	
	swapAreaLC := self.myMobileGenericAgent.myTerminalArea.swapStack.getLocationsController;
	if swapAreaLC = null then
		msg := app.getErrorString(Cargo_locat_swap_stack_found_a);
		return false;
	endif;
	
	if self.allConfirmedArray.isEmpty and not roroLane.allTrackedItems.isEmpty then
		msg := app.getErrorString1( Cargo_select_move_existi_items, swapAreaLC.getFullId );
		app.beep();
		if self.msgBox(msg , app.getErrorString(Continue), MsgBox_Yes_No, false) = MsgBox_Return_No then
			msg := null;
			return false;
		endif;
		
	elseif self.allConfirmedArray.size &lt; roroLane.allTrackedItems.size then
		matches := false;
		
	else
		matches := true;
		foreach ti in roroLane.allTrackedItems do
			if not self.allConfirmedArray.includes(ti) then
				matches := false;
				break;
			endif;
		endforeach;

	endif;
	
	if not matches then
		msg := app.getErrorString2( Some_items_curre_recor_not_lis, roroLane.id, swapAreaLC.getFullId );
		app.beep();
		if self.msgBox(msg , app.getErrorString(Continue), MsgBox_Yes_No, false) = MsgBox_Return_No then
			msg := null;
			return false;
		endif;
		msg := null;
	endif;
	
	//OK so we have either accounted for everything, or the the user is happy to move anything else to the IC area.
	if not self.myMobileGenericAgent.forward then
		create reversedArray transient;
		foreach ti in self.allConfirmedArray reversed do
			reversedArray.add(ti);
		endforeach;
	endif;
	
	while true do
	
		if self.myMobileGenericAgent.forward then
			app.myTrxUA.trxUpdateRoRoLaneCargo(roroLane, swapAreaLC, self.allConfirmedArray, app.myPassport );
		else	
			app.myTrxUA.trxUpdateRoRoLaneCargo(roroLane, swapAreaLC, reversedArray, app.myPassport );
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.setVoyageCounts();
			return true;
		else
			app.beep();
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
	
	endwhile;

	return false;

epilog

	if msg &lt;&gt; null then
		app.beep();
		self.msgBox(msg , app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	delete reversedArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doConfirmBtn" id="512d2d76-8d3b-4f7c-9abf-7bdf114fe8a1">
        <updating/>
        <source>doConfirmBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	index : Integer;
	ti : CM_TrackedItem;

begin
	//clear the array and rebuild it
	self.allConfirmedArray.clear();
	
	foreach index in 1 to self.tblVehicles.rows do
		ti := self.tblVehicles.accessRow(index).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			if self.allConfirmedArray.includes(ti) then
				if self.myMobileGenericAgent.forward then
					self.allConfirmedArray.remove(ti); // from its old position
					self.allConfirmedArray.add(ti); // add into its latest position
				else
					//don't add it again this was the old position.
					continue;
				endif;
			else
				self.allConfirmedArray.add(ti);
			endif;
		endif;
	endforeach;
	
	self.setVoyageCounts();
	
	self.setMyTrackedItem(null,null);
	self.txtCargoId_lostFocus(self.txtCargoId);
	self.txtCargoId.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDamageBtn" id="34d199d0-82d4-4224-a0c6-686233e656d6">
        <updating/>
        <source>doDamageBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

begin

	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.btnDamage.caption = app.getErrorString(Cancel) then
		self.btnLabel.caption := app.getErrorString(Heading_Label);
		self.btnDamage.caption := app.getErrorString(Damage);
		self.btnOne.enabled := true;
		self.btnConfirm.enabled := self.myTrackedItem &lt;&gt; null;
		
		self.doDisableDamageTable();
			
		return;
	endif;
	

	//need to add the table and the label and resize...
	if not self.tblDamage.visible then
		self.tblDamage.visible := true;
		self.lblNoDamage.visible := false;
	endif;
	
	self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
	self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
	
	if not self.myTrackedItem.allDamageInstances.isEmpty then
		self.tblDamage.addNewRow();
	endif;
	
	self.btnOne.enabled := false; // Disable the Complete button.  
	self.btnLabel.caption := app.getErrorString(Save);
	self.btnDamage.caption := app.getErrorString(Cancel);
	self.btnConfirm.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisableDamageTable" id="5b7e3222-7ba3-40b9-9a56-062f72e5d47f">
        <updating/>
        <source>doDisableDamageTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	rowIndex : Integer;
	colIndex : Integer;

begin

	foreach rowIndex in 2 to self.tblDamage.rows do
		foreach colIndex in 1 to self.tblDamage.columns do
			self.tblDamage.accessCell(rowIndex,colIndex).enabled := false;
		endforeach;
	endforeach;
	
	self.doResizeControls(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLabelBtn" id="ac8e254e-f274-41a6-9f63-fe8c1e5d2f9d">
        <updating/>
        <source>doLabelBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

begin
	if self.myTrackedItem = null then
		return;
	endif;

	if self.btnLabel.caption = app.getErrorString(Save) then
		if self.doSaveDamage() then
			self.btnLabel.caption := app.getErrorString(Heading_Label);
			self.btnDamage.caption := app.getErrorString(Damage);
			self.btnOne.enabled := true;
			self.btnConfirm.enabled := true;
			
			if self.myTrackedItem.allDamageInstances.isEmpty then
				self.lblNoDamage.visible := true;
				self.tblDamage.visible := false;
			else
				self.lblNoDamage.visible := false;
				self.tblDamage.visible := true;
				self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
				self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
				self.doDisableDamageTable();
			endif;
			
		endif;
		
	else
		self.doPrintCargoLabel( self.myTrackedItem );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResetBtn" id="6bb03c3e-b345-4940-9a4a-8812d2717021">
        <updating/>
        <source>doResetBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

begin

	self.setMyTrackedItem(null,null);
	self.txtCargoId_lostFocus(self.txtCargoId);
	self.txtCargoId.setFocus();
	
	self.setVoyageCounts();	
	
	self.doResizeControls(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="3565306d-51d2-4797-b172-abec315c6d28">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	top : Real;
	stdHeight : Real;
	stdWidth : Real;
	tabIndex : Integer;
	tableHeight : Real;
	tableBottom: Real;
	btnWidth : Real;
	btnLeft : Real;
	damCount : Integer;
	maxHeightUnits : Integer;
	idealDamUnits : Integer;
	setUnits : Integer;
	cusWidth : Real;
	cusHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	self.resizeCmdButtons();
	
	top := self.resizedMargin;
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
						 
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(self.resizedMargin,
						 top,
						 stdWidth / 2,
						 stdHeight );
						 
	if _initialSetup then
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
		self.lblCargoDesc.visible := true;
	endif;
	self.lblCargoDesc.move( (self.resizedMargin * 2 ) + stdWidth / 2,
							 top,
							 stdWidth / 2,
							 stdHeight );
						 
	top := top + self.lblCargoDesc.height + self.resizedMargin;
	tableHeight := stdHeight * 3; //default height
	if self.myTrackedItem &lt;&gt; null then
		damCount := self.myTrackedItem.allDamageInstances.size;
		if damCount &gt; 1 then
			maxHeightUnits := (self.clientHeight / stdHeight).Integer;
			idealDamUnits := damCount + 3; 
			setUnits := idealDamUnits;
			while maxHeightUnits - setUnits &lt; 9 do
				setUnits := setUnits - 1;
			endwhile;
			if setUnits &gt; 3 then
				tableHeight := stdHeight * setUnits;
			endif;
		endif;
	endif;
	if _initialSetup then
		self.tblDamage.visible := true;
		self.tblDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.tblDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							tableHeight );
							
	if _initialSetup then
		self.lblNoDamage.visible := false;
		self.lblNoDamage.enabled := false;
		self.lblNoDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblNoDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
	
	top := top + self.tblDamage.height + self.resizedMargin;
	btnWidth := self.btnOne.width;
	while true do
		if (( btnWidth * 4 ) + ( self.resizedMargin * 5 )) &gt; clientWidth then
			btnWidth := btnWidth - 1;
			continue;
		endif;
		break;
	endwhile;
	
	if _initialSetup then
		self.btnDamage.visible := true;
		self.btnDamage.enabled := false;
		self.btnDamage.setAndIncrementTabIndex( tabIndex );
		self.btnDamage.tabStop := false;
	endif;
	self.btnDamage.move(	self.resizedMargin,
							top,
							btnWidth,
							self.btnTwo.height ); 
						
	btnLeft := btnWidth + ( self.resizedMargin * 2);
	if _initialSetup then
		self.btnLabel.visible := true;
		self.btnLabel.enabled := false;
		self.btnLabel.setAndIncrementTabIndex( tabIndex );
		self.btnLabel.tabStop := false;
	endif;
	self.btnLabel.move(	btnLeft,
						top,
						btnWidth,
						self.btnOne.height );
	
	btnLeft := ( btnWidth * 2 ) + ( self.resizedMargin * 3);
	if _initialSetup then
		self.btnReset.visible := true;
		self.btnReset.enabled := false;
		self.btnReset.setAndIncrementTabIndex( tabIndex );
		self.btnReset.tabStop := false;
	endif;
	self.btnReset.move(	btnLeft,
							top,
							btnWidth,
							self.btnOne.height );
							
	btnLeft := ( btnWidth * 3 ) + ( self.resizedMargin * 4);
	if _initialSetup then
		self.btnConfirm.visible := true;
		self.btnConfirm.enabled := false;
		self.btnConfirm.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnConfirm.move(	btnLeft,
							top,
							btnWidth,
							self.btnOne.height );
	
	top := top + self.btnDamage.height + self.resizedMargin;
	tableBottom := self.clientHeight - (self.btnOne.height + ( self.resizedMargin * 2 ));
	tableHeight := tableBottom - top;
	if _initialSetup then
		self.tblVehicles.setAndIncrementTabIndex( tabIndex );
		self.tblVehicles.visible := true;
	endif;
	self.tblVehicles.move(self.resizedMargin,
						 top,
						 stdWidth,
						 tableHeight );
						 
	top := top + self.tblVehicles.height + self.resizedMargin;
	cusWidth := self.btnTwo.left - self.resizedMargin - 1;
	cusHeight := self.btnTwo.height;
	if _initialSetup then
		self.lblShipCounts.setAndIncrementTabIndex( tabIndex );
		self.lblShipCounts.visible := true;
	endif;
	self.lblShipCounts.move(self.resizedMargin,
						 top,
						 cusWidth,
						 cusHeight );					
						

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDamage" id="f22f9687-8ac1-407c-8fbc-201ae6be676b">
        <source>doSaveDamage():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	errors : String;
	sessionAgent : CM_MobileAgent;
	damageInterface : IF_DamageDetails;
	damageLC : String; // The location the cargo was in when the damage was noted.
	damageInstance : CM_DamageInstance;

begin

	damageLC := self.myMobileGenericAgent.myLocationsController.CM_RoRoController.getFullId;

	app.mousePointer := self.MousePointer_HourGlass;
	sessionAgent := self.getSessionAgent();
	sessionAgent.setMyProxy( self.myTrackedItem );
	
	damageInterface:=sessionAgent.getMyProxyObject.IF_DamageDetails;
	
	self.tblDamage.setProxyFromTable( damageInterface, errors, damageLC );
	
	if sessionAgent.updateDamages(damageInterface, null, 3) then
		return true;
	endif;
	
	if errors &lt;&gt; null then
		app.beep();
		self.msgBox(errors,app.getErrorString(Error),MsgBox_OK_Only, false);
	endif; 
	
	return false;
	
epilog

	sessionAgent.setMyProxy(null);
	app.mousePointer := self.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTryTrunacteAndHookCode" id="1c4e9709-d04f-4e1b-a3c6-51a63a21cb29">
        <source>doTryTrunacteAndHookCode( tiArray : CM_TIArray input; rawUserStr : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160/4238

*/

vars

	term : CM_Terminal;
	voyage : CM_Voyage;
	cargoId : String;
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	cmif : CMIF_IDConversion;
	processedText : String;

begin

	term := self.myMobileDataAgent.myTerminal;
	voyage := self.myMobileGenericAgent.myVoyage;
	
	cargoId := rawUserStr;
	cargoIdLength := cargoId.length;	
	cargoIdReversed := cargoId.reverse;	
	
	// Use the last 6 characters "for a reverse id search". (I.e a partial match)
	if voyage &lt;&gt; null and cargoIdLength &gt;= 6 then
	
		cargoIdReversed := rawUserStr.reverse[1:6].trimBlanks; // first 6 chars of the reversed scanned value
		cargoIdLength := cargoIdReversed.length; // Not necessarily 6, because we might have trimmed a space
												// that was previously embedded but was on the end after
												// the truncation
		firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
	endif;
	
	if tiArray.isEmpty then
		//Still nothing
	
		create cmif transient;
		cmif.myTerminal := term;
		cmif.myVoyage := voyage;
		cmif.scannedValue := rawUserStr;
		cmif.isAlternateId := false;
		cmif.callerName := self.class.name;
	
		processedText := app.convertScannedCargoId( null,  null, false, cmif );
		
		if processedText &lt;&gt; rawUserStr then	// because no point in trying it if its not different
		
			//OK we have something that has potentially had some suffix crap taken off the end
			cargoId := processedText;
			cargoIdLength := cargoId.length;	
			cargoIdReversed := cargoId.reverse;
			//try an exact match against the hook code processed text.
			if voyage &lt;&gt; null then
				firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
				if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
					iter := voyage.allOnshipTIsByIdCargoType.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
			
				//Try a reverse id match against the hook code processed text.
				if tiArray.isEmpty then
					firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
					if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
						iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
						iter.startAtObject(firstTi);
						while iter.next( ti ) do
							if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
								break;
							endif;
							tiArray.addExclusive(ti);
						endwhile;
						delete iter;
					endif;
					
				endif;
			
			else	// No voyage selected
				firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
				if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
					iter := term.allOnsiteTIsByIdCargoType.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
			endif;
			
		endif;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="rawUserStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doUpdateAlternateId" id="dc088cab-f7e8-4b60-9e35-93c66f85e7e6">
        <source>doUpdateAlternateId( _ti : CM_TrackedItem; _rawUserStr : String ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160/4238

*/

vars

	pxyTi : CM_TrackedItem;
	load : Boolean;
	result : Integer;

begin

	app.cmsBeginLoad(load);
	pxyTi := _ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	pxyTi.zSetPxyAlternativeId( _rawUserStr );
	
	app.myPassport.clearErrorsWarnings();
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			break;
		elseif not app.myPassport.noErrors then 
			app.beep;
			app.showErrorWarningDialog('Alternate Id Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			app.beep;
			result := app.showErrorWarningDialog('Alternate Id Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	return true;

epilog

	app.cmsEndLoad(load);
	delete pxyTi;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_rawUserStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="7d16bc3a-b88a-4955-b205-354ee65510ed">
