    <JadeMethod name="validateLCsHaveSameParent" id="b3c63fc0-f7fa-4c3d-b517-c4b516702189">
        <source>validateLCsHaveSameParent() protected;
/*
------------------------------------------------------------------------
Created:			02 December 2003 by cnwdwq1
Purpose:			Checks that all of the LC's in this moveTo have the same parent 
							(i.e, not one on a wagon, and one in the yard!)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	lcParent : CM_Object;
	lc : CM_LocationsController;
begin
	foreach lc in self.allToLocations do
		if lcParent = null then
			//Set it first up
			lcParent := lc.getParent();
		else
			if lcParent &lt;&gt; lc.getParent() then
				app.setContinueCMExceptions(false);
				app.raiseCMException(Err_MoveDifferentParents, null, null);
				return;
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateMove" id="34fcc620-f7fa-4242-8045-69dc1cb3082f">
        <updating/>
        <source>validateMove( _passport : CM_Passport input ) updating, protected;
/*
 ------------------------------------------------------------------------
Created:			08 January 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing

Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
26 Sep 2008		consw1			PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
03 Jun 2010		cnwkpd1			PAR #24368 - Stops evaluation performance changes
02 Nov 2010     cnwrs1          par 26165 - add stop prevent check for planning move against voyage planning
23 Nov 2010		cnwrl1			PAR 26381 - Only do the stop prevention if doing Load Voyage Planning (see above PAR).
22/06/17		cnwns1 			TFS 4672	:C3 - Fix for Tickets 4206 and 3851
26 Mar 2019		jlgdap1			TFS 43994 C3 Cannot Load Logs to Voyage
29 May 2019		jlgdap1			TFS 44981 C3 Cannot Transfer Logs
14 Sep 2022		navkc1			Bug 54650: C3L-Unable to load logs to voyage
21 Oct 2024		navbs1  		Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
---------------------------------------------------------------------------
*/
vars
	wle 				: CM_WorkListEntry;
	tmpToLC				: CM_LocationsController;
	tmpTi				: CM_TrackedItem;
	origTi				: CM_TrackedItem;
	numPlanFM, fmType	: Integer;
	ti					: CM_TrackedItem;
	firstStopTable		: CM_StopsTable;
	firstStop			: CM_Stops;
	allStops			: CM_StopsByIdDict;
	invalid				: Boolean;
	roroCont			: CM_RoRoController;
	cargoLength			: Real;
	bol					: CM_BOL;						// TFS 43994
	otherTI				: CM_TrackedItem;				// TFS 43994
	differentTarget		: Boolean;
	matches : Integer;
begin

	// ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
	app.setMoveController(self);
	
	// ### TFS 52572 21Jan2022 NAVPW1
	if self.isLogMovement then
		app.setContinueCMExceptions(true);
	endif;
	// ### TFS 52572 21Jan2022 NAVPW1
	
	self.setMyToSecondaryLocations(null); // PAR 8995. clear out 2nd location controller.
	//-------------------
	//Validate the data 1st
	//-------------------
	ti := self.myTrackedItem;
	if ti = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tracked Item', null, null);
		app.raiseCMException(Input_required_field_trkdItem, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// PAR 19913
	if (ti.isInTransitOnShip and ti.isOnWagon())  // OR TRAIN PAR 21148
	and ti.myPrimaryActualLocation &lt;&gt; null 
	and self.myToPrimaryLocation &lt;&gt; null then
		if ti.myPrimaryActualLocation.class &lt;&gt; self.myToPrimaryLocation.class then
			if not ti.myPrimaryActualLocation.isSwapStack and not self.myToPrimaryLocation.isSwapStack then
				app.raiseCMException(YOU_NO_SHIFT_DA_CARGO,  null, null);
				return;
			endif;
		endif;
		
	endif;
	
	tmpToLC := self.myToPrimaryLocation;
	if tmpToLC &lt;&gt; null then
		
		if (not tmpToLC.isKindOf(CM_LogVoyageController)) then
			if self.myToTerminal = null and self.isUndoMove = false then
				app.setContinueCMExceptions(false);
			//	app.raiseCMException1(REQUIRED_FIELD, 'To Terminal', null, null);
				app.raiseCMException(Input_required_field_toTerm, null, null); // cnwdb2	PAR 35364
			endif;
		endif;
	endif;
	
	if self.moveMode = REAL_MODE and self.isUndoMove then
		//We CANNOT operate an undo in REAL_MODE (yet)
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return;
	endif;
	
	if self.moveMode = QUEUE_MODE 
	and self.isJobShipLoad()
	and ti.site = TI_SITE_ONSHIP
	and self.isRehandleMove then
		app.raiseCMException1(ERR_DLR_NOTQUEUED_CARGO_ONSHIP, ti.id, null, null);
		return;
	
	endif;

	// PAR 17839 - the user has planned the DLR discharge into the yard, they have switched to planned view, 
	//					then in the yard they have drag dropped in planned mode the container to a different location. 
	//					This was creating a load DLR future planned move!
	if self.isRehandleMove and (self.moveMode = PLANNING_MODE) 
	and not self.isUndoMove then // PAR 19762 do not do this if we are unplanning
		if ti &lt;&gt; null then
			if ti.isOnShip() // is on Ship
			and (ti.allPlannedFutureMoves.size = 1 and ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge) &lt;&gt; null) // Only has 1 futureMove and it is the DLR Discharge i.e. does not have a DLR Load
			and self.myToPrimaryLocation.isYardLocation() then // Planning to the YARD. NO!!! only the DLR Discharge plans to the yard the DLR load plans to the ship!
				app.raiseCMException1(ERR_DLR_CANNOT_PLAN_TO_YARD, ti.id, null, null);
				return;
			endif;
		endif;
	endif;

	//------------------
	//Test to ensure the TI is not already in the intended spot
	//------------------
	if ((self.moveMode = REAL_MODE) or (self.moveMode = QUEUE_MODE)) 
	and (tmpToLC &lt;&gt; null) 
	and (not tmpToLC.isKindOf(CM_LogVoyageController))
//	  (not tmpToLC.isKindOf(CM_VehicleController)) and	//this allows a move to the current vehicle - causes a problem in RoadOps window with drag drop to same line ??
	and (not tmpToLC.isKindOf(CM_VoyageController)) 
	and (not tmpToLC.isKindOf(CM_BoxcarWagonController))
	and (ti.getPrimaryLocation(REAL_MODE) = tmpToLC) 
	and (not self.isForcedMove) 
	// CCMS 1577	
	and (not ti.isMultiQueued()) then //cnwth2 - if forced, move it to same pos - need this for changing TI size
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_HERE, ti.id, tmpToLC.getID(), null, null);
		return;	
	endif;
	
	//cnwns1 22/06/17	TFS 4672:C3 - Fix for Tickets 4206 and 3851
	if (tmpToLC.isKindOf(CM_LogController) and ti.isKindOf(CM_Log))
	and ((self.moveMode = REAL_MODE) or (self.moveMode = QUEUE_MODE)) 
	and (tmpToLC &lt;&gt; null) 
	and (ti.getPrimaryLocation(REAL_MODE) = tmpToLC) then
		if self.isLogMovement then // ### TFS 52572 21Jan2022 NAVPW1
			app.raiseCMException2(ERR_ALREADY_HERE, ti.id, tmpToLC.getID(), null, null); // ### TFS 52572 21Jan2022 NAVPW1
		else // ### TFS 52572 21Jan2022 NAVPW1
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_ALREADY_HERE, ti.id, tmpToLC.getID(), null, null);
			return;	
		endif; // ### TFS 52572 21Jan2022 NAVPW1
	endif;	
	
	// TFS 43994 Prevent drag-drop in cargo enquiry messing up partially-compete log dockets
	// Log Dockets are special - the first log in the docket's collection of logs
	// is used as the TI for validation purposes. But if we have a log docket that has been 
	// partially loaded to a ship, and the first log has been loaded, then the first log
	// won't be "here" but some of the rest of the logs could be. We have to check them all.
	if ((self.moveMode = REAL_MODE) or (self.moveMode = QUEUE_MODE)) 
	and tmpToLC &lt;&gt; null and not tmpToLC.isKindOf(CM_LogVoyageController)
	and not (tmpToLC.isKindOf(CM_SkeletonCarWagonController) or tmpToLC.isKindOf(CM_BoxcarWagonController))		// 7/9/19 MAP
	and self.allTISets.isEmpty 						// TFS 44981 allTISets will be populated if we're doing a move from the Logs Transfers screen
	and ti.isKindOf(CM_Log) then					// In this case we don't want this check, as the logs are moved in groups of 100, so once the
		if ti.myReceivalBOL &lt;&gt; null then			// first 100 have been moved, some of the logs in the BOL will be in the target location
			bol := ti.myReceivalBOL;
		elseif ti.myReleaseBOL &lt;&gt; null then
			bol := ti.myReleaseBOL;
		endif;
		if bol &lt;&gt; null then
			// 14/09/2022	navkc1	#54650 Starts
			// While off loading the logs from the OffLoad screen, the CMIF_MoveController.allOtherTrackedItems collection will be empty
			// While drag &amp; droping the log dockets in Cargo Enquiry screen, we have the logs in CMIF_MoveController.allOtherTrackedItems collection.
			// After discussion with team, we are using the CMIF_MoveController.allOtherTrackedItems collection to determine where is the operation from and how to handle them
			if self.allOtherTrackedItems.isEmpty() then
				// 14/09/2022	navkc1	#54650 
				// When it's empty, the operation is from OffLoad screen, use the logic from TFS45819
				foreach otherTI in bol.allTrackedItems discreteLock do
					if otherTI.getPrimaryLocation(REAL_MODE) &lt;&gt; tmpToLC then		// 31/7/19 MAP TFS45819	Don't raise exception unless ALL logs are already in target location
						differentTarget := true;
						break;
					endif;
				endforeach;
				if not differentTarget then
					app.setContinueCMExceptions(false);
					app.raiseCMException2(ERR_ALREADY_HERE, bol.number, tmpToLC.getID(), null, null);
					return;
				endif;
			else
				// 14/09/2022	navkc1	#54650 
				// When it's NOT empty, the operation is from enquiry screen, use the logic from TFS 43994
				foreach otherTI in bol.allTrackedItems discreteLock do
					if otherTI.getPrimaryLocation(REAL_MODE) = tmpToLC then
						app.setContinueCMExceptions(false);
						app.raiseCMException2(ERR_ALREADY_HERE, bol.number, tmpToLC.getID(), null, null);
						return;
					endif;
				endforeach;
			endif;
			// 14/09/2022	navkc1	#54650 Ends
		endif;
	endif;
	// TFS 43994 end
	
	if self.myPassport = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, "Passport", null, null);
		app.raiseCMException(Input_required_field_passport, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.userCode.trimBlanks = null then
		app.setContinueCMExceptions(false);
//		app.raiseCMException1(REQUIRED_FIELD, "User Code", null, null);
		app.raiseCMException(Input_required_field_userCode, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// PAR 8072 - APR2004AKB added this replan code.
	if self.moveMode = PLANNING_MODE and (self.isReplan) and (not self.isSystemMove) then
		//07 July 2013	NDL	Par 31559
		if self.myWorkListEntry.isKindOf(CM_VoyageWLE) then
			if self.myWorkListEntry.CM_VoyageWLE.isTwinLift then
				if self.myWorkListEntry.job &lt;&gt; null then
					app.raiseCMWarning2(Replan_twinlift_needs_job_save, ti.id, self.myWorkListEntry.job.id, null, null,self.myTrackedItem);
				endif;
			endif;
		endif;
		app.raiseCMWarning2(WARN_REPLAN_CONFIRM, ti.id, tmpToLC.getFullId(), null, null,self.myTrackedItem);
	endif;
	if self.moveMode = QUEUE_MODE and (self.isReQueue) and (not self.isSystemMove) then // PAR 19600
		app.raiseCMWarning2(Sure_thatyou_wantto_requeu, ti.id, tmpToLC.getFullId(), null, null,self.myTrackedItem);

	endif;
	
	//28 Jan 2011	NDL	Par 26315
	if app.myPassport.myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "app.myPassport.myTerminal is null", null, null);
	endif;
	
	if app.myPassport.myTerminal.getConfig(ReadyToShipPlanning).Boolean then	
		if self.moveMode = PLANNING_MODE and not self.isFullyUnplan and not self.isEDIMove then
			// CCMS 1077 10/09/2007 AER - remove ready to ship warnings for DLR's
			if not (self.myTrackedItem.isSOB or self.myTrackedItem.isRehandle) then
				if not self.myTrackedItem.readyToShip and (tmpToLC &lt;&gt; null and tmpToLC.isKindOf(CM_SlotController)) then
					app.raiseCMWarning1(ERR_TI_NOT_READY_TO_SHIP, self.myTrackedItem.id, null,  null, self.myTrackedItem);
				endif;
			endif;
		endif;
	endif;

	// AKB2003 DEC 07 ADDED to limit number of planned moves.
	if self.moveMode = PLANNING_MODE
	and not ti.isTranshipExport()
	and not (self.isFullyUnplan or self.isUndoMove or self.isReplan or self.isSystemMove) then
// PAR 37282		numPlanFM := ti.allPlannedFutureMoves.size;
// PAR 37282		if numPlanFM &gt; 0 then
			if ti.isRehandle then
				fmType := self.determineFutureMoveType();
				if fmType &lt;&gt; TI_FutureMoveDLRDischarge and fmType &lt;&gt; TI_FutureMoveDLRLoad then
					app.raiseCMException1(ERR_DLR_ONLY_DISCHARGE_OR_MOVE, ti.id, null, null);
					return;
				elseif numPlanFM = 2 then
					app.raiseCMException1(ERR_DLR_FULLY_PLANNED, ti.id, null, null);
					return;
				endif;
			endif;
// PAR 37282		endif;
	endif;
	
	// If the we are doing discharge voyage planning then do not need to check the Voyage Planning Stops
	if self.moveMode = PLANNING_MODE and
	   self.isJobShipLoad() then
		app.myPassport.setContext(Context_Pass_CUST_FullyCleared); // ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1		//21.10.2024  navbs1  #14791
		ti.checkStopsToBePrevented(StopPreventVoyagePlanning, null, true);			
		app.myPassport.setContext(Context_Pass_Null); // ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1					//21.10.2024  navbs1  #14791
		//cnwjo3 par 20262
		 //cnwjo3 par 23103.  New condition.  Are we trying to plan onto a ship?  if not then don't raise warning...
		if self.isUndoMove = false then  //don't need to verify if stops presents for undo move at this time
			if self.myTrackedItem.isNotified() then  //is the ti a pre-notified container
				create allStops transient;
				self.myTrackedItem.getAllActiveStops(allStops);
				if not allStops.isEmpty() then														// PAR #24368
					// I am sure there are better ways to do this but this replicate was is done above!
					firstStop		:= allStops.first();
					firstStopTable	:= app.myRoot.allStopsTable[firstStop.id];
					if firstStopTable &lt;&gt; null then  //check that stop still exists....
						app.raiseCMWarning3(WARN_TI_HAS_STOP,
											"Error: ",
											self.myTrackedItem.id,
											firstStopTable.heading,
											null,
											null, 
											null);
						return;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	wle := self.myWorkListEntry;
	if wle &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,wle,invalid);  //cnwjo3 par 20258
		wle.validateForMove(self, _passport);	
		if not invalid then //cnwjo3 par 20258
			//jlier1 TFS 56772 21/3/23 - if you have warnings that are not acknowledged you still want to do the validation further down that might be an error
			if _passport.hasErrors then
				return;
			endif;
		endif;
	endif;

	//-------------------
	//Lock up
	//-------------------
	self.doTILock();

	//-------------------
	//now validate the actual move itself. We ask the TI to ask its intended controllers if its ok.
	//-------------------
	ti.validateMove(self);
	
	// Validate all other TI first otherwise the rest are never validated
	if (not self.allOtherTrackedItems.isEmpty) then
	
		if not self.isShiftMove // PAR 18682
		and (tmpToLC &lt;&gt; null and  (not tmpToLC.canReceiveBulkMove)) then
			app.raiseCMException1(VB_BULK_MOVE, tmpToLC.getFullId, null, null);
			return;
		endif;
		
		// Need to do the validation for all the other TI's

		origTi := ti;
		foreach tmpTi in self.allOtherTrackedItems do
			//jlier1 TFS 56772 21/3/23 
			if _passport.hasErrors and _passport.allErrors.includesErrorCode(ERROR_RoRoLaneNoFit) then
				continue;
			endif;
			
			self.setMyTrackedItem(tmpTi);
			
			// ### TFS 52572 21Jan2022 NAVPW1
			if self.isLogMovement and (tmpTi.getPrimaryLocation(REAL_MODE) = tmpToLC) then 
				app.raiseCMException2(ERR_ALREADY_HERE, tmpTi.id, tmpToLC.getID(), null, null);
			endif; // ### TFS 52572 21Jan2022 NAVPW1
			
			tmpTi.validateMove(self);
			// Validate all other TI first so that all errors/warnings are shown
			// otherwise the rest are never validated			
		endforeach;
		self.setMyTrackedItem(origTi);
		
		if tmpToLC.isKindOf(CM_RoRoController) then		// TFS 2822 cnwmp6 31/10/16
			roroCont := tmpToLC.CM_RoRoController;
			if not roroCont.canFitCargo(self.myTrackedItem, false, null, self, cargoLength) then
				app.raiseCMException3(Lengt_selec_cargo_items_stand_, cargoLength.String, roroCont.spareLengthActual.max(0).String, roroCont.id, null, null);
			endif;
		endif;
	endif;
	
	if _passport.hasErrors then //jlier1 TFS 54703 22/9/22 if the passport has warnings to ignore stopping if there is warnings does not work
		return;
	endif;

	//----------------
	//Check we have enough locations to do the move PROPERLY
	//(the +1 is for the primary location)
	//----------------
	if tmpToLC = null then
		return;
	endif;
	
	if self.numExpectedLCs &gt; self.allToLocations.size then
		//--------------------
		//Not enough LC's in collection to do the move to! STOP
		//--------------------
		app.setContinueCMExceptions(false);
		app.raiseCMException(Err_Insufficient_Locns, null, null);
		return;
	endif;
	
epilog
	delete allStops;
	if origTi &lt;&gt; null then
		self.setMyTrackedItem(origTi);
	endif;
	// ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
	app.setMoveController(null);
end;
</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRelease" id="ae7a69e7-6f4f-45a1-8760-266279cbb982">
        <updating/>
        <source>validateRelease()updating, protected;
// FD for validate Road Release jobs(ISO ,TI release from VB)
// in V6,these checkings are scattered acorss getMoveTarget;actionMoveTarget;etc
// Now we centralize them first to see how it goes. We might consider delegating 
// the validation down to the specfic request types. 
// I Only expect this method to be called on Road Releases in CMIF_MoveController::ValidateMove 
// So some flag may be needed in CMIF_MoveController to decide whether to call this method. 
vars
	request : CM_Request;
	requestType : Integer;
begin
	if self.myWorkListEntry = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, 'WorkListEntry', null, null);
		app.raiseCMException(Input_required_field_wrkLstEnt, null, null); // cnwdb2	PAR 35364
	endif;
	if self.myWorkListEntry.job.isKindOf(CM_RoadJob) = false then
		return;
	endif;
	request :=  self.myWorkListEntry.myRequest; 
	if request = null then
		return;
	endif;
	if (request.isKindOf(CM_TIRequest) = false and request.isKindOf(CM_DeliveryRequest) = false) then
	    return;  // At the moment only validate ISO and TI releases
	endif;
	
	requestType := self.myWorkListEntry.getRequestType();
	if self.myWorkListEntry.status = WLE_UNACTIONED then
		if requestType = REQ_ISO_RELEASE then
			if self.moveMode = QUEUE_MODE then
				app.raiseCMException(VB_MOVE_INVALID,null,null);
			endif;
			if self.moveMode = PLANNING_MODE then
				app.raiseCMException(VB_MOVE_INVALID,null,null);
			endif;
			if self.moveMode = REAL_MODE then
				
			endif;
		elseif requestType = REQ_TI_RELEASE then
			if self.moveMode = QUEUE_MODE then
		
			elseif self.moveMode = PLANNING_MODE then
				//app.raiseCMException(VB_MOVE_INVALID,null,null);
			elseif self.moveMode = REAL_MODE then
		
			endif;
		elseif requestType = REQ_TI_RECEIPT then
			if self.moveMode = QUEUE_MODE then

			elseif self.moveMode = PLANNING_MODE then
				//app.raiseCMException(VB_MOVE_INVALID,null,null);
			elseif self.moveMode = REAL_MODE then
			
			endif;
		endif;

	endif;
	
	
		
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
