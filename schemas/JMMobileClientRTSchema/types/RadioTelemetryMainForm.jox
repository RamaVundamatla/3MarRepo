    <JadeMethod name="doQueueEntriesTableClick" id="50e03db0-87b5-4dba-902f-f38d7aa25695">
        <updating/>
        <source>doQueueEntriesTableClick() updating, protected;

/*

Purpose:			Handle selection of required Queue Entry by attempting to accept the real
					Queue Entry stored as the row object of the selected row


Return Value:		None


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	table			: Table;
	tableRow		: JadeTableRow;
	queueEntry		: Object;
	
begin
	table := self.tblQueueEntries;
	
	if table.row &gt; table.fixedRows then
		tableRow := table.accessRow(table.row);
		
		queueEntry := tableRow.itemObject;
		if queueEntry &lt;&gt; null then
			// Try and Accept the selected Queue Entry
			self.doAcceptSpecificTask(queueEntry);
		endif;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRejectTask" id="cd4f6dda-72e9-41da-a14e-07fa55c9265a">
        <updating/>
        <source>doRejectTask() protected, updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;
	
begin
	if self.aIsOnHold then
		return;
	endif;
	
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.rejectTask(self.aState, errorStr, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else
			self.updateFromState();
		endif;
		
		break;
	endwhile;
	
	return;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRequestTask" id="07d254f7-001f-4f18-b6a6-43a791787fb5">
        <updating/>
        <source>doRequestTask(_automatic : Boolean) protected, updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;
	
begin
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.requestTask(self, errorStr, self.aState, self.aWarnings) and not _automatic then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else
			self.updateFromState();
		endif;
		
		break;
	endwhile;
	
	return;
end;</source>
        <access>protected</access>
        <Parameter name="_automatic" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResetFromOnHold" id="939a8eff-ab14-4298-8395-fb9bfdd5ea5b">
        <updating/>
        <source>doResetFromOnHold() : Boolean updating, protected;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;

begin
	if not app.msgBox(	'Do you wish to return to the held queue entry?',
						'Recover', 
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		return false;
	endif;
	
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.resetFromOnHold(self, self.aState, errorStr, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else	
			self.updateFromState();
			return true;
		endif;
		
		break;
	endwhile;
	
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResetSession" id="f3bcc644-5692-4c7d-8abe-25af8ab5476c">
        <updating/>
        <source>doResetSession() protected, updating;
// -------------------------------------------
// Created 26 January 2006 by cnwdvb1
// -------------------------------------------
vars

	errorString : String;

begin

	if not app.msgBox('Do you wish to reset the session?', 'Reset Session',  MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes then
		return;
	endif;
	
	if not app.myRTGuiAgent.resetMediator(self.aClientConnectionDetails, self.aState, self.aResetState, errorString, self.aLastTs) then
		self.showMessage(errorString, true);
	else
		self.setOnHoldBtn(false);
	endif;
	
	self.updateFromState();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearchResultsTableClick" id="f0d4ad18-9004-42b0-92bf-3881d0a8ba62">
        <updating/>
        <source>doSearchResultsTableClick() updating, protected;

/*

Purpose:			Handle selection of required Container by passing the container
					id from the selected row to the doEnqTrackedItem method


Return Value:		None


Date		Who		Reason
06 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	containerID		: String;
	table			: Table;
	ti, overstowTi	: CM_TrackedItem;
	
begin
	table := self.tblContSrchRes;
	
	if table.row &gt; table.fixedRows then
		containerID := table.getCellText(table.row, 1);
		self.txtContainerID.text := containerID;
		
		self.doEnqTrackedItem();
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetdown" id="17a13ad6-e2f9-4441-a6d3-4112b247d23d">
        <updating/>
        <source>doSetdown() protected, updating;
// -------------------------------------------
// Created 18 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr	: String;
	tandemTIid	: String;
	
begin
	if aMachineLiftType = TANDEM_LIFT then
		tandemTIid := self.txtContainerID2.text;
	endif;
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.setdown(self.txtNewLocation.text,  tandemTIid, self, errorStr, self.aState, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else
			self.updateFromState();
		endif;
		
		break;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
