    <JadeMethod name="getAuditTALocationDetails" id="4eb60744-b230-46f6-939b-53c85aab1b89">
        <source>getAuditTALocationDetails() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	str, text : String;
	hours, minutes : String;
	
begin
	text := self.id &amp; ", " &amp; self.myTerminalArea.id;
	return text;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazTempRangesDisplay" id="969ad028-188b-4116-b66b-a02983225130">
        <source>getHazTempRangesDisplay() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazTempRange : CM_HazTempRange;
	str : String;

begin
	foreach hazTempRange in self.allHazTempRanges do
		if str = null then
			str := hazTempRange.getDisplayDetails(false);
		else
			str := str &amp; Comma &amp; Space &amp; hazTempRange.getDisplayDetails(false);
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPackingGroupsForDisplay" id="37db9f2a-691d-4f25-8215-1186ef691299">
        <source>getPackingGroupsForDisplay() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/122/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	str, group : String;

begin
	foreach group in self.packingGroups do
		if str = null then
			str := group;
		else
			str := str &amp; Comma &amp; Space &amp; group;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1ce818ac-90d2-42ff-acfa-87c534579845">
        <updating/>
        <source>setForCreate(_pxyHazDetail : CM_TerminalAreaHazDetails) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	self.id := _pxyHazDetail.id;
	self.colour := _pxyHazDetail.colour;
	self.myHazardClass := _pxyHazDetail.myHazardClass;
	self.allHazTempRanges.clear;
	_pxyHazDetail.allHazTempRanges.copy(self.allHazTempRanges);
	self.acidBase := _pxyHazDetail.acidBase;
	self.packingGroups.clear;
	_pxyHazDetail.packingGroups.copy(self.packingGroups);
	self.allowNonHazardous := _pxyHazDetail.allowNonHazardous;
	self.showError := _pxyHazDetail.showError;
	_pxyHazDetail.allLocationsControllers.copy(self.allLocationsControllers);
	
	self.myTerminalArea := _pxyHazDetail.myTerminalArea;
epilog

end;</source>
        <Parameter name="_pxyHazDetail" type="CM_TerminalAreaHazDetails"/>
    </JadeMethod>
