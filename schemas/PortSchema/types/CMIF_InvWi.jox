    <JadeMethod name="initializeForActivity" id="8d478540-74fc-4609-a0b3-d398de377c1a">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
30 Aug 2021 navpw1 ChangeRequest 51853: MTN - Opsview Container - Gate
*/

vars
	wle : CM_WorkListEntry;
begin
	inheritMethod(_any, _ewsOpsView);
	
	self.tableName 			:= self.Inv_wi;

	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey                       := self.generateFullGKey(_any, "").Integer64;
		
		self.move_stage		 			:= "PLANNED";
		return;
	endif;
	
	wle := _any.CM_WorkListEntry;
	
	wle.initializeForActivity(_ewsOpsView, self); // ### TFS 53569 10MAY2022 NAVAB1

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
    <JadeMethod name="initializeForDelete" id="bbd295f9-b2e4-40d6-8015-a7b84d7baa47">
        <updating/>
        <source>initializeForDelete(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
30 August 2021	navab1	TFS 51853
*/

vars

begin
	if _any.isKindOf(CM_WorkListEntry) then // ### TFS 51853 27AUG2021 NAVAB1
		if _any.CM_WorkListEntry.job = null then // ### TFS 51855 03FEB2022 NAVAB1 job is being deleted
			self.move_stage		 			:= "CANCELLED"; // ### TFS 51855 03FEB2022 NAVAB1
		
		elseif _any.CM_WorkListEntry.job.isRoadJob() then // ### TFS 51853 27AUG2021 NAVAB1
			self.move_stage		 			:= self.n4MoveStage(_any);  // ### TFS 53569 12MAY2022 NAVAB1       mapper(_any,CMIF_InvWi::move_stage.name).String;
		else
			self.move_stage		 			:= "PLANNED"; // ### TFS 51853 27AUG2021 NAVAB1
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
