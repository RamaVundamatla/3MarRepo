    <JadeMethod name="doSave" id="4dd6bf48-3ca3-47fa-b5a9-8820df1389c1">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errObj							: CM_Error;
	idx								: Integer;
	tmpListBox						: ListBox;
	ignoreWarnings,rtnValue,
	isNotAvailableForEntry			: Boolean;
	proxyShippingAgent				: CM_ShippingAgent;
	lCode,lDescription				: String;
	theForm 						: SOP_TableMaintForm;
begin
  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ShippingAgent transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyShippingAgent := theForm.myProxyObject.CM_ShippingAgent;
	proxyShippingAgent.setProxy(lCode, lDescription,isNotAvailableForEntry);
	proxyShippingAgent.allContacts.clear();
	theForm.mulSelect1.getSelected(proxyShippingAgent.allContacts);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateShippingAgent(proxyShippingAgent, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateShippingAgent(proxyShippingAgent,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
