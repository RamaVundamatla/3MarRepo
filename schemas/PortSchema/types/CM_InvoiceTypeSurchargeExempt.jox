	else
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Minimum vessel secondary vessel is not found", LogINFO.String);
		endif;
	// End - 1.3.2023 navmk20 TFS 56140
	endif;
	
	return vessMinCharge;

epilog

end;</source>
