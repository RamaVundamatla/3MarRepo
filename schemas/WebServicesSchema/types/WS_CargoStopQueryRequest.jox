<Class name="WS_CargoStopQueryRequest" id="a304bb4c-b69d-4f63-a8a3-253b41898908">
    <superclass name="WS_CargoEventQueryRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="stops" id="4ccd2931-f984-4b6f-9e16-0a9e88ad1758">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="stops" id="85f3bcaa-15f1-4f5e-a8a9-44a0366514d6">
        <methodInvocation>mapping</methodInvocation>
        <source>stops(set : Boolean; _value : String io) mapping;

/*

Purpose: Mapping method to create stop request objects			

Parameters:			

Return Value:		


Date		Who		Reason
16 Feb 2009 cnwdz2 
*/

vars
	requestTypes: StringArray;
	str:		String;
	reqType:	WS_Stop;
begin

	if set then
		create requestTypes transient;
		_value.getTokensForDelimiter("|", requestTypes);
		foreach str in requestTypes do
			create reqType transient;
			reqType.id := str.Integer;
			allStopTables.add(reqType);
		endforeach;	
	endif;	
epilog
	delete requestTypes;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
