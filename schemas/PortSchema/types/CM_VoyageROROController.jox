    <JadeMethod name="getMyFutureTIs" id="de8799d6-e05e-4254-be40-2a506e316947">
        <source>getMyFutureTIs(_currentTIs : CM_TIArray input) protected;
//----------------------------------------------------------------
//	Created:	25 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
04 Jun 2010	cnwkpd1	PAR #24281 - Speed up Planning performance

*/

vars
	tis			: CM_TIArray;
	allWLETIs	: CM_TISet;			// Changed from Array to Set to speed up includes and remove
	sr			: CM_RORORequest;
	ti			: CM_TrackedItem;
	fm			: CM_FutureMove;
	include		: Boolean;
begin
	// we want to allow for the following scenarios (however unlikely or impossible):
	// discharge
	// load
	// discharge - load
	// load - discharge
	// discharge - load - discharge
	// etc
	
	
	create tis transient;
	create allWLETIs transient;

	foreach sr in self.allRequestsDischarge do
		sr.getAllUnworkedTIs(tis);	// get TI's with uncompleted wle's (they will be discharge wle's)
	
		foreach ti in tis do
			if not allWLETIs.includes(ti) then
				allWLETIs.add(ti);
			endif;
		endforeach;
	endforeach;

	foreach sr in self.allRequestsLoad do
		sr.getAllUnworkedTIs(tis);	// get TI's with uncompleted wle's (they will be load wle's)
		foreach ti in tis do
			if ti.allPlannedFutureMoves.isEmpty then
				// there is no future move (as it has not been planned yet) so
				// we assume that this is the final target location
				if not _currentTIs.includes(ti) then
					_currentTIs.add(ti);
				endif;
			elseif not allWLETIs.includes(ti) then
				allWLETIs.add(ti);
			endif;
		endforeach;
	endforeach;

	//we now have all TIs to be loaded/discharged to/from this spot 
	//check their final target locn
	foreach ti in allWLETIs do
		include := false;
		foreach fm in ti.allPlannedFutureMoves do
			if not CM_FutureMovePlanned.hasInstance(fm) 
			or CM_FutureMovePlannedEDI.hasInstance(fm) then // PAR 8667 added
				continue;
			endif;
			//global.processDebug("CNWJC2", true);
			if fm.CM_FutureMovePlanned.allLocationsControllers.includes(self) then
				//we have a load
				include := true;
				break; // PAR 9089. if a DLR disch is unplanned and replanned it is then the 2nd FM for this TI so the include is set to false.
			else
				//ti has some other destination
				include := false;
			endif;
		endforeach;

		if include then
			// add TI if not already here	
			if not _currentTIs.includes(ti) then
				_currentTIs.add(ti);
			endif;
		else
			// remove TI if it's here
			if _currentTIs.includes(ti) then
				_currentTIs.remove(ti);
			endif;
		endif;
		
	endforeach;

epilog
	delete tis;
	delete allWLETIs;
end;</source>
        <access>protected</access>
        <Parameter name="_currentTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
