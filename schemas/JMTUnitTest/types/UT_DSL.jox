        <source>deleteISOGroup(_isoGroupId : String);

/*

Purpose:		Delete an iso Group	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	isoGroup			: CM_ISOTypeGroup;
	isoType				: CM_ISOType;
	isoSubTypeGroup     : CM_ISOTypeGroup;

begin

	isoGroup := app.myRoot.allISOTypeGroups[_isoGroupId];
	if isoGroup &lt;&gt; null then
	
		beginTransaction;
		foreach isoType in isoGroup.allISOTypes discreteLock do
			isoGroup.allISOTypes.remove(isoType);		
		endforeach;
		
		foreach  isoSubTypeGroup in isoGroup.allSubstitutingISOGroups discreteLock do
			isoGroup.allSubstitutingISOGroups.remove(isoSubTypeGroup);
		endforeach;
		
		commitTransaction;
		
		
		app.myTrxDA.trxDeleteISOTypeGroup(isoGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_isoGroupId" type="String"/>
    </JadeMethod>
