    <JadeMethod name="initialiseHatchManApp" id="910fb732-391e-434f-a79a-2511ae7feb50">
        <updating/>
        <source>initialiseHatchManApp() updating;
vars
	msg : String;
	form : Form;
begin
	self.initialize;
	self.getTerminalRTDeviceOpenMax(HandHeldAppIniFileSection, null);			// 31/08/2011 cnwmh5 #28091
	create self.myMobileGUIAgent as MOB_HandHeldAgent;
	create self.myLogonAgent as HandHeldLogonAgent;
	self.myLogonAgent.initWithDevice(null);
	
	//21 June 2012	NDL	Par 29677
	create form as MOB_HandHeldMsgBox transient;
	msg := "'Hatchman' app" &amp; CrLf &amp; "is no longer supported!";
	msg := msg &amp; CrLf &amp; "Please use the" &amp; CrLf &amp; "'Loading MTs to Vessel' option";
	msg := msg &amp; CrLf &amp; "in the 'HandHeld' app";
	form.MOB_HandHeldMsgBox.setMessage(msg, "Error", MsgBox_OK_Only);
	form.showModal();
	terminate;
	return;
	
	self.myMobileGUIAgent.setHomeForm(MOB_HandHeldSelectVoyageForm);
	self.myMobileGUIAgent.setHelpDescription(CrLf &amp;
			'Function Keys' &amp; CrLf &amp; CrLf &amp;
			'F1 - toggle help' &amp; CrLf &amp;
			'F3 - undo completed slot' &amp; CrLf &amp;
			'F4 - toggle twin lift' &amp; CrLf &amp;
			'F5 - refresh');
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialiseMobileApp" id="f58e06c5-3451-44f7-aa5a-0fc5703ceefa">
        <updating/>
        <source>initialiseMobileApp()updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason
07 Feb 2012	cnwkpd1	PAR #28381 - Update JSM version info correctly in managed environments
	
*/

vars

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	app.niceName := "JMT Mobile";
	app.setupAppVersion();			// PAR #28381
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	on Exception do app.generalExceptionHandler(exception) global;

	self.initialize();
	self.initialiseScreenColours();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseScreenColours" id="6ce4f227-437e-4e95-98ac-167869e25db7">
        <updating/>
        <source>initialiseScreenColours()updating, protected;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
	
17 Jun 10 cnwer1 CCMS 1099 changed to use rt vehicle config	uses day colours
28 Jun 2010	NDL	Par 24802
	
*/

vars
	terminalObj		: CM_Terminal;
	tokenControl	: Label;
	screenConfig	: CM_RTScreenConfig;
begin
	terminalObj	:=	app.getMyTerminalDO_NOT_USE();
	//always uses the terminal config for 
	if terminalObj &lt;&gt; null and terminalObj.myRTVehicleConfig &lt;&gt; null then	//28 Jun 2010	NDL	Par 24802
		screenConfig:=	terminalObj.myRTVehicleConfig.myDayScreenConfig;
	endif;
	
	if screenConfig &lt;&gt; null then	//28 Jun 2010	NDL	Par 24802
		colorBackGeneral	:=	screenConfig.screenBackColour;//getConfig(DefaultRTColorBackground).Integer;
		colorBackTables		:=	screenConfig.tableBackColour; // terminalObj.getConfig(DefaultRTColorTableBack).Integer;
		colorForeGeneral	:=	screenConfig.screenForeColour; //terminalObj.getConfig(DefaultRTColorForeground).Integer;
		colorForeTables		:=	screenConfig.tableForeColour;// terminalObj.getConfig(DefaultRTColorTableFore).Integer;
	endif;
	
	if colorBackGeneral = null and colorForeGeneral = null then
		create tokenControl transient;
		// There was an error fetching the screen colors, so just use the default Windows colors.
		self.colorBackGeneral	:=	tokenControl.getSystemColor(Window.Color_3DFace);
		self.colorForeGeneral	:=	tokenControl.getSystemColor(Window.Color_WindowText);
		self.colorBackTables	:=	tokenControl.getSystemColor(Window.Color_3DFace);
		self.colorForeTables	:=	tokenControl.getSystemColor(Window.Color_WindowText);
	endif;
epilog
	delete tokenControl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialiseVehicleMountedApp" id="b769bbc5-157a-4930-bebe-97f6c413f936">
        <updating/>
        <source>initialiseVehicleMountedApp() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwer1	Initial creation

*/

vars
	errorStr :  String;
begin
	self.initialize();
	
	self.setIsBackGroundApp(true);
	self.isRTApp:=true; //epr par 25190 
	
	self.getTerminalRTDeviceOpenMax("VehicleMountedApp", null);					// 31/08/2011 cnwmh5 #28091

	create self.myLogonAgent as VehicleMountedLogonAgent;
	self.myLogonAgent.initWithDevice(null);
	
	//check this first don't make user type in login details if not setup
	if not self.myLogonAgent.validateRTDeviceDetails(errorStr) then
		if errorStr &lt;&gt; null then
			app.msgBox(errorStr,app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
			terminate;
		endif;
	endif;
	
	if self.myLogonAgent.myTerminal.myRTVehicleConfig = null then
		// give error  need to set up the RT Vehicle Config
		app.msgBox(app.getErrorString(Cannot_start_VehicleRTConfig),app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
		terminate;
	endif;
	
	//epr par 29196 1/3/12
	create self.myVMAgent transient;
	self.myVMAgent.setDetailsFromLogonAgent(self.myLogonAgent.VehicleMountedLogonAgent);
	
	//epr par 33147 6/12/13
	self.myLogonAgent.setMediator(self.myVMAgent.myMediator);
	
	//epr par 26011 14/10/10 if we got errors from binding the mediator these were not handled
	if app.myPassport.hasErrors then
		app.msgBox(app.myPassport.allErrors.first.text,app.getErrorString(Logon_error), MsgBox_Exclamation_Mark_Icon);
			terminate;
	endif;
	
	create self.myHandHeldCheckerAgent transient;	//06 May 2013	NDL	Par 31506
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="98c4dc9e-bb1b-4c95-bedd-e9c820229a03">
        <updating/>
        <source>initialize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2010	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();
	//CCMS 1099 epr 11 June 2008
	app.fontName:="Tahoma"; //On Windows CE  causes crash if displaying anything but Tahoma
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initializeAgents" id="3e443afd-8abe-4226-812f-4e1f658caefd">
        <updating/>
        <source>initializeAgents() updating;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod();
	
	if self.myMobileAgent = null then
		create self.myMobileAgent transient;
	endif;
	
	if self.myMobileGUIAgent = null then
		create self.myMobileGUIAgent transient;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="isOnDevice" id="f5055443-0a28-4b05-b8f8-8bb1a50379ab">
        <source>isOnDevice(): Boolean;
/*

Purpose:			Determine whether or not the current process is running on a CE device

Parameters:			None

Return Value:		True if running on a CE device


Date		Who		Reason
26 Aug 2009 cnwgb1	Initial creation
01 Apr 2011	cnwkpd1	PAR #27039 - Handle exceptions calling getOSPlatform when in reconnect
					state
					
*/

constants
	WindowsCE = 19;

vars
	osPlatform,
	osArchitecture: Integer;
	osVersion : String;

begin
	on Exception do self.handleManagementException(exception);		// PAR #27039
	
	osPlatform	:=	process.getOSPlatform(osVersion, osArchitecture);
	
	if osPlatform = Node.OSWindowsMobile or osPlatform = WindowsCE then
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWarehouseVMTApp" id="6a9a0f68-a941-4688-bb56-436a94fbffcf">
        <source>isWarehouseVMTApp(): Boolean;
/*

Date		Who		Reason
15 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myVMAgent = null then
		return false;
	endif;
	
	return self.myVMAgent.isWarehouseVMT;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="7e941dc4-cede-4dfb-847a-6f28f2bcd752">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
// ---------------------------------------------------------------------------
// Created:     03 April 2008 by cnwaer1
//
// Purpose:     Re-implementation of app.msgBox.
// ---------------------------------------------------------------------------
vars
	msgboxFormObj	: MOB_MsgBoxForm;
	handHeldMsgBox : MOB_HandHeldMsgBox;
begin
	if app.name = HandHeldApp or
		 app.name =VehicleMountedApp or
		 app.name = VehicleMountedWithDevice1 or
		 app.name = HandHeldWithDevApp1 then
		create handHeldMsgBox transient;
		handHeldMsgBox.setMessage(msg, title, flags);
		return handHeldMsgBox.showModal();
	else
		create msgboxFormObj transient;
		msgboxFormObj.setMessage(msg, title, flags);
		return msgboxFormObj.showModal();
	endif;
epilog
	delete msgboxFormObj;
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
