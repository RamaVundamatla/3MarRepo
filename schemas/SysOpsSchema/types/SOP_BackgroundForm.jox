    <JadeMethod name="doShowMenu" id="89d77341-40e9-4459-80fe-4990ff06b886">
        <updating/>
        <source>doShowMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
17 September 2025		navmd1	Initial creation MTN-36066

*/

vars
	menu, clonedMenu,
	subMenuItem, clonedSubMenuItem		: MenuItem;
	clickMethod							: Method;
	startIdx							: Integer;
begin
	menu := self.mnuBackground;
	
	if app.isAllowedToInspect() then
		if self.myBGPObject &lt;&gt; null and self.myBGPObject.isKindOf(BGP_LockKeeperController) then
			startIdx := 1;
			clonedMenu := menu.getMenuItem(startIdx);
			
			if clonedMenu = null then
				clonedMenu := menu.loadMenu(startIdx);
			endif;
			
			foreach subMenuItem in menu.children do
				startIdx += 1;
				clonedSubMenuItem := clonedMenu.getMenuItem(startIdx);
				if clonedSubMenuItem = null then
					clonedSubMenuItem := clonedMenu.loadSubMenu(startIdx);
				endif;
				
				clonedSubMenuItem.caption := subMenuItem.caption;
				clonedSubMenuItem.visible := subMenuItem.visible;
				clonedSubMenuItem.enabled := subMenuItem.enabled;
				clonedSubMenuItem.userObject := subMenuItem.userObject;
				clonedSubMenuItem.setShortCutKey(subMenuItem.shortCutKey, subMenuItem.shortCutFlags);
				clickMethod := subMenuItem.clickMethod();
				if clickMethod &lt;&gt; null then
					clonedSubMenuItem.setEventMappingEx(MenuItem::click, clickMethod);
				endif;
			endforeach;
			
			if clonedMenu.getMenuItem(startIdx+1) = null then
				startIdx += 1;
				clonedSubMenuItem := clonedMenu.loadSubMenu(startIdx);
				clonedSubMenuItem.caption := "-";
				clonedSubMenuItem.visible := true;
				
				startIdx += 1;
				clonedSubMenuItem := clonedMenu.loadSubMenu(startIdx);
				clonedSubMenuItem.caption := "Dump Stats...";
				clonedSubMenuItem.visible := true;
				clonedSubMenuItem.setEventMappingEx(MenuItem::click, SOP_BackgroundForm::doDumpStatsClick);
				
				startIdx += 1;
				clonedSubMenuItem := clonedMenu.loadSubMenu(startIdx);
				clonedSubMenuItem.caption := SOP_BackgroundForm.MenuCaption_IncludeTrx;
				clonedSubMenuItem.visible := true;
				clonedSubMenuItem.checked := true;
				clonedSubMenuItem.setEventMappingEx(MenuItem::click, SOP_BackgroundForm::doClonedMenuClickSpecial);
			endif;
			
			menu := clonedMenu;
		endif;
	endif;
	
	return self.showContextMenu(menu, cntrl, conwin, mouse, x, y);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doStartNotesTimer" id="04038805-023d-4e5b-a3ae-fc2ba0449021">
        <updating/>
        <source>doStartNotesTimer() protected, updating;
/*

Purpose:			Start the time for handling notifications

Parameters:			None

Return Value:		None

Date		Who		Reason
29 Nov 2011	cnwkpd1	PAR #28753 - BGP form performance issues

*/

vars

begin
	if not self.notesTimerStarted then
		self.beginTimer(self.Notify_Timer_Delay, Timer_OneShot, self.Notify_Timer_Event);
		self.notesTimerStarted := true;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartStopButtons" id="667fdf9c-163a-4ec9-8b80-fd9a915ae943">
        <source>doStartStopButtons() protected;

// cnwdvb1 29 October 2002 

vars


begin
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;


	if self.mode = Mode_View then
		if self.myBGPObject = null then
			self.mnuStart.enabled	:= false;
			self.btnStartBGP.enabled	:= false;
			self.mnuStop.enabled	:= false;
			self.btnStopBGP.enabled 	:= false;
			self.mnuEdit.enabled	:= false;
			self.btnEditBGP.enabled := false;
			self.mnuDelete.enabled	:= false;
			self.btnDeleteBGP.enabled	:= false;
			self.mnuView.enabled	:= false;
			self.btnViewBGP.enabled	:= false;
			self.btnAbort.enabled := false;
			self.mnuAdd.enabled		:= true;
			self.btnAddBGP.enabled	:= true;
			self.mnuLogInfo.enabled := false;
			return;
		endif;
			
		if self.myBGPObject.isManager() then
			self.mnuLogInfo.enabled := false;
			self.mnuView.enabled:= false;
			self.btnViewBGP.enabled	:= false;
			self.btnAbort.enabled := false;
			if self.myBGPObject.isRunning() then
				self.btnViewBGP.enabled	:= true;
				self.btnStartBGP.enabled	:= false;
				self.btnStopBGP.enabled 	:= true;
				self.mnuStart.enabled	:= false;
				self.mnuStop.enabled 	:= true;
				self.btnEditBGP.enabled 	:= false;
				self.btnDeleteBGP.enabled	:= false;
				self.mnuEdit.enabled 	:= false;
				self.mnuDelete.enabled	:= false;
				//self.mnuLogInfo.enabled := true; //+ cnwmd1 Par 20497
			
			else
				if self.myBGPObject.BGP_Manager.isRunOnServer then
					self.btnStartBGP.enabled	:= true;
					self.btnStopBGP.enabled	:= false;
					self.mnuStart.enabled	:= true;
					self.mnuStop.enabled	:= false;
				else
					self.btnStartBGP.enabled	:= true;
					self.btnStopBGP.enabled		:= false;
					self.mnuStop.enabled		:= false;
					self.mnuStart.enabled		:= true;
				endif;
				self.btnEditBGP.enabled 	:= true;
				self.btnDeleteBGP.enabled	:= true;
				self.mnuEdit.enabled 	:= true;
				self.mnuDelete.enabled	:= true;
			endif;
		else
			self.mnuDelete.enabled		:= false;
			self.btnDeleteBGP.enabled		:= false;
			if self.myBGPObject.isRunning() then
				self.btnAbort.enabled := true;
				self.btnStartBGP.enabled	:= false;
				self.btnStopBGP.enabled 	:= true;
				self.mnuStart.enabled	:= false;
				self.mnuStop.enabled 	:= true;
				self.mnuLogInfo.enabled := true;
				if self.myBGPObject.BGP_Controller.isEditable then
					self.mnuView.enabled	:= true;
					self.btnViewBGP.enabled	:= true;
					self.btnEditBGP.enabled	:= false;
					self.mnuEdit.enabled	:= false;
				else
					self.mnuView.enabled	:= false;
					self.btnViewBGP.enabled	:= false;
					self.btnEditBGP.enabled	:= false;
					self.mnuEdit.enabled	:= false;
				endif;
			else
				if self.myBGPObject.BGP_Controller.myBGPManager.isRunning() then
					if not self.myBGPObject.BGP_Controller.isSetup then
						self.btnStartBGP.enabled	:= false;
						self.btnStopBGP.enabled 	:= false;
						self.mnuStart.enabled	:= false;
						self.mnuStop.enabled 	:= false;
					else
						self.btnStartBGP.enabled	:= true;
						self.btnStopBGP.enabled 	:= false;
						self.mnuStart.enabled	:= true;
						self.mnuStop.enabled 	:= false;
					endif;
				else
					self.btnStartBGP.enabled	:= false;
					self.btnStopBGP.enabled 	:= false;
					self.mnuStart.enabled	:= false;
					self.mnuStop.enabled 	:= false;
				endif;
				if self.myBGPObject.BGP_Controller.isEditable then
					self.mnuView.enabled	:= false;
					self.btnViewBGP.enabled	:= false;
					self.btnEditBGP.enabled	:= true;
					self.mnuEdit.enabled	:= true;
				else
					self.mnuView.enabled	:= false;
					self.btnViewBGP.enabled	:= false;
					self.btnEditBGP.enabled	:= false;
					self.mnuEdit.enabled	:= false;
				endif;
			endif;
		endif;	
		self.mnuAdd.enabled			:= true;
		self.btnAddBGP.enabled		:= true;
		
	elseif self.mode = Mode_EditView then
		self.mnuStart.enabled		:= false;
		self.btnStartBGP.enabled	:= false;
		self.mnuStop.enabled		:= false;
		self.btnStopBGP.enabled 	:= false;
		self.mnuEdit.enabled		:= false;
		self.btnEditBGP.enabled		:= false;
		self.mnuDelete.enabled		:= false;
		self.btnDeleteBGP.enabled	:= false;
		self.mnuAdd.enabled			:= false;
		self.btnAddBGP.enabled		:= false;
		self.mnuView.enabled		:= false;
		self.btnViewBGP.enabled		:= false;
		self.mnuLogInfo.enabled		:= false;
	else
		self.mnuStart.enabled		:= false;
		self.btnStartBGP.enabled	:= false;
		self.mnuStop.enabled		:= false;
		self.btnStopBGP.enabled 	:= false;
		self.mnuEdit.enabled		:= false;
		self.btnEditBGP.enabled		:= false;
		self.mnuDelete.enabled		:= false;
		self.btnDeleteBGP.enabled	:= false;
		self.mnuAdd.enabled			:= false;
		self.btnAddBGP.enabled		:= false;
		self.mnuView.enabled		:= false;
		self.btnViewBGP.enabled		:= false;
		self.mnuLogInfo.enabled		:= false;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStopAllApps" id="40c7cd88-9996-48bf-93c9-b070ef624335">
        <source>doStopAllApps() protected;
// -------------------------------------------
// Created 01 October 2003 by cnwdvb1
// -------------------------------------------
vars

	bgpManager	: BGP_Manager;
	iter		: Iterator;

begin

	if app.msgBox(app.getErrorString(Do_You_Wish_To_Stop_All_Apps),app.getErrorString(Stop_Applications),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	iter := app.myRoot.allBGPManagers.createIterator;
	while iter.next(bgpManager) do
		if stopManagerWarning(bgpManager) then
			bgpManager.terminateProcessing(app.myPassport.userCode);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStopNotesTimer" id="541b74df-b9d2-4387-a37b-ab5bde144220">
        <updating/>
        <source>doStopNotesTimer() updating, protected;
/*

Purpose:			Start the time for handling notifications

Parameters:			None

Return Value:		None

Date		Who		Reason
29 Nov 2011	cnwkpd1	PAR #28753 - BGP form performance issues

*/

vars
	option,
	time			: Integer;
	
begin
	if self.notesTimerStarted then
		if self.getTimerStatus(self.Notify_Timer_Event, option, time) then
			self.endTimer(self.Notify_Timer_Event);
		endif;
		self.notesTimerStarted := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
