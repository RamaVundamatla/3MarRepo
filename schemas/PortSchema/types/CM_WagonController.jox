    <JadeMethod name="getLocationForVehicleMove" id="5f5bbb32-5555-4e2b-8112-fb8211ccf271">
        <source>getLocationForVehicleMove(_vehicle: CM_Vehicle): CM_YardController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	railLine : CM_RailLine;
	taArea : CM_YardTransferArea;
	ti : CM_TrackedItem;
	visit : CM_VehicleVisitRecord;

begin

	railLine := self.getRailLine();
	if railLine &lt;&gt; null then
		if railLine.myRailArea &lt;&gt; null then
			taArea := railLine.myRailArea.myTransferArea;
		endif;
	endif;
	
	if taArea = null then
		return inheritMethod(_vehicle);
	endif;
	
	foreach ti in self.allTrackedItems where ti.directDelivery do
		if ti.myPrimaryActualLocation = _vehicle.locationsController then
			return taArea.getLocationsController.CM_YardController;
		endif;
	endforeach;
	
	visit := _vehicle.getCurrentVisit();
	if visit &lt;&gt; null then
		foreach ti in visit.allReceivedTrackedItems where ti.directDelivery do
			if ti.myPrimaryPlannedLocation = self then
				return taArea.getLocationsController.CM_YardController;
			endif;
		endforeach;
	endif;

	return inheritMethod(_vehicle);

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
