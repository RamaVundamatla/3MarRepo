    <JadeMethod name="getMovementPreviousGlobal" id="935198d0-1e4b-4de5-a18e-db246a5d2d78">
        <source>getMovementPreviousGlobal() : HMS_Movement;
//-----------------------------------------------------------------------
//	Created:	27 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	movement	: HMS_Movement;
begin
	movement := self.getMovementPrevious();
	if movement = null then
		if self.myVoyageGlobal &lt;&gt; null then
			movement := self.myVoyageGlobal.allHMSMovements.getAtKeyLss(self.occursOnDTNEW);
			if movement = null then
				if self.myVoyageGlobal.myPriorVoyageGlobal &lt;&gt; null then
					if self.myVoyageGlobal.myPriorVoyageGlobal.allHMSMovements.size &gt; 0 then
						movement := self.myVoyageGlobal.myPriorVoyageGlobal.allHMSMovements.last;
					endif;
				endif;
			endif;
		endif;
	endif;
	return movement;
epilog

end;</source>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
