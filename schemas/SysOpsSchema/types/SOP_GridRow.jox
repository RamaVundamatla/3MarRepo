        <type name="CM_GridRow"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doSelection" id="ac6aaaa9-9be2-41ea-a803-38f9d4e6e522">
        <updating/>
        <source>doSelection() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2008	cnwjk3	CCMS 1032

*/
vars
	pnt : CMUI_GridPoint;
begin
	foreach pnt in self.allGridPointsByColumn do
		if not self.myGridArea.allSelectedPoints.includes(pnt) then
			self.myGridArea.allSelectedPoints.add(pnt);
		endif;
	endforeach;
	self.myGridArea.myVLabelsFrame.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="bbd65002-da84-460e-8f7f-e2ea315cdb5b">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	LeftTextMargin	: Integer = 5;

vars
	caption : String;
	pos		: Integer;
begin
	caption := self.label;
	if self.label[1:1] = "_" then	//system label
		caption := null; //self.label;
	else
		pos := self.label.pos('&gt;',1);
		if pos &gt; 0 and self.label.length &gt; pos then
			caption := self.label[pos + 1:end];
		endif;
	endif;
	pFrame.drawTextAt(caption, LeftTextMargin, self.y1, Black);

end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="handleMouseDownEvent" id="43ae0a33-8657-4033-b237-678fb9f0a692">
        <updating/>
        <source>handleMouseDownEvent(button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pnt	: CMUI_GridPoint;
	frame : Frame;
begin
	self.myGridArea.allSelectedPoints.clear();

	foreach pnt in self.allGridPointsByColumn do
		self.myGridArea.allSelectedPoints.add(pnt);
	endforeach;

	self.myGridArea.drawSelf();
	if button = 2 then
		frame := self.myGridArea.myGridAreaFrame;
// 		PAR 9036 changed this slightly		
//		self.myGridArea.myGridAreaFrame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, false);
		frame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, false);
	else
		self.myGridArea.myGridAreaFrame.form.SOP_TerminalAreaDefForm.setButtonPenLabels();
	endif;
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3a22eaaf-2c90-4a4d-8c19-0fec024b036a">
        <updating/>
        <source>setForCreate(_sopGridArea : SOP_GridArea; _gridRow : CM_GridRow) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.setLabel(_gridRow.label, _sopGridArea);//validateLabel();
	self.row := _gridRow.row;
	//self.maxHeight := _sopGridArea.maxRowHeight;
	self.myGridRow := _gridRow;
	self.myPxyGridRow := _gridRow;
	self.myGridArea	:= _sopGridArea;
end;</source>
        <Parameter name="_sopGridArea" type="SOP_GridArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="setLabel" id="223f5494-6890-43b8-9e17-caff767d2732">
        <updating/>
        <source>setLabel(_label : String; _sop_GridArea : SOP_GridArea)updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	// TFS 2232 want to keep "1" as is and not pad with zeros so it looks better
	self.label := _label;
	//if _label.length = 1 and _label.isInteger then
	//	self.label := _label.padLeadingZeros(2);
	//else
	//	self.label := _label;
	//endif;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_sop_GridArea" type="SOP_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setMaxHeight" id="d5313870-7dc6-4603-9414-5638b1ded7e8">
        <updating/>
        <source>setMaxHeight(_height : Integer) updating;

vars

begin

	self.maxHeight := _height;

end;</source>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRow" id="d81c2ceb-0d2a-4983-9d17-dc640338febb">
        <updating/>
        <source>setRow(_row : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.row := _row;
	if self.myPxyGridRow &lt;&gt; null then
		self.myPxyGridRow.setRow(_row);
	endif;
end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
</Class>
