    <JadeMethod name="initMainTable" id="04c4271f-6d52-4b0a-bbde-3d6ad2cc3fb3">
        <source>initMainTable() protected;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.frmEdit.top 	:= 10;
	self.frmEdit.left	:= 5;
	self.frmEdit.width	:= 295;
	//self.frmEdit.width	:= self.frmDetailsTop.width;
	self.frmEdit.height := 235;
	return;
	
	self.frmEdit.height := 235;
	self.lstImex.height := 95;
	self.lblAttributes.top := self.lstImex.top + self.lstImex.height + self.VerticalSpacing;
	self.lstAttributes.top := self.lblAttributes.top;
