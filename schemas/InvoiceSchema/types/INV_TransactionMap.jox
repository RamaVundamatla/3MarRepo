		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(_theMap.myProductMap,CMIF_TranMapController.TM_Level_06_Product, idx);

		if idx &gt; 0 then
			create trGroup;
			trGroup.myImexMap := _theMap;
			trGroup.itemName := _theMap.imexStatusString;
			trGroup.extractName := _theMap.imexStatusString;	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_07_IMEX, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ImexServiceMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteInvoiceLineType" id="900da42b-4678-482f-9acc-e7ee77807289">
        <source>doUserNoteInvoiceLineType(_theMap : CM_InvoiceLineDesc; _event : Integer);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmcGroup : CMIF_TMCGroup;
	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		while idx &lt;= self.lstData.itemLevel.size do
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_14_InvoiceLine, idx);
			if idx &gt; 0 then
				self.lstData.removeItem(idx);
				delete tmcGroup;
			else
				break;
			endif;
		endwhile;
		return;
	endif;

	if _event = EVENT_TRANSACTIONMAP_UPDATE then
		while idx &lt;= self.lstData.itemLevel.size do
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_14_InvoiceLine, idx);
			if idx &gt; 0 then
				self.lstData.itemText[idx] := _theMap.narration;
			else
				break;
			endif;
		endwhile;

	endif;
end;</source>
        <Parameter name="_theMap" type="CM_InvoiceLineDesc"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteProduct" id="66cf812f-0c39-4833-884d-4e98ef36a37c">
        <updating/>
        <source>doUserNoteProduct(_theMap : CM_ProductMap; _event : Integer) updating;
