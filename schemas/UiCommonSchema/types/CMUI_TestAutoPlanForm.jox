    <JadeMethod name="tblSelectedCargo_dragDrop" id="d7b4d363-7a79-467d-a0b9-47ed41d8207b">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectedCargo_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	class : Class;
	dockBar : CMUI_JadeDockBar;
	drawCont : CMUI_GridDrawingController;

begin

	create tiArray transient;

	if app.isDragging then
		if win &lt;&gt; null then
			class := win.class;
			if class.name = "YRD_ContainerDrawingFrame" then
				drawCont := win.sendMsg("getDrawingController").CMUI_GridDrawingController;
				if drawCont &lt;&gt; null then
					drawCont.getAllSelectedTIs(tiArray);
				endif;
			endif;
		endif;
		app.isDragging := false;
	endif;
	
	if app.myMoveController &lt;&gt; null then
		if app.myMoveController.myTrackedItem &lt;&gt; null then
			tiArray.addExclusive( app.myMoveController.myTrackedItem );
		endif;
		foreach ti in app.myMoveController.allOtherTrackedItems do
			tiArray.addExclusive( ti );
		endforeach;
	endif;
	
	if not tiArray.isEmpty then
		self.addSelectedCargo(tiArray );
	endif;

epilog

	delete tiArray;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
