    <JadeMethod name="updStgAndProceedBasedOnComp" id="b53965cd-dadf-404f-926f-38b69e982b04">
        <updating/>
        <source>updStgAndProceedBasedOnComp(_voyageProgress : CM_VoyageProgress io; _comparisonAgent : CM_LoadListComparisonAgent ; _ediData : CM_EDIDataLoadList; _selectedLoadListOperators : CM_OperatorSet io) updating;
/*

Purpose:			

	This method consilidates changes for
		//navra1 - CR 65823 - 6th Sep 2024, 
		//navra1 - MTN-33017 - 11th Oct 2024
		//navra1 - MTN-33086 - 21st Oct 2024
		//navra1 - MTN-33017 - 11th Oct 2024

	and does the following,
		//1) updates the voyageStage for each operator based on the comparison 
		//2) proceeds the voyage to the next stage based on the pause status
		//3) updates the voyage status depending upon a)if any operator has succeeded comparison and b)if the voyage is paused	
		
Parameters:			

Return Value:		

Date		Who		Reason
01 November 2024	navra1	Initial creation for //navra1 - MTN-33185 - 1th Nov 2024
*/

vars
	isPaused : Boolean;
	oper,oneOperator : CM_Operator;
	failedLoadListOperators : CM_OperatorSet;
	ediTI : CM_EDITrackedItem;
	voyStatus : CM_VoyageStatus;
	failureDescription : String;
	currPortCode : String;						//navra1 - DEFECT-33512 - 26th Nov 2024
	
begin
	create failedLoadListOperators transient;
	
	isPaused := _voyageProgress.pauseProgress;
	
	currPortCode := self.myCurrentVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();

	if (_comparisonAgent.allDiscrepancyTIs &lt;&gt; null and _comparisonAgent.allDiscrepancyTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allDiscrepancyTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end			
			
			oper := app.myRoot.allOperators[ediTI.CM_EDILoadListTI.operatorCode];
			if oper &lt;&gt; null then
				//do a tryRemove - and if it succeeds, ie. it existed in _selectedLoadListOperators, then you want to fail the operator, 
				//if it did not exist in _selectedLoadListOperators it is not a failed operator since we dont care about him in the first place
				if _selectedLoadListOperators.tryRemove(oper) = true then	//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about					
					failedLoadListOperators.tryAdd(oper);
				endif;														//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about
			endif;
		endforeach;
	endif;
	
	if (_comparisonAgent.allUnmatchedDBTIs &lt;&gt; null and _comparisonAgent.allUnmatchedDBTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allUnmatchedDBTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end
			
			oper := app.myRoot.allOperators[ediTI.CM_EDILoadListTI.operatorCode];
			if oper &lt;&gt; null then
				//do a tryRemove - and if it succeeds, ie. it existed in _selectedLoadListOperators, then you want to fail the operator, 
				//if it did not exist in _selectedLoadListOperators it is not a failed operator since we dont care about him in the first place
				if _selectedLoadListOperators.tryRemove(oper) = true then	//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about
					failedLoadListOperators.tryAdd(oper);
				endif;														//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about
			endif;
		endforeach;
	endif;
	
	if (_comparisonAgent.allUnmatchedLLTIs &lt;&gt; null or _comparisonAgent.allUnmatchedLLTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allUnmatchedLLTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end
			
			oper := app.myRoot.allOperators[ediTI.CM_EDILoadListTI.operatorCode];
			if oper &lt;&gt; null then
				//do a tryRemove - and if it succeeds, ie. it existed in _selectedLoadListOperators, then you want to fail the operator,
				//if it did not exist in _selectedLoadListOperators it is not a failed operator since we dont care about him in the first place
				if _selectedLoadListOperators.tryRemove(oper) = true then	//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about
					failedLoadListOperators.tryAdd(oper);
				endif;														//navra1 - MTN-33494 - 22nd Nov 2024 - //you want to add this operator as a failed operator only if it was an operator we cared about
			endif;
		endforeach;
	endif;							
	
	if _selectedLoadListOperators.size() &gt; 0 then	//only if some operator is ready to proceed, we change the voyage status to "Auto Progress" or "Auto Progress Paused"
		//navra1 - MTN-33086 - 21st Oct 2024 - start		
		if not isPaused then
			voyStatus := _voyageProgress.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];				
			self.changeAutoVoyageStatus(voyStatus);
		else
			//navra1 - MTN-33086 - 21st Oct 2024 - start			
			voyStatus := _voyageProgress.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];				
			self.changeAutoVoyageStatus(voyStatus);
			//navra1 - MTN-33086 - 21st Oct 2024 - end		
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
	endif;
	
	//now selectedLoadListOperators contains only operators that had no problems, proceed them to the next stage, after making the comparison stage successful for them
	foreach oneOperator in _selectedLoadListOperators do
		if self.comparisonMode = LOAD_COMPARISON and _ediData.listType = 'L' then
			failureDescription  := '';
			_voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, _voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Load, null, null, _ediData, null, null, failureDescription);	//navra1 - MTN-34348 - 13th March 2025
			if not isPaused then
				_voyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadManMoved, null, oneOperator, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
			endif;
		elseif self.comparisonMode = DISCHARGE_COMPARISON and _ediData.listType = 'D' then
			failureDescription  := '';
			_voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, _voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Discharge, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
			if not isPaused then
				_voyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManMoved, null, oneOperator, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
			endif;
		endif;
	endforeach;
	
	//now failedLoadListOperators contains the operators that had problems, dont proceed them to the next stage, after marking the comparison stage as failure for them
	foreach oneOperator in failedLoadListOperators do
		if self.comparisonMode = LOAD_COMPARISON and _ediData.listType = 'L' then
			failureDescription  := _voyageProgress.getComparisonFailureDesc(_comparisonAgent, oneOperator.code);			//navra1 - MTN-34829 - 8th May 2025
			_voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, _voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Load, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		elseif self.comparisonMode = DISCHARGE_COMPARISON and _ediData.listType = 'D' then
			failureDescription  := _voyageProgress.getComparisonFailureDesc(_comparisonAgent, oneOperator.code);			//navra1 - MTN-34829 - 8th May 2025
			_voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, _voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		endif;
	endforeach;
			
epilog
	delete failedLoadListOperators;
end;</source>
        <Parameter name="_voyageProgress" type="CM_VoyageProgress" usage="io"/>
        <Parameter name="_comparisonAgent" type="CM_LoadListComparisonAgent"/>
        <Parameter name="_ediData" type="CM_EDIDataLoadList"/>
        <Parameter name="_selectedLoadListOperators" type="CM_OperatorSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateQueryFrame" id="bd7c28c9-39bb-47e6-9b3b-cded4eaad1a4">
        <updating/>
        <source>updateQueryFrame() updating;

/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
24 November 2009	cnwas3	Initial creation
27 May		2022	navkc1	ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.
*/
vars
	bVoyDetails : Boolean;
	
begin
	
	self.setSelected(); 		// 27/07/2022	navkc1	#53629		Set selected field based on comparison mode
	
	if self.comparisonMode = VOYAGE_DETAILS_COMPARISON then
		bVoyDetails := false;
	else
		bVoyDetails := true;
	endif;
	
	self.cmbLoadList.visible := bVoyDetails;
	self.lblLoadList.visible := bVoyDetails;
	self.chkAutoUpdateRTS.visible := bVoyDetails;
	
	self.shtQuery2.visible := bVoyDetails;
	
	self.shtQuery5.visible := bVoyDetails;

	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	if self.cmbVoyage.listIndex &lt;= null then
		// if the voyage has been deleted or reset in some way clear the previously selected list.
		self.cmbLoadList.listIndex	:= -1;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="fd5ebd94-d6f0-4712-a660-867f5fbbba2d">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2025	navra1	Initial creation for //navra1 - MTN-36126 - 24th Sep 2025

*/

vars

begin
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );
	
	//navra1 - MTN-36424 - 30th Oct 2025
	self.txtFilters.text := self.getFilterDetailsForDisplay();


epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="b502b293-86ae-4acb-8eed-33f781d5c4e1">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theTopRow,idx,foreColour, backColour : Integer;
	theVJob : CM_VoyageJob;
	theDataLine : String;
	theJobTITotals : CMIF_JobTITotals;
	theTable : CM_DataTable;
begin
	theTable := self.tblData;
	
	if _obj &lt;&gt; null and _event &lt;&gt; VoyageJob_Delete_Event then // &lt;&lt;&lt;&lt; UPDATE AND CREATE
		if _obj.isKindOf(CM_VoyageJob) then
			theVJob := _obj.CM_VoyageJob;
			if theVJob.myVoyage = self.myCurrentVoyage then
				// find the job and update that line OR add onto the end of the list
				theTable.findObjectInRow(theVJob,theTopRow);
				create theJobTITotals transient;
				theVJob.getJobTITotals(theJobTITotals);
				theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);
				if theTopRow &gt; 0 then	
					theTable.removeItem(theTopRow);
					
					// insert as per the job sheet, if we are only looking at a particular crane
					if theVJob.myJobSheet &lt;&gt; null 
					and self.cmbLoadList.itemData[self.cmbLoadList.listIndex] = self.JobType_CraneSC then
						theTopRow := theVJob.myJobSheet.allJobsByOrder.indexOf(theVJob);
						if theTopRow &lt; 1 then
							theTopRow := theTable.rows - 6;
						else
							theTopRow := theTopRow + theTable.fixedRows;
						endif;
					endif;
					
					theTable.addItemAt(theDataLine,theTopRow);
					theTable.accessRow(theTopRow).itemObject := theVJob;
					idx := theTopRow;
					// if we are viewing jobs that are not for a particular crane then re sort
					if self.cmbLoadList.itemData[self.cmbLoadList.listIndex] &lt;&gt; self.JobType_CraneSC then
						theTable.sortColumn[1] := 1;
						theTable.resort();
					endif;
				else
					idx := theTable.rows - 6; // take away 6 because of the totals
					theTable.addItemAt(theDataLine,idx);
					theTable.accessRow(idx).itemObject := theVJob;
				endif;
				theVJob.getRowColour(foreColour, backColour);
				theTable.accessRow(idx).backColor := backColour;
				theTable.accessRow(idx).foreColor := foreColour;
				if theTopRow &gt; theTable.fixedRows then
					theTable.topRow := theTopRow;
				endif;
			endif;
		endif;
	elseif _obj &lt;&gt; null and _event = VoyageJob_Delete_Event then
		self.tblInfo.rows := 0;
		theTable.findObjectInRow(_obj,theTopRow);
		if theTopRow &gt; theTable.fixedRows then
			theTable.removeItem(theTopRow);
		endif;
	else
		inheritMethod(_event, _noteobj,_obj);
	endif;
epilog
	
	delete theJobTITotals;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
