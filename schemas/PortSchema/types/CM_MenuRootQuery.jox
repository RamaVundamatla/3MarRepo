vars

begin
	return self.heading;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultStringForTrackedItem" id="49f15ed5-7c9d-4cad-921d-fe933e1e6839">
        <source>getResultStringForTrackedItem(_queryDef : CM_QueryDefinition; _ti : CM_TrackedItem) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2013	cnwndl1	Initial creation

*/

vars
	rowStr,
	propValStr,
	attrName	: String;
	queryProp	: CM_QueryProperty;
	propVal		: Any;	
	propDict	: CM_QueryPropertyDict;
	oper 		: CM_QueryOperator;
begin
	
	propDict	:= _queryDef.allQueryProperties;

	foreach attrName in self.allVisibleColumns do
		queryProp := propDict[attrName];
		
		if queryProp = null then
			propValStr := 'Could not retreive ' &amp; attrName;
		elseif (CM_QStringLookupProperty.hasInstance(queryProp)) then	//no need to translate
			propValStr := _ti.getPropertyValue(queryProp.propertyName).String;
		else
			oper := null;
			propVal := queryProp.getValueForObject(_ti,null);
			
			if propVal = null
			and (not queryProp.displayNull)
			then
				propValStr := null;
			else
				propValStr := queryProp.translateToDisplayValue(propVal);
			endif;
		endif;
		
		rowStr := rowStr &amp; propValStr &amp; Tab;
	endforeach;
	
	return rowStr;
epilog

end;</source>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resetNcColumns" id="0b08e6ee-3011-4557-b7de-dbe6daab467f">
        <source>resetNcColumns( _queryType : Integer; _queryMode : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2019	jlgndl1	Initial creation	TFS 44100

*/

vars

	qDef : CM_QueryDefinition;
	allNcVisibleColumns : StringArray;

begin

	qDef := app.myRoot.allQueryDefinitionObjects[ _queryType, _queryMode ];
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Query definition object, query type = '" &amp; _queryType.String &amp; "' and query mode = '" &amp; _queryMode.String &amp; "' could not be found");
		return;
	endif;
	
	create allNcVisibleColumns transient;
	qDef.getSelectorVisibleColumns( allNcVisibleColumns );
	
	self.setNonCargoSelectorColumns( _queryType, _queryMode, allNcVisibleColumns );
		
epilog

	delete allNcVisibleColumns;

end;</source>
        <Parameter name="_queryType" type="Integer"/>
        <Parameter name="_queryMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetSelectorColumns" id="96b38beb-5391-465c-a150-34b7dbf97283">
        <source>resetSelectorColumns(_setDefaults : Boolean);
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	colArray	: StringArray;
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
begin
	self.allColumns.clear();

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null]; //get the tracked Item mode definition object
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition object for Tracked Item mode could not be found');
		return;
	endif;
	
	foreach qProp in qDef.allQueryProperties do
		self.allColumns.add(qProp.propertyName);
	endforeach;
	
	if _setDefaults then
		self.allVisibleColumns.clear();
		//add default visible columns
		qProp := qDef.allQueryProperties['id'];
		if qProp &lt;&gt; null then
			self.allVisibleColumns.add(qProp.propertyName);
		endif;	
		
		qProp := qDef.allQueryProperties['locationId'];
		if qProp &lt;&gt; null then
			self.allVisibleColumns.add(qProp.propertyName);
		endif;	
		
		qProp := qDef.allQueryProperties['operatorCode'];
		if qProp &lt;&gt; null then
			self.allVisibleColumns.add(qProp.propertyName);
		endif;
	endif;
end;</source>
        <Parameter name="_setDefaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetUserSelectorColumns" id="ebdb233a-dd52-425b-baf1-dc0376f2ed83">
        <source>resetUserSelectorColumns(_setDefaults : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/05/2013	cnwdap1		Initial creation PAR #31486 Reset user-defined cargo type selector columns
//
vars
	colArray	: StringArray;
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	
begin
	self.allUserColumns.clear();
	
	// get the user-defined cargo type definition
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.UserDefined_Query_Mode];
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition object for Tracked Item mode could not be found');
		return;
	endif;
	
	foreach qProp in qDef.allQueryProperties do
		self.allUserColumns.add(qProp.propertyName);
	endforeach;
	
	if _setDefaults then
		self.allUserVisibleColumns.clear();
		//add default visible columns
		qProp := qDef.allQueryProperties['id'];
		if qProp &lt;&gt; null then
			self.allUserVisibleColumns.add(qProp.propertyName);
		endif;	
		
		qProp := qDef.allQueryProperties['locationId'];
		if qProp &lt;&gt; null then
			self.allUserVisibleColumns.add(qProp.propertyName);
		endif;	
		
		qProp := qDef.allQueryProperties['operatorCode'];
		if qProp &lt;&gt; null then
			self.allUserVisibleColumns.add(qProp.propertyName);
		endif;	
		
		qProp := qDef.allQueryProperties['cargoType'];
		if qProp &lt;&gt; null then
			self.allUserVisibleColumns.add(qProp.propertyName);
		endif;	
	endif;
end;</source>
        <Parameter name="_setDefaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNonCargoSelectorColumns" id="12e2094f-7d69-408c-b9b6-c155e0b91f13">
        <source>setNonCargoSelectorColumns( _queryType : Integer;
							_queryMode : Integer;
							_allVisibleColumns : StringArray
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2019	jlgndl1	Initial creation	TFS 44100
22 Dec 2022 	navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
20 Feb 2023     navmv20 CR 55626 Task 55688: Jade - Selector Query Contracts
10 May 2023 	navlw1 ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
30 May 2024		jlier1 TFS 64054
*/

vars

	allNcVisibleColumns : StringArray;
	qDef : CM_QueryDefinition;
begin
	qDef := app.myRoot.allQueryDefinitionObjects[ _queryType, _queryMode ];

	if _queryType = CM_QueryDefinition.Transaction_Query_Type
	or _queryType = CM_QueryDefinition.Invoicing_Query_Type
	or _queryType = CM_QueryDefinition.Cash_Query_Type
	or _queryType = CM_QueryDefinition.Audit_Query_Type
	or _queryType = CM_QueryDefinition.VehicleBookingSlot_Query_Type //10.05.2023 navlw1 #53902
	then
		//All good so far, we know what to do with these types
		if _queryMode = CM_QueryDefinition.Audit_Query_Mode
		or _queryMode = CM_QueryDefinition.CargoTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.CashPayment_Query_Mode
		or _queryMode = CM_QueryDefinition.CashReceipt_Query_Mode
		or _queryMode = CM_QueryDefinition.EventTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.HMSTransaction_Query_Mode
		or _queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode
		or _queryMode = CM_QueryDefinition.Invoice_Query_Mode
		or _queryMode = CM_QueryDefinition.Location_Activity_Query_Mode	//14 Apr 2021	NDL	TFS 50906
		or _queryMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode	//22.12.2022 navhl20 #54350[54269]
		or _queryMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode //10.05.2023 navlw1 #53902
		or _queryMode = CM_QueryDefinition.Contract_Query_Mode //20/02/2023 navmv20 CR 55626 Task 55688
		then
			//And, we know what to do with these modes
		else
			return;
		endif;	
	elseif qDef &lt;&gt; null and  (qDef.isKindOf(CM_QDefTILC) or qDef.isKindOf(CM_QDefCar)) then
		//can continue  //TFS 64054 jlier1 30/5/24
	else
		return;
	endif;
	
	if self.allNonCargoVisibleColumns.size &lt; _queryMode or self.allNonCargoVisibleColumns[ _queryMode ] = null then
		//not found create it
		create allNcVisibleColumns persistent;
		self.allNonCargoVisibleColumns.atPut( _queryMode, allNcVisibleColumns );
	else
		allNcVisibleColumns := self.allNonCargoVisibleColumns[ _queryMode ].StringArray;
		//21 Apr 2021	NDL	- found during testing - over zealous clean-up of 'orphaned StringArrays' in DMAST/WMAST
		if not global.isValidObject( allNcVisibleColumns ) then
			create allNcVisibleColumns persistent;
			self.allNonCargoVisibleColumns.atPut( _queryMode, allNcVisibleColumns );
		endif;
	endif;
	
	allNcVisibleColumns.clear();
	_allVisibleColumns.copy( allNcVisibleColumns );

epilog

end;</source>
        <Parameter name="_queryType" type="Integer"/>
        <Parameter name="_queryMode" type="Integer"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setSelectorColumns" id="f0107fbb-8e26-4a1f-af42-e52619aeca28">
        <source>setSelectorColumns(_allColumns, _allVisibleColumns : StringArray);
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allColumns.clear();
	self.allVisibleColumns.clear();
	_allColumns.copy(self.allColumns);
	_allVisibleColumns.copy(self.allVisibleColumns);
	

end;</source>
        <Parameter name="_allColumns" type="StringArray"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setUserSelectorColumns" id="0df75bbb-7670-42dd-be69-cf9b46091579">
        <source>setUserSelectorColumns(_allColumns, _allVisibleColumns : StringArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/05/2013	cnwdap1		Initial creation PAR #31486 Set column arrays 
//
vars

begin
	self.allUserColumns.clear();
	self.allUserVisibleColumns.clear();
	_allColumns.copy(self.allUserColumns);
	_allVisibleColumns.copy(self.allUserVisibleColumns);
epilog

end;</source>
        <Parameter name="_allColumns" type="StringArray"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
    </JadeMethod>
