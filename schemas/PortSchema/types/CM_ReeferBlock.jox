    <JadeMethod name="validateMe" id="04c8c8d3-f145-47c4-b06d-07a54e061ef5">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579
12 April 2021	navmd1	TFS 51044 Prevent spaces/non-alphanumeric characters in the walkpath name

*/

vars

	reeferPos : CM_ReeferBlockPosition;
	existing : CM_ReeferBlock;
	myReal : CM_ReeferBlock;

begin

	if self.myTerminalArea = null then
		app.raiseCMException(Terminal_area_selected, null, null);
		return;
	endif;
	
	if self.name = null then
		app.raiseCMException(Name_required_field, null, null);
		return;
	endif;
	
	self.validateName();	// TFS 51044
	
	if self.isTransient then
		myReal := self.pxyGetRealObject().CM_ReeferBlock;
		existing := self.myTerminalArea.allReeferBlocks.getAtKey( self.name );
		if existing &lt;&gt; null and existing &lt;&gt; myReal then
			app.raiseCMException1(Value_Already_been_used, self.name, null, null);
		endif;
	else	
		foreach reeferPos in self.allReeferPositions do
			reeferPos.validateMe();
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateName" id="9156b746-21a0-4fbe-831f-eab3294130f8">
        <source>validateName() protected;
/*

Purpose:			The Navis side of the ReeferAPI doesn't suppose non-numeric characters very well...

Parameters:			

Return Value:		

Date			Who		Reason
12 April 2021	navmd1	Initial creation TFS 51044 - Prevent 'invalid' characters from going to the Navis API

*/

vars
	realObj		: SelfType;
	checkName	: Boolean;
begin

	// No spaces, or underscores, as they are (unhelpfuuly) 'automagically' escaped into other random characters
	// Which no one really knows how it works.
	if not self.name.toUpper.containsOnlyUppAlphaAndNumeric then
		app.raiseCMException1(NReefer_Err_Invalid_Char, self.name, null, null);
		return;
	endif;
	
	// Only bother checking the length of the name if its changed
	if self.isTransient then
		realObj := self.pxyGetRealObject();
		if realObj = null then
			// Newly Created
			checkName := true;
		else
			if self.name &lt;&gt; realObj.name then
				// Name changed
				checkName := true;
			endif;
		endif;
	endif;
	
	// Produce a warning if more than 4 characters are entered
	if self.name.length &gt; 4 then
		if self.isTransient and not checkName then
			// Do nothing
		else
			app.raiseCMWarning1(NReefer_Err_Name_To_Big, self.name, null, null, null);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
