    <JadeMethod name="getFullId" id="bb68bef4-8865-4ffc-a67b-a3f8eab75446">
        <source>getFullId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	if self.myLocation &lt;&gt; null then
		str := self.myLocation.getFullId;
		str := str &amp; " " &amp; self.ident;
		return str;
	else
		return inheritMethod();
	endif;
epilog

end;</source>
