    <JadeMethod name="getTransMovedForDocketCorrect" id="0a60bcb8-ea4d-4950-9681-4013b7104644">
        <source>getTransMovedForDocketCorrect( _moveTransFromRoadToLocn2 : CM_Move output; _moveTransFromLocn1ToLocn2 : CM_TITransaction output );
// --------------------------------------------------------------------------------------------------------
// Created:     01 Feb 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				Finds the Moved transactions to be edited for the Docket Correction transaction.
//				Usually, there is only one Moved transaction on the Log.
//				However, when _moveTransFromLocn1ToLocn2 &lt;&gt; null, it means that the log has been transferred 
//				to a new location. in this case we cannot edit the myPrimaryActualLocation for the Log.
//
// Changed On   Changed By  Reason
// 03 05 2010	cnwvu1		PAR 24049 - when a location is deleted or archived, there is an unexpected error, when
//							Docket Correction corrects the old stock movemets for the old invovlved location.
// 06 07 2010	cnwvu1		PAR 24462 - CM_ReinstateReject should be considered as second move transaction,
//							when a log has been reinstated to another location.
// ----------------------------------------------------------------------------------------------------------

vars
	trans				: CM_TITransaction;
	transMove			: CM_Move;
	transReinstateReject: CM_ReinstateReject;
	tmpFoundSourceLocn,
	tmpFoundTargetLocn	: CM_LocationsController;
	tmpFoundHeight		: Integer;
	tmpStrRoad			: String;
	locationInvolvedStr	: String;	//PAR 234049. This is the first location after Road. It is to be changed because fo Docket Correction.
	
begin
	
	// PAR 234049. When a log row is deleted or archived, found location = null.
	//In this case, there is only one way to find a Move transaction from Road to a Location1:
	// to check the "Road" string in CM_Move.sourceLocn
	tmpStrRoad	:= app.getErrorString(Road);
	
	// -------------------------------------------------------------------------------
	// analyzing Move transactions
	// P.S. for the first log there is an extra Moved transaction from Nowhere to Road
	// -------------------------------------------------------------------------------
	foreach trans in self.allTransactions do
	
		if _moveTransFromRoadToLocn2 = null then	// need to find the first transaction from Road to Location1
			if trans.isKindOf( CM_Move ) then
				transMove := trans.CM_Move;
				if transMove.sourceLocn.pos(tmpStrRoad, 1) &gt; 0 then	// PAR 24049. Using this technic, because usual method doesn't serach for archived locations - self.myTerminal.findLocationFromString(transMove.sourceLocn, true, tmpFoundSourceLocn, tmpFoundHeight)
				//if n &gt; 0 then	// transation from Road to Location1 found
					_moveTransFromRoadToLocn2	:= transMove;
					locationInvolvedStr		:= transMove.targetLocn;	// PAR 234049. This is the first location after Road. It is to be changed because fo Docket Correction.
				endif;
			endif;
			continue;	// don't search for the second _moveTransFromLocn1ToLocn2, when the first _moveTransFromRoadToLocn2 is not find
		endif;

		// looking for the second transaction = from Location1 to Lcoation2
		if trans.isKindOf( CM_Move ) then	// a log can be moved by CM_Move transaction.
			transMove := trans.CM_Move;
			if transMove.sourceLocn = locationInvolvedStr then
				_moveTransFromLocn1ToLocn2	:= transMove;
			endif;
			
		elseif trans.isKindOf( CM_ReinstateReject ) then	// #24462. A log can be moved by CM_ReinstateReject as well
			transReinstateReject := trans.CM_ReinstateReject;
			if transReinstateReject.myLocationTo &lt;&gt; self.priorLocation then 	// if a log was reinstated to another location, there was an actual move from location1 to location2
				_moveTransFromLocn1ToLocn2	:= transReinstateReject;	// a log was reinstated to another location, actually move occurred.
			endif;
		endif;

		if _moveTransFromLocn1ToLocn2 &lt;&gt; null then
			break; // when the second location found, don't need to check all the follwwing transactions. They are not involved into Docket Correction for stock movements.
		endif;
	
	endforeach;

	
	if _moveTransFromRoadToLocn2 = null and _moveTransFromLocn1ToLocn2 &lt;&gt; null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction. Move transaction from the Road to a Location not found.' );
		return;
	endif;

end;
</source>
        <Parameter name="_moveTransFromRoadToLocn2" type="CM_Move" usage="output"/>
        <Parameter name="_moveTransFromLocn1ToLocn2" type="CM_TITransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTransProductForDocketCorrec" id="ff89a58f-f794-4d5e-93ef-49e2ec7a17de">
        <source>getTransProductForDocketCorrec() : CM_EditProductCode protected;
// --------------------------------------------------------------------------------------------------------------
// Created:     04 Feb 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				Returns the first Product Changed transaction to be edited for the Docket Correction transaction.
// --------------------------------------------------------------------------------------------------------------

vars
	trans : CM_TITransaction;

begin
	
	foreach trans in self.allTransactions do
		if trans.isKindOf( CM_EditProductCode ) then
			if not trans.isKindOf( CM_EditOperator ) then
				return trans.CM_EditProductCode;
			endif;
		endif;
	endforeach;

	return null;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="CM_EditProductCode"/>
    </JadeMethod>
    <JadeMethod name="getTransSupplierForDocketCorre" id="ed7f1fcb-49d6-4b55-bb9b-3e90f1f99603">
        <source>getTransSupplierForDocketCorre() : CM_EditOperator protected;
// ---------------------------------------------------------------------------------------------------------------
// Created:     01 Feb 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				Returns the first Operator Changed transaction to be edited for the Docket Correction transaction.
// ---------------------------------------------------------------------------------------------------------------

vars
	trans : CM_TITransaction;

begin
	
	foreach trans in self.allTransactions do
		if trans.isKindOf( CM_EditOperator ) then
			return trans.CM_EditOperator;
		endif;
	endforeach;

	return null;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="CM_EditOperator"/>
    </JadeMethod>
