    <JadeMethod name="searchExceptionHandler" id="ccff6ee7-5bc4-41e7-a873-34ebe39dc829">
        <source>searchExceptionHandler(e:Exception):Integer protected;

constants
	Invalid_Object_Reference = 4;
	Null_Object_Reference = 1090;
vars
	obj : Object;
	cls : Class;
begin
	
	obj := e.errorObject;
	cls := getClassForObject(obj);

	if e.errorCode = Null_Object_Reference then
		// the situationwhere a developer has deleted the global constant can't easily be deteceted because
		// the errorObject type cannot be determined, so the item is displayed with no constant name or value
	endif;
	
	if e.errorCode = Invalid_Object_Reference then
		if cls &lt;&gt; null and cls.inheritsFrom(XLAT_TranslatableText) then
			// item has been deleted, but remains in the search result set
			return Ex_Resume_Next;
		endif;
	endif;
	
	return Ex_Pass_Back;
end;
</source>
        <access>protected</access>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setButtonsEnabled" id="87be4480-c540-42b7-9522-982a10f6e79f">
