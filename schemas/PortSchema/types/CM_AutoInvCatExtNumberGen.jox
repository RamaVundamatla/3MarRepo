    <JadeMethod name="auditIdDisplay" id="f77d8c51-5bea-47e6-a376-717253fa47d6">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	
	idDisplay		: String;
	bank			: CM_Bank;
	
begin
	
	idDisplay := app.getErrorString(Auto) &amp; " " &amp; self.getDisplayStringForId(self.idType);
	
	bank := self.myBusinessUnit;
	
	if bank &lt;&gt; null then
		idDisplay := idDisplay &amp; " - " &amp; bank.code;
	endif;
	
	return idDisplay;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextId" id="61cc23f3-0e6d-40af-9655-2df9cfe151f6">
        <updating/>
        <source>getNextId(_cargoTypeAbbr: String; _terminalCode: String): String updating;
/*

Purpose:			
		Reimplementing this method for CM_AutoInvCatExtNumberGen
Parameters:			

Return Value:		

Date				Who		Reason
28 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55521
09/02/2023			navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
11 September 2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars
	bank				: CM_Bank;
	serverDate 			: Date;
	prefix 				: String;
	year 				: String;
	seqNum 				: Real;
	newId 				: String;
	nextSeqNum 			: Real;
	
	failSafeCount 		: Integer;
	inTransactionState 	: Boolean;
	
begin
	
	seqNum := self.CM_AutoInvCatExtNumberGen.currSeq;
	
	serverDate := app.actualTimeServer().Date;
	year := serverDate.format("yy");
	
	// Country code (CC)
	if self.idStyle = AutoIdStyle_CC_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_L_YY_SSS then
		if self.currCountry = null then 	// 09/02/2023	navkc1	Bug 56444
			prefix := "??";
		else
			prefix := self.currCountry; 	// 09/02/2023	navkc1	Bug 56444
		endif;
	endif;
	
	// Terminal code (T)
	if self.idStyle = AutoIdStyle_CC_T_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_L_YY_SSS then
		if _terminalCode = null then
			prefix := prefix &amp; "??";
		else
			prefix := prefix &amp; _terminalCode;
		endif;
	endif;
	
	// Business unit code (B)
	if self.idStyle = AutoIdStyle_CC_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_B_L_YY_SSS 			//17/01/2025	navkc1 JIRA Bug MTN-33813
	then
		bank := self.CM_AutoInvCatExtNumberGen.myBusinessUnit;
		
		if bank = null then
			prefix := prefix &amp; "??";
		else
			prefix := prefix &amp; bank.code;
		endif;		
	endif;

	// Id Prefix (P) or (L)
	if self.idStyle = AutoIdStyle_CC_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_L_YY_SSS
	or self.idStyle = AutoIdStyle_P_SSS
	or self.idStyle = AutoIdStyle_B_L_YY_SSS 	//17/01/2025	navkc1 JIRA Bug MTN-33813
	or self.idStyle = AutoIdStyle_L_YY_SSSS 	//17/01/2025	navkc1 JIRA Bug MTN-33813
	then
		prefix := prefix &amp; self.idPrefix;
	endif;
	
	// Year (YY)
	if self.idStyle = AutoIdStyle_CC_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_B_L_YY_SSS
	or self.idStyle = AutoIdStyle_CC_T_L_YY_SSS
	or self.idStyle = AutoIdStyle_B_L_YY_SSS 	//17/01/2025	navkc1 JIRA Bug MTN-33813
	or self.idStyle = AutoIdStyle_L_YY_SSSS 	//17/01/2025	navkc1 JIRA Bug MTN-33813
	then
		prefix := prefix &amp; year;
	endif;
	
	while true do
		if seqNum.String.length &gt; self.idSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		newId := prefix &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength);
		
		if self.newIdNotAlreadyUsed( newId ) then
			// no object of this type already uses this id.
			break;
		endif;
		
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	nextSeqNum := seqNum + 1;
	
	if nextSeqNum.String.length &gt; self.idSeqNumLength then
		nextSeqNum := 1;
	endif;
	
	inTransactionState := process.isInTransactionState;
	
	if not inTransactionState then
		beginTransaction;
	endif;
	
	self.setLastAndNextValues(	newId, nextSeqNum, year.Integer, serverDate);
	
	if not inTransactionState then
		commitTransaction;
	endif;
	
	return newId;
	
epilog

end;</source>
        <Parameter name="_cargoTypeAbbr" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidResetOptions" id="90e94fae-466b-47f5-a9b1-36ede60b0b9a">
        <source>getValidResetOptions(intArray: IntegerArray input; _styleId: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2024		jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars

begin

	if _styleId &lt;= 0 then
		return;
	endif;
	
	if _styleId = AutoIdStyle_P_SSS then
		intArray.add(self.Reset_On_Overflow_Int);
		return;
	endif;
	
	intArray.add(self.Reset_On_Year_Chg_Int);
	intArray.add(self.Reset_On_Overflow_Int);

epilog

end;</source>
        <Parameter name="intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_styleId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="59ead122-07fb-4b9a-96c0-64bec7bcafb5">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoIdGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2024		jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars
	now : Date;
	
begin

	inheritMethod(_proxy);
	
	if not self.isTransient() then
		now := app.actualTimeAppServer().Date;
		
		self.setLastAndNextValues(null, 1, _proxy.CM_AutoInvCatExtNumberGen.currYear, now);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0edab545-ca5c-4a3b-8fbb-043d20c6c0b8">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoInvCatExtNumberGen) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2024		jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars

begin
	self.idPrefix		:= _proxy.idPrefix;
	self.idSeqNumLength	:= _proxy.idSeqNumLength;
	self.idStyle		:= _proxy.idStyle;
	self.resetSeqOn		:= _proxy.resetSeqOn;
	
	self.currSeq 		:= _proxy.currSeq;
	self.currYear		:= _proxy.currYear;
	self.myBusinessUnit	:= _proxy.myBusinessUnit;
	self.currCountry	:= _proxy.currCountry; 		// 09/02/2023	navkc1	Bug 56444
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoInvCatExtNumberGen"/>
    </JadeMethod>
    <JadeMethod name="setLastAndNextValues" id="5e505e45-35c2-4d05-9eb7-08ebeabd01b0">
        <updating/>
        <source>setLastAndNextValues(_lastIdGenerated: String; _nextSeqNum: Real; _seqYear: Integer; _lastGeneratedDate: Date) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navkc1	Initial creation  TFS CR 55300 TASK 55522

*/

vars

begin
	
	self.lastIdGenerated 	:= _lastIdGenerated;
	self.lastGeneratedDate	:= _lastGeneratedDate;
	self.currSeq			:= _nextSeqNum.Integer;
	self.currYear			:= _seqYear;

epilog

end;</source>
        <Parameter name="_lastIdGenerated" type="String"/>
        <Parameter name="_nextSeqNum" type="Real"/>
        <Parameter name="_seqYear" type="Integer"/>
        <Parameter name="_lastGeneratedDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setProxyOtherAttributes" id="3f21a52d-f8fc-4892-adfe-a4d334eff3e1">
        <updating/>
        <source>setProxyOtherAttributes(_currSeq, _currYear : Integer; _bank : CM_Bank; _currCountry : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	navkc1	Initial creation
09/02/2023	navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
*/

vars

begin
	
	self.currSeq		:= _currSeq;
	self.currYear		:= _currYear;
	self.myBusinessUnit	:= _bank;
	self.currCountry	:= _currCountry; // 09/02/2023	navkc1	Bug 56444
	
epilog

end;</source>
        <Parameter name="_currSeq" type="Integer"/>
        <Parameter name="_currYear" type="Integer"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_currCountry" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="0b2e3e5b-3bf9-4232-a91e-c3fa849323a0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars

begin
	
	if _property = null then
		return false;
	endif;
	
	// we are using currSeq, audit that instead
	if _property = CM_AutoIdGenerator::nextSequenceNum then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6dc25f5b-ca93-4d08-9fc7-4eef19512c15">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55522
11 September 2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5c8a739c-216f-4e23-adf7-4db74ed9198b">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55522
11 September 2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars

	now 	: Date;
	year 	: Integer;
	
begin
	
	if self.idStyle = AutoIdStyle_P_SSS then
		return;
	endif;
	
	now := app.actualTimeAppServer().Date;
	year := now.format("yy").Integer;
	
	// Year cannot exceed 2 digits
	if self.currYear.String.length() &gt; 2 then
		app.raiseCMException1(Year_exceed_digit, "2", null, null);
	endif;
	
	// Year cannot be less than current year
	if self.currYear &lt; year then
		app.raiseCMException1(Year_cannot_less_than, year.String, null, null);
	endif;
	
	// Category Prefix cannot be greater than 2 chars
	if self.idPrefix.length() &gt; 2 then
		app.raiseCMException1(Prefix_exceed_chars, "2", null, null);
	endif;
	
	if self.idSeqNumLength &lt; 3 or
		self.idSeqNumLength &gt; 6 then
		app.raiseCMException2(Seq_num_between, "3", "6", null, null);
	endif;
	
	//17/01/2025	navkc1 JIRA Bug MTN-33813 - Don't check Country if the style does not have it included
	if not (self.idStyle = AutoIdStyle_B_L_YY_SSS 
			or self.idStyle = AutoIdStyle_L_YY_SSSS
			) then
			
		if self.currCountry.length() &lt; 2 then
			app.raiseCMException1(Country_must_have_chars, "2", null, null); // 09/02/2023	navkc1	Bug 56444
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
