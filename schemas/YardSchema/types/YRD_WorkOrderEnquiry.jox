    <JadeMethod name="showNewWorkOrder" id="a45cdef9-e8eb-4c9b-8884-0b5109fa0744">
        <source>showNewWorkOrder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
13 Sep 2022 navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
20 Feb 2022 navma1	Bug 56605: MTN - Cancelled voyages in voyage work orders issues and proxy deletion issues on exceptions
27 Jun 2024 navhl20	Bug 64912: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 2
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor
*/

vars
	woForm 			: YRD_WorkOrder;
	pxyWorkOrder,
	realWorkOrder 	: CM_WorkOrder;
	selObj			: Object;
	voyage			: CM_Voyage;	
	task 			: CM_WorkOrderDtl;
	sharedWO		: CM_WorkOrder;
	objArr			: CM_ObjectArray;
	mode			: Integer; //13/11/2024	navkc1 JIRA Story MTN-33012
begin

	selObj := self.tblData.allSelectedObjects.first;
	
	if selObj = null then
		app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
	if selObj.isKindOf(CM_WorkOrder) then
		realWorkOrder := selObj.CM_WorkOrder;
		task		  := realWorkOrder.allWoDtls.first;		//13.09.2022 navma1 #54645
	elseif selObj.isKindOf(CM_WorkOrderDtl) then			//13.09.2022 navma1 #54645
		realWorkOrder := selObj.CM_WorkOrderDtl.myParent;	//13.09.2022 navma1 #54645
		task		  := selObj.CM_WorkOrderDtl;			//13.09.2022 navma1 #54645
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
	endif;
	
	if realWorkOrder &lt;&gt; null and realWorkOrder.isVoyageWorkOrder then				
		voyage := realWorkOrder.CM_WorkOrderVoyage.getMyVoyageObject();				
	endif;	
	
	pxyWorkOrder := realWorkOrder.pxyGetProxyObject();		//27.06.2024 navhl20 #64912
	if pxyWorkOrder &lt;&gt; null then							//20.02.2023 navma1 #56605
		/*In case of a failure before*/
		delete pxyWorkOrder;
	endif;
	
	mode := YRD_WorkOrder.MODE_UPDATE; //13/11/2024	navkc1 JIRA Story MTN-33012
	
	//13/11/2024	navkc1 JIRA Story MTN-33012 - New mode for updating completed work order
	if realWorkOrder.isComplete() then
		mode := YRD_WorkOrder.MODE_UPDATECOMPLETED;
	endif;
	
	pxyWorkOrder 	 := app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
	app.mousePointer := MousePointer_HourGlass;
	
	woForm 			 := app.getForm(YRD_WorkOrder.name).YRD_WorkOrder;
	//jlier1 29/5/25 MTN-34591 
	if woForm &lt;&gt; null and woForm.myWorkOrder &lt;&gt; realWorkOrder then
		woForm:=null;
	endif;
	
	if woForm = null then
		woForm := app.loadForm(YRD_WorkOrder, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrder;
	endif;
	
	if woForm = null then
		return;
	endif;
	
	woForm.centreWindow;
	woForm.setMyTerminal(self.myTerminal);
	//woForm.initialise( self, pxyWorkOrder, YRD_WorkOrder.MODE_UPDATE, pxyWorkOrder.getProxyTask(task), pxyWorkOrder.getWorkOrderMode, voyage );
	woForm.initialise( self, pxyWorkOrder, mode, pxyWorkOrder.getProxyTask(task), pxyWorkOrder.getWorkOrderMode, voyage ); //13/11/2024	navkc1 JIRA Story MTN-33012
	woForm.setDeleteProxy(true);
	woForm.show;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPaymentStatusMenu" id="117a1f7f-808e-4d44-b3c4-b6d81805fd38">
        <source>showPaymentStatusMenu(_wo : CM_WorkOrder; _mnuMaster	: MenuItem);

/*

Purpose:			
	// JLGAB1 08MAR19 update  payment status

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2019	jlgab1	Initial creation

*/

vars
	mnuChild, mnuMaster	: MenuItem;
	mnuIndex, statusIDX : Integer;	
	showMenu : Boolean;
	captionStr : String;
begin

	// JLGAB1 08MAR19 update  payment status
	if not app.isSpecial() then
		return;
	endif;
	
	mnuMaster := _mnuMaster;
	showMenu := true;
	mnuMaster.caption := "DEV - Set All Cash Receipt Payment Status";
	
	foreach statusIDX in 0 to 6 do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
		endif;
		
		captionStr := app.paymentStatusCashEnumToString(statusIDX);
		
		mnuChild.caption := captionStr;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.userObject := _wo;
		mnuChild.helpContextId := statusIDX;
	
	endforeach;
	
	

epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_mnuMaster" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="showSelectedCount" id="c46ed6e0-ede8-4244-be3b-96ef184e3922">
        <updating/>
        <source>showSelectedCount(selected: Integer; max: Integer) updating;
/*

Purpose:			

