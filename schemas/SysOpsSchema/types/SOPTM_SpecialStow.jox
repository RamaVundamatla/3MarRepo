    <JadeMethod name="doDelete" id="c256d9eb-685a-4b21-8421-c13dbe0854e1">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
