    <JadeMethod name="utlUpdateStopOverriddenReason" id="75ded6a9-e853-4431-a118-dce55af461b1">
        <updating/>
        <source>utlUpdateStopOverriddenReason(
	_proxyStopOverriddenReason	: CM_StopOverridenReason input;
	_passport					: CM_Passport input ) updating;
	
/*
Date		Who		Reason
20 Aug 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/
	
vars
	cancelSave					: Boolean;
	expectedEdition				: Integer;
	tempStr						: String;
	realStopOverriddenReason	: CM_StopOverridenReason;
	
begin
	self.initialiseActivity();
	
	_proxyStopOverriddenReason.raiseExceptionIfNotProxy( method );
	
	app.setContinueCMExceptions( true );
	
	_proxyStopOverriddenReason.pxyGetRealObjectAndEdition( realStopOverriddenReason, expectedEdition );
	if realStopOverriddenReason = null then
		tempStr	:= app.getString( Stop_Overridden_Reason );
		app.raiseCMException1( ProxyMgrCannotLocateReal, CM_StopOverridenReason.name, tempStr, null );
		return;
	endif;
	
	app.myValUA.valStopOverriddenReason( realStopOverriddenReason, _proxyStopOverriddenReason );
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions( false );
	
	exclusiveLock( realStopOverriddenReason );
	if _passport.noErrors and realStopOverriddenReason.edition &lt;&gt; expectedEdition then
		tempStr	:= app.getString( Stop_Overridden_Reason );
		app.raiseCMException1( ObjectUpdatedByAnotherUserSave, tempStr, tempStr, null );
		return;
	endif;
	
	if _passport.noErrors then
		realStopOverriddenReason.setForUpdate( _proxyStopOverriddenReason );
	endif;

epilog
	
end;
</source>
        <Parameter name="_proxyStopOverriddenReason" type="CM_StopOverridenReason" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateStopStartJobActivty" id="cc5c24f6-efa8-4c6c-9244-31031603a7d5">
        <updating/>
        <source>utlUpdateStopStartJobActivty(_job : CM_Job;_start, _stop : TimeStamp; _ti : CM_TrackedItem; _passport : CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 26MAR2024
ADO -  CR 62696 TASK 62945 
23 Sep 2024 navbs1  Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_job, 'Stop Start Job');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateStopStartJobActivty(_job, _start, _stop,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// do updates
		/*
		//08.10.2024 navhl20 #12389
		_job.createStopStartTransaction(Job_Action_Start,_start, null);			//23.09.2024  navbs1  #12445
		_job.createStopStartTransaction(Job_Action_Complete,_stop, null);		//23.09.2024  navbs1  #12445*/
		_job.createStopStartTransaction(Job_Action_Start,_start, _ti);			//08.10.2024 navhl20 #12389
		_job.createStopStartTransaction(Job_Action_Complete,_stop, _ti);		//08.10.2024 navhl20 #12389
	endif;
	
	//26/03/2024	navkc1 CR62696 Task 62944
	if _passport.noErrors() then
		_job.updateObjectEdition(_job);
	endif;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_stop" type="TimeStamp"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
