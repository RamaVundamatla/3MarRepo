    <JadeMethod name="translateForm" id="65fd6d94-6d5b-49da-9e1e-15d8c898a3e3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:52:55.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022882, locale);
	btnCancel.translateCaption(Xlat_0015844, locale);
	btnOK.translateCaption(Xlat_0015845, locale);
	lblOpearator.translateCaption(Xlat_0015846, locale);
	lblOperation.translateCaption(Xlat_0015847, locale);
	lblReceival.translateCaption(Xlat_0015848, locale);
	lblReleases.translateCaption(Xlat_0015849, locale);
	lblTitle.translateCaption(Xlat_0015850, locale);
end;</source>
    </JadeMethod>
