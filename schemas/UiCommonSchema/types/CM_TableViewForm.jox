    <JadeMethod name="zClearTblData" id="1fabdb40-40ca-4b74-bf04-983349b247c5">
        <updating/>
        <source>zClearTblData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	entTableRowProxy : EntTableRow;
begin
	
	if (not self.useTblData) then
		return;
	endif;

	self.tblData.clearAllData();
	
/*	//epr par 33900 4/4/14 leaking transients
	foreach entTableRowProxy in self.allTblDataTransientRows do
		if self.tblData.allTblDataEntRows.includes(entTableRowProxy) then
			self.tblData.allTblDataEntRows.remove(entTableRowProxy);
