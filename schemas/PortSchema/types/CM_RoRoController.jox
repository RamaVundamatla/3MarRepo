    <JadeMethod name="reCalcUsedLength" id="815cc66f-0c21-4ea4-a564-7fd43a4c168c">
        <updating/>
        <source>reCalcUsedLength(_control : CMIF_MoveController; isUndoMove : Boolean ) updating;

/*

Purpose:			
	
	Called each time a TI is moved into the Location Controller to update the used length

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwjk3	Initial creation

*/

vars
	used	: Decimal[6,2];
	lc		: CM_RoRoController;
begin
	if not isUndoMove then
		if self = _control.myOriginatingLocation then
			if _control.moveMode = REAL_MODE then
				// This is the source of the move, so we need to decrease the used space by the size 
				// of the ti (plus standard gap if there are more TIs remaining)
				used := self.usedLength - self.getTILengthInMetres(_control.myTrackedItem);
				//if self.allTrackedItems.size() &gt; 0 then
				if self.getNumQueuedPlannedActualTIs() &gt; 0 then
					used := used -  self.myRoRoLaneArea.standardGap;
				endif;
				self.usedLength := used;
				
				used := self.usedLengthActual - self.getTILengthInMetres(_control.myTrackedItem);
				//if self.allTrackedItems.size() &gt; 0 then
				if self.getNumActualTIs() &gt; 0 then
					used := used -  self.myRoRoLaneArea.standardGap;
				endif;
				self.usedLengthActual := used;
			endif;
		else
			// This is the destination of the move, so we need to increase the used space by the size 
			// of the ti (plus standard gap if there are more TIs present in the lane)			
			used := self.usedLength + self.getTILengthInMetres(_control.myTrackedItem);
			//if self.allTrackedItems.size() &gt; 1 then
			if  self.getNumQueuedPlannedActualTIs() &gt; 1 then
				used := used + self.myRoRoLaneArea.standardGap;
			endif;	
			self.usedLength := used;
			if _control.moveMode = REAL_MODE then
				used := self.usedLengthActual + self.getTILengthInMetres(_control.myTrackedItem);
				//if self.allTrackedItems.size() &gt; 1 then
				if self.getNumActualTIs() &gt; 1 then
					used := used + self.myRoRoLaneArea.standardGap;
				endif;
				self.usedLengthActual := used;
			endif;	
		endif;
	else
		if self = _control.myOriginatingLocation then
			// This is the source of the undo move.  No action is required. 
		else
			// This is the destination of the undo move, so we need to decrease the used space by the size 
			// of the TI			
			used := self.usedLength - self.getTILengthInMetres(_control.myTrackedItem);
			if  self.getNumQueuedPlannedActualTIs() &gt; 0 then
				used := used - self.myRoRoLaneArea.standardGap;
			endif;	
			
			self.usedLength := used;			
		endif;	
	endif;
epilog
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="isUndoMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reCalcUsedLengths" id="c8409952-8b8a-4b6c-b1bc-32232f47f936">
        <updating/>
        <source>reCalcUsedLengths(_sendNote : Boolean) updating;

/*

Purpose: recalculate the actual used length from the length of the TIs in the lane

Parameters:			

Return Value:		


Date		Who		Reason
10 March 2010	cnwjk3	PAR 22832

*/

vars
	arrTIs	: CM_TIArray;
	ti		: CM_TrackedItem;
	used	: Decimal[6,2];
	length	: Decimal[6,2];
begin
	create arrTIs transient;
	
	 self.allTrackedItems.copy(arrTIs);

	// Firs the ACTUAL used
	foreach ti in arrTIs do
		length := self.getTILengthInMetres(ti);
		length := length + self.myRoRoLaneArea.standardGap;
		used := used + length;
	endforeach;
	if used &gt; 0 then
		used := used - self.myRoRoLaneArea.standardGap;
	endif;
	
	self.usedLengthActual := used;
	
	// Now used including queued/planned
	used := 0;
	self.getAllQueuedTrackedItems(arrTIs, false);
	self.getAllPlannedTrackedItems(arrTIs, false, false);
	foreach ti in arrTIs do
		length := self.getTILengthInMetres(ti);
		length := length + self.myRoRoLaneArea.standardGap;
		used := used + length;
	endforeach;
	if used &gt; 0 then
		used := used - self.myRoRoLaneArea.standardGap;
	endif;

	self.usedLength := used;

	// Send a note so that the lane re-draws
	if _sendNote then														// cnwjk3 PAR 23443 26/03/2010
		app.myEventManager.createSingleObjInfoNoteEvt(self.myRoRoLaneArea, 
					self.myTerminal.getTerminalEvent(EVENT_TI_MOVE),
					self);
	endif;																	// cnwjk3 PAR 23443 26/03/2010

epilog
	delete arrTIs;
end;</source>
        <Parameter name="_sendNote" type="Boolean"/>
    </JadeMethod>
