    <JadeMethod name="kpdTestStackingSequencer" id="05a68ee1-53f6-4069-a30d-68fc5d2e39f5">
        <source>kpdTestStackingSequencer();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Mar 2009	cnwkpd1	PAR #19164 - Decking Options issues

*/

constants
	Rows			= 20;
	Stacks			= 20;
	Tiers			= 3;
	
vars
	seq				: CMIF_DeckingSequenceService;
	row,
	stack,
	tier,
	sequence		: Integer;
	str				: String;
	startTime,
	endTime			: Decimal[20];
	
begin
	write CrLf &amp; "Starting " &amp; Stacks.String &amp; " x " &amp; Rows.String &amp; CrLf;
	
	create seq transient;
	seq.setExtent(Stacks, Rows, Tiers);
	seq.setRules(DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise);
	
	startTime := app.relativeMachineMicros;
	
	foreach tier in 1 to Tiers do
		write CrLf &amp; "Tier " &amp; tier.String &amp; CrLf;
		foreach row in 1 to Rows do
			str := null;
			foreach stack in 1 to Stacks do
				sequence := seq.getStackingSequence(stack, row, tier);
				str := str &amp; sequence.String.padBlanks(8);
			endforeach;
			write str;
		endforeach;
	endforeach;	
	
	endTime := app.relativeMachineMicros;
	
	write "New method " &amp; (startTime - endTime).abs.String;

	startTime := app.relativeMachineMicros;

	foreach tier in 1 to Tiers do
		write CrLf &amp; "Tier " &amp; tier.String &amp; CrLf;
		foreach row in 1 to Rows do
			str := null;
			foreach stack in 1 to Stacks do
				sequence := seq.getStackingSequenceByStack(stack, row, tier);
				str := str &amp; sequence.String.padBlanks(8);
			endforeach;
			write str;
		endforeach;
	endforeach;	
	
	endTime := app.relativeMachineMicros;
			
	write "Old method " &amp; (startTime - endTime).abs.String;
	
	
epilog

end;</source>
    </JadeMethod>
