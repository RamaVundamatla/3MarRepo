    <JadeMethod name="includeObject" id="55ae081d-dc5f-415a-8704-0b41963b353c">
        <updating/>
        <source>includeObject(_cargoType: CM_CargoType; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL cargo Types not showing in System Admin
begin
	//if _cargoType.id &gt; TI_CargoBOLType_JMTMax then										// TFS 49252
	if _cargoType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	// TFS 49252
		return false;
	endif;
	
/*	if (self.filterAbbreviation = null or _cargoType.abbreviation.toUpper.pos(self.filterAbbreviation.toUpper, 1) &lt;&gt; 0)
	and (self.filterDescription = null or _cargoType.description.toUpper.pos(self.filterDescription.toUpper, 1) &lt;&gt; 0)
	then
		return true;
	endif;
	
	return false;
*/	
	if self.filterTerminal &lt;&gt; null then 
		if  not self.filterTerminal.allCargoBOLTypes.includes(_cargoType) then 
			return false;
		endif;
	endif;
	
	if self.filterAbbreviation &lt;&gt; null then 
		if _cargoType.abbreviation.toUpper.pos(self.filterAbbreviation.toUpper, 1) = 0 then
			return false;
		endif;
	endif;

	if self.filterDescription &lt;&gt; null then
		if _cargoType.description.toUpper.pos(self.filterDescription.toUpper, 1) = 0 then
			return false;
		endif;
	endif;
	
	// PAR 19704. CCMS 1080 - User Defined Cargo Type.
	if not self.chkShowNotAvail.value then	// to show only active cargo type (exclued Not Available For Entry)
		if _cargoType.isNotAvailableForEntry then
			return false;
		endif;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
