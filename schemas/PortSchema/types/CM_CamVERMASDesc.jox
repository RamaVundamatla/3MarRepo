    <JadeMethod name="outputHeader_RFF" id="22cada08-f157-412e-86ed-7d6cbcf107f2">
        <updating/>
        <source>outputHeader_RFF(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment(_protocol, null, "SI",  _camMessage.camVoyage.getSanitisedVoyageCode()), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
