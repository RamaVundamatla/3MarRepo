    <JadeMethod name="valFormData" id="28564c9f-f301-4cc7-a76c-d8a1a976f389">
        <source>valFormData() : Boolean;
// -----------------------------------------------------------------------------
// Created:		21 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	msg	: String;
begin
	msg := null;
	
	if txtCoyCode.text = null then
		msg := msg &amp; "Please enter a company code" &amp; CrLf;
	endif;
		
	if txtCoyName.text = null then
		msg := msg &amp; "Please enter a company name" &amp; CrLf;
	endif;

	if txtClientName.text = null then
		msg := msg &amp; "Please enter a Client name" &amp; CrLf;
	endif;
	
	if self.txtUserName.text = null then
		msg := msg &amp; "Please enter a user name" &amp; CrLf;
	endif;
		
	if self.txtPassword1.text &lt;&gt; self.txtPassword2.text then
		msg := msg &amp; "Passwords are not the same" &amp; CrLf;
	endif;
	
	if self.txtTermName.text = null then
		msg := msg &amp; "Please enter a Terminal Name" &amp; CrLf;
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg, 'Error', MsgBox_Stop_Icon);
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
