    <JadeMethod name="btnCancel_click" id="4024c874-e8c2-4980-b0d9-61d9d4430a89">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.modalResult := 1;
	self.returnedProfileName := null;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="7feec55d-82eb-41af-ae24-77c8007ffe54">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

vars
	lst : ListBox;
	obj : Object;
	
begin
	lst := self.lstDrvProfiles;
	
	if lst.listIndex &lt; 1 or lst.listIndex &gt; lst.listCount then
		// belts and braces
		self.returnedProfileName := null;
	else
		obj := lst.itemObject[lst.listIndex];
		
		if obj = null or (not obj.isKindOf(JtdDriverProfile)) then
			self.returnedProfileName := null;
		else
			self.returnedProfileName := obj.JtdDriverProfile.jtdName;
		endif;
	endif;
	
	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="141d2a9c-7249-4c3e-a699-083262656573">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 116 then // F5
		self.loadTheLot;
		keyCode := 0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="dcaa4d25-b4c2-4a9c-87c0-cf9226806838">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.width := 785;
	self.height := 460;
	self.splitterVert.left := 320;
	self.loadTheLot;
	self.resizeTheLot;
	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadMethodProfilesTable" id="8f50024f-6e36-48b4-81c6-ca4b1e691655">
        <source>loadMethodProfilesTable(dp : JtdDriverProfile) protected;

vars
	mp : JtdMethodProfile;
	tbl : Table;
	
begin
	tbl := self.tblMthProfiles;
	
	tbl.rows := tbl.fixedRows;
	
	if dp = null then
		return;
	endif;

	if dp.jtdAllPrologProfiles.size &gt; 0 then
		tbl.addItem("Prolog");
		tbl.accessCell(tbl.rows, 1).fontBold := true;
		
		foreach mp in dp.jtdAllPrologProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;

	if dp.jtdAllMethodProfiles.size &gt; 0 then
		if dp.jtdAllPrologProfiles.size &gt; 0 or dp.jtdAllEpilogProfiles.size &gt; 0 then
			tbl.addItem("Main");
			tbl.accessCell(tbl.rows, 1).fontBold := true;
		endif;
		
		foreach mp in dp.jtdAllMethodProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;

	if dp.jtdAllEpilogProfiles.size &gt; 0 then
		tbl.addItem("Epilog");
		tbl.accessCell(tbl.rows, 1).fontBold := true;
		
		foreach mp in dp.jtdAllEpilogProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="dp" type="JtdDriverProfile"/>
    </JadeMethod>
    <JadeMethod name="loadTheLot" id="c33c4b2d-f388-44de-b2e0-92e09198942f">
        <source>loadTheLot() protected;

vars
	dsdDict : DriverSchemaDescriptorNameDict;
	dpDict : JtdDriverProfileNameDict;
	dsd : DriverSchemaDescriptor;
	dp : JtdDriverProfile;
	s, ds : String;
	lst : ListBox;
	tbl : Table;
	n : Integer;
	
begin
	self.allDriverProfiles.purge;
	
	lst := self.lstDrvProfiles;
	tbl := self.tblMthProfiles;
	
	lst.clear;
	
	tbl.rows := tbl.fixedRows;
	tbl.accessCell(1, 1).text := "Method" &amp; Tab &amp; "Calls" &amp; Tab &amp; "Delay";
	tbl.accessColumn(2).alignment := Table.Alignment_Center;
	tbl.accessColumn(3).alignment := Table.Alignment_Center;

	create dsdDict transient;
	create dpDict transient;

	// get descriptors for all driver schemas in schema name order
	rootSchema.getAllDriverSubschemaDescs(dsdDict);

	foreach dsd in dsdDict do
		dpDict.clear;
		app.createDriverProfilesFromMethod(dsd.myProfileTextMethod, dpDict, true);

		if dpDict.size &lt; 1 then
			continue;
		endif;

		dpDict.copy(self.allDriverProfiles);
		lst.addItem(dsd.schemaName);
		lst.itemLevel[lst.newIndex] := 1;

		foreach dp in dpDict do
			if dp.jtdDefaultThinkSecs &gt; 0 then
				ds := ", Delay " &amp; dp.jtdDefaultThinkSecs.String;
			else
				ds := null;
			endif;
			s := dp.jtdName &amp; " [" &amp; dp.jtdGetTotalMethods.String &amp; ", ";
			if dp.jtdRandomSelection then
				s := s &amp; "Random" &amp; ds &amp; ']';
			else
				s := s &amp; "In Sequence" &amp; ds &amp; ']';
			endif;
			lst.addItem(s);
			lst.itemLevel[lst.newIndex] := 2;
			lst.itemObject[lst.newIndex] := dp;
		endforeach;
	endforeach;
	
	foreach n in 1 to lst.listCount do
		lst.itemExpanded[n] := true;
	endforeach;
	
epilog
	if dsdDict &lt;&gt; null then
		dsdDict.purge;
		delete dsdDict;
	endif;

	// the contents of dpDict is copied to self.allDriverProfiles,
	// which is purged at the start of the method and also when the
	// form is unloaded
	delete dpDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_click" id="ff669c0b-c6f5-419d-a74f-8017ba850f64">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDrvProfiles_click(listbox: ListBox input) updating;

vars
	obj : Object;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		self.tblMthProfiles.rows := self.tblMthProfiles.fixedRows;
		return;
	endif;
	
	obj := listbox.listObject;
	
	if obj = null or (not obj.isKindOf(JtdDriverProfile)) then
		self.tblMthProfiles.rows := self.tblMthProfiles.fixedRows;
		return;
	endif;

	self.loadMethodProfilesTable(obj.JtdDriverProfile);	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_dblClick" id="3b53f7c1-07a2-4831-a837-33124f6b5a6f">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDrvProfiles_dblClick(listbox: ListBox input) updating;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		return;
	endif;
	if listbox.itemLevel[listbox.listIndex] = 1 then
		listbox.itemExpanded[listbox.listIndex] := not listbox.itemExpanded[listbox.listIndex];
	else
		// do the same as clicking the OK button
		self.btnOK_click(self.btnOK);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_pictureClick" id="97672ff1-1652-4c9d-96d4-11b5d0fc40a4">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDrvProfiles_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;

begin
	if picIndex &lt; 1 or picIndex &gt; listbox.listCount then
		// belts and braces
		return;
	endif;
	listbox.listIndex := picIndex;
	if listbox.itemLevel[picIndex] = 1 then
		listbox.itemExpanded[picIndex] := not listbox.itemExpanded[picIndex];
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resize" id="88266869-b391-4481-9b12-0a1bc05372fb">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	self.resizeTheLot;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTheLot" id="33a6fd9d-dc94-4b44-8dc0-df4a2617ce53">
        <source>resizeTheLot() protected;

vars
	r : Real;
	
begin
	self.btnCancel.top := self.clientHeight - self.btnCancel.height - 4;
	self.btnCancel.left := self.clientWidth - self.btnCancel.width - 4;
	
	self.btnOK.top := self.btnCancel.top;
	self.btnOK.left := self.btnCancel.left - 4 - self.btnOK.width;

	self.splitterVert.top := 0;
	self.splitterVert.height := self.btnOK.top - 8;
	
	self.lstDrvProfiles.move(0, 0, self.splitterVert.left, self.splitterVert.height);

	r := self.splitterVert.left + self.splitterVert.width;	
	self.tblMthProfiles.move(r, 0, self.clientWidth - r, self.splitterVert.height);
	
	self.tblMthProfiles.columnWidth[1] := (self.tblMthProfiles.clientWidth * 0.68).Integer;
	self.tblMthProfiles.columnWidth[2] := (self.tblMthProfiles.clientWidth * 0.16).Integer;
	self.tblMthProfiles.columnWidth[3] := self.tblMthProfiles.clientWidth -
		self.tblMthProfiles.columnWidth[1] - self.tblMthProfiles.columnWidth[2];
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="splitterVert_mouseDown" id="f2a95212-d510-4764-b227-92722b982b39">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterVert_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	self.splitterMoving := true;
	self.drawMode := 7; // xor
	self.autoRedraw := false;
	self.clipControls := false;
	self.drawWidth := 4;
	self.drawStyle := 0;
	self.mouseMileage := self.splitterVert.left;
	self.drawLine(self.mouseMileage + 3, 0, self.mouseMileage + 3, self.splitterVert.height, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="splitterVert_mouseMove" id="c7a2151e-d3d6-4a05-b7f5-029c048f2098">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterVert_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pos : Integer;

begin
	if not self.splitterMoving then
		return;
	endif;
	
	pos := (self.splitterVert.left + x).Integer;
	if pos &lt; 10 or pos &gt; (self.clientWidth - 10) then
		return;
	endif;

	self.drawLine(self.mouseMileage + 3, 0, self.mouseMileage + 3, self.splitterVert.height, White);
	self.mouseMileage := pos;
	self.drawLine(self.mouseMileage + 3, 0, self.mouseMileage + 3, self.splitterVert.height, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="splitterVert_mouseUp" id="ef6cb985-cd05-49f3-9b66-b3a7f2d6a8cc">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterVert_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	if not self.splitterMoving then
		return;
	endif;
	
	self.drawLine(self.mouseMileage + 3, 0, self.mouseMileage + 3, self.splitterVert.height, White);
	self.splitterVert.left := self.mouseMileage;
	self.splitterMoving := false;
	self.resizeTheLot;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="unload" id="c7a0de01-f9f9-4401-be82-f9bf0c37ecc1">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.allDriverProfiles.purge;
end;</source>
    </JadeMethod>
</GUIClass>
