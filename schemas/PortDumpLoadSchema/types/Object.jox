    <JadeMethod name="importPLXMLValidateProperty" id="79f9d1ea-696c-4802-b67b-8b0e5e9bcbe6">
        <updating/>
        <source>importPLXMLValidateProperty(_propertyName : String; _propertyValue : Any) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	//re-implement as neccessary
	if _propertyValue = null then
		return false;
	endif;

	return true;
end;</source>
