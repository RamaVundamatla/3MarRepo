    <JadeMethod name="addIfNewInvoiceType" id="ea57ccce-4268-4c4d-a944-7baf58315a2f">
        <source>addIfNewInvoiceType(_desc : String) : CM_InvoiceDesc;
// conditional create of this invoice type, only if not already present
vars
	invType	: CM_InvoiceDesc;
begin
	invType := self.getInvoiceType(_desc);
	if invType = null then
		invType := self.createInvoiceType(_desc, InvoiceTypeGeneral);
	endif;

	return invType;
end;
</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="addIfNewServiceILD" id="396584ea-9a9c-406f-b3ce-c10cb68d6af7">
        <source>addIfNewServiceILD(_serviceName : String; _calcType : String; _lineTypeName : String; _glCode : CM_GLCode; _invType : CM_InvoiceDesc) protected;
/*

Purpose:		Create service and invoice line type if not already found.  Used for services and invoice line types
				we don't want to keep deleting and recreating.
Parameters:			

Return Value:		


Date		Who		Reason
03 October 2012	cnwjre1	Initial creation

*/

vars
	calType	: CM_CalculationType;
	invLineType : CM_InvoiceLineDesc;
	service	: CM_Service;
	services : CM_ServiceByNameDict;

begin
	create services transient;

	service := self.myBank.services[_serviceName];
	calType := app.myRoot.allCalculationTypesByCode[_calcType];
	if service = null then
		service := self.createInvoiceService(_serviceName, "Remarks", calType, _glCode);
	endif;
	invLineType := self.myBank.invoiceLineDescriptors[_lineTypeName];
	if invLineType = null then
		services.clear;
		services.add(service);
		invLineType := self.createInvoiceLineType(_lineTypeName, calType, _invType, services, "SDT4");
	else
		beginTransaction;
		invLineType.setPropertyValue("bOneLinePerFinancialPeriod", false);
		invLineType.zSetInvoiceType(_invType);
		commitTransaction;
	endif;
	
epilog
	delete services;
end;</source>
        <access>protected</access>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_calcType" type="String"/>
        <Parameter name="_lineTypeName" type="String"/>
        <Parameter name="_glCode" type="CM_GLCode"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="addInvInventoryAllocationLines" id="d768482e-a1c4-45e0-baaf-118a476413d1">
        <source>addInvInventoryAllocationLines(_realAlloc : CM_InvoiceInventoryAllocation; _ctCode, _desc,_ild1, _ild2 : String; _from, _tooo : Integer; _newrange : Boolean);
/*
Purpose:			

Date		Who		Reason
16JUN2021	NAVAB1	TFS 51219
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/

vars
	sb : CM_InventoryServiceBroker;
	bu : CM_Bank;
	pxyQM :CM_QuantityMap;
	pxyQRM, realQRM :CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
	lines : CM_InvoiceLineDescSet; // TFS 40620
	ct : CM_CalculationType;
	mapType	: CM_TranMapInvoiceLineGroupType;
	mesType : CM_MeasurementType;
	serv : CM_Service;
	services : CM_ServiceByNameDict;
	invtype : CM_InvoiceDesc;
begin
	sb := _realAlloc.myServiceBroker.CM_InventoryServiceBroker;
	bu := sb.getBank();
	
	mesType := app.myRoot.allMeasurementTypesByShortName['UT AB ST'];
	
	ct := app.myRoot.allCalculationTypesByCode[_ctCode];
	if ct = null then
		ct := addCalculationType(INV_CALC_TYPE_INVENT_WEIGHT,_ctCode,_desc, "", "", "",0, 0,0,0,false,false,false,true,INV_CALC_TYPE_INVENT_VALUE1, mesType ,null);
		self.assertTrueMsg(ct &lt;&gt; null, "Inventory Allocation - Calc Type " &amp; _ctCode &amp; " is Null");

	endif;

	invtype := self.getInvoiceType(	"UT_VoyageGroup");
	beginLoad;
	pxyQM := sb.myChildQuantityMap.pxyCreateUpdateProxy().CM_QuantityMap;
	endLoad;
	
	if _newrange then
		create pxyQRM transient;
		mapType := bu.getInvLineGroupAll();
		
	else
		realQRM := sb.myChildQuantityMap.allQuantityRanges.first;
		beginLoad;
		pxyQRM := realQRM.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endLoad;
		mapType := realQRM.allTMInvoiceLineMappings.first.CM_TranMapInvoiceLineMapping.myTMInvoiceLineGroupType;
	endif;
	
	pxyQM.setProxy(sb,true, 1,ct, null);

	create lines transient;
	if _ild1 &lt;&gt; "" then
	//	
		self.deleteInvoiceService(_ild1,FORCED_ERASE);
		self.deleteInvoiceLineType(_ild1,FORCED_ERASE);
		
		create services transient;
		serv := self.createInvoiceService(_ild1,"UT Remarks Inventory",ct, null);
		self.assertTrueMsg(serv &lt;&gt; null, "Inventory Allocation - Service " &amp; _ild1 &amp; " is Null");

		services.add(serv);

		ild := self.createInvoiceLineType(_ild1,ct,invtype,services,"SDT1");
		self.assertTrueMsg(ild &lt;&gt; null, "Inventory Allocation - Invoice Line Type " &amp; _ild1 &amp; " is Null");
	
		lines.add(ild);
	endif;
	
	pxyQRM.setProxyInvoiceLineTypes(lines,mapType);
	pxyQRM.setProxy(sb.myChildQuantityMap,_from,_tooo,0);
	
	app.myTrxUA.trxUpdateInvoiceCargoAllocMap(not _newrange, pxyQM,pxyQRM, sb); // trxUpdateInvoiceCargoAllocMap is used by cargo and inventory mapping
	self.assertTrueTrxOKShowPassport("Mapping Invoice Lines 1 " &amp; _realAlloc.description);
epilog
	delete pxyQM;
	delete pxyQRM;
	delete lines;
	delete services;

end;</source>
        <Parameter name="_realAlloc" type="CM_InvoiceInventoryAllocation"/>
        <Parameter name="_ctCode" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_ild1" type="String"/>
        <Parameter name="_ild2" type="String"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_tooo" type="Integer"/>
        <Parameter name="_newrange" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceCargoAllocation" id="ff12b1dc-1bfc-43ee-92c7-0fe543876ebd">
        <source>addInvoiceCargoAllocation(_realTM : CM_TranMapCargoAllocation input; _cargoType : Integer; _imexStatus : Integer; _transType : Integer;
							_inOper : String; _outOper : String; _code,_desc : String;
							_srcTA1 : String;_srcTA2 : String) : CM_InvoiceCargoAllocation;
/*
Purpose:			
Date		Who		Reason
27 March 2015	NAVAB1	Initial creation
09 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
*/

vars

	allTransientCriteriaObj	: CMIF_Array;
	objs : ObjectSet;
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	cmifCriteria : CMIF_YACriteriaPriority;
	proxyYAObj, realAlloc : CM_InvoiceCargoAllocation;

begin
	
	
	// ### Invoice Cargo Allocation
	
	// #### CRITERIA
	create allTransientCriteriaObj transient;
	create objs transient;
	// ### CARGO TYPE
	if _cargoType &lt;&gt; 0 then
		objs.clear;
		objs.add(app.myRoot.allCargoTypesById[_cargoType]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;

	// ### TRANSACTION TYPE
	
	if _transType &lt;&gt; 0 then
		objs.clear;
		objs.add(app.myRoot.allTransactionTypes[_transType]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	// ### SOURCE TERM AREA
	
	if _srcTA1 &lt;&gt; null then
	
		objs.clear;
		objs.add(_realTM.getMyTerminal().allTerminalAreas[_srcTA1]);
		if _srcTA2 &lt;&gt; null then
			objs.add(_realTM.getMyTerminal().allTerminalAreas[_srcTA2]);
		endif;

		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_SrcTermArea].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_SrcTermArea], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	// ### IMEX
	if _imexStatus &lt;&gt; null then
		objs.clear;
		objs.add(app.myRoot.allImexStatuses[_imexStatus]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	// YACriteriaType_InShipOper and YACriteriaType_OutShipOper
	if _inOper &lt;&gt; null then
		objs.clear;
		objs.add(app.myRoot.allOperators[_inOper]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_InShipOper].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_InShipOper], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	if _outOper &lt;&gt; null then
		objs.clear;
		objs.add(app.myRoot.allOperators[_outOper]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_OutShipOper].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_OutShipOper], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	create proxyYAObj transient;
	proxyYAObj.setProxy(_code, _desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.getTerminal());

	proxyYAObj.initialiseProxy(_realTM);							

	//app.myTrxUA.trxUpdateInvoiceCargoAlloc(false,allTransientCriteriaObj, _realTM, proxyYAObj,realAlloc); //19/06/2017 cnwma1 TFS #4498
	app.myTrxUA.trxUpdateInvoiceCargoAlloc(false,false,false,false,allTransientCriteriaObj, _realTM, proxyYAObj,realAlloc);  //19/06/2017 cnwma1 TFS #4498
	self.assertTrueTrxOKShowPassport("Invoice Cargo Allocations - " &amp; _desc);
	
	return realAlloc;
epilog
	allTransientCriteriaObj.purge;
	delete proxyYAObj;
	delete allTransientCriteriaObj;
	delete objs;

end;</source>
        <Parameter name="_realTM" type="CM_TranMapCargoAllocation" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_inOper" type="String"/>
        <Parameter name="_outOper" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_srcTA1" type="String"/>
        <Parameter name="_srcTA2" type="String"/>
        <ReturnType type="CM_InvoiceCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceCargoAllocationLines" id="74b05b75-77b1-4a3a-b70f-2c0cb9eb5a7c">
        <source>addInvoiceCargoAllocationLines(_realAlloc : CM_InvoiceCargoAllocation; _ctCode, _ild1, _ild2 : String; _from, _tooo : Integer; _newrange : Boolean);
/*
Purpose:			
Date		Who		Reason
27 March 2015	NAVAB1	Initial creation
*/

vars
	sb : CM_CargoAllocServiceBroker;
	bu : CM_Bank;
	pxyQM :CM_QuantityMap;
	pxyQRM, realQRM :CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
// TFS 40620	lines : CM_InvoiceLineDescMapDict;
	lines : CM_InvoiceLineDescSet; // TFS 40620
	ct : CM_CalculationType;
	mapType	: CM_TranMapInvoiceLineGroupType;
begin
	sb := _realAlloc.myServiceBroker.CM_CargoAllocServiceBroker;
	bu := sb.getBank();
	ct := app.myRoot.allCalculationTypesByCode[_ctCode];

	
	beginLoad;
	pxyQM := sb.myChildQuantityMap.pxyCreateUpdateProxy().CM_QuantityMap;
	endLoad;
	
	if _newrange then
		create pxyQRM transient;
		mapType := bu.getInvLineGroupAll();
		
	else
		realQRM := sb.myChildQuantityMap.allQuantityRanges.first;
		beginLoad;
		pxyQRM := realQRM.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endLoad;
		mapType := realQRM.allTMInvoiceLineMappings.first.CM_TranMapInvoiceLineMapping.myTMInvoiceLineGroupType;
	endif;
	
	pxyQM.setProxy(sb,true, 1,ct, null);

	create lines transient;
	if _ild1 &lt;&gt; "" then
		ild := bu.invoiceLineDescriptors[_ild1];
		lines.add(ild);
	endif;
	if _ild2 &lt;&gt; "" then
		ild := bu.invoiceLineDescriptors[_ild2];
		lines.add(ild);
	endif;
	
	pxyQRM.setProxyInvoiceLineTypes(lines,mapType);
	pxyQRM.setProxy(sb.myChildQuantityMap,_from,_tooo,0);
	
	app.myTrxUA.trxUpdateInvoiceCargoAllocMap(not _newrange, pxyQM,pxyQRM, sb);
	self.assertTrueTrxOKShowPassport("Mapping Invoice Lines 1 " &amp; _realAlloc.description);
epilog
	delete pxyQM;
	delete pxyQRM;
	delete lines;

end;</source>
        <Parameter name="_realAlloc" type="CM_InvoiceCargoAllocation"/>
        <Parameter name="_ctCode" type="String"/>
        <Parameter name="_ild1" type="String"/>
        <Parameter name="_ild2" type="String"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_tooo" type="Integer"/>
        <Parameter name="_newrange" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceInventoryAllocation" id="bfb338f5-1dfb-4c01-aa93-77f48f80337b">
        <source>addInvoiceInventoryAllocation(_realTM : CM_TranMapInventoryAllocation input; _cargoType : Integer; _moveDir : String; _eventType : Integer;
							_inOper : String; _outOper : String; _code,_desc : String;
							_srcTA1 : String;_srcTA2 : String) : CM_InvoiceInventoryAllocation;
/*
Purpose:			

Date		Who		Reason
16JUN2021	NAVAB1	TFS 51219
*/


vars

	allTransientCriteriaObj	: CMIF_Array;
	objs : ObjectSet;
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	cmifCriteria : CMIF_YACriteriaPriority;
	proxyYAObj, realAlloc : CM_InvoiceInventoryAllocation;

begin
	
	
	// ### Invoice Inventory Allocation
	
	// #### CRITERIA
	create allTransientCriteriaObj transient;
	create objs transient;
	// ### CARGO TYPE
	if _cargoType &lt;&gt; 0 then
		objs.clear;
		objs.add(app.myRoot.allCargoTypesById[_cargoType]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;

	// ### MOVE DIRECTION TYPE
	// app.getErrorString(LocnActMoveStr_BargeToBarge)
	if _moveDir &lt;&gt; "" then
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_LocnActMoveDir].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_LocnActMoveDir], _moveDir, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	// ### TRANSACTION TYPE
	if _eventType &lt;&gt; 0 then
		objs.clear;
		objs.add(app.myRoot.allEventTypesByType[_eventType]);
		create proxyCriteria transient;
		itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_InventoryType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_InventoryType], objs, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
	endif;
	
	
	create proxyYAObj transient;
	proxyYAObj.setProxy(_code, _desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.getTerminal());

	proxyYAObj.initialiseProxy(_realTM);							


	app.myTrxUA.trxUpdateInvoiceInventAlloc (false,false,false,false,allTransientCriteriaObj, _realTM, proxyYAObj,realAlloc); 
	self.assertTrueTrxOKShowPassport("Invoice Inventory Allocations - " &amp; _desc);
	
	return realAlloc;
epilog
	allTransientCriteriaObj.purge;
	delete proxyYAObj;
	delete allTransientCriteriaObj;
	delete objs;

end;</source>
        <Parameter name="_realTM" type="CM_TranMapInventoryAllocation" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_moveDir" type="String"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_inOper" type="String"/>
        <Parameter name="_outOper" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_srcTA1" type="String"/>
        <Parameter name="_srcTA2" type="String"/>
        <ReturnType type="CM_InvoiceInventoryAllocation"/>
    </JadeMethod>
    <JadeMethod name="addNewCargoType" id="d0cd3172-2a7f-47cd-bab3-73defea26c37">
        <source>addNewCargoType(): CM_CargoType;
/*
Purpose:	

Date		Who		Reason
12 August 2024	navab1	CR 65336 TASK 65339
*/
constants
	CARGOTYPEDESC = "UTSLO";
vars
	cargoType: CM_CargoType;
	term : CM_Terminal;
	allComodities	: CM_CommodityByCodeDict;
	comod1			: CM_Commodity;
	comod2			: CM_Commodity;
begin
	term := self.getTerminal();

	self.opts.purge;
	self.opts.addAssociation("teuMultiplier", TEUMultiplierIndexQ);
	self.opts.addAssoc("AllowDuplicateId", false);
	self.opts.addAssoc("isCargoGroupRequired", false);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	create allComodities transient;
	
	comod1 := self.addCommodity("CMX1","Commodity X One",null);
	//comod2 := self.addCommodity("COM1","Comodity CX Two",null); - navpw1 COM1 is used in UT_CargoType::tCommodityCargoNonISO
	comod2 := self.addCommodity("CMX2","Commodity CX Two",null);
	
	allComodities.add(comod1);
	allComodities.add(comod2);
	
	self.opts.addAssoc("Comodities",allComodities);
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	
	return cargoType;
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="addOnsiteCargoForId2" id="32bf46c5-0175-45ab-b493-925af5b3fbe0">
        <updating/>
        <source>addOnsiteCargoForId2(_id : String; _operator : CM_Operator; _daysBack : Integer) : CM_TrackedItem updating, protected;

/*

Purpose:		Add onsite container with the given id, in UT_BS1, with an optional Washed transaction so there is an existing charge
					also optionally back-date the transactions to get storage charges
Parameters:			

Return Value:		


Date		Who		Reason
22 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	baseDate,
	now		: Date;
	ti : CM_TrackedItem;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;

begin

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := self.getTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack &lt;&gt; null, "Block Stack UT_BS1 not found...");

	ti := self.addContainerAtLocation( _id, _operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "4000".Decimal );
	commitTransaction;
	
	// set transaction dates back the given number of days
	if _daysBack &lt;&gt; 0 then
		baseDate := now - _daysBack;	// cargo create date
		self.setTransactionDate(ti, baseDate);
	endif;

	return ti;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_daysBack" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="assertSurcharges" id="4785dd63-b6c1-493b-bc82-cc2eea99db38">
        <source>assertSurcharges(_title : String; _invoice : CM_Invoice; _surchargeLines : CM_InvoiceLineSet input; _surchargeMultiSet : CM_InvTypeCargoMultSchByFromDT input) protected;
/*

Purpose:			Asserts whether surcharges are valid for the invoice

Parameters:			_title				String							The title to use for the error messages
					_invoice			CM_Invoice						The invocie to check
					_surchargeLines		CM_InvoiceLineSet				The lines for surcharging (passing it in to save the creation of a transient everytime)
					_surchargeMultiSet	CM_InvTypeCargoMultSchByFromDT	The  surcharges that need to be applied (passing it in to save the creation of a transient everytime)

Return Value:		NONE

Date		Who		Reason
08 December 2022	navpw1	Initial creation TFS: 54571

*/

constants
	NullMSG							: String = " Expected: 'not null' | Actual: 'null'";
	IsNotEmptyMSG					: String = " Expected: 'Is not empty' | Actual: 'Is empty'";
	IsEmptyMSG						: String = " Expected: 'Is empty' | Actual: 'Is not empty'";
	
vars
	invoice							: CM_Invoice;
	invoiceLines					: CM_InvoiceLineBySeqNumDict;
	line,
	surchargeLine					: CM_InvoiceLine;
	iter							: Iterator;
	surChgExempt					: CM_InvoiceTypeSurchargeExempt;
	ctSurChgMultiRate				: CM_InvTypeCargoMultiSurcharge;
	ctSurchargeAmount,
	ctSurchargeGreaterThan			: Decimal[23,3];
	ctSurchargeGreaterThanLineTotal : Boolean;
	invLineQuantity					: Real;
	effectiveDT						: TimeStamp;
	conversionRate					: CM_CurrencyRate;
	ctSurchargeRate,
	requiredSurchargeAmount,
	invLineTotal					: Decimal [23,6];
	ctSurchgInvLineType				: CM_InvoiceLineDesc;
	
begin
	//Grabbed surcharge lines (Manual) in to a collection
	invoice := _invoice;
	invoiceLines := invoice.invoiceLines;
	surChgExempt := invoice.invoiceType.mySurchargeAndExemptions;
	
	self.assertTrueMsg(surChgExempt &lt;&gt; null, _title &amp; "surChgExempt" &amp; NullMSG);
	
	if surChgExempt.myCurrencyType &lt;&gt; null then
		effectiveDT := invoice.getRateDateForCurrencyCode();
		conversionRate := surChgExempt.myCurrencyType.getRate(effectiveDT);
	endif;
	
	self.assertTrueMsg(surChgExempt.allInvTypeCargoMultiSurcharges.isNotEmpty() &lt;&gt; null, _title &amp; "surChgExempt.allInvTypeCargoMultiSurcharges" &amp; IsNotEmptyMSG);
	self.assertTrueMsg(invoice.totalAmount = invoice.getTotalAmount(), invoice.sequenceNum.String &amp; " Invoice static total does not equal dynamic total");  // ### JIRA 35790 01SEP2025 NAVAB1
	
	surChgExempt.getCargoTypeSurchargesForInv(invoice, _surchargeMultiSet);
	self.assertTrueMsg(_surchargeMultiSet.isNotEmpty() &lt;&gt; null, _title &amp; "surchargeMultiSet" &amp; IsNotEmptyMSG);
	
	foreach surchargeLine in invoiceLines where surchargeLine.manual do
		_surchargeLines.add(surchargeLine);
	endforeach;
	
	iter := invoiceLines.createIterator;
	
	//Looped invoice lines excluding surcharge lines (Manual)
	while iter.next(line) do :invoiceLineLoop
		if line.manual or line.status = CM_InvoiceLine.STATUS_VOIDED then
			continue invoiceLineLoop;
		endif;
		self.assertTrueMsg(line.totalAmount = line.lineTotal,invoice.sequenceNum.String &amp; "/" &amp;  line.sequenceNum.String &amp; " Invoice line static total does not equal dynamic total");  // ### JIRA 35790 01SEP2025 NAVAB1
		
		//Check that surcharges can be applied to invoice here or outside of while loop
		ctSurChgMultiRate := _surchargeMultiSet.findFirstUsing(line.invoiceLineDesc );
		if ctSurChgMultiRate = null then
			//no surcharge to apply
			continue; //Should we continue or assert i.e do we want to stop on this??
		endif;
		
		ctSurchargeRate					:= ctSurChgMultiRate.surchargeRate;
		ctSurchargeAmount				:= ctSurChgMultiRate.surchargeAmount;
		ctSurchargeGreaterThan			:= ctSurChgMultiRate.applyGreaterThanAmount;
		ctSurchargeGreaterThanLineTotal	:= ctSurChgMultiRate.applyGreaterThanLineTotal;
		ctSurchgInvLineType				:= ctSurChgMultiRate.getCargoSurchargeInvLineType();
		
		invLineTotal := line.getLineTotalConverted( conversionRate );
		invLineQuantity := line.quantity;
		
		if ctSurchargeAmount &gt; 0 then //If we have a surcharge amount greater than 0 then apply a fixed rate
			if ctSurchargeGreaterThanLineTotal and invLineTotal &gt;= ctSurchargeGreaterThan then
				requiredSurchargeAmount := ctSurchargeAmount;
			elseif not ctSurchargeGreaterThanLineTotal and invLineQuantity &gt;= ctSurchargeGreaterThan then
				requiredSurchargeAmount := ctSurchargeAmount;
			else
				continue invoiceLineLoop; //Should we assert or continue??
			endif;
		else //Calculate off a percentage
			if ctSurchargeGreaterThanLineTotal and invLineTotal &gt;= ctSurchargeGreaterThan then
				requiredSurchargeAmount := invLineTotal * ( ctSurchargeRate / 100 );
			elseif not ctSurchargeGreaterThanLineTotal and invLineQuantity &gt;= ctSurchargeGreaterThan then
				requiredSurchargeAmount := invLineTotal * ( ctSurchargeRate / 100 );
			else
				continue invoiceLineLoop; //Should we assert or continue??
			endif;
		endif;
		
		if ctSurchgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
			// all good
		else
			// convert requiredSurchargeAmount to other currency
			requiredSurchargeAmount := conversionRate.convertBaseCurrencyToMe(requiredSurchargeAmount, 0);
		endif;
		
		self.assertTrueMsg(_surchargeLines.isNotEmpty, _title &amp; "surchargeLines" &amp; IsNotEmptyMSG);
		
		foreach surchargeLine in _surchargeLines do :surchargeLoop
			//Reverse Engineered applySurcharges to check if they were applied correctly
			//Check surcharge line is for line
			if surchargeLine.lineTotal &lt;&gt; requiredSurchargeAmount then
				continue surchargeLoop;
			endif;
			
			_surchargeLines.remove(surchargeLine);
			break;
			
		endforeach;
		
	endwhile;
	
	//Check collection is empty at end cause they should be removed in the checking loop if they match
	self.assertTrueMsg(_surchargeLines.isEmpty() &lt;&gt; null, _title &amp; "surchargeLines" &amp; IsEmptyMSG);
	
	_surchargeLines.clear();
	_surchargeMultiSet.clear();
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_title" type="String"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_surchargeLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_surchargeMultiSet" type="CM_InvTypeCargoMultSchByFromDT" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignedTeam" id="24d7e9b1-99cd-40f6-ad0a-673f798b1821">
