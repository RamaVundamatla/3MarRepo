    <JadeMethod name="getAuditStringForOperator" id="156611ca-5de6-4d90-bb0f-5c999695f28e">
        <source>getAuditStringForOperator() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	str : String;
	crit : CM_YACriteria;
	carrier : CM_Carrier;

begin
	foreach crit in self.allCriteria discreteLock do
		if str = null then
			str := crit.getDisplayForYAMTableColumn;
		else
			str := str &amp; Comma &amp; Space &amp; crit.getDisplayForYAMTableColumn;
		endif;
	endforeach;
	
	str := str &amp; ": Carriers:";
	foreach carrier in self.allCarriers do
		str := str &amp; carrier.code &amp; Comma &amp; Space;
	endforeach;
	
	if str[str.length-1:end] = Comma &amp; Space then
		str := str[1:str.length-2];
	endif;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="09aa2d46-e164-467d-bcba-1e686595d093">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	carrier : CM_Carrier;
	str : String;
	crit : CM_YACriteria;

begin
	if _attrName = ETRow_Carriers then
		foreach carrier in self.allCarriers do
			if str = null then
				str := carrier.code;
			else
				str := str &amp; Comma &amp; Space &amp; carrier.code;
			endif;
		endforeach;
		return str;
	elseif _attrName = ETRow_CargoType then
		crit := self.getCriteriaFor(YACriteriaType_CargoType);
		if crit &lt;&gt; null then
			return crit.myYACriteriaType.getDataDisplay(crit.myYAData);
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoSubType then
		crit := self.getCriteriaFor(YACriteriaType_Product);
		if crit &lt;&gt; null then
			return crit.myYACriteriaType.getDataDisplay(crit.myYAData);
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsoType then
		crit := self.getCriteriaFor(YACriteriaType_ISO);
		if crit &lt;&gt; null then
			return crit.myYACriteriaType.getDataDisplay(crit.myYAData);
		else
			return null;
		endif;
	elseif _attrName = ETRow_TrailerType then
		crit := self.getCriteriaFor(YACriteriaType_TrailerType);
		if crit &lt;&gt; null then
			return crit.myYACriteriaType.getDataDisplay(crit.myYAData);
		else
			return null;
		endif;
	endif;
	
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchesCriteria" id="4d4d3de9-1772-4b82-997f-b419f19c79b7">
        <source>matchesCriteria(_criteria : CMIF_Array) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	cmifObj : CMIF_Object;
	cmifCriterion : CMIF_YACriteriaPriority;
	crit, currentCrit : CM_YACriteriaPriority;
	matchArray : BooleanArray;
	idx : Integer;

begin
	if _criteria.size &lt;&gt; self.allCriteria.size then
		return false;
	endif;
	
	create matchArray transient;
	foreach idx in 1 to self.allCriteria.size do
		matchArray.add(false);
	endforeach;
	
	idx := null;
	foreach cmifObj in _criteria do
		cmifCriterion := cmifObj.CMIF_YACriteriaPriority;
		idx := idx + 1;
		crit := cmifCriterion.myProxy;
		foreach currentCrit in self.allCriteria do
			if currentCrit.match(crit.CM_YACriteria) then
				matchArray[idx] := true;
			endif;
		endforeach;
	endforeach;
	
	foreach idx in 1 to matchArray.size do
		if matchArray[idx] = false then
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete matchArray;
end;</source>
        <Parameter name="_criteria" type="CMIF_Array"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3cbd8859-05ff-4f80-b70c-3dddcca96703">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	opCrit : CM_OperatorCarrierCriteria;
	completedOK : Boolean;

begin
	opCrit := inheritMethod();
	self.allCarriers.copy(opCrit.allCarriers);
	opCrit.myOperator := self.myOperator;
	completedOK := true;
	
	return opCrit;

epilog
	if not completedOK then
		delete opCrit;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAllCarriers" id="d3c79229-4255-4752-96c1-ba2f557bf8bb">
        <updating/>
        <source>setAllCarriers(_carrierSet : CM_CarrierSet) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	carrier : CM_Carrier;

begin
	self.allCarriers.clear;
	foreach carrier in _carrierSet do
		self.allCarriers.addNoDuplicates(carrier, false);
	endforeach;
epilog

end;</source>
        <Parameter name="_carrierSet" type="CM_CarrierSet"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3810c9da-1014-4554-99b8-5f58707aed9c">
        <updating/>
        <source>setForCreate(_proxy: CM_ObjectMatchCriteria) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	inheritMethod(_proxy);
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="96de10df-b295-469b-b54e-8439bb2e89c2">
        <updating/>
        <source>setForUpdate(_proxy: CM_ObjectMatchCriteria) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	inheritMethod(_proxy);
	
	self.allCarriers.clear;
	_proxy.CM_OperatorCarrierCriteria.allCarriers.copy(self.allCarriers);
	self.myOperator := _proxy.CM_OperatorCarrierCriteria.myOperator;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="setMyOperator" id="aed641aa-e55e-49bb-a40d-4171344174f7">
        <updating/>
        <source>setMyOperator(_operator : CM_Operator) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	self.myOperator := _operator;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="184734dd-5927-439d-a57d-6cfdeeffec16">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	criteria, otherCriteria : CM_YACriteria;
	foundCont, foundChassis, foundSubType : Boolean;
	allObjects : CM_ObjectSet;
	obj : Object;
	cargoType : CM_CargoType;
	subType : CM_Product;

begin
	inheritMethod();
	
	// iso type criteria is only valid if cargo type cirteria includes ISO container
	// trailer tYpe criteria is only valid of cago type criteria includes at least one cargo type that is "Track As Chassis"
	// check cargo sub type criteria is a subtype of one of the selected cargo types
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_ISO then
			foreach otherCriteria in self.allCriteria do 
				if otherCriteria.myYACriteriaType.type = YACriteriaType_CargoType then
					allObjects := otherCriteria.myYAData.getDataValue.CM_ObjectSet;
					foreach obj in allObjects do
						if obj.CM_CargoType.type = TI_CargoType_Container then
							foundCont := true;
							break;
						endif;
					endforeach;
				endif;
			endforeach;
			if not foundCont then
				app.raiseCMException(Container_req_for_isotype, null, null);
			endif;
		elseif criteria.myYACriteriaType.type = YACriteriaType_TrailerType then
			foreach otherCriteria in self.allCriteria do 
				if otherCriteria.myYACriteriaType.type = YACriteriaType_CargoType then
					allObjects := otherCriteria.myYAData.getDataValue.CM_ObjectSet;
					foreach obj in allObjects do
						if obj.CM_CargoType.isTrailer then
							foundChassis := true;
							break;
						endif;
					endforeach;
				endif;
			endforeach;
			if not foundChassis then
				app.raiseCMException(Chassis_req_for_trailertype, null, null);
			endif;
		elseif criteria.myYACriteriaType.type = YACriteriaType_Product then
			subType := criteria.myYAData.getDataValue.CM_ObjectSet.first.CM_Product;
			foreach otherCriteria in self.allCriteria do
				if otherCriteria.myYACriteriaType.type = YACriteriaType_CargoType then
					allObjects := otherCriteria.myYAData.getDataValue.CM_ObjectSet;
					foreach obj in allObjects do
						if obj.CM_CargoType.allProducts.includes(subType) then
							foundSubType := true;
							break;
						endif;
					endforeach;
				endif;
			endforeach;
			if not foundSubType then
				app.raiseCMException(Cargo_type_criteria_not_found, null, null);
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
</Class>
