Date		Who		Reason
05 August 2009	cnwmd1	Initial creation
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if self.startAtDT &lt;&gt; null then
		return self.systemToLocalTime(self.startAtDT).time.asStringJMT;
	else
		return null;
	endif;
epilog

end;</source>
