        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="typeName" id="79033198-9ddb-4913-9dd4-54517526d09c">
        <source>typeName() : String;
/*
Date		    Who			Reason
05 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.myDeck &lt;&gt; null then
		return self.myDeck.typeName &amp; " (" &amp; app.getErrorString(Graphic).toUpper() &amp;")";
	else
		return app.getErrorString(Graphic).toUpper();
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
