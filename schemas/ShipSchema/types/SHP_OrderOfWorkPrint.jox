    <JadeMethod name="doBuildBaysFast" id="ea781032-dd50-43ad-a06c-4b6c59c03bc9">
        <updating/>
        <source>doBuildBaysFast(_voyageJob : CM_VoyageJob; _displayMode : Integer; _seqReporter : CMIF_JobSequenceReporter input) updating, protected;
/* ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
30 Oct 2012	PJS		PAR #30631 - moved over from redundant Seq sheet form
01 Aug 2013	EPR  	CCMS 2265 
*/
vars
	bayOne,	bayTwo: CM_Bay;
begin

	_voyageJob.getBays(bayOne, bayTwo);
	if bayOne = null then
		return;
	endif;

	_seqReporter.baysDescription := bayOne.id;

	if bayTwo &lt;&gt; null then
		_seqReporter.baysDescription := _seqReporter.baysDescription &amp; '/' &amp; bayTwo.id &amp; ' (' &amp; bayOne.idBay40 &amp; ')';
	endif;
	
	if _voyageJob.ordinalDeck = DeckOnDeck then
		_seqReporter.baysDescription := app.getErrorString1(On_Deck, _seqReporter.baysDescription);	//30631
	else
		_seqReporter.baysDescription := app.getErrorString1(Under_Deck, _seqReporter.baysDescription);  //30631
	endif;

	//epr CCMS 2265 refactored code block into own method to get the image
	_seqReporter.bayPicture := self.getLOLOImageDetailed(_voyageJob); 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_seqReporter" type="CMIF_JobSequenceReporter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildDeckPic" id="49519953-56ce-40c8-8139-ae8cb103b622">
        <updating/>
        <source>doBuildDeckPic(_voyageJob : CM_VoyageJob;_seqReporter : CMIF_JobSequenceReporter input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Aug 2011	cnwer1	Initial creation CCMS MES 1033
30 Oct 2012	PJS		PAR #30631 - Copied from Seq sheet form		

*/

vars	
	voyageDeckJob : CM_VoyageDeckJob;
	deck 		: CM_Deck;
	deckImage	: Binary;
	roroPrintForm : SHP_ROROPrint;
begin
	// not a voyage deck job then return
	if not _voyageJob.isKindOf(CM_VoyageDeckJob) then
		return;
	endif;
	
	voyageDeckJob:=_voyageJob.CM_VoyageDeckJob;
	deck:=voyageDeckJob.myDeck;
	_seqReporter.baysDescription :=deck.code;
	
	if deck.myDeckLayout = null then
		return;
	endif;
	
	create roroPrintForm transient;
	//epr ccms 2265 31/7/13 
	deckImage:=roroPrintForm.getROROJobImagePosition(voyageDeckJob);
	
	_seqReporter.bayPicture := deckImage;	
	
epilog
	delete roroPrintForm;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_seqReporter" type="CMIF_JobSequenceReporter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbCraneBuildSC" id="7d72c070-5241-4472-b09f-70a9dc8eaa73">
        <source>doCmbCraneBuildSC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2012	cnwpjs1	Initial creation  PAR #30631  - From sequence sheet form

*/

vars
	saveIdx,
	idx : Integer;
	theVoyageJS : CM_VoyageJobSheet;
	workPointObj	: CM_Object;
begin
	
	saveIdx := self.cmbCrane.listIndex;
	self.cmbCrane.clear;
	self.cmbCrane.sorted := false;
	if self.myCurrentVoyage = null then
		return;
	endif;

	idx := self.cmbCrane.addItem(app.getErrorString(Unallocated_jobs));  //30631
	self.cmbCrane.itemObject[idx] := null;
	self.cmbCrane.itemData[idx] := CMUI_QueryEnquiry.JobType_UnallocatedSC;
	idx := self.cmbCrane.addItem(app.getErrorString(All_Jobs));  //3063
	self.cmbCrane.itemObject[idx] := null;
	self.cmbCrane.itemData[idx] := CMUI_QueryEnquiry.JobType_AllSC;
	
	foreach theVoyageJS in self.myCurrentVoyage.allJobSheets do
		workPointObj:=theVoyageJS.getMyWorkPointObject;
	
	//epr CCMS 1033 15/8/2011
		if workPointObj &lt;&gt; null then
			idx := self.cmbCrane.addItem(workPointObj.IF_VoyageWorkPoint.getID &amp; " - " &amp; workPointObj.IF_VoyageWorkPoint.getDescription);
			self.cmbCrane.itemObject[idx] := workPointObj;
			self.cmbCrane.itemData[idx] := CMUI_QueryEnquiry.JobType_CraneSC;
		endif;
	endforeach;

	if saveIdx &gt; 0 and saveIdx &lt;= self.cmbCrane.listCount then
		self.cmbCrane.listIndex := saveIdx;
	else
		self.cmbCrane.listIndex := 2;
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbSequenceBuild" id="ee3e8379-e78b-4256-bf2b-77200e4735f4">
        <source>doCmbSequenceBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2012	cnwpjs1	Initial creation  PAr #30631 - From Sequence Sheet form

*/

vars

	idx : Integer;
begin
	self.cmbSequence.clear;
	self.cmbSequence.sorted := false;
	
	idx := self.cmbSequence.addItem(app.getErrorString(Standard));
	self.cmbSequence.itemData[idx] := self.Seq_Standard;
	idx := self.cmbSequence.addItem(app.getErrorString(Custom));
	self.cmbSequence.itemData[idx] := self.Seq_Custom;
	idx := self.cmbSequence.addItem(app.getErrorString(Planned));
	self.cmbSequence.itemData[idx] := self.Seq_Planned;


	self.cmbSequence.listIndex := 2;
//	self.tblQuery.setValueByControlName(self.cmbSequence.name,self.cmbSequence.text);

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbSideBuild" id="274820f7-641e-444b-8eff-a9deaa43b0cc">
        <source>doCmbSideBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2012	cnwpjs1	Initial creation  PAR # 30621

*/

vars
	idx 		: Integer;
begin

	self.cmbSide.clear;
	self.cmbSide.sorted := false;
	
	idx := self.cmbSide.addItem("Port");
	self.cmbSide.itemData[idx] := 1;
	idx := self.cmbSide.addItem("Starboard");
	self.cmbSide.itemData[idx] := 0;
	
	self.cmbSide.listIndex := 1;
	
	//08 Sep 2021	NDL	TFS 51929
	if self.myCurrentVoyage = null then
		return;
	elseif self.myCurrentVoyage.starboardBerthed then
		self.cmbSide.listIndex := 2;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doJobBuild" id="089ed46c-ff88-493c-a5d8-5572ee0e4597">
        <updating/>
        <source>doJobBuild() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2012	cnwpjs1	Initial creation  PAR #30631 -  code is from Sequence sheet form

*/

vars
	workPointObj	: CM_Object;
	theJob 			: CM_Job;
	theJobs 		: CM_JobArray;
	jobsTable		: CMUI_ListTable;
	craneID,
	jobNum			: String;
	jobType			: Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	jobsTable := self.lstJobs;
	jobsTable.allSelectedObjects.clear();
	jobsTable.rows := 0;

	if self.cmbCrane.listIndex &gt; -1 then
		jobType := self.cmbCrane.itemData[self.cmbCrane.listIndex];
		workPointObj :=self.cmbCrane.listObject.CM_Object;
		if workPointObj &lt;&gt; null then
			craneID:=workPointObj.IF_VoyageWorkPoint.getID;
		endif;
	else
		app.msgBox(app.getErrorString(Please_Select_Crane) ,app.getErrorString(Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
	
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create theJobs transient;
	self.myCurrentVoyage.getOOWJobs(jobType,craneID,false,theJobs);
	

	foreach theJob in theJobs do
		if theJob.jobType = JOB_TYPE_USER then // &lt;&lt;&lt; PAR 5487 - NO Hatch Lid Jobs!!!
			continue;
		endif;
		if theJob.CM_VoyageJob.isLoadedToOperations then // &lt;&lt;&lt; PAR 5487
			jobNum := theJob.CM_VoyageJob.jobNum;
			jobsTable.accessRow(jobsTable.addItem('0' &amp; Tab &amp; jobNum)).itemObject := theJob;
		endif;
	endforeach;
	
epilog
	delete theJobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="8f4f4c9e-22c5-4c26-a8fa-44632fbaa60c">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2012	cnwpjs1	Initial creation  PAr #30631
09 Feb 2017	cnwdap1	TFS 3220 LNX Voyage Operations Enhancements
*/

vars

	printOK : Boolean;
	
	jrwDesignName : String;
	qryRep : CM_QryReport;
	reportName : String;
	repIndex : Integer;
	oowForm : Boolean;

begin
	if myParentForm.isKindOf(SHP_OrderOfWorkForm) then			// TFS 3220
		oowForm := true;										// TFS 3220
	endif;														// TFS 3220
	if oowForm then												// TFS 3220
		myParentForm.SHP_OrderOfWorkForm.setXMLPrintPreview(chkPreview.value);
	endif;														// TFS 3220


	if optOOWPrint.value then
		printOK:= doOrderOfWorkPrint;
		if oowForm then											// TFS 3220
			myParentForm.SHP_OrderOfWorkForm.setXMLPrintLidComments(chkLidOOW.value);
		endif;													// TFS 3220
		
	elseif self.optSequenceSheet.value then
		printOK := doSequenceSheetPrint;
		if oowForm then											// TFS 3220
			myParentForm.SHP_OrderOfWorkForm.setXMLPrintLidComments(chkLidSeqSheet.value);
		endif;													// TFS 3220
		
	elseif self.optReport1.value then	//03 Feb 2016 2016	NDL	TFS 3216/3047
		reportName := self.myTerminal.getConfig(DefVoyageRep1).String;
		if reportName &lt;&gt; null then
			if reportName &lt;&gt; null then
				repIndex := self.cmbSendToRep.findStringExact(1,reportName);
			endif;
			if repIndex &gt; 0 then
				qryRep := self.cmbSendToRep.itemObject[repIndex].CM_QryReport;
			else
				return;
			endif;
		endif;
		
	elseif self.optReport2.value then	//03 Feb 2016	NDL	TFS 3216/3047
		reportName := self.myTerminal.getConfig(DefVoyageRep2).String;
		if reportName &lt;&gt; null then
			if reportName &lt;&gt; null then
				repIndex := self.cmbSendToRep.findStringExact(1,reportName);
			endif;
			if repIndex &gt; 0 then
				qryRep := self.cmbSendToRep.itemObject[repIndex].CM_QryReport;
			else
				return;
			endif;
		endif;
		
	elseif self.optSendToRep.value then		//03 Feb 2016	NDL	TFS 3216/3047
		qryRep := self.cmbSendToRep.listObject.CM_QryReport;
		if qryRep = null then
			app.msgBox(app.getErrorString( No_Report_Selected), app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endif;
	
	if qryRep &lt;&gt; null then
		printOK := self.doPrintVoyageReport( qryRep );
	endif;

	
	if printOK then	
		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOrderOfWorkPrint" id="4283964d-6d91-4d4f-be0a-ac9d134b4758">
        <source>doOrderOfWorkPrint() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2010	consw1	PAR #22886 - Leaking report transients
29 oct 2012	PJS		PAR #30631 - Voyage rationalisation 
 ---------------------------------------------------------------------------
*/

vars
	qryReport				: CM_QryReport;
	filter					: CMQF_VoyageOrderOfWork;
	jrwManager				: JadeReportWriterManager;
	jadeReportWriterReport	: JadeReportWriterReport;
	jadeReport				: JadeReport;
	jrwFileName				: String;
	
begin
	
	qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyageOrderOfWork);
	if qryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query report "Order Of Work" not found');
		return false;
	endif;
	
	filter := qryReport.createFilter().CMQF_VoyageOrderOfWork;
	filter.allTerminals.add(self.myTerminal);
	filter.setMyVoyage( self.myCurrentVoyage );
	filter.showRemarks := showRemarks;
	

	filter.hideNonCargoJobs := chkHideHatch.value;
	filter.doHatchLidJobRemarks:= chkLidOOW.value;
	
//	filter.hideNonCargoJobs := self.xmlHideHatchJobs;	//ccms 1081
//  filter.doHatchLidJobRemarks := self.xmlPrintLidComments;	// ccms1052 cnwvu1 - to print HATCH LID job remarks in report

	
	filter.jobType := self.jobType;
	
	if filter.jobType = SHP_OrderOfWorkForm.JobType_CraneSC then
		filter.craneId := self.filterWorkPoint.getID;
	endif;

	qryReport.doFilter(filter, app.myPassport);
	
	//now get the JRW report and tell it to print
	jrwManager := app.createReportWriterManager();
	jrwFileName := qryReport.jrwReportName.first;
	
	jadeReportWriterReport := jrwManager.getReport(jrwFileName);

	if jadeReportWriterReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Jade Report not loaded into system using JRW');
		return false;
	endif;
	
	create jadeReport transient;
	jadeReport.description := jadeReportWriterReport.name;
	app.printer.setReport(jadeReport);
	jadeReportWriterReport.run();
	app.printPreview(jadeReport, true);
	
	abortTransaction;		// to clear any locks held by the report writer
	
	return true;
	
epilog
	delete jadeReportWriterReport;
	delete jrwManager;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintVoyageReport" id="28358b4c-7ddc-4438-9ba0-b11dc837848a">
        <source>doPrintVoyageReport( qryReport : CM_QryReport input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	filter : CMQF_VoyageSummary;
	jrwManager : JadeReportWriterManager;
	jadeReportWriterReport : JadeReportWriterReport;
	jadeReport : JadeReport;
	jrwFileName : String;

begin

	if qryReport = null then
		return false;
	endif;

	filter := qryReport.createFilter().CMQF_VoyageSummary;
	filter.allTerminals.add(self.myTerminal);
	filter.setMyVoyage( self.myCurrentVoyage );
	
	qryReport.doFilter(filter, app.myPassport);
	
	//now get the JRW report and tell it to print
	jrwManager := app.createReportWriterManager();
	jrwFileName := qryReport.jrwReportName.first;
	
	jadeReportWriterReport := jrwManager.getReport(jrwFileName);

	if jadeReportWriterReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Jade Report not loaded into system using JRW');
		return false;
	endif;
	
	create jadeReport transient;
	jadeReport.description := jadeReportWriterReport.name;
	app.printer.setReport(jadeReport);
	jadeReportWriterReport.run();
	app.printPreview(jadeReport, true);
	
	abortTransaction;		// to clear any locks held by the report writer
	
	return true;

epilog

end;</source>
        <Parameter name="qryReport" type="CM_QryReport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="04beb16b-0895-44ee-acd0-e35b4f1d2341">
        <source>doSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2012	cnwpjs1	Initial creation PAR #30631

*/

vars

begin
	
	if self.btnSelectAll.bubbleHelp = app.getErrorString(SelectAll) then
		self.lstJobs.setAllToTrue;
		self.btnSelectAll.bubbleHelp := app.getErrorString(Deselect_All);
	else
		self.lstJobs.setAllToFalse;
		self.btnSelectAll.bubbleHelp := app.getErrorString(SelectAll);
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSequenceSheetPrint" id="97954fa9-eb4a-4fdf-ab17-cc63eac8e415">
        <updating/>
        <source>doSequenceSheetPrint() : Boolean updating;



//
// Purpose:     
//			 
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// 24 Aug 2011	cnwer1		CCMS 1033 - changed so will print decks if it is a voyage deck job being printed
// 29 Oct 2012	cnwpjs1		Initial creation  PAR #30631 - Code copied over from redundant Seq sheet form
// 19/03/2013		cnwab1		request was hard coded for a LOLO  slot request, so crashed when it was a RORO reqeust
//
// ---------------------------------------------------------------------------

vars
	obj							: Object;
	voyageJob					: CM_VoyageJob;

	pageHolderReport,
	jadeReport					: JadeReport;
	jrwReport,
	jrwROROReport				: JadeReportWriterReport;
	clonedPrintData,
	printData					: JadePrintData;
	printDataArray				: JadePrintDataArray;
	seqReporter					: CMIF_JobSequenceReporter;
	jrwTrans					: CM_JRWVoyageSummary;
	jobTable					: CMUI_ListTable;
	displayMode					: Integer;
	wle							: CM_WorkListEntry;
	dynaDict					: DynaDictionary;
	cmifMonitor					: CMIF_Monitor;
	partsComplete,
	partsInJob					: Integer;
	termDict					: CM_TerminalByCodeDict;
	isFirst	, getROROReport		: Boolean;
	documentType,
	orientation ,
	copies,
	topOfPage, 
	bottomOfPage,
	leftMargin,
	rightMargin,
	borderWidth,
	duplex 						: Integer;
	collate 					: Boolean;
begin
	
	if self.lstJobs.allSelectedObjects.isEmpty then
		app.msgBox(app.getErrorString(Must_Select_Job),app.getErrorString(No_Jobs_Selected), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	app.mousePointer := Busy;
	isFirst := true;
	create dynaDict transient;
	jobTable := self.lstJobs;
	
	//if it is a RORO voyage get the 
	getROROReport:= self.myCurrentVoyage.myROROStructure &lt;&gt; null;
		
	
	if self.optNormal.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtMedium); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtMediumRORO);
		endif;
	elseif self.optLargeP.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtLarge); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtLargeRORO);
		endif;
	elseif self.optLargeL.value then
		jrwReport := self.getReportFromConfig(ShipSeqShtXLarge); // CCMS 1494
		if getROROReport then
			jrwROROReport := self.getReportFromConfig(ShpSeqShtXLargeRORO);
		endif;
	endif;
		
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The report named for the sequence sheet report could not be found');
		return false;
	endif;
	
	if getROROReport and  jrwROROReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The report named the RORO sequence sheet report could not be found');
		return false;
	endif;
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWVoyageSummary).CM_JRWVoyageSummary;
	jrwTrans.doPadZeros := not self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;

	//epr ccms 2265 par 32142 set orientation of report so when creating image know size of page
	jrwReport.getPageOptions(documentType,
							orientation ,
							copies,
							topOfPage, 
							bottomOfPage,
							leftMargin,
							rightMargin,
							borderWidth,
							collate,
							duplex );
	app.printer.orientation:=orientation;
	
	
	cmifMonitor := self.showMonitorForPrinting();
	partsInJob := jobTable.allSelectedObjects.size();
	
	//30631 - now translatable
	if partsInJob &gt; 30 then
		if app.msgBox(app.getErrorString(Warning_30_More_Reports), 
					app.getErrorString(Warning), 
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) &lt;&gt; MB_OK then
			return false;
		endif;
	endif;
	
	self.setDynaKey;

	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTrans.setAllTerminals(termDict);

	
	jrwTrans.orderedByOption := self.dynaKey;
	
	// ???  does not look right ???  - print preview option
	// print weights not used in this class
	//jrwTrans.printWeights := true
			
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	if jrwROROReport &lt;&gt; null then
		jrwROROReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	endif;
	
	app.printer.printPreview := false;
	create printDataArray transient;
	
	foreach obj in jobTable.allSelectedObjects do
		voyageJob := obj.CM_VoyageJob;

			// ______________________ ccms1052 cnwvu1 01/02/2007 __________________________
		if chkLidSeqSheet.value then
			jrwTrans.hatchLidJobRemarks := voyageJob.getSeqSheetNextLidJobRemarks( voyageJob );
		else
			jrwTrans.hatchLidJobRemarks := null;
		endif;
		
		jrwTrans.allJobSequenceReporters.purge();
		create seqReporter transient;
		jrwTrans.allJobSequenceReporters.add(seqReporter);
		seqReporter.myVoyageJob := voyageJob;
		
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.message := app.getErrorString1(Building_Sequence_Info,voyageJob.jobNum);	//30631
			cmifMonitor.updateProgress(null, partsInJob, partsComplete);
			if cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Cancel then
				return false;
			elseif cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Return then
				break;
			endif;
		endif;
		
		if not isFirst then	
			dynaDict.clear();
			dynaDict.clearKeys();
		endif;
		isFirst := false;
		dynaDict.setMembership(CM_VoyageWLE);
		dynaDict.addMemberKey(self.getConvertedDyna(voyageJob.isTwinLift, self.dynaKey), false, true);
		dynaDict.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, true);
		dynaDict.endKeys(true);
		foreach wle in voyageJob.workListEntries do
//			if voyageJob.isSOB and wle.myRequest.CM_SlotRequest.isLoad then
			if voyageJob.isSOB and wle.myRequest.isReleaseType() then		// 22/8/17 MAP TFS5493
				continue;
			endif;
			dynaDict.add(wle);	
		endforeach;
		
		dynaDict.copy(seqReporter.allWLEs);
		
		//30631 - now translatable
		if voyageJob.isSOB then
			displayMode := ShpDisplayMode_ColCodeDisch;
			seqReporter.jobTitle := app.getErrorString(Shift_Board_Sequence);
		elseif voyageJob.isRelease then
			displayMode := ShpDisplayMode_ColCodeLoad;
			seqReporter.jobTitle := app.getErrorString(Load_Sequence_Sheet);
		else 
			displayMode := ShpDisplayMode_ColCodeDisch;
			seqReporter.jobTitle := app.getErrorString(Discharge_Sequence_Sheet);
		endif;

		
		
		self.doBuildBaysFast(voyageJob, displayMode, seqReporter);
		
		//epr CCMS 1033 24/8/11
		self.doBuildDeckPic(voyageJob, seqReporter);

		if cmifMonitor &lt;&gt; null then
			cmifMonitor.message := app.getErrorString1(JRW_Processing_Output,voyageJob.jobNum); //30631
			cmifMonitor.updateProgress(null, partsInJob, partsComplete);
			if cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Cancel then
				return false;
			elseif cmifMonitor.monitorReturnValue = cmifMonitor.MonitorReturnValue_Return then
				break;
			endif;
		endif;
	
		// Reset printer
		app.printer.abort();
		create jadeReport transient;
		app.printer.setReport(jadeReport);
		
		
		if voyageJob.isKindOf(CM_VoyageDeckJob) then
			jrwROROReport.setPreviewOptions(false, false, false, true, null);
			jrwROROReport.run();
		else
			jrwReport.setPreviewOptions(false, false, false, true, null);
			jrwReport.run();
		endif;
		partsComplete := partsComplete + 1;
		
		foreach printData in jadeReport.printArray do
			clonedPrintData := printData.cloneSelf(true);
			printDataArray.add(clonedPrintData);
		endforeach;
	
		seqReporter.bayPicture := null;
		delete jadeReport;
		delete seqReporter;
	endforeach;
	
	//pile all the pages into the first report object
	create pageHolderReport transient;
	pageHolderReport.description := app.getErrorString(Sequence_Sheet_Report);
	printDataArray.copy(pageHolderReport.printArray);
	if self.chkPreview.value then
		app.printPreview(pageHolderReport, true);
	else
		app.printer.printPreview := false;
		app.printerFixPAR34782(pageHolderReport);
		app.printer.printReport(pageHolderReport);
	endif;
	
	dynaDict.clear();
	dynaDict.clearKeys();
	
	return true;
	
epilog
	endLoad;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;

	
	delete jadeReport;
	delete dynaDict;
	delete jrwReport;
	delete jrwROROReport;
	delete jrwTrans;
	delete termDict;
	delete seqReporter; //epr par 27470 23/5/2011
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getConvertedDyna" id="c16c4b5d-fa44-4dd9-a814-16ce2c0e8084">
        <source>getConvertedDyna(_isTwin : Boolean; _dyna : String) : String protected;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// 
// 30 Oct 2012		PJS		PAR #30631 - copied over from redundant Seq Sheet form
// -------------------------------------------
vars

begin


	if not _isTwin then
		return _dyna;
	endif;
	
	if _dyna = ETRow_SeqNumWorkOrder then
		return ETRow_SeqNumWorkOrder;
	elseif _dyna = ETRow_SeqNumPort then
		return CM_VoyageWLE::numSeqPortTwin.name;
	elseif _dyna = ETRow_SeqNumStarboard then
		return CM_VoyageWLE::numSeqStarboardTwin.name;
	elseif _dyna = ETRow_SeqNumCustomPort then
		return CM_VoyageWLE::numSeqPortTwinCustom.name;
	elseif _dyna = ETRow_SeqNumCustomStarboard then
		return CM_VoyageWLE::numSeqStarboardTwinCustom.name;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_isTwin" type="Boolean"/>
        <Parameter name="_dyna" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstRepNameForJRWD" id="0050713e-e889-474f-ac59-e0745cab6eb2">
        <source>getFirstRepNameForJRWD( _jrwDesignName : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	pos		: Integer;
	jrwDesignName	: String;
	qrs : CM_QryReportSystem;
	qru : CM_QryReportUser;

begin

	//This is a bit hot and miss, but if the users have just one report
	//declared matching this, (or they actually only want the first one)
	//all will be good, otherwise they will need to select from the combo.

	if _jrwDesignName = null then
		return null;
	endif;
	
	jrwDesignName := _jrwDesignName;
	pos := _jrwDesignName.pos("?", 1);
	if pos &gt; 0 and pos &lt; _jrwDesignName.length then
		jrwDesignName := _jrwDesignName[1:pos-1];
	endif;
	
	foreach qrs in CM_QryReportSystem.instances do
		if qrs.jrwReportName.includes(jrwDesignName) then
			return qrs.reportName;
		endif;
	endforeach;
	
	foreach qru in CM_QryReportUser.instances do
		if qru.jrwReportName.includes(jrwDesignName) then
			return qru.reportName;
		endif;
	endforeach;
	
	// didn't find one...
	return _jrwDesignName;
	
epilog

end;</source>
        <Parameter name="_jrwDesignName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLOLOImageDetailed" id="6eff2fb6-3d69-4083-ab9c-f21164c839ce">
        <source>getLOLOImageDetailed(_voyageJob : CM_VoyageJob) : Binary;
/*

Date		Who		Reason
31 July 2013	cnwer1	Initial creation PAR

*/

vars
	bayOne,	bayTwo: CM_Bay;
	tmpVoyage	: CM_Voyage;
	theHolds : CM_HoldByOrdinalDict;
	tmpBayController : SHP_BayDrawingController;
	frWidth, frHeight,displayModeOne, displayModeTwo : Integer;
	isSidePort,onDeck	: Boolean;
	ordinalDeck : Integer;
begin
	_voyageJob.getBays(bayOne, bayTwo);
	if bayOne = null then
		return null;
	endif;
	
	if _voyageJob.isSOBOnly() then
		// this is SOB so if only displaying 1 bay show the planned locations, i.e. the load colour coding.
		//			else if showing 2 bays show from and to
		if bayTwo &lt;&gt; null then // PAR 7634 added
			displayModeOne := ShpDisplayMode_ColCodeDisch;
			displayModeTwo := ShpDisplayMode_ColCodeLoad;
		else
			displayModeOne := ShpDisplayMode_ColCodeLoad; // PAR 7634 added
			displayModeTwo := ShpDisplayMode_ColCodeLoad; // PAR 7634 added
		endif;
	else
		if _voyageJob.isSOB then
			displayModeOne := ShpDisplayMode_ColCodeDisch;
		elseif _voyageJob.isRelease then
			displayModeOne := ShpDisplayMode_ColCodeLoad;
		else 
			displayModeOne := ShpDisplayMode_ColCodeDisch;
		endif;
		displayModeTwo :=displayModeOne;

	endif;
	
	
	tmpVoyage := _voyageJob.myVoyage;
	
	create theHolds transient;
	theHolds.add(bayOne.myHold);
	if bayTwo &lt;&gt; null then
		if bayOne.myHold &lt;&gt; bayTwo.myHold then
			theHolds.add(bayTwo.myHold);
		endif;
	endif;
	
	tmpBayController := self.myBayDrawingController;
	
	tmpBayController.init(tmpVoyage, theHolds, self.myTerminal);
	tmpBayController.setDisplayMode(displayModeOne);
	tmpBayController.setJobSeqSheet(_voyageJob);
	tmpBayController.setFromVoyage(_voyageJob.myVoyage); //### &lt;&lt;&lt;&lt;&lt;&lt; added SATURDAY 14th AUGUST 4:43 PM 2004 by AKB
	self.frmBayFast1.myJobSeqSheet := _voyageJob;
	self.frmBayFast2.myJobSeqSheet := _voyageJob;
	tmpBayController.showNoColours := true;
	tmpBayController.setAmPrinting(true, CMUI_GridDrawingController.PrintOutput_Medium, false);
	tmpBayController.setScale(CMUI_GridDrawingController.PrintOutput_Medium, true, true);

	// PAR-8919
	isSidePort := self.cmbSide.itemData[self.cmbSide.listIndex].Integer.Boolean;
	tmpBayController.setIsStarboardBerthed(not isSidePort);
	tmpBayController.isTwinLiftSequenceView := _voyageJob.isTwinLift;

	onDeck := _voyageJob.ordinalDeck = DeckOnDeck;

	tmpBayController.drawSelfSeqSheet(true,self.frmBayFast1,bayOne,onDeck); 
	if bayTwo &lt;&gt; null then
		tmpBayController.setDisplayMode(displayModeTwo);
		
		ordinalDeck := _voyageJob.getBaysSecondOrdinalDeck(bayTwo.CM_BayVoyage); // PAR 8729
		if ordinalDeck &lt;&gt; -1 then // if its -1 then use teh same ordinal deck as bay 1
			onDeck := ordinalDeck = DeckOnDeck;
		endif;
		
		tmpBayController.drawSelfSeqSheet(true,self.frmBayFast2,bayTwo,onDeck); 
		frWidth := (self.frmBayFast1.width + self.frmBayFast2.width).Integer;
		frHeight := self.frmBayFast1.height.Integer;
		frHeight := frHeight.max(self.frmBayFast2.height.Integer);
		self.frmBayFast2.visible := true;
	else
		frWidth := self.frmBayFast1.width.Integer ;
		frHeight := self.frmBayFast1.height.Integer;
	endif;
	self.frmBayFast1.visible := true;
	self.frmBayFast1.left := 1;
	self.frmBayFast1.top := 1;
	self.frmBayFast2.left := self.frmBayFast1.width + 5;
	self.frmBayFast2.top := 1;
	self.frmBayFastPic.ignoreSkin := true;//added by cnwyl for par 12465
	self.frmBayFastPic.move(0,0,frWidth,frHeight);
	
	return self.frmBayFastPic.createPictureIndirect(false, true);
epilog
		//epr 27470 more leaking transients
	delete theHolds;

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getReportFromConfig" id="efbc8cfa-b9d1-44bd-8be0-61ff22a0f2cb">
        <source>getReportFromConfig(_config : String) : JadeReportWriterReport;
// ---------------------------------------------------------------------------
// Created:		13 December 2006 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1494
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// 30 Oct 2012	PJS			PAR # 30631 (moved over ferom seq sheet form)
// ---------------------------------------------------------------------------
vars
	jrwReport	: JadeReportWriterReport;
	reportString : String;
	jrwManager					: JadeReportWriterManager;
begin
	jrwManager := app.createReportWriterManager();
	reportString := self.myTerminal.getConfig(_config).String;
	if reportString = null then
		reportString:=app.getDefaultSeqSheetReportName(_config);
		beginTransaction;
		self.myTerminal.setConfig(_config,reportString);
		commitTransaction;
	endif;

	jrwReport := jrwManager.getReport(reportString);
	if jrwReport = null then
		reportString:=app.getDefaultSeqSheetReportName(_config);
		beginTransaction;
		self.myTerminal.setConfig(_config,reportString);
		commitTransaction;
		jrwReport := jrwManager.getReport(reportString);
	endif;

	return jrwReport;
	
epilog
	delete jrwManager;
end;</source>
        <Parameter name="_config" type="String"/>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="handlePrintOption" id="637d3c09-1c61-489c-9389-9d8e378995e1">
        <source>handlePrintOption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwpjs1	Initial creation  PAR # 30631

*/

vars

begin

	self.grpSeqPrint.visible := self.optSequenceSheet.value;
	self.fldSeqSheet.visible := self.optSequenceSheet.value;	//18 Jan 2016	NDL	TFS 3216/3047
	self.grpOrderOfWork.visible := self.optOOWPrint.value;	//18 Jan 2016	NDL	TFS 3216/3047
	self.cmbSendToRep.enabled := self.optSendToRep.value;	//18 Jan 2016	NDL	TFS 3216/3047
/*	if optOOWPrint.value then 
		grpOrderOfWork.visible := true;
		fldSeqSheet.visible := false;
	else
		
		grpOrderOfWork.visible := false;
		fldSeqSheet.visible := true;

	endif;
*/
epilog

end;</source>
