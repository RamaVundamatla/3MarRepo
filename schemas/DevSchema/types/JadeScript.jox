    <JadeMethod name="sh3GetReportXMLInfo" id="56c99ec5-e1f1-4132-ae89-2c217691aec2">
        <source>sh3GetReportXMLInfo();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		08 February 2010
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
constants
	FileName 	= 'C:\aJunk\viewtestmain.xml';
	TagName		= '&lt;name&gt;';
	TagClose	= '&lt;/';
	SystemRepPrefix = 'CM_';
vars
	file : File;
	line,
	reportName : String;
	namePos,
	endTagPos,
	sysRepPref : Integer;
	doMonitorDesign,
	doMonitorView : Boolean;
	designArray,
	viewArray : StringArray;
	
begin
	self.sh3StandardInitialize();
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := FileName;
	
	create designArray transient;
	create viewArray transient;
	
	file.open;
	doMonitorDesign := false;
	doMonitorView := false;
	while not file.endOfFile do
		line := file.readLine();
		if line = '&lt;JRDReport&gt;' then
			doMonitorDesign := true;
		elseif line = '&lt;/JRDReport&gt;' then
			doMonitorDesign := false;
		elseif line = '&lt;JRDReportingView&gt;' then
			doMonitorView := true;
		elseif line = '&lt;/JRDReportingView&gt;' then
			doMonitorView := false;
		endif;
		
		if doMonitorDesign then
			namePos := 1;
			endTagPos := 1;
			namePos := line.pos(TagName, 1);
			if namePos &gt; 0 then
				endTagPos := line.pos(TagClose, 1);
				reportName := line[TagName.length + 1 : endTagPos - TagName.length - 1];
				//write reportName;
				sysRepPref := reportName.pos(SystemRepPrefix, 1);
				//if sysRepPref &lt;=0 then
				if sysRepPref = 1 then
					//write '********* ' &amp; reportName &amp; ' &gt;&gt;&gt;&gt;&gt;  POSSIBLE NON SYSTEM REPORT - PLEASE CONFIRM **********';
					write reportName;
					designArray.add(reportName);
				endif;
				doMonitorDesign := false;
			endif;
		endif;
		
		if doMonitorView then
			namePos := 1;
			endTagPos := 1;
			namePos := line.pos(TagName, 1);
			if namePos &gt; 0 then
				endTagPos := line.pos(TagClose, 1);
				reportName := line[TagName.length + 1 : endTagPos - TagName.length - 1];
				//write reportName;
				viewArray.add(reportName);
				doMonitorView := false;
			endif;			
		endif;
	endwhile;
	
	write 'Report Views';
	foreach reportName in viewArray do
		write reportName;
	endforeach;
	
	write CrLf;
	write 'Report Designs';
	foreach reportName in designArray do
	endforeach;
		write reportName;
	file.close;
epilog
	delete file;
	delete viewArray;
	delete designArray;
	write 'terminado';
end;</source>
    </JadeMethod>
