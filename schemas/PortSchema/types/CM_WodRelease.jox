    <JadeMethod name="hasExtnsNotApprovedOrNotPaid" id="47812833-2746-4164-a763-f9059c3361c9">
        <source>hasExtnsNotApprovedOrNotPaid():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	woDtl : CM_WorkOrderDtl;
	wo : CM_WorkOrder;

begin

	if self.allExtensionWorkOrders.isEmpty then
		return false;
	endif;
	
	foreach woDtl in self.allExtensionWorkOrders do
		wo := woDtl.getMyParent;
		if wo.taskStatus &lt;&gt; WO_STATUS_COMPLETE then
			// not approved / completed.
			return true;
		endif;
		if wo.allCashReceipts.isEmpty then
			// can't be any paid
			return true;
		endif;
		if not wo.allCashReceiptsAre( CM_CashReceipt.PAID ) then
			// at least one not paid
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailableForExtension" id="f1b0752c-fa40-471f-9f4a-b110652d53d1">
        <source>isAvailableForExtension():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2019	jlgndl1	Initial creation	TFS 43405
Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
*/

vars

	parent : CM_WorkOrder;
	relReq : CM_BulkRelease;
begin

	relReq := self.getMyReleaseRequest();		//Bug 44134
	
	if relReq = null or relReq.isComplete then	//Bug 44134
		return false;
	endif;
	
	if self.allAvailableTIs.isEmpty then
		return false;
	endif;

	parent := self.getMyParent;
	if parent = null then
		return false;
	endif;
	
	
	if parent.allCashReceipts.isEmpty then
		return false;
	endif;
	
	if not parent.allCashReceiptsAre( CM_CashReceipt.PAID ) then
		return false;
	endif;
	
	if self.hasExtnsNotApprovedOrNotPaid() then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOKToDelete" id="cdda8f7d-8a27-41ee-a069-ad9b67c1ecdb">
        <source>isOKToDelete(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders fix ups
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//
vars

begin
	return self.requiredByDT = null and self.getMyReleaseRequest() = null and self.allToDoRequests.isEmpty;	//Bug 44134
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
