    <JadeMethod name="getDataForEntRowName" id="d0ee9c7a-c207-4403-8f6f-a239c8c3252f">
        <source>getDataForEntRowName(_entRowName: String): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	accessCell : JadeTableCell;
begin
	row:=self.findRowWithEntRowName(_entRowName);
	if row = 0 then
		return null;
	endif;
	
	accessCell:=self.myTable.accessCell(row,self.dataColumn);
	
	if accessCell = null or
		self.myTable.accessRow(row).visible = false then
		return null;
	endif;
	
	return accessCell.text;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
