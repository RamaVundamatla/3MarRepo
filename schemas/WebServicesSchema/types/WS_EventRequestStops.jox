<Class name="WS_EventRequestStops" id="d4b4e2bd-681e-47f6-8fde-8a9303ab6bdf">
    <superclass name="WS_EventRequestTI"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used for Adding details ie.[Stops,Grades,Remarks &amp; ToDo Tasks] when tracked item received.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="additionalRequiredInfo" id="55f30e95-e438-48f9-90f3-dd88286cc5bf">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Additional information that is required for the addition or removal of that stop.</text>
    </PrimAttribute>
    <PrimAttribute name="autoCleanUp" id="4c7df840-8ff3-4517-82c7-44252922d855">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>whether this request need to be deleted after an event occured or not  ie[True/False].</text>
    </PrimAttribute>
    <PrimAttribute name="cargoRemarks" id="ab5c7699-9bd8-40e8-a578-88f12fdb7a79">
        <type name="String"/>
        <access>readonly</access>
        <text>Used to update cargo remarks when tracked item received.</text>
    </PrimAttribute>
    <PrimAttribute name="clearanceExpiryDate" id="ac5dfc58-f894-4a07-a8a1-47a974316efe">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The date on which the Stop clearance expires.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="grade" id="afabddfe-9a32-4aa5-a26d-aee93d165125">
        <embedded/>
        <type name="WS_AvailabilityGrade"/>
        <access>readonly</access>
        <text>Availability grade that you want to apply to the cargo.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="isCertified" id="7585d4a5-ac88-4621-af20-db0be39a08b8">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isClear" id="8b57f736-66d2-403b-b012-76378bffa916">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>whether this for clearing stop or not. ie[True/False].</text>
    </PrimAttribute>
    <PrimAttribute name="isNotify" id="51b76cbe-0e7b-48b5-85d3-a9da8f4b5393">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Notification required or not. ie[True/False].</text>
    </PrimAttribute>
    <ImplicitInverseRef name="stops" id="c64637a9-f214-4aca-9a5e-e4b185f9c06a">
        <embedded/>
        <type name="WS_Stop"/>
        <access>readonly</access>
        <text>Stop Information.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="toDoRemarks" id="4a477ea2-3e2d-4c8a-a03a-3f4d382e9e6d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="toDoTasks" id="a75a2554-214e-4851-b185-ed190ec03c97">
        <embedded/>
        <type name="WS_ToDoTaskDesc"/>
        <access>readonly</access>
        <text>ToDo Tasks that you want to apply to the cargo.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="totalWeight" id="9919ce1c-32ae-43b2-bc4c-501490f2037c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="type" id="bf22f153-606d-4aa5-b0c3-3d7f531f5b72">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="weighCertifyingPerson" id="dc779e65-5841-41dc-afc1-2cca2ed17dce">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="weightCerifyingAuthority" id="5aa210d8-9988-468e-91bd-e2021ef92fc1">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="c8ce6a5b-59b8-4342-ba1a-d1e08c415c3e">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwkao1	Initial creation

*/

vars

begin
	delete self.stops;
	delete self.toDoTasks;
	delete self.grade;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="afcac6e1-6cea-4de9-b286-ec6885a06fa7">
        <updating/>
        <source>setProxyFromObject(_object: CM_EventRequestStops) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);	
	//cnwmc5 - PAR 32206 - 5 Sep 2013
	self.isNotify			:= _object.isNotify.String;//app.getYesNo(_object.isNotify);
	self.isClear			:= _object.isClear.String;//app.getYesNo(_object.isClear);
	 //10/09/2009 cnwdz2 20629
	self.autoCleanUp	:= _object.autoCleanup.String;//app.getYesNo(_object.autoCleanup);
	
	//cnwjo3 par 25843
	self.additionalRequiredInfo := _object.additionalRequiredInfo;
	//self.clearanceExpiryDate := _object.clearanceExpiryDate.asStringJMT();
	self.clearanceExpiryDate := _object.clearanceExpiryDate.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
	
	create self.stops transient;
	if _object.myStopsTable &lt;&gt; null then
		self.stops.setProxyFromObject(_object.myStopsTable);
	endif;
	
	create self.grade transient;
	if _object.myGrade &lt;&gt; null then
		
		self.grade.setProxyFromObject(_object.myGrade);
	endif;
	
	self.cargoRemarks:=_object.cargoRemarks;
	
	self.toDoRemarks := _object.toDoRemarks;
	
	create self.toDoTasks transient;
	if _object.myToDoTaskDesc &lt;&gt; null then	
		self.toDoTasks.setProxyFromObject(_object.myToDoTaskDesc);
	endif;
	
	//epr TFS 38000 17/4/18 weight update for web portal
	self.type :=_object.typeString;
	self.description :=_object.getUpdateDetails;	
	self.isCertified :=_object.isWeightCertified;
	self.totalWeight :=_object.totalWeight.asStringJMT;
	self.weighCertifyingPerson:=_object.reference;
	self.weightCerifyingAuthority:=_object.weightCertifiedName;
	
	
epilog

end;</source>
        <Parameter name="_object" type="CM_EventRequestStops"/>
    </JadeMethod>
</Class>
