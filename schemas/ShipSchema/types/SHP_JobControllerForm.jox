    <JadeMethod name="doPrint" id="cf7784c2-9cb3-4079-8911-bd48210a4552">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	tmpJadeReport  : JadeReport;
	tmpTable : Table;
	theReturn, idx : Integer;
	theLeft : Real;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	gridArea : CMUI_GridArea;
	theReport : CMUI_ReportLine;
	theType, theCode : String;
	theString : String;
	theX, theY, theWidth, theHeight, theColour : Integer;
	thePicture ,cranesPicture : Binary;
	tmpShpJobControllerController : SHP_JobControllerController;
	craneHeight : Real;
	cmifVoyageStats : CMIF_VoyageStats;
begin
	if self.myVoyage = null then
		app.msgBox("Please select a voyage to print","Print Error",MsgBox_OK_Only);
		return;
	endif;

	theString := "Are you sure that you want to print " &amp; self.myVoyage.code &amp; "?";

	create theReport transient;
	theReport.initReport;
	theReport.lblTitle01.caption :=  app.getProductName;
	theReport.lblTitle03.caption :=  "Ship Job Controller"; //app.myRoot.getVersionAndPatchLevel();
	theReport.lblTitle04.caption := self.myVoyage.vesselName.trimBlanks;
	theReport.lblTitle02.caption := self.myVoyage.code &amp; " -"  ;
	theReport.lblPrintedBy.caption := null;
	theReport.lblPrintedBylbl.caption := null;
	theReport.initReportForLandscape();
	app.printer.setMargins(Print_Landscape,5,5,5,5);
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Ship Job Controller";
	app.printer.setReport(tmpJadeReport);

	app.printer.printPreview := false;
	app.printer.documentType := Print_A4;
	
	create tmpShpJobControllerController transient;
	self.frmPrtScrollMain.visible:=true;
	self.frmPrtScrollMain.clearGraphics;
	self.frmPrtScrollMain.autoRedraw := true;
	theColour := self.frmPrtScrollMain.backColor; 
	self.frmPrtScrollMain.backColor := White;
	self.frmPrtScrollMain.height:=501;
	self.frmPrtScrollMain.width:=900;
	tmpShpJobControllerController.setFlipVertical(self.myJobController.flipVertical);
	tmpShpJobControllerController.setDetails(self,
											self.myVoyage,
											self.frmPrtScrollMain,
											self.frmPrtScrolling,
											null,
											1,
											500,
											1045,
											1,
											0,
											self.myJobController.hideCompleted);	
	create cmifVoyageStats transient;
	cmifVoyageStats.init(self.myVoyage);
	self.myJobController.getVoyageStats(cmifVoyageStats);
	tmpShpJobControllerController.getVoyageTimes(cmifVoyageStats);
	tmpShpJobControllerController.drawPrintVoyageNew(cmifVoyageStats);
	delete cmifVoyageStats;
	// ## PRINT THE MAIN SHIP GRAPHIC		
	theReport.printLine("");
	self.frmPrint.visible := true;
	self.frmPrint.autoRedraw:=true;
	
	app.printer.setPrintPosition(100);		
	self.frmCranesNew.backColor:=White;
	cranesPicture:=self.frmCranesNew.createPictureIndirect(false,true);
	craneHeight:=self.frmCranesNew.height; 
	thePicture := self.frmPrtScrollMain.createPictureIndirect(false,true);
	self.frmPrint.move(10,1, 1050,500 + craneHeight + 10 );
	self.frmPrint.drawPictureAt(cranesPicture,1,1);
	self.frmPrint.drawPictureAt(thePicture,1,1 + craneHeight +10);
	app.printer.print(self.frmPrint);
	self.frmPrtScrollMain.backColor := theColour;
	self.frmCranesNew.backColor:= theColour;
	//theReport.printLine("");
	//theReport.printLine(self.caption);
	
	app.printer.close();
	app.printPreview(tmpJadeReport, true);
	
	

epilog
//self.frmPrtScrollMain.visible:=false;
	self.frmPrint.visible:=false;
	self.frmPrtScrollMain.visible := false;
	self.frmPrtScrollMain.left := 5;
	delete theReport;
	delete tmpShpJobControllerController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="122e73be-bc51-4ade-b171-05fc465045e9">
