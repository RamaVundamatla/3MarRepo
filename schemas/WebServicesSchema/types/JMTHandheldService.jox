    </JadeMethod>
    <JadeMethod name="putAllCargoPackToRelease" id="6a389a0a-4d54-43de-8af4-b40d577a047d">
        <updating/>
        <source>putAllCargoPackToRelease(request : WS_CargoPackToReleaseRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2021	jlier1	Initial creation 51879
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	response : WS_Response;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	cargoOid : String;
	parentCargo,cargo : CM_TrackedItem;
	cmifLoader : CMIF_MobileGenericAgent;
	setParentFromChild  : Boolean;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	reason :String;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Cargo_item_not_found,request.releaseOid, null,null);
		return response;
	endif;
		
	//epr TFS 5535 8/8/17
	parentCargo:=app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		return response;
	endif;
	setParentFromChild :=  parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and parentCargo.isStorage;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	
	
	
	foreach cargoOid in request.allCargoOids discreteLock do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		
		//already packed maybe from previous call before a warning
		if cargo.myParent = parentCargo then
			continue;
		endif;
		
		if not setParentFromChild then
			parentCargo.validateCargoToPack(cargo);
			if app.myPassport.hasErrors then
				return response;
			endif;
		endif;			
		quantity := cargo.totalQuantity;
		weight := cargo.totalWeight;
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,quantity, weight,reason);
		if reserveDetail = null then
			app.raiseCMException(Cargo_item_release_issue,null,null);
			return response;
		endif;
		reserveDetail.validateForPack(reserveDetail, cargo, quantity, weight);
		if app.myPassport.hasErrors then
			return response;
		endif;
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxUpdatePackCargo(parentCargo, cargo, quantity, weight, setParentFromChild,release, reserveDetail,true,null, app.myPassport);	//19.03.2024 navhl20 #62863
		if not app.myPassport.trxCompletedOK then
			return response;
		endif;
		
	endforeach;
	
	return response;
epilog
	delete cmifLoader;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoToLoadToRelease" id="bc7d84e3-f205-452b-8a79-8dfddd85173a">
        <updating/>
        <source>putAllCargoToLoadToRelease(request : WS_CargoLoadToReleaseRequest): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_Response;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	vehicle  : CM_Vehicle;
	chassis	  : CM_TILC;
	wagon  : CM_Wagon;
	cmifLoader : CMIF_MobileGenericAgent;
	cargo : CM_TrackedItem;
	roadJob : CM_RoadJob;
	targetLocation 	: CM_LocationsController;
	reason : String;
	wle: CM_WorkListEntry;
	cargoOid : String;
	getReserveFromCargo : Boolean;
	moveController : CMIF_MoveController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
		release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	getReserveFromCargo:=reserveDetail = null;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	vehicle:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Vehicle).CM_Vehicle;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
	endif;
	if vehicle = null then
		//lets see if it is a chassis
		chassis:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_TILC).CM_TILC;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;	
		if chassis = null then
			wagon:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Wagon).CM_Wagon;
			if app.myPassport.hasErrors then
				app.myPassport.clearErrorsWarnings;
			endif;	
		endif;
	endif;	
	
	if vehicle = null and  chassis = null and wagon = null  then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);

	if vehicle &lt;&gt; null then
		roadJob:=vehicle.getCurrentRoadJob();
		targetLocation:=vehicle.locationsController;
	elseif chassis &lt;&gt; null then
		roadJob:=chassis.jobRoadRelease;
		targetLocation:=chassis.allLCs.first;
	endif;
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		//already loaded maybe from the first call before any cargo had warnings
		if cargo.myPrimaryActualLocation = targetLocation then
			continue;
		endif;
		
		
		if getReserveFromCargo then
			reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,cargo.totalQuantity.max(1), cargo.totalWeight,reason);
		endif;
		wle:=cmifLoader.getWleForLoadTarget(wagon,roadJob,cargo,reserveDetail);
		cmifLoader.setMyWle(wle);
	
		if wagon &lt;&gt; null then
			targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
		endif;
		cmifLoader.setMyLocationsController(targetLocation);
		
		cmifLoader.validateReleaseLoad(reserveDetail, roadJob,cargo.quantity.max(1),cargo.totalWeight);
	
		if app.myPassport.hasErrors then
			return response;
		endif;
		if app.myPassport.hasWarnings and not request.warningsAcknowledged then
			return response;
		endif;
		//we have cargo, reserve and target location
		if wle &lt;&gt; null and (wle.myTrackedItem = null or wle.myTrackedItem.isRRP ) then
			delete moveController;
			create moveController transient;
			moveController.setMyWorkListEntry(wle);
			moveController.setMyToPrimaryLocation(targetLocation);
			moveController.setMyTrackedItem(cargo);
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				return response;
			endif;
		else
			if not cmifLoader.moveTI(cargo, null, targetLocation, wle, true, null, null, reserveDetail) then
				return response;
			endif;
		endif;
		
	endforeach;
	
		
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoToPickingLocation" id="92d261cc-1b24-41a6-a555-a9308cf013f6">
        <updating/>
        <source>putAllCargoToPickingLocation(request : WS_CargoPickingRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail : CM_ReserveDetail;
	release	: CM_BulkRelease;
	targetLocation : CM_LocationsController;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	stagedAreas : CM_LCSet;
	tis : CM_TISet;
	cargoOid : String;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(No_release_item_selected,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if targetLocation = null then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	
	
	create tis transient;
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		tis.addNoDuplicates(cargo,false);
		
		if ( cargo.myCargoType.isBulkByVolume or cargo.myCargoType.isBulkByWeight) then
			weight :=weight + cargo.totalWeight;		
		else
			
			quantity:=quantity +	cargo.totalQuantity;
		endif;		
		
	endforeach;
	
	if not request.warningsAcknowledged then
		create allWarningsToIgnore transient;
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String) then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release) then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);		
				endif;
			endif;
		endif;
		
		if  not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String)   then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
		
		create stagedAreas transient;
		if not release.validateStagedToOneArea( stagedAreas ) and not allWarningsToIgnore.includes(Releas_staged_multip_areas_con.String)  then
			app.raiseCMWarning(Releas_staged_multip_areas_con,null,null,null);
		endif;
		
		if not allWarningsToIgnore.includes(This_relea_curre_stage_into_su.String)  then
			if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; targetLocation then
				app.raiseCMWarning2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, targetLocation.getFullId,null,null,null);
			endif;
		endif;
			
		if  not allWarningsToIgnore.includes(Will_OverStage.String)   then
			if reserveDetail.wouldBeOverStaged( null, quantity, weight ) then
				app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
			endif;
		endif;
	endif;
	
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	app.myTrxUA.trxStageMultiCargoForRelease(tis, reserveDetail,targetLocation, app.myPassport);
	
	return response;
epilog
	delete allWarningsToIgnore;
	delete stagedAreas;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoPickingRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoAssignToCargoGroup" id="62e92404-a1cd-4995-8fa9-b0ad793ca4e2">
        <updating/>
        <source>putCargoAssignToCargoGroup(request : WS_AssignCargoToGroupRequest;cargoOid : String ) :WS_AssignCargoToGroupResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation 51683

*/

vars
	response : WS_AssignCargoToGroupResponse;
	cga, completeAssignment, nextAssignment  : CM_CargoGroupAssignment;
	cg 	: CM_CargoGroup;
	cargo : CM_TrackedItem;
	terminal : CM_Terminal;
	location,newLocation : CM_LocationsController;
	foundHeight : Integer;
	info , moreInfo: String;
	onlyCompleteGroup,completeGroup, clearCargoGroup , clearLocation : Boolean;
	nextCargoGroup : CM_CargoGroup ; 
	cgsToComplete : CM_TISet;
	strArray : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmHHCargoGroupMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cga:=app.myPassport.getObjectOfTypeFromOid(request.groupAssignOid,CM_CargoGroupAssignment).CM_CargoGroupAssignment;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	
	cg:=app.myPassport.getObjectOfTypeFromOid(request.cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
	if cg = null then
		//need to change to appriopriate error
		app.raiseCMException(Cargo_group_found, null, null);
		return response;
	endif;
	
	cargo:=app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	terminal.findLocationFromString(request.locationId.asStringRESTFUL ,true,location,foundHeight);
	
	if location = null  then
		app.raiseCMException1(Location_NotFound,request.locationId.asStringRESTFUL,null,null);	
		return response;
	endif;
	
	info :=cg.validateForAssignMove(cga,cargo,nextCargoGroup,newLocation, onlyCompleteGroup,completeGroup,clearCargoGroup, clearLocation);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if onlyCompleteGroup then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxCargoGroupComplete(cg,app.myPassport);
		
		if not app.myPassport.hasErrors then
			if nextCargoGroup &lt;&gt; null then
				response.nextCargoGroupOid:=nextCargoGroup.getOidAsString;
				response.clearLocation:=clearLocation;
				response.clearCargoGroup:=clearCargoGroup;
			endif;
		endif;
		
		return response;
	endif;
	
	create cgsToComplete transient;
	if  completeGroup then
		cgsToComplete.add(cg);
	endif;
	
	if nextCargoGroup &lt;&gt; null then
		cg:=nextCargoGroup;
	endif;
	if newLocation &lt;&gt; null then	
		location:=newLocation;
	endif;
	
	create strArray transient;
	if cga.getNotYetScanned( strArray, true ) = 1 then
		// this is the last ti, we must be all complete
		completeAssignment :=  cga;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxAddToCargoGroup(cg, cargo, location, cgsToComplete, completeAssignment, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if newLocation &lt;&gt; null then
		response.newLocationId:=newLocation.getFullId;
	endif;
	if nextCargoGroup &lt;&gt; null then
		response.nextCargoGroupOid:=nextCargoGroup.getOidAsString;
	endif;
	
	if completeAssignment &lt;&gt; null then
		nextAssignment := completeAssignment.getNextAvailAssignment();
		if nextAssignment &lt;&gt;  null then	
			create response.myCargoGroupAssign transient;
			response.myCargoGroupAssign.setProxyFromObject(nextAssignment);
			moreInfo:= app.getErrorString1(Last_avail_item_been_com_b, completeAssignment.id);
		else
			response.clearCargoGroupAssign:=true;
			moreInfo:= app.getErrorString1(Last_avail_item_been_com_a, completeAssignment.id);
		endif;
	endif;
	
	if response.myCargoGroupAssign = null and not response.clearCargoGroupAssign then
		create response.myCargoGroupAssign transient;
		response.myCargoGroupAssign.setProxyFromObject(cga);
		response.myCargoGroupAssign.selectedCargoGroupOid:=cg.getOidAsString;
	endif;
	
	return response;
epilog
	if not request.warningsAcknowledged then
		response.addInfo(info);
		response.addInfo(moreInfo);
	endif;
	
	delete cgsToComplete;
	delete strArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_AssignCargoToGroupRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_AssignCargoToGroupResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoGroupComplete" id="5de7622f-a172-46b7-b86e-ef197080d587">
        <updating/>
        <source>putCargoGroupComplete(request : WS_Request; groupOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation 51683

*/

vars
	response : WS_Response;
	cargoGroup : CM_CargoGroup;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHCargoGroupMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargoGroup	:= app.myPassport.getObjectOfTypeFromOid(groupOid,CM_CargoGroup).CM_CargoGroup;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargoGroup = null then
		app.raiseCMException(Cargo_group_found,null,null);
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxCargoGroupComplete(cargoGroup,app.myPassport);
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="groupOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoLoadToRelease" id="8b682fd3-29bd-466f-bdbb-cf757d6b29b4">
        <updating/>
        <source>putCargoLoadToRelease(request : WS_CargoLoadToReleaseRequest; cargoOid : String) : WS_CargoLoadToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_CargoLoadToReleaseResponse;
	cargo : CM_TrackedItem;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	vehicle  : CM_Vehicle;
	chassis	  : CM_TILC;
	wagon  : CM_Wagon;
	wle : CM_WorkListEntry;
	roadJob : CM_RoadJob;
	cmifLoader : CMIF_MobileGenericAgent;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	targetLocation 	: CM_LocationsController;
	moveController : CMIF_MoveController;
	tiToAdd : CM_TrackedItem;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	cargoLoaded 	: WS_CargoSummary;
	reason : String;
	cargoSplitable, cargoWillSplit : Boolean;
	context : Object;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	

	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
		
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	vehicle:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Vehicle).CM_Vehicle;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
	endif;
	if vehicle = null then
		//lets see if it is a chassis
		chassis:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_TILC).CM_TILC;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;	
		if chassis = null then
			wagon:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Wagon).CM_Wagon;
			if app.myPassport.hasErrors then
				app.myPassport.clearErrorsWarnings;
			endif;	
		endif;
	endif;	
	
	if vehicle = null and  chassis = null and wagon = null  then
		app.raiseCMException(No_Target_location_found,null,null);
		return response;
	endif;
	
	cargoSplitable:=cargo.myCargoType.allowDuplicates;
	if cargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;	
		cargoWillSplit := quantity &lt; cargo.totalQuantity;
	elseif cargo.isBulkByWeight or cargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;	
		cargoWillSplit := weight &lt; cargo.totalWeight;
	endif;	
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);

	if reserveDetail = null then
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,cargo.totalQuantity.max(1), cargo.totalWeight,reason);
	endif;
	
	if vehicle &lt;&gt; null then
		roadJob:=vehicle.getCurrentRoadJob();
		targetLocation:=vehicle.locationsController;
	elseif chassis &lt;&gt; null then
		roadJob:=chassis.jobRoadRelease;
		targetLocation:=chassis.allLCs.first;
	endif;
	wle:=cmifLoader.getWleForLoadTarget(wagon,roadJob,cargo,reserveDetail);
	cmifLoader.setMyWle(wle);
	
	if wagon &lt;&gt; null then
		targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
		if targetLocation = null then
			targetLocation:=wagon.allLocationsControllers.first;
		endif;
	endif;
	
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		
		if cargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		if roadJob &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_TRUKLOAD];
		elseif wagon &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_RAIL_REL];
		endif;
		if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(cargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	cmifLoader.setMyLocationsController(targetLocation);
	
	
	
	cmifLoader.validateReleaseLoad(reserveDetail, roadJob,quantity,weight);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if app.myPassport.hasWarnings and not request.warningsAcknowledged then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	if wle &lt;&gt; null and ( wle.myTrackedItem = null or wle.myTrackedItem.isRRP ) then
		create moveController transient;
		moveController.setMyWorkListEntry(wle);
		moveController.setMyToPrimaryLocation(targetLocation);
		moveController.setMyTrackedItem(cargo);
		moveController.setQuantity( quantity);
		moveController.setWeight( weight);
	
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	else	
		if cargoWillSplit then
			context :=reserveDetail;
		endif;	
		cmifLoader.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, context);
	
	endif;
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if cargoSplitable then
		if moveController &lt;&gt; null then	//03 Nov 2015	NDL	Par 37005
			// used a wleToProcess
			tiToAdd := moveController.myTrackedItem;
		else
			// came thru the direct move code
			if wagon &lt;&gt; null then
				tiToAdd := wagon.findTi( cargo.id );
			else
				tiToAdd := targetLocation.allTrackedItemsById.getAtKey( cargo.id, cargo.cargoType ); // Might have been split off.. 
			endif;
		endif;
	endif;

	if cargoSplitable and cargo &lt;&gt; tiToAdd and tiToAdd &lt;&gt; null then
		//has been a split
		create cargoLoaded transient;
		cargoLoaded.setProxyFromObject(tiToAdd);
		response.myCargo:=cargoLoaded;
	endif;
	
	response.setWeightAndCounts(release,targetLocation);
	
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	delete cmifAutoPlan;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoLoadToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoLoadToReleaseUndo" id="7815b6b0-9af0-4da1-8a9f-b5e7ccc0a7cb">
        <updating/>
        <source>putCargoLoadToReleaseUndo(request : WS_CargoLoadToReleaseRequest; cargoOid : String) : WS_CargoLoadToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_CargoLoadToReleaseResponse;
	cargo : CM_TrackedItem;
	release : CM_BulkRelease;
	cmifLoader : CMIF_MobileGenericAgent;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	targetLocation,
 	currentLocation	: CM_LocationsController;
	moveController : CMIF_MoveController;
	tiToAdd : CM_TrackedItem;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	wsCargo 	: WS_CargoSummary;
	cargoSplitable, cargoWillSplit : Boolean;
	context : Object;
	vehicle  : CM_Vehicle;
	wagon  : CM_Wagon;
	wle : CM_WorkListEntry;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	

	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	currentLocation:=cargo.myPrimaryActualLocation;
	if currentLocation = null or not cargo.isOnSite then
		app.raiseCMException1( ERR_TI_NOT_ONSITE,cargo.id,null,null);
		return response;
	endif;
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
		
	targetLocation:=cargo.getPriorLocationLC;
	if targetLocation = null then
		app.raiseCMException(No_Target_location_found, null,null);
		return response;
	endif;
	
	
	
	cargoSplitable:=cargo.myCargoType.allowDuplicates;
	if cargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
		cargoWillSplit := quantity &lt; cargo.totalQuantity;
	elseif cargo.isBulkByWeight or cargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		cargoWillSplit := weight &lt; cargo.totalWeight;
	endif;	
		
	if currentLocation.isKindOf(CM_VehicleController) then
		vehicle:=currentLocation.CM_VehicleController.vehicle;
	elseif currentLocation.isKindOf(CM_TILCController) then
		vehicle:=currentLocation.CM_TILCController.getVehicle;
	elseif currentLocation.isKindOf(CM_WagonController)  &lt;&gt; null then
		wagon:=currentLocation.CM_WagonController.myWagon;
	endif;
	
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		if cargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		if vehicle &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_TRUKUNLOAD];
		elseif wagon  &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_RAIL_REC];
		endif;
		if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(cargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	cmifLoader.setMyLocationsController(targetLocation);
	
	if cargo.jobRoadRelease &lt;&gt; null then
		wle:=cargo.jobRoadRelease.getWLEForTI(cargo);
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	

	if cargoWillSplit then
		context :=release;
	endif;	
	cmifLoader.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, context);
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if cargoSplitable then
	
		tiToAdd := targetLocation.allTrackedItemsById.getAtKey( cargo.id, cargo.cargoType ); // Might have been split off.. 	
	endif;

	if cargoSplitable and cargo &lt;&gt; tiToAdd and tiToAdd &lt;&gt; null then
		//has been a split
		create wsCargo transient;
		wsCargo.setProxyFromObject(tiToAdd);
		response.myCargo:=wsCargo;
	endif;
	
	response.setWeightAndCounts(release,currentLocation);
	
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	delete cmifAutoPlan;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoLoadToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoOnMachineForPicking" id="2994bf3c-dccb-464a-9843-bc614ae23512">
        <updating/>
        <source>putCargoOnMachineForPicking(request : WS_CargoToMachineRequest; cargoOid : String)  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 52626

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	machine  : CM_Machine;
	moveController : CMIF_MoveController;
	quantity 		: Integer;
	weight 			: Decimal [16,4];
	targetLocation 	: CM_LocationsController;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
		
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(Cargo_item_not_found,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	machine:=app.myPassport.getObjectOfTypeFromOid(request.machineOid, CM_Machine).CM_Machine;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if machine = null then
		app.raiseCMException1(Cargo_item_not_found,request.machineOid, null,null);
		return response;
	endif;
	

	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if not request.warningsAcknowledged then
		create allWarningsToIgnore transient;
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if  not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String)  then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release)  then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);			
				endif;
			endif;
		endif;
		
		if not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String) then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
	endif;
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargo );
	moveController.setMoveMode( REAL_MODE );
	moveController.setMyToPrimaryLocation( machine.myMachineController );
	
	if cargo.isBulkByQuantity then	
		quantity:=request.amount.asIntegerJMT;
		moveController.setQuantity(quantity);
	else
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		if weight &gt; 0 then
			moveController.setWeight(weight);
		endif;
	endif;	
	
		
	if not request.warningsAcknowledged and   not allWarningsToIgnore.includes(Will_OverStage.String)   then
		if reserveDetail.wouldBeOverSelected( cargo, quantity, weight ) then
			app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
		endif;
	endif;
	
	// from functional review - was not including overstage if got any of the other warnings
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail,false, app.myPassport);
	
	return response;
epilog
	delete allWarningsToIgnore; 
	delete moveController;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoToMachineRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoPackToRelease" id="7d2d6917-c34f-41fb-b5d9-64d9fecfd5e0">
        <updating/>
        <source>putCargoPackToRelease(request : WS_CargoPackToReleaseRequest;cargoOid : String) : WS_CargoPackToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	response : WS_CargoPackToReleaseResponse;
	beforePackCargo,
	packCargo,
	parentCargo,
	child	: CM_TrackedItem;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	bulkRelease			: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	setParentFromChild,cargoSplitable 	: Boolean;
	cmifLoader : CMIF_MobileGenericAgent;
	reason :String;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	wsCargo 	: WS_CargoSummary;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	packCargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if packCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	//epr TFS 5535 8/8/17
	parentCargo:=app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		return response;
	endif;
	cargoSplitable:=packCargo.myCargoType.allowDuplicates;
	if packCargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
	elseif packCargo.isBulkByWeight or packCargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  packCargo.myCargoType.isTrackByVolume then		
			weight := weight * packCargo.getDensity;		
		endif;
	endif;	
		
	if request.completedChecks = false then
		//check if the cargo needs checks
		if packCargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_PACK];
			if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(packCargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
		
	bulkRelease:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if bulkRelease = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	setParentFromChild :=  parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and parentCargo.isStorage;
							
	if not setParentFromChild then
		parentCargo.validateCargoToPack(packCargo);
		if app.myPassport.hasErrors then
			return response;
		endif;
	endif;			

	if reserveDetail = null then
		create cmifLoader transient;
		cmifLoader.setMyTerminal(app.myPassport.myTerminal);
		cmifLoader.setMyBulkRelease(bulkRelease);
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(packCargo,quantity, weight,reason);
	endif;
	
	if reserveDetail = null then
		app.raiseCMException(Cargo_item_release_issue,null,null);
		return response;
	endif;
	reserveDetail.validateForPack(reserveDetail, packCargo, quantity, weight);
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	beforePackCargo:=packCargo;
	app.myTrxUA.trxUpdatePackCargo(parentCargo, packCargo, quantity, weight, setParentFromChild,bulkRelease, reserveDetail,true,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	//need to figure out appropriate way of updating commodity on parent to not empty
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	if beforePackCargo &lt;&gt; packCargo then
		create wsCargo transient;
		wsCargo.setProxyFromObject(packCargo);
		response.myCargo:=wsCargo;
	endif;
	
	response.setWeightAndCounts(bulkRelease,parentCargo);
	return response;
epilog
	delete cmifAutoPlan;
	delete cmifLoader;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoPackToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoPackToReleaseUndo" id="8527175d-d196-4f8a-8175-b14a6736bc09">
        <updating/>
        <source>putCargoPackToReleaseUndo(request : WS_CargoPackToReleaseRequest;cargoOid : String) : WS_CargoPackToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2021	jlier1	Initial creation
09 Aug 2022 navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars
	response 			: WS_CargoPackToReleaseResponse;
	unpackCargo,
	unpackedCargo,
	parentCargo			: CM_TrackedItem;
	bulkRelease			: CM_BulkRelease;
	priorLocation 		: CM_LocationsController;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	cargoSplitable 		: Boolean;
	wsCargo 			: WS_CargoSummary;
	cargoCheck	 	    : CM_CargoCheck;
	check 				: CM_CargoCheckItem;
	cmifAutoPlan		: CMIF_YAAutoPlanNormal;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if not app.getMyUser.canDo( app.myPassport.myTerminal, PmHHPackContainer) then
		app.raiseCMException(Err_InsufficientPermission, null, null);//79610

		return response;
	endif;		
	
	unpackCargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if unpackCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	if not unpackCargo.isChild then
		app.raiseCMException(Not_unpack_cargo_not_packed,null,null);
		return response;
	endif;
	
	parentCargo:=unpackCargo.myParent;
	bulkRelease:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	priorLocation:=unpackCargo.getPriorLocationLC();
	if priorLocation = null then
		app.raiseCMException(ERR_UNPACK_NULL_LOCATION,null,null);
		return response;
	endif;
	
	cargoSplitable:=unpackCargo.myCargoType.allowDuplicates;
	if unpackCargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
	elseif unpackCargo.isBulkByWeight or unpackCargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  unpackCargo.myCargoType.isTrackByVolume then		
			weight := weight * unpackCargo.getDensity;		
		endif;
	endif;	
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		if unpackCargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_UNPACK];
			if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(unpackCargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	//app.myTrxUA.trxUpdateUnpackCargo(unpackCargo, priorLocation,quantity,weight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(unpackCargo, priorLocation,quantity,weight,false,null, app.myPassport); 	//14.03.2024 navhl20 #62861

	if app.myPassport.trxCompletedOK() then
		if cargoSplitable then
			unpackedCargo := priorLocation.allTrackedItemsById.getAtKey( unpackCargo.id, unpackCargo.cargoType );
			if unpackedCargo &lt;&gt; unpackCargo then
				create wsCargo transient;
				wsCargo.setProxyFromObject(unpackedCargo);
				response.myCargo:=wsCargo;
			endif;
		endif;
	endif;
	
	response.setWeightAndCounts(bulkRelease,parentCargo);
	return response;
	
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoPackToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoQueueToLocation" id="2746035f-6a79-4e8b-96bb-8f691f343357">
        <updating/>
        <source>putCargoQueueToLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;
	location 		: String;
	quantity 			: Integer;
	dummyHeight		: Integer;
	failedDAC		: CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	app.checkCurrentUserHasAccess(PmWebCargoQueuedMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	// Get the parameters
	location := request.location;
	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);

	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
	
	moveAgent.doQueueTI(cargo, targetLocation , quantity, weight);
	
	return response;
epilog
	delete moveAgent;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToLocation" id="8c401697-192b-40e6-8fb6-42690dd7dac9">
        <updating/>
        <source>putCargoToLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2019	jlger1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;	
	location 		: String;
	quantity 			: Integer;
	dummyHeight		: Integer;
	failedDAC		: CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmWebCargoInstantMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	
	// Get the parameters
	location := request.location;
	
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
		
	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	
	if cargo.myPrimaryActualLocation = targetLocation then
		app.raiseCMException2(Cargo_already_located, cargo.id, targetLocation.getID,null,null );
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
		
	moveAgent.moveTI(cargo, location, targetLocation, null, true, quantity, weight, null);			
	
	return response;
epilog
	delete moveAgent;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToPickingLocation" id="5e2fef22-41a9-4940-9871-c947c4338d7f">
        <updating/>
        <source>putCargoToPickingLocation(request : WS_CargoPickingRequest;cargoOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail : CM_ReserveDetail;
	release	: CM_BulkRelease;
	targetLocation : CM_LocationsController;
	moveController : CMIF_MoveController;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	stagedAreas : CM_LCSet;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(No_release_item_selected,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if targetLocation = null then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	create allWarningsToIgnore transient;
	if not request.warningsAcknowledged then
		
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String) then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release) then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);		
				endif;
			endif;
		endif;
		
		if  not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String)   then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
		
		create stagedAreas transient;
		if not release.validateStagedToOneArea( stagedAreas ) and not allWarningsToIgnore.includes(Releas_staged_multip_areas_con.String)  then
			app.raiseCMWarning(Releas_staged_multip_areas_con,null,null,null);
		endif;
		
		if not allWarningsToIgnore.includes(This_relea_curre_stage_into_su.String)  then
			if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; targetLocation then
				app.raiseCMWarning2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, targetLocation.getFullId,null,null,null);	
			endif;
		endif;
	endif;
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargo );
	moveController.setMoveMode( REAL_MODE );
	moveController.setMyToPrimaryLocation( targetLocation);
	
	if cargo.isBulkByQuantity then
		quantity:=	request.amount.asIntegerJMT;
		moveController.setQuantity(quantity);
	else
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		if weight &gt; 0 then
			moveController.setWeight(weight);
		endif;
	endif;	
	
	if not request.warningsAcknowledged and   not allWarningsToIgnore.includes(Will_OverStage.String)   then
		if reserveDetail.wouldBeOverStaged( cargo, quantity, weight ) then
			app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
		endif;
	endif;
	
	// from functional review - was not including overstage if got any of the other warnings
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail, false,app.myPassport);
	
	
	return response;
epilog
	delete allWarningsToIgnore;
	delete moveController;
	delete stagedAreas;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoPickingRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToPreviousLocation" id="a146636d-118a-491d-b91e-077f0e186e11">
        <updating/>
        <source>putCargoToPreviousLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2019	jlger1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
20/09/2021	jlier1 	TFS 51626 - wanted to also unasssign the release if moving to prior release
22/7/2022	jlier1 TFS 53363 
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;
	location 		: String;
	quantity 			: Integer;
	dummyHeight 	: Integer;
	failedDAC		: CM_DataAccessController ;
	permissions 	: IntegerArray;
	lastMoveTrx		: CM_TITransaction;
	reserveDetailOid : String;
	reserveDetail : CM_ReserveDetail;
	moveController : CMIF_MoveController;
	bulkRelease 	: CM_BulkRelease;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//jler1 TFS 51626 3/9/21 - 
	create permissions transient;
	permissions.add(PmWebCargoInstantMove);
	permissions.add(PmHHOrderPicking);
	app.myPassport.validateUserHasOnePermission(permissions);
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	location := cargo.priorLocation;
	
	if location.trimBlanks = "" then
		app.raiseCMException1(Cargo_previous_location,cargo.id, null,null);
		return response;
	endif;	
	
		
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
		
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if cargo.myPrimaryActualLocation.isKindOf(CM_WagonController) then
		if targetLocation.isKindOf(CM_WagonController) then
			targetLocation:=cargo.getLastTALocation;
		endif;
	endif;
	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	app.writeLog(targetLocation.String, LogINFO);
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	

	if cargo.myPrimaryActualLocation &lt;&gt; null then
	
		if cargo.myPrimaryActualLocation.isKindOf(CM_MachineController) then
			//if this is for staging then unstage
			lastMoveTrx :=cargo.allTransactions.getLastTransOfType(TRANS_TYPE_MOVE_PICKUP,null);
			if lastMoveTrx &lt;&gt; null and lastMoveTrx.CM_Move.targetLocn = cargo.locationId then
				//check if it was assigned to a release here
				reserveDetailOid:=lastMoveTrx.getExtraData(TrnsExtraDataAssignedRel).String;
				if reserveDetailOid &lt;&gt; null then
					reserveDetail:=reserveDetailOid.asOid.CM_ReserveDetail;
				endif;
			endif;
		endif;
		//jlier1 TFS 53363 25/7/22
		if cargo.myPrimaryActualLocation.isKindOf(CM_WagonController) then
			lastMoveTrx:=cargo.allTransactions.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN,null);
			if lastMoveTrx.isFromMobileApp then
				if lastMoveTrx &lt;&gt; null and 	lastMoveTrx.CM_RelRequestAssign.myBulkReleaseCode &lt;&gt; null then
					foreach bulkRelease in cargo.allBulkReleasesAssigned discreteLock  where bulkRelease.code = lastMoveTrx.CM_RelRequestAssign.myBulkReleaseCode do
						if bulkRelease.isRailType then
							reserveDetail:=bulkRelease.getReserveDetailFor(cargo);
							if reserveDetail &lt;&gt; null then
								break;
							endif;
						endif;
					endforeach;
				endif;
			endif;
		endif;
		app.writeLog(method.name &amp; " lastMoveTrx = "  &amp; lastMoveTrx.String, LogDEBUG);
	
		if reserveDetail &lt;&gt; null then
			//un stage it 
				create moveController transient;
				moveController.setMyTrackedItem( cargo );
				moveController.setMoveMode( REAL_MODE );
				moveController.setMyToPrimaryLocation( targetLocation);
				if quantity &lt;&gt; 0 then
					moveController.setQuantity(quantity);
				endif;
				if weight &lt;&gt; 0 then
					moveController.setWeight(weight);
				endif;
				app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
				//this trx just moves and will unassign from release if is undo
				app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail, true,app.myPassport);
				
				return response;
		endif;
		
	endif;
	
		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
	
	moveAgent.moveTI(cargo, location, targetLocation, null, true, quantity, weight, null);			
	
	return response;
epilog
	delete moveAgent;
	delete moveController;
	delete permissions;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToWagon" id="14e50c3f-b6a7-4ecb-a334-f1bcdde4341b">
        <updating/>
        <source>putCargoToWagon(request :  WS_CargoToWagonRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2019	jlger1	Initial creation TFS 45291

*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;	
	quantity 			: Integer;
	failedDAC		: CM_DataAccessController ;
	wagon 			: CM_Wagon;
	reserveDetail  : CM_ReserveDetail;
	wle : CM_WorkListEntry;
	moveController : CMIF_MoveController;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmWebCargoInstantMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
		
	//app.raiseCMWarning1(Wagon_not_found_expect_wagons,request.wagonOid, null,null,null);
	//return response;
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(request.wagonOid, CM_Wagon).CM_Wagon;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,request.wagonOid, null,null);
		return response;
	endif;

	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	wle:= wagon.getWLEforCargo(cargo,reserveDetail);
	
	targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
	
	if targetLocation = null then
		app.raiseCMException2(ERR_NO_SPACE,cargo.id,wagon.id ,null,null);
		return response;
	endif;	
	
	if cargo.myPrimaryActualLocation = targetLocation then
		app.raiseCMException2(Cargo_already_located, cargo.id, targetLocation.getID,null,null );
		return response;
	endif;
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.userName,targetLocation.auditId,null, null,null);
		return response;
	endif;

	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	if wle &lt;&gt; null and ( wle.myTrackedItem = null or wle.myTrackedItem.isTBAorIsRRP ) then
		create moveController transient;
		moveController.setMyWorkListEntry(wle);
		moveController.setMyToPrimaryLocation(targetLocation);
		moveController.setMyTrackedItem(cargo);
		moveController.setQuantity( quantity);
		moveController.setWeight( weight);
	
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	else
	
		create moveAgent transient;		
		//jlier1 TFS 51372 10/8/22
		moveAgent.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, reserveDetail);	
	endif;
	
	
	return response;
epilog
	delete moveAgent;
	delete moveController;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoToWagonRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCompleteTruck" id="60dd0770-b0c4-4c3e-a42c-b9281b092b4b">
        <updating/>
        <source>putCompleteTruck(request : WS_Request; truckOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_Response;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	truck : CM_Vehicle;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	truck:=app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
		return response;
	endif;
	if truck = null then
		app.raiseCMException1(Truck_not_found,truckOid, null,null);
		return response;
	endif;
	
	
	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal(truck.myTerminal);
	truckUnLoaderController.setTruck(truck);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	truckUnLoaderController.doTruckComplete(false,false,true);
	return response;
epilog
	delete truckUnLoaderController;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putGrade" id="7c4ebec4-b92b-4e3f-931c-88b69a372045">
        <updating/>
        <source>putGrade(request : WS_AvailabilityGradeRequest ; cargoOid :String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
*/

vars
	response 			 : WS_Response;
	avGrade    			 : CM_MTGrade;
	cargoGradeController : CMIF_MobileGenericAgent;
	cargo				 : CM_TrackedItem;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	app.checkCurrentUserHasAccess(PmWebGradeMaintenance);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	// Check AV Grade
	if request.code = "" then
		app.raiseCMException(Input_required_field_grade, null,null);
		return response;
	endif;	
	
	avGrade  := app.myRoot.allAvailabilityGrades[request.code.asIntegerJMT];
	
	if avGrade = null then
		app.raiseCMException1(Invalid_AvailabilityGrade,request.code,null,null);
		return response;
	endif;
	
	//Update AV Grade
	create cargoGradeController transient;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	if not cargoGradeController.updateAvailabilityGrade(cargo,avGrade) then
		return response;
	endif;
	
	return response;
epilog
	delete cargoGradeController;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_AvailabilityGradeRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putLocationChecks" id="bb2f5d56-80d4-4205-a088-f95403f86cba">
        <updating/>
        <source>putLocationChecks(request : WS_LocationChecksRequest; locationOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2021	jlier1	Initial creation TFS 51684

*/

vars
	location : CM_LocationsController;
	response : WS_Response;
	iter : Iterator;
	allTIs  : CM_TIArray;
	ti : CM_TrackedItem;
	trxCmifSet : CMIF_TITxnControllerSet;
	trxDict : CM_TITransactionSet;
	confirmedTIOids : StringArray;
	cmif : CMIF_LocationCheckController;
	locationID,
	cargoOid : String;
	size : Integer;
	cargoGroup : CM_CargoGroup;
begin	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	location:=app.myPassport.getObjectOfTypeFromOid(locationOid,CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if location = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;
	locationID:=location.getFullId();
	
	if request.cargoGroupOid &lt;&gt; null then
		cargoGroup:=app.myPassport.getObjectOfTypeFromOid(request.cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
		if app.myPassport.hasErrors then
			return response;
		endif;
	endif;
	
	create confirmedTIOids transient;
	request.allCargoOids.copy(confirmedTIOids);
	create trxCmifSet transient;
	create trxDict transient;
	
	create allTIs transient;
	location.getTIs(allTIs,REAL_MODE,true);
	iter:=allTIs.createIterator;
	while iter.next(ti) do
		if cargoGroup &lt;&gt; null then
			if ti.myCargoGroup &lt;&gt; cargoGroup then
				continue;
			endif;
		endif;
	
		create cmif transient;
		cmif.type := TRANS_TYPE_LocationCheck;
		cmif.userId := app.myPassport.userCode;
		cmif.dateTime := app.actualTimeServer();
		cmif.myTrackedItem := ti;
		cmif.expectedLocation:=locationID;
		cmif.actualLocation := null;
		if confirmedTIOids.includes(ti.getOidAsString()) then
				cmif.actualLocation := locationID;		
				confirmedTIOids.remove(ti.getOidAsString());
		endif;	
		trxCmifSet.add( cmif );
	endwhile;
	
	//any left must be in a this actual location but not expected in differnt location 
	foreach cargoOid in confirmedTIOids discreteLock do
	
		ti:=app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			//ti is invalid or not found
			app.myPassport.clearErrorsWarnings;
			continue;
		endif;
		// shouldn't happen but just incase
		if ti = null then
			continue;
		endif;
		create cmif transient;
		cmif.type := TRANS_TYPE_LocationCheck;
		cmif.userId := app.myPassport.userCode;
		cmif.dateTime := app.actualTimeServer();
		cmif.myTrackedItem := ti;
		cmif.expectedLocation:=ti.myPrimaryActualLocation.getFullId();
		cmif.actualLocation := locationID;
		trxCmifSet.add( cmif );
	endforeach;
	
	size := trxCmifSet.size;
	if size =  0 then
		app.raiseCMException(Locatio_check_transac_create,null,null);
		return response;
	endif;
	
	if not request.warningsAcknowledged then
		app.raiseCMWarning1(Sure_want_creat_locat_check_tr,size.String,null,null,null);
		return response;
	endif;
		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxCA.trxCreateLocationCheckTrans( trxCmifSet, trxDict, app.myPassport	);

	return response;
epilog
	if trxCmifSet &lt;&gt; null then
		trxCmifSet.purge();
	endif;

	delete allTIs;
	delete trxCmifSet;
	delete trxDict;		
	delete confirmedTIOids;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_LocationChecksRequest"/>
        <Parameter name="locationOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putMark" id="e76d34b3-abee-41bf-ab81-ad8d7e6377e2">
        <updating/>
        <source>putMark(request :WS_MarkRequest ;cargoOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system

*/

vars
	response    : WS_Response;
	cargo,
	pxyTi		: CM_TrackedItem;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmWebMarkMaintenance);		
	
	if app.myPassport.hasErrors then		
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	
	// Check Marks
	if request.mark = "" then
		app.raiseCMException(Input_required_field_Mark, null,null);
		return response;
	endif;	
	
	//Update Cargo Marks
	pxyTi := app.createUpdateProxy(cargo).CM_TrackedItem;
	pxyTi.setMark(request.mark);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxUpdateTrackedItem(pxyTi,null,TI_UPDMODE_NORMAL,null,app.myPassport);
	

	return response;
epilog
	delete pxyTi;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_MarkRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putPackComplete" id="5ec9a3f3-78a8-4ccf-aabc-7b83b749380a">
        <updating/>
        <source>putPackComplete(request : WS_PackCompleteRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	jlier1	Initial creation 51879
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	response    : WS_Response;
	parentCargo,
	pxyTI		: CM_TrackedItem;
	release		: CM_BulkRelease;
	subTerminal : CM_SubTerminal;
	operator 	: CM_Operator;
	terminal	: CM_Terminal;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	parentCargo	:= app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,request.parentCargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid,CM_BulkRelease).CM_BulkRelease;	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release &lt;&gt; null and not release.isPackingType then
		release := null;
	endif;

	pxyTI :=  app.createUpdateProxy(parentCargo).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	operator:=app.myRoot.allOperators[request.operatorCode];
	if operator &lt;&gt; null and  operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(terminal) then
		subTerminal := app.myRoot.allSubTerminals[request.subTerminalCode];
		if subTerminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subTerminal);
		endif;
	endif;
		
	app.myTrxUA.trxUpdateTIPackComplete(pxyTI, release, null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	return response;
epilog
	delete pxyTI;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_PackCompleteRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putTasksOnCargo" id="15439cfe-b671-4aae-9884-70b30524b6a3">
        <updating/>
        <source>putTasksOnCargo( request : WS_CargoTaskDescRequest ; cargoOid : String ) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
*/

vars
	response 			: WS_Response;
	cargo				: CM_TrackedItem;
	wsTask      		: WS_CargoTask;
	toDoTaskDesc   		: CM_ToDoTaskDesc;
	terminal    		: CM_Terminal;
	user				: CM_User;
	allTasks			: WS_CargoTaskArray;
	cmifToDoTask        : CMIF_TiToDoTasks;
	cmifToDoTaskArray   : CMIF_TiToDoTasksArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	
	user 		:= app.myPassport.myUser;
	terminal	:= app.myPassport.myTerminal;
	allTasks 	:= request.allTasks;
	
	create cmifToDoTaskArray transient;
	
	foreach wsTask in allTasks do 
		
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[wsTask.code];
		
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, wsTask.code.String, null, null);
			return response;
		endif;
		
		create cmifToDoTask transient;
		cmifToDoTask.myToDoTaskDesc := toDoTaskDesc;
		cmifToDoTask.remarks        := wsTask.remarks;
		
		cmifToDoTaskArray.add(cmifToDoTask);
	
		
	endforeach;
	
	if not cmifToDoTaskArray.isEmpty then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxCA.trxAddToDoTasks(cargo,cmifToDoTaskArray,app.myPassport);
	endif;
	
	
	return response;
epilog
	
	delete cmifToDoTaskArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoTaskDescRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putTasksOnCargoCompleted" id="cf1c4bdd-8726-4571-ba1c-38ef89692498">
        <updating/>
        <source>putTasksOnCargoCompleted(request : WS_CargoTaskDescRequest ; cargoOid : String ) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system

*/

vars
	response 	 		: WS_Response;

	cargo		 		: CM_TrackedItem;
	wsTask       		: WS_CargoTask;
	toDoTaskDesc        : CM_ToDoTaskDesc;
	toDoTask     		: CM_ToDoTask;
	terminal     		: CM_Terminal;
	user		 		: CM_User;
	tsConverted         : TimeStamp;
	allTasks			: WS_CargoTaskArray;
	cmifToDoTask        : CMIF_TiToDoTasks;
	cmifToDoTaskArray   : CMIF_TiToDoTasksArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	
	user 		:= app.myPassport.myUser;
	terminal	:= app.myPassport.myTerminal;
	allTasks 	:= request.allTasks;
	
	create cmifToDoTaskArray transient;
	
	foreach wsTask in allTasks do 
		
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[wsTask.code];
		
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, wsTask.code.String, null, null);
			return response;
		endif;
			
		if not cargo.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
			app.raiseCMException1(ERR_NO_TODO_TASK, toDoTaskDesc.description, null, null);
			return response;
		endif;
		
		if not user.canCompleteTodoTask(terminal,toDoTaskDesc) then
			app.raiseCMException1(ERR_COMPLETE_TASK, toDoTaskDesc.description, null, null);
			return response;
		endif;
		
		create cmifToDoTask transient;
		
		cmifToDoTask.myToDoTaskDesc := toDoTaskDesc;
		cmifToDoTask.remarks        := wsTask.remarks;
		
		if wsTask.completedDate = null and wsTask.completedDateUTC = null then
			
			cmifToDoTask.completeDT := app.actualTimeServer;
		endif;
	
		if  wsTask.completedDateUTC &lt;&gt; null then 
			
			tsConverted 			:= wsTask.completedDateUTC.convertISO8601ToUTCTimeStamp;
			tsConverted 			:= app.myTimeZoneHelper.convertTimeFromUtc(tsConverted, app.myTimeZoneHelper.getSystemTimeZoneID);
			cmifToDoTask.completeDT := tsConverted;
		else
			if wsTask.completedDate &lt;&gt; null then
				tsConverted 			:= wsTask.completedDate.asTimeStampFromWebInterface;
				cmifToDoTask.completeDT := tsConverted;
			endif;
		endif;
		
		cmifToDoTaskArray.add(cmifToDoTask);
	
		
	endforeach;
	
	if not cmifToDoTaskArray.isEmpty then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxCompleteToDoTasks(cargo,cmifToDoTaskArray,app.myPassport);
	endif;
	
	return response;
	
epilog

	delete cmifToDoTaskArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoTaskDescRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="c0532e4d-83fc-48b5-8060-df65ea34fedb">
        <source>validateLicense(path: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgrr1	Initial creation TFS 49227

*/

vars

begin
	// JMT Handheld does not require a separate subscription license
	// root.canDo(PmWebServiceModule) is checked on application start in initJMTRestService
	return true;

epilog

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
