    <JadeMethod name="translateForm" id="a54fdd81-5d5c-4487-bc28-c5d5418a8797">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 November 2024 13:45:53.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026117, locale);
	btnAdd.translateBubbleHelp(Xlat_0026118, locale);
	btnAdd.translateCaption(Xlat_0026119, locale);
	btnAudit.translateBubbleHelp(Xlat_0026120, locale);
	btnAudit.translateCaption(Xlat_0026121, locale);
	btnClose.translateCaption(Xlat_0026122, locale);
	btnRemove.translateBubbleHelp(Xlat_0026123, locale);
	btnRemove.translateCaption(Xlat_0026124, locale);
	btnTrans.translateCaption(Xlat_0027004, locale);
	btnUpdate.translateBubbleHelp(Xlat_0026125, locale);
	btnUpdate.translateCaption(Xlat_0026126, locale);
	lblAccumQty.translateCaption(Xlat_0026127, locale);
	lblAccumTEU.translateCaption(Xlat_0026128, locale);
	lblAccumVol.translateCaption(Xlat_0026129, locale);
	lblAccumWeight.translateCaption(Xlat_0026130, locale);
	lblVessel.translateCaption(Xlat_0026131, locale);
	lblVoyage.translateCaption(Xlat_0026132, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026133, locale);
	mnuContextMenu.translateCaption(Xlat_0026134, locale);
	mnuInspectObject.translateCaption(Xlat_0026135, locale);
end;</source>
    </JadeMethod>
