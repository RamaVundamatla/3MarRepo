    <JadeMethod name="delete" id="67e6b752-cc7f-4e3f-b109-68d6258ea3e0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

vars

begin
	self.doDeleteProxies();	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="fe838d4b-7502-4adb-a42d-0b1097e9a174">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	loadStateSet : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	inheritMethod();
	app.cmsBeginLoad(loadStateSet);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.myCurrentROROVoyageStructure &lt;&gt; null then
			app.myTrxUA.trxUpdateRORODecksOrdinal(self.pxyDecks, null, app.myPassport);
		elseif myCurrentGCVoyageStructure &lt;&gt; null then
			app.myTrxUA.trxUpdateRORODecksOrdinal(null, self.pxyGcs, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Decks), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteProxies" id="20a12fc4-8bc2-4681-86fe-8392cd82f06a">
        <source>doDeleteProxies();
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	deck : CM_DeckVoyage;
	gc : CM_GeneralCargoController;
begin
	foreach deck in self.pxyDecks do
		self.pxyDecks.remove(deck);
		delete deck;
	endforeach;
	//03 Feb 2017	NDL	TFS 3216/3047
	foreach gc in self.pxyGcs do
		self.pxyGcs.remove(gc);
		delete gc;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayDecks" id="d297578a-af44-4cb7-b5bb-d6ba9d34218d">
        <updating/>
        <source>doDisplayDecks() updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	deck	: CM_DeckVoyage;
	
	pxyDeck : CM_DeckVoyage;
	idx : Integer;
	theTable : CM_DataTable;
	
	gc : CM_GeneralCargoController;
	pxyGc : CM_GeneralCargoController;
	
begin
	if self.myCurrentROROVoyageStructure = null and myCurrentGCVoyageStructure = null then
		return;
	endif;
	
	theTable := self.tblDecks;
	
	self.tblDecks.rows := self.tblDecks.fixedRows;	
	
	if self.myCurrentROROVoyageStructure &lt;&gt; null then
		beginLoad;
		foreach deck in self.myCurrentROROVoyageStructure.allDecks do		
			
			pxyDeck := deck.pxyCreateUpdateProxy();
			
			pxyDeck.setOrdinal(deck.ordinal);
			self.pxyDecks.add(pxyDeck);
		endforeach;
		endLoad;
	
	
		foreach deck in self.pxyDecks discreteLock do		
			
			idx := self.tblDecks.addItemObject(deck,deck.code &amp; Tab &amp; deck.description &amp; Tab &amp; Tab);		
			self.addUpAndDownArrows(idx);	
			//  Note: no sub-deck ordering here
		endforeach;	
	
	//03 Feb 2017	NDL	TFS 3216/3047
	elseif self.myCurrentGCVoyageStructure &lt;&gt; null then
		beginLoad;
		idx := 0;
		foreach gc in self.myCurrentGCVoyageStructure.allLocationsByOrdinal do		
			
			pxyGc := gc.pxyCreateUpdateProxy();
			idx := idx + 1;
			pxyGc.setOrdinal(idx);
			self.pxyGcs.add(pxyGc);
		endforeach;
		endLoad;
	
	
		foreach gc in self.pxyGcs discreteLock do		
			idx := self.tblDecks.addItemObject(gc,gc.name &amp; Tab &amp; gc.getFullId &amp; Tab &amp; Tab);		
			self.addUpAndDownArrows(idx);	
		endforeach;	
		
	endif;
	
	self.tblDecks.adjustHeight(self.FORM_HEIGHT + 50);
	self.tblDecks.height := self.tblDecks.height + 2;	// 28687 avoid the vertical scroll when it actually does fit
	self.height := self.tblDecks.height + 50 + self.frmToolbar.height;
epilog
	endLoad;										// 19/04/2013 cnwmh5 #31457
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDecksClick" id="58dfd0fe-83c4-4120-8cd5-23db4a11bf15">
        <updating/>
        <source>doTblDecksClick() updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	theCol, theRow 		: Integer;
	deck 				: CM_DeckVoyage;	
	realDeck 			: CM_Deck;
	ordinal1, ordinal2 	: Integer;
	
	gc : CM_GeneralCargoController;
	
begin

	theRow := self.tblDecks.row;
	if theRow &lt;= self.tblDecks.fixedRows then
		return;
	endif;
	theCol := self.tblDecks.column;

	if self.myCurrentROROVoyageStructure &lt;&gt; null then
		deck := self.tblDecks.accessRow(theRow).itemObject.CM_DeckVoyage;
		ordinal1 := deck.ordinal;
		// MOVE UP
		if theCol = self.TblCol_Up and theRow &gt; 2 then
			deck := self.tblDecks.accessRow(theRow - 1).itemObject.CM_DeckVoyage;
			ordinal2 := deck.ordinal;
			self.pxyDecks.moveElement(ordinal1,ordinal2,deck,true);
			self.tblDecks.moveRow(theRow,theRow - 1);	
		endif;
		
		// MOVE DOWN
		if theCol = self.TblCol_Down and theRow &lt; self.tblDecks.rows then			
			deck := self.tblDecks.accessRow(theRow +1).itemObject.CM_DeckVoyage;
			ordinal2 := deck.ordinal;
			self.pxyDecks.moveElement(ordinal1,ordinal2,deck,true);
			self.tblDecks.moveRow(theRow,theRow + 1);
		endif;
	
	//03 Feb 2017	NDL	TFS 3216/3047
	elseif myCurrentGCVoyageStructure &lt;&gt; null then
		gc := self.tblDecks.accessRow(theRow).itemObject.CM_GeneralCargoController;
		ordinal1 := gc.ordinal;
		// MOVE UP
		if theCol = self.TblCol_Up and theRow &gt; 2 then
			gc := self.tblDecks.accessRow(theRow - 1).itemObject.CM_GeneralCargoController;
			ordinal2 := gc.ordinal;
			self.pxyGcs.moveElement(ordinal1,ordinal2,gc);
			self.tblDecks.moveRow(theRow,theRow - 1);	
		endif;
		
		// MOVE DOWN
		if theCol = self.TblCol_Down and theRow &lt; self.tblDecks.rows then			
			gc := self.tblDecks.accessRow(theRow +1).itemObject.CM_GeneralCargoController;
			ordinal2 := gc.ordinal;
			self.pxyGcs.moveElement(ordinal1,ordinal2,gc);
			self.tblDecks.moveRow(theRow,theRow + 1);
		endif;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="17d1396a-78fc-4783-98f4-ac3cf86e6b64">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018577, locale);
end;</source>
    </JadeMethod>
</GUIClass>
