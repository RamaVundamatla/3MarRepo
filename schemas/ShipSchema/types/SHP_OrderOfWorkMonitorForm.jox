    <JadeMethod name="setMyCurrentVoyage" id="ec7398f9-be83-4201-901f-6f3915f16d03">
        <updating/>
        <source>setMyCurrentVoyage(_newVoyage : CM_Voyage)updating, protected;
/*

Date		Who		Reason
24 March 2017	cnwer1	Initial creation TFS

*/

vars
	
begin
	if self.myCurrentVoyage = _newVoyage then
		return;
	endif;
	
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event));
		self.endNotification(self.myCurrentVoyage, EVENT_WLE_COMPLETE); //epr TFS 830 21/3/17
	endif;
	
	self.myCurrentJob:=null;
	self.myCurrentVoyage:=_newVoyage;
	
	//cnwjo3 par 23105
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, EVENT_WLE_COMPLETE, Response_Continuous, null);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setNumericColumnWidths" id="0d6778a9-6ccf-459a-9098-b88b5dd2ec9a">
        <source>setNumericColumnWidths(_tbl : CM_DataTable input) protected;
/*

Date		Who		Reason
29 March 2017	cnwer1	Initial creation TFS

*/

vars
	entTableRow : EntTableRow;
	colIdx : Integer;
begin
	if _tbl = null then
		return;
	endif;
	
	colIdx:=1;
	foreach entTableRow in _tbl.allTblDataEntRows do 
		if entTableRow.inputType = Table.InputType_TextNumeric then
			_tbl.accessColumn(colIdx).width:=55;
			_tbl.accessColumn(colIdx).wordWrap:=true;
			_tbl.accessColumn(colIdx).alignment:= Table.Alignment_Right;
		endif;
		colIdx:=colIdx + 1;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="dbe5f93f-2b2f-4c9e-9a24-b40a3ee0baf9">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Date		Who		Reason
28 March 2017	cnwer1	Initial creation TFS

*/

vars
	cmifJobSheetStats : CMIF_JobSheetStats;
	i : Integer;
	iterStats : Iterator;
	tblCrane : CM_DataTable;
begin
	if self.myVoyageStats = null then
		return;
	endif;
	
	iterStats := self.myVoyageStats.allJobSheetStats.createIterator;
	
	
	while iterStats.next(cmifJobSheetStats) do
		i:=  i + 1;	
		tblCrane:= self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);
		
		self.cloneTable(tblCrane,self.myCurrentTable,cmifJobSheetStats,false);
		
	endwhile;
epilog
	delete iterStats;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
