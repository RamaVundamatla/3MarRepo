        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDefaultTareWeight" id="36bab5ac-5816-4493-b8c1-4ec7d74cee8f">
        <source>getDefaultTareWeight(): Decimal;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Default value to use for tareWeight if the property value is not specified
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/05/2010	cnwcs5		par 24178
// ---------------------------------------------------------------------------
vars
	type		:CM_ISOType;
	tareWeight	:Decimal[14,4];
begin
/*	The tare weight  defaults to (in the following order:
		- the tare weight for the CM_TIMaster (done in superclass method)
		- the tare weight from the ISO type
*/
	tareWeight := inheritMethod();
	
	if tareWeight = null then
		// keep looking - ISO type
		type	:= self.getISOTypeObject;
		
		if type &lt;&gt; null then
			tareWeight := type.tareKilos;
		endif;
	endif;
	
	return tareWeight;		
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d19f5e4e-8f85-455a-9466-4177fcc8d191">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//29 January 2010	cnwml2


vars

begin
	if _attrName = ETRow_OverHeight or
		_attrName = ETRow_OverLengthBack or
		_attrName = ETRow_OverLengthFront or
		_attrName = ETRow_OverWidthLeft or
		_attrName = ETRow_OverWidthRight then
		return null;
	elseif _attrName = ETRow_FirstConnectedDTSort  or _attrName = ETRow_LastConnectedDTSort or _attrName = ETRow_LastDisconnDTSort then //04/08/2016 cnwma1 TFS #2430
	
		return null.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
