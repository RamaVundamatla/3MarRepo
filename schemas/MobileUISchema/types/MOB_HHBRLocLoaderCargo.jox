    <JadeMethod name="translateForm" id="3385a9ec-c399-4e6a-96e1-724a70dfb19e">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019839, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validate" id="80082e15-9784-4f71-ab90-8e1dd1850ddd">
        <source>validate() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwdw1	Initial creation  35781
12 Nov 2015	NDL	Par 37092
*/
vars
	quantityLoading: Integer;
	weightLoading : Decimal[16,4];
	quantityLoaded : Integer;
	weightLoaded : Decimal[16,4];
	maxWleQuantityToLoad : Integer;
	maxWleWeightToLoad : Decimal[16,4];
	row: Integer;
	msg : String;
	wles: CM_WLESet;
	wle: CM_WorkListEntry;
	reserveDetail : CM_ReserveDetail;
	mess	: String;

begin
	row := tblCargo.getRow(ETRow_NumItems);
	if row &gt; 0 then
		quantityLoading := tblCargo.getCellText(row,2).trimBlanks.Integer;
	endif;
	
	if self.myTrackedItem &lt;&gt; null and ( self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume ) then
		weightLoading := self.getConvertedWeight;
		quantityLoading := 0;
	endif;
	
	create wles transient;
	// cnwmc5 - 2 Feb 2016 - PAR 37483
	reserveDetail := self.myMobileGenericAgent.myReserveSelection;
	if reserveDetail = null then
		reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( self.myTrackedItem, 0, 0, mess );
	endif;
	if reserveDetail &lt;&gt; null then
		self.getWLEsForReserve( wles, reserveDetail );
	else
		self.getWLEsForRelease( wles );
	endif;	
	
	if not wles.isEmpty then
		// technically you can't get to the a specific reserve details just from a bulk release
		// this code assumes STW rule of one release detail per Bulk release, but allows for multiple trucks working it
		
		// cnwmc5 - 2 Feb 2016 - PAR 37483 
		wle := wles.getFirstUnactionedWLE(); // first incomplete one.
		if wle = null then
			self.msgBox("No WLE!", app.getErrorString(Error), MsgBox_OK_Only, false);
			return false;
		endif;
		
		maxWleQuantityToLoad := wle.quantity;
		maxWleWeightToLoad := wle.weight;
		if wle.myRequest &lt;&gt; null then
			if wle.myRequest.isDeliveryRequest then
				reserveDetail := wle.myRequest.CM_DeliveryRequest.myReserveDetail;
			elseif wle.myRequest.isKindOf( CM_TIRequest) then
				reserveDetail := wle.myRequest.CM_TIRequest.myReserveDetail;
			endif;
		endif;
		if reserveDetail &lt;&gt; null then
			msg := reserveDetail.validateWeightQuantityAdd(	quantityLoading, weightLoading, false ).trimBlanks;
			if msg &lt;&gt; null then
				self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
				return false;
			endif;
		endif;
	endif;
	
	// cnwmc5 - 2 Feb 2016 - PAR 37483 
	// Get the quantity loaded related to self.myHandHeldCheckerAgent.myReserveSelection, if not null.
	// Otherwise, the quantity for the whole Bulk Release.
	quantityLoaded := self.getQuantityLoaded( weightLoaded, reserveDetail );	//already on the truck
	
	
	//Relative to the WLE where potentailly multiple trucks are working one bulk release,
	// should be able to load more than teh amount on the WLE on the basis that the checks above
	// will have determined that there was enough left on teh reserve details of teh bulk release.
	if quantityLoading &gt; 0 and maxWleQuantityToLoad &gt; 0 then
		if quantityLoaded &gt;= maxWleQuantityToLoad then
			//Already on the truck
			msg := app.getErrorString(Fully_loaded);
			if self.msgBox(msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		elseif (quantityLoaded + quantityLoading) &gt; maxWleQuantityToLoad then
			if quantityLoading &gt; 0 then
				msg := app.getErrorString3(Addin_truck_will_excee_totla_w, quantityLoading.String, quantityLoaded.String, maxWleQuantityToLoad.String );
			else
				msg := app.getErrorString2(Addin_will_excee_total_work_li, quantityLoading.String, maxWleQuantityToLoad.String );
			endif;
			if self.msgBox(app.getErrorString(Fully_loaded), app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
		
	elseif weightLoading &gt; 0 and  maxWleWeightToLoad &gt; 0 then
		if weightLoaded &gt;= maxWleWeightToLoad then
			//Already on the truck
			msg := app.getErrorString(Fully_loaded);
			if self.msgBox(msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		elseif (weightLoaded + weightLoading) &gt; maxWleWeightToLoad then
			if weightLoading &gt; 0 then
				msg := app.getErrorString3(Addin_truck_will_excee_totla_w, weightLoading.String, weightLoaded.String, maxWleWeightToLoad.String );
			else
				msg := app.getErrorString2(Addin_will_excee_total_work_li, weightLoading.String, maxWleWeightToLoad.String );
			endif;
			if self.msgBox(app.getErrorString(Fully_loaded), app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	
	endif;
	
	return true;
epilog

	delete wles;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
