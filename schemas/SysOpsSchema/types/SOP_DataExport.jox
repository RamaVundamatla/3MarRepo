    <JadeMethod name="mnuHistExtract_click" id="7fb9421e-8680-48ee-9113-ec90e3a53b9d">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuHistExtract_click(menuItem: MenuItem input) updating;

vars
	obj : Object;
	ddExtractHistory : CM_DataDumpExtractHistory;
	file : File;
	objArray : ObjectArray;
	fileSaveDialog:	CMDFileSave;
	defaultPath, defaultFileName : String;
begin
	create file transient;
	// Present save file dialog
	create fileSaveDialog;

	if fileSaveDialog.open = 0 then
		file.fileName := fileSaveDialog.fileName;	// get selected name (including path)
		file.mode := File.Mode_Output;
	//	file.kind := File.Kind_ANSI;
		file.allowCreate := true;	// create if not there
		file.open;		
	else
		return; // File opened failed
	endif;
	create objArray transient;
	file.writeLine("&lt;"&amp;app.name&amp;"&gt;");
	foreach obj in self.tblExtractHist.allSelectedObjects do
		if (not CM_DataDumpExtractHistory.hasInstance(obj)) then
			continue;
		endif;
		obj.CM_DataDumpExtractHistory.exportMeXML(file, objArray, false, false);
	endforeach;
	file.writeLine("&lt;/"&amp;app.name&amp;"&gt;");
	file.close;
epilog
	delete fileSaveDialog;
	delete file;
	delete objArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
