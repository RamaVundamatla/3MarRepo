    <JadeMethod name="setProxyFromCMIF_Machine" id="5ea76cd1-88e1-46a4-b69c-65d7766d9050">
        <updating/>
        <source>setProxyFromCMIF_Machine(_cmifMachine : CMIF_Machine; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 31/12/2013 	cnwer1	PAR 31267	edit crane rates
vars
	transArea : CM_CraneTransferArea;
	pxyCraneMoveRate : CM_CraneMoveRates;//par 22065
	realCraneMoveRate: CM_CraneMoveRates;//par 22065
	
begin
	inheritMethod(_cmifMachine,  _passport);
	
	transArea := _cmifMachine.craneTransferArea;
	if transArea &lt;&gt; null and transArea.crane &lt;&gt; self then
		self.transferArea := _cmifMachine.craneTransferArea;
	endif;
	
	if self.myMoveRate = null  then //par 22065 begin
		create pxyCraneMoveRate transient;
		pxyCraneMoveRate.setProxy(_cmifMachine.ratePerHourSLOD,
										_cmifMachine.ratePerHourSLUD,
										_cmifMachine.ratePerHourTLOD,
										_cmifMachine.ratePerHourTLUD,
										_cmifMachine.ratePerHourOD);
		pxyCraneMoveRate.setMyCrane(self);		
	else
	
		pxyCraneMoveRate:=self.myMoveRate;
		pxyCraneMoveRate.setProxy(_cmifMachine.ratePerHourSLOD,
										_cmifMachine.ratePerHourSLUD,
										_cmifMachine.ratePerHourTLOD,
										_cmifMachine.ratePerHourTLUD,
										_cmifMachine.ratePerHourOD);
	endif;//par 22065 end
	
	self.useRTForPickup := _cmifMachine.useRTForPickup;
	self.useRTForSetDown := _cmifMachine.useRTForPickupSetdown;
	self.targetRatePH := _cmifMachine.targetRatePH;
	self.jobSeed := _cmifMachine.craneJobSeed;
	self.minItemsForTLJob := _cmifMachine.minItemsForTLJob; // CCMS 1529
	self.maxLiftWeightTL := _cmifMachine.maxLiftWeightTL; // CCMS 1061
	
	self.allHatchJobTypes.clear;
	_cmifMachine.allHatchJobTypes.copy(self.allHatchJobTypes);
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347

end;</source>
        <Parameter name="_cmifMachine" type="CMIF_Machine"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="712b7823-906d-494b-b0b1-a732ce9c3121">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	cq : CM_VoyageCraneQueue;
	voyageCode : String;
begin
	inheritMethod();
	
//	if self.craneQueue &lt;&gt; null then
	cq := self.allCraneQueues.first(); // PAR 20474
	if cq &lt;&gt; null then
//		app.raiseCMException2(ERR_CRANE_HASQ, self.id &amp; " - " &amp; self.description, self.craneQueue.id, app.getErrorString(Crane_Queue), null);
		app.raiseCMException2(ERR_CRANE_HASQ, self.id &amp; " - " &amp; self.description, cq.id, app.getErrorString(Crane_Queue), null);
	endif;
	
	//Check to see if we aren't using the crane in any current voyages and job sheets
	voyageCode := self.isUsedForCurrentVoyage();
	if  voyageCode &lt;&gt; null then
		app.raiseCMException2(Err_crane_hasjobsheet, self.id , voyageCode, self.id, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateLanesAndCages" id="5c87c5fb-e7c2-4658-af1b-01711d999757">
        <source>validateLanesAndCages(_mess : String io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		The transfer area can say which lanes have twin lift load cages. 
//				The Q can say which lanes are for loading.
//				ARE THEY THE SAME?
//
// ---------------------------------------------------------------------------

vars
	theQ : 	CM_VoyageCraneQueue;
	theArea : CM_CraneTransferArea;
begin
	//if not self.canTwinLift then
	if self.machineLiftType = NORMAL_LIFT then//ccms1595 27/11/07
		return true;
	endif;

	theQ := self.allCraneQueues.first.CM_VoyageCraneQueue; // PAR 20474
	if theQ = null then
		_mess := "Crane has no crane queue.";
		return false;
	endif;
	
	theArea := self.transferArea;
	
	if theArea = null then
		_mess := "Crane has no transfer Area.";
		return false;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="5aa2b5f3-0230-44d9-81f4-e9372c6cd9ae">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	if self.transferArea = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Crane_Transfer_Area), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Crane_Transfer_Area), null, null); // cnwdb2	PAR 35364
	else
		if self.transferArea.crane &lt;&gt; null and self.transferArea.crane.id &lt;&gt; self.id then
			app.raiseCMException2(ERR_CTA_ALLOCATED, self.transferArea.id, self.transferArea.crane.id, null, null);
		endif;
	endif;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
