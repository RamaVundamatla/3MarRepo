    <JadeMethod name="doBtnCloseClick" id="428c0dc9-07f9-44d7-bfd3-4ffcf1933fe3">
        <updating/>
        <source>doBtnCloseClick() updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2003		cnwth2	
//
// Purpose:     Collects all objects		 
// ----------   ----------  --------------------------------------------------
vars
	fixedRows,
	numRows,
	row			: Integer;
	coll		: Collection;
	theTable	: CM_DataTable;
	obj			: Object;
begin
	/*
		Date	Who		Reason
	11 Sep 2008	cnwdz2	Par17640 - to avoid the error 1090.
	*/
	if self.myEnqController &lt;&gt; null then
		coll := self.myEnqController.allObjects;
	
		coll.clear();
	
		theTable := self.tblResults;
		fixedRows	:= theTable.fixedRows;
		numRows := theTable.rows;
			
		foreach row in fixedRows + 1 to numRows do
			obj := theTable.accessRow(row).itemObject;
			if obj &lt;&gt; null then
				coll.add(obj);
			endif;
		endforeach;
	endif;
	//cnwth2 - to investigate if this needed anymore as form is never modal anymore
	//self.saveCriteriaToParent();
	/*
		Date		      Who		Reason
		16 July 2008	cnwdz2	    Par15715 - moveing the above line of code into the method unloadForm.
	*/
	self.unloadForm;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLocateYardEnqClick" id="4219c7eb-e3ed-4d9f-aaa7-8b4c5104013f">
        <updating/>
        <source>doBtnLocateYardEnqClick() updating;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theTerminalArea : CM_GridArea;
	theArea : CM_TerminalArea;
	rows : CM_ObjectArray;
	objs : ObjectSet;
	theENQ : CM_EnquiryController;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	create objs transient;

	if self.tblResults.allSelectedObjects.isEmpty then
		self.myEnqController.allObjects.copy(objs);
	else
		self.tblResults.allSelectedObjects.copy(objs);
	endif;
	
	self.myAssistant.showYardRowEnquiryForm(objs, self.myMasterMenuAction,  self.myEnqController,false, VIEW_DESTPORT, 3, null);

epilog
	delete rows;
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="c3115e00-bf96-4d68-92c2-427456bf700f">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	// Get a collection of ALL the rows displayed to pass to the Summary Definition form.
	app.mousePointer	:= Busy;
	create coll transient;
	
	tblResults.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearFilter" id="7dbbc1e6-9345-43f5-b245-b96d88a2c0fd">
        <updating/>
        <source>doClearFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 October 2022	navgm20	ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS

*/

vars
	txtFilter	:	CMUI_TextBox;
	rowIndex	:	Integer;
begin
	txtFilter := self.txtArgFind;
	
	if txtFilter.text &lt;&gt; "" then
		txtFilter.text := "";
		self.btnClear.enabled := true;
	elseif txtFilter.text = "" then
		self.btnClear.enabled := false;
	endif;
	
	foreach rowIndex in 1 to self.tblArgument.rows do
		self.tblArgument.accessRow( rowIndex ).visible := true;
	endforeach;
	self.tblArgument.row := 1;
	self.tblArgument.topRow := 1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbMeasureClick" id="798a07d7-0977-4d05-ba47-eab1ad7c4ec7">
        <updating/>
        <source>doCmbMeasureClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurenments
//
vars
	tbl					: CM_DataTable;
	tblSheet			: JadeTableSheet;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
	theRow				: Integer;
	currentCriteriaLine	: CM_SelectorCriteriaLine;
	prop, transProp		: CM_QueryProperty;
	measure				: CM_MeasurementType;
	operator, transOp	: CM_QueryOperator;
	controlType			: Integer;

begin
	tbl 				:= self.tblCriteria;
	tblSheet 			:= tbl.accessSheet(tbl.topSheet);
	criteriaLineHolder	:= tblSheet.itemObject.CM_QueryCriteriaLineHolder;
	
	theRow := tblSheet.row;
	if theRow &lt;&gt; 0 then
		currentCriteriaLine := tblSheet.accessRow(theRow).itemObject.CM_SelectorCriteriaLine;
	endif;
	
	prop 		:= self.cmbAttr.listObject.CM_QueryProperty;
	operator 	:= self.cmbOperator.listObject.CM_QueryOperator;
	if prop = null or operator = null then
		return;
	endif;
	
	transProp := prop.cloneSelf(true);
	transOp := operator.cloneSelf(true);
	if CM_QDecimalTotalWeightProperty.hasInstance(prop) then
		measure := self.cmbMeasure.listObject.CM_MeasurementType;
		if measure &lt;&gt; null and measure &lt;&gt; transProp.CM_QDecimalTotalWeightProperty.myMeasurementType then
			transProp.CM_QDecimalTotalWeightProperty.myMeasurementType := measure;
			if currentCriteriaLine.myQueryProperty.isKindOf(CM_QDecimalProperty) then
				currentCriteriaLine.set(transProp, transOp, self.chkUnavailable.value);
			endif;
			controlType := prop.getControlTypeForOperator(operator);
			if controlType = QueryControl_ComboBox then
				transProp.setComboValues(self.cmbArgument, criteriaLineHolder, operator, app.myPassport);
			endif;
		endif;
	endif;

epilog
	
end;</source>
    </JadeMethod>
