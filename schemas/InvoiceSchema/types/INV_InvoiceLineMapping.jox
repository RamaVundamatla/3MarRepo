		//self.myCurrentDebtor := null;		// ### TFS 54566 10Oct2022 NAVPW1
		self.mulDebtors.setSelected(null);	// ### TFS 54566 10Oct2022 NAVPW1
	endif;
	self.loadLines();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="17a1cabf-d0e6-4da0-9be9-46c9e7051c8e">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 14/10/2022	navpw1	TFS: 55142 - Added reset of combobox for bank, selection for debtors and invoice line types
vars
	now : Date;
	bankIndex : Integer;	// ### TFS 55142 14Oct2022 NAVPW1
	
begin
	inheritMethod();
	
	bankIndex := self.cmbBank.findObject(self.myCurrentBank);	// ### TFS 55142 14Oct2022 NAVPW1
	self.cmbBank.listIndex := bankIndex;						// ### TFS 55142 14Oct2022 NAVPW1
	self.mulDebtors.setSelected(null);							// ### TFS 55142 14Oct2022 NAVPW1
	self.mulInvLineTypes.setSelected(null);						// ### TFS 55142 14Oct2022 NAVPW1
	
	//self.cmbDebtor.listIndex := 1; // ### TFS 54566 10Oct2022 NAVPW1
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="5f2f3219-e30a-4810-a85b-12de39cb4836">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 11/10/2022	navpw1	TFS: 54566 - Changed method to do Bulk Create, Update and Delete of Invoice Line Mappings. Delete only occurrs when you change a line mapping back to the default invoice type
vars
	pxyMapping, 
	realMapping			: CM_InvoiceLineDescMapping;
	ls					: Boolean;
	theReturn,
	row, col			: Integer;							// ### TFS 54566 10Oct2022 NAVPW1
	proxyCreateMappings,
	proxyUpdateMappings,
	proxyDeleteMappings,
	realCreateMappings	: CM_InvLineDescMapByDebtorLType;	// ### TFS 54566 10Oct2022 NAVPW1
	theTable			: CM_DataTable;						// ### TFS 54566 10Oct2022 NAVPW1
	bank				: CM_Bank;							// ### TFS 54566 10Oct2022 NAVPW1
	invTypeDescription	: String;							// ### TFS 54566 10Oct2022 NAVPW1
	debtor				: CM_DebtorNode;					// ### TFS 54566 10Oct2022 NAVPW1
	selectedInvoiceType,
	invoiceDescLoop,
	invoiceDesc			: CM_InvoiceDesc;					// ### TFS 54566 10Oct2022 NAVPW1
	lineType			: CM_InvoiceLineDesc;				// ### TFS 54566 10Oct2022 NAVPW1
	selectedDebtors		: CM_DebtorNodeByNameDict;			// ### TFS 54566 10Oct2022 NAVPW1
	
begin
	/*if self.myCurrentDebtor.isKindOf(CM_DebtorGroup) then
		app.msgBox("Cannot set maps for debtor groups.","Mapping Update Error",MsgBox_OK_Only);
		return;
	endif;*/ // ### TFS 54566 10Oct2022 NAVPW1 - Below code replaces this
	
	create selectedDebtors transient;
	self.mulDebtors.getSelected(selectedDebtors);
	
	foreach debtor in selectedDebtors do
		if debtor.isKindOf(CM_DebtorGroup) then
			app.msgBox("Cannot set maps for debtor groups.","Mapping Update Error",MsgBox_OK_Only);
			return;
		endif;
	endforeach;
	
	debtor := null;
	
	/*realMapping := self.myCurrentBank.allInvoiceLineDescMappings[self.myCurrentDebtor.CM_Debtor,self.myCurrentInvLineType, self.myCurrentInvType];
	
	if realMapping &lt;&gt; null then	
		app.cmsBeginLoad(ls);
		pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
		app.cmsEndLoad(ls);
	else
		create pxyMapping transient;
	endif;
	
	pxyMapping.setProxy(self.myCurrentBank,self.myCurrentDebtor.CM_Debtor,self.myCurrentInvLineType, self.myCurrentInvType);
	*/ // ### TFS 54566 10Oct2022 NAVPW1 - Uses bulk create/update logic below
	
	selectedInvoiceType := self.cmbInvoiceTypes.listObject.CM_InvoiceDesc;
	theTable := self.tblData;
	bank := self.myCurrentBank;
	row := 1;
	col := 1;
	
	create proxyCreateMappings transient;
	create proxyUpdateMappings transient;
	create proxyDeleteMappings transient;
	
	while theTable.selectedNext(row, col) do :selectedObjectsLoop
		debtor := theTable.accessColumn(col).itemObject.CM_DebtorNode;
		lineType := theTable.accessRow(row).itemObject.CM_InvoiceLineDesc;
		invTypeDescription := theTable.accessCell(row, col).text;
		
		foreach invoiceDescLoop in bank.invoiceTypes discreteLock do :invoiceTypeLoop
			if invoiceDescLoop.description &lt;&gt; invTypeDescription then
				continue invoiceTypeLoop;
			endif;
			
			invoiceDesc := invoiceDescLoop;
			break invoiceTypeLoop;
		endforeach;
		
		realMapping := self.myCurrentBank.allInvoiceLineDescMappings[debtor.CM_Debtor, lineType, invoiceDesc];
		if realMapping &lt;&gt; null and lineType.invoiceType = selectedInvoiceType then
			proxyDeleteMappings.add(realMapping);
			
		elseif realMapping &lt;&gt; null then	
			if realMapping.myInvoiceType = selectedInvoiceType then //If our real object already uses the invoice type then skip
				continue;
			endif;
			
			app.cmsBeginLoad(ls);
			pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
			app.cmsEndLoad(ls);
			
			pxyMapping.setProxy(self.myCurrentBank, debtor.CM_Debtor, lineType, selectedInvoiceType);
			proxyUpdateMappings.add(pxyMapping);
			
		else
			create pxyMapping transient;
			pxyMapping.setProxy(self.myCurrentBank, debtor.CM_Debtor, lineType, selectedInvoiceType);
			proxyCreateMappings.add(pxyMapping);
			
		endif;
		
	endwhile;
	
	while true do
		/*if self.mode = self.Mode_Update then
//			app.myTrxUA.trxUpdateInvoiceLineDescMap(pxyMapping, app.myPassport);
		else
			app.myTrxCA.trxCreateInvoiceLineDescMap(pxyMapping, realMapping, app.myPassport);
		endif;*/ // ### TFS 54566 10Oct2022 NAVPW1 - Uses bulk create/update trx below
		
		app.myTrxCA.trxCreateBulkInvLineDescMap(proxyCreateMappings, proxyUpdateMappings, proxyDeleteMappings, realCreateMappings, app.myPassport);	// ### TFS 54566 10Oct2022 NAVPW1
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(ls);			// 08/04/2011 cnwmh5 #27347
	delete selectedDebtors;		// ### TFS 54566 10Oct2022 NAVPW1
	delete pxyMapping;
	delete proxyCreateMappings;	// ### TFS 54566 10Oct2022 NAVPW1
	
	// ### TFS 54566 10Oct2022 NAVPW1
	if proxyUpdateMappings &lt;&gt; null and not proxyUpdateMappings.isEmpty then
		proxyUpdateMappings.purge;
		delete proxyUpdateMappings;
	endif;
	// ### TFS 54566 10Oct2022 NAVPW1
	
	delete realCreateMappings;	// ### TFS 54566 07Oct2022 NAVPW1
	delete proxyDeleteMappings; // ### TFS 54566 10Oct2022 NAVPW1
	
end;</source>
    </JadeMethod>
