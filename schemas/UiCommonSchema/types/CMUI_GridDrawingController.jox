    <JadeMethod name="drawIcons" id="61df00da-eec6-42fd-bc47-995a5cb4bd1c">
        <updating/>
        <source>drawIcons(_ti : CM_TrackedItem; _frame : CMUI_Frame input; _x1,_y1 : Real; _inverseColor : Integer; _planning : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 11/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
vars
	tmpIcons	: StringArray;
	theAtt		: Integer;
	tmpStr		: String;

begin
	// Draw the attributes (if any)
	self.allDrawingIcons.clear;
	tmpIcons := self.allDrawingIcons;
	//_ti.getAllDrawingIcons(tmpIcons);
	//_ti.getAllDrawingIconsByPriority(tmpIcons, self.attrMaxNum);		// 8/12/17 MAP TFS7493	// TFS 46405
	_ti.getAllDrawingIconsByPriority(tmpIcons, self.attrMaxNum, _planning);						// TFS 46405

	if tmpIcons.size &gt; 0 then
		if self.defaultFontSizeForAttributes &gt; 0 then
			_frame.drawFontSize := self.defaultFontSizeForAttributes;
		else
			_frame.drawFontSize := 8;
		endif;
		theAtt := 0;
		foreach tmpStr in tmpIcons do
			self.drawAttribute(_ti,_frame,_x1,_y1, _inverseColor, tmpStr, theAtt);
		endforeach;

		// reset back to the default font
		self.setDefaultFont(_frame);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_inverseColor" type="Integer"/>
        <Parameter name="_planning" type="Boolean"/>
    </JadeMethod>
