    <JadeMethod name="isBOL_Match" id="aaf20bf9-6925-47f2-8f91-da12ecbd4a6e">
        <source>isBOL_Match(_yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Sep 2019	jlgdi1	46043	Initial creation
*/
vars
	billOfLading : String;

begin
	if self.myTransaction = null then
		return false;
	endif;
	
	billOfLading := self.myTransaction.billOfLading.trimBlanks();
	
	if billOfLading = null then
		billOfLading := self.myTransaction.myTrackedItem.billOfLading.trimBlanks();
	endif;
	
	return _yaData.doesValueMatch(billOfLading); 
end;</source>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoTypeForContents_Match" id="1bc156f7-4275-4a1e-af0e-56fa8dd635a3">
        <source>isCargoTypeForContents_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2025	navkc1 JIRA 36148 AAT | RotaBox ISO Type and New Attributes - Yard Allocation
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	code 		: String;
	ct 			: CM_CargoType;
	dictByAbbr	: CM_CargoTypeByAbbrDict;
begin
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	create dictByAbbr transient;
	
	app.myRoot.allCargoTypesByDescription.copyNoDuplicates(dictByAbbr, false);
	
	foreach ct in dictByAbbr do
		// Do we have a match?
		if _yaData.matches(ct) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	delete dictByAbbr;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoType_Match" id="127b390a-e3f0-4969-ac3b-e3fadb1d7669">
        <source>isCargoType_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars
	ct : CM_CargoType;
begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	ct := app.myRoot.allCargoTypesById[self.myTransaction.cargoType];
	if ct = null then
		return false;
	endif;
	
	// Do we have a match?
	if _yaData.matches(ct) then
		return true;
	endif;
	
	return false;


end;</source>
