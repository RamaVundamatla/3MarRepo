    <JadeMethod name="btnGo_click" id="e8f53021-3521-4037-822c-e5007fb0100c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGo_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	
begin
	beginTransaction;

	myControl.numMessages 		:= txtNumMsgs.text.Integer;
	myControl.state 			:= TestAppControl.STATE_GO;
	myControl.silentMode 		:= chkSilent.value;
	myControl.remoteAddress 	:= txtHostname.text.trimBlanks;
	myControl.remotePort		:= txtPort.text.Integer;
	
	commitTransaction;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStartApps_click" id="1848feac-4366-43e5-9c85-fe520358d321">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStartApps_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	i				: Integer;
		
begin
	foreach i in 1 to txtNumApps.text.Integer do
		app.startApplication(currentSchema.name, "TestApplication");
	endforeach;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStop_click" id="64d08db7-655c-43af-8254-04b1933b4abc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStop_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	beginTransaction;
	myControl.state := TestAppControl.STATE_STOP;
	commitTransaction;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnTerminate_click" id="1a268dba-29ed-4e61-b978-c40a7f99b6bc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTerminate_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	beginTransaction;
	myControl.state := TestAppControl.STATE_TERMINATE;
	commitTransaction;


epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="2b12ae58-676b-4230-aec4-3edd043955cd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	
begin
	myControl := TestAppControl.firstInstance;
	
	if myControl = null then
		beginTransaction;
		create myControl;
		commitTransaction;
	endif;
	
	txtHostname.text 	:= TestAppControl.DEFAULT_HOSTNAME;
	txtPort.text 		:= TestAppControl.DEFAULT_PORT.String;
	

epilog
	
end;</source>
    </JadeMethod>
</GUIClass>
