    </JadeMethod>
    <JadeMethod name="tCamGroup" id="078621b4-a2a6-4cfa-9e7c-aaeb17a99981">
        <source>tCamGroup();
/*

Purpose:			

Date		Who		Reason
24/04/2014	cnwma1	Initial creation

*/
constants

	CamGroup ="UT_CAMG";
vars
	camGroup : CM_CamGroup;
		operatorDict : CM_OperatorByCodeDict;
		freightForwarders : CM_ConsigneeConsignorSet;
		operator : CM_Operator;
	
begin
	//Delete Cam Group
	self.deleteCamGroup(CamGroup);
	
	
	operator := self.getOperator("APL");
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	
	// Add Cam Group
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	
	// Update SubTerminal
	self.opts.purge();
	self.opts.addAssoc("CamDesc", "UT_CAMGUP");
	self.updateCamGroup(camGroup);
	
epilog
	delete operatorDict;
	delete freightForwarders;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCommodityGroup" id="3b195c60-c1b2-422f-ba89-9271c9e5885a">
        <source>tCommodityGroup();
/*

Purpose:	Create,Update and Delete Commodity Group		

Parameters:			

Date		Who		Reason
20/02/2014	cnwma1	Initial creation

*/

vars
	commodityGroup	: CM_CommodityGroup;
	commoditySet	: ObjectArray;
	comDesc			: String;
	
begin

	// Prepare Commodity 
	create commoditySet transient;
	commoditySet.add(app.myRoot.allCommodities["MEAT"]);
	commoditySet.add(app.myRoot.allCommodities["LAMB"]);
	
	self.opts.purge();
	self.opts.addAssoc("Commodity",commoditySet);
	
	//Create Commodity group
	commodityGroup	:= self.addCommodityGroup("MEAT","Frozen Meat");
	self.assertNotNull(commodityGroup);
	
	// update Commodity Group
	comDesc := commodityGroup.description &amp; ":UP";
	self.opts.purge();
	self.opts.addAssoc("ComDesc", comDesc);
	self.updateCommodityGroup(commodityGroup);
	self.assertEqual(commodityGroup.description, comDesc);
	
epilog

	delete commoditySet;


end;</source>
    </JadeMethod>
    <JadeMethod name="tConsigneeConsignorAddress" id="66874836-572c-48ea-b4b6-60feeb25a894">
        <source>tConsigneeConsignorAddress();
// cnwmk3
// cnwjre1	test par 31448, address maintenance for consignee/or
constants

	ConsigneeId1		: String = "UTCE1";
	ConsignorId1		: String = "UTCO1";
	ConsigneeId2		: String = "UTCE2";
	ConsignorId2		: String = "UTCO2";

vars
	consignee1,
	consignor1	: CM_ConsigneeConsignor;
	consignee2,
	consignor2	: CM_ConsigneeConsignor;
begin

	// create the consignee
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee1 := self.addConsigneeConsignorAddress(ConsigneeId1, ConsigneeId1, true, false, false,
													'address 1', 'address 2','address 3', 'ABC123', 'Canterbury', 'NZ');
	self.assertNotNull(consignee1);
	self.assertEqualMsg(consignee1.getAddress1(), 'address 1', "Consignee1 address 1 'address 1'");
	self.assertEqualMsg(consignee1.getAddress2(), 'address 2', "Consignee1 address 2 'address 2'");
	self.assertEqualMsg(consignee1.getAddress3(), 'address 3', "Consignee1 address 3 'address 3'");
	self.assertEqualMsg(consignee1.getAddressPostCode(), 'ABC123', "Consignee1 post code 'ABC123'");
	self.assertEqualMsg(consignee1.getAddressRegion(), 'Canterbury', "Consignee1 region 'Canterbury'");
	self.assertEqualMsg(consignee1.getAddressCountryName(), 'NEW ZEALAND', "Consignee1 country 'NEW ZEALAND'");

	// create the consignor
	self.deleteConsigneeConsignor(ConsignorId1);
	consignor1 := self.addConsigneeConsignorAddress(ConsignorId1, ConsignorId1, false, true, false,
													'address 4', 'address 5','address 6', '321XYZ', 'QLD', 'AU');
	self.assertNotNull(consignor1);	
	self.assertEqualMsg(consignor1.getAddress1(), 'address 4', "Consignor1 address 1 'address 4'");
	self.assertEqualMsg(consignor1.getAddress2(), 'address 5', "Consignor1 address 2 'address 5'");
	self.assertEqualMsg(consignor1.getAddress3(), 'address 6', "Consignor1 address 3 'address 6");
	self.assertEqualMsg(consignor1.getAddressPostCode(), '321XYZ', "Consignor1 post code '321XYZ'");
	self.assertEqualMsg(consignor1.getAddressRegion(), 'QLD', "Consignor1 region 'QLD'");
	self.assertEqualMsg(consignor1.getAddressCountryName(), 'AUSTRALIA', "Consignor country1 'AUSTRALIA'");
	
	// create a consignee with no address
	self.deleteConsigneeConsignor(ConsigneeId2);
	consignee2 := self.addConsigneeConsignor(ConsigneeId2, ConsigneeId2, false, true, false);
	self.assertNotNull(consignee2);	
	self.assertEqualMsg(consignee2.getAddress1(), null, "Consignee 2 no address");
	
	// update each consignee/or address
	self.opts.purge();
	self.opts.addAssoc( ETRow_AddressLine1, 'address XX1');
	self.opts.addAssoc( ETRow_AddressLine3, 'address XX3');
	self.updateConsigneeConsignor( consignee1 );
	self.assertEqualMsg(consignee1.getAddress1(), 'address XX1', "Consignee1 updated address 1 'address XX1'");
	self.assertEqualMsg(consignee1.getAddress3(), 'address XX3', "Consignee1 updated address 3 'address XX3'");
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_AddressPostCode, 'A1B2C3');
	self.opts.addAssoc( ETRow_AddressLine2, 'address XX2');
	self.updateConsigneeConsignor( consignor1 );
	self.assertEqualMsg(consignor1.getAddressPostCode(), 'A1B2C3', "Consignor1 updated post code 'A1B2C3'");
	self.assertEqualMsg(consignor1.getAddress2(), 'address XX2', "Consignor1 updated address 2 'address XX2'");
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_AddressCountry, 'NZ');
	self.opts.addAssoc( ETRow_AddressRegion, 'Auckland');
	self.updateConsigneeConsignor( consignee2 );
	self.assertEqualMsg(consignee2.getAddressRegion(), 'Auckland', "Consignee2 updated region 'Auckland'");
	self.assertEqualMsg(consignee2.getAddressCountryName(), 'NEW ZEALAND', "Consignee2 updated country 'NEW ZEALAND'");
	
epilog
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="tContainerRange" id="7344d48a-8637-433e-a32e-2414b22f222f">
