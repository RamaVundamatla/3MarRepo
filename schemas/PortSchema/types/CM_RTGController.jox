    <JadeMethod name="getParentForMachine" id="58fd67e5-510d-4521-9422-70f88f18bf1d">
        <source>getParentForMachine(_machine: CM_Machine): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwer1	Initial creation

*/

vars

begin
	if	 _machine.machineType = MACHINETYPE_RTG  or  _machine.machineType = MACHINETYPE_RMG then
		 return inheritMethod(_machine);
		
	endif;

	return  self.getMyLaneController.myTerminalArea;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getPic" id="06f67f79-0901-4e84-8ccd-d0eea8e77693">
        <source>getPic(): String;
/*
----------   ----------  --------------------------------------------------
Created:	14 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.usage = BUILDING_USE then
		return PicTIBuilding;
	elseif self.usage = LIGHT_TOWER_USE then
		return PicTILight;
	elseif self.usage = REEFERGANTRY_USE then
		return PicTIReeferGantry;
	elseif self.availability &lt;&gt; PAD_AVAILABLE then
		return PicTIUnavail;
	endif;
	
	return inheritMethod();


end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="789ebc0f-5dc6-488b-b890-4dd42ad2767f">
        <source>getQueueTasks(_arbiter: CM_RTQueueArbiter input; _isSource : Boolean);

// Created by cnwdvb1 on 15 August 2006

vars

	task	: CM_RTQueueTask;

begin
	

	if _isSource then
		//cnwrd1 ccms 2014 24.3.2011
		if _arbiter.entry = null or not _arbiter.entry.isPlanOnPickup then
			create task;
			task.setDetails(	self, 
								self.myGridColumn.CM_RTGColumn.getMyLaneController(),
								TASK_UNACTIONED,
								TASK_PICKUP,
								_arbiter.ti);
		elseif not _arbiter.entry.isPlanOnPickupNoTarget then	
			//dont want to create a pickup task here.
		else
			create task;
			task.setDetails(	self, 
								self.myGridColumn.CM_RTGColumn.getMyLaneController(),
								TASK_UNACTIONED,
								TASK_PICKUP,
								_arbiter.ti);				
		endif;
		

								
	else
		create task;
		task.setDetails(	self.myGridColumn.CM_RTGColumn.getMyLaneController(), 
								self,
								TASK_UNACTIONED,
								TASK_SETDOWN,
								_arbiter.ti);
	endif;
	if task &lt;&gt; null then //cnwrd1 par 27482 20.5.2011
		_arbiter.entry.addTask(task);	
	endif;	

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="6f45713c-72d1-4be6-8d34-7191b857011c">
        <source>getQueues(queueSet: CM_RTQueueSet io);
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	taGroup		: CM_TerminalAreaGroup;
	rtQueue		: CM_RadioTelemetryQueue;
begin

	inheritMethod(queueSet);
	
	//epr CCMS 1076 11/8/09
	foreach taGroup in self.myTerminalArea.allTerminalAreaGroups do 
		if taGroup &lt;&gt; null then
			foreach rtQueue in taGroup.allSubRTQueues discreteLock do
				if not queueSet.includes(rtQueue) then
					queueSet.add(rtQueue);
				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRowColumn" id="329e65d6-d66d-4efc-9268-e4a2120a681c">
        <source>getRowColumn(_row: Integer output; _column: Integer output; _flippedH, _flippedV : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		used for auto planning to ship, RTG stacks need to work by column
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myGridRow = null then
		return;
	endif;
	 _column := self.myGridRow.row;
	_row := self.myGridColumn.column;
end;</source>
        <Parameter name="_row" type="Integer" usage="output"/>
        <Parameter name="_column" type="Integer" usage="output"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_flippedV" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIsColour" id="8bb0c88e-d7f3-4156-a046-a50d57c284d3">
        <source>getStackHeightOfTIsColour() : Integer;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
/* note these are the meanings of the colours
  strs(1) = "Unavailable"
  strs(2) = "SubBlock"
  strs(3) = "Light"
  strs(4) = "Building"
  strs(5) = "Empty"
  strs(6) = "Ẅ"
  strs(7) = "1"
  strs(8) = "1 Ẅ"
  strs(9) = "2"
  strs(10) = "2 Ẅ"
  strs(11) = "3"
  strs(12) = "3 Ẅ"
  strs(13) = "4"
  strs(14) = "4 Ẅ"
  strs(15) = "5"
  strs(16) = "5 Ẅ"
  strs(17) = "6"
  strs(18) = "6 Ẅ"
  strs(19) = "7"
  strs(20) = "7 Ẅ"
  strs(21) = "8"

*/
// ---------------------------------------------------------------------------
vars
	totalHeight	:	Integer;
	idx, colur : Integer;
	ti : CM_TrackedItem;
	prevGC : CM_GridController;
begin

	if self.mySubBlockStack &lt;&gt; null then
		return 2;
	elseif self.usage = BUILDING_USE then
		return 4;
	elseif self.usage = LIGHT_TOWER_USE then
		return 3;
	elseif self.usage = UNAVAILABLE_USE or self.availability = PAD_USER_UNAVAILABLE or self.availability = PAD_UNAVAILABLE then 
		return 1;
	else
		// PAR 17067 from here
		if self.allTrackedItems.isEmpty() then
			if self.allTrackedItemOSBackEnds.isEmpty()  and self.offset53 = self.Offset53_6 then
				prevGC := self.getPreviousControllerOfType(CM_RTGController);
				if prevGC &lt;&gt; null then
					foreach ti in prevGC.allTrackedItemOSBackEnds do
						totalHeight := totalHeight + ti.getHeightOfTI();
					endforeach;
				endif;
			else
				foreach ti in self.allTrackedItemOSBackEnds do
					totalHeight := totalHeight + ti.getHeightOfTI();
				endforeach;
			endif;
		else
		// PAR 17067 to here
			foreach ti in self.allTrackedItems do
				totalHeight := totalHeight + ti.getHeightOfTI();
			endforeach;
		endif;
		idx := totalHeight;
		idx := idx + 5;
		if idx &gt; 21 then
			idx := 21;
		endif;
		
		return idx;
	endif;
	
	return -1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
