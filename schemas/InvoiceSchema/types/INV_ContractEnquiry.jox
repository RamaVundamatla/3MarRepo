	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvContractDelete), Response_Continuous, null);
	
	self.setCaption("Invoice Contracts Enquiry " &amp; self.myCurrentBank.code );
	
	
epilog

end;</source>
