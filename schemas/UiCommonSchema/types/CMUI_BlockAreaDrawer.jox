    <JadeMethod name="delete" id="857a7340-c884-4d01-b7ce-1cd72dbc0d1a">
        <updating/>
        <source>delete() updating;
//29 May 2008	cnwdw1	
//
begin
	self.myCells.purge();
	self .deleteDummyYardAllocation();
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDummyYardAllocation" id="112199f9-de58-4c64-8180-cef38600f633">
        <updating/>
        <source>deleteDummyYardAllocation() updating, protected;
//17 June 2008	cnwdw1	
// A transent yadr allocation is created when a new yard allocation is created. We have to delete it
vars
	yardAllocation : CM_YardAllocation;
begin
	yardAllocation := self.getSelectedYardAllocation();
	if yardAllocation &lt;&gt; null and yardAllocation.isTransient() then
		delete self.mySelectedYardAllocation;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteLocation" id="16ecbb40-7921-4925-b87c-a5f1654ecf1a">
        <updating/>
        <source>deleteLocation(location : CM_IrregularBlockController) updating;
// a location has been deleted from the area
begin
	
	//epr par 35113 10/11/14
	if self.allSelectedObjects.includes(self.mySelectedLocation) then
		self.allSelectedObjects.remove(self.mySelectedLocation);
	endif;
	self.deselectLocation(self.mySelectedLocation);
	self.deleteLocationFromCells(location);
	
	
	self.mySelectedLocation:=self.allSelectedObjects.last.CM_IrregularBlockController;
end;
</source>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="deleteLocationFromCells" id="edf99b64-38ef-403c-a044-f827b92225c9">
        <source>deleteLocationFromCells(location : CM_IrregularBlockController) protected;
// Delete the location region from the cells location. 
vars
	topLeft, bottomRight : Point;
	x, y : Integer;
begin
	if location.region.isEmpty() then
		return;
	endif;

	topLeft := location.region.first;
	bottomRight := location.region.last;
	foreach x in topLeft.x to bottomRight.x do
		foreach y in topLeft.y to bottomRight.y do
			self.getCell(x, y).setLocation(null);
			self.drawCell(x, y);
		endforeach;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="deselectAll" id="4c7ded11-b099-464a-abb9-3edab3f75a2f">
        <updating/>
        <source>deselectAll() updating,protected;
// Deselect all selected cells and locations
vars
	obj : Object;
	gridCell : CMUI_BlockGridCell;
begin
	self.deselectLocation(mySelectedLocation);
	
	foreach obj in self.myCells do
		gridCell := obj.CMUI_BlockGridCell;
		if gridCell.isSelected then
			self.deselectCell(gridCell.column, gridCell.row);
		endif;
	endforeach;
	
	self.allSelectedObjects.clear; // PAR 32308

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deselectCell" id="80e0145e-30e3-4562-9754-4300c6045186">
        <source>deselectCell(x, y : Integer) protected;
// Deselect the cell
begin
	self.getCell(x, y).setIsSelected(false);
	self.drawCell(x, y);
end;
</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deselectLocation" id="b5deb510-daa0-4bd6-b963-39671f9d19da">
        <updating/>
        <source>deselectLocation(location: CM_IrregularBlockController) updating, protected;
// Deselect the location
begin
	mySelectedLocation := null;
	if location &lt;&gt; null then
		self.drawLocation(location, false);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
