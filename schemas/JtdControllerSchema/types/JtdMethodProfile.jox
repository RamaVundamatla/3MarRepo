    <DbClassMap file="Jtd"/>
    <PrimAttribute name="jtdClassName" id="49ea82ec-060c-4645-83a8-98477a466434">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="jtdMethodName" id="a5752be4-f920-4de3-98a3-1cb964273f4a">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="jtdMyDriverProfile" id="7868c938-5b15-489e-b87f-8337670c8195">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="JtdDriverProfile"/>
        <access>readonly</access>
        <Inverse name="JtdDriverProfile::jtdAllEpilogProfiles"/>
        <Inverse name="JtdDriverProfile::jtdAllMethodProfiles"/>
        <Inverse name="JtdDriverProfile::jtdAllPrologProfiles"/>
    </ExplicitInverseRef>
    <PrimAttribute name="jtdNumCalls" id="504bfaa0-a8a4-439f-9a88-82115f44d977">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="jtdThinkSecs" id="6d24f470-2f06-4d41-b7c8-b2ea635bf1f3">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="jtdAsString" id="ad1b870f-ef1d-485d-882d-ec006c2f500b">
        <source>jtdAsString() : String;

begin
	return self.jtdClassName &amp; ';' &amp; self.jtdMethodName &amp; ';' &amp;
		self.jtdNumCalls.String &amp; ';' &amp; self.jtdThinkSecs.String &amp; ';';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdClassAndMethodExist" id="ec482fde-ea35-4cd6-beb3-bb4e5901a489">
        <source>jtdClassAndMethodExist() : Boolean;

vars
	cls : Class;
	
begin
	cls := currentSchema.jtdGetClasses[self.jtdClassName];
	
	if cls = null then
		return false;
	endif;
	
	return cls.jtdGetMethods[self.jtdMethodName] &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdInitialize" id="5997e545-b355-4635-8bc9-0f02477b9f7b">
        <updating/>
        <source>jtdInitialize() updating;

begin
	self.jtdClassName := null;
	self.jtdMethodName := null;
	self.jtdNumCalls := 0;
	self.jtdThinkSecs := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdIsFirst" id="6a455a81-4a5b-44e2-b224-1a268e63b1f2">
        <source>jtdIsFirst() : Boolean;

vars
	dp : JtdDriverProfile;

begin
	dp := self.jtdMyDriverProfile;
	
	if dp = null then
		return false;
	endif;
	
	return dp.jtdAllMethodProfiles.first = self or
		   dp.jtdAllPrologProfiles.first = self or
		   dp.jtdAllEpilogProfiles.first = self;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdIsLast" id="3939d1b9-d54d-405c-abf0-be809d4da5a6">
        <source>jtdIsLast() : Boolean;

vars
	dp : JtdDriverProfile;

begin
	dp := self.jtdMyDriverProfile;
	
	if dp = null then
		return false;
	endif;
	
	return dp.jtdAllMethodProfiles.last = self or
		   dp.jtdAllPrologProfiles.last = self or
		   dp.jtdAllEpilogProfiles.last = self;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdIsLastEpilogMethod" id="c64b13f7-3bb4-4052-bfb0-23a080bea5d3">
        <source>jtdIsLastEpilogMethod() : Boolean;

begin
	return self.jtdMyDriverProfile &lt;&gt; null and
		   self.jtdMyDriverProfile.jtdAllEpilogProfiles.last = self;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdIsLastMainMethod" id="963dc41d-3784-4716-bca4-763d5fdece2e">
        <source>jtdIsLastMainMethod() : Boolean;

begin
	return self.jtdMyDriverProfile &lt;&gt; null and
		   self.jtdMyDriverProfile.jtdAllMethodProfiles.last = self;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdIsLastPrologMethod" id="378679d2-712e-4e43-a770-bdbd1011d877">
        <source>jtdIsLastPrologMethod() : Boolean;

begin
	return self.jtdMyDriverProfile &lt;&gt; null and
		   self.jtdMyDriverProfile.jtdAllPrologProfiles.last = self;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdSetClassAndMethodNames" id="44c21482-99d5-4830-a8b9-371ac7cfcbd8">
        <updating/>
        <source>jtdSetClassAndMethodNames(clsName, mthName : String) updating;

begin
	self.jtdClassName := clsName;
	self.jtdMethodName := mthName;
end;</source>
        <Parameter name="clsName" type="String"/>
        <Parameter name="mthName" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetFromString" id="56f27977-bf1c-41c6-b0c6-3111f645dc26">
        <updating/>
        <source>jtdSetFromString(valueString : String) updating;

vars
	i, n, len : Integer;
	vs, s : String;
	
begin
	self.jtdInitialize;

	vs := valueString.trimBlanks;

	i := 1;
	n := 1;
	len := vs.length;
		
	while n &lt;= len do
		s := vs.scanUntil(';', n);
		
		if n &lt; 1 then
			break;
		endif;

		if i = 1 then		
			self.jtdClassName := s;
		elseif i = 2 then
			self.jtdMethodName := s;
		elseif i = 3 then
			self.jtdSetNumCalls(s.Integer);
		elseif i = 4 then
			self.jtdSetThinkSecs(s.Integer);
			break;
		endif;

		n := n + 1;
		i := i + 1;
	endwhile;
end;</source>
        <Parameter name="valueString" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetNumCalls" id="0af40f21-a2a7-4c80-aba7-0d2793279518">
        <updating/>
        <source>jtdSetNumCalls(n : Integer) updating;

begin
	if n &lt; 1 then
		self.jtdNumCalls := 0;
	else
		self.jtdNumCalls := n;
	endif;
end;</source>
        <Parameter name="n" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetThinkSecs" id="bcc270f7-ff71-41bd-a936-0df003c40cb4">
        <updating/>
        <source>jtdSetThinkSecs(n : Integer) updating;

begin
	if n &lt; 1 then
		self.jtdThinkSecs := 0;
	elseif n &gt; JtdMaxThinkSeconds then
		self.jtdThinkSecs := JtdMaxThinkSeconds;
	else
		self.jtdThinkSecs := n;
	endif;
end;</source>
        <Parameter name="n" type="Integer"/>
    </JadeMethod>
</Class>
