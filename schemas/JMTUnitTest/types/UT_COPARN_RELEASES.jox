LOC+11+NZAKL:139:6'
LOC+98+NZPOE:139:6'
MEA+AAE+G+KGM:1000'
MEA+AAE+T+KGM:2500'
MEA+AAE+EGW+KGM:3500'
TDT+30+1124+1++MAE:172:20+++9346562:146:11:BC SAN FRANCISCO'
LOC+11+AUSYD:139:6'
EQD+CN++42G1:102:5+2+2+4'
RFF+BN:GB100001'
EQN+1'
TMD+3++2'
DTM+201:" &amp; strTS1 &amp; ":203'
LOC+8+AUSYD:139:6'
LOC+11+NZAKL:139:6'
LOC+98+NZPOE:139:6'
MEA+AAE+G+KGM:1500'
