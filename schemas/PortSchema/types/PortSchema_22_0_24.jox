    <JadeMethod name="updateTerminalVbsProcess" id="eac2e649-3562-40ce-8f55-2b229aa35f35">
        <source>updateTerminalVbsProcess(_controller : CnEcReleaseController);
/*

Purpose:			Updates all the terminals to the default Vbs process

Parameters:			_controller	CnEcReleaseController	Handles logging etc

Return Value:		NONE

Date		Who		Reason
20 January 2023	navpw1	Initial creation TFS: 53697 (55830) Upgrade Script for adding new VBS Processes

*/

vars
	terminal					: CM_Terminal;
	realStandardVBSProcess		: CM_VBSProcess;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Updating All Terminals Default VBS Process", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating All Terminals Default VBS Process") ;	
	endif;
	
	realStandardVBSProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE];
	
	if realStandardVBSProcess = null then
		app.writeLog(method.qualifiedName &amp; " Could not find standard Vbs process", LogINFO);
		_controller.logEntry(" Could not find standard Vbs process") ;
		return;
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setDefaultVBSProcess(realStandardVBSProcess);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Updating All Terminals Default VBS Process complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Updating All Terminals Default VBS Process complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateTrailerEntTables" id="c488d7a3-5d8e-4b8e-b2ea-aeb16745fad0">
        <source>updateTrailerEntTables(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars
	iter : Iterator;
	cargoType : CM_CargoType;
	root : CM_Root;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Updating Trailer ent table defintions with Load Details", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating Trailer ent table defintions with Load Details") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	iter:=root.allCargoTypesById.createIterator;
		
	app.writeLog ('Updating User Cargo Types ent table defs', LogINFO);
	
	while iter.next(cargoType) do	
		if  cargoType.isSystemCargoBOLType then
			continue;
		endif;
		
		if not cargoType.isTrailer then
			continue;
		endif;
		
		beginTransaction;
		cargoType.sendMsgWithParams(CM_CargoType::setProxyProductType.name,cargoType.productType);
		commitTransaction;
	endwhile;

	
	
	
	app.writeLog(method.qualifiedName &amp; " Updating Trailer ent table defintions with Load Details complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating Trailer ent table defintions with Load Details complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete iter;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
