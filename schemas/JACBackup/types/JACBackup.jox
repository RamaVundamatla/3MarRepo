    <JadeMethod name="globalExceptionHandler" id="ffa97248-2c2f-43b1-823d-f48e578ce2cb">
        <updating/>
        <source>globalExceptionHandler(_exObj : Exception) :Integer updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	subject,message:String;
begin

	on Exception do app.horribleExceptionHandler(_exObj);

	if _exObj.errorCode = 1227 then
		// 1227 = Notification subscriber not found which can happen when multiple splits all
		// 			finish close together. Ignore
		return Ex_Resume_Next;
	endif;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' *** ERROR *** ' &amp; _exObj.String &amp; ', ' &amp; _exObj.reportingMethodDesc.String &amp; ', ' &amp; _exObj.currentMethodDesc.String &amp; ', ' &amp; _exObj.errorCode.String, LogAlways);

	self.doDumpStack(_exObj);

	if process.isInTransientTransactionState then
		commitTransientTransaction;
	endif;
	abortTransaction;

	subject := "JacBackup Exception occured for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
	message := "An exception ("&amp;_exObj.errorCode.String&amp;") has occured in JacBackup. See jommsg log for details";
	app.myServerAppObject.sendEmail(subject, message);

	return Ex_Abort_Action;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="globalLockExceptionHandler" id="6a8d3b2c-89cf-48ec-bb91-faf4ef8dd9de">
        <source>globalLockExceptionHandler(le : LockException) : Integer;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Attempt to handle locks
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
 	lockedByUserCode: String;
 	retryCount: Integer;
begin
 	if global.isValidObject(le.targetLockedBy) then	// locking process could have gone away  
 		lockedByUserCode := le.targetLockedBy.userCode;
 		if lockedByUserCode = '' then
 			lockedByUserCode := 'not available';
 		endif;
 	endif;

 	while (not tryLock(le.lockTarget, le.lockType, le.lockDuration, le.lockTimeout)) do
 		retryCount := retryCount + 1;
 		if retryCount &gt; 30 then		// 30 seconds if lock timeout is 1000 mS
 			return Ex_Pass_Back;	// let another handler deal with it
 		endif;
 	endwhile;

 	return Ex_Continue;				// must have the lock if we get to here

end;</source>
        <Parameter name="le" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedObject" id="da3fb50a-559c-4393-9766-a7dfede635c8">
        <source>handleDeletedObject(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;

/*

Purpose:			General exception handler to deal with invalid object references.  Needs to be
					armed with a specific object reference to be checked.


Return Value:		Standard Exception return codes, and _invalidObject set to true if
					the specified object reference caused the exception.


Date		Who		Reason
18 Mar 2008	cnwkpd1	PAR #16195 - Allow generic handling of invalid objects
03 Jun 2008	cnwkpd1	PAR #16718 - handle exclusive collection exceptions as well, as there are
					situations where an exclusive collection on the object we are interested in
					will be the error object in the exception
21 May 2009	cnwkpd1	Change to use new JADE Object::getOwnerForObject method
04 Feb 2011	cnwkpd1	PAR #27142 - Added code to handle null _obj, to protect against incorrect
					arming and therefore invalid resume for standard objects (with no owner)
					
*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="horribleExceptionHandler" id="4aabaccc-7833-4111-a85b-bac1208f50ec">
        <updating/>
        <source>horribleExceptionHandler(_exObj: Exception) :Integer updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

// armed and called from within other exception handlers if an exception occurs
// while dealng with the first exception

vars
	subject, message: String;
begin

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' *** HORRIBLE ERROR *** ' &amp; _exObj.String &amp; ', ' &amp; _exObj.reportingMethodDesc.String &amp; ', ' &amp; _exObj.currentMethodDesc.String &amp; ', ' &amp; _exObj.errorCode.String, LogAlways);
	subject := "JacBackup Exception occured for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
	message := "An exception ("&amp;_exObj.errorCode.String&amp;") has occured in JacBackup. See jommsg log for details";
	app.myServerAppObject.sendEmail(subject, message);

	return Ex_Abort_Action;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initLogFile" id="ee022f6b-02b4-4133-97ba-eb0bf4615655">
        <updating/>
        <source>initLogFile() updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	log	: JadeLog;
	date: Date;
begin
	if app.myLogFile = null then
		create log;
		log.formatOutput := true;	// adds timestamp, etc to each line
		log.versionFile := false;	// do NOT rollover when reaches max size
		log.fileName := app.name &amp; '_' &amp; date.userFormat($CnCCYYMMDD_ns) &amp; '.log';
		app.myLogFile := log;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="f7563c9a-c2bb-4aad-a236-137b4b14b8ad">
        <updating/>
        <source>initialize() updating;
// ---------------------------------------------------------------------------
// Created:     
//
