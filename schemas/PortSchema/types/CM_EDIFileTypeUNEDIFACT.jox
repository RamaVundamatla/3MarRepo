    <JadeMethod name="getOperatorTranslation" id="ce2049ab-3e31-4e11-9154-fdb51c0588da">
        <source>getOperatorTranslation(_translationText	: String; _operator	: CM_Operator; _ediTranslation	: Integer; _maxLength : Integer ) : String;
/*
Purpose:		This method will attempt to obtain the required operator translation if one exists for the supplied
				operator and editTranslation. Returning a string truncated to the supplied maximum length (if not null).

Date				Who		Reason
28 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
07 Mar 2013			cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
	
vars
	returnStr		: String;
	foundMatch		: Boolean;
begin
	returnStr	:= _translationText.trimBlanks;
	
	// do some basic sanity checking
	if returnStr = null then
		return returnStr;
	endif;
	
	if _operator = null or _translationText = null then
		if _maxLength = null then
			return returnStr;
		else
			return returnStr[ 1 : _maxLength ];
		endif;
	endif;
	
	// OK attempt to do the operator translation.
	returnStr	:= _operator.getXlationSystemCode( returnStr, _ediTranslation, foundMatch );
	
	if _maxLength = null then
		return returnStr;
	else
		return returnStr[ 1 : _maxLength ];
	endif;
epilog
	
end;
</source>
        <Parameter name="_translationText" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediTranslation" type="Integer"/>
        <Parameter name="_maxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getServiceStringAdviceInfo" id="d7e11484-e570-4749-8b11-14ad0d75a339">
        <source>getServiceStringAdviceInfo(	_message:String;
							_fieldSeparator:String output;
							_itemSeparator:String output;
							_decimalChar:String output;
							_escapeChar:String output;
							_eolChar:String output):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2010
//
// Purpose:		Returns the characters defined as separators and delimiters for the
//				message file, as specified by the "UNA" file line.
/*
UNA, Service String advice

 Function:	To define the characters selected for use as delimiters and indicators in
			the rest of the interchange that follows:

 The specifications in the Service string advice take precedence over the specifications
 for delimiters etc. in segment UNB.  See clause 4.

 When transmitted, the Service string advice must appear immediately before the
 Interchange Header (UNB) segment and begin with the upper case characters UNA
 immediately followed by the six characters selected by the sender to indicate, in
 sequence, the following functions:

 Repr.        Name								Remarks

 an1    M     COMPONENT DATA ELEMENT SEPARATOR	(i.e. ":")
 an1    M     DATA ELEMENT SEPARATOR			(i.e. "+")
 an1    M     DECIMAL NOTATION					Comma or full stop
 an1    M     RELEASE INDICATOR					If not used, insert space character (i.e. "?")
 an1    M     Reserved for future				Insert space character use
 an1    M     SEGMENT TERMINATOR				(i.e. "'")
*/
// Returns:		True if the UNA line was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
vars
	startPos	: Integer;
	isValid		: Boolean;
	
begin
	startPos	:=	_message.pos(self.UNA, 1);
	
	if startPos = 0 then
		isValid	:=	false;
	endif;
	
	if startPos &lt;&gt; 1 or _message.length() &lt; 9 then
		// The UNA line must be at the very beginning of the message.
		isValid	:=	false;
	endif;
	
	if isValid then
		_itemSeparator	:=	_message[4:1];
		_fieldSeparator	:=	_message[5:1];
		_decimalChar	:=	_message[6:1];
		_escapeChar		:=	_message[7:1];
		_eolChar		:=	_message[9:1];
	else
		_itemSeparator	:=	":";
		_fieldSeparator	:=	"+";
		_decimalChar	:=	".";
		_escapeChar		:=	QuestionMark;
		_eolChar		:=	SingleQuote;
	endif;
epilog
	return isValid;
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
        <Parameter name="_fieldSeparator" type="String" usage="output"/>
        <Parameter name="_itemSeparator" type="String" usage="output"/>
        <Parameter name="_decimalChar" type="String" usage="output"/>
        <Parameter name="_escapeChar" type="String" usage="output"/>
        <Parameter name="_eolChar" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
