    <JadeMethod name="createTranslationProxies" id="154538e1-a57c-4a3f-91ed-d5c7fc6135fc">
        <updating/>
        <source>createTranslationProxies() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
25 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars

	locale : CM_Locale;
	rtnValue : Boolean;
	result : Integer;
	code :  String;
	pxyQuestion : CM_KioskTranslation;
	pxyErrorMsg : CM_KioskTranslation;
	
begin

	if self.myProxyKioskObject = null then
		if self.mode = self.MODE_ADDITIONAL then
			create self.myProxyKioskObject as CM_KioskAdditionalQuestion transient;
		else
			create self.myProxyKioskObject as CM_KioskPPEQuestion transient;
		endif;
	endif;
	
	if self.cmbLocale.listIndex &gt; 0 then
		locale := self.cmbLocale.itemObject[self.cmbLocale.listIndex].CM_Locale;
	endif;
	
	if locale = null then
		app.msgBox(app.getErrorString1(REQUIRED_FIELD, app.getErrorString(Info_Locale)), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	self.myProxyKioskObject.setMyKiosk(self.myKiosk);
	
	if self.mode = self.MODE_ADDITIONAL then
		self.myProxyKioskObject.CM_KioskAdditionalQuestion.setProxy(self.txtCode.text);	
		pxyQuestion := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allQuestions[locale.localeId];
		pxyErrorMsg := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allErrorMessages[locale.localeId];
		
	else
		self.myProxyKioskObject.CM_KioskPPEQuestion.setProxy(self.txtCode.text, self.txtImageId.text);	
		pxyQuestion := self.myProxyKioskObject.CM_KioskPPEQuestion.allQuestions[locale.localeId];
		pxyErrorMsg := self.myProxyKioskObject.CM_KioskPPEQuestion.allErrorMessages[locale.localeId];
		
	endif;
	
	if pxyQuestion = null then
		create pxyQuestion transient;
	endif;
	
	if pxyErrorMsg = null then
		create pxyErrorMsg transient;
	endif;
	
	pxyQuestion.setProxy(locale.localeId, self.txtQuestion.text);
	pxyErrorMsg.setProxy(locale.localeId, self.txtErrorMessage.text);
		
	if self.mode = self.MODE_ADDITIONAL then
		self.myProxyKioskObject.CM_KioskAdditionalQuestion.addTranslation(pxyQuestion, pxyErrorMsg);
	else
		self.myProxyKioskObject.CM_KioskPPEQuestion.addTranslation(pxyQuestion, pxyErrorMsg);
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3001d93f-19a6-4d9a-b7ba-9493b3e8acd7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars

begin
	
	if self.myProxyKioskObject &lt;&gt; null then
		delete self.myProxyKioskObject;
	endif;
	
	self.allCriteria.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNext" id="de3b8a89-8a39-4354-87c8-cfec1ca47673">
        <updating/>
        <source>doNext() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation

*/

vars
	locale : CM_Locale;
	rtnValue : Boolean;
	result : Integer;
	code :  String;
	proxiesCreated : Boolean;
	idx : Integer;
	
begin
	proxiesCreated := self.createTranslationProxies();
	
	if not proxiesCreated then
		return;
	endif;

	idx := self.cmbLocale.listIndex;
	
	if idx = self.cmbLocale.listCount then
		self.cmbLocale.listIndex := 1;
	else
		self.cmbLocale.listIndex := idx +1;
	endif;

	self.selectedLocale := self.cmbLocale.listObject.CM_Locale;
	self.loadTranslationFields();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="6eb987a0-3d92-4d11-b6f8-da030a0c84c0">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	locale : CM_Locale;
	completedOK : Boolean;
	result : Integer;
	code :  String;
	proxiesCreated : Boolean;
	
begin
	proxiesCreated := self.createTranslationProxies();
	
	if not proxiesCreated then
		return;
	endif;
	
	if self.mode = self.MODE_ADDITIONAL then
		completedOK := self.doSaveAdditionalQuestion();
	else
		completedOK := self.doSavePPEQuestion();
	endif;
	
	if not completedOK then
		return;
	endif;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAdditionalQuestion" id="06a6494b-4bfc-4b70-85e8-533fbc30a10d">
        <updating/>
        <source>doSaveAdditionalQuestion() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	completedOK : Boolean;
	result 		: Integer;
	allTransientCriteriaObj	: CMIF_Array;
	
begin

	if not self.myProxyKioskObject.isKindOf(CM_KioskAdditionalQuestion) then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_class_objects));
		return false;
	endif;
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF(allTransientCriteriaObj);
		
	while true do
		if self.myKioskObject = null then
			app.myTrxCA.trxCreateKioskAddQuestion(self.myProxyKioskObject.CM_KioskAdditionalQuestion, self.myKioskObject.CM_KioskAdditionalQuestion, allTransientCriteriaObj, app.myPassport);
			completedOK	:=	app.myPassport.trxCompletedOK;
			
		else
			app.myTrxUA.trxUpdateKioskAddQuestion(self.myProxyKioskObject.CM_KioskAdditionalQuestion, allTransientCriteriaObj, app.myPassport);
			completedOK	:=	app.myPassport.trxCompletedOK;
		endif;
			
		if (not completedOK) then
			result := app.showErrorWarningDialog('Additional Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		else
			self.clearErrorWarnings();
		endif;
		break;
	
	endwhile;
	
	if not completedOK then
		return false;
	endif;
	
	return true;
	
epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
		delete allTransientCriteriaObj;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePPEQuestion" id="84f9b538-f6d0-4422-a928-bc304b104806">
        <updating/>
        <source>doSavePPEQuestion() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	completedOK : Boolean;
	result : Integer;
	
begin
	if  self.myKioskObject &lt;&gt; null and not self.myProxyKioskObject.isKindOf(CM_KioskPPEQuestion) then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_class_objects));
		return false;
	endif;

	while true do
		if self.myKioskObject = null then	
			app.myTrxCA.trxCreateKioskPPEQuestion(self.myProxyKioskObject.CM_KioskPPEQuestion, self.myKioskObject, app.myPassport);
			completedOK	:=	app.myPassport.trxCompletedOK;
			
		else
			app.myTrxUA.trxUpdateKioskPPEQuestion(self.myProxyKioskObject.CM_KioskPPEQuestion, app.myPassport);
			completedOK	:=	app.myPassport.trxCompletedOK;
		endif;
			
		if (not completedOK) then
			result := app.showErrorWarningDialog('PPE Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		else
			self.clearErrorWarnings();
		endif;
		break;
	
	endwhile;
	
	if not completedOK then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCriteriaForm" id="d2370fd2-6d6c-424d-8385-0f152c049bda">
