C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D2050,,,,"&amp;ContainerId11&amp;",1,2200,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName&amp;"
