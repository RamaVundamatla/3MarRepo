    <JadeMethod name="canPlanOverstow" id="cf9bf2e2-439a-478d-b51a-084c70cd1b72">
        <source>canPlanOverstow( _moveItem: CM_Object; _otherLoc: CM_LocationsController input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	maxNumInStack : Integer;
	count : Integer;
	nextWc : CM_FlatcarWagonController;
	firstItemActualLength : Real;
	firstItem : CM_Object;
	firstItemLengthInUnits : Integer;
	moveItemActualLength : Real;
	moveItemLengthInUnits : Integer;
	foundA20: Boolean;
	obj : CM_Object;
	wle : CM_WorkListEntry;
	dummyWle : CM_WorkListEntry;
	stackHeight : Real;
	nextWcStackHeight : Real;

begin

	maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
	if maxNumInStack = 1 then
		// can't multi stack
		return false;
	endif;
	
	moveItemActualLength := self.myWagon.getActualLengthFor( _moveItem );
	moveItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( _moveItem ).Integer;
	firstItem := self.getFirstExistingItem( null, wle );
	
	if _otherLoc = null then
		// checking primary location
		nextWc := self;
		count := moveItemLengthInUnits - 1;
		stackHeight := self.getStackHeight;
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController.CM_FlatcarWagonController;
			if nextWc = null then 
				// not enough controllers...  
				return false;
			elseif nextWc.allTrackedItems.size &lt;&gt; self.allTrackedItems.size then
				// location I need is already occupied, not enough room  
				return false;
			endif;
			nextWcStackHeight := nextWc.getStackHeight; 
			if stackHeight &lt;&gt; nextWcStackHeight then
				return false;
			endif;
		endwhile;
	endif;
	
	if firstItem = null then
		// on the bottom row 
		nextWc := self;
		count := moveItemLengthInUnits - 1;
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController.CM_FlatcarWagonController;
			if nextWc = null then
				break;
			endif;
			if  nextWc.getFirstExistingItem( null, dummyWle ) &lt;&gt; null then
				// location I need is already occupied, not enough room  
				return false;
			endif;
		endwhile;
		
	else
		// on the top row
		firstItemActualLength := self.myWagon.getActualLengthFor( firstItem );
		
		if moveItemActualLength &lt;&gt; firstItemActualLength then
			// must be the same lengths on flatcars - ( use well car for large over small )
			return false;
		
//		elseif moveItemActualLength &lt; firstItemActualLength then
			// not allwed to stack small on large
//			return false;
			
		elseif _otherLoc = null then
			firstItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( firstItem ).Integer;
			if firstItem.isKindOf(CM_TrackedItem) and not firstItem.CM_TrackedItem.isRRP and firstItem.CM_TrackedItem.myPrimaryActualLocation &lt;&gt; self then
				// trying to stagger stack the containers  
				return false;
			
			elseif wle &lt;&gt; null and self.myWagon.getFirstLocationFor(wle) &lt;&gt; self then
				// trying to stagger stack the iso type / isogroup  
				return false;
				
			elseif firstItemLengthInUnits = 2  // bottom one is a 20
			and moveItemLengthInUnits &lt;&gt; 2  // top one is bigger
			then
				// another way of trying to stagger stack the containers  i.e. a 40(or larger) over a 20 then a 40..
				// But 40 over 2 x 20s is allowed.
				nextWc := self;
				while true do
					nextWc := nextWc.myNextController.CM_FlatcarWagonController;
					if nextWc = null then
						break;
					endif;
					obj := nextWc.getFirstExistingItem( null, dummyWle );
					if obj &lt;&gt; firstItem then
						if obj &lt;&gt; null and self.myWagon.getLengthInUnitsForWagon( obj ) = 2 then
							foundA20 := true;
							break;
						else
							return false;  // second item is not a 20
						endif;
					endif;
				endwhile;
				if not foundA20 then
					// stacking over a gap
					return false;
				endif;
			endif;
		endif;
		
	endif;
		
	return true;

epilog

end;</source>
        <Parameter name="_moveItem" type="CM_Object"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColIdForJMT" id="2d2f211e-e57e-41fd-a61d-3c2d24ca2357">
        <source>getColIdForJMT( _ti : CM_TrackedItem ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	lWagon : CM_Wagon;
	idx : Integer;

begin

	lWagon := self.myWagon;
	idx := lWagon.allLocationsControllersArray.indexOf(self);
	if idx &lt;= lWagon.myWagonClass.locationIds.size then
		return lWagon.myWagonClass.locationIds[idx];
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColIdForUPSP" id="7d1162c1-d1dd-4e91-9fc4-f109555fcb2c">
        <source>getColIdForUPSP(  _ti : CM_TrackedItem ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	wcIndex : Integer;
	wc : CM_FlatcarWagonController;
	lc : CM_LocationsController;
	index : Integer;
	tiArray : CM_TISet;
	heightIndex : Integer;
	tmpWc : CM_WagonController;
	tmpTi : CM_TrackedItem;
	lastTi : CM_TrackedItem;
	spaceCount : Integer;
	count : Integer;
	wcq : CM_FlatcarWagonController;
	wcp : CM_FlatcarWagonController;
	fm : CM_FutureMove;
	
begin

	create tiArray transient;
	//get the count of cargo from front of wagon to this cargo item / position at the same height
	// and including contiguous spaces
	if _ti = null then
		wc := self;
		wcq := wc;
		heightIndex := wc.allTrackedItems.size + 1;
	else
		lc := _ti.myPrimaryActualLocation;
		if lc &lt;&gt; null and lc.isKindOf( CM_FlatcarWagonController ) and lc.CM_FlatcarWagonController = self then
			wc := lc.CM_FlatcarWagonController;	
			heightIndex := wc.allTrackedItems.indexOf( _ti );
		endif;
		if wc = null then
			lc := _ti.myPrimaryQueuedLocation;
			if lc &lt;&gt; null and lc.isKindOf( CM_FlatcarWagonController ) and lc.CM_FlatcarWagonController = self then
				wcq := lc.CM_FlatcarWagonController;
				wc := lc.CM_FlatcarWagonController;
				heightIndex := wc.allTrackedItems.size + wc.allQueuedFutureMoves.getIndexOfTI( _ti );
			endif;
			//29 May 2015	NDL	Par 36169
			if self.allPlannedFutureMoves.containsTI( _ti ) then
				wcp := self;
				wc := self;
				heightIndex := wc.allTrackedItems.size + wc.allPlannedFutureMoves.getIndexOfTI( _ti );
			endif;
		endif;
		count := 1;
	endif;
	
	if wc &lt;&gt; null and heightIndex &gt; 0 then
		
		wcIndex := wc.myWagon.allLocationsControllersArray.indexOf(wc);
		foreach index in 1 to wc.myWagon.allLocationsControllersArray.size do
			lastTi := tmpTi;
			tmpWc := wc.myWagon.allLocationsControllersArray[index];
			tmpTi := null;
			if tmpWc.allTrackedItems.size &gt;= heightIndex then
				tmpTi := tmpWc.allTrackedItems[heightIndex];
			endif;
			
			if index = wcIndex then
				if _ti = null then
					if index = 1 then
						spaceCount := 1;
					elseif lastTi &lt;&gt; tmpTi then
						count := count + 1;
					endif;
				endif;
				break;
			endif;
			
			//if wcq &lt;&gt; null and tmpTi = null then
			if tmpTi = null then
				if wcq &lt;&gt; null then
					fm := tmpWc.allQueuedFutureMoves.first;
					if fm &lt;&gt; null and fm.isKindOf(CM_FutureMoveQueued) then
						tmpTi := fm.CM_FutureMoveQueued.myTrackedItem;
					endif;
				elseif wcp &lt;&gt; null then	//29 May 2015	NDL	Par 36169
					fm := tmpWc.allPlannedFutureMoves.first;
					if fm &lt;&gt; null and fm.isKindOf(CM_FutureMovePlanned) then
						tmpTi := fm.CM_FutureMovePlanned.myTrackedItem;
					endif;
				endif;
			endif;
			if tmpTi &lt;&gt; null then
				tiArray.addNoDuplicates( tmpTi, false );
			else
				if lastTi &lt;&gt; tmpTi then
				// now a space and wasn't before.
					spaceCount := spaceCount + 1;
				elseif tmpTi = null and index = 1 then
					spaceCount := 1;
				endif;
			endif;
		endforeach;
		
		if _ti &lt;&gt; null then
			if tiArray.includes( _ti ) then
				count := count - 1;
			endif;
		endif;
		
		count := count + spaceCount + tiArray.size;
		
		return count.String;
	
	endif;
	
	return null;

epilog

	delete tiArray;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeckHeight" id="06065e91-3c58-496a-beac-4e0df2f61db7">
        <source>getDeckHeight(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

begin

	if self.myWagon = null then
		return 0;
	endif;

	if self.myWagon.myWagonClass &lt;&gt; null then
		return self.myWagon.myWagonClass.deckHeight;
	elseif self.myWagon.myWagonMaster &lt;&gt; null and self.myWagon.myWagonMaster.myWagonClass &lt;&gt; null then
		return self.myWagon.myWagonMaster.myWagonClass.deckHeight;
	else	
		return 0;
	endif;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isFlatcarCont" id="75d987a9-587b-493f-8ed8-8df4066d32ab">
        <source>isFlatcarCont(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveOverstow" id="cb72befb-1ab7-4c09-b78c-e4c52110efcc">
        <source>validateMoveOverstow( control: CMIF_MoveController input; _moveTI : CM_TrackedItem; _otherLoc: CM_LocationsController input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/
vars

	maxNumInStack : Integer;
	count : Integer;
	nextWc : CM_FlatcarWagonController;
	firstItemActualLength : Real;
	firstItem : CM_Object;
	firstItemLengthInUnits : Integer;
	moveItemActualLength : Real;
	moveItemLengthInUnits : Integer;
	foundA20: Boolean;
	obj : CM_Object;
	dummyWle : CM_WorkListEntry;
	stackHeight : Real;
	actualTIs,
	nextActualTIs  : CM_TIArray;
begin

	maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
	if maxNumInStack = 1 then
		// can't multi stack
		return false;
	endif;
	
	//epr par 37324 22/1/16
	create actualTIs transient;
	self.getActualTIsForValidateMove(control,actualTIs);
		
	create nextActualTIs transient;
	
	moveItemActualLength := self.myWagon.getActualLengthFor( _moveTI );
	moveItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( _moveTI ).Integer;
	firstItem := self.getFirstExistingItem( control, dummyWle );
	
	if _otherLoc = null then
		// checking primary location
		nextWc := self;
		count := moveItemLengthInUnits - 1;
		stackHeight := self.getStackHeight();
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController.CM_FlatcarWagonController;
			nextActualTIs.clear;
			if nextWc &lt;&gt; null then
				nextWc.getActualTIsForValidateMove(control,nextActualTIs);
			endif;
			if nextWc = null then 
				app.raiseCMException2(No_room_start_position, _moveTI.id, self.getFullId, null, _moveTI);
					return false;
			elseif nextActualTIs.size &lt;&gt; actualTIs.size  then
				//stacked to different heights
				app.raiseCMException(Not_place_cargo_where_overs_st, null, _moveTI);
				return false;
			elseif stackHeight &lt;&gt; nextWc.getStackHeight then
				//stacked to different heights
				app.raiseCMException(Not_place_cargo_where_overs_st, null, _moveTI);
				return false;
			endif;
			
		endwhile;
	endif;
	
	if firstItem = null then
		// on the bottom row 
		nextWc := self;
		count := moveItemLengthInUnits - 1;
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController.CM_FlatcarWagonController;
			if nextWc.getFirstExistingItem( control, dummyWle ) &lt;&gt; null then
				// location I need is already occupied, not enough room  
				app.raiseCMException1(Not_place_cargo_where_overs_st, _moveTI.id, null, _moveTI);
				return false;
			endif;
		endwhile;
		
	else
		if firstItem = _moveTI then
			return true;
		endif;
		
		// on the top row
		firstItemActualLength := self.myWagon.getActualLengthFor( firstItem );
		
		if moveItemActualLength &lt;&gt; firstItemActualLength then
			// must be the same lengths on flatcars - ( use well car for large over small )
			app.raiseCMException(Not_stagger_stack_cargo, null, _moveTI);
			return false;
		
//		elseif moveItemActualLength &lt; firstItemActualLength then
			// not allowed to stack small on large
//			app.raiseCMException2(Not_stack_smallOnLarge, moveItemActualLength.String, firstItemActualLength.String, null, _moveTI);
//			return false;
			
		elseif _otherLoc = null then
			firstItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( firstItem ).Integer;
			if firstItem.isKindOf(CM_TrackedItem) and not firstItem.CM_TrackedItem.isRRP and firstItem.CM_TrackedItem.myPrimaryActualLocation &lt;&gt; self then
				// trying to stagger stack the containers 
				app.raiseCMException(Not_stagger_stack_cargo, null, _moveTI);
				return false;
			
			elseif firstItemLengthInUnits = 2  // bottom one is a 20
			and moveItemLengthInUnits &lt;&gt; 2  // top one is bigger
			then
				// another way of trying to stagger stack the containers  i.e. a 40(or larger) over a 20 then a 40..
				// But 40 over 2 x 20s is allowed.
				nextWc := self;
				while true do
					nextWc := nextWc.myNextController.CM_FlatcarWagonController;
					if nextWc = null then
						break;
					endif;
					obj := nextWc.getFirstExistingItem( control, dummyWle );
					if obj &lt;&gt; firstItem then
						if obj &lt;&gt; null and self.myWagon.getLengthInUnitsForWagon( obj ) = 2 then
							foundA20 := true;
							break;
						else
							app.raiseCMException(Not_stagger_stack_cargo, null, _moveTI);
							return false;  // second item is not a 20
						endif;
					endif;
				endwhile;
				if not foundA20 then
					// stacking over a gap
					app.raiseCMException1(Not_stack_overgap, _moveTI.id, null, _moveTI);
					return false;
				endif;
			endif;
		endif;
		
	endif;
		
	return true;

epilog
	delete actualTIs;
	delete nextActualTIs;
end;
</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
