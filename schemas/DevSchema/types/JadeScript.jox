    <JadeMethod name="zGetParmForMethod" id="4ac3ef0a-dd3d-47a8-934e-16aaba8d996e">
        <source>zGetParmForMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2024		navma1	Initial creation

*/

vars
	targetMth			: Method;
	parmCol : ParameterColl;
	parm : Parameter;
	meths :MethodNDict;
begin
	create  meths transient;
	self.class.getMethods(meths); 
	//	parmCol :=targetMth.getParameters();
	write parmCol.size;
epilog
	delete meths;
	end;</source>
    </JadeMethod>
    <JadeMethod name="zmEDILockTester" id="f856783b-af8c-4f74-aa49-e0b92b688413">
        <source>zmEDILockTester();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2019	jlgzm1	Initial creation

*/
vars
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["T02"];
	
	beginTransaction;
	app.msgBox("Lock byTypeDate", "lock", 0);
	self.exclusiveLock(terminal.allTITransactionsByTypeDate);
	app.msgBox("Lock AllTITransactions", "lock", 0);
	self.exclusiveLock(terminal.allTITransactions);
	commitTransaction;
epilog
	self.unlock(terminal.allTITransactionsByTypeDate);
	self.unlock(terminal.allTITransactions);

end;</source>
    </JadeMethod>
    <JadeMethod name="zmEDILockTester2" id="7fff93e6-5239-4aa1-a439-74f5d66ed4b8">
        <source>zmEDILockTester2();
/*

Purpose:			Locks prenoted cargo set, to cause a lock error

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2019	jlgzm1	Initial creation

*/
vars
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["T02"];//MAKE SURE TO SET THIS TO THE RIGHT TERMINAL
	
	app.msgBox("Lock", "lock", 0);
	self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);
	//self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);
	//self.exclusiveLock(terminal.allTbaTIsByCargoTypeId);
	//self.exclusiveLock(terminal.allCargoGroupsByCargoTypeId);
	app.msgBox("Unlock", "unlock", 0);
epilog
	self.unlock(terminal.allNotifiedTIsByCargoTypeId);
	//self.unlock(terminal.allTITransactionsByTypeDate);
	//self.unlock(terminal.allTITransactions);

end;</source>
    </JadeMethod>
    <JadeMethod name="zmFindCharges" id="353d6e4a-fd3b-46ac-8ae0-982b81af31bf">
        <source>zmFindCharges();
/*

Purpose:			tests CM_Charges with no invoiceLine don't cause a 1090 

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2018	jlgzm1	Initial creation

*/

vars

	charge: CM_Charge;
	count: Integer;

begin
	foreach charge in CM_Charge.instances do
		if charge.invoiceLine = null then
			write  charge.total.String; //try to cause 1090
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="zmTestWLEAssignTI" id="6875d935-9075-4bdb-aef7-f9de36bb6369">
        <source>zmTestWLEAssignTI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2018	jlgzm1	Initial creation

*/

vars
	wle	: CM_YardWLE;
	count : Integer;
	array : ObjectArray;
	moveController : CMIF_MoveController;
	
begin
	app.initialize();
	/*
	create array transient;
	foreach wle in CM_YardWLE.instances where wle.myRequest.isKindOf(CM_DeliveryRequest) and wle.myTrackedItem &lt;&gt; null and wle.job.isKindOf(CM_RoadJob) and not wle.myTrackedItem.isEmpty do
		count := count + 1;
		array.add(wle);
	endforeach;
	array.inspectModal;
	*/
	
	wle := "2425.1072587".asOid.CM_YardWLE; //may need to use a different tracked item
	
	beginTransaction;
	wle.setStatus(WLE_UNACTIONED);
	commitTransaction;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyTrackedItem(wle.myTrackedItem);
	moveController.isReplanAnExport := false;

	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	

	
epilog
	delete moveController;
	abortTransaction;
	delete array;
end;</source>
    </JadeMethod>
</Class>
