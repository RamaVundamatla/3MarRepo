    <JadeMethod name="setForm" id="6a916b9e-01da-4f19-98ce-132b48e19e61">
        <updating/>
        <source>setForm(pTheForm:Form) updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Updates the Form Interface's reference to the form it interfaces to.
//
// Parameters:	pTheForm - The form object that is being interfaced to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myForm &lt;&gt; pTheForm then
		self.myForm	:=	pTheForm;
	endif;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
    </JadeMethod>
