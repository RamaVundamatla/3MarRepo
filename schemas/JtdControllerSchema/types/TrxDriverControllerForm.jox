    <JadeMethod name="setTableColWidthsFromIntArray" id="4c944dca-dff4-4d4e-94a3-26ab7c86cb45">
        <source>setTableColWidthsFromIntArray(tbl : Table; ia : IntegerArray) protected;

vars
	n, sz : Integer;
	
begin
	if tbl = null or ia = null then
		return;
	endif;
	
	sz := ia.size;
	
	foreach n in 1 to tbl.columns do
		if n &gt; sz then
			break;
		endif;
		
		tbl.columnWidth[n] := ia[n];
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table"/>
        <Parameter name="ia" type="IntegerArray"/>
    </JadeMethod>
