<GUIClass name="CMUI_PrintPreviewFind" id="2abfbbae-351f-4116-b7cd-e2a4985d35ab">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cMUI_Label3" id="1b856d29-7499-467c-b1d2-7c152c1e2ee2">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cMUI_Label3_1" id="2843bee5-47eb-4481-9f14-06e6cbb9cc35">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="chk_CaseSensitiv" id="710a5449-39c7-4238-8431-26637222a734">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="chk_WholeWords" id="4ade24dc-555d-4fe7-85bb-87805b290602">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="printPreviewForm" id="dcaa989e-7252-48a2-9e10-449ee406c93f">
        <embedded/>
        <type name="CMUI_PrintPreview"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txt_StartPage" id="75d3c5a5-cfde-406e-91a4-040887187873">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txt_ToFind" id="53766dc1-c5fe-43f1-acbb-edf055cf96bc">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="0e1dfa2d-6849-4973-80f5-970606a95aea">
        <updating/>
        <source>doOK() updating;
/*
------------------------------------------------------------------------
Created:			27 May 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	printer : Printer;
	page    : Integer;
	str : String;
begin
	page := txt_StartPage.text.Integer;
	
	if page &gt; self.printPreviewForm.aMyJadeReport.pageCount then
		str := app.getErrorString1(FindStringPageError, self.printPreviewForm.aMyJadeReport.pageCount.String);
		app.msgBox(str, app.getErrorString(Print_Preview_Find_Caption), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if txt_ToFind.text.trimBlanks = null then
		str := app.getErrorString2(ERR_INVALID_VALUE, 'a search string', '&lt;empty&gt;' );
		app.msgBox(str, app.getErrorString(Print_Preview_Find_Caption), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		// save parameters for the find next call
	self.printPreviewForm.aV_findString := txt_ToFind.text;
	self.printPreviewForm.aV_findNextPage := page;
	self.printPreviewForm.aV_findNextPagePos := 0;
	self.printPreviewForm.aV_findNextCharPos := 0;
	self.printPreviewForm.aV_findCased := self.chk_CaseSensitiv.value;
	self.printPreviewForm.aV_findWholeWords := chk_WholeWords.value;
	
	if self.printPreviewForm.findString(true, false) then
		unloadForm;	// found one
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="adec330f-4e3a-421a-b69b-f23a445788fd">
        <updating/>
        <source>setupForm() updating;
/*
------------------------------------------------------------------------
Created:			28 May 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	inheritMethod();
	centreWindow;
	
	self.txt_StartPage.text  := printPreviewForm.aCurrentPage.String;
	self.txt_ToFind.text := printPreviewForm.aV_findString;
	self.chk_CaseSensitiv.value  := printPreviewForm.aV_findCased;
	self.chk_WholeWords.value  := printPreviewForm.aV_findWholeWords;
//	self.btnOk.enabled := tbFindText.text.trimBlanks &lt;&gt; null;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0e0f61f3-542a-460d-9c58-9d9c9db84a0f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007952, locale);
	cMUI_Label3.translateCaption(Xlat_0000671, locale);
	cMUI_Label3_1.translateCaption(Xlat_0000696, locale);
	chk_CaseSensitiv.translateCaption(Xlat_0000666, locale);
	chk_WholeWords.translateCaption(Xlat_0000670, locale);
end;</source>
    </JadeMethod>
</GUIClass>
