    <JadeMethod name="translateForm" id="aff94dd2-c68a-4c84-9a6f-752069bc08d1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:39:24.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019857, locale);
	btnExtractCode.translateCaption(Xlat_0023229, locale);
	btnImport.translateCaption(Xlat_0019859, locale);
	btnSaveSelection.translateCaption(Xlat_0019860, locale);
	chkSelectAll.translateCaption(Xlat_0019861, locale);
	lblFormat.translateCaption(Xlat_0019862, locale);
	lblLog.translateCaption(Xlat_0019863, locale);
	lblMain.translateCaption(Xlat_0019864, locale);
	lblNoid.translateCaption(Xlat_0019865, locale);
	shtClasses.translateCaption(Xlat_0019866, locale);
	shtExtract.translateCaption(Xlat_0019867, locale);
	shtImport.translateCaption(Xlat_0019868, locale);
	shtObjects.translateCaption(Xlat_0019869, locale);
end;</source>
    </JadeMethod>
