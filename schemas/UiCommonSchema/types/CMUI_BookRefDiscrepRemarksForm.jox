<GUIClass name="CMUI_BookRefDiscrepRemarksForm" id="b3b69f38-e01f-4a43-b5b5-73e5d10060a6">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkClosed" id="9b4f3158-d796-4bd7-aaf3-146e53f3c7d3">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblRemarks" id="6beba81a-f0af-41f8-99a7-ab7ab662e97c">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCMEVT_BookingRefDiscrep" id="dbced97f-8a38-49af-acce-37f91c8d0b0f">
        <embedded/>
        <type name="CMEVT_BookingRefDiscrep"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtRemarks" id="58bc5315-1e2f-4ff5-bb56-a02315f6e768">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="4c7cc1c2-c5ee-4bac-854b-4dfc37b8560b">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation

*/

vars

begin
	self.permissionView  := PmAdmBookingRefDiscrepView;
	self.permissionMaint := PmAdmBookingRefDiscrepMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="d3107977-a78c-46c6-a601-62564f886d9d">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	
begin

	app.myTrxUA.trxUpdateBookingRefRemarks(myCMEVT_BookingRefDiscrep, txtRemarks.text, chkClosed.value, app.myPassport);
	

	if app.myPassport.noErrors then
		inheritMethod();
	endif;

epilog

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCMEVT_BookingRefDiscrep" id="dea91f02-9284-46d2-afd6-9b119bdc39c8">
        <updating/>
        <source>setMyCMEVT_BookingRefDiscrep( _bookingRefDiscrep : CMEVT_BookingRefDiscrep) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation

*/

vars

begin
	self.myCMEVT_BookingRefDiscrep := _bookingRefDiscrep;
	if _bookingRefDiscrep &lt;&gt; null then
		txtRemarks.text := _bookingRefDiscrep.remarks;
		chkClosed.value := _bookingRefDiscrep.isClosed;
	else
		txtRemarks.text := null;
		chkClosed.value := false;
	endif;
epilog

end;</source>
        <Parameter name="_bookingRefDiscrep" type="CMEVT_BookingRefDiscrep"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b073808f-ce97-4759-b0c9-29b1dee9c063">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation

*/

vars

begin

	//app.hideDebug := true;
	self.handleMenusForModalDisplay();

	inheritMethod();
	
	if self.myCMEVT_BookingRefDiscrep = null then
		self.unloadForm;
		return;
	endif;
	
	btnOk.caption := app.getErrorString(SAVE_THAT_LADY_YO);
	
	self.setCaption("Booking Discrepancy Remarks : " &amp; myCMEVT_BookingRefDiscrep.getId);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="eb724141-c3aa-4f31-89e5-00869e17572a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017256, locale);
	chkClosed.translateCaption(Xlat_0011823, locale);
	lblRemarks.translateCaption(Xlat_0011824, locale);
end;</source>
    </JadeMethod>
</GUIClass>
