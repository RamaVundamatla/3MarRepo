begin

	ediData := '&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;
&lt;' &amp; TagCargoGroupAssignments &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_DELETE &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCgaId &amp; '&gt;' &amp; _cargoGroupAssignBaseId &amp; '4&lt;/' &amp; TagCgaId &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
&lt;/' &amp; TagCargoGroupAssignments &amp; '&gt;';
	
	return ediData;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoGroupAssignBaseId" type="String"/>
        <Parameter name="_cargoBaseId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tAddDuplicateCargoGroup" id="cfb97aa8-4097-4695-86dc-626fd70fdf2d">
        <updating/>
        <source>tAddDuplicateCargoGroup()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jun 2025 navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev

*/
constants
	CG_ID1 = "UTCG30625.01";	
vars
	cg 				 : CM_CargoGroup;
	allCargoToAssign : CM_TISet;
	ti 				 : CM_TrackedItem;
	locations 		 : CM_LCArray;
begin
	
	create allCargoToAssign transient;
	self.deleteCargoGroup(CG_ID1);
	cg := self.addCargoGroup( CG_ID1, allCargoToAssign );
	self.assertNotNullMsg(cg, "Cargo Group is has not been created ");
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Already_exists_cargo_group);
	self.expectedTrxErrors.add(Already_exists_cg_operator);
	
	cg := self.addCargoGroup( CG_ID1, allCargoToAssign );
	assertNull(cg);
	
	self.assertIncludesExceptions();

epilog
	delete allCargoToAssign;
end;</source>
    </JadeMethod>
    <JadeMethod name="tArchiveCargoGroup" id="e6f086f6-434b-423d-9b5e-0e60c2e30de8">
        <source>tArchiveCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation	Par 36338
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	term : CM_Terminal;
	now : TimeStamp;
	yesterday : TimeStamp;
	iter : Iterator;
	ti : CM_TrackedItem;
	cg : CM_CargoGroup;
	preCount : Integer;
	archivePotentialCount : Integer;
	afterCount : Integer;
	agent : CM_DBPurgeAgent;

begin

	term := self.getTerminal;
	now := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	yesterday.setDate( now.Date - 1);
	yesterday.setTime( now.Time);
	
	preCount := term.allCargoGroupsByIdCargoType.size;
	iter := term.allCargoGroupsByIdCargoType.createIterator;
	while iter.next( ti ) do
		if ti.releasedDT &lt;&gt; null and ti.releasedDT.Date.isValid then
			cg := ti.CM_CargoGroup;
			if cg.releasedDT &lt; yesterday then
				self.assertTrueMsg( not cg.hasOnsiteAssignedCargo, "Cargo Group [" &amp; cg.id &amp; "] has 'releaseDt' set but has on-site cargo");
				archivePotentialCount := archivePotentialCount + 1;
			endif;
		endif;
	endwhile;
	
	if archivePotentialCount &lt; 1 then
		// none hanging around to archive.
		return;
	endif;

	create agent transient;
	app.myTrxDA.trxDeleteDBPurgeCargoGroups( term, yesterday, agent, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrors, "Cargo Group archive error. = " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	afterCount := term.allCargoGroupsByIdCargoType.size;
	self.assertTrueMsg( preCount = ( archivePotentialCount + afterCount ), "Cargo Group archive expected to archive '"
															&amp; archivePotentialCount.String &amp; "' Cargo Group(s), did '"
															&amp; (preCount - archivePotentialCount).Integer.String&amp; "'.");

epilog

	delete agent;
	delete iter;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCargoGroupAdditionalTests" id="e11acad7-fa23-4523-a1ca-3355e9dbf51e">
        <source>tCargoGroupAdditionalTests();

/*

Purpose:		Additional tests for Cargo Group	

Date			Who		Reason
10/05/2016		cnwmh5	Initial creation

*/

constants

	CargoGroupAssignId : String = "UTCGA01";
	
	TagCargoGroupAssignments : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignments;
	TagCargoGroupAssignment : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignment;
	TagAction : String = CM_EDIFileTypeXMLCargoGrpAssig.TagAction;
	TagCargoGroupAssignmentId : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignmentId;
	TagSelectableCargoIds : String = CM_EDIFileTypeXMLCargoGrpAssig.TagSelectableCargoIds;
	TagCargoId : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoId;
	TagCargoGroup : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroup;
	TagCargoGroupId : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupId;
	TagDefaultLocation : String = CM_EDIFileTypeXMLCargoGrpAssig.TagDefaultLocation;
	TagMinWeight : String = CM_EDIFileTypeXMLCargoGrpAssig.TagMinWeight;
	TagMaxWeight : String = CM_EDIFileTypeXMLCargoGrpAssig.TagMaxWeight;
	TagCargoType : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoType;
	TagOperator : String = CM_EDIFileTypeXMLCargoGrpAssig.TagOperator;
	TagPreAssignedCargoIds : String = CM_EDIFileTypeXMLCargoGrpAssig.TagPreAssignedCargoIds;
	TagCargoGroupRemarks : String = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupRemarks;

vars

	bs1						: CM_BlockStack;
	gbs1					: CM_ForkLiftStack;
	operator1				: CM_Operator;
	operator2				: CM_Operator;
	cg1						: CM_CargoGroup;
	ti						: CM_TrackedItem;
	transaction				: CM_TITransaction;
	vvr						: CM_VehicleVisitRecord;
	
	tiArray					: CM_TIArray;
	tiArray2				: CM_TIArray;
	allCargoToAssign		: CM_TISet;
	
	iter					: Iterator;
	
	txnCount				: Integer;
	index					: Integer;
	
	ediData : String;
	ediFile : CM_EDIFile;
	
	term : CM_Terminal;
	cargoGroupCargoType : CM_CargoType;
	cgAssign : CM_CargoGroupAssignment;
	
begin

	

	// initialisations
	self.setTerminalConfig(PrenoteUniqBooking, false);
	create tiArray transient;
	create tiArray2 transient;
	create allCargoToAssign transient;
	
	operator1 := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator1);
	
	operator2 := app.myRoot.allOperators["MSC"];
	self.assertNotNull(operator2);
	
	// Cargo Groups multiple locations
	bs1 := self.addBlockStack("MHBS89", 99, null);
	self.assertNotNull(bs1);
	
	gbs1 := self.addForkLiftStack("MHGB89", 6, 6, 4);
	self.assertNotNull(gbs1);
		
	foreach index in 1 to 3 step 1 do
		ti := self.addContainerAtLocation("MDHCONT10" &amp; index.padLeadingWith("0", 2), operator1, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs1);
		self.deleteStops(ti);
		allCargoToAssign.add(ti);
	endforeach;
	
	self.deleteCargoGroup("UTMHCG1");
	self.deleteCargoGroup("UTMHCG2");
	
	//create cargo group assignment - TFS 49789
	term := self.getTerminal;
	self.deleteCargoGroupAassignment( term, CargoGroupAssignId );
	cargoGroupCargoType := self.getTerminal.getDefaultCargoGroupCargoType();
	ediData := '&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;
&lt;' &amp; TagCargoGroupAssignments &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; CargoGroupAssignId &amp; '&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
		&lt;' &amp; TagSelectableCargoIds &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '01&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '02&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '03&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '04&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '05&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '06&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '07&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '08&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '09&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '10&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; "MDHCONT10" &amp; '11&lt;/' &amp; TagCargoId &amp; '&gt;
		&lt;/' &amp; TagSelectableCargoIds &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; "UTMHCG1" &amp; '&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; bs1.id &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;10&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;45000&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoGroupCargoType.abbreviation &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operator2.code &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
&lt;/' &amp; TagCargoGroupAssignments &amp; '&gt;';

	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, method.name, EDIFileType_XML_CargoGrpAssign, true, true, false, false, null);
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignId );
	self.assertTrueMsg( cgAssign &lt;&gt; null, "Should have created Cargo Group Assignment");
	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 1");
	
	// create cargo group with operator2 as the operator
	
	self.opts.purge();
	self.opts.addAssoc("Operator", operator2);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Cargo_Group_Oper_diff);
	cg1 := self.addCargoGroup("UTMHCG2", allCargoToAssign);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(cg1);
	self.assertTrueMsg((cg1.allAssignedTrackedItems.size = 0), "Cargo group has incorrect number of tis");
	
	foreach ti in allCargoToAssign do
		self.updateTI(ti);
	endforeach;
	
	foreach index in 4 to 6 step 1 do
		ti := self.addContainerAtLocation("MDHCONT10" &amp; index.padLeadingWith("0", 2), operator2, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs1);
		self.deleteStops(ti);
		allCargoToAssign.add(ti);
	endforeach;	
	
	self.deleteCargoGroup("UTMHCG2");
	self.clearExpectedTrxErrors();
	self.opts.purge();
	self.opts.addAssoc("Operator", operator2);		
//	cg1 := self.addCargoGroup("UTMHCG1", allCargoToAssign);
	cg1 := term.allCargoGroupsByIdCargoType.getAtKey( "UTMHCG1", cargoGroupCargoType.id ).CM_CargoGroup;
	foreach ti in allCargoToAssign do
		app.myTrxUA.trxCargoGroupAddTi(cg1, ti, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	self.assertNotNull(cg1);
	self.assertNull(cg1.locationId);
	self.assertEqualMsg(cg1.allAssignedTrackedItems.size, 6, "Cargo Group (" &amp; cg1.id &amp; ") has " &amp; cg1.allAssignedTrackedItems.size.String &amp; 
		" items rather than 6");
	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 2");
	
	// check cargo for assigned transaction
	foreach ti in allCargoToAssign do
		if not ti.allTransactions.last.isKindOf(CM_GroupAssign) then
			self.assertTrueMsg(false, "Tracked Item (" &amp; ti.id &amp; ") does not have CM_GroupAssign as it's last transaction");
		endif;
		self.deleteStops(ti);
	endforeach;
	
	// check cargo group has 6 CM_GroupAssign transactions - one for each item
	foreach transaction in cg1.allTransactions do
		if transaction.isKindOf(CM_GroupAssign) then
			txnCount := txnCount + 1;
		endif;
	endforeach;
	self.assertEqualMsg(txnCount, 6, "Cargo Group only has " &amp; txnCount.String &amp; " CM_GroupAssign transactions rather than 6");
	
	// remove the first cargo, check for unassigned txns and add back
	ti := allCargoToAssign.first;
	beginTransaction;
	cg1.removeAssignedCargo(ti, app.myPassport);
	commitTransaction;
	if not ti.allTransactions.last.isKindOf(CM_GroupUnassign) then
		self.assertTrueMsg(false, "Tracked Item (" &amp; ti.id &amp; ") does not have CM_GroupUnassign as it's last transaction");
	endif;
	if not cg1.allTransactions.last.isKindOf(CM_GroupUnassign) then
		self.assertTrueMsg(false, "Cargo Group (" &amp; cg1.id &amp; ") does not have CM_GroupUnassign as it's last transaction");
	endif;
//	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 3");
	
	// Gate out cargo item
	iter := cg1.allAssignedTrackedItems.createIterator;
	index := 0;
	while iter.next(ti) do
		index := index + 1;
		self.deleteVehicle("UTMHTI" &amp; index.String);
		vvr := self.gateOutContainer("UTMHTI" &amp; index.String, "", "", ti.CM_Container, true, 
			self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), null);
		self.assertNotNull(vvr);
		self.workVehicle(vvr);
		self.deleteStops(ti);
		self.roadExit(vvr);
	endwhile;
	
	self.assertEqualMsg(cg1.allAssignedTrackedItems.size, 5, "Gated out all items, cargo group has " &amp; 
		cg1.allAssignedTrackedItems.size.String &amp; " rather than 5");
	self.assertNotEqualMsg(cg1.releasedDT, null, "Final Cargo Released not set");
	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 4");
	
	// add more cargo
	allCargoToAssign.clear();
	foreach index in 7 to 9 step 1 do
		ti := self.addContainerAtLocation("MDHCONT10" &amp; index.padLeadingWith("0", 2), operator2, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs1);
		self.deleteStops(ti);
		allCargoToAssign.add(ti);
	endforeach;	
		
	foreach ti in allCargoToAssign do
		app.myTrxUA.trxCargoGroupAddTi(cg1, ti, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	self.assertEqualMsg(cg1.allAssignedTrackedItems.size, 8, "3 items have been assigned to the cargo group (" &amp; 
		cg1.id &amp; ") but only has " &amp; cg1.allAssignedTrackedItems.size.String &amp; " rather than 8");
	self.assertEqualMsg(cg1.releasedDT, null, "Final Cargo Released should be null");
	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 5");
	
	// mark the group as complete
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Total_weight_exceed_maximu_wei);
	app.myTrxUA.trxCargoGroupComplete(cg1, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 6");
	
	self.clearExpectedTrxErrors();
	beginTransaction;
	cg1.setPropertyValue("minWeight", "10.00".Decimal);
	cg1.setPropertyValue("maxWeight", "45000.00".Decimal);
	commitTransaction;
	app.myTrxUA.trxCargoGroupComplete(cg1, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
//	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 7");
	
	if not cg1.allTransactions.last.isKindOf(CM_GroupComplete) then
		self.assertTrueMsg(false, "Cargo Group (" &amp; cg1.id &amp; ") does not have CM_GroupComplete as it's last transaction");
	endif;
	
	// try to assign more cargo
	allCargoToAssign.clear();
	foreach index in 10 to 11 step 1 do
		ti := self.addContainerAtLocation("MDHCONT10" &amp; index.padLeadingWith("0", 2), operator2, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs1);
		self.deleteStops(ti);
		allCargoToAssign.add(ti);
	endforeach;	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Cargo_group_already_complet);
	foreach ti in allCargoToAssign do
		app.myTrxUA.trxCargoGroupAddTi(cg1, ti, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		beginTransaction;
		// because we're expecting an error, teh post trx action won't have been done - clear it out
		// otherwise we get transient leaks
		app.myPassport.allTrxPostActions.purge;
		commitTransaction;
	endforeach;
//	self.assertTrueMsg( app.myPassport.allTrxPostActions.isEmpty, "Passport still has post actions 8");
	
	//14 Aug 2020	NDL	TFS - Add EDI On Site cargo for "MDHCONT1002" with CG = "UTMHCG1", when that exact sam value is already in the group but gone off-site
	// this is what STWR did.
	
	ediData := 'A,UTMHCG1,MDHCONT1002,CONT,2000,'&amp;operator2.code&amp;',1,'&amp;bs1.myLocationsController.getFullId&amp;',2200,ignore';
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "Unit Test CargoOnSiteCG", "Unit Test CargoOnSiteCG1"&amp;method.name, EDIFileType_UserDefined, false, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, app.myPassport.getErrorsAndWarningsAsString );
	
epilog

	delete tiArray;
	delete allCargoToAssign;
	delete iter;
	delete tiArray2;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCargoGroupAssignmentEDI" id="12bc934f-af48-48a4-b0de-24046071c735">
        <source>tCargoGroupAssignmentEDI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2015	cnwndl1	Initial creation		Par 36608

*/

constants

	CargoGroupAssignBaseId : String = "UTCG";
	CargoGroupBaseId : String = "UTEDICG";
	CargoBaseId : String = "UTEDICGA1";
	BSId : String = "BS01";
	RemarksTest : String = "Remarks test";
	
vars

	index : Integer;
	id : String;
	term : CM_Terminal;
	bs1 : CM_BlockStack;
	ediData : String;
	ediFile	:CM_EDIFile;
	oper : CM_Operator;
	ti : CM_TrackedItem;
	filesToDelete : CM_EDIFileSet;
	cgAssign : CM_CargoGroupAssignment;
	notifiedCG : CM_CargoGroup;
	cgCargoType : CM_CargoType;

begin

	term := self.getTerminal;
	cgCargoType := term.getDefaultCargoGroupCargoType;
	oper :=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	create filesToDelete transient;
	
	foreach index in 1 to 4 do
		self.deleteCargoGroupAassignment( term, CargoGroupAssignBaseId &amp; index.String );
	endforeach;
	foreach index in 1 to 24 do
		self.deleteCargo( CargoBaseId &amp; index.padLeadingWith('0',2), "CONT" );
	endforeach;
	foreach index in 1 to 9 do
		self.deleteCargoGroup( CargoGroupBaseId &amp; index.String );
	endforeach;
	self.deleteTerminalArea(BSId);
	
	bs1 := self.addBlockStack(BSId,200,null);
	self.assertNotNull(bs1);
	
	//Test error conditions first
	self.opts.purge();
	self.opts.addAssoc( "ExpectErrors", true );
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 1 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '1'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignmentId &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 1");
	filesToDelete.add(ediFile);
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 2 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '2'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignmentId &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 2");
	filesToDelete.add(ediFile);
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 3 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '3'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagAction &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 3");
	filesToDelete.add(ediFile);
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 4 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '4'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupId &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 4");
	filesToDelete.add(ediFile);
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 5 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '5'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupId &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 5");
	filesToDelete.add(ediFile);
	
	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 6 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '6'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("&lt;" &amp; CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroup &amp; "&gt;",1) &gt; 1, "Should have caused an error - test 6");
	filesToDelete.add(ediFile);

	ediData := self.getCGAXMLStringWithErrors( CargoGroupAssignBaseId, CargoBaseId, 7 );
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML_CargoGrpAssign, null, '7'&amp;method.name);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString.pos("no pre-assigned",1) &gt; 1, "Should have caused an error - test 7");
	filesToDelete.add(ediFile);

	//Now test it actually loads.  Add 4  Cargo Group Assignments with associated Cargo groups ( 3 to keep one to delete )
	self.opts.purge();
	
	ediData := self.getCargoGroupAssignAddXML( CargoGroupAssignBaseId, CargoGroupBaseId, CargoBaseId, oper.code, BSId, RemarksTest);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, '8'&amp;method.name, EDIFileType_XML_CargoGrpAssign, true, true, false, false, null);
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "1" );
	
	self.assertTrueMsg( cgAssign &lt;&gt; null, "Should have created Cargo Group Assignment 1 - test 8");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "1");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "1", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 1 - test 9");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "2");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "2", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 2 - test 10");
	
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "2" );
	self.assertTrueMsg( cgAssign &lt;&gt; null, "Should have created Cargo Group Assignment 2 - test 11");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "3");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "3", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 3 - test 12");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "4");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "4", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 4 - test 13");
	
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "3" );
	self.assertTrueMsg( cgAssign &lt;&gt; null, "Should have created Cargo Group Assignment 3 - test 14");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "5");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "5", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 5 - test 15");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "6");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "6", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 6 - test 16");
	
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "4" );
	self.assertTrueMsg( cgAssign &lt;&gt; null, "Should have created Cargo Group Assignment 4 - test 17");
//	notifiedCG := cgAssign.allNotifiedCargoGroupByIdDict.getAtKey( CargoGroupBaseId &amp; "7");
	notifiedCG := term.allCargoGroupsByIdCargoType.getAtKey( CargoGroupBaseId &amp; "7", cgCargoType.id).CM_CargoGroup;
	self.assertTrueMsg( notifiedCG &lt;&gt; null, "Should have created Cargo Group 7 - test 18");
	
	self.assertTrueMsg( notifiedCG.remarks[ 1: RemarksTest.length ] = RemarksTest, notifiedCG.id &amp; " Should have created with remarks - test 18A");
	
	filesToDelete.add(ediFile);  // leave this one here so we have something to look at...

	// Process the file to delete cargo group assignment 4.
/*	ediData := self.getCargoGroupAssignRemoveXML( CargoGroupAssignBaseId, CargoBaseId );
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, '9'&amp;method.name, EDIFileType_XML_CargoGrpAssign, true, true, false, false, null);

	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "4" );
	self.assertTrueMsg( cgAssign = null, "Should have deleted Cargo Group Assignment 4 - test 19");
	
	filesToDelete.add(ediFile);
*/	
	
	foreach index in 1 to 24 do
		id := CargoBaseId &amp; index.padLeadingWith('0',2);
		ti := self.addContainerAtLocation(id, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
		self.assertTrueMsg( ti &lt;&gt; null, "Failed to create cargo '" &amp; id &amp; "'");
	endforeach;
	
	// Process the file to delete cargo group assignment 4.
	ediData := self.getCargoGroupAssignRemoveXML( CargoGroupAssignBaseId, CargoBaseId );
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, '9'&amp;method.name, EDIFileType_XML_CargoGrpAssign, true, true, false, false, null);
	filesToDelete.add(ediFile);
	
	cgAssign := term.findCargoGroupAssignment( CargoGroupAssignBaseId &amp; "4" );
	self.assertTrueMsg( cgAssign = null, "Should have deleted Cargo Group Assignment 4 - test 19");
	
	//04 Oct 2018	NDL	TFS 39186
	
	ediData := self.getCargoGroupAssignModifyXML( CargoGroupAssignBaseId, CargoGroupBaseId, CargoBaseId, oper.code, BSId, RemarksTest);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, '10'&amp;method.name, EDIFileType_XML_CargoGrpAssign, true, true, false, false, null);
	
	filesToDelete.add(ediFile);
	
	
	
	
epilog

	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCargoGroupDetails" id="00dd1314-0b52-4a1b-978e-c56bce43967b">
        <source>tCargoGroupDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2022	navam1	Initial creation
//TFS 53393
*/
constants
	Rebar_Cargo = "UTREBAR";
	MyVessel = "VESS53387_CG";
	MyVoyage = "VOY53387_CG";
	MyTrain = "TRAIN53387";
	MyWagon1 = "UK53387_1";
	MyWagon2 = "UK53387_2";
	MyTruck = "TRUCK53387";
	MyCarrier = "CR53387";
	MyBlockStack = "BS53387";
	ContCargoGroup = "CCG53387";
	RebarCargoGroup = "RCG53387";
	ShipCont1 = "SHIP53387_1";
	ShipCont2 = "SHIP53387_2";
	ShipRebar1 = "SHIPREBAR53387_1";
	ShipRebar2 = "SHIPREBAR53387_2";
	RailPreCont1 = "RAIL53387_1";
	RailPreCont2 = "RAIL53387_2";
	RailPreRebar1 = "RAILREBAR53387_1";
	RailPreRebar2 = "RAILREBAR53387_2";
	RoadPreCont1 = "ROAD53387_1";
	RoadPreCont2 = "ROAD53387_2";
	RoadPreRebar1 = "ROADREBAR53387_1";
	RoadPreRebar2 = "ROADREBAR53387_2";
	
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	dualGate : CM_Gate;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	train : CM_Train;
	wagon1, wagon2 : CM_Wagon;
	contOnShip1, contOnShip2, contRailPre1, contRailPre2, contRoadPre1, contRoadPre2 : CM_TrackedItem;
	rebarOnShip1, rebarOnShip2, rebarRailPre1, rebarRailPre2, rebarRoadPre1, rebarRoadPre2 : CM_TrackedItem;
	contCargoGroup, rebarCargoGroup : CM_CargoGroup;
	detail : CM_CargoGroupDetail;
	tiArray : CM_TIArray;
	tiSet : CM_TISet;
	cDynaDict, rDynaDict : DynaDictionary;
	email : CM_EmailEntityByTypeNameDict;
	truck : CM_Vehicle;
	carrier : CM_Carrier;
	blockStack : CM_BlockStack;

begin
	// basic setup stuff - terminal, operator, etc
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Rebar_Cargo);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertTrueMsg(terminal &lt;&gt; null,"Terminal not found - setup phase : (test 1)" );
	self.assertTrueMsg(operator &lt;&gt; null,"Opertaor not found - setup phase : (test 2)" );
	self.assertTrueMsg(cargoType &lt;&gt; null,"Cargo Type not found - setup phase : (test 3)" );
	self.assertTrueMsg(dualGate &lt;&gt; null,"Gate not found - setup phase : (test 4)" );
	
	// tidy up
	self.deleteCargoGroup(ContCargoGroup);
	self.deleteCargoGroup(RebarCargoGroup);
	self.deleteContainer(ShipCont1);
	self.deleteContainer(ShipCont2);
	self.deleteContainer(RailPreCont1);
	self.deleteContainer(RailPreCont2);
	self.deleteContainer(RoadPreCont1);
	self.deleteContainer(RoadPreCont2);
	self.deleteCargo(RailPreRebar1, cargoType);
	self.deleteCargo(RailPreRebar2, cargoType);
	self.deleteCargo(RoadPreRebar1, cargoType);
	self.deleteCargo(RoadPreRebar2, cargoType);
	self.deleteCargo(ShipRebar1, cargoType);
	self.deleteCargo(ShipRebar2, cargoType);
	self.deleteTerminalArea(MyBlockStack);
	self.deleteVoyage(MyVoyage);
	self.deleteVessel(MyVessel);
	self.deleteTrainAndWagons(MyTrain);
	self.deleteVehicle(MyTruck);
	self.deleteCarrier(MyCarrier);
	self.deleteTerminalArea(MyBlockStack);
	
	// create a vessel and voyage
	vessel := self.addVesselGeneralCargo(MyVessel, operator, 2);
	self.assertNotNullMsg(vessel, "Vessel not created - setup phase : (test 5)");
	voyage := self.addVoyageWithGeneralCargoStruc(MyVoyage, MyVessel, operator.code, null, 2);
	self.assertNotNullMsg(voyage, "Voyage not created - setup phase : (test 6)");
	
	// create a train and wagons
	train := self.addTrain(MyTrain, null);
	self.assertNotNullMsg(train, "Train not created - setup phase : (test 7)");
	wagon1 := self.addWagon(MyWagon1, "UK", train);
	self.assertNotNullMsg(train, "Wagon 1 not created - setup phase : (test 8)");
	wagon2 := self.addWagon(MyWagon2, "UK", train);
	self.assertNotNullMsg(train, "Wagon 2 not created - setup phase : (test 9)");
	
	// add some cargo to the voyage
	contOnShip1 := self.addContainerOnShip(ShipCont1, operator, "2200", "GENL", null, voyage, "NZLYT", "0101");
	contOnShip2 := self.addContainerOnShip(ShipCont2, operator, "22G1", "MT", null, voyage, "NZPOE", "0202");
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("TotalQuantity", 10);
	self.opts.addAssoc("TotalVolume", 100.Decimal);
	self.opts.addAssoc("TotalWeight", 100.Decimal);
	rebarOnShip1 := self.addCargoForVoyage(voyage, ShipRebar1);
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("TotalQuantity", 20);
	self.opts.addAssoc("TotalVolume", 200.Decimal);
	self.opts.addAssoc("TotalWeight", 200.Decimal);
	rebarOnShip2 := self.addCargoForVoyage(voyage, ShipRebar2);
	beginTransaction;
	rebarOnShip1.setImExStatus(TI_IMEX_STATUS_IMPORT);
	rebarOnShip1.setDischargePort("NZPOE");
	rebarOnShip1.setTotalQuantity(10);
	rebarOnShip2.setImExStatus(TI_IMEX_STATUS_IMPORT);
	rebarOnShip2.setDischargePort("NZPOE");
	rebarOnShip2.setTotalQuantity(20);
	rebarOnShip2.setColour("RED");
	commitTransaction;
	self.assertEqualMsg(voyage.allOnshipTIsByCargoTypeId.size, 4, "Wrong number of cargo items on ship - setup phase : (test 10)");
	
	// prenote some rail cargo
	self.opts.purge;
	self.opts.addAssoc("CargoType", TI_CargoType_Container);
	self.opts.addAssoc("ISOType", "2201");	
	contRailPre1 := self.addRailPreNote(MyWagon1, "UK", RailPreCont1);
	contRailPre2 := self.addRailPreNote(MyWagon1, "UK", RailPreCont2);
	beginTransaction;
	contRailPre1.setMyVoyage(voyage, app.myPassport);
	contRailPre1.setImExStatus(TI_IMEX_STATUS_EXPORT);
	contRailPre2.setMyVoyage(voyage, app.myPassport);
	contRailPre2.setImExStatus(TI_IMEX_STATUS_EXPORT);
	commitTransaction;
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType.id);
	rebarRailPre1 := self.addRailPreNote(MyWagon2, "UK", RailPreRebar1);
	rebarRailPre2 := self.addRailPreNote(MyWagon2, "UK", RailPreRebar2);
	beginTransaction;
	rebarRailPre1.setTotalQuantity(30);
	rebarRailPre1.setMyTotalVolume(3000.0000);
	rebarRailPre1.setTotalWeightWithoutTrans(3000.0000);
	rebarRailPre1.setImExStatus(TI_IMEX_STATUS_EXPORT);
	rebarRailPre1.setMyVoyage(voyage, app.myPassport);
	rebarRailPre2.setTotalQuantity(40);
	rebarRailPre2.setMyTotalVolume(4000.0000);
	rebarRailPre2.setTotalWeightWithoutTrans(4000.0000);
	rebarRailPre2.setImExStatus(TI_IMEX_STATUS_EXPORT);
	rebarRailPre2.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	create tiArray transient;
	train.getAllTrackedItems(true, tiArray);
	self.assertEqualMsg(tiArray.size, 4, "Wrong number of cargo items on train - setup phase : (test 11)");
	delete tiArray;
	
	// prenote some road cargo
	self.opts.purge;
	self.opts.addAssoc("Commodity", "AUTO");
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("OperatorCode", operator.code);
	self.opts.addAssoc("TotalWeight", 24000);
	self.opts.addAssoc("CargoWeight", 20000);
	self.opts.addAssoc("TareWeight", 2000);
	contRoadPre1 := self.addPrenoted(RoadPreCont1);
	self.opts.purge;
	self.opts.addAssoc("Commodity", "AUTO");
	self.opts.addAssoc("ISOType", "2210");
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("OperatorCode", operator.code);
	self.opts.addAssoc("TotalWeight", 22000);
	self.opts.addAssoc("CargoWeight", 18000);
	self.opts.addAssoc("TareWeight", 2000);
	contRoadPre2 := self.addPrenoted(RoadPreCont2);
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("Colour", "RED");
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("DischargePort", "NZWLG");
	self.opts.addAssoc("OperatorCode", operator.code);
	self.opts.addAssoc("TotalWeight", 5000);
	self.opts.addAssoc("TotalQuantity", 50);
	rebarRoadPre1 := self.addPrenoted(RoadPreRebar1);
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("DischargePort", "NZWLG");
	self.opts.addAssoc("OperatorCode", operator.code);
	self.opts.addAssoc("TotalWeight", 6000);
	self.opts.addAssoc("TotalQuantity", 60);
	rebarRoadPre2 := self.addPrenoted(RoadPreRebar2);
	beginTransaction;
	rebarRoadPre1.setTotalQuantity(50);
	rebarRoadPre2.setTotalQuantity(60);
	commitTransaction;
	self.assertEqualMsg(voyage.allNotifiedTIsByCargoTypeId.size, 8, "Wrong number of prenoted cargo items - setup phase : (test 12)");
	
	// create a container cargo group and assign all the containers to it
	create tiSet transient;
	tiSet.add(contOnShip1);
	tiSet.add(contOnShip2);
	tiSet.add(contRailPre1);
	tiSet.add(contRailPre2);
	tiSet.add(contRoadPre1);
	tiSet.add(contRoadPre2);
	self.opts.purge;
	contCargoGroup := self.addCargoGroup(ContCargoGroup, tiSet);
	self.assertTrueMsg(contCargoGroup &lt;&gt; null, "Container Cargo group not created - setup phase (test 13)");
	
	// now create a Rebar cargo group and add all the rebar to it
	tiSet.clear;
	tiSet.add(rebarOnShip1);
	tiSet.add(rebarOnShip2);
	tiSet.add(rebarRailPre1);
	tiSet.add(rebarRailPre2);
	tiSet.add(rebarRoadPre1);
	tiSet.add(rebarRoadPre2);
	rebarCargoGroup := self.addCargoGroup(RebarCargoGroup, tiSet);
	self.assertTrueMsg(rebarCargoGroup &lt;&gt; null, "Rebar Cargo group not created - setup phase (test 14)");
	
	// check the container cargo group details - there should be 3 details
	// transport code VOY53387_CG and site On Ship - 2 containers
	// transport code TRAIN53387 and site Notified - 2 containers
	// transport code TRUCK and site Notified - 2 containers
	create cDynaDict transient;
	cDynaDict.setMembership(CM_CargoGroupDetail);
	cDynaDict.addMemberKey(CM_CargoGroupDetail::transportCode.name, false, true);
	cDynaDict.addMemberKey(CM_CargoGroupDetail::site.name, false, true);
	cDynaDict.endKeys(false);
	contCargoGroup.allCargoGroupDetails.copy(cDynaDict);
	self.assertTrueMsg(cDynaDict.size = 2, "Container Cargo group has wrong number of details - setup phase (test 15)"); // 06JUL2023	NAVAB1	 BUG 58853 - now only generating a detail for the voyage sites, not creating TRUCK or TRAIN details. So now only 2 - Onship and Prenote
	// check the rebar cargo group details - there should be 3 details
	// transport code VOY53387_CG and site On Ship - 2 items
	// transport code TRAIN53387 and site Notified - 2 items
	// transport code TRUCK and site Notified - 2 items
	create rDynaDict transient;
	rDynaDict.setMembership(CM_CargoGroupDetail);
	rDynaDict.addMemberKey(CM_CargoGroupDetail::transportCode.name, false, true);
	rDynaDict.addMemberKey(CM_CargoGroupDetail::site.name, false, true);
	rDynaDict.endKeys(false);
	rebarCargoGroup.allCargoGroupDetails.copy(rDynaDict);
	self.assertTrueMsg(rDynaDict.size = 2, "Rebar Cargo group has wrong number of details - setup phase (test 16)"); // 06JUL2023	NAVAB1	 BUG 58853
	
	// Container Cargo Group Transport Code VOY53387_CG site On Ship - 2 containers 
	//		dischargePort "NZLYT,NZPOE"
	//		imexStatus "Import"
	//		location "VOY53387_CG 0101,VOY53387_CG 0202"
	//		operator "UTOP"
	//		totalWeight 8000
	detail := cDynaDict[MyVoyage, TI_SITE_ONSHIP].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " is null - testing phase (test 1)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has the wrong number of TIs - testing phase (test 2)");
	self.assertTrueMsg(detail.dischargePort = "NZLYT,NZPOE", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect dischargePort " &amp; detail.dischargePort &amp; " - testing phase (test 3)");
	self.assertTrueMsg(detail.imexStatus = "Import", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 4)");
	self.assertTrueMsg(detail.location = "VOY53387_CG 0101,...", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 5)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 6)");
	self.assertTrueMsg(detail.totalWeight = 8000.0000, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 7)");
	
	// Container Cargo Group Transport Code TRAIN53387 site Notified - 2 containers 
	//		imexStatus "Export"
	//		location " 01 1, 03 1"
	//		operator "UTOP"
	//		totalWeight 8000
	
	/* 06JUL2023	NAVAB1	 BUG 58853 - no longer creating details for a train, EUP do not currently have cargo group details for rail ops
	detail := cDynaDict[MyTrain, TI_SITE_UNDEFINED].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " is null - testing phase (test 8)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has the wrong number of TIs - testing phase (test 9)");
	self.assertTrueMsg(detail.imexStatus = "Export", "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 10)");
	self.assertTrueMsg(detail.location = " 01 1, 03 1", "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 11)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 12)");
	self.assertTrueMsg(detail.totalWeight = 8000.0000, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 13)");
	*/
	
	
	// Container Cargo Group transport Code TRUCK site Notified - 2 containers
	//		imexStatus "Export"
	//		location "TRUCK"
	//		operator "UTOP"
	//		totalWeight 46000
	/* 06JUL2023	NAVAB1	 BUG 58853 - no longer creating details for a trucks, EUP do not currently have cargo group details for road ops
	detail := cDynaDict[CMIF_CargoGroupDtlController.TRUCK, TI_SITE_UNDEFINED].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " is null - testing phase (test 14)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has the wrong number of TIs - testing phase (test 15)");
	self.assertTrueMsg(detail.imexStatus = "Export", "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 16)");
	self.assertTrueMsg(detail.location = null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 17)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 18)");
	self.assertTrueMsg(detail.totalWeight = 46000.0000, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 19)");
	*/
	// Rebar Cargo group transport code VOY53387_CG site On Ship - 2 rebar
	//		dischargePort "NZPOE"
	//		imexStatus "Import"
	//		location "VOY53387_CG"
	//		operator "UTOP"
	//		totalQuantity 30
	//		totalVolume 300
	//		totalWeight 300
	detail := rDynaDict[MyVoyage, TI_SITE_ONSHIP].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " is null - testing phase (test 20)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has the wrong number of TIs - testing phase (test 21)");
	self.assertTrueMsg(detail.dischargePort = "NZPOE", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has the wrong number of TIs - testing phase (test 22)");
	self.assertTrueMsg(detail.imexStatus = "Import", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 23)");
	self.assertTrueMsg(detail.location = MyVoyage, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 24)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 25)");
	self.assertTrueMsg(detail.totalQuantity = 30, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect totalQuantity " &amp; detail.totalQuantity.String &amp; " - testing phase (test 26)");
	self.assertTrueMsg(detail.totalVolume = 300.0000, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect totalVolume " &amp; detail.totalVolume.String &amp; " - testing phase (test 27)");
	self.assertTrueMsg(detail.totalWeight = 300.0000, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 28)");
	self.assertTrueMsg(detail.colour = "RED", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect colour " &amp; detail.colour &amp; " - testing phase (test 7a)");
	self.assertTrueMsg(detail.remarks = "Created by unit test UT_CargoGroup::tCargoGroupDetails", "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has incorrect remarks " &amp; detail.remarks &amp; " - testing phase (test 7b)");
	
	// Rebar Cargo group transport code TRAIN53387 site Notified - 2 rebar
	//		imexStatus "Export"
	//		location "TRAIN53387"
	//		operator "UTOP"
	//		totalQuantity 70
	//		totalVolume 7000
	//		totalWeight 7000
	/* 06JUL2023	NAVAB1	 BUG 58853 - no longer creating details for a train, EUP do not currently have cargo group details for rail ops
	detail := rDynaDict[MyTrain, TI_SITE_UNDEFINED].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " is null - testing phase (test 20)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has the wrong number of TIs - testing phase (test 29)");
	self.assertTrueMsg(detail.imexStatus = "Export", "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 30)");
	self.assertTrueMsg(detail.location = " 01 1, 02 1", "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 31)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 32)");
	self.assertTrueMsg(detail.totalQuantity = 70, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalQuantity " &amp; detail.totalQuantity.String &amp; " - testing phase (test 33)");
	self.assertTrueMsg(detail.totalVolume = 7000.0000, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalVolume " &amp; detail.totalVolume.String &amp; " - testing phase (test 34)");
	self.assertTrueMsg(detail.totalWeight = 7000.0000, "CargoGroup Detail for " &amp; MyTrain &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 35)");
	*/
	
	// Rebar Cargo Group transport Code TRUCK site Notified - 2 rebar
	//		imexStatus "Export"
	//		location null
	//		operator "UTOP"
	//		totalQuantity 110
	//		totalWeight 11000
	/* 06JUL2023	NAVAB1	 BUG 58853 - no longer creating details for a trucks, EUP do not currently have cargo group details for road ops
	detail := rDynaDict[CMIF_CargoGroupDtlController.TRUCK, TI_SITE_UNDEFINED].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " is null - testing phase (test 36)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has the wrong number of TIs - testing phase (test 37)");
	self.assertTrueMsg(detail.imexStatus = "Export", "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect imex status " &amp; detail.imexStatus &amp; " - testing phase (test 38)");
	self.assertTrueMsg(detail.location = null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect location " &amp; detail.location &amp; " - testing phase (test 39)");
	self.assertTrueMsg(detail.operator = operator.code, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect operator " &amp; detail.operator &amp; " - testing phase (test 40)");
	self.assertTrueMsg(detail.totalQuantity = 110, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalQuantity " &amp; detail.totalQuantity.String &amp; " - testing phase (test 41)");
	self.assertTrueMsg(detail.totalWeight = 11000.0000, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has incorrect totalWeight " &amp; detail.totalWeight.String &amp; " - testing phase (test 42)");
	*/
	
	// receive one of the road container prenotes 
	create email transient;
	carrier := self.addCarrier(MyCarrier, MyCarrier, email, false, false, true, null);
	self.gateInPrenote(MyTruck, null, null, contRoadPre1, dualGate);
	self.assertTrueMsg(contRoadPre1.isOnSite, contRoadPre1.id &amp; " not received");
	// check cargo group details
	// Container Cargo Group should now have 4 details - on ship, TRUCK/on site, TRUCK/notified and rail/notified
	// Container Cargo Group TRUCK Notified detail should now only have 1 TI
	// Container Cargo Group TRUCK On site detail should have 1 TI
	self.assertTrueMsg(contCargoGroup.allCargoGroupDetails.size = 3, "Container Cargo Group has the wrong number of details (test 43)"); // 06JUL2023	NAVAB1	 BUG 58853 - now only generating a detail for the voyage sites, not creating TRUCK or TRAIN details. So now only 3 - Onsite, Onship and Prenote
	
		/* 06JUL2023	NAVAB1	 BUG 58853 - no longer creating details for a trucks, EUP do not currently have cargo group details for road ops

	cDynaDict.clear;
	contCargoGroup.allCargoGroupDetails.copy(cDynaDict);
	detail := cDynaDict[CMIF_CargoGroupDtlController.TRUCK, TI_SITE_UNDEFINED].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " is null (test 44)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 1, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_UNDEFINED) &amp; " has the wrong number of TIs (test 45)");
	detail := cDynaDict[CMIF_CargoGroupDtlController.TRUCK, TI_SITE_ONSITE].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSITE) &amp; " is null (test 46)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 1, "CargoGroup Detail for " &amp; CMIF_CargoGroupDtlController.TRUCK &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSITE) &amp; " has the wrong number of TIs (test 47)");
	*/
	
	// discharge one of the onship containers
	blockStack := self.addBlockStack(MyBlockStack, null, null);
	self.opts.purge();
	self.opts.addAssoc('isForcedMove', true);
	self.move(contOnShip1, blockStack.myLocationsController);
	self.assertTrueMsg(contOnShip1.isOnSite, "Move of container from ship to on site failed");
	self.assertTrueMsg(contOnShip1.myPrimaryActualLocation = blockStack.myLocationsController, "Container from ship is not in block stack");
	// check cargo group details
	// Container Cargo Group should now have 5 details - voyage/on ship, voyage/on site, TRUCK/on site, TRUCK/notified and rail/notified
	// Container Cargo Group Voyage OnShip detail should now only have 1 TI
	// Container Cargo Group Voyage On site detail should have 1 TI
	self.assertTrueMsg(contCargoGroup.allCargoGroupDetails.size = 3, "Container Cargo Group has the wrong number of details (test 47)"); // 06JUL2023	NAVAB1	 BUG 58853 - now only generating a detail for the voyage sites, not creating TRUCK or TRAIN details. So now only 3 - Onsite, Onship and Prenote
	cDynaDict.clear;
	contCargoGroup.allCargoGroupDetails.copy(cDynaDict);
	detail := cDynaDict[MyVoyage, TI_SITE_ONSHIP].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " is null (test 48)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 1, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSHIP) &amp; " has the wrong number of TIs (test 49)");
	detail := cDynaDict[MyVoyage, TI_SITE_ONSITE].CM_CargoGroupDetail;
	self.assertTrueMsg(detail &lt;&gt; null, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSITE) &amp; " is null (test 50)");
	self.assertTrueMsg(detail.allAssignedTrackedItems.size = 2, "CargoGroup Detail for " &amp; MyVoyage &amp; " and " &amp; app.siteEnumToString(TI_SITE_ONSITE) &amp; " has the wrong number of TIs (test 51)"); // 06JUL2023	NAVAB1	 BUG 58853 - now only generating a detail for the voyage sites, so all TIs however they were received are in the single ONSITE detail
	
epilog
	delete tiArray;
	delete tiSet;
	delete cDynaDict;
	delete rDynaDict;
	delete email;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoGroupEDI" id="5e978a2a-cc89-4cb6-8df1-bcdca907b853">
        <source>tCargoGroupEDI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2018	jlgndl1	Initial creation	TFS 40120

*/

constants

	CargoGroupId1 : String = "CG40120A";
	CargoGroupId2 : String = "CG40120B";
	CargoGroupId3 : String = "CG40120C";
	
vars

	term : CM_Terminal;
	oper1 : CM_Operator;
	cgCargoType : CM_CargoType;
	
	pxyFileTypeUser : CM_EDIFileTypeUser;
	realFileTypeUser : CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData :String;
	ediFile	:CM_EDIFile;
	
	cg : CM_CargoGroup;
	
	filesToDelete : CM_EDIFileSet;

begin

	create filesToDelete transient;

	term := self.getTerminal;
	oper1 := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( oper1 &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	cgCargoType := term.getDefaultCargoGroupCargoType();
	self.assertTrueMsg( cgCargoType &lt;&gt; null, "Default Cargo Group Cargo Type not found during setup.");

	self.deleteCargoGroup(CargoGroupId1);
	self.deleteCargoGroup(CargoGroupId2);
	self.deleteCargoGroup(CargoGroupId3);

	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.userDefinedFormatPNCG(UserDefinedCargoGroup);	// the XML format for "Unit Test Prenote CG"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; UserDefinedCargoGroup &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	//Add the 3 Cargo Group objects
	ediData := 
	"Action,ID,Operator,CargoType Descr,Min Weight,Max Weight,Remarks" &amp; CrLf
	&amp; "A,"&amp;CargoGroupId1&amp;","&amp;oper1.code&amp;","&amp;cgCargoType.description&amp;",12,250,TFS 40120"&amp;CrLf
	&amp; "A,"&amp;CargoGroupId2&amp;","&amp;oper1.code&amp;","&amp;cgCargoType.description&amp;",12,250,TFS 40120"&amp;CrLf
	&amp; "A,"&amp;CargoGroupId3&amp;","&amp;oper1.code&amp;","&amp;cgCargoType.description&amp;",12,250,TFS 40120" ;

	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedCargoGroup, UserDefinedCargoGroup&amp;'5'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId1,null).CM_CargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null and cg.id = CargoGroupId1, "Cargo Group '" &amp; CargoGroupId1 &amp; "' not created - Test 1.");
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId2,null).CM_CargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null and cg.id = CargoGroupId2, "Cargo Group '" &amp; CargoGroupId2 &amp; "' not created - Test 2.");
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null and cg.id = CargoGroupId3, "Cargo Group '" &amp; CargoGroupId3 &amp; "' not created - Test 3.");
	
	filesToDelete.add(ediFile);
	
	//modify cg2  and delete cg3
	ediData := 
	"Action,ID,Operator,CargoType Descr,Min Weight,Max Weight,Remarks" &amp; CrLf
	&amp; "M,"&amp;CargoGroupId2&amp;","&amp;oper1.code&amp;",,,,Modified Remarks"&amp;CrLf
	&amp; "D,"&amp;CargoGroupId3&amp;",,,,," ;
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedCargoGroup, UserDefinedCargoGroup&amp;'5'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId2,null).CM_CargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null and cg.id = CargoGroupId2 and cg.remarks[1:16] = "Modified Remarks", "Cargo Group '" &amp; CargoGroupId2 &amp; "' not modified - Test 4.");
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	self.assertTrueMsg( cg = null or cg.id &lt;&gt; CargoGroupId3, "Cargo Group '" &amp; CargoGroupId3 &amp; "' not deleted - Test 5.");
	
epilog

	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateCargoGroup" id="b0d80993-4879-4f7a-bb8f-7820d0830685">
        <source>tCreateCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation	Par 36338
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants
	BSId : String = "UTCG1";
	TiId1 : String = "UTCG0002201";
	TiId2 : String = "UTCG0002202";
	TiId3 : String = "UTCG0002203";
	TiId4 : String = "UTCG0009904";
	TiId5 : String = "UTCG0009905";
	Cargo_Type : String = "UTREBAR";
	TruckId : String = "UTCGTruk";
	RelId : String = "UTCGRel";
	DriverId : String = "UTDRIVER";
vars

	term : CM_Terminal;
	oper : CM_Operator;
	bs1 : CM_BlockStack;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	allCargoToAssign : CM_TISet;
	now : TimeStamp;
	cgId1 : String;
	cgId2 : String;
	cgId3 : String;
	cg1 : CM_CargoGroup;
	cg2 : CM_CargoGroup;
	cg3 : CM_CargoGroup;
	cargoType : CM_CargoType;
	newTiIds : StringArray;
	cargo4 : CM_Cargo;
	cargo5 : CM_Cargo;
	rr: CM_BulkRelease;
	request: CM_Request;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	dualGate : CM_Gate;
	assignedTrxCount : Integer;
	unAssignedTrxCount : Integer; 

begin

	now := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	term := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.assertTrueMsg(term &lt;&gt; null,"Terminal not found - setup phase : (test 1)" );
	self.assertTrueMsg(oper &lt;&gt; null,"Opertaor not found - setup phase : (test 2)" );
	self.assertTrueMsg(cargoType &lt;&gt; null,"Cargo Type not found - setup phase : (test 3)" );
	self.assertTrueMsg(dualGate &lt;&gt; null,"Gate not found - setup phase : (test 4)" );

	//This test should leave a couple of Cargo Groups hanging around ready to be archived in two days.
	
	self.deleteTerminalArea(BSId);
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	self.deleteCargo(TiId4, cargoType);
	self.deleteCargo(TiId5, cargoType);
	self.deleteVehicle(TruckId);
	
	bs1 := self.addBlockStack(BSId,200,null);
	self.assertNotNull(bs1);

	create allCargoToAssign transient;
	
	ti1 := self.addContainerAtLocation(TiId1, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertTrueMsg(ti1 &lt;&gt; null,TiId1 &amp; " not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	allCargoToAssign.add(ti1);
	
	ti2 := self.addContainerAtLocation(TiId2, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertTrueMsg(ti2 &lt;&gt; null,TiId2 &amp; " not created : (test 5) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	allCargoToAssign.add(ti2);
	
	ti3 := self.addContainerAtLocation(TiId3, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertTrueMsg(ti3 &lt;&gt; null,TiId3 &amp; " not created : (test 6) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	allCargoToAssign.add(ti3);
	
	cargo4 := self.addCargoAtLocation(TiId4, cargoType, oper, bs1.myLocationsController).CM_Cargo;
	self.assertTrueMsg( cargo4 &lt;&gt; null, TiId4 &amp; " not created : (test 7) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	beginTransaction;
	cargo4.setTotalQuantity(50);
	cargo4.setMyTotalVolume(50000);
	cargo4.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	
	//assign 3 tis to cg1
	cgId1 := "UTCG" &amp; now.Date.format("yyMMdd") &amp; "01"; //todays date.
	self.deleteCargoGroup(cgId1);	// to allow for re-running, otherwise leave it there so the archive test has somethng to do in a couple of days.
	cg1 := self.addCargoGroup( cgId1, allCargoToAssign );
	self.assertTrueMsg(cg1 &lt;&gt; null, cgId1 &amp; " Cargo Group not created : (test 8) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg1.onSiteAssignedCount = 3 , cgId1 &amp; " should have 3 assigned on-site items : (test 9)  - has " &amp; cg1.onSiteAssignedCount.String );
	self.assertTrueMsg(cg1.releasedDT = null ," Cargo Group " &amp; cgId1 &amp; " should not have releasedDT set while it has on-site cargo : (test 10) - releasedDT = " &amp; cg1.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 3, cgId1 &amp; " (test 11) Cargo Group should have 3 Assign transactions but has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, cgId1 &amp; " (test 12) Cargo Group should have 0 UNAssign transactions but has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( ti1, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 1, ti1.id &amp; " (test 13) Cargo Group should have 1 Assign transactions but has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( ti1, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, ti1.id &amp; " (test 14)Cargo Group should have 0 UNAssign transactions but has " &amp; unAssignedTrxCount.String );
	
	//move one TI off cg1 to cg2
	allCargoToAssign.clear();
	allCargoToAssign.add( ti3 );
	cgId2 := "UTCG" &amp; now.Date.format("yyMMdd") &amp; "02"; //todays date.
	self.deleteCargoGroup(cgId2);	// to allow for re-running, otherwise leave it there so the archive test has somethng to do in a couple of days.
	cg2 := self.addCargoGroup( cgId2, allCargoToAssign );
	self.assertTrueMsg(cg2 &lt;&gt; null, cgId2 &amp; " Cargo Group not created (test 15) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg1.onSiteAssignedCount = 2 , cgId1 &amp; " should have 2 assigned on-site items (after create of " &amp; cgId2 &amp; ") (test 16) - has " &amp; cg1.onSiteAssignedCount.String );
	self.assertTrueMsg(cg2.onSiteAssignedCount = 1 , cgId2 &amp; " should have 1 assigned on-site items (test 17) - has " &amp; cg2.onSiteAssignedCount.String );
	self.assertTrueMsg(cg2.releasedDT = null ," Cargo Group " &amp; cgId2 &amp; " should not have releasedDT set while it has on-site cargo - (test 18) releasedDT = " &amp; cg2.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 3, cgId1 &amp; " Cargo Group should have 3 Assign transactions but (test 19) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 1, cgId1 &amp; " Cargo Group should have 1 UNAssign transactions but (test 20) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 2, ti3.id &amp; " Cargo Group should have 2 Assign transactions but (test 21) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 1, ti3.id &amp; " Cargo Group should have 1 UNAssign transactions but (test 22) has " &amp; unAssignedTrxCount.String );
	
	//move the same TI to off cg2 to cg3
	cgId3 := "UTCG" &amp; now.Date.format("yyMMdd") &amp; "03"; //todays date.
	self.deleteCargoGroup(cgId3);	// to allow for re-running, otherwise leave it there so the archive test has somethng to do in a couple of days.
	cg3 := self.addCargoGroup( cgId3, allCargoToAssign );
	self.assertTrueMsg(cg3 &lt;&gt; null,cgId3 &amp; " Cargo Group not created - (test 23) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg2.onSiteAssignedCount = 0 , cgId2 &amp; " should have NO on-site items (after create of " &amp; cgId3 &amp; ") - (test 24) has " &amp; cg2.onSiteAssignedCount.String );
	self.assertTrueMsg(cg2.releasedDT &lt;&gt; null and cg2.releasedDT.Date = now.Date , cgId2 &amp; " Cargo Group SHOULD have releasedDT set to now (after create of " &amp; cgId3 &amp; ") - (test 25) releasedDT = " &amp; cg2.releasedDT.asStringJMT );
	self.assertTrueMsg(cg3.onSiteAssignedCount = 1 , cgId3 &amp; " should have 1 assigned on-site items  - (test 26) has " &amp; cg3.onSiteAssignedCount.String );
	self.assertTrueMsg(cg3.releasedDT = null ," Cargo Group " &amp; cgId3 &amp; " should not have releasedDT set while it has on-site cargo - (test 27) releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 3, ti3.id &amp; " Cargo Group should have 3 Assign transactions but (test 28) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 2, ti3.id &amp; " Cargo Group should have 2 UNAssign transactions but (test 29) has " &amp; unAssignedTrxCount.String );
	
	//move the same TI to off cg3 to cg1
	app.myTrxUA.trxCargoGroupAddTi(cg1, ti3, app.myPassport);
	self.assertTrueMsg(cg3.onSiteAssignedCount = 0 , cgId3 &amp; " should have NO on-site items (after re-assign of " &amp; ti3.id &amp; " to " &amp; cgId1 &amp; ") - (test 30) has " &amp; cg3.onSiteAssignedCount.String );
	self.assertTrueMsg(cg3.releasedDT &lt;&gt; null and cg3.releasedDT.Date = now.Date , cgId3 &amp; " Cargo Group SHOULD have releasedDT set to now (after reassign " &amp; ti3.id &amp; " to " &amp; cgId1 &amp; ") - (test 31) releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 4, cgId1 &amp; " Cargo Group should have 4 Assign transactions but (test 32) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg1, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 1, cgId1 &amp; " Cargo Group should have 1 UNAssign transactions but (test 33) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 4, ti3.id &amp; " Cargo Group should have 4 Assign transactions but (test 34) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( ti3, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 3, ti3.id &amp; " Cargo Group should have 3 UNAssign transactions but (test 35) has " &amp; unAssignedTrxCount.String );
	
	//assign cargo4 to cg3
	app.myTrxUA.trxCargoGroupAddTi(cg3, cargo4, app.myPassport);
	self.assertTrueMsg(cargo4.myCargoGroup &lt;&gt; null, TiId4 &amp; "'s Cargo Group reference not set (test 36) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg3.onSiteAssignedCount = 50 , cgId3 &amp; " should have 50 assigned on-site items  - (test 37) has " &amp; cg3.onSiteAssignedCount.String );
	self.assertTrueMsg(cg3.releasedDT = null ," Cargo Group " &amp; cgId3 &amp; " should not have releasedDT set while it has on-site cargo - (test 38) releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 2, cgId3 &amp; " Cargo Group should have 2 Assign transactions but (test 39) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 1, cgId3 &amp; " Cargo Group should have 1 UNAssign transactions but (test 40) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 1, cargo4.id &amp; " Cargo Group should have 1 Assign transactions but (test 41) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, cargo4.id &amp; " Cargo Group should have 0 UNAssign transactions but (test 42) has " &amp; unAssignedTrxCount.String );

	//split off cargo5 from cargo4, should still both be on cg3 and should create a new assign trx
	create newTiIds transient;
	newTiIds.add( TiId5 );
	app.myTrxUA.trxSplitBreakBulkToNewID(	cargo4,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											25,	//_quantity : Integer;
											25000,	// _weightOrVolume : Decimal;
											oper,	//_operator : CM_Operator;
											false,
											false,
											false,
											false,
											app.myPassport	//_passport : CM_Passport input
											);
	
	cargo5 := self.getTerminal.lookupTrackedItem(TiId5, cargoType.id, TI_STATE_UNDEFINED, null, false).CM_Cargo;
	self.assertTrueMsg(cargo5 &lt;&gt; null, TiId5 &amp; " not found after " &amp; cargo4.id &amp; " split - (test 43) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cargo5.myCargoGroup &lt;&gt; null, TiId5 &amp; "'s Cargo Group reference not set - (test 44) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg3.onSiteAssignedCount = 50 , cgId3 &amp; " should have 50 assigned on-site items  - (test 45) has " &amp; cg3.onSiteAssignedCount.String &amp; " " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg3.releasedDT = null ," Cargo Group " &amp; cgId3 &amp; " should not have releasedDT set while it has on-site cargo - (test 46) releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 3, cgId3 &amp; " Cargo Group should have 3 Assign transactions but (test 47) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 1, cgId3 &amp; " Cargo Group should have 1 UNAssign transactions but (test 48) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 1, cargo4.id &amp; " Cargo Group should have 1 Assign transactions but (test 49) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, cargo4.id &amp; " Cargo Group should have 0 UNAssign transactions but (test 50) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( cargo5, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 1, cargo5.id &amp; " Cargo Group should have 1 Assign transactions but (test 51) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cargo5, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, cargo5.id &amp; " Cargo Group should have 0 UNAssign transactions but (test 52) has " &amp; unAssignedTrxCount.String );

	//shift cargo4 to cg2
	app.myTrxUA.trxCargoGroupAddTi(cg2, cargo4, app.myPassport);
	self.assertTrueMsg(cg3.onSiteAssignedCount = 25 , cgId3 &amp; " should have 25 assigned on-site items  - (test 53) has " &amp; cg3.onSiteAssignedCount.String &amp; " " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(cg3.releasedDT = null ," Cargo Group " &amp; cgId3 &amp; " should not have releasedDT set while it has on-site cargo (test 54) - releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	self.assertTrueMsg(cg2.onSiteAssignedCount = 25 , cgId1 &amp; " should have 25 assigned on-site items (after reassign of " &amp; cargo4.id &amp; ") (test 55) - has " &amp; cg2.onSiteAssignedCount.String );
	assignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 3, cgId3 &amp; " Cargo Group should have 3 Assign transactions but (test 56) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 2, cgId3 &amp; " Cargo Group should have 2 UNAssign transactions but (test 57) has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 2, cargo4.id &amp; " Cargo Group should have 2 Assign transactions but (test 58) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cargo4, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 1, cargo4.id &amp; " Cargo Group should have 1 UNAssign transactions but (test 59) has " &amp; unAssignedTrxCount.String );
	
	//release cargo 5 off site and check values on cg3.
	self.opts.purge();
	self.opts.addAssociation("TotalRequested", "25".Integer);
	vvr := self.gateOutGC(TruckId, "", DriverId, cargo5, dualGate, null);
	self.assertTrueMsg( vvr &lt;&gt; null, " No vehicle visit record created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.workVehicle( vvr );
	self.roadExit( vvr );
	self.assertTrueMsg(vvr.myRoadJob = null, "Vehicle Visit Road Job not worked - (test 60) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg(vvr.status = CM_VehicleVisitRecord.Status_Complete, "Vehicle Visit not complete - (test 61) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.assertTrueMsg(cg3.onSiteAssignedCount = 0 , cgId3 &amp; " should have NO on-site items (after gate out of " &amp; cargo5.id &amp; ") - (test 62) has " &amp; cg3.onSiteAssignedCount.String );
	self.assertTrueMsg(cg3.releasedDT &lt;&gt; null and cg3.releasedDT.Date = now.Date , cgId3 &amp; " Cargo Group SHOULD have releasedDT set to now (after gate out of " &amp; cargo5.id &amp; ") (test 63) - releasedDT = " &amp; cg3.releasedDT.asStringJMT );
	assignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_ASSIGN );		self.assertTrueMsg(assignedTrxCount = 3, cgId3 &amp; " Cargo Group should have 3 Assign transactions but (test 64) has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cg3, TRANS_TYPE_GRP_UNASSIGN );	self.assertTrueMsg(unAssignedTrxCount = 2, cgId3 &amp; " Cargo Group should have 2 UNAssign transactions (test 65) but has " &amp; unAssignedTrxCount.String );
	assignedTrxCount := self.countTransactionsOfType( cargo5, TRANS_TYPE_GRP_ASSIGN ); 		self.assertTrueMsg(assignedTrxCount = 1, cargo5.id &amp; " Cargo Group should have 1 Assign transactions (test 66) but has " &amp; assignedTrxCount.String );
	unAssignedTrxCount := self.countTransactionsOfType( cargo5, TRANS_TYPE_GRP_UNASSIGN ); 	self.assertTrueMsg(unAssignedTrxCount = 0, cargo5.id &amp; " Cargo Group should have 0 UNAssign transactions (test 67) but has " &amp; unAssignedTrxCount.String );
	
epilog

	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	if cargoType &lt;&gt; null then
		self.deleteCargo(TiId4, cargoType);
		self.deleteCargo(TiId5, cargoType);
	endif;
	self.deleteTerminalArea(BSId);
	self.deleteVehicle(TruckId);

	delete allCargoToAssign;
	delete newTiIds;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tPreNoteEDIwithCargoGroup" id="1abff571-2811-43a9-b85e-2edc75cbc87d">
        <source>tPreNoteEDIwithCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/
constants

	Cargo_Type1 : String = "UTREBAR";
	CargoId1 : String = "UT37544R1";
	CargoId2 : String = "UT37544R2";
	CargoId3 : String = "UT37544R3";
	CargoGroupId1 : String = "CGPRE1";
	CargoGroupId2 : String = "CGPRE2";
	CargoGroupId3 : String = "CGPRE3";
	RFIDTagId : String = "UTCG1";
	RFIDSerial : String = "UCGS01";
	TruckRego1 : String = "UTCGAUTO1";

vars

	term : CM_Terminal;
	oper1 : CM_Operator;
	oper2 : CM_Operator;
	cargoType1 : CM_CargoType;
	cgCargoType : CM_CargoType;

	pxyFileTypeUser : CM_EDIFileTypeUser;
	realFileTypeUser : CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData :String;
	ediFile	:CM_EDIFile;
	
	ti : CM_TrackedItem;
	cg : CM_CargoGroup;
	
	filesToDelete : CM_EDIFileSet;
	
	pinNumber : String;
	allPins : StringArray;
	carrier : CM_Carrier;
	driverCode : String;
	carrierCode : String;
	gateName : String;
	rfidTag : CM_RFIDTag;
	batNumber : String;
	extraDetail : String;
	expectedError : Integer;
	truckRego1 : String;
	truckState : String;
	vehicle1 : CM_Vehicle;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	lc : CM_LocationsController;
	tiSet : CM_TISet;
	
begin

	term := self.getTerminal;
	self.setTerminalConfig(PrenoteUniqBooking, false);
	oper1 := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( oper1 &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	oper2 := app.myRoot.allOperators.getAtKey("UTO2");
	self.assertTrueMsg( oper1 &lt;&gt; null, "Operator of 'UTO2' not found during setup.");
	cargoType1 := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type1);
	self.assertTrueMsg( cargoType1 &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type1 &amp; "' not found during setup.");
	cgCargoType := term.getDefaultCargoGroupCargoType();
	self.assertTrueMsg( cgCargoType &lt;&gt; null, "Default Cargo Group Cargo Type not found during setup.");
	
	//clean up from last run
	self.deleteVehicle(TruckRego1);
	self.deleteCargo(CargoId1, cargoType1);
	self.deleteCargo(CargoId2, cargoType1);
	self.deleteCargoGroup(CargoGroupId1);
	self.deleteCargoGroup(CargoGroupId2);
	self.deleteCargoGroup(CargoGroupId3);

	// delete any existing user defined setup for this one, and add it again.
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.userDefinedFormatPNCG(UserDefinedPreNoteWithCG);	// the XML format for "Unit Test Prenote CG"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; UserDefinedPreNoteWithCG &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.userDefinedFormatPNCG(UserDefinedCargoGroup);	// the XML format for "Unit Test Prenote CG"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; UserDefinedCargoGroup &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create filesToDelete transient;
	
	//First one, is to simply add a single pre-note to a cargo group that is not yet created.
	// get the data to import
	self.opts.purge();	
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,Cargo Group Id,TotalQuantity" &amp; CrLf
	&amp; "A,"&amp;CargoId1&amp;","&amp;cargoType1.description&amp;",,,25,Storage,,"&amp;oper1.code&amp;",NZABY,,"&amp;CargoGroupId1&amp;",1" &amp; CrLf
	&amp; "A,"&amp;CargoId3&amp;","&amp;cargoType1.description&amp;",,,25,Storage,,"&amp;oper1.code&amp;",NZABY,,"&amp;CargoGroupId1&amp;",1" ;
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedPreNoteWithCG, UserDefinedPreNoteWithCG&amp;'1'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 1.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	self.assertTrueMsg( ti &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2a.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId3);
	self.assertTrueMsg( ti &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2b.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	cg := ti.myCargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created with a Cargo Group - Test 3.");
	self.assertTrueMsg( cg.id = CargoGroupId1, "Prenote attached to the wrong Cargo Group - Test 4.");
	
	filesToDelete.add(ediFile);
	
	//Second one, add a another pre-note to the same cargo group. (I.e an existing one.)
	// get the data to import
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,Cargo Group Id,TotalQuantity" &amp; CrLf
	&amp; "A,"&amp;CargoId2&amp;","&amp;cargoType1.description&amp;",,,25,Storage,,"&amp;oper1.code&amp;",NZABY,,"&amp;CargoGroupId1&amp;",1" ;
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedPreNoteWithCG, UserDefinedPreNoteWithCG&amp;'2'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 5.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId2);
	self.assertTrueMsg( ti &lt;&gt; null, "Prenote '" &amp; CargoId2 &amp; "' not created - Test 6.");
	
	cg := ti.myCargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null, "Prenote '" &amp; CargoId2 &amp; "' not associated with a Cargo Group - Test 7.");
	self.assertTrueMsg( cg.id = CargoGroupId1, "Prenote attached to the wrong Cargo Group - Test 8.");
	
	filesToDelete.add(ediFile);
	
	//Third one Add a second Cargo Group, by modifying the first ti onto a new cargo group that is not yet known.	
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,Cargo Group Id,TotalQuantity" &amp; CrLf
	&amp; "M,"&amp;CargoId1&amp;","&amp;cargoType1.description&amp;",,,,,,,,,"&amp;CargoGroupId2&amp;"," ;
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedPreNoteWithCG, UserDefinedPreNoteWithCG&amp;'3'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 9.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	cg := ti.myCargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not no longer has a Cargo Group - Test 10.");
	self.assertTrueMsg( cg.id = CargoGroupId2, "Prenote attached to the wrong Cargo Group - Test 11.");
	
	filesToDelete.add(ediFile);

	
	//Fourth one, is to simply update a single pre-note to a cargo group that already exists.	
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,Cargo Group Id,TotalQuantity" &amp; CrLf
	&amp; "U,"&amp;CargoId1&amp;","&amp;cargoType1.description&amp;",,,25,Storage,,"&amp;oper1.code&amp;",NZABY,,"&amp;CargoGroupId1&amp;",1" ;
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedPreNoteWithCG, UserDefinedPreNoteWithCG&amp;'4'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 12.");
	
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	cg := ti.myCargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not updated with a Cargo Group - Test 13.");
	self.assertTrueMsg( cg.id = CargoGroupId1, "Prenote attached to the wrong Cargo Group - Test 14.");
	
	filesToDelete.add(ediFile);
	
	// Cargo Group Message - Add one
	ediData := 
	"Action,ID,Operator,CargoType Descr,Min Weight,Max Weight,Remarks" &amp; CrLf
	&amp; "A,"&amp;CargoGroupId3&amp;","&amp;oper1.code&amp;","&amp;cgCargoType.description&amp;",12,250,Happy thoughts" ;

	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedCargoGroup, UserDefinedCargoGroup&amp;'5'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	self.assertTrueMsg( cg &lt;&gt; null and cg.id = CargoGroupId3, "Cargo Group '" &amp; CargoGroupId3 &amp; "' not created - Test 15.");
	
	filesToDelete.add(ediFile);
	
	// Move both the pre-notes onto cargo group 3, one by update, one by modify
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,Cargo Group Id,TotalQuantity" &amp; CrLf
	&amp; "U,"&amp;CargoId1&amp;","&amp;cargoType1.description&amp;",,,25,Storage,,"&amp;oper1.code&amp;",NZABY,,"&amp;CargoGroupId3&amp;",1"&amp;CrLf
	&amp; "M,"&amp;CargoId2&amp;","&amp;cargoType1.description&amp;",,,,,,,,,"&amp;CargoGroupId3&amp;","; 
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedPreNoteWithCG, UserDefinedPreNoteWithCG&amp;'6'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 16.");
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	self.assertTrueMsg( cg.allAssignedTrackedItems.size = 2, "Prenotes not updated onto Cargo Group 3 - Test 17.");
	
	filesToDelete.add(ediFile);
	
	// Modify cargo group 3, operator only
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	beginTransaction;
	cg.allOperators.add(oper2);
	commitTransaction;
	ediData := 
	"Action,ID,Operator,CargoType Descr,Min Weight,Max Weight,Remarks" &amp; CrLf
	&amp; "M,"&amp;CargoGroupId3&amp;","&amp;oper2.code&amp;",,,," ;

	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedCargoGroup, UserDefinedCargoGroup&amp;'7'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId3,null).CM_CargoGroup;
	self.assertTrueMsg( cg.myOperator = oper2, "Cargo Group 3, operator not modified - Test 18.");
	self.assertTrueMsg( cg.minWeight = 12, "Cargo Group 3, minWeight should not have changed - Test 19.");
	self.assertTrueMsg( cg.maxWeight = 250, "Cargo Group 3, maxWeight should not have changed - Test 20.");
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	self.assertTrueMsg( ti.myOperator = oper2, "Cargo '"&amp;CargoId1&amp;"', operator should have been modified to match the Cargo Groups operator - Test 21.");
	ti := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId2);
	self.assertTrueMsg( ti.myOperator = oper2, "Cargo '"&amp;CargoId2&amp;"', operator should have been modified to match the Cargo Groups operator - Test 22.");
	
	filesToDelete.add(ediFile);
	
	//Update cargo group 1
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId1,null).CM_CargoGroup;
	beginTransaction;
	cg.allOperators.add(oper2);
	commitTransaction;
	ediData := 
	"Action,ID,Operator,CargoType Descr,Min Weight,Max Weight,Remarks" &amp; CrLf
	&amp; "U,"&amp;CargoGroupId1&amp;","&amp;oper2.code&amp;","&amp;cgCargoType.description&amp;",7,17,Happy thoughts" ;

	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, UserDefinedCargoGroup, UserDefinedCargoGroup&amp;'8'&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	cg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId1,null).CM_CargoGroup;
	self.assertTrueMsg( cg.myOperator = oper2, "Cargo Group 1, operator now be updated - Test 23.");
	self.assertTrueMsg( cg.minWeight = 7, "Cargo Group 1, minWeight should now be 7 - Test 24.");
	self.assertTrueMsg( cg.maxWeight = 17, "Cargo Group 1, maxWeight should now be 17 - Test 25.");
	self.assertTrueMsg( cg.remarks.pos("Happy thoughts",1) &gt; 0, "Cargo Group 1, remarks should now have Happy thoughts - Test 26.");
	
	filesToDelete.add(ediFile);
	
	// Now try gating in the two pre-notes via the Web Service call (Hunstman version) to ensure that the Cargo group ID stays aattached...
	create allPins transient;
	create tiSet transient;
	
	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	self.assertTrueMsg( carrier &lt;&gt; null, "Failed to find Carrier - Test 27.");
	
	ti1 := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId1);
	beginTransaction;
	ti1.setReleaseCarrier(carrier.code);
	ti1.setCustomsEntryNumber("X");
	tiSet.clear;
	tiSet.add(ti1);
	app.myUtilityUA.utlUpdateGeneratePin(tiSet, null, true, app.myPassport);
	commitTransaction;
	
	pinNumber := ti1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for '"&amp;CargoId1&amp;"' - Test 28.");
	allPins.add( pinNumber );
	
	ti2 := term.allNotifiedTIsByCargoTypeId.getAtKey(cargoType1.id,CargoId2);
	beginTransaction;
	ti2.setReleaseCarrier(carrier.code);
	ti2.setCustomsEntryNumber("X");
	tiSet.clear;
	tiSet.add(ti2);
	app.myUtilityUA.utlUpdateGeneratePin(tiSet, null, true, app.myPassport);
	commitTransaction;
	
	pinNumber := ti2.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for '"&amp;CargoId2&amp;"' - Test 29.");
	allPins.add( pinNumber );
	
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Gate In Prenote on CG";
	expectedError := 0;
	truckRego1 := TruckRego1;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	vehicle1 := term.vehicles[truckRego1, truckState];
	self.assertTrueMsg( vehicle1 &lt;&gt; null, "Failed to create vehicle1 - test 30");
	self.assertTrueMsg( ti1.isOnSite, "Cargo Item " &amp; CargoId1 &amp; " should be on site - test 31");
	lc := ti1.myPrimaryActualLocation;
	self.assertTrueMsg( lc.isYardLocation, "Cargo Item " &amp; CargoId1 &amp; " should be in Yard - test 32");
	self.assertTrueMsg( vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be on site - test 33");
	
	self.assertTrueMsg( ti1.getMyCargoGroupId = CargoGroupId3, "Cargo Item '" &amp; CargoId1 &amp; "' should still be part of Cargo Group '"&amp;CargoGroupId3&amp;"' when on site - test 34");
	self.assertTrueMsg( ti2.getMyCargoGroupId = CargoGroupId3, "Cargo Item '" &amp; CargoId2 &amp; "' should still be part of Cargo Group '"&amp;CargoGroupId3&amp;"' when on site - test 35");
	

epilog

	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;
	delete allPins;
	delete tiSet;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uCargoGroupMandatory" id="fa4c6a49-0528-415b-a32f-32deb91390ec">
        <updating/>
        <source>uCargoGroupMandatory()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2022	navds20	ChangeRequest 54219: EUP - Cargo Group to be mandatory

*/
constants
	CargoTypeDesc : String = 'UT'   &amp; UT_DSL.TFS54219 ;
	TI1		 	  : String = 'UT'   &amp; UT_DSL.TFS54219 ;
	CargoGroup    : String = 'UTGRP'&amp; UT_DSL.TFS54219 ;
	CargoGroup1   : String = 'UTGRP1'&amp; UT_DSL.TFS54219 ;
	TERMINAL 	  : String = "UT";
vars
	cargoType 	 	     : CM_CargoType;
	ti1			 		 : CM_TrackedItem;
	voyage 				 : CM_Voyage;
	isCarGoGroupRequired : Boolean;
	tiSet 				 : CM_TISet;
	cargoGroup 			 : CM_CargoGroup;
	lc					 : CM_LocationsController;
	vessel				 : CM_Vessel;
	height               : Integer;
	passport 			 : CM_Passport;
	helper				 : UT_HelperAdmSys;
	terminal			 : CM_Terminal;
begin
	
	terminal := self.getMyTerminal;
	/*
	1-	Cargo Type
	*/
	create helper transient;
	helper.code:= CargoTypeDesc;
	
	self.opts.addAssoc("Terminal", TERMINAL);
	helper.opts.addAssoc("Terminal", TERMINAL);
	helper.setActiveProfile();
	helper.xDeleteCargoType(false,false,true,true,false,true);
	//self.deleteCargoType(CargoTypeDesc);

	self.opts.purge();
	self.opts.addAssoc("isCargoGroupRequired", true);
	
	cargoType := self.addCargoType(CargoTypeDesc, false);
	
	self.assertNotNull(cargoType);
	self.assertEqual(cargoType.description, CargoTypeDesc );
	self.assertTrue(cargoType.isCargoGroupRequired = true);
	
	/*
	2. Voyage
	*/
	self.deleteVessel('UTVSL'&amp;UT_DSL.TFS54219);
	
	self.deleteVoyage('UTVOY'&amp;UT_DSL.TFS54219);
	
	vessel := self.addVesselWithHolds('UTVSL'&amp;UT_DSL.TFS54219, 2, 2);
	
	voyage := self.addVoyageWithGeneralCargoStruc('UTVOY'&amp;UT_DSL.TFS54219, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);

	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 
	self.assertNotNull(cargoType);
	self.assertEqual(voyage.code, 'UTVOY'&amp;UT_DSL.TFS54219 );
	
	/*
	3. Cargo
	*/
	self.deleteCargo(TI1,cargoType);
	
	//ti1 := self.addCargoBreakBulkAtLocation('UTVOY'&amp;UT_DSL.TFS54219, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, voyage.myOperator);
	ti1 := lc.createNewCargoForLCDetailed(cargoType,null, TI1, null, TI_IMEX_STATUS_IMPORT, voyage, voyage.myOperator, 1, null).CM_Cargo; 
	self.assertExceptionRaised(90982,"No Cargo Group");
	//self.assertNull(ti1); // 19/08/2022 navds20 TFS 54219
	
	//4. Updating cargo group
	self.updateTI(ti1);
	ti1.setCargoGroup(cargoGroup,CargoGroup1,passport);
	self.assertNull(ti1);
	
epilog
	delete helper;
end;</source>
    </JadeMethod>
    <JadeMethod name="uSetUpCargoGroupAssignment" id="216ce4f2-c85e-4a5b-9336-f455598f7f81">
        <source>uSetUpCargoGroupAssignment();
/*

Purpose:			

Parameters:			Set up spme test data for prototyping  STW 2491
					TFS 192, 342

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608
13 Nov 2019	NDl	TFS 47298 testing

*/
constants
	LOCATION0 = "TR1";
	LOCATION1 = "NDLBLK";
	LOCATION2 = "NDLBK2";
	//LOCATION1 = "BLOCK1";
	//LOCATION2 = "GLSHED";

vars

	objArray : ObjectArray;
	cgAssign : CM_CargoGroupAssignment;
	wt : CM_WorkTask;
	iter : Iterator;
//	notifyCargoGroup : CM_NotifiedCargoGroup;
	pxyCgAssign : CM_CargoGroupAssignment;
	allCargoIds : StringArray;
	term : CM_Terminal;
	pxyNotifyCargoGroup : CM_NotifiedCargoGroup;
	pxysToDelete : ObjectArray;
	operator : CM_Operator;
	cgCargoType, ct : CM_CargoType;
	
	cargoId : String;
	index : Integer;
	bs : CM_BlockStack;
	ti : CM_TrackedItem;

begin

	self.opts.purge();
	term := app.myRoot.allTerminals.getAtKey("NDL");
	//term := app.myRoot.allTerminals.getAtKey("DAVE");
	self.opts.addAssoc("Terminal",term.code);
	operator := app.myRoot.allOperators.getAtKey("DOUG");
	cgCargoType := term.getDefaultCargoGroupCargoType();
	if cgCargoType.abbreviation &lt;&gt; "PBCG" then
		iter := term.allCargoBOLTypes.createIterator;
		while iter.next(ct) do
			if ct.abbreviation = "PBCG" then
				cgCargoType := ct;
				break;
			endif;
		endwhile;
	endif;
	if cgCargoType = null then
		cgCargoType := term.getDefaultCargoGroupCargoType();
	endif;
	
	foreach index in 1 to 24 do
		cargoId := "CARGO" &amp; index.padLeadingWith('0',2);
		self.deleteContainer( cargoId );
	endforeach;
	
	self.deleteCargoGroup("CG1");
	self.deleteCargoGroup("CG2");
	self.deleteCargoGroup("CG3");
	self.deleteCargoGroup("CG4");
	self.deleteCargoGroup("CG5");
	self.deleteCargoGroup("CG6");
	self.deleteCargoGroup("CG7");

	create objArray transient;
	//CM_CargoGroupAssignment.instances.copy( objArray );
	foreach wt in term.allWorkTasksDict do
		if wt.isKindOf(CM_CargoGroupAssignment) then
			objArray.add(wt);
		endif;
	endforeach;
	
	if not objArray.isEmpty then
		beginTransaction;
		objArray.purge();
		commitTransaction;
	endif;

	create pxysToDelete transient;
	
	create allCargoIds transient;
	allCargoIds.add("CARGO01");
	allCargoIds.add("CARGO02");
	allCargoIds.add("CARGO03");
	allCargoIds.add("CARGO04");
	allCargoIds.add("CARGO05");
	allCargoIds.add("CARGO06");
	
	create pxyCgAssign transient;
	pxysToDelete.add(pxyCgAssign);
	pxyCgAssign.setProxy(	"CGA1",	//_id : String;
							allCargoIds,	//_allCargoIds : StringArray;
							term	//_myTerminal : CM_Terminal
							);
							
	allCargoIds.clear();
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG1",	//_id : String;
									LOCATION1,	//_defaultLocation : String;
									"Some remarks",	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	allCargoIds.clear();
//	allCargoIds.add("CARGO05");
//	allCargoIds.add("CARGO06");
//	allCargoIds.add("CARGO07");
//	allCargoIds.add("CARGO08");
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG2",	//_id : String;
									LOCATION2,	//_defaultLocation : String;
									"Some other remarks",	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG7",	//_id : String;
									null,	//_defaultLocation : String;
									"Some other remarks",	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	app.myTrxCA.trxCreateCGAssignment( pxyCgAssign, cgAssign, app.myPassport );
	
	allCargoIds.clear();
	create pxyCgAssign transient;
	pxysToDelete.add(pxyCgAssign);
	pxyCgAssign.setProxy(	"CGA2",	//_id : String;
							allCargoIds,	//_allCargoIds : StringArray;
							term	//_myTerminal : CM_Terminal
							);
							
	allCargoIds.clear();
	allCargoIds.add("CARGO09");
	allCargoIds.add("CARGO10");
	allCargoIds.add("CARGO11");
	allCargoIds.add("CARGO12");
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG3",	//_id : String;
									LOCATION2,	//_defaultLocation : String;
									null,	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	allCargoIds.clear();
	allCargoIds.add("CARGO13");
	allCargoIds.add("CARGO14");
	allCargoIds.add("CARGO15");
	allCargoIds.add("CARGO16");
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG4",	//_id : String;
									LOCATION2,	//_defaultLocation : String;
									null,	//_remarks : String;
									3000,	//_minWeight : Decimal;
									8000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	app.myTrxCA.trxCreateCGAssignment( pxyCgAssign, cgAssign, app.myPassport );
	
	allCargoIds.clear();
	allCargoIds.add("CARGO17");
	allCargoIds.add("CARGO18");
	allCargoIds.add("CARGO19");
	allCargoIds.add("CARGO20");
	allCargoIds.add("CARGO21");
	allCargoIds.add("CARGO22");
	allCargoIds.add("CARGO23");
	allCargoIds.add("CARGO24");
	create pxyCgAssign transient;
	pxysToDelete.add(pxyCgAssign);
	pxyCgAssign.setProxy(	"CGA3",	//_id : String;
							allCargoIds,	//_allCargoIds : StringArray;
							term	//_myTerminal : CM_Terminal
							);
							
	allCargoIds.clear();
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG5",	//_id : String;
									LOCATION1,	//_defaultLocation : String;
									null,	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	allCargoIds.clear();
	create pxyNotifyCargoGroup transient;
	pxysToDelete.add(pxyNotifyCargoGroup);
	pxyNotifyCargoGroup.setProxy(	"CG6",	//_id : String;
									LOCATION1,	//_defaultLocation : String;
									null,	//_remarks : String;
									3000,	//_minWeight : Decimal;
									5000,	//_maxWeight : Decimal;
									cgCargoType,	//_myCargoType : CM_CargoType;
									operator,	//_myOperator : CM_Operator;
									allCargoIds,	//_allPreAssigned : StringArray;
									pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	app.myTrxCA.trxCreateCGAssignment( pxyCgAssign, cgAssign, app.myPassport );
	
	bs := self.getTerminal.allTerminalAreas.getAtKey(LOCATION0).CM_BlockStack;
	
	foreach index in 1 to 24 do
		cargoId := "CARGO" &amp; index.padLeadingWith('0',2);
		ti := self.addContainerAtLocation(cargoId, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
		self.assertTrueMsg( ti &lt;&gt; null, cargoId &amp; " container not created");
		beginTransaction;
		ti.setPropertyValue("totalWeight","2000".Decimal);
		commitTransaction;
	endforeach;

epilog

	if pxysToDelete &lt;&gt; null and not pxysToDelete.isEmpty then
		pxysToDelete.purge();
	endif;
	delete pxysToDelete;
	delete objArray;
	delete allCargoIds;
	delete iter;

end;</source>
    </JadeMethod>
