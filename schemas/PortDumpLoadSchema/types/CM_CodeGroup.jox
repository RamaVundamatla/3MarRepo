<Class name="CM_CodeGroup">
    <JadeMethod name="exportPDXMLMyCollections" id="c286726a-d760-4413-9230-30d33cc5b5e1">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	code: CM_Code;
	operator: CM_Operator;
begin
	if _property.name = CM_CodeGroup::allCodes.name then
		_file.writeLine('&lt;'&amp;CM_CodeGroup::allCodes.name&amp;'&gt;');
		foreach code in self.allCodes do
			_file.writeLine('&lt;class&gt;'&amp;code.class.name&amp;'&lt;/class&gt;');
			code.exportPDXML(_file, _objArray, true, true);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_CodeGroup::allCodes.name&amp;'&gt;');

	elseif _property.name = CM_CodeGroup::allOperators.name then
		_file.writeLine('&lt;'&amp;CM_CodeGroup::allOperators.name&amp;'&gt;');
		foreach operator in self.allOperators do
			_file.writeLine('&lt;class&gt;' &amp; operator.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; operator.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_CodeGroup::allOperators.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="16b4d8ff-83f3-4f0e-8fd4-8ed9cd593089">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	operator : CM_Operator;
	proxyArray: ObjectArray;
	newObject: Object;
begin
	create proxyArray transient;
	if _name = CM_CodeGroup::allOperators.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_CodeGroup::allOperators.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				operator := app.myRoot.allOperators[theKey];
				if operator &lt;&gt; null then
					operator.allCodeGroups.add(self);
				endif;				
			endif;
		endwhile;
	elseif _name = CM_CodeGroup::allCodes.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, _name, proxyArray);
		foreach newObject in proxyArray do
			newObject.CM_Code.setPropertyValue(CM_Code::myCodeGroup.name, self);//newObject.CM_Code);
		endforeach;
	endif;
	
epilog
	delete proxyArray;		// PAR #27874
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="ec9e83b7-3bad-4fe7-94ea-3cb2dbb9067e">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_CodeGroup::myRoot.name then
		return app.myRoot;
	elseif _name = CM_CodeGroup::myCodeGroupType.name then
		return app.myRoot.allCodeGroupTypes[_theCode.Integer];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
