    <JadeMethod name="displayRows" id="5dbf006d-6674-4084-bcba-b6a4e2d0d4af">
        <source>displayRows(_iter : Iterator io);
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
21 Jul 2008	cnwkpd1	PAR #17554 - Found during development of new RIA Web Service application
					Reverse order of checks inside while loop so break check is done first

*/

vars
	tmpUser : CM_User;
	tmpReq : CM_EventRequest;

begin
	if _iter = null then
		return;
	endif;
	
	tmpUser := app.getMyUser();
	
	while _iter.next(tmpReq) do
		if (not self.includeRequest(tmpReq)) then		// PAR #17554 - check for break condition first
			break;
		endif;
		self.tblDataDisplayRow(tmpReq);
	endwhile;
	
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';			
end;</source>
        <Parameter name="_iter" type="Iterator" usage="io"/>
    </JadeMethod>
