    <JadeMethod name="isMPIClearance" id="c5a938e8-2e6a-4bf7-ba4e-90322f940e37">
        <source>isMPIClearance() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/04/2021	navdap1		Initial creation TFS 51073 PNL TSW B07 removing stop CEDO Stop
//
vars

begin
	return self.responseStatus.isOneOf(	MPI_Clearance_1, MPI_Clearance_2, MPI_Clearance_3, 
										MPI_QualifiedClearance_1, MPI_QualifiedClearance_2, MPI_QualifiedClearance_3 );
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOlderThan" id="c658986c-4e0f-422c-bb50-f3f26df15070">
        <source>isOlderThan(_csTI: CM_EDICustomStopTI): Boolean;
//----------------------------------------------------------------
//	Created:	06 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Dont use this after 723 (OK in 723)
vars
	myEntryNumberEdition	: String;
	otherEntryNumberEdition	: String;
	pos						: Integer;
begin
	
	pos := self.entryNumber.pos("/", 1);
	if pos &gt; 0 
	and pos &lt; self.entryNumber.length then
		myEntryNumberEdition := self.entryNumber[pos+1:end];	
	endif;
	
	pos := _csTI.entryNumber.pos("/", 1);
	if pos &gt; 0 
	and pos &lt; _csTI.entryNumber.length then
		otherEntryNumberEdition := _csTI.entryNumber[pos+1:end];	
	endif;	
	
	if (myEntryNumberEdition.isInteger and otherEntryNumberEdition.isInteger)
	and (myEntryNumberEdition.Integer &lt; otherEntryNumberEdition.Integer) then
		return true;
	endif;
	return false;

end;</source>
        <Parameter name="_csTI" type="CM_EDICustomStopTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTSWAllClearMessage" id="2f59aff7-a132-434f-a971-7e1cc500111e">
        <source>isTSWAllClearMessage() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2018	jlgsl4	TFS 39133 - TSW - IM1/EX1 'all clear' message
*/

vars

begin
	if hasNZCSClearance() and not self.responseStatus = NZCS_QualifiedClearance_1 then
		if self.customsRef = Valid_TSWIM1DocumentName then
			return EDIAction_TSWImportAllClear;
		elseif self.customsRef = Valid_TSWEX1DocumentName then
			return EDIAction_TSWExportAllClear;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
