    <JadeMethod name="utlCreateStopsForTIs" id="a931ef9c-1b33-47c7-98d6-ad10cabddbed">
        <updating/>
        <source>utlCreateStopsForTIs(_tiSet : CM_TISet; 
					_theStops : IntegerArray; 
					_passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/
vars
	ti		: CM_TrackedItem;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	if _tiSet = null then	
		app.raiseCMException2(MethodWithNullParam, method.name, "_tiSet", null, null);
		return;
	endif;
	
	if _theStops = null then	
		app.raiseCMException2(MethodWithNullParam, method.name, "_theStops", null, null);
		return;
	endif;
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	foreach ti in _tiSet do
		//ti.createStops(_theStops, false, true, _passport); //cnwrs1 par19389 June 2009 //- cnwmd1, Par 19903
		ti.createStops(_theStops, false, _tiSet.size &gt; 1, _passport); //+ cnwmd1, Par 19903
		// this looks wrong but is done like this because validateStops validates actual stops not stops integer array
		// this needs to be cleanup in JMT763
		ti.validateStops(TI_UPDMODE_NORMAL, false);  //cnwrs1 june 2009 par19389
		
		//epr par 21357 15/10/09 need notes for creating stops
		if not _passport.hasErrors then
//			ti.causeEvent(Object_Update_Event,false,self);
			self.updateObjectEdition(ti);
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
