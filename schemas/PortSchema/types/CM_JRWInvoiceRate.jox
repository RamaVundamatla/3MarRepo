<Class name="CM_JRWInvoiceRate" id="227964ec-bbb1-4174-a27e-3847882c0114">
    <superclass name="CM_JRWTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="allInvoiceRates" id="ec0a1f64-7562-489d-ab0f-3dc9eb5184ad">
        <memberTypeInverse/>
        <type name="CMIF_InvRateReporterSet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="effectiveDateTime" id="d9986ca4-b504-4374-a394-c1d1916cede9">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="expiryDateFrom" id="3d174dbb-f00d-4cb3-b44d-ab66ef0f2b98">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="expiryDateTo" id="9ce4c836-5a12-4327-a048-f6114c43bafb">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myBank" id="3a6f9b3c-6072-43e6-ab77-28f971f45278">
        <embedded/>
        <type name="CM_Bank"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDebtor" id="3d8456d0-f862-4bf6-835b-1ac2d91a6d3b">
        <embedded/>
        <type name="CM_Debtor"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myService" id="857b1596-573a-4d92-a49e-d8ba58eb0638">
        <embedded/>
        <type name="CM_Service"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myServiceGroup" id="6dd65454-2e24-48e2-ac9a-6793faf640e3">
        <embedded/>
        <type name="CM_ServiceGroup"/>
    </ImplicitInverseRef>
    <JadeMethod name="copyReportItemsToCollection" id="ed6912b2-72c3-4237-924d-a3cfde964d80">
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem : Integer);
//----------------------------------------------------------------------
// Created by 	cnwjre1	
// Date 		Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars

begin
	_collection.copy(self.allInvoiceRates);

epilog
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="4fafb997-d869-43a9-bd23-5edfe04f5e8e">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars

begin
	//tidy up the transients.
	self.allInvoiceRates.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getEffectiveDateTimeLocalTZ" id="010de80a-f53d-47a0-bfa8-a96db2e19cd9">
        <source>getEffectiveDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.effectiveDateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExpiryDateFromLocalTZ" id="b1647858-3bae-452e-852c-fc08a9cb9ca9">
        <source>getExpiryDateFromLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(expiryDateFrom,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getExpiryDateToLocalTZ" id="1698e150-6c82-44c8-b90f-0a218d4f5b66">
        <source>getExpiryDateToLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(expiryDateTo,TimeEndOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="cf44a597-3fd3-43e8-977a-78a303dbf9fc">
        <source>noOutputReturned(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars

begin
	return self.allInvoiceRates.isEmpty();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
