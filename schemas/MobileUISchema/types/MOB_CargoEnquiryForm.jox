    <JadeMethod name="doSearchCargoItem" id="67f94340-d042-4c99-8c01-0b43c128b699">
        <updating/>
        <source>doSearchCargoItem()updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	id 			: String;
	ti 			: CM_TrackedItem;
	result 		: Integer;
begin
	id := self.txt_CargoID.text.trimBlanks.toUpper;
	if id = null then
		return;
	endif;
	ti := self.myMobileDataAgent.findOnsiteCargoByID(id);
	if ti = null then
		result := app.msgBox (app.getErrorString(Item_NotFound), app.getErrorString(Item_NotFound), MsgBox_OK_Only);
		self.tbl_Display.rows := 0;
		self.txt_CargoID.text := "";
		self.txt_CargoID.setFocus;
		return;
	else
		self.setMyTI(ti);
		self.loadTable();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectedLocation" id="3b560547-2582-443b-84d2-eae7c42b54c8">
        <source>getSelectedLocation(): String;

vars

begin
	if myTI &lt;&gt; null then
		return myTI.getPrimaryLocation(REAL_MODE).getFullId;
	endif;
	return null;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="25db43dd-f504-4db4-bae4-0a65ab1291e7">
        <source>getTableSettings(_columns: Integer output; _header: String output);
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	_columns := 2;
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleF10Key" id="da911ccd-a986-49a6-b8ed-f416eae99a99">
        <source>handleF10Key();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/04/2013	cnwdap1	Initial creation PAR #31378 CCMS PNL 2247 Show Booking screen on F10
*/
vars
	ti				: CM_TrackedItem;
	bookingRef 		: CM_BookingRef;
	desc			: String;
	invalidObject	: Boolean;
	form			: MOB_CEBookingRefForm;

begin
	on Exception do app.handleDeletedObject(exception, bookingRef, invalidObject);
	
	ti := self.myTI;
	if ti = null then
		return;
	endif;
	if ti.myBookingRef = null then
		app.msgBox(app.getErrorString(Cargo_Item_No_Order_Number), "", MsgBox_OK_Only);
		return;
	endif;
	bookingRef := ti.myBookingRef;
	
	// check for deleted object
	desc := bookingRef.description;
	if invalidObject then
		return;
	endif;
	
	create form transient;
	form.setBookingRef(bookingRef);
	form.btn_Details.enabled := false;
	form.show;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleF3Key" id="007039e6-9982-4b80-87bb-2e00162af6e2">
        <updating/>
        <source>handleF3Key() updating;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
begin
	if self.myTI &lt;&gt; null then
		app.myMobileGUIAgent.loadRecordDamageForm(myTI);
	else
		app.msgBox(app.getErrorString(Damage_Nothing_Selected), "", MsgBox_OK_Only);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleF5Key" id="b3e4b783-8b65-46e1-b262-7ad5497287fd">
        <updating/>
        <source>handleF5Key() updating;

vars

begin
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleF6Key" id="1e4dd35b-d903-4a52-80a6-ab66baaf2802">
        <updating/>
        <source>handleF6Key() updating;

vars

begin
	if app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobMaintainAllocations) then
		app.myMobileGUIAgent.loadStorageAllocateForm(myTI, myTI.getPrimaryLocation(REAL_MODE));
	else
		app.msgBox(app.getErrorString1(NoPermission, 'allocate storage.'), '', MsgBox_OK_Only);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="1726c4a8-483a-4f3f-8229-e314dba2c39c">
        <source>loadTable();
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	propsToDisplay : CM_StringArray;
	prop : String;
begin
	create propsToDisplay transient;
	self.tbl_Display.rows := 0;
	if self.myTI &lt;&gt; null then
		if self.myTI.myProduct &lt;&gt; null then
			propsToDisplay.add('productCode');
		else
			propsToDisplay.add('cargoTypeDescr');
		endif;
		propsToDisplay.add('locationId');
		propsToDisplay.add('bookingReference');
		propsToDisplay.add('voyageCode');
		propsToDisplay.add('mark');
		propsToDisplay.add('weight');
		propsToDisplay.add('length');
		propsToDisplay.add('height');
	endif;
	
	foreach prop in propsToDisplay do
		self.addPropToTable(prop);
	endforeach;	
epilog
	delete propsToDisplay;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTI" id="dcd76677-1b87-4b74-bc6f-18d352fb1fb0">
        <updating/>
        <source>setMyTI(_ti : CM_TrackedItem input)updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myTI := _ti;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDisplayTable" id="6fa5522f-fe1a-4c1c-9548-82f4d5bc7250">
        <source>setupDisplayTable(tbl : CM_MobTable input);
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
intColumns 		: Integer;
	strHeader 		: String;
begin		
	self.getTableSettings(intColumns, strHeader);
	tbl.setMargins();
	tbl.selectMode := tbl.SelectMode_Row;
	tbl.fontSize := 16;
	
	tbl.columns := intColumns;
	tbl.rows := 0;
	tbl.defaultRowHeight := 36;
	tbl.accessColumn(1);
	tbl.accessedColumn.fontSize := 16;
	tbl.accessedColumn.foreColor := Red;
	tbl.gridLines := true;
	tbl.setFixedColours();
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e2155bb1-682e-47d2-8418-8c684457144a">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	setMyTI(myMainObject.CM_TrackedItem);
	loadTable;
	self.lbl_Title.caption := app.getErrorString(Cargo_Enquiry); 
	self.setupDisplayTable(self.tbl_Display);
	if self.myTI &lt;&gt; null then
		self.txt_CargoID.text := self.myTI.id.String;
		self.loadTable();
	else
		self.txt_CargoID.setFocus();
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="53975ded-27eb-4f72-93ba-e99e842e174a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017600, locale);
	btn_Cancel.translateCaption(Xlat_0012988, locale);
	lbl_CargoID.translateCaption(Xlat_0012989, locale);
	lbl_Title.translateCaption(Xlat_0012990, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
