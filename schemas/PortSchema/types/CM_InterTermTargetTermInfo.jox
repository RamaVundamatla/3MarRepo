    <JadeMethod name="createProxy" id="79c4f3ad-f631-4bf9-b7f0-2bd9c8b6d9b1">
        <updating/>
        <source>createProxy() : CM_InterTermTargetTermInfo updating;
/*

Purpose:			Create a transient copy of self

Parameters:			

Return Value:		Transient copy of self

Date				Who		Reason
04 February 2010	conkc1	Initial creation
*/
vars

	ittti : CM_InterTermTargetTermInfo;
begin

	create ittti transient;
	ittti.myDefaultTargetTermArea := self.myDefaultTargetTermArea;
	ittti.myTargetTerminal        := self.myTargetTerminal;
	ittti.autoPlanAtDestTerminal  := self.autoPlanAtDestTerminal;
	return ittti;

epilog

end;</source>
        <ReturnType type="CM_InterTermTargetTermInfo"/>
    </JadeMethod>
    <JadeMethod name="update" id="6a76175e-ca77-49a1-b77b-89db4383fb2b">
        <updating/>
        <source>update(pProxy : CM_InterTermTargetTermInfo) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 February 2010	conkc1	Initial creation

*/
vars

begin
	self.myDefaultTargetTermArea  := pProxy.myDefaultTargetTermArea;
	self.myTargetTerminal         := pProxy.myTargetTerminal;
	self.autoPlanAtDestTerminal   := pProxy.autoPlanAtDestTerminal;
epilog

end;</source>
        <Parameter name="pProxy" type="CM_InterTermTargetTermInfo"/>
    </JadeMethod>
    <JadeMethod name="updateProxy" id="ccdca42d-c115-47f4-a4cc-ac5199dbe117">
        <updating/>
        <source>updateProxy(_autoPlan : Boolean; _terminalArea : CM_TerminalArea; _terminal : CM_Terminal) updating;
/*
Purpose:			Populate self with the above data

Parameters:			

Return Value:		

Date				Who		Reason
04 February 2010	conkc1	Initial creation
*/
vars

begin

	self.myDefaultTargetTermArea  := _terminalArea;
	self.myTargetTerminal         := _terminal;
	self.autoPlanAtDestTerminal   := _autoPlan;
epilog

end;</source>
        <Parameter name="_autoPlan" type="Boolean"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
