    <JadeMethod name="setValues" id="b63dc654-f58e-4049-8b05-88d3649c104c">
        <updating/>
        <source>setValues(pWBName:String;
			pWBDescription: String;
			pWBDataWS: String;
			pWBHideDataSheet: Boolean;
			pWBTopSheet: String) updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	workbookName 			:= pWBName;
	workbookDescription 	:= pWBDescription;
	workbookDataWorksheet 	:= pWBDataWS;
	workbookHideDataSheet	:= pWBHideDataSheet;
	workbookTopWorksheet 	:= pWBTopSheet;

epilog

end;</source>
        <Parameter name="pWBName" type="String"/>
        <Parameter name="pWBDescription" type="String"/>
        <Parameter name="pWBDataWS" type="String"/>
        <Parameter name="pWBHideDataSheet" type="Boolean"/>
        <Parameter name="pWBTopSheet" type="String"/>
