    <JadeMethod name="getDisplayStringForAttribute" id="9c4ae6fc-9342-4a62-81f9-de9be68a514f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin

	if _attrName = ETRow_HasInvoices then
		return self.allInvoices.isNotEmpty().getYesNo();
	elseif _attrName = ETRow_Operator then
		return self.operatorCode;
	elseif _attrName = ETRow_Debtor then
		return self.debtorCode;
	elseif _attrName = ETRow_Stage then
		return app.getVoyageStageFromEnum(self.stage);
	elseif _attrName = ETRow_Type then
		return getTypeDescription();
	elseif _attrName = ETRow_DateTime then
		return self.dateTime.asStringJMT();
	elseif _attrName = ETRow_Status then
		return self.getStatusDescription(self.status);
	elseif _attrName = ETRow_Description then
		return self.description;													//navra1 - CR 66185 - 18th Sep 2024
		//return self.ediDataDesc;													//navra1 - CR 66185 - 18th Sep 2024
	elseif _attrName = ETRow_LastModified then
		return self.lastUpdateTime.asStringJMT();
	elseif _attrName = ETRow_FailureMessage then
		return self.failureMessage;	
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="2bec0292-d9f0-438c-bc79-6a09508d1581">
