    <JadeMethod name="positionQueryFrame" id="a5f3b20a-6919-4aaf-afa0-e7722df9719a">
        <source>positionQueryFrame() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlgma1	Initial creation

*/

vars

begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	50;			// position higher
	self.frmQuery.height	:=	410 ;		// stretch to fit the debtor and service multi-select group boxes
	self.frmQuery.width		:=	460;		// stretch to fit the debtor and service multi-select group boxes
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setBaseRateEntry" id="a0b1ffc5-abbe-4522-a2c8-dc2b81e19e3c">
        <updating/>
        <source>setBaseRateEntry()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	invalidObj : Boolean;
	rate : CM_Rate;
	debtorNode : CM_DebtorNode;
	rootDebtorGroup : CM_RootDebtorGroup;
	service: CM_Service;
	ts : TimeStamp;

begin

	self.myBaseRateEntry := null;
	
	if self.mode = self.Mode_Update then
		if self.myCurrentRateEntry = null then
			return;
		endif;
		
		on Exception do app.handleDeletedObject(exception, self.myCurrentRateEntry, invalidObj );
		
		debtorNode := self.myCurrentRateEntry.getMyDebtorNode();	
		if debtorNode = null or debtorNode.bank = null then
			return;
		endif;
		
		rootDebtorGroup := debtorNode.bank.getRootDebtorGroup;
		if debtorNode = rootDebtorGroup then
			//we are already using the 'base' rate entry value.
			self.myBaseRateEntry := self.myCurrentRateEntry;
		else
			service := self.myCurrentRateEntry.rate.service;
			ts := self.myCurrentRateEntry.startTimestamp;
			self.myBaseRateEntry := rootDebtorGroup.getServiceTimeRate( service, ts );
		endif;
	// PAR 31696
	elseif self.mode = self.Mode_Add then
		debtorNode := self.myCurrentDebtor;
		if debtorNode = null or debtorNode.bank = null then
			return;
		endif;
		
		rootDebtorGroup := debtorNode.bank.getRootDebtorGroup;
		if debtorNode = rootDebtorGroup then
			//we are already using the 'base' rate entry value.
			self.myBaseRateEntry := self.myCurrentRateEntry;
		else
			service := self.myCurrentService;
			ts := app.actualTimeServer;
			self.myBaseRateEntry := rootDebtorGroup.getServiceTimeRate( service, ts );
		endif;
	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="2c60d431-6d55-4cdd-b1db-15ff8335a4c8">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
