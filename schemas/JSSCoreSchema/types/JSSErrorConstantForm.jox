    <JadeMethod name="findExceptionConstantCategory" id="a70af72c-d87c-4c36-aba9-8aeef686186c">
        <source>findExceptionConstantCategory(pTheSchema:Schema):ConstantCategory protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCategory		: ConstantCategory;
	allCategories	: ConstCategoryNDict;
	prefixLength	: Integer;
	categoryName	: String;
	
begin
	prefixLength	:=	JSS_EXCEPTION_NAME_PREFIX.length;
	allCategories	:=	pTheSchema.getPropertyValue("constantCategories").ConstCategoryNDict;
	
	foreach theCategory in allCategories do
		categoryName	:=	theCategory.name;
		
		if categoryName.length &lt; prefixLength then
			continue;
		elseif categoryName[1:prefixLength] = JSS_EXCEPTION_NAME_PREFIX then
			return theCategory;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
        <ReturnType type="ConstantCategory"/>
    </JadeMethod>
</GUIClass>
