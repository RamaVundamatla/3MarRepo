    <JadeMethod name="moveTiToWagon" id="3cdda527-c570-499f-9746-14c3e494507d">
        <source>moveTiToWagon(_ti: CM_TrackedItem; _destination: Any);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519
8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
*/

vars
	moveController	: CMIF_MoveController;
	destination: CM_LocationsController;
begin
	if _destination.isKindOf(CM_LocationsController) then
		destination := _destination.CM_LocationsController;
	elseif _destination.isKindOf(CM_TerminalArea) then
		destination := _destination.CM_TerminalArea.allLocationsControllers.first;
	endif;

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="Any"/>
    </JadeMethod>
    <JadeMethod name="moveToGroundUsingHH" id="d46b3359-d846-40ee-965b-b2c3c5fbd0bf">
        <source>moveToGroundUsingHH(_ti : CM_TrackedItem io; _voyageJob : CM_VoyageJob; _crane : CM_Crane);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwmh5	Initial creation

*/

vars

	lanes			: CM_LCArray;

begin

	create lanes transient;
	_crane.getLanes(lanes);
	
	app.myTrxUA.trxLanderDischargeToGround(GroundComplete, _ti, lanes.first, _voyageJob, _ti.allWorklistEntries.first, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_REC_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(_ti, TRANS_TYPE_WHARFAGE);

epilog
	
	delete lanes;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_crane" type="CM_Crane"/>
