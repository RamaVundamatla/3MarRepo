    <JadeMethod name="valUpdateOnePortStatuses" id="ae852903-39d3-43bc-84b0-ae88056455bc">
        <source>valUpdateOnePortStatuses(_terminal : CM_Terminal; _statuses : CM_NameValuePairDict);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
	
	nvPair		: CM_NameValuePair;
	sa			: StringArray;
	inUsed		: Boolean;
	name		: String;
	mtnStatus,
	idx			: Integer;
begin
	
	create sa transient;
	
	// check for duplicate name
	foreach nvPair in _statuses do
		name := nvPair.name;
		
		// Already exists
		if sa.includes(name) then
			// raise error
			app.raiseCMException1(OnePortDuplicateStatus, name, null, nvPair);
			continue;
		endif;
		
		idx := 1;
		mtnStatus 	:= nvPair.value.scanUntil("|", idx).Integer;
		inUsed		:= nvPair.value.endsWith("|1");
		
		// If we are using the Status, make sure it has valid MTN Status
		if inUsed and not app.isValidHMSMovementStatus(mtnStatus) then
			// raise error
			app.raiseCMException2(OnePortInvalidMTNStatus, name, mtnStatus.String, null, nvPair);
			continue;
		endif;
		
		sa.add(name);
	endforeach;
	
epilog
	delete sa;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_statuses" type="CM_NameValuePairDict"/>
    </JadeMethod>
