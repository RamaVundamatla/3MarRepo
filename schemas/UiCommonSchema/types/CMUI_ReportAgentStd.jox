    <JadeMethod name="getSelectedSites" id="1efed85a-955d-4315-b754-ad7696f238ae">
        <source>getSelectedSites(_siteArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     09 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	strObj	: Object;
	site	: Integer;
begin

	if _siteArray = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_siteArray', null, null);
		return;
	endif;

	foreach strObj in self.myLstTblSiteState.allSelectedObjects do
		site := app.siteStringToEnum(strObj.CM_String.string);
		//par14062 Mohammad 16/5/2007
		/*if site = TI_SITE_UNDEFINED then
			continue; 
		endif;*/
		
		_siteArray.add(site);
	endforeach;

end;</source>
        <Parameter name="_siteArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
