        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

begin

	if txtCargoId.text = lblCargoId.caption.toUpper then
