    <JadeMethod name="btnBack_click" id="8dfddb80-01ff-42e8-a783-c88039ce9a1e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBack_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		27 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.doShowFrmMain();
end;</source>
