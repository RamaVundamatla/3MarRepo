    <JadeMethod name="getCargoLoadTime" id="4777484a-344d-4c24-8ac3-aeba7128398f">
        <source>getCargoLoadTime():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		12 March 2007 by cnwdad1
//
// Purpose:		Returns the timestamp when the Voyage's cargo is deemed to have been
//				loaded.
//
// Parameters:	None
//
// Returns:		The timestamp when the cargo has been loaded, or the departure
//				timestamp, whichever is the earliest.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	globalVoyObj	: CM_VoyageGlobal;
	vesselObj		: CM_Vessel;
	arrivalTime		: TimeStamp;
	loadTime		: TimeStamp;
	timeDeparting	: TimeStamp;
	loadHours		: Decimal[12,2];		// The number of hours it takes to load the Vessel.
	loadMins		: Integer;
	
begin
	globalVoyObj	:=	self.getGlobalVoyage();
	
	if globalVoyObj = null then
		return null;
	else
		vesselObj	:=	globalVoyObj.getMyVessel();
	endif;
	
	if vesselObj = null then
		if self.myTerminal = null then
			return null;
		else
			loadHours	:=	self.myTerminal.getConfig(GrossLoadingTime).Decimal;
		endif;
	else
		loadHours	:=	vesselObj.getGrossDischargeTime(self.myTerminal);
	endif;
	
	arrivalTime		:=	self.arrivedDT;
	timeDeparting	:=	self.departedDT;
	loadMins		:=	(loadHours * 60) div 2;
	loadTime		:=	arrivalTime.cnEcAddMinutes(loadMins);
	

	if loadTime &gt; timeDeparting then

		return timeDeparting;
	else
//if loadTime &lt; arrivalTime then

//else

//endif;
		return loadTime;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCargoManifestStr" id="903e242e-a72a-4eac-bc4d-930a46373e64">
        <source>getCargoManifestStr() : String;
/*

Purpose:			Gets the cargo manifest information as a CSV String

Parameters:			NONE

Return Value:		String: Containing a CSV format

Date		Who		Reason
05 Apr 2022	navpw1	Initial creation TFS: 53132
01 Feb 2024 navbs1  Bug 62255: GPHA -- 1310 Stack Dump error when extracting the CM_Voyage class to a external SQL Server DB
28 Feb 2024 navhl20 Bug 62671: MTN - Expose CM_WorkPointType class for data export to fix the unit test
*/

vars
	ti					: CM_TrackedItem;
	cargoManifest		: CMIF_CargoManifest;
	cargoManifests		: CMIF_CargoManifests;
	measureType			: CM_MeasurementType;
	cargoManifestCsv,
 	mode,
	cargoTypeId			: String;	// ### TFS 56103 23Feb2023 NAVPW1
	
begin
	create cargoManifests transient;
	
	foreach ti in self.allOnshipTIsByCargoTypeId do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
			
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
			
		endif;
		
		// ### TFS 56103 23Feb2023 NAVPW1
		if ti.myCargoType &lt;&gt; null then
			cargoTypeId := ti.myCargoType.id.String;
		else
			cargoTypeId := ti.cargoType.String;
		endif;
		// ### TFS 56103 23Feb2023 NAVPW1
		
		//cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		cargoManifest := cargoManifests[mode, cargoTypeId];	// ### TFS 56103 23Feb2023 NAVPW1
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			//cargoManifest.setProxyForCreate(ti.myCargoType.id.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifest.setProxyForCreate(cargoTypeId, ti.myCargoType, null, ti.totalWeight, mode);	// ### TFS 56103 23Feb2023 NAVPW1
			//cargoManifests.addNoDuplicates(cargoManifest, false);	//01.02.2024 navbs1 #62255			//28.02.2024 navhl20 #62671
			if not cargoManifests.addNoDuplicates(cargoManifest, false) then							//28.02.2024 navhl20 #62671
				delete cargoManifest;
			endif;
		endif;
	endforeach;
	
	foreach ti in self.allOnsiteTIsByCargoTypeId do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
			
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
			
		endif;
		
		// ### TFS 56103 23Feb2023 NAVPW1
		if ti.myCargoType &lt;&gt; null then
			cargoTypeId := ti.myCargoType.id.String;
		else
			cargoTypeId := ti.cargoType.String;
		endif;
		// ### TFS 56103 23Feb2023 NAVPW1
		
		//cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		cargoManifest := cargoManifests[mode, cargoTypeId];	// ### TFS 56103 23Feb2023 NAVPW1
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			//cargoManifest.setProxyForCreate(ti.myCargoType.id.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifest.setProxyForCreate(cargoTypeId, ti.myCargoType, null, ti.totalWeight, mode);	// ### TFS 56103 23Feb2023 NAVPW1
			//cargoManifests.addNoDuplicates(cargoManifest, false);	//01.02.2024 navbs1 #62255			//28.02.2024 navhl20 #62671
			if not cargoManifests.addNoDuplicates(cargoManifest, false) then							//28.02.2024 navhl20 #62671
				delete cargoManifest;
			endif;
		endif;
	endforeach;
	
	foreach ti in self.allOffsiteTIsByCargoTypeId do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
			
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
			
		endif;
		
		// ### TFS 56103 23Feb2023 NAVPW1
		if ti.myCargoType &lt;&gt; null then
			cargoTypeId := ti.myCargoType.id.String;
		else
			cargoTypeId := ti.cargoType.String;
		endif;
		// ### TFS 56103 23Feb2023 NAVPW1
		
		//cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		cargoManifest := cargoManifests[mode, cargoTypeId];	// ### TFS 56103 23Feb2023 NAVPW1
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			//cargoManifest.setProxyForCreate(ti.myCargoType.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifest.setProxyForCreate(cargoTypeId, ti.myCargoType, null, ti.totalWeight, mode);	// ### TFS 56103 23Feb2023 NAVPW1
			//cargoManifests.addNoDuplicates(cargoManifest, false);	//01.02.2024 navbs1 #62255			//28.02.2024 navhl20 #62671
			if not cargoManifests.addNoDuplicates(cargoManifest, false) then							//28.02.2024 navhl20 #62671
				delete cargoManifest;
			endif;
		endif;
	endforeach;
	
	foreach ti in self.allNotifiedTIsByCargoTypeId do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
			
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
			
		endif;
		
		// ### TFS 56103 23Feb2023 NAVPW1
		if ti.myCargoType &lt;&gt; null then
			cargoTypeId := ti.myCargoType.id.String;
		else
			cargoTypeId := ti.cargoType.String;
		endif;
		// ### TFS 56103 23Feb2023 NAVPW1
		
		//cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		cargoManifest := cargoManifests[mode, cargoTypeId];	// ### TFS 56103 23Feb2023 NAVPW1
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			//cargoManifest.setProxyForCreate(ti.myCargoType.id.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifest.setProxyForCreate(cargoTypeId, ti.myCargoType, null, ti.totalWeight, mode);	// ### TFS 56103 23Feb2023 NAVPW1
			//cargoManifests.addNoDuplicates(cargoManifest, false);	//01.02.2024 navbs1 #62255			//28.02.2024 navhl20 #62671
			if not cargoManifests.addNoDuplicates(cargoManifest, false) then							//28.02.2024 navhl20 #62671
				delete cargoManifest;
			endif;
		endif;
	endforeach;
	
	//Build String from data
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	
	foreach cargoManifest in cargoManifests do
		if cargoManifest.myCargoType = null or cargoManifest.mode = null then
			continue;
		endif;
		
		cargoManifestCsv &amp;= cargoManifest.myCargoType.description &amp; " - " &amp; cargoManifest.getDefaultMeasureTotalWeight() &amp; measureType.shortName &amp; " - " &amp; cargoManifest.mode;
		cargoManifestCsv &amp;= ", ";
	endforeach;
	
	cargoManifestCsv := cargoManifestCsv.stripTrailingChar(",");
	
	return cargoManifestCsv;

epilog
	cargoManifests.purge();					//28.02.2024 navhl20 #62671
	delete cargoManifests;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoOpEndDate" id="9e43df6d-16fa-47b4-974b-dd4a58c2c510">
        <source>getCargoOpEndDate():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		15 February 2008 by cnwdad1
//
// Purpose:		ONLY FOR Global Voyage Commodity Planning.
//
// Parameters:	None
//
// Returns:		The actual cargo operation end date if is valie.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/09/2011	cnwcs5		CCMS RIO 2041 / PAR 28220 START/STOP TIMES
// --------------------------------------------------------------------------------
vars
	voyageDataObj	: HMS_VoyageData;
	movement		: HMS_VoyageMovement;
	interval		: CM_TimeStampInterval;
	cargoOpEndDate,
	startDT, endDT	: TimeStamp;
	
begin
	voyageDataObj	:=	self.myHMSVoyageData;
	
	if voyageDataObj = null then
		return null;
	endif;
	
	cargoOpEndDate := null;
	
	foreach movement in voyageDataObj.allVoyageMovements do
		if movement.myPreviousMovement &lt;&gt; null and movement.myPreviousMovement.isForTerminal() then 
			interval := movement.allCargoOperationsIntervals.last;
			
			if interval = null then
				continue;
			endif;
			
			startDT := interval.startDT;
			endDT 	:= interval.endDT;
			
			if startDT.isValid and endDT.isValid then 
				if startDT &gt;= self.arrivedDT and endDT &lt;= self.departedDT then
					if (not cargoOpEndDate.isValid) or (cargoOpEndDate.isValid and cargoOpEndDate &lt; endDT) then
						cargoOpEndDate := endDT;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return cargoOpEndDate;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypes" id="74b7984d-ad0a-47e6-b413-33960a31f51b">
        <source>getCargoTypes(_cargoTypes : CM_CargoTypeSet input; _subTypes : CM_ProductSet input; _commodities : CM_CommoditySet input);
/*
Purpose - 	
Who - NAVAB1
Date - 06AUG2024
ADO - CR 65328 TASK 65329
*/

vars
	commodity : CM_Commodity;
	cargodesc : String;
	ti : CM_TrackedItem;
	cargotype : CM_CargoType;
	cargoForecast : CM_CargoForecast;
	subType : CM_Product;
	comm : CM_Commodity;
	tis : CM_TIByCargoTypeIdDict;
begin

	create tis transient;
	self.allOnshipTIsByCargoTypeId.copyNoDuplicates(tis, false);
	self.allOnsiteTIsByCargoTypeId.copyNoDuplicates(tis, false);
	self.allNotifiedTIsByCargoTypeId.copyNoDuplicates(tis, false);
	self.allOffsiteTIsByIdCargoType.copyNoDuplicates(tis, false);

	foreach ti in tis discreteLock do
		if not _cargoTypes.includes(ti.myCargoType) then
			_cargoTypes.addNoDuplicates(ti.myCargoType, false);
		endif;
		
		subType := ti.myProduct;
		if subType &lt;&gt; null 
		and not _subTypes.includes(subType) then
			_subTypes.addNoDuplicates(subType, false);
		endif;
		
		comm := ti.getCommodityObject;
		if comm &lt;&gt; null 
		and not _commodities.includes(comm) then
			_commodities.addNoDuplicates(comm, false);
		endif;
	endforeach;
	
epilog

	delete tis;
end;</source>
        <Parameter name="_cargoTypes" type="CM_CargoTypeSet" usage="input"/>
        <Parameter name="_subTypes" type="CM_ProductSet" usage="input"/>
        <Parameter name="_commodities" type="CM_CommoditySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCashInvoice" id="38608810-429d-4112-84be-e174353c74c5">
        <source>getCashInvoice() : CM_Invoice;
 /*

Purpose:			// TFS 37454

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgab1	Initial creation

*/

vars
	cp		: CM_CashPayment;
	cr		: CM_CashReceipt;
	invoice,
	cashInvoice	: CM_Invoice;
begin
	foreach cp in self.allCashPayments do
		if cp.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		// 35232 skip voided payments
		if cp.voided then
			continue;
		endif;
		cr := cp.myCashReceipt;
		if cr &lt;&gt; null then
			invoice := cr.myCashInvoice;
			if invoice &lt;&gt; null and
			   not invoice.isVoided and
			  // not invoice.status = CM_Invoice.INVOICE_POSTED and
			   not invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
			   then
				cashInvoice := invoice;
				break;
			endif;
		endif;
	endforeach;

	return cashInvoice;
epilog

end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getColourAsRBG" id="00bf8874-cab6-4509-b1b8-fd9c453f0ad0">
        <source>getColourAsRBG():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2014	cnwndl1	Initial creation	Par 34218

*/

vars

	red : Integer;
	green : Integer;
	blue : Integer;
	colourString : String;

begin

	//As Hexideciaml
//	colourString := self.colou.cnEcGetHexColor();
//	return colourString;

	//As RGB
	self.colour.cnEcGetRGBValues (red,green,blue);
	colourString := red.String &amp; ':' &amp; green.String &amp; ':' &amp; blue.String;
	return colourString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getComboBoxDisplayString" id="12277baa-6076-4953-bddb-4b371119e712">
        <source>getComboBoxDisplayString( arrival : Boolean ) : String;
//-----------------------------------------------------------------------
//	Created:	01 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	globalVoy : CM_VoyageGlobal;
begin
	if arrival then
		globalVoy := self.myVoyageGlobalArrival;
	else
		globalVoy := self.myVoyageGlobalDeparture;
	endif;
	if globalVoy &lt;&gt; null then // an error was produced when the LVO form was opened. 18/5/2007
		if globalVoy.noOfVoyageForThisTerminal ( self.myTerminal ) &gt; 1 then
			return self.myTerminal.name &amp; " " &amp; self.arrivedDT.display ;
		else
			return self.myTerminal.name;
		endif;
	else
		return null;
	endif;
	
epilog

end;</source>
        <Parameter name="arrival" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
