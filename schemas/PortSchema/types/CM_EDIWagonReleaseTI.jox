    <JadeMethod name="getDisplayStringForAttribute" id="ecd7f242-1189-47b8-a439-3d648aefc268">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2022	navra1	Initial creation

*/

vars

begin
	if _attrName = ETRow_AssignedAnyAmount then
		if self.isAssignedAnyAmountTrue(self.assignedAnyAmount) = true then
			return 'Yes';
		else
			return 'No';
		endif;
	endif;	
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
