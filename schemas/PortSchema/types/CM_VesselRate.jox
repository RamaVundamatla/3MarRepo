    <JadeMethod name="getTimeRate" id="436b1770-7d93-4ea3-8d98-35783125938a">
        <source>getTimeRate(bank: CM_Bank; t: TimeStamp): CM_RateEntry;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
vars
	iter : Iterator;
	found : Boolean;
	retVal : CM_RateEntry;

begin
	iter := self.rateEntries.createIterator;
	self.rateEntries.startKeyLeq(t, iter);
	found := false;
	while iter.back(retVal) do
		if retVal.ignoreThisEntry then
			continue;
		endif;
		if retVal.expiryTimestamp &lt;&gt; null and
		   retVal.expiryTimestamp &lt;= t then
			continue;
		endif;
		found := true;
		break;
	endwhile;
	if not found then
		retVal := null;
	endif;
	return retVal;
epilog

end;</source>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b103a4c8-de22-4607-9676-5ea493a441ce">
        <updating/>
        <source>setForCreate(_pxyRate: CM_VesselRate) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
vars

begin
	inheritMethod(_pxyRate);
	self.myVessel := _pxyRate.myVessel;
epilog

end;</source>
        <Parameter name="_pxyRate" type="CM_VesselRate"/>
    </JadeMethod>
