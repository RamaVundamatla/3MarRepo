    <JadeMethod name="create" id="97732005-86d6-45d1-bdbd-8064bd8d67cc">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Coparn, null);
	
	if type = null or type.type &lt;&gt; EDIFileType_Coparn then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Coparn file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBookingIgnoreText" id="47937fd9-9809-4492-9e05-5d76a774ab87">
        <source>doBookingIgnoreText(_text :String io);
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	rule :CM_EDIRule;
begin
	foreach rule in self.allEDIPartyRules do
		if rule.getItem &lt;&gt; CM_EDIEDIFactRule.Item_FTX_4_1 or rule.getFunction &lt;&gt; CM_EDIEDIFactRule.Function_FTX_4_1_BookingIgnore then
			continue;
		endif;
		
		// just keep ignoring - there could be &gt; 1 thing in there
		rule.doBookingIgnoreText (_text);
	endforeach;
epilog

end;</source>
        <Parameter name="_text" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCoparnEDIDataStyle" id="d472a1e6-3997-4c13-870a-f205d295d2e5">
        <source>getCoparnEDIDataStyle() : Boolean;
//
// 09 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
// 29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// false for new style ie EDI Gate Document
// true for old style ie EDI BookingMultiLine / ReleaseRequest single line
vars
	value : String;
begin
	global.getExtraData(self.allExtraData, "CoparnEDIDataStyle", value);
	if value = null then
		value := false.String;
	endif;
//	value := false.String;			
	return value.Boolean;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyage" id="2f5a8246-6c36-4ec7-9c5d-e965c36df9cd">
        <source>getDefaultVoyage():CM_Voyage;
/*
Date		Who		Reason
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual
*/
vars
	gotException	:Boolean;
	voyage			:CM_Voyage;
begin
	on Exception do app.handleDeletedObject (exception, voyage, gotException);
	
	voyage := self.myDefaultVoyage;
	
	if voyage = null then
		return null;
	endif;
	
	if voyage.edition &gt;= 0 then
		return voyage;
	endif;
		
	// must have got an exception
	return null;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getFTXMTGradeText" id="d63e67f7-d954-4960-af42-deaaacdc86c5">
        <source>getFTXMTGradeText(_segment :String; _remarks :String output):Boolean;
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	ftxString, dummy, remarks040	:String;
begin
	ftxString := _segment [5:end];		// strip off 'FTX+'
	
	if ftxString &lt;&gt; null then
		ftxString := ftxString[1:ftxString.length()-1];	// strip off "'"
	endif;
	
	if not self.isMatchForFunction (CM_EDIEDIFactRule.Item_FTX_1_1, ftxString, CM_EDIEDIFactRule.Function_FTX_1_1_BookingRemark, dummy, remarks040) then
		// segment does not contain booking remarks
		return false;
	endif;
	
	// do we have any text to ignore in our remarks
	
	// get rid of any ":" characters
	remarks040.replaceChar (":", " ");
epilog

end;</source>
        <Parameter name="_segment" type="String"/>
        <Parameter name="_remarks" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeForGenerator" id="5ec2d1ad-f8f2-4d04-8324-cf89a6281296">
        <source>getISOTypeForGenerator():String;
/*
Date		Who		Reason
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual
*/
vars
	gotException	:Boolean;
	iso				:CM_ISOType;
	result			:String;
begin
	on Exception do app.handleDeletedObject (exception, iso, gotException);
	
	iso := self.myISOTypeForEQD_plus_RD;
	
	if iso = null then
		return null;
	endif;
	
	result := iso.code;
			
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRelByTypeOnly" id="efbd0bd8-097f-4761-8674-cca6bd10c7c1">
        <source>getRelByTypeOnly(): Boolean;

/*

Purpose:	get method for par 33790	

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2014	cnwrd1	Initial creation

*/

vars

begin

	return self.releaseByTypeOnly;	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="09b9202e-9c5c-4551-a908-93e5ca4bdd57">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
26/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - new properties
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual

*/
vars
	proxy	:CM_EDIPartyCoparnRules;
begin
	proxy :=  inheritMethod();
	
	proxy.myDefaultCarrier			:= self.myDefaultCarrier;
	proxy.myDefaultSubTerminal		:= self.myDefaultSubTerminal;
	proxy.myDefaultVoyage			:= self.getDefaultVoyage;		// par 32094(3)
	proxy.myISOTypeForEQD_plus_RD	:= self.myISOTypeForEQD_plus_RD;
	
	proxy.sendEmailForBlockedDel	:= self.sendEmailForBlockedDel;	// par 29481 May 2012
	proxy.sendEmailForBlockedUpd	:= self.sendEmailForBlockedUpd;	// par 29481 May 2012
	proxy.releaseByTypeOnly 		:= self.releaseByTypeOnly; //cnwrd1 33790

	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCoparnEDIDataStyle" id="86537f8e-c14b-4613-8d69-d28d10b73bc4">
        <source>setCoparnEDIDataStyle(_value : Boolean);
//
// 09 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
// true for new style ie EDI Gate Document
// false for old style ie EDI BookingMultiLine / ReleaseRequest single line
vars

begin
	global.setExtraData(self.allExtraData, self, "CoparnEDIDataStyle", _value);
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="25b8c7b7-164c-4396-bec9-3008f65b618e">
        <updating/>
        <source>setForUpdate(_proxy :CM_EDIPartyCoparnRules)updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
30/08/2012	cnwcs5	par 30097 - configure delete/update rules
19 Feb 2013	cnwcs5	CCMS PNL 2243 / par 31185
06/06/2017	cnwdap1	TFS 4434 	SNO COPARN Prenotes and VGM Updates
22/08/2017	jlgdap1	TFS 6632 	POL Make COPARN Prenotes optional
14 Nov 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
02/05/2019	jlgzm1	TFS 43425 	SNO Append new bookings rather than replace
01/08/2019	jlgka1 	TFS 45467	SNO - Clean attribute in release request
============================================================================*/
begin
	inheritMethod (_proxy);
	
	self.allowDelActioned				:= _proxy.allowDelActioned;		// par 30097 August 2012
	self.allowDelArchived				:= _proxy.allowDelArchived;		// par 30097 August 2012
	self.allowDelCompleted				:= _proxy.allowDelCompleted;	// par 30097 August 2012
	self.allowUpdActioned				:= _proxy.allowUpdActioned;		// par 30097 August 2012
	self.allowUpdArchived				:= _proxy.allowUpdArchived;		// par 30097 August 2012
	self.allowUpdCompleted				:= _proxy.allowUpdCompleted;	// par 30097 August 2012
	
	self.createReleaseForEQA_plus_RD	:= _proxy.createReleaseForEQA_plus_RD;
	self.defaultAvailabilityGrade		:= _proxy.defaultAvailabilityGrade;
	self.defaultAvailabilityGradeReefer	:= _proxy.defaultAvailabilityGradeReefer;
	self.defaultDeliveryReasonCode		:= _proxy.defaultDeliveryReasonCode;
	self.defaultDeliveryReasonDesc		:= _proxy.defaultDeliveryReasonDesc;
	self.defaultReleaseStatus			:= _proxy.defaultReleaseStatus;	//  par 31185 Feb 2013
	self.defaultReleaseType				:= _proxy.defaultReleaseType;
	self.myDefaultCarrier				:= _proxy.myDefaultCarrier;
	self.myDefaultSubTerminal			:= _proxy.myDefaultSubTerminal;
	self.myDefaultVoyage				:= _proxy.myDefaultVoyage;
	self.myISOTypeForEQD_plus_RD		:= _proxy.myISOTypeForEQD_plus_RD;
	self.resetCompletedOnQtyIncrease	:= _proxy.resetCompletedOnQtyIncrease;	// par 31185 Feb 2013
	self.sendEmailForDeletes			:= _proxy.sendEmailForDeletes;
	self.sendEmailForUpdates			:= _proxy.sendEmailForUpdates;
	self.sendEmailForBlockedDel			:= _proxy.sendEmailForBlockedDel;		// par 29481 May 2012
	self.sendEmailForBlockedUpd			:= _proxy.sendEmailForBlockedUpd;		// par 29481 May 2012
	self.releaseByTypeOnly				:= _proxy.releaseByTypeOnly;			// cnwrd1 33790
	self.updateVGMForOnsiteCargo		:= _proxy.updateVGMForOnsiteCargo;		// TFS 4434
	self.createPrenotesForEQDWithID		:= _proxy.createPrenotesForEQDWithID;	// TFS 6632
	self.appendNewBookings				:= _proxy.appendNewBookings;			// TFS 43427
	self.defaultReleaseIncludeNonClean	:= _proxy.defaultReleaseIncludeNonClean; // jlgka1 TFS 45467
	
	self.useISOGroupForReleaseRequests	:= _proxy.useISOGroupForReleaseRequests;
	self.setCoparnEDIDataStyle(_proxy.getCoparnEDIDataStyle);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="275b5480-916f-4734-899e-228823edc923">
        <updating/>
        <source>setProxy(_blockUpdActioned, _blockUpdArchived, _blockUpdCompleted, _blockDelActioned, _blockDelArchived, _blockDelCompleted,
			_emailUpdate, _emailDelete, _emailUpdateErr, _emailDeleteErr, _resetCompleted, _useISOGroup, _createGenRR :Boolean;
			_subTerminal :CM_SubTerminal; _carrier :CM_Carrier; _releaseType, _releaseStatus :Integer;
			_voyage :CM_Voyage; _reasonDesc :String; _gradeDry, _gradeReefer :Integer;
			_genISOType :CM_ISOType; _relByTypeOnly : Boolean; _updateVGMForOnsite : Boolean; _createPrenotes : Boolean;
			_appendBookings : Boolean; _useOldStyleCoparn : Boolean; _defaultRelInclNonClean : Boolean ) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
22 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/02/2012	cnwcs5	par 29162 - problem storing delivery reason code
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
30 Aug 2012	cnwcs5	par 30097
19 Feb 2013	cnwcs5	CCMS PNL 2243 / par 31185 
02/06/2017	cnwdap1	TFS 4434 	SNO COPARN VGM Updates
22/08/2017	jlgdap1	TFS 6632 	Make COPARN prenotes optional
14 Nov 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
02/05/2019	jlgzm1	TFS 43425 	SNO Append new bookings rather than replace
01/08/2019	jlgka1 	TFS 45467	SNO - Clean attribute in release request
============================================================================*/
begin
	self.allowDelActioned				:= _blockDelActioned;	// par 30097
	self.allowDelArchived				:= _blockDelArchived;	// par 30097
	self.allowDelCompleted				:= _blockDelCompleted;	// par 30097
	self.allowUpdActioned				:= _blockUpdActioned;	// par 30097
	self.allowUpdArchived				:= _blockUpdArchived;	// par 30097
	self.allowUpdCompleted				:= _blockUpdCompleted;	// par 30097
	
	self.sendEmailForUpdates 			:= _emailUpdate;
	self.sendEmailForDeletes 			:= _emailDelete;
	
	self.sendEmailForBlockedUpd			:= _emailUpdateErr;	// par 29481 may 2012
	self.sendEmailForBlockedDel			:= _emailDeleteErr;	// par 29481 may 2012
	
	self.resetCompletedOnQtyIncrease	:= _resetCompleted;	// par 31185 Feb 2013
	self.useISOGroupForReleaseRequests	:= _useISOGroup;
	self.createReleaseForEQA_plus_RD	:= _createGenRR;
	
	self.myDefaultSubTerminal			:= _subTerminal;
	self.myDefaultCarrier				:= _carrier;
	self.defaultReleaseStatus			:= _releaseStatus;	// par 31185 feb 2013
	self.defaultReleaseType				:= _releaseType;	
	self.myDefaultVoyage				:= _voyage;
	self.defaultDeliveryReasonDesc		:= _reasonDesc;
	self.defaultDeliveryReasonCode		:= app.deliveryReasonStringToEnum (self.defaultDeliveryReasonDesc);	// par 29162
	self.defaultAvailabilityGrade		:= _gradeDry;
	self.defaultAvailabilityGradeReefer	:= _gradeReefer;
	self.myISOTypeForEQD_plus_RD		:= _genISOType;
	self.releaseByTypeOnly 				:=  _relByTypeOnly; 	//cnwrd1 par 33790
	
	self.updateVGMForOnsiteCargo		:= _updateVGMForOnsite;	// TFS 4434
	
	self.createPrenotesForEQDWithID		:= _createPrenotes;		// TFS 6632
	self.appendNewBookings				:= _appendBookings;		// TFS43425
	self.defaultReleaseIncludeNonClean	:= _defaultRelInclNonClean; // jlgka1 TFS 45467
	
	self.setCoparnEDIDataStyle(_useOldStyleCoparn);
epilog

end;</source>
        <Parameter name="_blockUpdActioned" type="Boolean"/>
        <Parameter name="_blockUpdArchived" type="Boolean"/>
        <Parameter name="_blockUpdCompleted" type="Boolean"/>
        <Parameter name="_blockDelActioned" type="Boolean"/>
        <Parameter name="_blockDelArchived" type="Boolean"/>
        <Parameter name="_blockDelCompleted" type="Boolean"/>
        <Parameter name="_emailUpdate" type="Boolean"/>
        <Parameter name="_emailDelete" type="Boolean"/>
        <Parameter name="_emailUpdateErr" type="Boolean"/>
        <Parameter name="_emailDeleteErr" type="Boolean"/>
        <Parameter name="_resetCompleted" type="Boolean"/>
        <Parameter name="_useISOGroup" type="Boolean"/>
        <Parameter name="_createGenRR" type="Boolean"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_releaseStatus" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_reasonDesc" type="String"/>
        <Parameter name="_gradeDry" type="Integer"/>
        <Parameter name="_gradeReefer" type="Integer"/>
        <Parameter name="_genISOType" type="CM_ISOType"/>
        <Parameter name="_relByTypeOnly" type="Boolean"/>
        <Parameter name="_updateVGMForOnsite" type="Boolean"/>
        <Parameter name="_createPrenotes" type="Boolean"/>
        <Parameter name="_appendBookings" type="Boolean"/>
        <Parameter name="_useOldStyleCoparn" type="Boolean"/>
        <Parameter name="_defaultRelInclNonClean" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="dbb33210-415e-494c-9556-b4bb277c8bab">
        <source>validate(_passport: CM_Passport input) protected;
/*
Date		Who		Reason
16 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
19 Feb 2013	cnwcs5	CCMS PNL 2243 / par 31185 - extra validation
*/
vars
	status, type	: Integer;
begin
	inheritMethod(_passport);

	if self.createReleaseForEQA_plus_RD and self.myISOTypeForEQD_plus_RD = null then
		app.raiseCMException (EDI_Party_Error4, null, null);
	endif;
	
	status 	:= self.defaultReleaseStatus;
	type	:= self.defaultReleaseType;
	
	if status &lt;&gt; BR_PENDING and
		status &lt;&gt; BR_ACTIVE then
		// the GUI should have taken care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Status must be Active or Pending');
	endif; 
	
	
/*	if type &lt;&gt; BR_TYPE_ROAD and
		type &lt;&gt; BR_TYPE_RAIL and
		type &lt;&gt; BR_TYPE_SHIP and
		type &lt;&gt; BR_TYPE_PACKING and
		type &lt;&gt; BR_TYPE_UNKNOWN then
		// the GUI should have taken care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Type must be Road, Rail, Ship, Packing, or Unknown');
	endif; */
	if type = null then
		app.raiseCMException(Please_select_release_type, null, null);	//22 Jan 2014	NDL	Par 32091
	endif;
	
	if type = BR_TYPE_UNKNOWN and status &lt;&gt; BR_PENDING then
		app.raiseCMException (EDI_Party_Error10, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
