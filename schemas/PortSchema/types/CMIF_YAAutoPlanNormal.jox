    <JadeMethod name="isHazardous_Match" id="2dd02077-4271-4b1c-8cba-6f6e609040c4">
        <source>isHazardous_Match(_yaData: CM_YADataString): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	str 	 : String;
	strArray : StringArray;
	pos		 : Integer;
	
begin
	//+cnwml2 PAR24472
	create strArray transient;
	self.myTrackedItem.getHazardsAsString.getTokensForDelimiter(",", strArray);

	foreach str in strArray do
		pos := str.pos('(', 1);
		if pos &lt;&gt; 0 then			// 23/01/2012 cnwar2 #29020
			str := str[1:pos-2];	// strip UNDG number
		endif;
		
		if _yaData.doesValueMatch(str.trimBlanks) then
			return true;
		endif;
	endforeach;

	return false;
epilog
	delete strArray;
end;</source>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
