    <JadeMethod name="translateForm" id="ea9e0cd5-2698-463a-b4d6-f142b1e08f2a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:23:43.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008752, locale);
	btnCancel.translateCaption(Xlat_0004552, locale);
	btnCreateLCL.translateBubbleHelp(Xlat_0004549, locale);
	btnCreateLCL.translateCaption(Xlat_0004553, locale);
	btnFilterExport.translateCaption(Xlat_0016340, locale);
	btnHideSearcher.translateCaption(Xlat_0004554, locale);
	btnInstruction.translateCaption(Xlat_0025208, locale);
	btnMakeHaz.translateBubbleHelp(Xlat_0020737, locale);
	btnMakeHaz.translateCaption(Xlat_0020738, locale);
	btnMakeLCL.translateBubbleHelp(Xlat_0004550, locale);
	btnMakeLCL.translateCaption(Xlat_0004555, locale);
	btnPack.translateCaption(Xlat_0004556, locale);
	btnPackComCancel.translateCaption(Xlat_0004557, locale);
	btnPackComOK.translateCaption(Xlat_0004558, locale);
	btnRepack.translateBubbleHelp(Xlat_0004551, locale);
	btnRepack.translateCaption(Xlat_0004559, locale);
	btnReset.translateCaption(Xlat_0004560, locale);
	btnSearch.translateCaption(Xlat_0004561, locale);
	btnSelector.translateCaption(Xlat_0004562, locale);
	btnSelectorQuery.translateCaption(Xlat_0004563, locale);
	btnShowSearcher.translateCaption(Xlat_0004564, locale);
	btnUnpack.translateCaption(Xlat_0004565, locale);
	btnUnpckComCanc.translateCaption(Xlat_0008753, locale);
	btnUnpckComOK.translateCaption(Xlat_0008754, locale);
	cbCharged.translateCaption(Xlat_0004566, locale);
	cbIgnoreWarnings.translateCaption(Xlat_0004567, locale);
