/*
Purpose:			

Date		Who		Reason
10 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	table : CM_DataTable;
	sheet : CMUI_Sheet;
begin
	sheet := self.fldMain.topSheet.CMUI_Sheet;
	
	if sheet &lt;&gt; null then
		table := self.getTableForSheet(sheet);
		if table &lt;&gt; null then
			self.doAutoPlanQueue(QUEUE_MODE,false,table);
		else
			global.beep;
		endif;
	else
		global.beep;
	endif;
epilog

end;</source>
