    <JadeMethod name="canDrop" id="ff6a1e97-fa03-4cd3-9680-7ba5274835df">
        <source>canDrop(_control: Control input; _win: Window input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myProxyXTAB.hasTabs then
		if _control = self.frmTabs or _control.parent = self.frmTabs then
			// can only add one tab property
			return false;
		endif;
	endif;
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
