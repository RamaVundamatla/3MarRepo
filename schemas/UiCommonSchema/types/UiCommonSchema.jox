    <JadeMethod name="getBearing" id="6d4ff167-f808-4098-a439-feab2c1c5432">
        <source>getBearing(_fromPoint, _toPoint : Point) : Real;
// ---------------------------------------------------------------------------
// Created:     15 July 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, x2, y1, y2,
	x, y, tmpAngle	: Real;
	
	
begin

	x1 := _fromPoint.x;
	y1 := _fromPoint.y;

	x2 := _toPoint.x;
	y2 := _toPoint.y;

	y := (y2-y1).sin * x2.cos;
	x := (x1.cos() * x2.sin) - (x1.sin * x2.cos * (y2-y1).cos);
	if y &gt; 0 then
	    if x &gt; 0 then
	    	tmpAngle := (y/x).arctan;
	    elseif x &lt; 0 then 
	    	tmpAngle := 180 - (-y/x).arctan;
	    elseif x = 0 then 
	    	tmpAngle := 90;
	    endif;
	elseif y &lt; 0 then
	    if x &gt; 0 then
	    	tmpAngle := 360 - (-y/x).arctan;
	    elseif x &lt; 0 then 
	    	tmpAngle := 180 + (y/x).arctan;
		elseif x = 0 then
			tmpAngle := 270;
		endif;
	elseif y = 0 then
	    if x &gt; 0 then 
	    	tmpAngle := 0;
	    elseif x &lt; 0 then 
	    	tmpAngle := 180;
	    elseif x = 0 then 
	    	// the 2 points are the same
		endif;
	endif;

	return tmpAngle;

end;</source>
        <Parameter name="_fromPoint" type="Point"/>
        <Parameter name="_toPoint" type="Point"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDatesLastMonth" id="c77b887b-10e5-45a8-8e34-54b4de47dfec">
        <source>getDatesLastMonth(_startDate, _endDate : Date io);
// ---------------------------------------------------------------------------
// Created:     18 November 2002		cnwth2	
//
// Purpose:     Populates params with the first day of last month and last day
//				of last month
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpEndDate,
	today		: Date;
	year,
	month		: Integer;
begin
	today := (app.actualTimeServer()).date;
	//get the first day of the month
	year := today.year;
	if today.month &lt;&gt; 1 then
		month := today.month -1;
	else
		month := 12;
		year := year - 1;
	endif;
	
	_startDate.setDate(1, month, year);	
	tmpEndDate := _startDate + 32;
	tmpEndDate.setDate(1, tmpEndDate.month, tmpEndDate.year); 
	
	_endDate := tmpEndDate - 1;

end;</source>
        <Parameter name="_startDate" type="Date" usage="io"/>
        <Parameter name="_endDate" type="Date" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDatesThisMonth" id="902c7bca-9012-4043-9018-81fdb3dcd093">
        <source>getDatesThisMonth(_startDate, _endDate : Date io);
// ---------------------------------------------------------------------------
// Created:     18 November 2002		cnwth2	
//
// Purpose:     Populates params with the first day of the current month and last day
//				of the current month
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpEndDate,
	today		: Date;
	year,
	month		: Integer;
begin
	today := self.systemToLocalTime(app.actualTimeServer()).date;	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
	//get the first day of the month
	year := today.year;
	month := today.month;
	_startDate.setDate(1, month, year);
	//month := month + 1;
	tmpEndDate := _startDate + 32;
	tmpEndDate.setDate(1, tmpEndDate.month, tmpEndDate.year); 
	
	_endDate := tmpEndDate - 1;

end;</source>
        <Parameter name="_startDate" type="Date" usage="io"/>
        <Parameter name="_endDate" type="Date" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDeckingOptionFromMenuIndex" id="058790af-9435-4224-8ac6-a69671959e1f">
        <source>getDeckingOptionFromMenuIndex(_deckingMenuIndex: Integer): Integer;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//default
	if _deckingMenuIndex = 1 then
		return DeckingRule_Default;
	
	//straddle/fork rules
	elseif _deckingMenuIndex = 3 then
		return Height_Then_Next_Row_Pos;
	elseif _deckingMenuIndex = 4 then
		return Height_Then_Prev_Row_Pos;
	elseif _deckingMenuIndex = 5 then
		return Layer_Then_First_Row_Pos;
	elseif _deckingMenuIndex = 6 then
		return Layer_Then_Last_Row_Pos;
	
	//fork only rules
	elseif _deckingMenuIndex = 8 then
		return Height_Then_Next_Col_Pos;
	elseif _deckingMenuIndex = 9 then
		return Height_Then_Prev_Col_Pos;
	elseif _deckingMenuIndex = 10 then
		return Layer_Then_First_Col_Pos;
	elseif _deckingMenuIndex = 11 then
		return Layer_Then_Last_Col_Pos;
	
	//custom
	elseif _deckingMenuIndex = 13 then
		return DeckingRule_Custom;
	elseif _deckingMenuIndex = 14 then
		return DeckingRule_ReverseOfOther;
	else
	
		return DeckingRule_Null; //invalid
	endif;
	

end;</source>
        <Parameter name="_deckingMenuIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFileStatus" id="bae667d5-0e58-4e4a-b801-d2414ce82455">
        <source>getFileStatus(_fileName, _clientPath, _serverPath : String;
				_sizeToDownload : Integer output) : Integer;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     Look for file on the presentation client and the server and compare size
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnStatus,
	localSize,
	serverSize		: Integer;
	fileToCheck		: String;
	localLastModifiedTime, serverLastModifiedTime: TimeStamp;
begin
	fileToCheck := _clientPath &amp; _fileName;
	if not global.checkFileExists(fileToCheck, true, localSize, localLastModifiedTime) then
		rtnStatus := self.FileStatus_AbsentClient;
	endif;
	
	fileToCheck := _serverPath &amp; _fileName;
	if not global.checkFileExistsServer(fileToCheck, serverSize, serverLastModifiedTime) then
		rtnStatus := self.FileStatus_AbsentEverywhere;
	endif;		
	
	if rtnStatus = null then
		if (serverSize /1024).Integer &lt;&gt; (localSize / 1024).Integer and
		   serverLastModifiedTime &gt; localLastModifiedTime then
			rtnStatus := self.FileStatus_OutOfDate;
		else
			rtnStatus := self.FileStatus_OK;
		endif;
	endif;
	
	_sizeToDownload := serverSize;
	return rtnStatus;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_clientPath" type="String"/>
        <Parameter name="_serverPath" type="String"/>
        <Parameter name="_sizeToDownload" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFileStatusUserMessage" id="95ea51e3-8394-4919-b4f2-bd54d5b35642">
        <source>getFileStatusUserMessage(_fileStatus : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _fileStatus = self.FileStatus_AbsentClient then
		return app.getErrorString(Ui_FileAbsentClient);
	elseif _fileStatus = self.FileStatus_OutOfDate then
		return app.getErrorString(FileOutOfDate);	
	elseif _fileStatus = self.FileStatus_AbsentEverywhere then
		return app.getErrorString(Ui_FileCannotBeFound);
	elseif _fileStatus = self.FileStatus_OK then
		return app.getErrorString(Ui_FileOK);
	elseif _fileStatus = self.FileStatus_EmptyFolderClient then
		return app.getErrorString(Ui_FolderEmptyClient);
	elseif _fileStatus = self.FileStatus_EmptyFolderServer then
		return app.getErrorString(Ui_FolderEmptyServer);
	endif;

end;</source>
        <Parameter name="_fileStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFolderStatus" id="ef6cbfa8-3d43-41bc-a554-77adf034ced9">
        <source>getFolderStatus(_fileName, _clientPath, _serverPath : String;
				_sizeToDownload : Integer output) : Integer;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     Look for file on the presentation client and the server and compare size
//			 
// ----------   ----------  --------------------------------------------------
// 17/03/2015	cnwmh5		Tranisent Leaks
vars
	rtnStatus,
	localSize,
	serverSize		: Integer;
	fileToCheck		: String;
	
	ff : FileFolder;
begin
	fileToCheck := _clientPath &amp; _fileName;
	if not global.checkFileFolderExists(fileToCheck, true, false) then
		rtnStatus := self.FileStatus_AbsentClient;
	else
		create ff transient;
		ff.fileName := fileToCheck;
		ff.mask := "*.idx";
		if ff.files.size &lt;&gt; 2 then
			rtnStatus := self.FileStatus_EmptyFolderClient;
		endif;
		delete ff;
	endif;
	
	fileToCheck := _serverPath &amp; _fileName;
	if not global.checkFileFolderExists(fileToCheck, false, false) then
		rtnStatus := self.FileStatus_AbsentEverywhere;
	endif;		
	
	if rtnStatus = null then
		if (serverSize /1024).Integer &lt;&gt; (localSize / 1024).Integer then
			rtnStatus := self.FileStatus_OutOfDate;
		else
			rtnStatus := self.FileStatus_OK;
		endif;
	endif;
	
	_sizeToDownload := serverSize;
	return rtnStatus;

epilog
	delete ff;	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_clientPath" type="String"/>
        <Parameter name="_serverPath" type="String"/>
        <Parameter name="_sizeToDownload" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHelpFileDescr" id="b0d323bd-9e87-4ed6-818d-3b36a4128d51">
        <source>getHelpFileDescr(_fileName : String) : String;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/01/2019	jlgdi1		TFS 42424 Added JMT Tallyman App description
begin
