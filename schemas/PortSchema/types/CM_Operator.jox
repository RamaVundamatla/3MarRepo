    <JadeMethod name="canOpAccessCarrierForCargoType" id="20d3e413-7fc1-4424-b875-9f5fb6c3071d">
        <source>canOpAccessCarrierForCargoType(	_carrier : CM_Carrier; 
								_cargoTypeId : Integer;
								_cargoSubType : String;
								_isoType : String;
								_trailerType : String	) : Boolean;
//
// 14 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 19 AUg 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	carrierSet : CM_CarrierSet;
	autoPlanScenario : CMIF_YAAutoPlanSenario;
	criteria : CM_YACriteria;
	objSetCT, objSetST, objSetISO, objSetTT : ObjectSet;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	isoType : CM_ISOType;
	trailerType : CM_TILCType;
	iter : Iterator;
	opCrit : CM_OperatorCarrierCriteria;
	crit : CM_YACriteria;
	matchFound : Boolean;
begin
	create autoPlanScenario transient;
	
	// Cargo type criteria
	cargoType := app.myRoot.allCargoTypesById[_cargoTypeId];
	if cargoType &lt;&gt; null then
		create criteria transient;
		create objSetCT transient;
		objSetCT.add(cargoType);
		criteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objSetCT, null);
		autoPlanScenario.allScenarioCriteria.add(criteria);
	endif;
	
	// Cargo sub type criteria
	cargoSubType := cargoType.getProductFromCode(_cargoSubType);
	if cargoSubType &lt;&gt; null then
		create criteria transient;
		create objSetST transient;
		objSetST.add(cargoSubType);
		criteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_Product], objSetST, null);
		autoPlanScenario.allScenarioCriteria.add(criteria);
	endif;
	
	// ISO Type criteria
	isoType := app.myRoot.allISOTypes[_isoType];
	if isoType &lt;&gt; null then
		create criteria transient;
		create objSetISO transient;
		objSetISO.add(isoType);
		criteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], objSetISO, null);
		autoPlanScenario.allScenarioCriteria.add(criteria);
	endif;
	
	// Trailer Type criteria
	trailerType := app.myRoot.allTILCTypes[null, _trailerType];
	if trailerType &lt;&gt; null then
		create criteria transient;
		create objSetTT transient;
		objSetTT.add(trailerType);
		criteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType], objSetTT, null);
		autoPlanScenario.allScenarioCriteria.add(criteria);
	endif;
	
	iter := self.allOperatorCarrierCriteria.createIterator;
	while iter.next(opCrit) do
		matchFound := true;
		foreach crit in opCrit.allCriteria do
			if not crit.isCMIFAutoPlanDataMatch(autoPlanScenario) then
				matchFound := false;
				break;
			endif;
		endforeach;
		if matchFound and not opCrit.allCarriers.includes(_carrier) then
			return false;
		endif;
	endwhile;
	
	return true;
	/*carrierSet := self.allCarriersByCargoTypeId.getAtKey(_cargoTypeId).CM_CarrierSet;
	if carrierSet = null or
	   carrierSet.isEmpty then
		return true;
	endif;
	return carrierSet.includes(_carrier);*/
epilog
	delete iter;
	if autoPlanScenario &lt;&gt; null then
		autoPlanScenario.allScenarioCriteria.purge;
	endif;
	delete autoPlanScenario;
	delete objSetCT;
	delete objSetST;
	delete objSetISO;
	delete objSetTT;
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_cargoTypeId" type="Integer"/>
        <Parameter name="_cargoSubType" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_trailerType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="ce9f0576-2409-4fd2-b183-c6bf1f204587">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	op : CM_Operator;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		op := app.myRoot.allOperators.getAtKey( code );
	endif;

epilog

	return op;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="create" id="8b255a28-dfb2-4143-a5ba-ea30fc413e37">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isTransient then
		create self.notRailIds transient;
		create self.notRoadIds transient;
	else
		create self.notRailIds persistent;
		create self.notRoadIds persistent;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="46dcef18-686a-463a-a829-a3701c3dd0f2">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	delete self.notRailIds;
	delete self.notRoadIds;
	
	//04 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setOperatorDictNeedsRefresh();
	endif;

// cnwrs1 june 2006 was missing

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="a3f1ae0b-fcbb-43c7-a2d9-97412bab7208">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b8369197-fd54-4662-bef4-a34e2e1906b8">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// 25/03/2013	cnwcs5	CCMS POL 2097 / par 31259
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations(self.allXlations, NORMAL_ERASE);
	self.eraseXlationTables();
	
	if self.notRailIds &lt;&gt; null then
		delete self.notRailIds;
	endif;	
	
	if self.notRoadIds &lt;&gt; null then
		delete self.notRoadIds;
	endif;	
		
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseXlationTables" id="ba8fd70a-4f27-4991-8edc-8b3ddb87afb8">
        <source>eraseXlationTables() protected;

vars
	objectArray		:ObjectArray;
	object			:Object;
	xlationTable	:CM_XlationTable;
begin
	create objectArray transient;
	
	foreach xlationTable in self.allXlationTables do
		objectArray.add(xlationTable);
	endforeach;
	
	foreach object in objectArray do
		object.CM_XlationTable.erase(NORMAL_ERASE);
	endforeach;
epilog
	if objectArray &lt;&gt; null then
		delete objectArray;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAddressDetailXML" id="0babf234-e7cf-4906-af82-2df89e5ddef6">
        <source>getAddressDetailXML(_xmlTag : String) : String;
/*

Date		Who		Reason
18 December 2013	cnwer1	Initial creation PAR 32982

*/
vars
	debtorAddress : String;
	
begin
	if self.debtor = null then
		return null;
	endif;
	
	if debtor.billingAddress = null or debtor.billingAddress.size = 0 then
		return null;
	endif;
	
	debtorAddress:=debtor.billingAddress.concatenate("");
	return debtorAddress.cnEcGetTagValueOfName(_xmlTag);
epilog

end;</source>
        <Parameter name="_xmlTag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
