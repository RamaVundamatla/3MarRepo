    <JadeMethod name="loadDB" id="970a7366-9061-4a61-b780-97ee0435dd46">
        <updating/>
        <source>loadDB(mergeCargo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmifDeckPlan : CMIF_EDIDeckPlan;
//	cmifDeckPlanGCCargo : CMIF_DeckPlanGCCargo;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	create cmifDeckPlan transient;
	cmifDeckPlan.myEDIData := self;
	self.setupProxiesCargo(Loading_EDI_Data_Total, cmifDeckPlan, _passport); // cnwrs par 22855 Mar 2010
	if _passport.hasErrors then 
		return;
	endif;
	
	app.myTrxCA.trxCreateEDIDeckPlan(false, self, cmifDeckPlan, _passport);
epilog
	cmifDeckPlan.cleanUpProxies();
	delete cmifDeckPlan;
end;
</source>
        <Parameter name="mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processDeckActual" id="6b66e0f0-6ab1-4ab3-b4a1-0df4995c1d6e">
        <source>processDeckActual(_deck : CM_Deck; _voyage : CM_Voyage; _tis : CM_TIArray input);
//
//16 Oct 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
//07 Nov 2012	cnwrs1	par 30688 OOTL layouts are missing for proposed
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed//
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
vars
	deckItem : CM_DeckItem;
	deckItemLayout : CM_DeckItemLayout;
	roroLocnDefnVoyage : CM_ROROLocnDefn;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
begin
	create tiArray transient;
	foreach deckItem in _deck.allDeckItems do
		// PAR 30587 - do not extract items on the load CC layer
		if deckItem.isOnLayerLoad() then
			continue;
		endif;
		
		deckItemLayout := deckItem.myLayout;
		if deckItem.isKindOf(CM_ROROEquipment) then
			self.processDeckItemLayoutActual(_voyage, deckItemLayout);
		elseif deckItem.isKindOf(CM_ROROGeneralArea) then
			self.processDeckItemLayoutActual(_voyage, deckItemLayout);
		elseif deckItem.isKindOf(CM_ROROLocnDefnVoyage) then
			roroLocnDefnVoyage := deckItem.CM_ROROLocnDefnVoyage;
			if roroLocnDefnVoyage.isOOTLLocn then
				if deckItem.checkCanProcessDeckItem(REAL_MODE) then	//07 Nov 2012	cnwrs1	par 30688
					self.processDeckItemLayoutActual(_voyage, deckItemLayout);
				endif;
			endif;
			if roroLocnDefnVoyage.isRotationMaster() then // PAR 30587 allPlannedRotatedLocnDefns.size &gt; 0 then
				if roroLocnDefnVoyage.isOOTLLocn then
					if deckItem.checkCanProcessDeckItem(REAL_MODE) then	//23 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
						self.processDeckItemLayoutRotation(_voyage, deckItemLayout, roroLocnDefnVoyage.allPlannedRotatedLocnDefns.size);
					endif;
				else	//23 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
					self.processDeckItemLayoutRotation(_voyage, deckItemLayout, roroLocnDefnVoyage.allPlannedRotatedLocnDefns.size);
				endif;
			endif;
		elseif deckItem.isKindOf(CM_ROROGCDefnVoyage) then
			if deckItem.hasTIs(REAL_MODE) then
				self.processDeckItemLayoutActual(_voyage, deckItemLayout);
			endif;
		endif;	
		deckItem.getAllTIs(REAL_MODE, tiArray, true);	//15 Jan 2013	cnwrs1	Par31258 include Exports as ROBs for EDI Proposed
		foreach ti in tiArray do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;' '&amp;ti.locationId;
			if not _tis.includes(ti) then
				_tis.add(ti);
			endif;
		endforeach;
	endforeach;
epilog
	delete tiArray;
end;
</source>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processDeckItemLayoutActual" id="4ee14373-0cad-411d-a434-dac06f010401">
        <source>processDeckItemLayoutActual(_voyage : CM_Voyage; _deckItemLayout : CM_DeckItemLayout);
//
// 30 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
//
//10 Sep 2012	cnwrs1	par 30358 extract equipment weight and general area weight
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//05 Feb 2013	cnwrs1	Par 31125 extract out actual layout points if no pre rotated points
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediLayoutTI : CM_EDILayoutTI;
	ediLayoutPointTI : CM_EDILayoutPointTI;
	str : String;
	deckItemCode : String;
	count : Integer;
	point : Decimal[12,2];
	rotateLabel : String;
	deckItemLayoutTemp : CM_DeckItemLayout;
begin
	create deckItemLayoutTemp transient;
	global.getExtraData(_deckItemLayout.getStateData(), RoRoRotatedLabel, rotateLabel);
	create ediLayoutTI persistent;
	ediLayoutTI.setForCreateNew(self);
	ediLayoutTI.setVoyageCode(_voyage.code);
	if _deckItemLayout.code[(_deckItemLayout.myDeckItem.code.length):1] = rotateLabel then
		deckItemCode := _deckItemLayout.code[1:_deckItemLayout.myDeckItem.code.length-1];
	else
		deckItemCode := _deckItemLayout.myDeckItem.code[1:10];
	endif;
	ediLayoutTI.layoutId := deckItemCode;
	if _deckItemLayout.myDeckItem &lt;&gt; null then
		str := _deckItemLayout.myDeckItem.getEDITypeCode();
		ediLayoutTI.layoutType := str[1:1];
		if _deckItemLayout.myDeckItem.isKindOf(CM_ROROEquipment) then
			ediLayoutTI.weight := _deckItemLayout.myDeckItem.CM_ROROEquipment.weight;
		endif;
		if _deckItemLayout.myDeckItem.isKindOf(CM_ROROGeneralArea) then
			ediLayoutTI.weight := _deckItemLayout.myDeckItem.CM_ROROGeneralArea.weight;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutTI.layoutId&amp;' '&amp;ediLayoutTI.layoutType;
	endif;
	count := 0;
	if _deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and
		_deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.isPlannedRotated then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		deckItemLayoutTemp.setPointsPolygon(_deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.myPreRotatePoints);
		if deckItemLayoutTemp.myPolygonCMs.isEmpty then	// if dont find any pre rotated points use actual
			deckItemLayoutTemp.setPointsPolygon(_deckItemLayout.myPolygonPixels);
		endif;
		foreach point in deckItemLayoutTemp.myPolygonCMs do
			count := count + 1;
			if count mod 2 &lt;&gt; 0 then	// ie odd
				create ediLayoutPointTI persistent;
				ediLayoutPointTI.setForCreateNew(self);
				ediLayoutPointTI.setVoyageCode(_voyage.code);
				ediLayoutPointTI.layoutId := deckItemCode;
				ediLayoutPointTI.pointOrder := (count/2 + 1).Integer;
				ediLayoutPointTI.longPos := point;
			else
				ediLayoutPointTI.transPos := point;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutPointTI.layoutId&amp;' '&amp;ediLayoutPointTI.pointOrder.String;
			endif;
		endforeach;
	else
		foreach point in _deckItemLayout.myPolygonCMs do
			count := count + 1;
			if count mod 2 &lt;&gt; 0 then	// ie odd
				create ediLayoutPointTI persistent;
				ediLayoutPointTI.setForCreateNew(self);
				ediLayoutPointTI.setVoyageCode(_voyage.code);
				ediLayoutPointTI.layoutId := deckItemCode;
				ediLayoutPointTI.pointOrder := (count/2 + 1).Integer;
				ediLayoutPointTI.longPos := point;
			else
				ediLayoutPointTI.transPos := point;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutPointTI.layoutId&amp;' '&amp;ediLayoutPointTI.pointOrder.String;
			endif;
		endforeach;
	endif;
epilog
	delete deckItemLayoutTemp;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="processDeckItemLayoutProposed" id="b4377154-4e0e-4961-9397-bebf44d05c94">
        <source>processDeckItemLayoutProposed(_voyage : CM_Voyage; _deckItemLayout : CM_DeckItemLayout);
//
//13 Sep 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//05 Feb 2013	cnwrs1	Par 31125 extract out actual layout points if no pre rotated points
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediLayoutTI : CM_EDILayoutTI;
	ediLayoutPointTI : CM_EDILayoutPointTI;
	str : String;
	deckItemCode : String;
	count : Integer;
	point : Decimal[12,2];
	rotateLabel : String;
	deckItemLayoutTemp : CM_DeckItemLayout;
begin
	create deckItemLayoutTemp transient;
	global.getExtraData(_deckItemLayout.getStateData(), RoRoRotatedLabel, rotateLabel);
	create ediLayoutTI persistent;
	ediLayoutTI.setForCreateNew(self);
	ediLayoutTI.setVoyageCode(_voyage.code);
	if _deckItemLayout.code[(_deckItemLayout.myDeckItem.code.length):1] = rotateLabel then
		deckItemCode := _deckItemLayout.code[1:_deckItemLayout.myDeckItem.code.length-1];
	else
		deckItemCode := _deckItemLayout.myDeckItem.code[1:10];
	endif;
	ediLayoutTI.layoutId := deckItemCode;
	if _deckItemLayout.myDeckItem &lt;&gt; null then
		str := _deckItemLayout.myDeckItem.getEDITypeCode();
		ediLayoutTI.layoutType := str[1:1];
		if _deckItemLayout.myDeckItem.isKindOf(CM_ROROEquipment) then
			ediLayoutTI.weight := _deckItemLayout.myDeckItem.CM_ROROEquipment.weight;
		endif;
		if _deckItemLayout.myDeckItem.isKindOf(CM_ROROGeneralArea) then
			ediLayoutTI.weight := _deckItemLayout.myDeckItem.CM_ROROGeneralArea.weight;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutTI.layoutId&amp;' '&amp;ediLayoutTI.layoutType;
	endif;
	count := 0;
	if _deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and
		_deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.isPlannedRotated then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		deckItemLayoutTemp.setPointsPolygon(_deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.myPreRotatePoints);
		if deckItemLayoutTemp.myPolygonCMs.isEmpty then	// if dont find any pre rotated points use actual
			deckItemLayoutTemp.setPointsPolygon(_deckItemLayout.myPolygonPixels);
		endif;
		foreach point in deckItemLayoutTemp.myPolygonCMs do
			count := count + 1;
			if count mod 2 &lt;&gt; 0 then	// ie odd
				create ediLayoutPointTI persistent;
				ediLayoutPointTI.setForCreateNew(self);
				ediLayoutPointTI.setVoyageCode(_voyage.code);
				ediLayoutPointTI.layoutId := deckItemCode;
				ediLayoutPointTI.pointOrder := (count/2 + 1).Integer;
				ediLayoutPointTI.longPos := point;
			else
				ediLayoutPointTI.transPos := point;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutPointTI.layoutId&amp;' '&amp;ediLayoutPointTI.pointOrder.String;
			endif;
		endforeach;
	else
		foreach point in _deckItemLayout.myPolygonCMs do
			count := count + 1;
			if count mod 2 &lt;&gt; 0 then	// ie odd
				create ediLayoutPointTI persistent;
				ediLayoutPointTI.setForCreateNew(self);
				ediLayoutPointTI.setVoyageCode(_voyage.code);
				ediLayoutPointTI.layoutId := _deckItemLayout.code;
				ediLayoutPointTI.pointOrder := (count/2 + 1).Integer;
				ediLayoutPointTI.longPos := point;
			else
				ediLayoutPointTI.transPos := point;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyage.code&amp;' '&amp;ediLayoutPointTI.layoutId&amp;' '&amp;ediLayoutPointTI.pointOrder.String;
			endif;
		endforeach;
	endif;
epilog
	delete deckItemLayoutTemp;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="processDeckItemLayoutRotation" id="c3868259-6e06-426e-976a-8167b72bbd02">
        <source>processDeckItemLayoutRotation(_voyage : CM_Voyage; _deckItemLayout : CM_DeckItemLayout; _rotatedItemCount : Integer);
//
// 09 Mar 2012	cnwrs1	Par 29246 - EDI RORO Deck Plan Extract not including rotation
// 13 Sep 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
// 29 Oct 2012	cnwcs5	par 30640 - not handling rotated OOTL
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediLayoutTI : CM_EDILayoutTI;
	str : String;
	rotateLabel : String;
begin
	global.getExtraData(_deckItemLayout.getStateData(), RoRoRotatedLabel, rotateLabel);
	create ediLayoutTI persistent;
	
	ediLayoutTI.setForCreateNew(self);
	ediLayoutTI.setVoyageCode(_voyage.code);
	
	if _deckItemLayout.code[(_deckItemLayout.myDeckItem.code.length):1] = rotateLabel then
		str := _deckItemLayout.code[1:_deckItemLayout.myDeckItem.code.length-1];
	else
		str := _deckItemLayout.myDeckItem.code[1:10];
	endif;
	
	ediLayoutTI.layoutId := str;
	ediLayoutTI.isRotationMaster := true;
	
	if _rotatedItemCount = 10 then
		str := "2X5";
	elseif _rotatedItemCount = 6 then
		str := "2X3";
	elseif _rotatedItemCount = 5 then
		str := "1X5";
	elseif _rotatedItemCount = 3 then
		str := "1X3";
	elseif _rotatedItemCount = 1 then	// par 30640 oct 2012
		// rotated OOTL
		str := "1X1";					// par 30640 oct 2012
	else								// par 30640 oct 2012
		str := null;					// par 30640 oct 2012
	endif;
	
	ediLayoutTI.rotation := str;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_rotatedItemCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processDeckProposed" id="1667a8de-fcaf-4488-8d24-c604cbcfaf48">
        <source>processDeckProposed(_deck : CM_Deck; _voyage : CM_Voyage; _tis : CM_TIArray input);
//
//16 Oct 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
//07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
//28 nov 2012	cnwrs1	Par 30738
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
//28 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//01 Feb 2013	cnwrs1	Par 31119 don't extract layout twice
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	deckItem : CM_DeckItem;
	deckItemLayout : CM_DeckItemLayout;
	roroLocnDefnVoyage : CM_ROROLocnDefn;
	roroGCDefn : CM_ROROGCDefn;
	ediLayoutTI : CM_EDILayoutTI;
	ediLayoutPointTI : CM_EDILayoutPointTI;
	roroRequest : CM_RORORequest;
	allRequests : CM_VoyageRequestArray;
	isLoad : Boolean;
	isDischarge : Boolean;
	isROB : Boolean;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	locn : CM_ROROLocnDefn;
	myRequestHasTis : Boolean;
	thisRotationHasTis : Boolean;
	layoutHasBeenExtracted : Boolean;
begin
	create allRequests transient;
	create tiArray transient;
	foreach deckItem in _deck.allDeckItems do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;deckItem.code;
		deckItemLayout := deckItem.myLayout;
		layoutHasBeenExtracted := false;
		if deckItem.isKindOf(CM_ROROLocnDefnVoyage) then
			roroLocnDefnVoyage := deckItem.CM_ROROLocnDefnVoyage;
			if roroLocnDefnVoyage.isOOTLLocn then
				if roroLocnDefnVoyage.checkCanProcessDeckItem(PLANNING_MODE) then
					if not layoutHasBeenExtracted then
						if not layoutHasBeenExtracted then
							self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
							layoutHasBeenExtracted := true;
						endif;
					endif;
					if roroLocnDefnVoyage.isPlannedRotated and
					   roroLocnDefnVoyage.isRotationMaster() then 
						self.processDeckItemLayoutRotation(_voyage, deckItemLayout, roroLocnDefnVoyage.allPlannedRotatedLocnDefns.size);
					endif;
				endif;
			else	// not OOTL	//24 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
				if roroLocnDefnVoyage.isPlannedRotated and
				   roroLocnDefnVoyage.isRotationMaster() then // PAR 30587 allPlannedRotatedLocnDefns.size &gt; 0 then
					foreach locn in roroLocnDefnVoyage.allPlannedRotatedLocnDefns do
						allRequests.clear();
						roroLocnDefnVoyage.getAllVoyageRequests(allRequests);
						isLoad := false;
						isDischarge := false;
						isROB := locn.hasROB(true);	//25 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
						thisRotationHasTis := false;
						foreach roroRequest in allRequests do
							if roroRequest = null then
								continue;
							endif;
				//				write deckItem.String&amp;' '&amp;deckItem.code&amp;' '&amp;roroRequest.String;
							if roroRequest.myROROControllerLoad &lt;&gt; null then
								isLoad := true;
							elseif roroRequest.myROROControllerDischarge &lt;&gt; null then
								isDischarge := true;
							endif;
						endforeach;
						if isDischarge and not isLoad and not isROB then
							continue;
						endif;
						if locn.hasTIs(PLANNING_MODE) then
							thisRotationHasTis := true;
							break;
						endif;
						if isROB and	//25 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
						   locn.hasTIs(REAL_MODE) then
							thisRotationHasTis := true;
							break;
						endif;
					endforeach;
					if thisRotationHasTis then
						self.processDeckItemLayoutRotation(_voyage, deckItemLayout, roroLocnDefnVoyage.allPlannedRotatedLocnDefns.size);
					endif;
				endif;
			endif;
		else
			allRequests.clear();
			deckItem.getAllVoyageRequests(allRequests);
			isLoad := false;
			isDischarge := false;
			isROB := deckItem.hasROB(true);
			foreach roroRequest in allRequests do
				if roroRequest = null then
					continue;
				endif;
				if roroRequest.myROROControllerLoad &lt;&gt; null then
					isLoad := true;
				elseif roroRequest.myROROControllerDischarge &lt;&gt; null then
					isDischarge := true;
				endif;
			endforeach;
			if isDischarge and not isLoad and not isROB then
				continue;
			endif;
			if deckItem.isKindOf(CM_ROROEquipment) then
				if not layoutHasBeenExtracted then
					self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
					layoutHasBeenExtracted := true;
				endif;
			elseif deckItem.isKindOf(CM_ROROGCDefnVoyage) then
				if deckItem.hasTIs(PLANNING_MODE) then
					if not layoutHasBeenExtracted then
						self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
						layoutHasBeenExtracted := true;
					endif;
				endif;
				deckItem.getAllTIsRoB(tiArray, true, true);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
				if tiArray.size &gt; 0 then
					if not layoutHasBeenExtracted then
						self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
						layoutHasBeenExtracted := true;
					endif;
				endif;
			elseif deckItem.isKindOf(CM_ROROGeneralArea) then
				if not layoutHasBeenExtracted then
					self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
					layoutHasBeenExtracted := true;
				endif;
			endif;
		endif;
//			tiArray.clear;
		deckItem.getAllTIs(PLANNING_MODE, tiArray, true);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		foreach ti in tiArray do
			if not _tis.includes(ti) then
				_tis.add(ti);
			endif;
		endforeach;
		deckItem.getAllTIsRoB(tiArray, true, true);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		foreach ti in tiArray do
			if not _tis.includes(ti) then
				_tis.add(ti);
			endif;
		endforeach;
	endforeach;
epilog
	delete allRequests;
	delete tiArray;
end;
</source>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processLayoutActual" id="8ca19c89-8820-47ac-8f24-9d6f55b21a40">
        <updating/>
        <source>processLayoutActual(_voyage : CM_Voyage; _tis : CM_TIArray input) updating;
//
// 16 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
//
// 09 Mar 2012	cnwrs1		Par 29246 - EDI RORO Deck Plan Extract not including rotation
// 07/08/2012 	cnwmh5		PAR 30077 - Rewrite so now includes Equipment
// 10 Sep 2012	cnwrs1	par 30358 extract equipment weight and general area weight
// 15/10/2012	cnwmh5		PAR 30556 - Fix issue when _voyage.myROROStructure = null
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	roroStructure : CM_ROROVoyageStructure;
	deck : CM_Deck;
	subDeck : CM_DeckVoyage;
//	ti : CM_TrackedItem;
begin
	roroStructure := _voyage.myROROStructure;
	if roroStructure = null then								// 15/10/2012 cnwmh5 #30556
		return;
	endif;
	foreach deck in roroStructure.allDecks do
		self.processDeckActual(deck, _voyage, _tis);
		foreach subDeck in deck.CM_DeckVoyage.allSubDecks do
			self.processDeckActual(subDeck, _voyage, _tis);
		endforeach;
	endforeach;
//	foreach ti in _tis do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;' '&amp;ti.myPrimaryActualLocation.String&amp;' '&amp;ti.myPrimaryActualLocation.getStowageId(ti);
//	endforeach;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processLayoutProposed" id="dedee722-8202-4f2d-a5fb-87fc6a7e1d29">
        <updating/>
        <source>processLayoutProposed(_voyage : CM_Voyage; _tis : CM_TIArray input) updating;
//
//16 Oct 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
//
// 15/10/2012	cnwmh5	#30556 - Fix issue of 1090 when _voyage.myROROStructure = null
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	roroStructure : CM_ROROVoyageStructure;
	deck : CM_Deck;
	subDeck : CM_DeckVoyage;
begin
	roroStructure := _voyage.myROROStructure;
	if roroStructure = null then							// 15/10/2012 cnwmh5 #30556
		return;
	endif;
	foreach deck in roroStructure.allDecks do
		self.processDeckProposed(deck, _voyage, _tis);
		foreach subDeck in deck.CM_DeckVoyage.allSubDecks do
			self.processDeckProposed(subDeck, _voyage, _tis);
		endforeach;
	endforeach;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMissedLayouts" id="a8b3f19f-6014-4a9a-a58e-bd5bf1608cc6">
        <source>processMissedLayouts(_voyage : CM_Voyage; _planType : Integer; _locationList : StringArray);
//
//20 Dec 2012	cnwrs1	Par 30962 - check the list of locations used for the trackeditem that we have already created Layout and if not re extract 
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDITrackedItem;
	locationID : String;
	found : Boolean;
	foundHeight : Integer;
	deckItemLayout : CM_DeckItemLayout;
	roro : CM_ROROVoyageStructure;
	roroLC : CM_LocationsController;
	roroDeck : CM_DeckVoyage;
	startLocn : CM_ROROLocnDefn; 
	locnDefn :CM_ROROLocnDefn;
	lookupCode : String;
	rotateLabel : String;
	deckItemCode : String;
	deckLayer : CM_DeckItemLayout;
begin
	foreach locationID in _locationList do
		found := false;
		foreach ediTI in self.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDILayoutTI) then
				if locationID = ediTI.CM_EDILayoutTI.layoutId then
					found := true;
					break;
				endif;
			endif;
		endforeach;
		if not found then
			//find layout
			lookupCode := _voyage.code &amp; " " &amp; locationID;
			self.getMyTerminal().findLocationFromString(lookupCode, true, roroLC, foundHeight);
			if roroLC = null then	//19 Dec 2012	cnwrs1	Par 30922 check is the Layout is a position id rather than location Id and if so take the first location
				roro := _voyage.myROROStructure;
				roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
				if roroDeck &lt;&gt; null then
					startLocn :=  roroDeck.allDeckItems[locationID].CM_ROROLocnDefn;
					if startLocn &lt;&gt; null and startLocn.allROROSlotDefnByOrdinal.size &gt; 0 then
						roroLC := startLocn.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController;
					endif;
				endif;
			endif;
			if roroLC &lt;&gt; null then
				if roroLC.isKindOf(CM_ROROSlotController) then
					locnDefn := roroLC.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
					if locnDefn &lt;&gt; null then
						deckItemLayout := locnDefn.myLayout;
					endif;
				elseif roroLC.isKindOf(CM_ROROGCController) then
					if roroLC.CM_ROROGCController.myGCDefn.myDeckLayerLayout.allDeckItemLayouts.size &gt; 0 then
						foreach deckLayer in roroLC.CM_ROROGCController.myGCDefn.myDeckLayerLayout.allDeckItemLayouts do
							if deckLayer.code = locationID then
								deckItemLayout := deckLayer;
							endif;
						endforeach;
						if deckItemLayout = null then 
							deckItemLayout := roroLC.CM_ROROGCController.myGCDefn.myDeckLayerLayout.allDeckItemLayouts.first;
						endif;
					endif;
				endif;
				if deckItemLayout &lt;&gt; null then
					global.getExtraData(deckItemLayout.getStateData(), RoRoRotatedLabel, rotateLabel);
					if deckItemLayout.code[(deckItemLayout.myDeckItem.code.length):1] = rotateLabel then
						deckItemCode := deckItemLayout.code[1:deckItemLayout.myDeckItem.code.length-1];
						// if it was a rotated code then re check if it was already extracted
						found := false;
						foreach ediTI in self.allEDITrackedItems do
							if ediTI.isKindOf(CM_EDILayoutTI) and 
							   ediTI.CM_EDILayoutTI.rotation = null then
								if deckItemCode = ediTI.CM_EDILayoutTI.layoutId then
									found := true;
									break;
								endif;
							endif;
						endforeach;
						if found then
							continue;
						endif;
					endif;
					if _planType = ACTUAL_BAYPLANS then
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;deckItemLayout.code&amp;' '&amp;locationID&amp;' '&amp;roroLC.ident&amp;' '&amp;deckItemLayout.myDeckItem.code;
						self.processDeckItemLayoutActual(_voyage, deckItemLayout);
					elseif _planType = PROPOSED_BAYPLANS then
						self.processDeckItemLayoutProposed(_voyage, deckItemLayout);
					endif;
				endif;
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_locationList" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="processTrackedItems" id="1a2d2f6d-6904-47fd-8446-c073b9a6de62">
        <updating/>
        <source>processTrackedItems(_trackedItem: CM_TrackedItem; _type: Integer; _voyage : CM_Voyage; _locationList : StringArray input) updating;
//
// 16 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
//
// 02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
//07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
//20 Dec 2012	cnwrs1	Par 30962 - check the list of locations used for the trackeditem that we have already created Layout and if not re extract 
// 14/03/2013	cnwmh5	#31258 - Change to save stowage position rather that TILocation
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	realTI : CM_TrackedItem;
	ediTrackedItem : CM_EDICargoOnShipTI;
	commodity : CM_Commodity;
    slotController : CM_SlotController;
	tmpReeferInfo : String;    
    bayId : String;
	portCode : String;
	lVolume : Real;
	tiLoc : CM_LocationsController;
	objParentCargoType : CM_CargoType;
	locationId : String;
	checkLocationId : String;
	startPos : Integer;
	endPos : Integer;
	imCodes : StringArray;
	actualLocation : CM_LocationsController;
	locationTI : CM_TrackedItem;
begin
	realTI := _trackedItem;
	if realTI = null then
		return;
	endif;
	
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);
	ediTrackedItem.setFromTrackedItem(realTI, _type);

	ediTrackedItem.setCargoType(realTI.cargoType);
	
	ediTrackedItem.setId(realTI.id);
	ediTrackedItem.alternativeId := realTI.alternativeId;	//06 May 2013	NDL	Par 31506
	ediTrackedItem.bookingRef := realTI.bookingReference;
	if realTI.isKindOf(CM_Container) then
		ediTrackedItem.availabilityGrade := realTI.CM_Container.availabilityGrade;
		if realTI.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;
	endif;

	create imCodes transient;
	ediTrackedItem.processTIHazards(realTI.allTIHazards, imCodes);
	imCodes.copy(ediTrackedItem.imCodes);//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI

    //setup bay position
	if _type = ACTUAL_BAYPLANS then
		locationId := self.getTILocation(realTI, REAL_MODE);
		actualLocation := realTI.myPrimaryActualLocation;
		if actualLocation.isKindOf(CM_ROROSlotController) then
			if actualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn then
				startPos := _voyage.code.length + 2;
				if locationId.length &gt;= startPos and
				   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
					checkLocationId := locationId[startPos:end];
				else
					checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
				endif;
				if not _locationList.includes(checkLocationId) then
					_locationList.add(checkLocationId);
				endif;
				//locationId := actualLocation.getStowageId(realTI);				// 14/03/2013 cnwmh5 #31258
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;locationId&amp;' '&amp;checkLocationId&amp;' real OOTL '&amp;realTI.myPrimaryActualLocation.String&amp;' '&amp;realTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn.String;
			endif;
		elseif actualLocation.isKindOf(CM_ROROGCController) then
			startPos := _voyage.code.length + 2;
			if locationId.length &gt;= startPos and
			   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
				checkLocationId := locationId[startPos:end];
			else
				checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
			endif;
			if not _locationList.includes(checkLocationId) then
				_locationList.add(checkLocationId);
			endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;checkLocationId&amp;' real GC '&amp;realTI.myPrimaryActualLocation.String&amp;' ';
		endif;
	//	locationId := actualLocation.getStowageId(realTI);				// 14/03/2013 cnwmh5 #31258
	else
		if realTI.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
			locationId := self.getTILocation(realTI, REAL_MODE);
			actualLocation := realTI.myPrimaryActualLocation;
			if actualLocation.isKindOf(CM_ROROSlotController) then
				if actualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn then
					startPos := _voyage.code.length + 2;
					if locationId.length &gt;= startPos and
					   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
						checkLocationId := locationId[startPos:end];
					else
						checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
					endif;
					if not _locationList.includes(checkLocationId) then
						_locationList.add(checkLocationId);
					endif;
					///locationId := actualLocation.getStowageId(realTI);				// 14/03/2013 cnwmh5 #31258
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;locationId&amp;' real OOTL '&amp;realTI.myPrimaryActualLocation.String&amp;' '&amp;realTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn.String;
				endif;
			elseif actualLocation.isKindOf(CM_ROROGCController) then
				startPos := _voyage.code.length + 2;
				if locationId.length &gt;= startPos and
				   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
					checkLocationId := locationId[startPos:end];
				else
					checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
				endif;
				if not _locationList.includes(checkLocationId) then
					_locationList.add(checkLocationId);
				endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;checkLocationId&amp;' real GC '&amp;realTI.myPrimaryActualLocation.String&amp;' ';
			endif;
		else
		
			//23 Jul 2013	NDL	Par 30952 - use the location TI thru this block...
			// if the real ti is a child, and is not planned... Occurred during testing, but not always
			if realTI.plannedLocnId = null and realTI.myParent &lt;&gt; null then
				locationTI := realTI.myParent;
			else
				locationTI := realTI;
			endif;
			
			if locationTI.plannedLocnId &lt;&gt; null then
				locationId := self.getTILocation(locationTI, PLANNING_MODE);
				actualLocation := locationTI.myPrimaryPlannedLocation;
				if actualLocation.isKindOf(CM_ROROSlotController) then
					if actualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn then
						startPos := _voyage.code.length + 2;
						if locationId.length &gt;= startPos and
						   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
							checkLocationId := locationId[startPos:end];
						else
							checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
						endif;
						if not _locationList.includes(checkLocationId) then
							_locationList.add(checkLocationId);
						endif;
						///locationId := actualLocation.getStowageId(realTI);				// 14/03/2013 cnwmh5 #31258
		//write class.name&amp;'::'&amp;method.name&amp;' '&amp;locationId&amp;' planned OOTL '&amp;realTI.myPrimaryPlannedLocation.String&amp;' '&amp;realTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen.isOOTLLocn.String;
					endif;
				elseif actualLocation.isKindOf(CM_ROROGCController) then
					startPos := _voyage.code.length + 2;
					if locationId.length &gt;= startPos and
					   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
						checkLocationId := locationId[startPos:end];
					else
						checkLocationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
					endif;
					if not _locationList.includes(checkLocationId) then
						_locationList.add(checkLocationId);
					endif;
		//write class.name&amp;'::'&amp;method.name&amp;' '&amp;checkLocationId&amp;' planned GC '&amp;realTI.myPrimaryPlannedLocation.String&amp;' ';
				endif;
			else	// must be remain on board
				locationId := self.getTILocation(locationTI, REAL_MODE);
				///actualLocation := realTI.myPrimaryActualLocation;
				///locationId := actualLocation.getStowageId(realTI);				// 14/03/2013 cnwmh5 #31258
			endif;
		endif;
	endif;
	startPos := _voyage.code.length + 2;
	if locationId.length &gt;= startPos and
	   locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
		ediTrackedItem.locationId := locationId[startPos:end];
	else
		ediTrackedItem.locationId := locationId;	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
	endif;
	if realTI.myParent &lt;&gt; null then
		objParentCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(realTI.myParent.cargoTypeDescr);
		if objParentCargoType &lt;&gt; null then
			ediTrackedItem.parentCargoTypeCode := objParentCargoType.id;
			ediTrackedItem.parentCargoType := objParentCargoType.description;
			ediTrackedItem.parentCargoID := realTI.myParent.id;
		endif;
	else
		ediTrackedItem.parentCargoTypeCode := 0;
	endif;
	ediTrackedItem.site := realTI.site;
	tmpReeferInfo := realTI.getReeferInfo();
	if tmpReeferInfo &lt;&gt; null then
		ediTrackedItem.remarks := tmpReeferInfo &amp; ' ' &amp; realTI.remarks;
	else
		ediTrackedItem.remarks := realTI.remarks;
	endif;

	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012
epilog
	delete imCodes;
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_locationList" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processVoyage" id="7fa55bf4-8aa5-44f8-bf68-2ec9f0a0150f">
        <updating/>
        <source>processVoyage(_voyage : CM_Voyage) updating;
//
// 16 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
vars
	ediTrackedItem : CM_EDIVoyageHeaderTI;
begin
	create ediTrackedItem persistent;
	
	ediTrackedItem.setForCreateNew(self);
	ediTrackedItem.setVoyageCode(_voyage.code);
	
	ediTrackedItem.vesselName := _voyage.vesselName;
	
	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromVoyage" id="5c273c77-bcbb-4cc8-a3bb-e6ad077feb80">
        <updating/>
        <source>setForCreateFromVoyage(_voyage : CM_Voyage; 
					  _ediConfig : CM_EDIConfig input;
					  _planType	: Integer;
					  _realEdiFile : CM_EDIFile input;
                      _userCode : String ) updating;
/*

Purpose:
Creates an EDI RORO Deck Plan from a voyage in the database			

Called in Transaction State


Date		Who		Reason
21 December 2011	cnwgb1	Initial creation for CCMS MSL 1009 Par 29024
UNDER CONSTRUCTION
02 May 2012	cnwrs1	Par 29388 extract proposed deck plan
31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
31/07/2012	cnwmh5	#29940 - Change so that ti's whose myPrimaryActualLocation isn't a CM_ROROSlotController don't
						get exported.  e.g. Items created with the Lander or dragged and dropped to the NPNW screens
						onship area
08/08/2012	cnwmh5	#30077 - Include those of CM_ROROGCController as well
//13 Sep 2012	cnwrs1	Par 29388 Proposed Deck Plan Extract
//20 Dec 2012	cnwrs1	Par 30962 - check the list of locations used for the trackeditem that we have already created Layout and if not re extract 
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
//	tiDict : CM_TIByCargoTypeIdDict;
	aTi : CM_TrackedItem;
    ti : CM_TrackedItem;
	tis : CM_TIArray; 
	locationList : StringArray;
	dyna : DynaDictionary;
	tmpObj : Object;
	classSorter : CMIF_ClassSorter;
	obj	: Object;
	iter : Iterator;
	str : String;
begin
	create dyna transient;
	dyna.setMembership(CMIF_ClassSorter);
	dyna.addMemberKey('key', false,false);
	dyna.endKeys(true);
	
    create locationList transient;
	create tis transient;
    // Sort out the EDIData
    self.setForCreateNoProxy(_ediConfig, EDIDataType_DeckPlan, null, _realEdiFile, _userCode);
	if _voyage.myOperator &lt;&gt; null then
		self.operatorCode := _voyage.myOperator.code;
	endif;

	self.setStatus (CM_EDIFile.EDI_STATUS_EXTRACTED);	// CCMS SFW 1284 May 2012
	
    // Now Sort out the EDITracked Items
    //Voyage Header
	self.processVoyage(_voyage);
   //Tracked Items
	if _planType = ACTUAL_BAYPLANS then
		self.processLayoutActual(_voyage, tis);
//		tiDict := _voyage.allOnshipTIsByCargoTypeId;
		foreach ti in tis do
			if ti.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) or 
			   ti.myPrimaryActualLocation.isKindOf(CM_ROROGCController) then			//31/07/2012 cnwmh5 #29940
				create classSorter transient;
				classSorter.myObject := ti;
				str := ti.myPrimaryActualLocation.getStowageId(ti);
				classSorter.key := str[1:30];
				dyna.add(classSorter);
			endif;
		endforeach;
	elseif _planType = PROPOSED_BAYPLANS then
		self.processLayoutProposed(_voyage, tis);
		foreach ti in tis do	
			create classSorter transient;
			classSorter.myObject := ti;
			if ti.myPrimaryPlannedLocation &lt;&gt; null then
				str := ti.myPrimaryPlannedLocation.getStowageId(ti);
			elseif ti.myPrimaryActualLocation &lt;&gt; null then
				str := ti.myPrimaryActualLocation.getStowageId(ti);
			endif;
			classSorter.key := str[1:30];
			dyna.add(classSorter);
		endforeach;	
	endif;
	iter := dyna.createIterator();			
	while iter.next(classSorter) do
		ti := classSorter.myObject.CM_TrackedItem;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;' '&amp;classSorter.key;
		self.processTrackedItems(ti, _planType, _voyage, locationList);
		if ti.allChildren.size &gt; 0 then
			foreach aTi in ti.allChildren do
				if self.excludeThisChildCargo( aTi ) then	//23 Jul 2013	NDL	Par 30952
					continue;
				endif;
				self.processTrackedItems(aTi, _planType, _voyage, locationList);
			endforeach;
		endif;
	endwhile;
 	// now check the layouts
  	self.processMissedLayouts(_voyage, _planType, locationList);
epilog
	delete tis;
	delete locationList;
	if dyna &lt;&gt; null then
		dyna.purge;
	endif;
	delete dyna;
	delete iter;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupProxiesCargo" id="2dc5f4ae-3d60-4706-8c78-787c4bbb5b04">
        <source>setupProxiesCargo(_progressStrInteger : Integer; _cmifDeckPlan : CMIF_EDIDeckPlan input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//30 Jan 2012	cnwrs1	Par 29024
//27 Feb 2012	cnwrs1	Par 29157 Check locationId for Roatated
//01 Mar 2012	cnwrs1	Par 29223 - update child to parent setting
//08 Mar 2012	cnwrs1	Par 29246 Fix up loaction checking
//21 Mar 2012	cnwrs1	Par 29308 - check the deckplan voyage code
//24 Apr 2012	cnwrs1	Par 29476
//20 Jun 2013	cnwcs5	par 31854 - avoid null voyage exception
//08 Dec 2014	cnwdb2	PAR 35364
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
// 30 Nov 2022  navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	partsDone, partsInJob 	: Integer;
	progressStr 			: String;
	progressTS 				: TimeStamp;
	ediTI 					: CM_EDITrackedItem;
	terminal 				: CM_Terminal;
	ediCargoTI 				: CM_EDICargoOnShipTI;
	voyageHeaderTI 			: CM_EDIVoyageHeaderTI;
	voyage 					: CM_Voyage;
	realCargoItem 			: CM_TrackedItem;
	lastID 					: String; 
	cmifDeckPlanGCCargo 	: CMIF_DeckPlanGCCargo;
	localIds 				: StringArray;
	parentTI 				: CM_TrackedItem;
	proxyCargoItem 			: CM_TrackedItem;
	trackedItems 			: CM_TIByCargoTypeIdDict;
	tmpDict 				: DynaDictionary;
	tmpObj 					: Object;
	cargoTIs				: CM_EDITIById;
	allEDISealDetails 		: DynaDictionary;
	sealIter 			    : Iterator;
	sealObj 			    : CM_EDITrackedItem;
	ediCargo 				: CM_EDICargoTI;
	ediAddVoyageDepartError : Boolean;

begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	partsInJob 				:= self.allEDITrackedItems.size();
	partsDone 				:= null;
	terminal 				:= self.getMyTerminal;
	ediAddVoyageDepartError	:= terminal.getConfig(EdiAddVoyageDepartError).Boolean;					//13.12.2022 navma1 #52499
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException(UnknownUser, null, null);
		return;
	endif;
	
	progressTS 	:= app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	progressStr := app.getString(_progressStrInteger, partsInJob.display);
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	create localIds transient;
	create trackedItems transient;
	create tmpDict transient;
	create cargoTIs transient;
	create allEDISealDetails transient;
	allEDISealDetails.setMembership(CM_EDISealTI);
	allEDISealDetails.addMemberKey( CM_EDISealTI::id.name, false, true ); 
	allEDISealDetails.endKeys(true);

	foreach ediTI in self.allEDITrackedItems where ediTI.isEDISealDetails do
		allEDISealDetails.add(ediTI);
	endforeach;
	
	tmpDict.setMembership(CM_EDICargoOnShipTI);
	tmpDict.addMemberKey(CM_EDICargoOnShipTI::parentCargoID.name, false, false);	// so we process parents before children
	tmpDict.endKeys(true);

	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyageHeaderTI := ediTI.CM_EDIVoyageHeaderTI;
			//epr par 37090 3/11/15
			voyage := terminal.lookupVoyage(voyageHeaderTI.getVoyageCode(), null, false);								//30.11.2022 navma1 #52499
			if voyage &lt;&gt; null and voyage.hasDeparted and  ediAddVoyageDepartError then									//13.12.2022 navma1 #52499
				app.raiseCMException1(Voyage_departed,voyage.code,ETRow_VoyageCode, ediCargoTI);
			endif;
			
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			localIds.add(ediTI.CM_EDILayoutTI.layoutId);
			
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			ediCargoTI := ediTI.CM_EDICargoOnShipTI;
			cargoTIs.add(ediCargoTI);
			tmpDict.add(ediCargoTI);
		endif;
	endforeach;
	// Fudge the progress indicator slightly
	partsDone := partsDone + (partsInJob/3).Integer;
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	if not allEDISealDetails.isEmpty then
		sealIter := allEDISealDetails.createIterator;
		while sealIter.next(sealObj) do
			ediCargo := cargoTIs[sealObj.id].CM_EDICargoTI;
			if ediCargo = null then
				continue;
			endif;
			app.myTrxUA.trxUpdateEDITIParent(sealObj, ediCargo, _passport);
		endwhile;
	endif;
	// Fudge the progress indicator slightly
	partsDone := partsDone + (partsInJob/3).Integer;
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	foreach tmpObj in tmpDict do
		ediCargoTI := tmpObj.CM_EDICargoOnShipTI;

		ediCargoTI.verifySelfDeckPlan(true);	//30 Jan 2012	cnwrs1	Par 29024	//09 Mar 2012	cnwrs1		Par 29216		
		
		if not _passport.noErrors then
			continue;
		endif;
		
		if lastID &lt;&gt; null then 
			if ediCargoTI.id = lastID then
				app.raiseCMException2(Ship_already_exists, ediCargoTI.id, ediCargoTI.getVoyageCode(), ETRow_Id, ediCargoTI); // cnwdb2 08/12/2014			
				continue;
			endif;
		endif;
		
		lastID := ediCargoTI.id; 
		voyage := terminal.lookupVoyage(ediCargoTI.getVoyageCode(), null, false);											//30.11.2022 navma1 #52499
		
		if voyage &lt;&gt; null then
			realCargoItem := voyage.allOnshipTIsByCargoTypeId[ediCargoTI.cargoType, ediCargoTI.id];
			//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
			if voyage.hasDeparted and  terminal.getConfig(EdiAddVoyageDepartError).Boolean then								//30.11.2022 navma1 #52499
				app.raiseCMException1(Voyage_departed,voyage.code,ETRow_VoyageCode, ediCargoTI);
			endif;
			
		else	
			app.raiseCMException1(ERR_INVALID_VOYAGE, ediCargoTI.getVoyageCode(), ETRow_VoyageCode, ediCargoTI);	//21 Mar 2012	cnwrs1	Par 29308 - check the deckplan voyage code
		endif;
		
		if ediCargoTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or
		   ediCargoTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then		
		   
			create cmifDeckPlanGCCargo transient;
			
			if realCargoItem = null then
				proxyCargoItem := terminal.createTI(ediCargoTI.myCargoType, true);
				
				ediCargoTI.setProxy(proxyCargoItem, ediCargoTI.site, terminal, null, _passport);
				
				if voyage &lt;&gt; null then
					// may happen if no voyage on voyage or carog ediTI
					proxyCargoItem.setVoyageCode(voyage.code, app.myPassport);	//24 Apr 2012	cnwrs1	Par29476
				endif;
				
				proxyCargoItem.setSubTerminal(null,null);
				
				if ediCargoTI.parentCargoID &lt;&gt; null then
					parentTI := trackedItems[ediCargoTI.parentCargoTypeCode, ediCargoTI.parentCargoID];

					if parentTI &lt;&gt; null and proxyCargoItem &lt;&gt; null then
						parentTI.attachChild(proxyCargoItem, _passport);
						delete cmifDeckPlanGCCargo;
						continue;
					else
						// error parent does not exist
						app.raiseCMException2(CargoInvalidParent, ediCargoTI.id, ediCargoTI.parentCargoID, null, ediCargoTI);
						delete proxyCargoItem;
						delete cmifDeckPlanGCCargo;
						continue;
					endif;
				else
					cmifDeckPlanGCCargo.myProxyCargoItem := proxyCargoItem;
					
					_cmifDeckPlan.allDeckPlanGCCargoToAdd.add(cmifDeckPlanGCCargo);
				endif;
			else
				beginLoad;
				cmifDeckPlanGCCargo.myProxyCargoItem := realCargoItem.pxyCreateUpdateProxy();
				
				ediCargoTI.setProxy(cmifDeckPlanGCCargo.myProxyCargoItem, ediCargoTI.site, terminal, null, _passport);
				cmifDeckPlanGCCargo.myProxyCargoItem.setSubTerminal(null,null);
				_cmifDeckPlan.allDeckPlanGCCargoToUpdate.add(cmifDeckPlanGCCargo);
				endLoad;
			endif;
			
			trackedItems.add(cmifDeckPlanGCCargo.myProxyCargoItem);
			
		elseif ediCargoTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if realCargoItem = null then
				// the delete is not necassary as it doesn't exist
			else
				_cmifDeckPlan.allDeckPlanGCCargoToDel.add(realCargoItem);
			endif;
		endif;
	endforeach;
	
	partsDone := partsInJob;
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
epilog
	delete localIds;
	if trackedItems &lt;&gt; null then
		trackedItems.clear();
	endif;
	delete trackedItems;
	delete tmpDict;
	delete cargoTIs;
	delete allEDISealDetails;
	delete sealIter;
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_progressStrInteger" type="Integer"/>
        <Parameter name="_cmifDeckPlan" type="CMIF_EDIDeckPlan" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
