<Class name="CM_EDIDataReleaseRequest" id="9453e1ea-d72a-4d2e-bf44-8805bbfcb6c5">
    <superclass name="CM_EDIData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>cnwrl1 28 August 2009 PAR 20318 - MES 1011 Web EDI Link</text>
    <DbClassMap file="edi"/>
    <JadeMethod name="canBeDBLoaded" id="b4103e21-e318-4d6b-9a30-5a7d59683231">
        <source>canBeDBLoaded(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	result 	:Boolean;
begin
	result := inheritMethod();
	
	if not result then
		result := self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS and self.getMyTerminal.getConfig (EdiReleaseAllowPartial).Boolean;
	endif;

	return result;	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="a85896cb-195d-4ddb-8c8b-abe0b8ac30b7">
        <source>canBePartiallyLoaded(): Boolean protected;
/*
Date		Who		Reason
16 August 2012	cnwcs5	Initial creation - par 30136
11 Oct 2012	cnwrs1	Change to use EdiBookingAllowPartial not EdiReleaseAllowPartial
*/
vars

begin
	return self.getMyTerminal.getConfig (EdiReleaseAllowPartial).Boolean;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="a4ac74eb-3b69-45cf-9a07-8d28925b88d2">
        <source>canBeReprocessedByBGP(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
23 Aug 2013 cnwcs5	CCMS POL 2221 / par 32094(2) 
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//13 May 2015	cnwrs1	Par 36099 - never reprocess a delete EDI release request
*/
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_LOADED or	
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;

	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
	//	purgeDate 	:= self.getUnprocessedExpiryDate (EDIReleaseUnprocPurgePeriod);
		purgeDate 	:= self.getUnprocessedExpiryDate (EDIUnprocReleaseExpiry);	//26 Sep 2014	NDL	Par 34955
		createTS 	:= self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog ('Release EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDEBUG);
			result := false;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEDIUpdateDelete" id="bdc051d6-b749-463b-a985-cb1c26a3214e">
        <source>canDoEDIUpdateDelete(realBulkRelease :CM_BulkRelease; _ediTI :CM_EDIReleaseRequestTI; _coparnRules :CM_EDIPartyCoparnRules;
						_passport :CM_Passport input):Boolean;
/*
Date		Who		Reason
02 May 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
09/05/2012	cnwcs5	par 29481 - do not check if not coparn file for 
16/08/2012	cnwcs5	par 30210 - set EDI TI status in calling method
30/08/2012	cnwcs5	par 30097 - configure whether updates/deletes OK
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	isBlocked, isDelete	:Boolean;
	emailBlockedDelete, emailBlockedUpdate :Boolean; 
	error				:Integer;
	subject, emailFrom, emailTo, message		:String;
begin 
	if not self.isCoparnFile then													// par 29481 May 2012
		return true;																// par 29481 May 2012
	endif;																			// par 29481 May 2012
	
	if _ediTI.getIsToBeProcessed then 
		// par 32094 - the user said process this item so DO IT
		return true;
	endif;
	
	if _coparnRules &lt;&gt; null then
		emailBlockedDelete	:= _coparnRules.sendEmailForBlockedDel;					// par 29481 May 2012
		emailBlockedUpdate 	:= _coparnRules.sendEmailForBlockedUpd;					// par 29481 May 2012
	endif;
	
	if _ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		isBlocked 	:= not realBulkRelease.canDoEDIDelete (_coparnRules, error);	// par 30097
		isDelete	:= true;
	else
		isBlocked := not realBulkRelease.canDoEDIUpdate (_coparnRules, error);		// par 30097
	endif;
	
	if isBlocked then
		if (emailBlockedDelete and isDelete) or (emailBlockedUpdate and not isDelete) then
			emailTo 	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;					// 22 Feb 2012	cnwrs1	Par
			emailFrom 	:= app.myRoot.getConfig(AutoSendersEmailAddress).String;

			subject := app.getErrorString1(error, _ediTI.releaseRequestNumber);
						
			app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), emailTo, emailFrom, null, null, subject, message,
															null, null, null, null, EmailSource_System,  null, _passport);

			app.setContinueCMExceptions(true);	// par 29480 April 2012 because last trx just reset it
		endif;
		// record error for each edi tracked item 
		app.raiseCMException1 (error, _ediTI.releaseRequestNumber, null, _ediTI);
					
		return false;
	endif;		
	
	return true;
end;</source>
        <Parameter name="realBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <Parameter name="_coparnRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
