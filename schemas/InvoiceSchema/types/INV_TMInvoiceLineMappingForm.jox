    <JadeMethod name="doSBMapGetMethodPos" id="8a664697-f50f-4dba-af71-8786c3cf1855">
        <source>doSBMapGetMethodPos(_allRegisteredMethods : StringArray; _name : String) : Integer protected;

vars
	count : Integer;
	theMethod : String;	
begin

	foreach theMethod in _allRegisteredMethods do
		count := count + 1;
		if theMethod = _name then
			return count;
		endif;
	endforeach;

	return 0;
end;</source>
        <access>protected</access>
        <Parameter name="_allRegisteredMethods" type="StringArray"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSBMapSetEnableObjects" id="7ed9c59c-3da9-49b8-a809-507698e88c17">
        <updating/>
        <source>doSBMapSetEnableObjects() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	col, row : Integer;
	theTable : Table;
begin
	theTable := self.tblLines;

	col := theTable.column;
	row := theTable.row;

	self.btnLinesSave.enabled := true;

	theTable.column := col;
	theTable.row := row;

	if (not app.myCurrentUserCan(self.myTerminal, PmAdmTransactionmapMaint)) then
		self.btnLinesSave.enabled := false;
		self.btnLinesNew.enabled := false;
		self.btnLinesDelete.enabled := false;
		self.caption := "Invoice Item Mappings... Read Only";
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblLinesClick" id="09ee4524-45db-4f00-8316-93d7472f4736">
        <updating/>
        <source>doTblLinesClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.tblLines.row = 2 and self.tblLines.column &lt; self.tblLines.columns then
		if self.tblLines.text &lt;&gt; "0" then
			app.msgBox("The default line mapping entry cannot be modified.", "Error" , 0);
			self.tblLines.text := "0";
		endif;
	endif;

	self.doCheckLengthBooleans(self.tblLines.row, self.tblLines.column);
	self.doSBMapSetEnableObjects();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblLinesKeyPress" id="2adeab13-e60e-4444-93fa-123d5ab90302">
        <updating/>
        <source> doTblLinesKeyPress(keyCharCode: Integer io) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if keyCharCode = 32 then // SPACE
		if self.tblLines.row = 2 and self.tblLines.column &lt; self.tblLines.columns then
			if self.tblLines.text &lt;&gt; "0" then
				app.msgBox("The default line mapping entry cannot be modified.", "Error" , 0);
				self.tblLines.text := "0";
			endif;
		endif;
	
		self.doSBMapSetEnableObjects();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMappingHeaders" id="0f6fa844-f76e-439d-b8a8-a88ba4488b10">
        <source>getMappingHeaders() protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	xmlDocument	: JadeXMLDocument;
	maxOrderEle, allXMLMethods,allXMLCargoTypes,allXMLQuestions	: JadeXMLElementArray;
	xmlCargoType,xmlQuestion,xmlMethod	: JadeXMLElement;


	idx,colNum, order, maxOrder : Integer;
	str, strLabel, strMethod, strClass : String;
begin

	self.allHeadings.clear;
	self.allMethods.clear;
	
	if self.myTranMapForm.myCurrentMapTM = null then
		return;
	endif;

	// ### GET XML
	create xmlDocument transient;
	xmlDocument.parseString(InvoiceMappingMethods);
	create allXMLMethods transient;
	create allXMLCargoTypes transient;
	create allXMLQuestions transient;
	create maxOrderEle transient;
	
	xmlDocument.getElementsByTagName(InvoiceMappingTag_ALL, allXMLMethods);	

	foreach xmlMethod in allXMLMethods do

		// INITIALISE
		xmlMethod.getElementsByTagName("MAXORDER", maxOrderEle);	
		foreach xmlCargoType in maxOrderEle do
			maxOrder := xmlCargoType.textData.Integer;
			self.allHeadings[maxOrder] := "";
			self.allMethods[maxOrder] := "";
		endforeach;

		 xmlMethod.getElementsByTagName(InvoiceMappingTag_CARGOTYPE, allXMLCargoTypes);
		foreach xmlCargoType in allXMLCargoTypes do
			strClass := xmlCargoType.getAttributeByName(InvoiceMappingAttr_CLASS).value;
			
			if strClass = CM_TrackedItem.name 
			or strClass = self.myTranMapForm.myCurrentMapTIService.className then
			
				xmlCargoType.getElementsByTagName(InvoiceMappingTag_QUESTION,allXMLQuestions);
				foreach xmlQuestion in allXMLQuestions do
					idx := idx + 1;
					
					strLabel := xmlQuestion.getTagValueOfName(InvoiceMappingTag_LABEL);
					
					// only show isRORO for ship release and receive
					if strLabel = InvoiceMappingLabelIsRORO then
						if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then
							if not (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
								or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
								or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
								continue;
							endif;
						else
							continue;
						endif;
					endif;
					strMethod := xmlQuestion.getTagValueOfName(InvoiceMappingTag_METHOD);
					order :=  xmlQuestion.getTagValueOfName(InvoiceMappingTag_ORDER).Integer;
					self.allHeadings[order] := strLabel;
					self.allMethods[order] := strMethod;
		
				endforeach;
			endif;
		endforeach;
	endforeach;

epilog
	delete xmlDocument;
	delete allXMLMethods;
	delete allXMLCargoTypes;
	delete allXMLQuestions;
	delete maxOrderEle;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMethodIndex" id="cb3416f3-2c6b-484f-acf4-cca46a7329a7">
        <source>getMethodIndex(_col : Integer) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	heading, str : String;
	idx : Integer;
begin
	heading := self.tblLines.accessCell(1, _col).text.trimBlanks();
	
	foreach str in self.allHeadings do
		idx := idx + 1;
		if str = heading then
			return idx;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleMappingSaveException" id="0b079a5d-4306-4c9e-af01-83e95f111de6">
        <source>handleMappingSaveException(_ex : Exception) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		12 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if _ex.errorCode = 1309 then
		app.msgBox("Cannot add the same mapping more than once", "Invoice Line Mapping Problem", MsgBox_OK_Only);
	else
		app.msgBox("An error has occurred during the save of the mappings - " &amp; Cr &amp; "'" &amp; _ex.text &amp; "'." &amp; Cr &amp;
						"Please try again", "Invoice Mapping Problem", MsgBox_OK_Only);
	
	endif;
	return Ex_Abort_Action;

end;</source>
        <access>protected</access>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadMappingHeadings" id="4d04e31a-cb12-4087-8285-b48f003f49dd">
        <source>loadMappingHeadings() protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLabel : String;
	idx, colNum, totW, colW : Integer;
	theTable : CM_DataTable;

begin

	
	theTable := self.tblLines;
	theTable.columns := 0;
	theTable.columns := self.allHeadings.size;
	theTable.rows := 1;
	theTable.fixedColumns := 0;
	theTable.accessMode := 1;
	theTable.row := 1;
	foreach aLabel in self.allHeadings do
		idx := idx + 1;
		if aLabel = null then
			continue;
		endif;
		colNum := colNum + 1;
		theTable.column := colNum;
		theTable.text := aLabel;
		colW := (theTable.getTextExtent(aLabel) + 10).min(55);
		theTable.columnWidth[colNum] := colW;
		theTable.wordWrap := true;
		totW := totW + colW;
	endforeach;
	
	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then		// 14/6/18 MAP TFS38899
		// ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1
		colNum := colNum + 1;
		theTable.columns := colNum;
		theTable.column := colNum;
		theTable.columnWidth[colNum] := 130; 
		totW := totW + 100;
		theTable.text := "Cargo Type";

		colNum := colNum + 1;
		theTable.columns := colNum;
		theTable.column := colNum;
		theTable.columnWidth[colNum] := 130; 
		totW := totW + 100;
		theTable.text := "Sub Type";

		colNum := colNum + 1;
		theTable.columns := colNum;
		theTable.column := colNum;
		theTable.columnWidth[colNum] := 130; 
		totW := totW + 100;
		theTable.text := "Commodity";

		colNum := colNum + 1;
		theTable.columns := colNum;
		theTable.column := colNum;
		theTable.columnWidth[colNum] := 130; 
		totW := totW + 100;
		theTable.text := "Vessel Category";
		
		theTable.accessRow(1).enabled := false; 

	endif;

//	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker)
//		or (self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker)
	if (self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker)	//16 Jul 2018	NDL	TFS 39740
			and (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
			or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name)) then // TFS 42221
		colNum := colNum + 1;
		theTable.columns := colNum;
		theTable.column := colNum;
		theTable.columnWidth[colNum] := 130; 
		totW := totW + 100;
		theTable.text := "Transfer Type";
	endif;

	colNum := colNum + 1;
	theTable.columns := colNum;
	theTable.column := colNum;
	theTable.columnWidth[colNum] := 130; 
	totW := totW + 100;
	theTable.text := "Grouping";

	colNum := colNum + 1;
	theTable.columns := colNum;
	theTable.column := colNum;
	theTable.columnWidth[colNum] := ((theTable.width - totW)).Integer - 5;
	theTable.text := "Invoice Line Items";

	theTable.rowHeight[1] := 35;
	theTable.rows := 1 + self.myCurrentMapQuantityRange.getNumMappings();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMappings" id="38e95a17-6c76-4835-91c6-0ec8edeb9cd0">
        <updating/>
        <source>loadMappings() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason

*/
	// ### TFS BUG 66001 19SEP2024 NAVAB1 - clone the combos for each line

vars

	rowIDX, i, j, k, n, methodIdx, currKey : Integer;
	methodName : String;
	ild : CM_InvoiceLineDesc;
	mapType	: CM_TranMapInvoiceLineGroupType;
	allTMInvoiceLineMaps	: CM_TMInvLineMapByCargoAttrDict;
	lineMapping	: CM_TranMapInvoiceLineMapping;
	theTable : Table;
	theBank : CM_Bank;
//	invDict : CM_InvoiceLineDescMapDict;
	regMethodsArray : StringArray;
	iter : Iterator;
	foundKeys	: IntegerArray;
	transferType: CM_VoyageJobTransferType;
	vesselCategory: HMS_VesselCategory;
	colAfterCheckBoxes: Integer;
	showTransType,
	showVesselCat: Boolean;
	cargotype : CM_CargoType;
	subtype : CM_Product;
	comm : CM_Commodity;
	vessCatCol : Integer;
	combo, combost, combocomm : CMUI_ComboBox;
begin

	if self.myTranMapForm.myCurrentMapTM &lt;&gt; null then
		theBank := self.myTranMapForm.myCurrentMapTM.bank;
	elseif self.myTranMapForm.myCurrentMapTMBOL &lt;&gt; null then	//04 Nov 2019	NLD	TFS 47100
		theBank := self.myTranMapForm.myCurrentMapTMBOL.myBank;
	elseif self.myTranMapForm.myCurrentMapTMVoyage &lt;&gt; null then
		theBank := self.myTranMapForm.myCurrentMapTMVoyage.myBank;
	elseif self.myTranMapForm.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
		theBank := self.myTranMapForm.myCurrentMapTMWorkOrder.myBank; // TFS 39236
	else
		theBank := self.myTranMapForm.myCurrentMapTMEvent.myBank;
	endif;
	theTable := self.tblLines;

	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then
		//showTransType := true;
		showTransType := false;	//16 Jul 2018	NDL	TFS 39740
		showVesselCat := true;
		colAfterCheckBoxes := 1;
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then			// 16/4/18 MAP TFS37555
		if (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
			colAfterCheckBoxes := theTable.columns - 2;
			showTransType := true;
		else
			colAfterCheckBoxes := theTable.columns - 1;
		endif;
	endif;

	if self.myCurrentMapQuantityRange &lt;&gt; null then
// TFS 40620		invDict := self.myCurrentMapQuantityRange.allInvoiceLineMaps;
// TFS 40620		iter := invDict.createIterator();
		regMethodsArray := self.myCurrentMapQuantityRange.allRegisteredMethods;
	else
		return;
	endif;
	
	allTMInvoiceLineMaps := self.myCurrentMapQuantityRange.allTMInvoiceLineMappings;

	theTable.accessMode := Table.AccessMode_Cell;
	theTable.row := 1;

	if self.myTranMapForm.myTMCContractIN &lt;&gt; null 
	or self.myTranMapForm.myTMCContractOUT &lt;&gt; null then
		rowIDX := 1;
		foreach lineMapping in allTMInvoiceLineMaps do
			currKey := lineMapping.mapValue;
			if self.myTranMapForm.myTMCContractIN &lt;&gt; null then
				if currKey &lt;&gt; CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT then
					continue;
				endif;
			else
				if currKey &lt;&gt; CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT then
					continue;
				endif;
			endif;
			rowIDX := rowIDX + 1;
			theTable.rows := rowIDX;
			theTable.row := rowIDX;

			if showVesselCat then

				// ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1
				cargotype := lineMapping.myCargoType;	
				theTable.column := 1;
//				theTable.cellControl := self.cmbCargoType;
//				self.cmbCargoType.listObject := cargotype;
//				if cargotype = null then
//					self.cmbCargoType.listIndex := 1;
//				else
					self.doComboCargoTypeBuild(cargotype,null, true, combo, combost, combocomm);  // NAVAB1 20AUG2024
//				endif;
				theTable.cellControl := combo;
				combo.listObject := cargotype;
				theTable.accessCell(theTable.row, theTable.column).itemObject := cargotype;
				if cargotype = null then
					combo.listIndex := 1;
				endif;
				theTable.accessCell(theTable.row, theTable.column).text := combo.text; //.cmbCargoType.text;

				subtype := lineMapping.myCargoSubtype;	
				theTable.column := 2;
				theTable.cellControl := combost; //self.cmbSubType;
				combost.listObject := subtype; // self.cmbSubType.listObject := subtype;
				if subtype = null then
					//self.cmbSubType.listIndex := 1;
					combost.listIndex := 1;
				endif;
				theTable.accessCell(theTable.row, theTable.column).itemObject := subtype;
				theTable.accessCell(theTable.row, theTable.column).text := combost.text; //.cmbSubType.text;

				comm := lineMapping.myCommodity;	
				theTable.column := 3;
				theTable.cellControl := combocomm; //self.cmbCommodity;
				combocomm.listObject := comm; // self.cmbCommodity.listObject := comm;
				if comm = null then
//					self.cmbCommodity.listIndex := 1;
					combocomm.listIndex := 1;
				endif;
				theTable.accessCell(theTable.row, theTable.column).itemObject := comm;
				theTable.accessCell(theTable.row, theTable.column).text := combocomm.text; //.cmbCommodity.text;
			
			
				vesselCategory := lineMapping.myVesselCategory;	// 14/6/18 MAP TFS38899
				theTable.column := 4;
				vessCatCol := 4;
				theTable.cellControl := self.cmbVesselCategory;
				self.cmbVesselCategory.listObject := vesselCategory;
				if vesselCategory = null then
					self.cmbVesselCategory.listIndex := 1;
				endif;
				theTable.accessCell(theTable.row, theTable.column).itemObject := vesselCategory;
				theTable.accessCell(theTable.row, theTable.column).text := self.cmbVesselCategory.text;
			endif;

			if showTransType then
				transferType := lineMapping.myTransferType;		// 22/3/18 MAP TFS37555
				theTable.column := 1 + vessCatCol; // ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1 showVesselCat.Integer;
				theTable.cellControl := self.cmbTransferType;
				self.cmbTransferType.listObject := transferType;
				if transferType = null then
					self.cmbTransferType.listIndex := 1;
				endif;
				theTable.accessCell(theTable.row, theTable.column).itemObject := transferType;
				theTable.accessCell(theTable.row, theTable.column).text := self.cmbTransferType.text;
			endif;

			mapType := lineMapping.myTMInvoiceLineGroupType;
			theTable.column := 1 + vessCatCol + showTransType.Integer; // ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1 showVesselCat.Integer;
			theTable.cellControl := self.cmbGrouping;
			self.cmbGrouping.listObject := mapType;
			theTable.accessCell(theTable.row, theTable.column).itemObject := mapType;
			theTable.accessCell(theTable.row, theTable.column).text := self.cmbGrouping.text;

			ild := lineMapping.myTMInvoiceLineDesc;
			theTable.column := 2 + vessCatCol + showTransType.Integer; // ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1 showVesselCat.Integer;
			theTable.cellControl := self.cmbInvoiceLines;
			self.cmbInvoiceLines.setIndexFromObject(ild);
			theTable.text := ild.narration;
			theTable.accessRow(theTable.row).itemObject := ild;
			self.currentLineRow := theTable.rows;
		endforeach;
	else
		//first load up the default entry
		rowIDX := 1;
		create foundKeys transient;
		foreach lineMapping in allTMInvoiceLineMaps do
			currKey := lineMapping.mapValue;
			if currKey &lt;&gt; CM_QuantityRangeMap.DEFAULT_INVOICELINE_KEY and
			   not foundKeys.includes(currKey) then
				foundKeys.add(currKey);
			endif;
			if currKey &lt;&gt; CM_QuantityRangeMap.DEFAULT_INVOICELINE_KEY then
				continue;
			endif;
			rowIDX := rowIDX + 1;

			ild := lineMapping.myTMInvoiceLineDesc;
			mapType := lineMapping.myTMInvoiceLineGroupType;
			transferType := lineMapping.myTransferType;
			vesselCategory := lineMapping.myVesselCategory;
			
			// ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1
			cargotype := lineMapping.myCargoType;
			subtype := lineMapping.myCargoSubtype;
			comm := lineMapping.myCommodity;
			
			if global.isValidObject(ild) then
				self.loadMappingsAddRow(rowIDX, ild, mapType, transferType, vesselCategory, cargotype, subtype, comm);
			else
				self.loadMappingsAddRow(rowIDX, theBank.voidInvoiceLineDesc, mapType, transferType, vesselCategory, cargotype, subtype, comm );
			endif;
		endforeach;
		
		// load the remaining entries
		n := regMethodsArray.size;
		theTable.rows := rowIDX;
		theTable.row := rowIDX;
		foreach i in foundKeys do
			
			foreach lineMapping in allTMInvoiceLineMaps do
				currKey := lineMapping.mapValue;
				if currKey &lt;&gt; i then
					continue;
				endif;

				ild := lineMapping.myTMInvoiceLineDesc;
				transferType := lineMapping.myTransferType;
				mapType := lineMapping.myTMInvoiceLineGroupType;
				if theTable.rows = theTable.row then
					theTable.rows := theTable.row + 1;
				endif;
				theTable.row := theTable.row + 1;

				j := 1;
				while (j &lt; colAfterCheckBoxes) do		// 22/3/18 MAP TFS37555
					theTable.column := j;
					theTable.inputType := Table.InputType_CheckBox;
					theTable.row := 1;
					methodIdx := self.allHeadings.indexOf(theTable.text);

					methodName := self.allMethods[methodIdx];
					theTable.row := theTable.rows;
					if regMethodsArray.includes(methodName) then
						k := regMethodsArray.indexOf(methodName);
						if i.bitAnd(2^(k-1)) &lt;&gt; 0 then
							theTable.text := "1";
						else
							theTable.text := "0";
						endif;
					else
						theTable.text := "0";
					endif;
					j := j + 1;
				endwhile;

				if showTransType then
					theTable.column := theTable.columns - 2;
					theTable.cellControl := self.cmbTransferType;
					self.cmbTransferType.listObject := transferType;
					if transferType = null then
						self.cmbTransferType.listIndex := 1;
					endif;
					theTable.accessCell(theTable.row, theTable.column).itemObject := transferType;
					theTable.accessCell(theTable.row, theTable.column).text := self.cmbTransferType.text;
				endif;

				theTable.column := theTable.columns - 1;
				theTable.cellControl := self.cmbGrouping;
				self.cmbGrouping.listObject := mapType;
				theTable.accessCell(theTable.row, theTable.column).itemObject := mapType;
				theTable.accessCell(theTable.row, theTable.column).text := self.cmbGrouping.text;

				theTable.column := theTable.columns;
				theTable.cellControl := self.cmbInvoiceLines;
				self.cmbInvoiceLines.setIndexFromObject(ild);
				theTable.text := ild.narration;
				theTable.accessRow(theTable.row).itemObject := ild;
			endforeach;
		endforeach;
	endif;
epilog
	delete iter;
	delete foundKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMappingsAddRow" id="edb6ca77-ef2e-4389-b4c5-392179ea9f98">
        <updating/>
        <source>loadMappingsAddRow(_row : Integer; _ild : CM_InvoiceLineDesc; _mapType : CM_TranMapInvoiceLineGroupType; _transferType: CM_VoyageJobTransferType; _vesselCategory: HMS_VesselCategory;
								_cargotype : CM_CargoType; _subtype : CM_Product; _comm : CM_Commodity) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		Add a table row, set up the columns with a check box for each question, a combo for the grouping
//					and a combo for the invoice line description.
// ---------------------------------------------------------------------------
	// ### TFS BUG 66001 19SEP2024 NAVAB1 - clone the combos for each line

vars

	i	: Integer;
	theTable : Table;
	colAfterCheckBoxes: Integer;
	showTransType,
	showVesselCat: Boolean;
	combo, combost, combocomm: CMUI_ComboBox;

begin

		
	theTable := self.tblLines;
	theTable.accessMode := Table.AccessMode_Cell;

	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then				// 18/6/18 MAP TFS38899
	//	showTransType := true;
		showTransType := false;	//16 Jul 2018	NDL	TFS 39740
		showVesselCat := true;
		colAfterCheckBoxes := 1;
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then			// 16/4/18 MAP TFS37555
		if (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name 
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
			colAfterCheckBoxes := theTable.columns - 2;
			showTransType := true;
		else
			colAfterCheckBoxes := theTable.columns - 1;
		endif;
	endif;

	theTable.rows := _row;
	theTable.row := _row;
	
	i := 1;
	while (i &lt; colAfterCheckBoxes) do		// 22/3/18 MAP TFS37555
		theTable.column := i;
		theTable.inputType := Table.InputType_CheckBox;
		theTable.text := "0";
		i := i + 1;
	endwhile;

	if showVesselCat then

		self.doComboCargoTypeBuild(_cargotype,null, true, combo, combost, combocomm);  // NAVAB1 20AUG2024
		app.doWindowEvents(200); // BUG 66001 - ADDED this to stop previous selected combo box selected item being used to set the new row (which should be all defaults)
	
		// ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1
		theTable.column := 1;
		theTable.cellControl := combo;
		combo.listObject := _cargotype; 
		theTable.accessCell(theTable.row, theTable.column).itemObject := _cargotype;
		if _cargotype = null then
			combo.listIndex := 1;
		endif;
		theTable.accessCell(theTable.row, theTable.column).text := combo.text;
	
		theTable.column := 2;
		theTable.cellControl := combost; 
		combost.listObject := _subtype; 
		if _subtype = null then
			combost.listIndex := 1;
		endif;
		theTable.accessCell(theTable.row, theTable.column).itemObject := _subtype;
		theTable.accessCell(theTable.row, theTable.column).text := combost.text; 
	
		theTable.column := 3;
		theTable.cellControl := combocomm;
		combocomm.listObject := _comm; 
		if _comm = null then
			combocomm.listIndex := 1;
		endif;
		theTable.accessCell(theTable.row, theTable.column).itemObject := _comm;
		theTable.accessCell(theTable.row, theTable.column).text := combocomm.text; 
	
	
		theTable.column := 4;
		theTable.cellControl := self.cmbVesselCategory;
		self.cmbVesselCategory.listObject := _vesselCategory;		//16 Jul 2018	NDL	TFS 39740
		if _vesselCategory = null then
			self.cmbVesselCategory.listIndex := 1;
		endif;
		theTable.accessCell(theTable.row, theTable.column).itemObject := _vesselCategory;
		theTable.accessCell(theTable.row, theTable.column).text := self.cmbVesselCategory.text;
	endif;

	if showTransType then
		theTable.column := theTable.columns - 2;
		theTable.cellControl := self.cmbTransferType;
		self.cmbTransferType.listObject := _transferType;
		if _transferType = null then
			self.cmbTransferType.listIndex := 1;
		endif;
		theTable.accessCell(theTable.row, theTable.column).itemObject := _transferType;
		theTable.accessCell(theTable.row, theTable.column).text := self.cmbTransferType.text;
	endif;

	theTable.column := theTable.columns - 1;
	theTable.cellControl := self.cmbGrouping;
	self.cmbGrouping.listObject := _mapType;
	theTable.accessCell(theTable.row, theTable.column).itemObject := _mapType;
	theTable.accessCell(theTable.row, theTable.column).text := self.cmbGrouping.text;

	theTable.column := theTable.columns;
	theTable.cellControl := self.cmbInvoiceLines;
	//epr TFS 1664 18/3/16
	self.cmbInvoiceLines.setIndexFromObject(_ild);
	theTable.text := _ild.narration;
	theTable.accessRow(theTable.row).itemObject := _ild;
	self.currentLineRow := theTable.rows;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_ild" type="CM_InvoiceLineDesc"/>
        <Parameter name="_mapType" type="CM_TranMapInvoiceLineGroupType"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType"/>
        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_cargotype" type="CM_CargoType"/>
        <Parameter name="_subtype" type="CM_Product"/>
        <Parameter name="_comm" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="recolourTable" id="f73b4e3f-24d7-4dfe-9d72-4068e89b1617">
        <updating/>
        <source>recolourTable(_table : Table input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     November 2012 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx,
	startRow,
	endRow		: Integer;
begin
	startRow	:= _table.fixedRows + 1;
	endRow		:= _table.rows;
	
	// re-colour
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			_table.accessRow(idx).backColor := self.colorRow1;
		else
			_table.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="88328c56-334c-4796-b03a-ce7432cc0554">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2012 by cnwab1
//
