    <JadeMethod name="getYMValueForVoyageWOAutoId" id="3885bc7d-0e5f-4bd4-a6d2-6b360c964ade">
        <source>getYMValueForVoyageWOAutoId( _yearMonthStr : String io; _zString : String; _lastSeqNumUsed : Integer output ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/08/2018	jlgndl1	Initial creation	TFS 40249
07 OCt 2021 jlier1	TFS 51963 - renamed
*/

vars

	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;

	id : String;
	workString : String;
	voyNumInteger : Integer;
	workInt : Integer;

begin

	if self.allWorkOrders.isEmpty then
		return 0;
	endif;
	
	foreach wo in self.allWorkOrders do
		if not wo.isVoyageWorkOrder then
			continue;
		endif;
		id := wo.id;
		if id.length = 16 then
			// format is YYYYMMVVVVV-ZSSS,  we want the 'VVVVV' and the 'SSS' bits which both should be integers.
			if voyNumInteger &lt; 1 then
				workString := id[7:5];
				if workString.isInteger then
					_yearMonthStr := id[1:6]; // so we don't increment the year month value...
					voyNumInteger := workString.Integer;
				endif;
			endif;
			
			//now get the last seqNum used ( for this zString type )
			
			if id[13:1] &lt;&gt; _zString then
				continue;
			endif;
			
			workString := id[14:3];
			if workString.isInteger then
				workInt :=  workString.Integer;
				if workInt &gt; _lastSeqNumUsed then
					_lastSeqNumUsed := workInt;
				endif;
			endif;
			
		endif;
	endforeach;
	
	return voyNumInteger;

epilog

end;</source>
        <Parameter name="_yearMonthStr" type="String" usage="io"/>
        <Parameter name="_zString" type="String"/>
        <Parameter name="_lastSeqNumUsed" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gettotalNONChargeShiftBerthage" id="881559b7-04fc-4321-a0b0-7c57e9706039">
        <source>gettotalNONChargeShiftBerthage() : Integer;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		Get the total number of time that the voyage was at a non chargeable berth
//
// ---------------------------------------------------------------------------

vars
	aVM,thePrevMove : HMS_VoyageMovement;
	aWharf : HMS_Wharf;
	aRes : HMS_Resource;
	totalNonChargeMinutes, diff : Integer;
begin

	foreach aVM in self.myHMSVoyageData.allVoyageMovements do
		if aVM.moveType = HMSMovementTypeShift then
			aWharf := aVM.getMyWharf;
			aRes := aWharf.getResourceForHarbourMovement(HMSMovementTypeShift,HMS_Wharf.First_Resource);
			
			// ## NON CHARGEABLE WHARF!!!!!!
			if aRes = null then
				thePrevMove := aVM.getVoyageMovementPrevious(); 
				if thePrevMove &lt;&gt; null then
					diff := thePrevMove.occursOnDTNEW.differenceInHours(aVM.occursOnDTNEW);
					totalNonChargeMinutes := diff * 60;
				endif;
			endif;
		endif;
	endforeach;
	return totalNonChargeMinutes;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleGCForWorkOrder" id="617587dc-5c63-4676-a87e-0cf811564023">
        <updating/>
        <source>handleGCForWorkOrder(_hasCargo : Boolean) updating;
/*

Purpose:			TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgab1	Initial creation

*/

vars
	pxyGCVoyage : CM_GeneralCargoVoyageStructure;

begin
	if _hasCargo then
		if self.myGeneralCargoVoyage = null then
			create pxyGCVoyage transient;
			self.setProxyVoyageGeneralCargo(pxyGCVoyage);
		endif;
		
	else
		if self.myGeneralCargoVoyage &lt;&gt; null then
			delete self.myGeneralCargoVoyage;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_hasCargo" type="Boolean"/>
    </JadeMethod>
