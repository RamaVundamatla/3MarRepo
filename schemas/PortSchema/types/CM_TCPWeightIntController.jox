    <JadeMethod name="closeConnection" id="9d3e4fbc-3094-433c-aff8-8d0f5931316d">
        <updating/>
        <source>closeConnection() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " myTCPConnection= " &amp; self.myTCPConnection.String &amp; " connectingState= " &amp; self.connectingState.String);
	if app.isValidObject(self.myTCPConnection)  then			//close can be called when the connection is in any state 
		self.myTCPConnection.close();
	endif;
	
	self.updateConnectionStatus();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="closeEvent" id="6a1f7746-61ae-47df-b9c3-c31196ad6d5c">
        <updating/>
        <source>closeEvent(_connection : TcpIpConnection) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwrh7	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " myTcpConnection=" &amp; self.myTCPConnection.String &amp; " connectiong state= " &amp; self.myTCPConnection.state.String);
	self.myTCPConnection.close();
epilog

end;</source>
