    <JadeMethod name="resetData_38579" id="14c447e1-4e58-4878-8a01-9b625c8f9b3f">
        <source>resetData_38579();
/*

Purpose:			Delete the train and all it's wagons

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2021	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	train					: CM_Train;
	user					: CM_User;
	
	tisToDelete				: StringArray;
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	create tisToDelete transient;
	tisToDelete.add("JLG38579A01");
	self.deleteTIResetScript(tisToDelete, terminal);
	
	train := self.getTrain("TRAIN38579", null);
	self.deleteTrainAndAssociatedObjs(train);

epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete tisToDelete;
	
end;</source>
