    <JadeMethod name="utlDeleteLogDocketData" id="6136e9aa-21a8-491a-9f0b-0d58a4d18de2">
        <source>utlDeleteLogDocketData(_logDocketData : CM_LogDocketData io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal : CM_Terminal;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	terminal:=_logDocketData.myTerminal;
	app.myValDA.valLogDocketData(_logDocketData);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_logDocketData);
	endif;
	
	//cnwmc5 - 9 April 2014 - PAR 33937
	if _passport.noErrors then
		//this event is also caused in the archiving of weighBridge data
		//(see CM_TrxControlUpdateAgent.trxUpdateWeighBridgeArchive
		//epr par 34885 11/9/14
		app.myEventManager.createSingleObjInfoNoteEvt(terminal,terminal.getTerminalEvent(EVENT_WEIGHBRIDGE_REMOVE),  _logDocketData);
	endif;
	
	if _passport.noErrors then
		_logDocketData.erase(NORMAL_ERASE);
	endif;
	
epilog
	return;

end;</source>
        <Parameter name="_logDocketData" type="CM_LogDocketData" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
