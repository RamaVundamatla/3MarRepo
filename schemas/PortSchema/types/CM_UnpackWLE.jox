<Class name="CM_UnpackWLE" id="b8d5097a-124d-48d6-8a5c-4d822f4888bb">
    <superclass name="CM_WorkListEntry"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
