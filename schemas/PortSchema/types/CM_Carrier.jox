    <JadeMethod name="setForCreate" id="133eacda-d6aa-4aa3-bf1f-9ba38f9bb615">
        <updating/>
        <source>setForCreate(pProxyCarrier : CM_Carrier; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDAC	: CM_DataAccessController;
begin

	self.setForUpdate(pProxyCarrier);
//	self.myRoot := app.myRoot;

	tmpDAC := _passport.allDataAccessControllers[CM_Carrier.name];
	if tmpDAC &lt;&gt; null then
		tmpDAC.addObject(self);
	endif;

end;</source>
        <Parameter name="pProxyCarrier" type="CM_Carrier"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3ddf1aba-b9bc-44ba-b0fd-46669a4fe8c9">
        <updating/>
        <source>setForUpdate(_proxy:CM_Carrier) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// ---------------------------------------------------------------------------
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - 
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars

	needsRefresh : Boolean;

begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;

	self.code 					:= _proxy.code.trimBlanks;
	if self.description &lt;&gt; _proxy.description then	//03 Apr 2019	NDL	TFS 44194
		self.description 		:= _proxy.description.trimBlanks;
		needsRefresh 			:= true;	//03 Apr 2019	NDL	TFS 44194
	endif;
	self.isNotAvailableForEntry	:= _proxy.isNotAvailableForEntry;
	self.isRail					:= _proxy.isRail;					//+ cnwmd1, CCMS 1067, Par 19710
	self.isRoad					:= _proxy.isRoad;					//+ cnwmd1, CCMS 1067, Par 19710
	self.isSubCarrier 			:= _proxy.isSubCarrier;				//12/05/2022 navhl20 TFS 53430
	self.colour					:= _proxy.colour;					// 12/6/17 MAP TFS4209
	self.setDebtor(_proxy.myDebtor);								//+ cnwmd1, CCMS 1067
	self.setOperatorDARec(_proxy.allDataAccessControllersRec.first());		// 12/9/17 MAP TFS2749
	self.setOperatorDARel(_proxy.allDataAccessControllersRel.first());		// 12/9/17 MAP TFS2749

	self.allPINNotifyEmailAddresses.clear;
	_proxy.allPINNotifyEmailAddresses.copy(self.allPINNotifyEmailAddresses);

	self.myRoot := app.myRoot;
	
	//03 Apr 2019	NDL	TFS 44194
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setCarrierDictNeedsRefresh();
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="0f738b60-6e91-4035-8acf-6bfa340a328f">
        <updating/>
