    <JadeMethod name="acceptAllFromLocation" id="60b60abc-a21f-41c0-884a-89ef0bf7797b">
        <updating/>
        <source>acceptAllFromLocation(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_Log;
	loadErr : CM_LogLoadError;
	tmpTISet : CM_TISet;
	bolOutExt : CM_BOLExtLogOut;
	location : CM_LocationsController;
	bolOut : CM_BOLOut;

begin
	
	create tmpTISet transient;
	bolOutExt := self.myMasterLoadError.myBOLExtLogOut;
	bolOut := bolOutExt.myBOL.CM_BOLOut;
	location := self.myMasterLoadError.myLog.getPrimaryLocation(REAL_MODE);
	
	//self.allLogLoadErrors should be zero but clear anyway
	self.allLogLoadErrors.clear(); 
	bolOutExt.allLogLoadErrors.copy(self.allLogLoadErrors);
	
	foreach loadErr in self.allLogLoadErrors do
		exclusiveLock(loadErr);
		log := loadErr.myLog;
		if log &lt;&gt; null then
			exclusiveLock(log);
			if log.getPrimaryLocation(REAL_MODE) = location then
				if log.myReleaseBOL = null then
					//epr TFS 5282 6/10/17 - logging
					if bolOut &lt;&gt; null then
						app.writeLog(method.qualifiedName &amp; " setting release BOL for log" &amp; log.id,  LogINFO);
					endif;
					log.setMyReleaseBOL(bolOut);
				endif;
				log.setMyVoyage(bolOut.myVoyage, _passport);			
				loadErr.erase(NORMAL_ERASE);
				if log.getLoadOutErrors(true, true) then		// 17/03/2010 cnwmh5 #22707
					tmpTISet.add(log);
				endif;
			endif;
		endif;
	endforeach;
	if self.moveToShip(tmpTISet, _passport) then
		bolOutExt.setIsFullyLoaded(true);
	endif;
	bolOutExt.setMyLogVoyageIfInError();
	bolOutExt.setPartiallyLoaded();													
	
epilog
	delete tmpTISet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="acceptSpecs" id="c8ecad48-d596-461c-a7b0-2860dc2f545c">
        <updating/>
        <source>acceptSpecs(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_Log;
	loadErr : CM_LogLoadError;
	tmpTISet : CM_TISet;
	bolOutExt : CM_BOLExtLogOut;
	product : CM_Product;

begin

	create tmpTISet transient;
	bolOutExt := self.myMasterLoadError.myBOLExtLogOut;
	product := self.myMasterLoadError.myLog.myProduct;
	
	//self.allLogLoadErrors should be zero but clear anyway
	self.allLogLoadErrors.clear(); 
	bolOutExt.allLogLoadErrors.copy(self.allLogLoadErrors);
	
	foreach loadErr in self.allLogLoadErrors do
		exclusiveLock(loadErr);
		log := loadErr.myLog;
		if log &lt;&gt; null then
			exclusiveLock(log);
			if log.myProduct = product then
				log.setMyVoyage(log.myReleaseBOL.myVoyage, _passport);				
				if _passport.noErrors then
					loadErr.erase(NORMAL_ERASE);
					if log.getLoadOutErrors(false, true) then
						tmpTISet.add(log);
					endif;
				else
					return;
				endif;
			endif;
		endif;
	endforeach;
	if self.moveToShip(tmpTISet, _passport) then
		bolOutExt.setIsFullyLoaded(true);
	endif;
	bolOutExt.setMyLogVoyageIfInError();
	bolOutExt.setPartiallyLoaded();													
	
epilog
	delete tmpTISet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeLogToNewLog" id="7d68c405-26d2-4828-9648-7aada2368018">
        <updating/>
        <source>changeLogToNewLog(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti, existingTI : CM_TrackedItem;
	terminal 	: CM_Terminal;
	matches 	: Integer;
	bolOutExt 	: CM_BOLExtLogOut;
	bolOut 		: CM_BOLOut;
	movedOK		: Boolean;
begin

	bolOutExt 	:= self.myMasterLoadError.myBOLExtLogOut.CM_BOLExtLogOut;
	bolOut 		:= bolOutExt.myBOL.CM_BOLOut;
	terminal 	:= bolOut.myTerminal;
	existingTI 	:= terminal.lookupTrackedItem(self.newID.toUpper, TI_CargoType_Log, TI_STATE_NORMAL, null, false);
	
	if existingTI &lt;&gt; null then
		exclusiveLock(existingTI);
		//epr TFS 5282 6/10/17 - logging
		if (bolOut &lt;&gt; null) then
			app.writeLog(method.qualifiedName &amp; " setting release BOL for log" &amp; existingTI.id,  LogINFO);	
		endif;	
		existingTI.setMyReleaseBOL(bolOut);
		existingTI.setMyVoyage(bolOut.myVoyage, _passport);			
		if existingTI.CM_Log.getLoadOutErrors(false, false) then
			movedOK := self.moveLogToShip(existingTI, _passport);
		endif;
		self.myMasterLoadError.erase(NORMAL_ERASE);

		if movedOK and (not bolOutExt.isInError) then
			// check to see if we can flag as fully loaded
			bolOutExt.checkLoadedFlags(true);
		endif;

		bolOutExt.setPartiallyLoaded();
		bolOutExt.setMyLogVoyageIfInError();						
	else
		self.myMasterLoadError.set(self.newID, self.myMasterLoadError.myBOLExtLogOut, null, 'Not Found', LogNotFound);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeToNoNumbers" id="d56e6f59-7b12-464c-ad3e-56e966d29730">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>changeToNoNumbers(_passport : CM_Passport input) updating, clientExecution;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_Log;
	newNNLog : CM_LogNoNumber;
	loadErr : CM_LogLoadError;
	tmpTISet : CM_TISet;
	bolOutExt : CM_BOLExtLogOut;
begin

	create tmpTISet transient;
	foreach loadErr in self.allLogLoadErrors do
		exclusiveLock(loadErr);
		exclusiveLock(loadErr.myBOLExtLogOut);
		bolOutExt := loadErr.myBOLExtLogOut;
		if loadErr.myLog &lt;&gt; null then
			// Log is already a No Number, use that and don't create another one.
			if loadErr.myLog.isKindOf(CM_LogNoNumber) then
				newNNLog := loadErr.myLog.CM_LogNoNumber;
				newNNLog.changeState(TI_STATE_NORMAL, _passport);
				newNNLog.setMyVoyage(bolOutExt.myVoyage, _passport);
				loadErr.erase(NORMAL_ERASE); //PAR 8134										
			elseif loadErr.myLog.myReleaseBOL &lt;&gt; null then
				//loadErr gets deleted in detactTI - PAR 8134
				loadErr.myLog.myReleaseBOL.myExtension.CM_BOLExtLogOut.detachTI(loadErr.myLog);
				newNNLog := bolOutExt.addNoNumberLog(_passport);						
			endif;
		else
			// No log so create a NoNumber one
			newNNLog := bolOutExt.addNoNumberLog(_passport);
			loadErr.erase(NORMAL_ERASE); //PAR 8134							
		endif;		
		if (not _passport.noErrors) then
			return;
		endif;
		
		//loadErr.erase(NORMAL_ERASE); PAR 8134		
		if newNNLog.getLoadOutErrors(false, false) then
			tmpTISet.add(newNNLog);
		endif;
		bolOutExt.setMyLogVoyageIfInError();
		bolOutExt.setPartiallyLoaded();										
	endforeach;
	
	if self.moveToShip(tmpTISet, _passport) then
		bolOutExt.setIsFullyLoaded(true);
	endif;
	
epilog
	delete tmpTISet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteAllSelected" id="6b71e633-1b3e-444b-a101-1087bf88ee88">
        <updating/>
        <source>deleteAllSelected(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log 	: CM_Log;
	loadErr : CM_LogLoadError;
	bolOutExt : CM_BOLExtLogOut;
	tiUpdCntrl : CMIF_TIUpdateController;		
begin

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);

	foreach loadErr in self.allLogLoadErrors do
		exclusiveLock(loadErr);
		bolOutExt := loadErr.myBOLExtLogOut;		
		if loadErr.myLog &lt;&gt; null then
			log := loadErr.myLog;
			exclusiveLock(log);
			//Erase loadErr first as detachLog updates voyage is in error
			loadErr.erase(NORMAL_ERASE);						
			if log.isKindOf(CM_LogNoNumber) then
				log.CM_LogNoNumber.createStockMovementForOffload(tiUpdCntrl, _passport);			
				log.erase(NORMAL_ERASE);
			elseif log.myReleaseBOL &lt;&gt; null then
				log.myReleaseBOL.myExtension.CM_BOLExtLogOut.detachTI(log);
			endif;
		else
			loadErr.erase(NORMAL_ERASE);
		endif;
		if bolOutExt &lt;&gt; null then
			exclusiveLock(bolOutExt);
			if (not bolOutExt.isInError) then
				// check to see if we can flag as fully loaded
				bolOutExt.checkLoadedFlags(true);
			endif;
			bolOutExt.setMyLogVoyageIfInError();
			bolOutExt.setPartiallyLoaded();				
		endif;
	endforeach;
epilog
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="4ceef9bc-3323-4bea-a232-eb505f635de8">
        <updating/>
        <source>doUpdate(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	if self.mode = Mode_AcceptAllFromLocation then
		self.acceptAllFromLocation(_passport);
		
	elseif self.mode = Mode_AcceptSpec then
		self.acceptSpecs(_passport);
		
	elseif self.mode = Mode_ChangeToNoNumber then
		self.changeToNoNumbers(_passport);
		
	elseif self.mode = Mode_DeleteSelected then
		self.deleteAllSelected(_passport);
		
	elseif self.mode = Mode_EditID then
		self.changeLogToNewLog(_passport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name,
			'Invalid Mode (' &amp; self.mode.String &amp; ') passed to method. Contact Developer.');	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveLogToShip" id="0cea2dd5-4e35-4e88-9ac4-48b779e22ad6">
        <updating/>
        <source>moveLogToShip(_ti : CM_TrackedItem; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	newLocn 		: CM_LocationsController;
	cancelSave		: Boolean;
begin
	
	exclusiveLock(_ti);
	// Initialise move controller parameters.
	create moveController transient;
	
	newLocn := _ti.myReleaseBOL.myPlannedLocation;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(newLocn);
	moveController.setMyTrackedItem(_ti);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if (not _passport.noErrors) then
		return false;
	endif;

	return true;
	
epilog
	delete moveController;		
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveToShip" id="14ccaa93-5702-4be0-aaa8-50438e61cf25">
        <updating/>
        <source>moveToShip(_tiSet : CM_TISet; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	moveController	: CMIF_MoveController;
	newLocn 		: CM_LocationsController;
	cancelSave, firstTime : Boolean;
begin

	if _tiSet = null or _tiSet.size = 0 then
		return false;
	endif;
	// Initialise move controller parameters.
	create moveController transient;

	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	
	firstTime := true;
	foreach ti in _tiSet do
		exclusiveLock(ti);
		if firstTime then
			newLocn := ti.myReleaseBOL.myPlannedLocation;
			moveController.setMyToPrimaryLocation(newLocn);						
			moveController.setMyTrackedItem(ti);
			firstTime := false;
			continue;
		endif;
		moveController.allOtherTrackedItems.add(ti);
	endforeach;		

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if (not _passport.noErrors) then
		return false;
	endif;
	
	return true;
	
epilog
	delete moveController;		
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="241e2b3d-fd0e-4766-9a43-60d78bef1b5f">
        <source>validateForUpdate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.mode = self.Mode_AcceptAllFromLocation or
	   self.mode = self.Mode_AcceptSpec then
		if self.myMasterLoadError = null then
			app.raiseCMException2(InvalidAttrForUpdate, 'Load Error', 'Null', null, null);
		endif;
		if _passport.noErrors then
			if self.myMasterLoadError.myLog = null then
				app.raiseCMException2(InvalidAttrForUpdate, 'Load Error myLog', 'Null', null, null);
			endif;
		endif;
	elseif self.mode = self.Mode_EditID then
		if self.myMasterLoadError = null then
			app.raiseCMException2(InvalidAttrForUpdate, 'Load Error', 'Null', null, null);
		endif;
		
	elseif self.mode = self.Mode_ChangeToNoNumber or
		self.mode = self.Mode_DeleteSelected then
		if self.allLogLoadErrors.size = 0 then
			app.raiseCMException(NoItemsSelected, null, null);
		endif;			
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode (' &amp; self.mode.String &amp; ') passed to method. Contact Developer.');	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
