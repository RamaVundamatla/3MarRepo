    <JadeMethod name="isInstructionType_Match" id="b3aeea12-1192-4a61-bf2f-dae1fdf1764e">
        <source>isInstructionType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars
	code 	: String;
	ti 	 	: CM_TrackedItem;
	rs		: CM_ReserveSelection;
	bi		: CM_BookingRefItem;
begin
	
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		if ti.myInstructions = null then
			return true;
		endif;
		
		code := ti.myInstructions.myInstructionType.code;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isInstructionType_Compare, code);
epilog

end;</source>
