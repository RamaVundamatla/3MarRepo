    </JadeMethod>
    <JadeMethod name="showSearchSelectVisitForm" id="fdf1ed68-39ff-42d6-a65b-895e32f0ff43">
        <source>showSearchSelectVisitForm(_selectedWorkingVoyage : CMIF_HMS_WorkingVoyage; _masterMenuAction : CMUI_MenuAction; _viewController : HMS_CMIF_ViewController);
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	theForm : HMS_SearchSelectVisit;
	menuAction : CMUI_MenuAction;
begin

	menuAction := app.myController.createMenuAction(PmHMSSearchSelectView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	theForm := menuAction.goToObject(null, null, false, null).HMS_SearchSelectVisit;
	if theForm = null then
		return;
	endif;

	theForm.myViewController := _viewController;
	theForm.currentVoyage := _selectedWorkingVoyage;
	theForm.show();

end;</source>
        <Parameter name="_selectedWorkingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_viewController" type="HMS_CMIF_ViewController"/>
    </JadeMethod>
    <JadeMethod name="showVoyageResourceUsedFormHMS" id="c63ba29c-5eb7-4006-836d-e0169783ce2e">
        <source>showVoyageResourceUsedFormHMS(_object : Object; _masterMenuAction : CMUI_MenuAction; _isModal : Boolean; _viewController : HMS_CMIF_ViewController input);
// ---------------------------------------------------------------------------
// Created:		August 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	resForm : Form;
	menuAction : CMUI_MenuAction;
	inv : CM_Invoice;
	assistClass,aClass : Class;
	jrw : Schema;
	jrwGlobal : Class;
	jrwGlobalObject : Object;
	path,
	fileName	: String;
	pos		: Integer;
	
	
begin
	//jrw := rootSchema.getSchema("HmsSchema");
	
	if _isModal then
		//aClass := jrw.getClass("HMS_VoyageResourceUsedNonMDI");
		aClass := HMS_VoyageResourceUsedNonMDI;
	else
		//aClass := jrw.getClass("HMS_VoyageResourceUsedForm");
		aClass := HMS_VoyageResourceUsedForm;
	endif;
	
	if not _object.isKindOf(CM_Voyage)  and _object &lt;&gt; null and not _object.isKindOf(CMIF_HMS_WorkingVoyage)then
		return;
	endif;

	if _isModal then
		resForm := app.loadForm(aClass, HMS_Assistant, false, false, true, self.myTerminal, _masterMenuAction);
	else
		resForm := app.loadForm(aClass, CMUI_Assistant, false, false, true, self.myTerminal, _masterMenuAction);
	endif;
	if resForm = null then
		return;
	endif;

	if _object.isKindOf(CMIF_HMS_WorkingVoyage) then
		//resForm.setPropertyValue("myCurrentVoyage", _object.CMIF_HMS_WorkingVoyage.myHMSVoyageData.myVoyage);
		resForm.setPropertyValue(HMS_VoyageResourceUsedNonMDI::myCurrentVoyage.name, _object.CMIF_HMS_WorkingVoyage.myHMSVoyageData.myVoyage);
		//resForm.setPropertyValue("myViewController", _viewController);
		resForm.setPropertyValue(HMS_VoyageResourceUsedNonMDI::myViewController.name, _viewController);
		
	else
		resForm.setPropertyValue(HMS_VoyageResourceUsedForm::myCurrentVoyage.name, _object);
	endif;
	resForm.setPropertyValue(CM_BaseForm::isBaseFormModal.name, _isModal);
	
	//We're potentially coming from a modal form so we don't want to be able to open any other forms from here otherwise we loop
	resForm.HMS_VoyageResourceUsedForm.showContextMnuTIEdit(false);
	resForm.show(); 

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_isModal" type="Boolean"/>
        <Parameter name="_viewController" type="HMS_CMIF_ViewController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showWorkingMovementForm" id="a181e0a2-7cb6-40ca-9a21-22d70ebdb2a6">
        <source>showWorkingMovementForm(_workingMovement : CMIF_HMS_WorkingMovement; _workingVoyage : CMIF_HMS_WorkingVoyage; _doEdit : Boolean; _masterMenuAction : CMUI_MenuAction; _viewController : HMS_CMIF_ViewController);
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	form	: HMS_WorkingMovementMaint;
	
begin
	if _workingMovement = null then
		return;
	endif;
	
	form	:=	app.loadForm(HMS_WorkingMovementMaint, HMS_Assistant, false, false, true, self.myTerminal, _masterMenuAction).HMS_WorkingMovementMaint;
	
	if form = null then
		return;
	endif;
	
	form.aMySelectedVoyage := _workingVoyage;
	
	if _doEdit then
		form.aMySelectedMovement := _workingMovement;
	else
		//Adding a shift movement for the selected voyage
		//do not set the movement as a shift one will be created
	endif;
	
	form.setMyTerminal(_viewController.myTerminal);
	form.aMyViewController := _viewController;
	form.showModal();

epilog
	delete form;

end;</source>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_viewController" type="HMS_CMIF_ViewController"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="d587c587-f88f-4eff-977b-c42c62e15c98">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars

begin
	self.setMyHarbour(self.myTerminal.myHarbour);
	if self.myForm &lt;&gt; null then
		self.myForm.handleNotificationRefreshView(eventType, theObject, eventTag, theObject);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="961912aa-c604-4e95-8b0d-66a9d92bb083">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
	self.setMyHarbour(self.myTerminal.myHarbour);

	if self.myForm &lt;&gt; null then
		self.myForm.handleNotificationRefreshView(eventType, theObject, eventTag, userInfo);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
