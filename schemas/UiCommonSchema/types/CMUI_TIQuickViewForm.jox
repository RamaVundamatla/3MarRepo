<GUIClass name="CMUI_TIQuickViewForm" id="a634fffd-fc8f-42e3-ac2a-5885a5d047c1">
    <superclass name="CMUI_QuickViewForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbTiType" id="989c1180-6886-4efb-8f2d-333ddea82c89">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblTiType" id="f8d59753-9327-4504-8ad8-8971e04ba048">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="translateForm" id="6d1fbfed-bc91-4d2d-8681-b85c04fbd75c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008202, locale);
	lblTiType.translateCaption(Xlat_0001056, locale);
end;</source>
    </JadeMethod>
</GUIClass>
