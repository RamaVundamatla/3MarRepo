    <JadeMethod name="addNewRateEntry" id="a162bf74-09f9-4fff-b762-305c19e0c1c5">
        <source>addNewRateEntry();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	tbl					: CM_EntryTable;
	idx					: Integer;
	str 				: String;
	rateEntry			 : CM_InvoiceContractRateEntry;
	fromStartDT, fromEndDT : TimeStamp;
	fromValue, toValue, newValue : Decimal[23,4];
	numDecimalPlaces, maxLength : Integer;
	increment : Decimal[3,2];
begin
	
	tbl := self.tblData;
	
	if tbl.rows &gt; 1 then
		fromValue := tbl.accessCell(tbl.rows, FROM_AMOUNT).text.Decimal;
		toValue := tbl.accessCell(tbl.rows, TO_AMOUNT).text.Decimal;
		
		if fromValue &gt; toValue
		or toValue = 0 
		or toValue = MAX_VALUE then
			return;
		endif;
	endif;
	
	fromStartDT.setDate(self.mskStartDate.text.asDateJMT());
	fromEndDT.setDate(self.mskEndDate.text.asDateJMT());
	fromStartDT.setTime(self.mskStartTime.text.asTimeJMT());
	fromEndDT.setTime(self.mskEndTime.text.asTimeJMT());

	self.getNumberFormat(maxLength,numDecimalPlaces, increment);
	
	// ### JIRA 34344 27MAR 2025 NAVAB1 start at zero
	if tbl.rows = 1 then
		newValue := 0;
	else
		newValue := toValue + increment;
	endif;
		
	// ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
	// ### JIRA 34344 27MAR 2025 NAVAB1 start at zero
	if newValue &lt; 0 then
		newValue := 0;
	endif;
	
	idx := tbl.addItem(newValue.asStringJMTWithPrecision(numDecimalPlaces, false)&amp; Tab &amp; "" &amp; Tab &amp; "");
	tbl.accessCell(idx,FROM_AMOUNT).inputType := Table.InputType_TextNumeric;
	tbl.accessCell(idx,FROM_AMOUNT).maxLength  := maxLength;
	tbl.accessCell(idx,FROM_AMOUNT).decimals := numDecimalPlaces;
	tbl.accessCell(idx,TO_AMOUNT).inputType := Table.InputType_TextNumeric;
	tbl.accessCell(idx,TO_AMOUNT).maxLength  := maxLength;
	tbl.accessCell(idx,TO_AMOUNT).decimals := numDecimalPlaces;
	tbl.accessCell(idx,RATE).inputType := Table.InputType_TextNumeric;
	tbl.accessCell(idx,RATE).maxLength  := 14;
	tbl.accessCell(idx,RATE).decimals := 4;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="btnAudit_click" id="53b26ee1-0eab-47b8-acaf-1f52b902c314">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAudit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navrv30	Bug 58391: EUP - Audits for Invoice Copy

*/

vars
	rate : CM_InvoiceContractRateEntry;
begin
	rate := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractRateEntry;
	if rate = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	app.viewAuditFormModal(rate, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
