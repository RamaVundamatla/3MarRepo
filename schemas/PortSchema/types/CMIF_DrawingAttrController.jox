    <JadeMethod name="handleCargoType" id="45792a42-4994-407f-a950-65933458ae32">
        <source>handleCargoType(cargoType : CM_CargoType; _code : String output; _viewModeCode : String; _color :Integer output; _object : Object output) protected;
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
	viewObjectColour : CM_ViewObjectColour;
	
begin

	trimCode := cargoType.description.trimBlanks;

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	theCode		:= null;
	theColor	:= NullColour;

	iter := self.myIterCargoTypes;
	self.allCargoTypes.startKeyGeq(trimCode, 0, iter);
	self.allCargoTypes.getIteratorKeys(codeKey, colorKey, iter);

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		create viewObjectColour transient;
		viewObjectColour.code := trimCode;
		viewObjectColour.colour := cargoType.getDrawColour;
		viewObjectColour.myObject := cargoType;
		self.allCargoTypes.add(viewObjectColour);
		theCode	:= viewObjectColour.code;
		theColor := viewObjectColour.colour;
		theObject := viewObjectColour.myObject;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;
end;</source>
        <access>protected</access>
        <Parameter name="cargoType" type="CM_CargoType"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleCarrierIn" id="60dd8af2-4729-4943-9df2-074af9470d29">
        <source>handleCarrierIn(_carrierCode: String; _code: String output; _color: Integer output; _object: Object output) protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2017	cnwmp6	Initial creation	TFS4209

*/
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpCarrier	: CM_Carrier;
	theObject : Object;
begin
	trimCode := _carrierCode.trimBlanks;
	
	if trimCode = null then
		_code	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.allCarriersIn.createIterator;
	self.allCarriersIn.startKeyGeq(trimCode, 0, iter);
	self.allCarriersIn.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _carrierCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		tmpCarrier := self.myRoot.allCarriers[trimCode];
		if tmpCarrier &lt;&gt; null then
		
			self.allCarriersIn.addNoDuplicates(tmpCarrier, false);
			self.beginNotification(tmpCarrier, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpCarrier.colour;
			theObject	:= tmpCarrier;
		else
			theCode		:= null;
			theColor	:= NullColour;
			theObject	:= null;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleCarrierOut" id="56a54090-db2d-42f4-9652-ff1cc7f9d5b2">
