<GUIClass name="CMUI_SelectWorkListEntry" id="4f92eede-46a3-4820-8749-509efdd157da">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allProspectWles" id="11160cc3-2f2c-4b92-8d02-47cec29e0823">
        <memberTypeInverse/>
        <type name="CM_WLESet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblSelect" id="a95421d1-9961-46e1-a500-7f295a6ba8e8">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myUserSelectedWle" id="2138dbd2-052a-4d27-80af-2d426a2d7b38">
        <embedded/>
        <type name="CM_WorkListEntry"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblWles" id="202edbf7-8cc9-4ace-9281-d93a4fe688b9">
        <embedded/>
        <type name="CM_DataTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="doResize" id="2412ae8d-1619-4d53-9092-bffac41419b2">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.lblSelect.left := 1;
	self.lblSelect.top := 1;
	self.lblSelect.width := self.clientWidth - 2;
	self.lblSelect.height := 35;
	
	self.tblWles.left := 1;
	self.tblWles.top := self.lblSelect.height + self.lblSelect.top;
	self.tblWles.width := self.clientWidth - 2;
	self.tblWles.height := self.btnOk.top  - ( self.tblWles.top + 10 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateWles" id="c012c9c3-779d-44af-a7f3-4ffc9d74a710">
        <source>populateWles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation

*/

vars

	def : EntTableDef;
	wle : CM_WorkListEntry;
	str : String;

begin

	def := app.myController.getEntTableDef( ETDef_MoveItWleSelect );
	
	self.tblWles.userInputEnabled := false;
	self.tblWles.selectMode := CM_EntryTable.SelectMode_FixedRow;
	self.tblWles.selectionType := CM_EntryTable.SelectionType_Row;
	self.tblWles.rows := self.tblWles.fixedRows;
	self.tblWles.cnEcResizeContents();
	
	if def &lt;&gt; null then
		self.tblWles.setTblDataEntRowsFromDef(def);
	endif;
	
	foreach wle in self.allProspectWles do
		str := wle.getAttributeStringForDefArray(self.tblWles.allTblDataEntRows);
		self.tblWles.addItemObject( wle, str );
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProspectWles" id="c06a5691-54d1-4591-8d6c-303157e15565">
        <updating/>
        <source>setProspectWles( _allProspectWles : CM_WLESet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

begin

	if _allProspectWles &lt;&gt; null and not _allProspectWles.isEmpty then
		_allProspectWles.copy( self.allProspectWles );
	endif;

epilog

end;</source>
        <Parameter name="_allProspectWles" type="CM_WLESet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a3f20d09-e12e-4612-8050-92a707634512">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

begin

	self.minimumWidth := 500;
	self.minimumHeight := 185;
	
	//default values
	self.width := 585;
	self.height := 250;
	
	self.lblSelect.caption := app.getErrorString2( Select_move, self.btnOk.caption, self.btnCancel.caption);

	inheritMethod();
	
	self.myUserSelectedWle := null;
	
	if self.allProspectWles.isEmpty then
		self.unloadForm();
		return;
	endif;
	
	self.populateWles();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblWles_mouseUp" id="58e599b6-bb9f-4887-8650-f33ce3a13ce3">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWles_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	row : Integer;
	wle : CM_WorkListEntry;

begin

	row := self.tblWles.row;
	if row &lt;= self.tblWles.rows and row &gt; self.tblWles.fixedRows then
		wle := self.tblWles.accessRow( row ).itemObject.CM_WorkListEntry;
		if wle &lt;&gt; null then
			self.myUserSelectedWle := wle;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="629fb1e5-d9e4-46bf-a314-60edc6dc017a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019225, locale);
	lblSelect.translateCaption(Xlat_0019226, locale);
end;</source>
    </JadeMethod>
</GUIClass>
