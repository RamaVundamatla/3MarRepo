    <JadeMethod name="setProxyJobNum" id="20a6637a-16a5-4802-ac6f-7d1f04b06d6b">
        <updating/>
        <source>setProxyJobNum(_jobNum : String; _isBulkEdit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	suffix, 
	proxSuffix : String;
begin
	self.raiseExceptionIfNotTransient(method);
	
	suffix := self.getJobNumSuffix(self.jobNum);//ccms1080
	proxSuffix := self.getJobNumSuffix(_jobNum);
	
	if proxSuffix = null and _isBulkEdit then
		self.jobNum := _jobNum &amp; suffix;
	else
		self.jobNum := _jobNum;
	endif;

end;</source>
        <Parameter name="_jobNum" type="String"/>
        <Parameter name="_isBulkEdit" type="Boolean"/>
    </JadeMethod>
