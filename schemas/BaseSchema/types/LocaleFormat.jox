        <source>cnEcCopyInfo(pLocaleFormatObj:LocaleFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified LocaleFormat to
