    <JadeMethod name="showMovementsTable" id="ac0aee96-4261-454a-889d-3829b5e40026">
        <source>showMovementsTable(_workingMovement : CMIF_HMS_WorkingMovement) protected;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
	movementsView:	HMS_MovementsTableForm;
	workingMovement : CMIF_HMS_WorkingMovement;
begin
	if self.myMovementsTableForm &lt;&gt; null then
		self.myMovementsTableForm.setFocus();
		self.myMovementsTableForm.buildEntireForeground();
		return;
	endif;
  	movementsView := app.loadForm(HMS_MovementsTableForm, HMS_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).HMS_MovementsTableForm;
	if movementsView = null then
		return;
	endif;
	movementsView.myGraphicalViewForm := self;
	movementsView.setMyViewController(self.myViewController);

	//If a voyage has been selected based on the working movement
	//we want the movements table to show the movements of that voyage
	movementsView.setSelectedMovement(_workingMovement);
	movementsView.optSelectedVoyage.value := _workingMovement &lt;&gt; null;
	movementsView.optAllVoyages.value := (not movementsView.optSelectedVoyage.value);	
	
	movementsView.setMyTerminal(self.myTerminal);
  	movementsView.show;
end;</source>
        <access>protected</access>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
