    <JadeMethod name="getRoadReleaseJob" id="697decd3-98aa-4d2d-b7df-43ab530ada75">
        <source>getRoadReleaseJob(_vehicle: CM_Vehicle): CM_RoadJob;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2013	cnwndl1	Initial creation	Par 32380

*/

vars

	wle : CM_WorkListEntry;
	roadJob : CM_RoadJob;

begin

	if _vehicle = null or ( not self.canMergeBreakBulk ) then
		return inheritMethod(_vehicle);
		
	else
		// could have multiples...
		// I.e. several truck at once all piking up a some of this break bulk
		// The ref will only be the latest.
		
		if self.jobRoadRelease &lt;&gt; null and self.jobRoadRelease.myVehicle = _vehicle then
			return self.jobRoadRelease;
			
		else
			foreach wle in self.allWorklistEntries do
				if wle.isReceipt then
					continue;
				endif;
				if wle.job = null or not wle.job.isRoadJob then
					continue;
				else
					roadJob := wle.job.CM_RoadJob;
				endif;
				if _vehicle = roadJob.myVehicle then
					return roadJob;
				endif;
			endforeach;
			
			return null;
			
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="getRollingLength" id="c7299c18-caaf-4d9f-9af3-f291f4423457">
        <source>getRollingLength() : Decimal; // ### TFS 54021 29June2022 NAVPW1 - Return type changed to Decimal from String
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	value : Decimal[23,2];	// ### TFS 54021 29June2022 NAVPW1

begin
	return self.rollingLength; // ### TFS 54021 22July2022 NAVPW1 - Using a virtual property
	//global.getExtraData(self.allExtraData, ExtraRollingLength, value); // ### TFS 54021 29June2022 NAVPW1
	//return value; 											 // ### TFS 54021 29June2022 NAVPW1
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getShortDescriptions" id="c7cbd9a2-ceba-47ba-8958-cc3f74884ede">
        <source>getShortDescriptions( desc1 : String output; desc2 : String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2013	cnwndl1	Initial creation	Par 32156

*/

vars

	retStr1, retStr2 : String;
	ls, ws, hs, col : String;
	pieces : Integer;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	descChar : String;
	measureType : CM_MeasurementType;
	hazDets : String;

begin

	retStr1 := self.cargoTypeDescr;
	if self.myProduct &lt;&gt; null then
		if retStr1 &lt;&gt; null then
			retStr1 := retStr1 &amp; "/";
		endif;
		retStr1 := retStr1 &amp; self.myProduct.code;
	endif;
	
	prod := self.myProduct;
	if prod = null and self.myCargoType &lt;&gt; null then
		prod := self.myCargoType.mySystemProductType;
	endif;

	if prod &lt;&gt; null then
		if self.length &gt; 0 then
			descChar := "L";
			prodAttr := prod.getProdAttrFromName(ETRow_MyLength);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Length);
			endif;
			ls := app.convertMeasurementForDisplay( measureType.shortName, self.length ) &amp; descChar;
		endif;
		
		if self.width &gt; 0 then
			descChar := "W";
			prodAttr := prod.getProdAttrFromName(ETRow_MyWidth);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Width);
			endif;
			ws := app.convertMeasurementForDisplay( measureType.shortName, self.width )  &amp; descChar;
		endif;
		
		if self.height &gt; 0 then
			descChar := "H";
			prodAttr := prod.getProdAttrFromName(ETRow_MyHeight);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Height);
			endif;
			hs := app.convertMeasurementForDisplay( measureType.shortName, self.height )  &amp; descChar;
		endif;
		
	endif;
	
	if ls &lt;&gt; null or ws &lt;&gt; null or hs &lt;&gt; null then
		if ls &lt;&gt; null then
			retStr2 := ls;
		endif;
		if ws &lt;&gt; null then
			if retStr2 &lt;&gt; null then
				retStr2 := retStr2 &amp; "x";
			endif;
			retStr2 := retStr2 &amp; ws;
		endif;
		if hs &lt;&gt; null then
			if retStr2 &lt;&gt; null then
				retStr2 := retStr2 &amp; "x";
			endif;
			retStr2 := retStr2 &amp; hs;
		endif;
	endif;
	
	if retStr2 &lt;&gt; null then
		retStr2 := retStr2 &amp; " ";
	endif;
	
//	if self.myCargoType &lt;&gt; null and self.myCargoType.allAttributesOnProduct.includes(ETRow_MyQuantity) then
	if prod &lt;&gt; null and prod.getProdAttrFromName(ETRow_MyQuantity) &lt;&gt; null then
		pieces := self.quantity;
	endif;
	
	if pieces &gt; 0 then
		retStr2 := retStr2 &amp; "(" &amp; pieces.String &amp; ") ";
	endif;
	
	col := self.getColour();
	if col &lt;&gt; null then
		retStr2 := retStr2 &amp; col &amp; " ";
	endif;

	if mark.trimBlanks &lt;&gt; null then
		retStr2 := retStr2 &amp; mark &amp; " ";
	endif;

	if retStr1 = null or retStr2 = null then
		inheritMethod( desc1, desc2 );
	else	//19 Jun 2017	NDL	TFS 4587
		if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig( HhIncludeHazDet ).Boolean then
			hazDets := self.getDisplayStringForAttribute( ETRow_AllTIHazards, false );
		endif;
		if hazDets &lt;&gt; null then
			retStr2 := hazDets &amp; ", " &amp; retStr2;
		endif;
	endif;
	
	if retStr2 &lt;&gt; null then
		desc2 := retStr2;
	endif;
	
	if retStr1 &lt;&gt; null then
		if self.canMergeBreakBulk then	//11 Sep 2013	NDL	Par 32380
			retStr1 := retStr1 &amp; "(" &amp; self.totalQuantity.String &amp; ")";
		endif;
		desc1 := retStr1;
	endif;

epilog

end;</source>
        <Parameter name="desc1" type="String" usage="output"/>
        <Parameter name="desc2" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantityReceived" id="a0bb8692-6136-46ab-87b1-e38a5d0adc50">
        <source>getTotalQuantityReceived( _trxType : Integer ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2013	cnwndl1	Initial creation	Par 32479 - Zombies don't have a total Quantity

*/

vars

	recQuantity : Integer;
	txn:  CM_TITransaction;

begin

	foreach txn in self.allTransactions where txn.type = _trxType do
		recQuantity :=  recQuantity + txn.totalQuantity;
	endforeach;
	
	return recQuantity;

epilog

end;</source>
        <Parameter name="_trxType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
