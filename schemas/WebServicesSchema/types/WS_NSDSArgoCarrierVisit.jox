    <JadeMethod name="setProxyObjectPrefix" id="14e0ef51-ba1e-4663-b715-8edb476f8040">
        <updating/>
        <source>setProxyObjectPrefix(_any: Any; _prefix : String) updating;
/*

Purpose:			
	Mapping 
	MTN : CM_Voyage
	N4  : argo_carrier_visit
Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	helper      	   : CMIF_ArgoCarrierVisit;
//	detail : CMIF_ArgoVisitDetails;
	wsVslVisitDetails  : WS_NSDSArgoVisitDetails;
	wstrainVisitDetails  : WS_NSDSRailTrainVisitDetails;
	ewsOpsView: CM_EWSActivityOpsview;
	seq : Integer;
begin
		
	inheritMethod(_any, _prefix);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	// ### NOTE this initializeForActivity builds a 4 deep structure for data tables, the sub data is used in the setFromOpsViewTable() method below to populate the same structue in the API
	helper.initializeForActivityPrefix(_any, ewsOpsView,_prefix);

	self.tableName 			:= helper.tableName;	
	self.gkey 				:= helper.gkey;
	
	self.ata 				:= helper.ata;
	self.atd 				:= helper.atd;
	self.carrier_mode 		:= helper.carrier_mode;
	self.cpx_gkey			:= helper.generateCpxGKey();
	self.cvcvd_gkey	 		:= helper.cvcvd_gkey;  // ### TFS 51855 01FEB2022 NAVAB1 - typo, did say 'cpx_gkey'
	self.fcy_gkey 			:= helper.fcy_gkey;
	self.id 				:= helper.id;
	self.operator_gkey	 	:= helper.operator_gkey;
	self.phase	 			:= helper.phase;	
	

	create wsVslVisitDetails transient;
	wsVslVisitDetails.setFromOpsViewTable(helper.argoVisitDetails, seq);
	self.argoVisitDetails := wsVslVisitDetails;

	// ### TFS 51855 07JAN2022 NAVAB1
	if helper.railTrainVisitDetails &lt;&gt; null then // only used for trains, not voyages etc.
		create wstrainVisitDetails transient;
		wstrainVisitDetails.setFromOpsViewTable(helper.railTrainVisitDetails, seq);
		self.railTrainVisitDetails := wstrainVisitDetails;
	endif;
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
</Class>
