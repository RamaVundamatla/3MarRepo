    <JadeMethod name="makeRFFSegment" id="78f06f6f-45eb-4152-af5f-3bdd16b00049">
        <source>makeRFFSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _type, _ref :String):String protected;
/*
Purpose:	Make a RFF segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "RFF";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _type;
	
	if _ref &lt;&gt; null then
		msg := msg &amp; colon &amp; _ref;
	endif;
	
	msg := msg &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
