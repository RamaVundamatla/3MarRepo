    <JadeMethod name="setYardAllocationCriteriaAuto" id="b3afa5a8-bc94-42f9-be8a-33d5b18abbca">
        <source>setYardAllocationCriteriaAuto(_allCriteria: CMIF_Array input; _tmpObjectSet : ObjectSet input);
// -------------------------------------------
// Created 19 September 2005 by cnwdvb1
// -------------------------------------------
vars

	isoGroup				: CM_ISOTypeGroup;
	isoType					: CM_ISOType;
	availabilityGrade		: CM_MTGrade;
	root					: CM_Root;
	criteriaPriorityObj		: CM_YACriteriaPriority;
	criteriaTypeObj			: CM_YACriteriaType;
	itemCode				: String;
	transientObj			: CMIF_YACriteriaPriority;

begin

	inheritMethod(_allCriteria, _tmpObjectSet);
	root := app.myRoot;
	
	_tmpObjectSet.clear();
	isoGroup := root.allISOTypeGroups[self.isoGroup];
	if isoGroup &lt;&gt; null then
		criteriaTypeObj := CM_YATypeISOGroup.firstInstance;
		_tmpObjectSet.add(isoGroup);
	else
		isoType := root.allISOTypes[self.isoType];
		if isoType &lt;&gt; null then
			criteriaTypeObj := CM_YATypeISO.firstInstance;
			 _tmpObjectSet.add(isoType);
		endif;
	endif;
	
	if criteriaTypeObj &lt;&gt; null then
		create criteriaPriorityObj as CM_YACriteria transient;
		itemCode := criteriaTypeObj.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		criteriaPriorityObj.setProxy(criteriaTypeObj, _tmpObjectSet, itemCode);
		transientObj	:=	criteriaPriorityObj.getTransient();
		transientObj.setFlag(true, false, false);
		_allCriteria.add(transientObj);
	endif;
		
	availabilityGrade := root.allAvailabilityGrades[self.availabilityGrade];
	if availabilityGrade &lt;&gt; null then
		_tmpObjectSet.clear();
		criteriaTypeObj := CM_YATypeAvGrade.firstInstance;
		_tmpObjectSet.add(availabilityGrade);
		create criteriaPriorityObj as CM_YACriteria transient;
		itemCode := criteriaTypeObj.description.cnEcUpto(CM_YACriteriaPriority::code.length-1);
		criteriaPriorityObj.setProxy(criteriaTypeObj, _tmpObjectSet, itemCode);
		transientObj	:=	criteriaPriorityObj.getTransient();
		transientObj.setFlag(true, false, false);
		_allCriteria.add(transientObj);
	endif;

	// Don't have this attribute.	
	if self.washDT.isValid() then
		criteriaTypeObj := CM_YATypeClean.firstInstance;
		itemCode := criteriaTypeObj.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		create criteriaPriorityObj as CM_YACriteria transient;
		criteriaPriorityObj.setProxy(criteriaTypeObj, true, itemCode);
		transientObj	:=	criteriaPriorityObj.getTransient();
		transientObj.setFlag(true, false, false);
		_allCriteria.add(transientObj);
	endif;
	
	if self.isRehandle then
		criteriaTypeObj := CM_YATypeRehandles.firstInstance;
		itemCode := criteriaTypeObj.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		create criteriaPriorityObj as CM_YACriteria transient;
		criteriaPriorityObj.setProxy(criteriaTypeObj, true, itemCode);
		transientObj	:=	criteriaPriorityObj.getTransient();
		transientObj.setFlag(true, false, false);
		_allCriteria.add(transientObj);
	endif;
	
end;</source>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_tmpObjectSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sizeGroup" id="4277eed5-6432-43fc-859c-301f97b735c5">
        <source>sizeGroup(): String;
//----------------------------------------------------------------
//	Created:	21 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.is40 then
		return "40'";
	else
		return "20'";
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
