    <JadeMethod name="oidStringToClassAndInstanceId" id="18356a77-1274-41e0-ac61-2f4a0169fdb2">
        <source>oidStringToClassAndInstanceId(_classId, _instanceId: Integer output);
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		Translates the oid string into class and instance id.
// ---------------------------------------------------------------------------
vars
	oidStr : String;
	dotPos : Integer;
	len : Integer;
	classIdStr, instanceIdStr : String;
	classId, instanceId: Integer;

begin
	len := self.length;
	if len &lt; 3 then
		// Not long enough to be a valid OidString
		return;
	endif;
	
	dotPos := self.pos(".", 1);
	if dotPos &lt;= 1 or dotPos = len then
		// Must have a . character
		return;
	endif;
	
	classIdStr := self[1:dotPos-1];
	if not classIdStr.isInteger then
		// Must be an integer
		return;
	endif;
	classId := classIdStr.Integer;
	
	instanceIdStr := self[dotPos+1:end];
	if not instanceIdStr.isInteger then
		// Must be an integer
		return;
	endif;
	instanceId := instanceIdStr.Integer;
	
	// Set both output parameters
	_classId := classId;
	_instanceId := instanceId;
end;</source>
        <Parameter name="_classId" type="Integer" usage="output"/>
        <Parameter name="_instanceId" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="oidStringToDataDumpBin" id="fa56d071-2a5c-4f2d-9ceb-e73629157a63">
        <source>oidStringToDataDumpBin() : Binary;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
//
// Purpose:		Translates the oid string into a binary[6] format suitable for
//				querying / updating an external data base directly.
// ---------------------------------------------------------------------------
vars
	classId, instanceId : Integer;
	bin : Binary[6];

begin
	self.oidStringToClassAndInstanceId(classId, instanceId);
	if classId = null then
		return null;
	endif;
		
	bin := classId.asBinary(2) &amp; instanceId.asBinary(4);
			
	return bin;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="oidStringToDataDumpHex" id="4923c5df-8fb8-409d-8693-8572a2c10168">
        <source>oidStringToDataDumpHex() : String;
// ---------------------------------------------------------------------------
// Created:     08 June 2003 by cnwsb1
//
// Purpose:		Translates the oid string into a format suitable for dumping to
//				a text file, and loading into another (probably non-JADE) database.
// ---------------------------------------------------------------------------
vars
	classId, instanceId : Integer;
	hexFormatStr : String;

begin
	self.oidStringToClassAndInstanceId(classId, instanceId);
	if classId = null then
		return null;
	endif;
	
	hexFormatStr := "0x" &amp; classId.asHex(4) &amp; instanceId.asHex(8);
	if hexFormatStr.length &gt; 14 then
		// cnwsb1: This should never happen.  If it does, we have a major
		// data conversion effort due with current external databases.
		app.raiseUnexpectedProgramError(String.name, method.name,
				"Data Dump Hex format string more than 14 characters: " &amp; hexFormatStr);
		return null;
	endif;
	
	return hexFormatStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padDecimalsWithZeros" id="ab7cebc4-320d-4a09-83ac-03f6b4c622db">
        <source>padDecimalsWithZeros(_nbrZeros : Integer) : String;
//
// Purpose:			Pad a string with trailing zeros to a certain specification e.g. 23 to 23.0000, 23.12. to 23.1200, etc
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/03/2020	jlgdap1		Initial creation TFS 48959 GPHA MS Dynamics Interface Enhancement
//
vars
	decPos : Integer;
	str : String;

begin
	str := self;
	decPos := str.pos(".", 1);
	if decPos = null then
		str := str &amp; ".";
		decPos := str.pos(".", 1);
	endif;
	
	while true do
		if str.length &gt;= decPos + _nbrZeros then
			break;
		endif;
		str := str &amp; "0";
	endwhile;
	
	return str;
epilog

end;</source>
        <Parameter name="_nbrZeros" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padLeftBlanks" id="caba446f-3a12-4cae-9f70-3c17de66043a">
        <source>padLeftBlanks(num : Integer) : String;

vars
	str : String;

begin

	if num &gt;= length then
		str := str.padBlanks(num-length);
		str := str &amp; self;
	else
		str := self[1:num];
	endif;

	return str;


end;</source>
        <Parameter name="num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padTrimTo" id="41df9549-7080-4251-945b-ebfe530f8059">
        <source>padTrimTo(_len: Integer): String;
//	returns a string of the specified length
//	- removes invalid chars
//	- pads with blanks if short
//	- truncates if long
vars
	tmpStr		: String;
begin

	tmpStr := self.removeEDIInvalidChars();

	if tmpStr.length &lt;= _len then
		return tmpStr.padBlanks(_len);
	else
		return tmpStr[1:_len];
	endif;

end;</source>
        <Parameter name="_len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padWithSpaces" id="c37f947c-47d0-4c08-9045-4b9bcd9af2be">
        <source>padWithSpaces() :String;
/*

Purpose:		Takes the inital string and adds a space between each character	

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars	
	returnString : String;
	i : Integer;
begin

	i:=1;
	while i &lt;= self.length  do	
		returnString:=returnString &amp; self[i];
		returnString:=returnString &amp; " ";
		i:=i+1;
	endwhile;

	return returnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padZeros" id="393404e0-13bf-4138-aa15-91c67bfdc484">
        <source>padZeros(num : Integer) : String;

vars
    str : String;
    i : Integer;
begin

    if num &gt; length then
        i := 0;
        while i &lt; num-length do
            str := str &amp; "0";
            i := i + 1;
        endwhile;
        str := str &amp; self;
    else
        str := self[1:num];
    endif;

    return str;

end;</source>
        <Parameter name="num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="parseCSV" id="4a7dae58-5a94-4dce-b4ee-9673024e2186">
        <source>parseCSV(strArray : HugeStringArray input);
// -----------------------------------------------------------------------------
// Created:		28 May 2002 by cnwka1
//
// Purpose:		
// -----------------------------------------------------------------------------
constants
	DoubleQuote = '"';
	Comma = ',';
vars
	workString, 
	field		: String;
	pos 		: Integer;
	cnt	: Integer;
begin
	strArray.clear;
	workString := self;
	
	while workString.length &gt; 0 do
		pos := 1;
		if workString[1:1] = DoubleQuote then
			if workString.length &lt;= 1 then
				// no matching quote
				break;
			endif;
				
			workString := workString[2:end];
			field := workString.scanUntil(DoubleQuote, pos);
		
			if pos = 0 then
				// no matching double quote found
				pos := 1;
				field := workString.scanUntil(Comma, pos);
			else
				// has matching double quote
				// need to replace any double doubleQuotes with a single doubleQuote
				while true do
	
					if workString.length &gt; pos then
						if workString[pos+1:1] = Comma then
							pos := pos+1;
							break;
	
						elseif workString[pos+1:1] = DoubleQuote then
							pos := pos + 2;
							if pos &lt;= workString.length then
								field := field &amp; DoubleQuote &amp; workString.scanUntil(DoubleQuote, pos);
							else
								field := field &amp; DoubleQuote;
								break;
							endif;
						endif;
					elseif workString.length = pos then
						workString := workString[1:pos-1];
						break;
					else
						break;
					endif;
	
				endwhile;
			endif;
			
		else
			field := workString.scanUntil(Comma, pos);
		endif;
		
		strArray.add(field);
		
		if workString = field then
			break;
		endif;
		
		if workString.length &gt; pos then
			workString := workString[pos+1:end];
		
		elseif workString.length = pos and
		       workString[pos:1] = Comma then
			// last char is a comma so add a null for the last field
			strArray.add(null);
			break;
		
		elseif workString.length &lt;= pos then
			break;
		endif;
		
	endwhile;
	
end;</source>
        <Parameter name="strArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="properCase" id="655f03ae-4d89-40a5-a0da-d28705af46a0">
        <source>properCase() : String;
