    <JadeMethod name="calculateGraphSize" id="7fb1eb90-dba4-491d-a45d-e1f35c68343e">
        <updating/>
        <source>calculateGraphSize() updating, protected;

vars

begin
	if self.isShowLineLegend then
		self.graphHeight	:=	(self.height - self.graphLabelHeight - self.graphLabelHeight - self.graphLabelHeight - 0).Integer;
		self.graphWidth		:=	(self.width - self.maxScaleLabelWidth - 6).Integer;
	else
		self.graphHeight	:=	(self.height - self.graphLabelHeight - self.graphLabelHeight - 0).Integer;
		self.graphWidth		:=	(self.width - self.maxScaleLabelWidth - 6).Integer;
	endif;
	
	if self.borderStyle &lt;&gt; 0 then
		self.graphHeight	:=	self.graphHeight - 2;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkData" id="7d08851f-c652-4314-bff5-5be064716a7f">
        <updating/>
        <source>checkData():String updating, protected;

vars
	returnValue		: String;
	numberOfLines 	: Integer;
	colorArrayObj	: IntegerArray;
	position		: Integer;
	lineColor		: Integer;
	
begin
	numberOfLines := self.allLinesArray.size();
	
	if numberOfLines = 0 then
		if self.isShowTestData then
			self.clearGraph();
			self.setDefaultsInPainter();
			numberOfLines	:=	self.allLinesArray.size();
		else
			returnValue	:=	"No Data";
			return returnValue;
		endif;
	endif;
	
	if (numberOfLines * self.graphLabelHeight) &gt; self.graphWidth then
		returnValue	:=	"Too Much Data";
		return returnValue;			
	endif;
	
	if self.isShowLineLegend then
		if numberOfLines &gt; self.allGraphColors.size() then
			returnValue	:=	"Not enough colors set";
			return returnValue;
		endif;
	
		create colorArrayObj transient;
	
		foreach position in 1 to numberOfLines do
			lineColor	:=	self.allGraphColors[position]; 
			
			if not colorArrayObj.includes(lineColor) then
				colorArrayObj.add(lineColor);
			else
				returnValue	:=	"Color used more than once";
				return returnValue;
			endif;	 
		endforeach;
	endif;  
	
	return returnValue;
epilog
	delete colorArrayObj;	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="12b7a1d7-6dba-4766-9a42-c53523f0024c">
        <updating/>
        <source>clearGraph() updating;

begin
	inheritMethod();
	self.allXAxisLabels.purge();
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createLegendLabel" id="a18cb42b-1fc0-4ab4-b729-7016409b1b21">
        <updating/>
        <source>createLegendLabel() updating, protected;

vars
	labelObj	: Label;
	
begin
	if self.isShowLineLegend then
		if self.myLegendLabel &lt;&gt; null then
			delete self.myLegendLabel;
		endif; 
			
		create labelObj transient;
		
		labelObj.name		:=	self.LEGEND_LABEL;
		labelObj.parent		:=	self;
		labelObj.left		:=	1;
		labelObj.visible	:=	true;
		labelObj.height		:=	self.graphLabelHeight;
		labelObj.top		:=	self.graphLabelHeight + self.graphHeight + self.graphLabelHeight;
		labelObj.width		:=	self.width - 2;
		labelObj.backColor	:=	self.backColor;
		labelObj.foreColor	:=	Black;
		labelObj.alignment	:=	Label.Alignment_Center_Middle;
		self.form.addControl(labelObj);
		labelObj.caption	:=	"";
		self.myLegendLabel	:=	labelObj;
		
		self.setLegendLabel(0);
	else
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLines" id="8cbf88b4-ce32-450c-bfd5-987c0e50942b">
        <updating/>
        <source>createLines(pPointGap : Integer; pNumberOfPoints : Integer; pLineObj : Object; pLineNumber : Integer) updating, protected;

vars
	startX						: Real; 
	startY						: Real; 
	endX						: Real; 
	endY						: Real; 
	lineColor					: Integer;
	unitValue					: Real;
	position					: Integer;
	lineValuesArrayObj			: RealArray;
	numberOfPointsOnThisLine	: Integer;
	
begin
	position	:=	1;
	
	if pLineNumber &lt;= self.allGraphColors.size() then
		lineColor	:=	self.allGraphColors[pLineNumber];
	else
		lineColor	:=	Black;
	endif;
	
	unitValue		:=	self.graphHeight / self.maxValue;
	self.drawWidth	:=	2;
	
	create lineValuesArrayObj transient;
	pLineObj.RealArray.copy(lineValuesArrayObj);
	numberOfPointsOnThisLine	:=	lineValuesArrayObj.size();
	  
	if pNumberOfPoints &gt; 1 then
	
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfPointsOnThisLine do	

//			// If the line position value is zero, then defer drawing the line.
//			
//			if lineValuesArray[position] = 0 then
//				continue;
//			endif;
			
			//set up x and y
			endX	:=	((position - 1) * pPointGap) + self.maxScaleLabelWidth;
			endY	:=	(self.graphHeight - (lineValuesArrayObj[position] * unitValue)) + self.graphLabelHeight;
		
			if position = 1 then
				startX	:=	endX;
				startY	:=	endY;
			endif;
			
			//draw the line here
			self.drawLine(startX, startY, endX, endY, lineColor);
		
			startX	:=	endX;
			startY	:=	endY;
			
		endforeach;
	endif;
epilog 
	delete lineValuesArrayObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pLineObj" type="Object"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e265b2cc-5901-4c16-b200-9de0cf7296c9">
        <updating/>
        <source>delete() updating;

begin
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddLine" id="0f744744-ddef-4634-b10e-0a01b18c4a56">
        <source>doAddLine() protected;

vars
	newLineArrayObj	: RealArray;
	
begin
	create newLineArrayObj transient;
	self.allLinesArray.add(newLineArrayObj);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddValue" id="f6e5d714-5e8c-43e2-affc-3fcf3db351d6">
        <source>doAddValue(pValue:Real; pLineNumber:Integer):Boolean;

vars
	lineArrayObj	: RealArray;
	numberOfLines	: Integer;
	
begin
	numberOfLines	:=	self.allLinesArray.size();
	
	while numberOfLines &lt; pLineNumber do
		self.doAddLine();
		numberOfLines	:=	numberOfLines + 1;
	endwhile;
	
	lineArrayObj	:=	self.allLinesArray[pLineNumber].RealArray;
	lineArrayObj.add(pValue);
	
	return true;  
end;</source>
        <Parameter name="pValue" type="Real"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeValue" id="cd057129-ba76-43d1-ae91-7b2004055f7c">
        <source>doChangeValue(pValue:Real; pLineNumber:Integer; pPosition:Integer ):Boolean;

vars
	lineArrayObj	: RealArray;
	
begin
	if self.allLinesArray.size() &lt; pLineNumber then
		return false;
	endif;
	
	lineArrayObj	:=	self.allLinesArray[pLineNumber].RealArray;
	
	if lineArrayObj.size() &lt; pPosition then
		return false;
	endif;
		
	lineArrayObj[pPosition]	:=	pValue;
	
	return true;
end;</source>
        <Parameter name="pValue" type="Real"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="050e6afe-25e7-4dde-af11-41f18a83e6e3">
        <updating/>
        <source>drawGraph() updating;

vars
	errorMessage	: String;
	
begin
	inheritMethod();
	
	errorMessage	:=	self.checkData();
	
	self.calculateGraphSize();

	if errorMessage = null then		
		self.autoRedraw	:=	true;
		self.setMaxScaleLength();
		self.createLegendLabel();
		self.setScale();
		self.setupForm();
	else
		self.doDataError(errorMessage);
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="cebde6e2-7d78-415a-90b9-82145e4572d0">
        <updating/>
        <source>mouseUp(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	inheritMethod(self, button, shift, x, y);
	
	if (not self.isInPainter()) then
		if self.isShowLineLegend then
			self.setLegendLabel(self.getPoint(x, y));
		endif;
	endif; 		
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="64858f24-dfc1-4456-898c-74ca37705f86">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	if self.graphTitle = null then
		self.graphTitle	:=	self.name &amp; " - Sample data";
	endif;
	 
	self.doAddValue(10, 1);
	self.doAddValue(20, 1);
	self.doAddValue(50, 1);
	self.doAddValue(30, 1);
	self.doAddValue(40, 1);
	
	self.doAddValue(20, 2);
//	self.doAddValue(10, 2);
//	self.doAddValue(40, 2);
	self.doAddValue(0, 2);
	self.doAddValue(0, 2);
	self.doAddValue(25, 2);
	self.doAddValue(30, 2);
	
	self.doAddValue(30, 3);
	self.doAddValue(40, 3);
	self.doAddValue(15, 3);
	self.doAddValue(20, 3);
	self.doAddValue(15, 3);
	
	self.allGraphColors.add(Red);	
	self.allGraphColors.add(Green);
	self.allGraphColors.add(Blue);
	
	self.allGraphLegends.add("1999");	
	self.allGraphLegends.add("2000");	
	self.allGraphLegends.add("2001");
	
	self.transparent := false;
	
	self.allXAxisLabels.add("January"); 
	self.allXAxisLabels.add("February");
	self.allXAxisLabels.add("March");
	self.allXAxisLabels.add("April");
	self.allXAxisLabels.add("May");
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLegendLabel" id="b5eb14e2-ebd2-41c1-8bef-8a698d2b84e5">
        <source>setLegendLabel(pColor:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2003 by cnwndl1
//
// Purpose:		Sets the legend label of the graph line that was clicked.
//
// Parameters:	pColor - The color of the graph line that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 15/12/2006	cnwdad1		Added check for a null legend label reference.  If so,
//							then return without doing anything.
// --------------------------------------------------------------------------------
vars
	lineIndex		: Integer;
	valueString		: String;
	
begin
	if self.myLegendLabel = null then
		return;
	endif;
	
	lineIndex	:=	self.allGraphColors.indexOf(pColor);
	
	if self.isInPainter() then
		valueString						:=	"Legend Label";
		self.myLegendLabel.foreColor	:=	Black; 
	else
		if lineIndex &lt;&gt; 0 then
			if lineIndex &lt;= self.allGraphLegends.size() then
				valueString	:=	self.allGraphLegends[lineIndex]; 
			else
				valueString	:=	"No legend - "; 		
			endif;
			
			self.myLegendLabel.foreColor	:=	pColor; 
		else
			valueString						:=	"Click on Line for Legends";
			self.myLegendLabel.foreColor	:=	Black; 
		endif;
	endif;	  
	
	self.myLegendLabel.caption	:=	valueString;		
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="29961a34-9749-455b-95ef-8bf5cd5c7e0c">
        <updating/>
        <source>setMaxScaleLength() updating, protected;

vars
	labelObj		: Label;
	lineObj			: Object;
	lineValue		: Real;
	position		: Integer;
	numberOfLines	: Integer;
	
begin
	self.maxScaleLabelWidth	:=	0;
	numberOfLines			:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do 
		lineObj	:=	self.allLinesArray[position];
		
		foreach lineValue in lineObj.RealArray do
			if lineValue &gt; self.maxValue then
				self.maxValue	:=	lineValue.roundedUp();
			endif;
		endforeach;
	endforeach;
	
	
	create labelObj transient;
	
	labelObj.caption		:=	lineValue.String;
	self.maxScaleLabelWidth	:=	labelObj.width.Integer;	
epilog
	delete labelObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setScale" id="b2162106-58d7-49e3-9bd6-a82a2b21e48e">
        <updating/>
        <source>setScale() updating, protected;

vars
	position	: Integer;
	startY		: Integer;
	textValue	: String;	
	
begin
	self.drawTextRotation	:=	0;
	
	foreach position in 1 to 5 do
		if position = 1 then
			textValue	:=	self.maxValue.String;
			startY		:=	self.graphLabelHeight;
		elseif position = 2 then
			textValue	:=	(self.maxValue * 0.75).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.25).Integer - 2;
		elseif position = 3 then
			textValue	:=	(self.maxValue * 0.5).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.50).Integer - 4;
		elseif position = 4 then
			textValue	:=	(self.maxValue * 0.25).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.75).Integer - 6;
		elseif position = 5 then
			textValue	:=	"0";
			
			if self.isShowLineLegend then
				startY	:=	(self.graphLabelHeight + self.graphHeight - 8).Integer;
			else
				startY	:=	(self.graphLabelHeight + self.graphHeight - 10).Integer;
			endif;
		endif;
		
		if self.maxValue &gt; 10 then
			textValue	:=	textValue.Integer.String;
		endif;
		
		self.drawTextAt(textValue, 1, startY, Black);	
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setXLabels" id="e6086e95-effc-4ecf-ad9d-5641b5cd3462">
        <updating/>
        <source>setXLabels(pPointGap : Integer; pNumberOfPoints : Integer; pLineNumber : Integer) updating, protected;

vars
	startX				: Real; 
	startY				: Real; 
	lineText			: String; 
	textColor			: Integer;
	position			: Integer;
	numberOfXAxisLabels	: Integer;
	
begin
	position			:=	1;
	textColor			:=	Black;
	numberOfXAxisLabels	:=	self.allXAxisLabels.size();
	
	if pNumberOfPoints &gt; 1 then
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfXAxisLabels do
			lineText	:=	self.allXAxisLabels[position];
			
			while self.getTextExtent(lineText) &gt; pPointGap and lineText.length &gt; 1 do
				lineText	:=	lineText[1:(lineText.length - 1).Integer];
			endwhile;
			
			if lineText.length = 1 then
				if self.getTextExtent(lineText) &gt; pPointGap then
					lineText	:=	"";
				endif;
			endif;
			
			startX	:=	((position - 1) * pPointGap) + self.maxScaleLabelWidth - 7;				
			startY	:=	self.graphLabelHeight + self.graphHeight; 
			
			//draw the text here
			self.drawTextRotation	:=	0;
			self.drawTextAt(lineText, startX, startY, textColor);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7a964969-a0ca-4946-8798-ecbbe58b0b1e">
        <updating/>
        <source>setupForm() updating, protected;

vars
	numberOfLines		: Integer;
	pointCount			: Integer;
	maxNumberOfPoints	: Integer;
	pointGap			: Integer;
	lineObj				: Object;
	position			: Integer;
	
begin
	numberOfLines	:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do
		pointCount	:=	self.allLinesArray[position].RealArray.size();
		
		if pointCount &gt; maxNumberOfPoints then
			maxNumberOfPoints	:=	pointCount;
		endif;
	endforeach;

	pointGap	:=	(self.graphWidth / (maxNumberOfPoints - .5 )).Integer;
	
	foreach position in 1 to numberOfLines do
		lineObj	:=	self.allLinesArray[position];
		self.createLines(pointGap, maxNumberOfPoints, lineObj, position);
	endforeach;
	
	self.setXLabels(pointGap, maxNumberOfPoints, position);	
end;</source>
        <access>protected</access>
    </JadeMethod>
