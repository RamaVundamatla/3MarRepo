    <JadeMethod name="getExtraPermissions" id="87fddfd0-6bc0-46e5-a2f8-b79c550a4da9">
        <source>getExtraPermissions(permArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     03 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(permArray);
	
	permArray.add(PmGteMTReleaseArchive);
	permArray.add(PmGteEmptyReleaseMaintPending);
	permArray.add(PmGteMTReleaseViewGen);
