<CollClass name="CM_TrackedItemDicts" id="bc3579b7-36f3-4b85-a493-65351f7bd906">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="trakitem"/>
    <JadeMethod name="checkProgress" id="02141f62-c323-4a1f-a42f-1096455f5c27">
        <source>checkProgress(_cmifMonitor : CMIF_Monitor input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cnt	: Integer;
	
begin

	if _cmifMonitor = null then
		return true;
	endif;
	
	cnt := _cmifMonitor.numSearched + 1;
	
	if cnt mod 500 = 0 then
		if (not _cmifMonitor.updateProgress(null, 0, 0)) then
			return false;
		endif;
	endif;
	
	_cmifMonitor.numSearched := cnt;

	return true;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
