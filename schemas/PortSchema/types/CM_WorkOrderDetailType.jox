        <source>setForCreate(pWorkOrderDetailType : SelfType)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars

begin
	pWorkOrderDetailType.raiseExceptionIfNotTransient(method);

	self.description 	  := pWorkOrderDetailType.description;
	self.id			 	  := pWorkOrderDetailType.id;
	self.requiresApproval := pWorkOrderDetailType.requiresApproval;
	self.type 			  := pWorkOrderDetailType.type;
	self.myRoot 	 	  := app.myRoot;
	
epilog

end;</source>
        <Parameter name="pWorkOrderDetailType" type="SelfType"/>
    </JadeMethod>
