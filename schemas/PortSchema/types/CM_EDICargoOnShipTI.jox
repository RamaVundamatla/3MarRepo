    <JadeMethod name="processAttributeDependencies" id="cea13eee-a50d-46c4-b14d-58cc4f52dc9d">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
// 20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 23 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
// 22 May 2024 	navhn30	Bug 63125: EUP* | Transport Manifest UDF - Transport Reference customer error when try to Verify Road manifest
vars
	portDestCode	: String;
	root			: CM_Root;
	ediData			: CM_EDIData;
	manifest 		: CM_EDIDataTransManifest;		// TFS 63125
begin
	
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	
	if _reset then 
	else
		ediData := self.myEDIData;											//21.11.2022 navma1 #55424
		
		if not ediData.isKindOf(CM_EDIDataShipManifest) and
		   not ediData.isKindOf(CM_EDIDataDeckPlan) then 
			return;
		endif;
		
		if self.getVoyageCode() = null then
			// make sure the manual collection on CM_EDIConfig gets maintained
			self.setVoyageCode( _ediUserDefinedAssist.currentVoyageCode );
		endif;		
		
		if self.bol = null then		// cnwdad1 08/06/2010 - PAR #24177.
			self.bol := _ediUserDefinedAssist.currentBOLCode;
		endif;
		
		self.myEDIBOLHeader	:=	_ediUserDefinedAssist.myCurrentBOLHeader;									// cnwdad1 01/07/2010 - PAR #24177.
		self.myEDIBOLDtl	:=	_ediUserDefinedAssist.myCurrentBOLDetail;
		root				:=  app.myRoot;																	//21.11.2022 navma1 #55424
		
		if self.imexStatus = null and self.messageMode &lt;&gt; EDI_ACTION_MODIFY then			// leave user entered values as they are.		//cnwmc5 - 22 April 2014 - CCMS 2352
			self.imexStatus	:= root.allImexStatuses[ TI_IMEX_STATUS_REMAINONBOARD ].description;			//21.11.2022 navma1 #55424
		endif;
		
		// PAR 30140 - NOT for RORO DeckPlan. RORO DeckPlans are supposed to mimick BAPLIE. BAPLIE always creates RoB
		if ediData.ediDataType = EDIDataType_DeckPlan then 
			self.imexStatus	:= root.allImexStatuses[ TI_IMEX_STATUS_REMAINONBOARD ].description;			//21.11.2022 navma1 #55424
		
		else
			// If the Discharge Port is set to the Terminals "This Port Code" aka "myself" then
			// the IMEXStatus should be set to "Import" if it is still "In Transit" at this point.
			if self.imexStatus = root.allImexStatuses[ TI_IMEX_STATUS_REMAINONBOARD ].description then
				
				portDestCode	:= self.getMyTerminal().getConfig( PortDestCode ).String;
				
				if self.dischargePort = portDestCode then
					self.imexStatus	:= root.allImexStatuses[ TI_IMEX_STATUS_IMPORT ].description;			//21.11.2022 navma1 #55424
				endif;
			endif;
		endif;
		// TFS 63125		
		if self.myEDIData.isTransportManifestRelated then
			if self.myEDIData.isKindOf(CM_EDIDataShipManifest) then
				manifest := self.myEDIData.CM_EDIDataShipManifest.myTransportManifest;
			endif;
			if manifest &lt;&gt; null then
				self.manifestNumber := manifest.manifestNumber;
			endif;
		endif;
		// TFS 63125 end
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="dc21e503-8656-4403-bfb6-da8dc36680a0">
        <updating/>
        <source>verifySelf() updating;
/*

Date		Who		Reason
22 October 2015	cnwer1	Initial creation PAR 37090
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks

*/

vars
	voyage  : CM_Voyage;
begin
	inheritMethod();

	
	voyage:=self.getVoyage();
	if voyage &lt;&gt; null then
		//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
		if voyage.hasDeparted and not voyage.isNullVoyage and  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then	
			app.raiseCMException1(Voyage_departed,voyage.code,"Voyage Code", self);
		endif;
	endif;
	
	//navra1 - DEFECT 66047 - 11th Sep 2024 - start
	/*
	//navra1 - BUG 65726 - 26th Aug 2024 - start	
	if self.imexStatus.toUpper() = app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT].description.toUpper() then
		if self.dischargePort &lt;&gt; app.myPassport.myTerminal.getConfig(PortDestCode).String.trimBlanks() then			
			app.raiseCMWarning2(Inv_dis_por_not_in_disch_comp, self.dischargePort, 'discharge port', ETRow_DischargePort, self, self);
			return;
		endif;
	endif;
	//navra1 - BUG 65726 - 26th Aug 2024 - end
	*/
	//navra1 - DEFECT 66047 - 11th Sep 2024 - end
epilog

end;</source>
    </JadeMethod>
</Class>
