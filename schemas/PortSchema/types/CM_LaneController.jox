    <JadeMethod name="getScanReader" id="7fcbd60f-3d90-4692-bcd4-f25f37c67a60">
        <source>getScanReader() : CM_ScanReaderObj;
/*

Purpose:			Gets the Scan Reader associated with the lane controller

Parameters:			NONE

Return Value:		CM_ScanReaderObj	Returns the Scan reader associated with the lane controller

Date			Who		Reason
04 May 2022		navpw1	Initial creation TFS: 52773
20 June 2022	navpw1	TFS 52773 - Added isValidObject check to ensure that the object exists to protect against error code 4, whereby the object reference no longer exists
19 July 2022	navmd1	TFS 52777 - And removed it again... because you know, there was an exception handler already there :(
*/

vars
	ld			: CM_LDScanReader;
	invalidObj 	: Boolean;
	
begin
	ld := self.getLaneDevice_ScanReader();
	on Exception do app.handleDeletedObject(exception, ld, invalidObj);
	
	if ld &lt;&gt; null then
		ld.edition;
		if not invalidObj then
			return ld.myScanReader;
		endif;
	endif;
	
	return null;

end;</source>
        <ReturnType type="CM_ScanReaderObj"/>
    </JadeMethod>
    <JadeMethod name="getScanReaderName" id="6d4e846f-5e16-4131-bfae-cfa2c1eb3543">
        <source>getScanReaderName() : String;
/*

Purpose:			Gets the Scan Reader name for the Scan Reader associated with the lane controller

Parameters:			NONE

Return Value:		String	Returns the Scan Reader name for the Scan Reader associated with the lane controller

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	scanReader : CM_ScanReaderObj;
	invalidObj : Boolean;

begin
	scanReader := self.getScanReader();
	on Exception do app.handleDeletedObject( exception, scanReader, invalidObj );
	
	if scanReader &lt;&gt; null then
		return scanReader.name;
		
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
