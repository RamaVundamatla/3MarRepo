    <JadeMethod name="createRTGArea" id="6550d27c-efbe-4976-ba91-519bc32dc9c1">
        <source>createRTGArea(_name: String; _rows,_stacks,_tiers: Integer): CM_RTGArea;
//01 September 2008	cnwdw1	 
//
vars
	num : Integer;
	row : CM_GridRow;
	col : CM_GridColumn;
	pxyRTGArea: CM_RTGArea;
begin
	create pxyRTGArea transient;
	pxyRTGArea.setIsEmpty(true);
	pxyRTGArea.setGridAreaProxy(_name, 
					"",
					TA_TYPE_RTG,
					_rows,
					_stacks,
					_tiers,
					true, 
					self.getTerminal,
					true,
					false,
					false,
					0,
					false, false, false, false, false, null,null, false, false,
					 null,null,null,null);
	
	foreach num in 1 to pxyRTGArea.numberOfRows do
		create row transient;
		row.setForProxy(num,"Row#"&amp;num.String,pxyRTGArea);
	endforeach;
	
	foreach num in 1 to pxyRTGArea.numberOfColumns do
		create col transient;
		col.setForProxy(num,"Col#"&amp;num.String,pxyRTGArea);
	endforeach;
	
	return pxyRTGArea;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="createRTGController" id="fef2cfd6-0c4f-4210-b959-4369e9cc1fe9">
        <source>createRTGController(name : String; rowNum,colNum : Integer; gridArea : CM_GridArea) : CM_GridController;
/*
Call the addRTGArea method before this one and use the result of that method as an
input into this one

Date		Who		Reason
05 February 2009	cnwcp2	Initial creation
*/

vars
	cont : CM_RTGController;
//	row : CM_GridRow;
//	col : CM_GridColumn;
begin
	create cont transient;
//	create row transient;
//	create col transient;
//	row.setForProxy(rowNum,"Row"&amp;rowNum.String,null);
//	col.setForProxy(colNum,"Col"&amp;colNum.String,null);
	//cont.setForProxyGridController(name,col,row,2);
	cont.setForProxy(PAD_AVAILABLE,NORMAL_USE,rowNum,colNum,name,1,true,false,null,gridArea,false,0,false,0,false,0);
	//cont.setForProxyRTGController(PAD_AVAILABLE,NORMAL_USE,null,null,false,0);
	
	return cont;
epilog

end;</source>
        <Parameter name="name" type="String"/>
