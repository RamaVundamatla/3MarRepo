    <JadeMethod name="setForUpdate" id="4d76ad6b-0ad0-4e86-b428-0bfddfe831a2">
        <updating/>
        <source>setForUpdate(_proxy: CM_HSCodeHeading) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
	
	if _proxy.myHSChapter &lt;&gt; null then
		self.myHSChapter := _proxy.myHSChapter;
	else
		self.myHSChapter := _proxy.getParentFromRoot();
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_HSCodeHeading"/>
    </JadeMethod>
