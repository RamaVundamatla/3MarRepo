    <JadeMethod name="calcPermission" id="98bfd014-bab8-4992-81e0-fbfbe843c46c">
        <source>calcPermission(_msgType : String) : Integer protected;
// -----------------------------------------------------------------------------
// Created:		13 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	constStr : String;
	const	: GlobalConstant;
	
begin

	//cnwrd1 par 30188 13.8.2012
	// this is for C3 the bolmaintrq message will use the bolentryrq permission.
	if _msgType = CM_RemoteDataManagerExternal.BOLMAINTRQ then
		constStr := 'PmXml' &amp; CM_RemoteDataManagerExternal.BOLENTRYRQ;
	else
		constStr := 'PmXml' &amp; _msgType;
	endif;
	
//	constStr := 'PmXmlTIQueryRq';
	const := currentSchema.getConstant(constStr);
	
	if const = null then
		return -1;
	endif;
	
	return const.getSource().Integer;
end;</source>
        <access>protected</access>
        <Parameter name="_msgType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkPermission" id="9e812a19-9cc9-497f-b007-f54762bc29a7">
        <source>checkPermission(_msgType : String; _doesExist:Boolean output):Boolean;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	permission : Integer;
	
begin
	permission := self.calcPermission(_msgType);
	
	if permission = -1 then
		app.cnWriteServerLog("Msg Type not found.");
		_doesExist	:=	false;
	else
		app.cnWriteServerLog("Msg Type exists.");
		_doesExist	:=	true;
	endif;
	
	if permission &lt;&gt; -1 and self.myUser &lt;&gt; null then
		return self.myUser.canDo(self.myTerminal, permission);
	endif;
	
	return false;
end;</source>
        <Parameter name="_msgType" type="String"/>
        <Parameter name="_doesExist" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPermissions" id="a100fdaf-a87d-43f9-a572-f999b0d83e18">
        <source>getPermissions();
/*

Purpose:		NOT REFERENCED DO NOT DELETE 
				just a reference (the only reference ) to the xml permissions used by this

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlger1	Initial creation

*/

vars
	permission : Integer;
begin
	permission:=PmXmlBOLQueryRq;
	permission:=PmXmlCodeRq;
	permission:=PmXmlJobLstQryRq;
	permission:=PmXmlJobPickupRq;
	permission:=PmXmlJobQryRq;
	permission:=PmXmlLcnQueryRq;
	permission:=PmXmlLogRowMntRq;
	permission:=PmXmlRegradeRq;
	permission:=PmXmlRejectRq;
	permission:=PmXmlReticketRq;
	permission:=PmXmlSclCheckRq;
	permission:=PmXmlSclTruckRq;
	permission:=PmXmlTIQueryRq;
	permission:=PmXmlTransferRq;
	permission:=PmXmlUserQueryRq;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetAttributes" id="3b92a86a-dc0d-48b2-8137-adbad7463010">
        <updating/>
        <source>resetAttributes(_terminal, _passWrd : String) updating;

vars

begin

	self.terminal	:= _terminal;
	self.passWrd	:= _passWrd;
	updateReferences();

end;</source>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_passWrd" type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="1faa853d-b1d2-48f3-b426-1dc5a02b63da">
        <updating/>
        <source>set(_userCode, _deviceID, _terminal, _version, _passWrd : String) updating;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.userCode 	:= _userCode;
	self.deviceID 	:= _deviceID;
	self.terminal	:= _terminal;
	self.theVersion	:= _version.Integer;
	self.passWrd	:= _passWrd;		
	self.updateReferences();
	
	app.myPassport.setMyTerminal(self.myTerminal);
	app.myPassport.setMyUser(self.myUser);

end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_deviceID" type="String"/>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_version" type="String"/>
        <Parameter name="_passWrd" type="String"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="a38c0d3e-9f7a-4ef3-9ece-ade0102165c6">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		13 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(eventTag);
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateReferences" id="00b7c377-3ce4-436a-a913-e1f2b9c794d7">
        <updating/>
        <source>updateReferences() updating, protected;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	user 	: CM_User;
	device	: CM_RadioTelemetryDevice;
begin
	
	user := app.myRoot.allUsers[self.userCode];
	if user &lt;&gt; self.myUser then
		self.myUser := user;
	endif;
	self.myTerminal := app.myRoot.allTerminals[self.terminal];

	if self.myTerminal = null then
		return;
	endif;
	
	device := self.myTerminal.radioTelemetry.allRTDevices[self.deviceID];

	if device &lt;&gt; self.myDevice then
		self.myDevice := device;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
