    <JadeMethod name="doToggleExtraInfo" id="468797d6-9269-4021-b093-2035c93c7f7f">
        <updating/>
        <source>doToggleExtraInfo(_splitter : CMUI_SplitContainer input) protected, updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
begin
	if self.mnuHideAdditionalInfo.caption = self.MNU_EXTRAINFO_SHOW then
		_splitter.showRightControl(100 - 65, true);
		self.mnuHideAdditionalInfo.caption := self.MNU_EXTRAINFO_HIDE;
	else
		_splitter.hideRightControl(true);
		self.mnuHideAdditionalInfo.caption := self.MNU_EXTRAINFO_SHOW;
	endif;
	
	_splitter.cnEcResizeContents;
end;</source>
