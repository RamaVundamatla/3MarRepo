    <JadeMethod name="delete" id="2333087e-7747-46e7-8aac-2b90db71d767">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Sep 2011	cnwkpd1		PAR #28262 - CCMS 1223 - Delivery Mechanisms (also par 29158)
// ---------------------------------------------------------------------------
vars
	objExt		: CM_ObjectExtension;
	//14 Jan 2021	NDL	TFS 50251
	localAudits : CM_AuditObjectDictByTimestamp;
	audit : CM_AuditObject;
	invalid : Boolean;
	edition : Integer;
	
begin
	if self.isTransient then
		if app.myProxyManager &lt;&gt; null then
			app.myProxyManager.deleteProxyLink(self);
		endif;
	endif;
	
	// PAR #28262 - Delete receiver's object extension if there is one
	objExt := self.getMyObjectExtension();
	if objExt &lt;&gt; null then
		delete objExt;
	endif;
		
end;</source>
    </JadeMethod>
