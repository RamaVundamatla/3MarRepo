    </JadeMethod>
    <JadeMethod name="loadMsgInvoiceTypes" id="5b9bdfef-ec39-4f93-a027-08aff498d71f">
        <source>loadMsgInvoiceTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57991 Task 57992: EUP - INCO Terms Mapping
*/

vars
	invoicelines : CM_InvoiceLineDescSet;
	invoiceline : CM_InvoiceLineDesc;
begin
	if self.myCurrentBank &lt;&gt; null then
		create invoicelines transient;
		foreach invoiceline in self.myCurrentBank.invoiceLineDescriptors discreteLock do
			invoicelines.add(invoiceline);
		
		endforeach;
	endif;
	
	self.msgInvlistTypes.myAvailableListBox.sorted 	:= true;
	self.msgInvlistTypes.mySelectedListBox.sorted 	:= true;
	self.msgInvlistTypes.setupControl(null, invoicelines, INV_INCOTermMapping::getLineTypeDescription.name);
	self.msgInvlistTypes.availableHeading	:= app.getErrorString(Available);
	self.msgInvlistTypes.selectedHeading	:= app.getErrorString(Selected);
	self.msgInvlistTypes.myBaseForm	:= self;
	self.msgInvlistTypes.setSelected(null);

epilog

end;</source>
    </JadeMethod>
