    <JadeMethod name="createTISealsFromEdiSeal" id="fd765a72-9fc9-4f74-a789-62bdfe0210a8">
        <source>createTISealsFromEdiSeal(_tmpSeals : ObjectArray io) : Boolean;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	retValue : Boolean;
	edi : CM_EDITrackedItem;
begin

	if self.myAttachedItems.isEmpty then
		return false;
	endif;
	
	foreach edi in self.myAttachedItems where edi.isEDISealDetails do
		_tmpSeals.add(edi);
		retValue := true;
	endforeach;
	
	return retValue;

epilog

end;</source>
        <Parameter name="_tmpSeals" type="ObjectArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="39cdf4cd-af39-4f0d-a056-fd8a5a212c5b">
        <updating/>
        <source>delete() updating;
/*
Purpose:	Make sure the manual collection on myEDIConfig is maintained

Date			Who		Reason
08 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
*/
vars
	voyageCodeStr	: String;
	
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getVoyageCode();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152 
	
epilog
	
end;
</source>
    </JadeMethod>
