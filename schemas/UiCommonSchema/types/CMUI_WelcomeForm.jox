    <JadeMethod name="selectReport" id="3cb6be19-dc12-4a58-89ed-f5b33e611d3e">
        <source>selectReport(_report :CM_QryReport; _form :CMUI_ReportRunner input)protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ut			:CM_UserTerminal;
	menuItem	:CM_MenuUserItem;
	parent		:CM_MenuEntity;
	index		:Integer;
begin
	ut := self.getUserTerminal;
		
	if ut = null then
		app.raiseCMException( ERR_dontHaveAccessToThisItem, null, self );
		return;
	endif;
		
	
	menuItem 	:= _report.getMenuUserDtl (self.getUserTerminal);
	if menuItem = null then	//Par 18024
		app.raiseCMException1( ERR_ReportNotFound, _report.reportName, null, self );
		return;
	endif;
	
	parent		:= menuItem.myParent;
	index 		:= _form.lbReportTree.findObject (parent);
	
	while index &gt; 0 and parent &lt;&gt; null do
		_form.lbReportTree.itemExpanded[index] := true;
		
		parent		:= parent.myParent;
		index 		:= _form.lbReportTree.findObject (parent);	
	endwhile;
	
	_form.lbReportTree.selectObject (menuItem);
	_form.doTreeClick;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="CM_QryReport"/>
        <Parameter name="_form" type="CMUI_ReportRunner" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1e91d08a-a5db-48a5-95b1-19a8c2743f6f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	label	:Label;
	pic		:Picture;
begin
	inheritMethod(); 	

	self.showToolbar	:= false;
	self.clientWidth	:= 750;
	self.clientHeight	:= 425;
	
	// set picture for navigator item to be that used in system
	picNavigator.picture	:= app.myRoot.getConfig (PicNavigateUp).Binary;

	//	column 1
	self.setupNavigatorItem (lblCol1Row1, picCol1Row1, PmGteFullReleaseView);
	self.setupNavigatorItem (lblCol1Row2, picCol1Row2, PmJobRequestView);
	// column 2
	self.setupNavigatorItem (lblCol2Row1, picCol2Row1, PmGtePreNoteView);
	self.setupNavigatorItem (lblCol2Row2, picCol2Row2, PmJobRequestView);
	// column 3
	self.setupNavigatorItem (lblCol3Row1, picCol3Row1, PmAdmCargoEnquiryView);
	self.setupReportItem (lblCol3Row2, picCol3Row2, CM_RepContainerSummary);
	self.setupNavigatorItem (lblCol3Row3, picCol3Row3, PmCargoQuickViewView);
	self.setupReportItem (lblCol3Row4, picCol3Row4, CM_RepVoyageList);
	
	self.setupHyperlinkItem (lblHyperlink1, null, 'http://www.dctgdansk.net/itcs/firststeps.html');
	self.setupHyperlinkItem (lblHyperlink2, null, 'http://www.dctgdansk.net/itcs/support.html');
	self.setupHyperlinkItem (lblHyperlink3, null, 'http://www.dctgdansk.net/itcs/elearning.html');
	self.setupHyperlinkItem (lblHyperlink4, null, 'http://www.dctgdansk.net/itcs/features.html');
	self.setupHyperlinkItem (lblHyperlink5, null, 'http://www.dctgdansk.net/itcs/news.html');

	self.zOrder (1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupHyperlinkItem" id="4e985b51-649f-4662-b2a1-8b45d8d12960">
        <source>setupHyperlinkItem(_label :Label input; _text, _link :String)protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _link = null then
		_label.visible := false;
	endif;
	
	if _text &lt;&gt; null then
		_label.caption	:= _text;
	endif;
	
	_label.tag		:= _link;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="Label" usage="input"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_link" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupNavigatorItem" id="4cdfe537-09f8-48f6-960e-12e5b563ba3e">
        <source>setupNavigatorItem(_label :Label input; _picture :Picture input;_permission :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item 	:CM_MenuDtlNav;
begin 
	if _permission = null or 
		not app.getMyUser.canDo (self.getTerminal, _permission) then
		_label.visible	:= false;
		_picture.visible	:= false;
		return;
	endif;
		
	item := app.myRoot.getNavigatorItem (_permission);
	
	if item = null then
		_label.visible		:= false;
		_picture.visible	:= false;
		return;
	endif;
	
	_label.userObject		:= item;
	_picture.userObject		:= item;
//	_label.caption			:= item.getHeading;
	_picture.picture		:= item.pictureButton;
	_picture.pictureDown	:= item.pictureButtonDown;
	_picture.borderStyle	:= null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="Label" usage="input"/>
        <Parameter name="_picture" type="Picture" usage="input"/>
        <Parameter name="_permission" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupReportItem" id="b88939ad-2258-4ccd-8a8b-f57dab0be11c">
        <source>setupReportItem(_label :Label input;_pic :Picture input; _report :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item	:CM_QryReport;
begin
	if _report = null or not
		app.getMyUser.canDo (self.getTerminal, PmReportRunnerView) then
		_label.visible	:= false;
		_pic.visible	:= false;
	endif;
	
	item := app.myRoot.myReportMenuRoot.getReportByConstantValue (_report);
	
	if item = null or 
		not app.getMyUser.canUserViewReport (item) then
		_label.visible	:= false;
		_pic.visible	:= false;
	endif;
	
	_label.userObject	:= item;
//	_label.caption		:= item.getHeading;
	_pic.userObject		:= item;
	_pic.picture		:= self.getPictureForReports;
	_pic.borderStyle	:= null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="Label" usage="input"/>
        <Parameter name="_pic" type="Picture" usage="input"/>
        <Parameter name="_report" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="262ccbe4-7cb1-4542-89fd-807a5cb06ed5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009092, locale);
	chkDoNotShow.translateCaption(Xlat_0009093, locale);
	lblCol1Row1.translateCaption(Xlat_0009107, locale);
	lblCol1Row2.translateCaption(Xlat_0009108, locale);
	lblCol2Row1.translateCaption(Xlat_0009109, locale);
	lblCol2Row2.translateCaption(Xlat_0009110, locale);
	lblCol3Row1.translateCaption(Xlat_0009111, locale);
	lblCol3Row2.translateCaption(Xlat_0009112, locale);
	lblCol3Row3.translateCaption(Xlat_0009113, locale);
	lblCol3Row4.translateCaption(Xlat_0009114, locale);
	lblHeading.translateCaption(Xlat_0009094, locale);
	lblHyperlink1.translateCaption(Xlat_0009115, locale);
	lblHyperlink2.translateCaption(Xlat_0009116, locale);
	lblHyperlink3.translateCaption(Xlat_0009117, locale);
	lblHyperlink4.translateCaption(Xlat_0009118, locale);
	lblHyperlink5.translateCaption(Xlat_0009119, locale);
	lblNavigator.translateCaption(Xlat_0009095, locale);
	lblSubHeading1.translateCaption(Xlat_0009096, locale);
	lblSubHeading2.translateCaption(Xlat_0009097, locale);
	lblSubHeading3.translateCaption(Xlat_0009098, locale);
end;</source>
    </JadeMethod>
</GUIClass>
