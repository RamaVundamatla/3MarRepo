        <source>passwordMessageException(exObj	:	Exception; errorCode	:	Integer io	)	:	Integer;

vars

begin
	if exObj.errorCode = ERR_INVALID_PASSWORD then
		errorCode := ERR_INVALID_PASSWORD;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
