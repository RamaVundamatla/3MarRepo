    <JadeMethod name="tCheckRotaContainer" id="e335c6e6-d73d-4681-b778-9fb16f740f9a">
        <source>tCheckRotaContainer();
/*

Purpose:			This unit test check Cargo Type for Contents and Cargo Sub Type for Contents are set correct for Rota Containers

Parameters:			

Return Value:		

Date		Who		Reason
08/10/2025	navkc1 JIRA 36145 AAT | RotaBox ISO Type and New Attributes - Unit Test

*/
constants
	UTISOTYPE = 'UR0T';
	UTCONT = 'CONT';
	UTCTYPECONTENTS = 'UR0TA';
	UTPRODCONTENTS = 'UR0TAS';
	UTCONTID = 'UTCROTA-1';
	UTTRUCKID = 'UTROTATRUCK';
vars
	cTypeContents,
	cTypeContainer	: CM_CargoType;
	product			: CM_Product;
	iso				: CM_ISOType;
	term 			: CM_Terminal;
	root			: CM_Root;
	vvr				: CM_VehicleVisitRecord;
	tiCont			: CM_TrackedItem;
	operator		: CM_Operator;
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Cargo Type Container
		cTypeContainer := self.getCargoType(UTCONT);
		self.assertNotNullMsg(cTypeContainer, "Failed to get Cargo Type Container");
	
	// Get ISO Type
		iso := self.addISOType(UTISOTYPE, "UT ROTA ISO TYPE", cTypeContainer, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, 1000);
	
	// Get Cargo Type for Contents
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Bulk);
		cTypeContents := self.addCargoType(UTCTYPECONTENTS, true);
	
	// Get Product
		self.opts.purge();
		product := self.addProduct(UTPRODCONTENTS, null, cTypeContents);
	
	// Get TI Container
		// Delete existing one
		tiCont := self.getTrackedItem(UTCONTID);
		self.deleteTrackedItem(tiCont, true);
	
	// Gate in Container
	self.deleteVehicle(UTTRUCKID);
		self.opts.purge();
		self.opts.addAssoc('CargoTypeForContents',cTypeContents);
		self.opts.addAssoc('SubTypeForContents', product);
		self.opts.addAssoc('WeightCargo', 1000);
		vvr := self.gateInContainer(UTTRUCKID, UTCONTID, UTISOTYPE, operator.code, null, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	// Do stuff
		self.workVehicle(vvr);
		self.roadExit(vvr);
		
	// Check - Make sure Cargo Type for Content and Prodcut is set correctly for Rota Container
		tiCont := self.getTrackedItem(UTCONTID);
		
		self.assertNotNullMsg(tiCont, 'Failed to get the Rota Container');
		self.assertEqualMsg(tiCont.getCargoTypeForContents(), cTypeContents, 'Actual CM_TrackedItem::myCargoTypeForContents does not match with the expected');
		self.assertEqualMsg(tiCont.myProduct, product, 'Actual CM_TrackedItem::myProduct does not match with the expected');
	
epilog
	self.deleteISOType(UTISOTYPE);
	self.deleteCargoType(UTCTYPECONTENTS);
	self.deleteTrackedItem(tiCont, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrackedItemState" id="7de7651c-a8c9-43f8-be3f-c295c3adc357">
        <source>tCheckTrackedItemState();
// cnwmp6
// cnwjre1 check par 33354
constants
	TrainCode : String = "UT-TRAINJ1";
	WagonCode1 : String = "JX_001";
	WagonClassCode : String = "JX";
	RailAreaId : String = "UT_JRA1";
	TrackedItem1 			= "UT100";
	StraddleStack1 			= "UT_ST1";
	QueueForStraddleStack1 	= "UT_ST1_Q";
	StraddleStack2 			= "UT_ST2";
	QueueForStraddleStack2 	= "UT_ST2_Q";
	Straddle1 				= "UTS1";
vars
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	operator : CM_Operator;
	ti			: CM_TrackedItem;
	st1, st2	: CM_GridArea;
	q1, q2		: CM_RadioTelemetryQueue;
	tas			: StringArray;
	straddle	: CM_Machine;
	task		: CM_RTQueueTask;
	accept, pickup, setdown	: CM_MachineMoveHistory;
	origRequiresImportOperatorPIN : Boolean;
	now : TimeStamp;	//07 Aug 2020	NDL	TFS 49852
	tiTrx : CM_TITransaction;	//07 Aug 2020	NDL	TFS 49852
	ordNo : Integer;	//07 Aug 2020	NDL	TFS 49852
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);		
	origRequiresImportOperatorPIN := operator.getConfig(RequiresImportOperatorPIN).Boolean;						// 30/04/2014 cnwmh5
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);

	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	railArea := self.addRailArea(RailAreaId, 4, 10);
	self.assertNotNull(railArea);
	
	wagonClass := self.addWagonClass(WagonClassCode);
	wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);
	
	self.deleteContainer(TrackedItem1);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteRTDevice("91");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 	:= self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);

	// move TI into straddle stack
	ti := self.addContainer(TrackedItem1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	// queue TI to other straddle stack
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	// assigning straddle to area
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2);
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack2);
	
	// Work first straddle task - move to Area 2
	straddle := self.getMachine(Straddle1);
	assertNotNull(straddle);
	self.machineLogon(straddle);
	
	task := self.machineTaskRequest(straddle);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	
	self.machineAcceptTask(straddle, task);
	// check history
		accept := straddle.history.last.CM_MachineMoveHistory;
			assertEqual(accept.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept.isStartOfLift, true);
			assertEqual(accept.isEndOfLift, false);
			assertEqual(accept.myPriorLiftHistory, null);
			assertEqual(accept.myPriorHistory, null);

	self.machinePickup(straddle);
		pickup := straddle.history.last.CM_MachineMoveHistory;
			assertEqual(pickup.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup.isStartOfLift, false);
			assertEqual(pickup.isEndOfLift, false);
			assertEqual(pickup.myPriorLiftHistory, accept);
			assertEqual(pickup.myPriorHistory, accept);
			
			assertEqual(accept.myNextLiftHistory, pickup);
			assertEqual(accept.myNextHistory, pickup);
			
	self.machineSetdown(straddle, ti, "UT_ST2 010001");
		setdown := straddle.history.last.CM_MachineMoveHistory;
			assertEqual(setdown.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown.isStartOfLift, false);
			assertEqual(setdown.isEndOfLift, true);
			assertEqual(setdown.myPriorLiftHistory, pickup);
			assertEqual(setdown.myPriorHistory, pickup);
			
			assertEqual(pickup.myNextLiftHistory, setdown);
			assertEqual(pickup.myNextHistory, setdown);

	self.assertEqual(ti.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);
				

	self.machineLogOff(straddle);
	
	//07 Aug 2020	NDL	TFS 49852
	now := app.actualTimeAppServer;
	beginTransaction;
	foreach tiTrx in ti.allTransactions do
		tiTrx.updateDateTime( now );
	endforeach;
	commitTransaction;
	
	foreach tiTrx in ti.allTransactions do
		self.assertTrueMsg( tiTrx.dateTime = now, "TI Transaction 'dateTime' not updated correctly " &amp; tiTrx.getDisplayDetails(false) );
		self.assertTrueMsg( tiTrx.orderNo = ordNo, "TI Transaction 'orderNo' not incremented correctly " &amp; tiTrx.getDisplayDetails(false) );
		ordNo := ordNo + 1;
	endforeach;
	
	//finished clean up
	self.deleteRailArea(RailAreaId);
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteTrain(TrainCode,null);
	self.deleteContainer(TrackedItem1);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteRTDevice("91");

epilog

	abortTransaction;

	// 30/04/2014 cnwmh5 - Reset to original value
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, origRequiresImportOperatorPIN);
	commitTransaction;

	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateChildTI" id="fdfc7426-3a33-4933-b56c-bd325f43f272">
        <source>tCreateChildTI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/04/2014	cnwma1	Initial creation
*/
constants
	CONT ="APZU66999";
	CANNON = "CANNON5555";
	BS	= "UTBS666";
vars
	ti 		   : CM_TrackedItem;
	pxyChild,
	realChild  : CM_TrackedItem;
	cargoType  : CM_CargoType;
	bs 		   :CM_BlockStack;

begin
	
	deleteTerminalArea(BS);
	bs := self.addBlockStack(BS,500,null);
	
	//deleteContainer(CONT);
	deleteCargo(CANNON,"CANNON");

	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
	
	pxyChild := self.createTrackedItem(CANNON,cargoType.id,null,self.getOperator("APL"),true, null);
	self.assertNotNull(pxyChild);
	
	ti := addContainerAtLocation(CONT,self.getOperator("APL"),"2200","GENL",TI_IMEX_STATUS_IMPORT,bs);
	self.assertNotNull(ti);

	
	app.myTrxCA.trxCreateChildTrackedItem(ti,pxyChild,realChild,app.myPassport);
	assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.allChildren.size,1);
	self.deleteStops(ti);

epilog

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCustomsReferencesCreateUpdate" id="28fcf562-e5aa-42b7-8a70-32eb21c30940">
        <source>tCustomsReferencesCreateUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2022	navpw1	Initial creation TFS: 55215
27/02/2024	navcs2	Defect 62587: CUX | POST/CustomsStatus Method Does not create any Transaction
20 Mar 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - added ti parameter to the trx call and set this to the current trackedItem
09 Apr 2024	navlw1  Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode

*/

constants
	CONTAINERID : String = "UT55215-001";
	BSName		: String = "UT55215";
	ReferenceType1	: String = "Ref1";
	ReferenceNumber1 : String = "Ref1";
	PositionNumber1 : Integer = 1; // navlw1 #63566
	Status1: String = "HELD";
	ObjectName1: String = "Ref1";
	TotalPackages1 : Integer = 0;
	PackagesRemaining1 : Integer = 0;
	CustomsControl1: String = "Ref1";
	RetentionPeriod1 : String = "21/11/2022 00:00:00.000";
	
	UpdStatus1: String = "HELD1";
	UpdObjectName1: String = "Ref11";
	UpdTotalPackages1 : Integer = 1;
	UpdPackagesRemaining1 : Integer = 1;
	UpdCustomsControl1: String = "Ref11";
	UpdRetentionPeriod1 : String = "22/11/2022 00:00:00.000";
	
	ReferenceType2	: String = "Ref2";
	ReferenceNumber2 : String = "Ref2";
	PositionNumber2 : Integer = 1;
	Status2: String = "HELD";
	ObjectName2: String = "Ref2";
	TotalPackages2 : Integer = 0;
	PackagesRemaining2 : Integer = 0;
	CustomsControl2: String = "Ref2";
	RetentionPeriod2 : String = "21/11/2022 10:00:00.000";
	
	UpdStatus2: String = "HELD2";
	UpdObjectName2: String = "Ref21";
	UpdTotalPackages2 : Integer = 2;
	UpdPackagesRemaining2 : Integer = 2;
	UpdCustomsControl2: String = "Ref21";
	UpdRetentionPeriod2 : String = "22/11/2022 10:00:00.000";
	
vars
	pxyTrackedItem,
	realTrackedItem,
	trackedItem : CM_TrackedItem;
	operator : CM_Operator;
	terminal : CM_Terminal;
	bs		: CM_BlockStack;
	
	proxyLink : CM_ProxyLink;
	customsReference,
	realCustomsReference,
	realCustomsReference2,
	pxyCustomsReference,
	pxyCustomsReference2 : CM_CustomsReference;
	pxyCustomsReferences,
	realCreateCustomsReferenceDict: CM_CustomsReferenceDict;
	retentionPeriod1 : Date;
	
begin
	self.deleteContainer(CONTAINERID);
	self.assertNoTrxErrorsOrWarnings();
	
	self.deleteTerminalArea(BSName);
	
	bs := self.addBlockStack( BSName, 32, null);	
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	terminal := self.getTerminal();
	
	trackedItem := self.addContainerAtLocation(CONTAINERID, operator, "2200", "FCL", TI_IMEX_STATUS_EXPORT, bs);
	
	//Test 1 - Updating a tracked item with Customs References
	//Test creation/update of customs references on traced item. Tests proxy creation and update trx to make sure customs references can be created froma proxy tracked item
	
	create realCreateCustomsReferenceDict transient;
	
	create pxyCustomsReferences transient;
	
	create pxyCustomsReference transient;
	pxyCustomsReference.setProxy(ReferenceType1, ReferenceNumber1, PositionNumber1, Status1, ObjectName1, TotalPackages1, PackagesRemaining1, CustomsControl1, RetentionPeriod1.asDate);
	pxyCustomsReference.setTrackedItem(trackedItem);
	
	pxyCustomsReferences.add(pxyCustomsReference);
	
	create pxyCustomsReference2 transient;
	pxyCustomsReference2.setProxy(ReferenceType2, ReferenceNumber2, PositionNumber2, Status2, ObjectName2, TotalPackages2, PackagesRemaining2, CustomsControl2, RetentionPeriod2.asDate);
	pxyCustomsReference2.setTrackedItem(trackedItem);
	
	pxyCustomsReferences.add(pxyCustomsReference2);
	
	//Run TRX
	
	app.myTrxCA.trxCreateCustomsReferences(pxyCustomsReferences, trackedItem, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realTrackedItem := app.myRoot.lookupTrackedItem(CONTAINERID, null, TI_STATE_UNDEFINED, null, false, terminal, true);
	
	//Check all customs references is not null/set
	self.assertNotNullMsg(realTrackedItem.allCustomsReferences, "Customs References");
	
	self.assertTrueMsg(realTrackedItem.allCustomsReferences.isNotEmpty, "Customs References is empty");
	
	//Check custom references objects to make sure they are correctly set
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType1, ReferenceNumber1, PositionNumber1];
	self.assertNotNullMsg(customsReference, "Customs Reference 1");
	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");
	self.assertFalseMsg(customsReference.myTrackedItem.isTransient, "Tracked item is a transient");
	self.assertTrueMsg(customsReference.myTrackedItem = realTrackedItem, "Tracked Item is not st to the correct reference");
	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType1, "Expected: " &amp; ReferenceType1 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber1, "Expected: " &amp; ReferenceNumber1 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber1, "Expected: " &amp; PositionNumber1.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = Status1, "Expected: " &amp; Status1 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = CustomsControl1, "Expected: " &amp; CustomsControl1 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = ObjectName1, "Expected: " &amp; ObjectName1 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = TotalPackages1, "Expected: " &amp; TotalPackages1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = PackagesRemaining1, "Expected: " &amp; PackagesRemaining1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = RetentionPeriod1.asDate, "Expected: " &amp; RetentionPeriod1 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);
	
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType2, ReferenceNumber2, PositionNumber2];
	self.assertNotNullMsg(customsReference, "Customs Reference 2");
	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");
	self.assertFalseMsg(customsReference.myTrackedItem.isTransient, "Tracked item is a transient");
	self.assertTrueMsg(customsReference.myTrackedItem = realTrackedItem, "Tracked Item is not st to the correct reference");
	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType2, "Expected: " &amp; ReferenceType2 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber2, "Expected: " &amp; ReferenceNumber2 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber2, "Expected: " &amp; PositionNumber2.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = Status2, "Expected: " &amp; Status2 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = CustomsControl2, "Expected: " &amp; CustomsControl2 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = ObjectName2, "Expected: " &amp; ObjectName2 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = TotalPackages2, "Expected: " &amp; TotalPackages2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = PackagesRemaining2, "Expected: " &amp; PackagesRemaining2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = RetentionPeriod2.asDate, "Expected: " &amp; RetentionPeriod2 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);
	
	delete pxyCustomsReference;
	delete pxyCustomsReference2;
	delete pxyTrackedItem;
	
	foreach proxyLink in app.myProxyManager.allReals do
		if not proxyLink.myRealObject.isKindOf(CM_CustomsReference) then
			continue;
		endif;
		
		self.assertTrueMsg(false, "Transients left over from creating proxy CM_CustomsReference" &amp; CrLf &amp; "More Info:" &amp; CrLf &amp; CM_CustomsReference::referenceNumber.name &amp; ": '" &amp; proxyLink.myProxyObject.CM_CustomsReference.referenceNumber);
		break;
		
	endforeach;
	
	if realCreateCustomsReferenceDict.isNotEmpty then
		realCreateCustomsReferenceDict.clear();
	endif;
	
	if pxyCustomsReferences.isNotEmpty then
		pxyCustomsReferences.clear();
	endif;
	
	//Test 2 - Updating Customs References on a tracked item and adding more
	trackedItem := app.myRoot.lookupTrackedItem(CONTAINERID, null, TI_STATE_UNDEFINED, null, false, terminal, true);
	
	realCustomsReference := trackedItem.allCustomsReferences[ReferenceType1, ReferenceNumber1, PositionNumber1];
	pxyCustomsReference := app.createUpdateProxy(realCustomsReference).CM_CustomsReference;
	pxyCustomsReference.setProxyForUpdate(UpdStatus1, UpdObjectName1, UpdTotalPackages1, UpdPackagesRemaining1, UpdCustomsControl1, UpdRetentionPeriod1.asDate);
	
	realCustomsReference2 := trackedItem.allCustomsReferences[ReferenceType2, ReferenceNumber2, PositionNumber2];
	pxyCustomsReference2 := app.createUpdateProxy(realCustomsReference2).CM_CustomsReference;
	pxyCustomsReference2.setProxyForUpdate(UpdStatus2, UpdObjectName2, UpdTotalPackages2, UpdPackagesRemaining2, UpdCustomsControl2, UpdRetentionPeriod2.asDate);
	
	pxyCustomsReferences.add(pxyCustomsReference);
	pxyCustomsReferences.add(pxyCustomsReference2);
	
	//Run TRX
	app.myTrxCA.trxCreateCustomsReferences(pxyCustomsReferences, trackedItem, app.myPassport);
	
	realTrackedItem := app.myRoot.lookupTrackedItem(CONTAINERID, null, TI_STATE_UNDEFINED, null, false, terminal, true);
	
	//Check all customs references is not null/set
	self.assertNotNullMsg(realTrackedItem.allCustomsReferences, "Customs References");
	
	self.assertTrueMsg(realTrackedItem.allCustomsReferences.isNotEmpty, "Customs References is empty");
	
	//Check custom references objects to make sure they are correctly set
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType1, ReferenceNumber1, PositionNumber1];
	self.assertNotNullMsg(customsReference, "Test 2: Customs Reference 1");
	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Test 2: Tracked Item");
	self.assertFalseMsg(customsReference.myTrackedItem.isTransient, "Test 2: item is a transient");
	self.assertTrueMsg(customsReference.myTrackedItem = realTrackedItem, "Test 2: Tracked Item is not st to the correct reference");
	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType1, "Test 2: field (referenceType) Expected: " &amp; ReferenceType1 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber1, "Test 2: field (referenceNumber) Expected: " &amp; ReferenceNumber1 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber1, "Test 2: field (positionNumber) Expected: " &amp; PositionNumber1.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = UpdStatus1, "Test 2: field (status) Expected: " &amp; UpdStatus1 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = UpdCustomsControl1, "Test 2: field (customsContol) Expected: " &amp; UpdCustomsControl1 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = UpdObjectName1, "Test 2: field (objectName) Expected: " &amp; UpdObjectName1 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = UpdTotalPackages1, "Test 2: field (packagesTotal) Expected: " &amp; UpdTotalPackages1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = UpdPackagesRemaining1, "Test 2: field (packagesRemaining) Expected: " &amp; UpdPackagesRemaining1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = UpdRetentionPeriod1.asDate, "Test 2: field (retentionPeriod) Expected: " &amp; UpdRetentionPeriod1 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);
	
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType2, ReferenceNumber2, PositionNumber2];
	self.assertNotNullMsg(customsReference, "Customs Reference 2");
	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");
	self.assertFalseMsg(customsReference.myTrackedItem.isTransient, "Tracked item is a transient");
	self.assertTrueMsg(customsReference.myTrackedItem = realTrackedItem, "Tracked Item is not st to the correct reference");
	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType2, "Test 2: field (referenceType) Expected: " &amp; ReferenceType2 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber2, "Test 2: field (referenceNumber) Expected: " &amp; ReferenceNumber2 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber2, "Test 2: field (positionNumber) Expected: " &amp; PositionNumber2.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = UpdStatus2, "Test 2: field (status) Expected: " &amp; UpdStatus2 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = UpdCustomsControl2, "Test 2: field (customsContol) Expected: " &amp; UpdCustomsControl2 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = UpdObjectName2, "Test 2: field (objectName) Expected: " &amp; UpdObjectName2 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = UpdTotalPackages2, "Test 2: field (packagesTotal) Expected: " &amp; UpdTotalPackages2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = UpdPackagesRemaining2, "Test 2: field (packagesRemaining) Expected: " &amp; UpdPackagesRemaining2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = UpdRetentionPeriod2.asDate, "Test 2: field (retentionPeriod) Expected: " &amp; UpdRetentionPeriod2 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);
	
	self.assertNotNullMsg(realTrackedItem.allTransactions.getLastTransOfType(TRANS_TYPE_EDIT, null), "An Edit transaction has not been created");		// 27/02/2024	navcs2	Defect 62587
	
	delete pxyCustomsReference;
	delete pxyCustomsReference2;
	delete pxyTrackedItem;
	
	foreach proxyLink in app.myProxyManager.allReals do
		if not proxyLink.myRealObject.isKindOf(CM_CustomsReference) then
			continue;
		endif;
		
		self.assertTrueMsg(false, "Transients left over from creating proxy CM_CustomsReference" &amp; CrLf &amp; "More Info:" &amp; CrLf &amp; CM_CustomsReference::referenceNumber.name &amp; ": '" &amp; proxyLink.myProxyObject.CM_CustomsReference.referenceNumber);
		break;
		
	endforeach;
	
epilog
	delete pxyCustomsReferences;
	if realCreateCustomsReferenceDict.isNotEmpty then
		realCreateCustomsReferenceDict.clear();
	endif;
	delete realCreateCustomsReferenceDict;
	delete pxyCustomsReference;
	delete pxyCustomsReference2;
	delete pxyTrackedItem;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeletePartialRecPrenote" id="620296ab-026d-4ec5-b80f-7dc65b54dc04">
        <source>tDeletePartialRecPrenote();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2019	jlgzm1	Initial creation TFS 47865 STWO Deleteing partially received prenotes

*/
constants

	TruckIn1 		: String = "UTTRUCK10";
	TruckIn2 		: String = "UTTRUCK11";
	TruckIn3 		: String = "UTTRUCK12";
	BBULKCargoType 	: String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	CargoID			: String = "UTBB47865";
	BS				: String = "BS47865";
	BookingID		: String = "BK47865";
	VesselCodeA		: String = "VES47865";
	VoyageCodeA		: String = "VOY47865";
	PrenoteQTY		: Integer = 100;

vars
	operator 	: CM_Operator;
	shipLineStr : String;
	booking		: CM_BookingRef;
	prenote		: CM_TrackedItem;
	ti			: CM_TrackedItem;
	onsiteTI	: CM_TrackedItem;	
	tiSet		: CM_TISet;
	bs 			: CM_BlockStack;
	cargoType	: CM_CargoType;
	vessel		: CM_Vessel;
	voyage 		: CM_Voyage;
	gate 		: CM_Gate;
	vvrIn1 		: CM_VehicleVisitRecord;
	vvrIn2 		: CM_VehicleVisitRecord;
	vvrIn3 		: CM_VehicleVisitRecord;
	numTrans	: Integer;
	
begin
	// Get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "No gate not found during setup.");
	
	self.deleteTerminalArea(BS);
	bs := self.addBlockStack(BS,500,null);
	
	// Clean up from previous runs
	self.deleteVoyage(VoyageCodeA);
	self.deleteVessel(VesselCodeA);
	self.deleteVehicle( TruckIn1 );
	self.deleteVehicle( TruckIn2 );
	self.deleteVehicle( TruckIn3 );
	
	self.deleteBooking(BookingID);
	self.deleteCargo(CargoID, cargoType);
	
	// setup a voayage
	vessel := self.addVesselWithHolds(VesselCodeA, 2, 1);
	self.assertNotNullMsg(vessel, "Vessel not created during setup");
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageCodeA, VesselCodeA, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(voyage, "Voyage not created during setup");
	
	// Create a boooking
	booking := self.addBookingForGeneralCargo(BookingID, operator, voyage, voyage.allPorts.first.code, cargoType.id, PrenoteQTY);
	self.assertNotNullMsg(booking, "Booking");
	
	// Create a prenote
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first());
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("TotalQuantity", PrenoteQTY);
	prenote := self.addPrenoted(CargoID);
	self.assertNotNullMsg(prenote, "Prenote");
	self.assertEqualMsg(prenote.totalQuantity, PrenoteQTY, "prenote has wrong quantity");
	
	// gate in parts of the prenote
	self.opts.purge();
	self.opts.addAssoc("Quantity", 10);
	vvrIn1 := self.gateInPrenote( TruckIn1, null, null, prenote, gate );
	self.assertEqualMsg(vvrIn1.allReceivedTrackedItems.size(), 1, "truck 1 has " &amp; vvrIn1.allReceivedTrackedItems.size().String &amp; " tis, should have 1");
	self.assertEqualMsg(prenote.totalQuantity, PrenoteQTY-10, "prenote qty not correctly reduced");
	vvrIn2 := self.gateInPrenote( TruckIn2, null, null, prenote, gate );
	self.assertEqualMsg(vvrIn1.allReceivedTrackedItems.size(), 1, "truck 2 has " &amp; vvrIn2.allReceivedTrackedItems.size().String &amp; " tis, should have 1");
	self.assertEqualMsg(prenote.totalQuantity, PrenoteQTY-20, "prenote qty not correctly reduced");
	vvrIn3 := self.gateInPrenote( TruckIn3, null, null, prenote, gate );
	self.assertEqualMsg(vvrIn1.allReceivedTrackedItems.size(), 1, "truck 3 has " &amp; vvrIn3.allReceivedTrackedItems.size().String &amp; " tis, should have 1");
	self.assertEqualMsg(prenote.totalQuantity, PrenoteQTY-30, "prenote qty not correctly reduced");
	
	create tiSet transient;
	tiSet.add(vvrIn1.allReceivedTrackedItems.first);
	tiSet.add(vvrIn2.allReceivedTrackedItems.first);
	tiSet.add(vvrIn3.allReceivedTrackedItems.first);
	
	onsiteTI := vvrIn1.allReceivedTrackedItems.first; // cargo brought onsite first should be the real TI, all others should be merged into this
	
	foreach ti in tiSet do
		self.deleteStops(ti);
		self.unqueueTI(ti);
		self.unplanTI(ti);
		self.movePlannedWLE(ti, bs.myLocationsController, ti.allWorklistEntries.first);
		self.moveWLE(ti.allWorklistEntries.first);
	endforeach;
	self.assertEqualMsg(onsiteTI.state, TI_STATE_NORMAL, "ti should be onsite");
	self.assertEqualMsg(onsiteTI.totalQuantity, 30, "expected quantity to be sum of caro brought onsite (3 x 10 = 30)");
	numTrans := onsiteTI.allTransactions.size();
	
	// Delete the prenote
	app.myPassport.warningsAcknowledged	:= true;
	self.assertEqualMsg(prenote.state, TI_STATE_NOTIFIED, "Prenote state is not 'notified'");
	app.myTrxDA.trxDeleteTI(prenote, false, app.myPassport);
	self.assertTrueMsg(prenote &lt;&gt; null, "partially received prenote should not actually get deleted when deleted");
	self.assertEqualMsg(prenote.state, TI_STATE_MERGED, "Deleted Prenote state is not 'merged'");
	
	self.assertEqualMsg(onsiteTI.allTransactions.size(), numTrans, "onsite ti's transactions should not have been affected by deleting prenote");
	
	self.deleteVoyage(VoyageCodeA);
	self.deleteVessel(VesselCodeA);
	self.deleteVehicle( TruckIn1 );
	self.deleteVehicle( TruckIn2 );
	self.deleteVehicle( TruckIn3 );
	
	self.deleteBooking(BookingID);
	self.deleteCargo(CargoID, cargoType);
	
	self.deleteTerminalArea(BS);
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDifferentDischargePorts" id="6f08b172-191a-452c-aae2-f7ac57c6f279">
        <updating/>
        <source>tDifferentDischargePorts() updating;
// cnwdap1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2011	cnwdap1	Initial creation PAR #27100
//10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/
constants
	VoyageNameImport 	= 'VOY01TSHIP';
	VoyageNameExport 	= 'VOY02TSHIP';
	ShipNameImport 		= 'IMPSHIP';
	ShipNameExport 		= 'EXPSHIP';
	TestOperator 		= 'UTOP';
	UserDefinedTranship	= 'Unit Test Tranship';
	ContainerID1 		= "UTTR0000001";
	ContainerID2 		= "UTTR0000002";
	
vars
	voyageImport 	: CM_Voyage;
	voyageExport 	: CM_Voyage;
	vessel 			: CM_Vessel;
	pxyTI, ti		: CM_TrackedItem;
	controller		: CMIF_TranshipTIController;
	locations 		: CM_LCArray;
	ya				: CM_YardAllocation;
	location		: CM_LocationsController;
	ta				: CM_GridArea;

begin
	
	self.deleteVoyage(VoyageNameImport);
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertIsDeleted(voyageImport);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertIsDeleted(voyageExport);
	
	self.deleteVessel(ShipNameImport);
	vessel := self.getVessel(ShipNameImport);
	self.assertIsDeleted(vessel);
	
	self.deleteVessel(ShipNameExport);
	vessel := self.getVessel(ShipNameExport);
	self.assertIsDeleted(vessel);
	
	// Create import voyage
	vessel := self.addVesselCellular(ShipNameImport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add import vessel failed');

	// Note: This picks up the profile system Trade eg "Unit Test Trade"
	voyageImport := self.addVoyageWithContainerStructur(VoyageNameImport,
													ShipNameImport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageImport, 'Add import voyage failed');
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertNotNull(voyageImport);

	// Create Export voyage
	vessel := self.addVesselCellular(ShipNameExport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add export vessel failed');

	voyageExport := self.addVoyageWithContainerStructur(VoyageNameExport,
													ShipNameExport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageExport, 'Add export voyage failed');
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertNotNull(voyageExport);

	// create container on import voyage
	self.deleteContainerOnVoyage(ContainerID1, VoyageNameImport);
	
	pxyTI := self.createContainer(ContainerID1, "2010", "FOIL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameImport&amp;' 010682');
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExport;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage");
	self.assertEqualMsg(ti.myVoyage, voyageImport, "TI myVoyage reference is not the import voyage");
	
	// now plan and move the TI to the yard
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti");
	self.opts.purge();																						// 15/10/2013 cnwmh5
	self.opts.addAssoc("isForcedMove", true);																// 15/10/2013 cnwmh5
	self.move(ti, location);
	self.assertEqualMsg(ti.myPrimaryActualLocation, location, "Did not move ti");
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move off import voyage");
	self.opts.purge();																						// 15/10/2013 cnwmh5
	
	// now change the discharge port and tranship discharge port to different values and see if it fails
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTI.setDischargePort('NZWLG');
	pxyTI.setTranshipDischargePort(app.myRoot.allPorts['GRAEF']);
	
	// the update should fail here - error 86772 was returned before PAR#30419, now we check that the two discharge ports
	// are the same, or we fail then
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	//self.assertTrxError(86772);
	self.assertTrueMsg(ti.dischargePort = ti.myTranshipDetail.myDischargePort.code, "TI Discharge Port is not the same as Tranship Discharge Port");
	
epilog
	delete controller;
	delete locations;
	// Because the transaction fails, we need to delete the TI here 
	// In a successful transaction, it would be deleted when the controller was deleted
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectDelivery" id="ce7f5455-89c1-41a7-8ff5-367516b48062">
        <source>tDirectDelivery();
// cnwndl1
/*
Purpose: Check the setting of direct delivery on various cargo types			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwdw1	Initial creation
*/
vars
	ti: CM_TrackedItem;
	bs: CM_BlockStack;
begin
	// Add container for DD
	self.deleteContainer("TST1234567");
	self.opts.purge;
	self.opts.addAssoc('directDelivery', true);
	ti := self.addContainerOpts ("TST1234567", "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(ti);
	assertTrue(ti.directDelivery);
	
	// Add BB for DD
	self.deleteCargo("UTREBAR123", self.getCargoType("UTREBAR"));
	self.opts.addAssoc('totalQuantity', 10);
	self.expectTrxError(Break_bulk_canno_direc_deliver); 
	ti := self.addCargoOpts("UTREBAR123", "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType("UTREBAR").id); 
	assertNull(ti);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tDisconnectReefer" id="7f6512f4-408d-4300-8ec9-518193c8668f">
        <source>tDisconnectReefer();
/*

Purpose:	Disconnect Reefer		

Date		Who		Reason
01/04/2014	cnwma1	Initial creation
15/05/2014  cnwma1  add add Storage Days

*/

vars
	ti 					: CM_TrackedItem;
	pxyTi				: CM_TrackedItem;
	tiTxnControllerSet  : CMIF_TITxnControllerSet;
	txnController 		: CMIF_TITransactionController;
	operator			: CM_Operator;
	rtgArea     		: CM_RTGArea;
	startLC				: CM_GridController;
	connectParams		: CMIF_ConnectParams;
	loadState				: Boolean;
	tiArray : CM_TIArray;
begin


	
	
	operator := app.myRoot.allOperators["MSL"];
	
	deleteTerminalArea("UTMAREF1");
	rtgArea := self.addRTGArea("UTMAREF1", 15,5,6);
	assertNotNull(rtgArea);
	
	startLC := rtgArea.allGridControllersByRowColumn.first();
	ti := self.addContainerAtLocation("REFMA10",operator,"2231","REEF",TI_IMEX_STATUS_EXPORT,startLC);
	self.assertNotNull(ti);
		
	// Connect the container
	app.myMobileAgent.updateTIConnection(	ti, true, true, null);
	self.assertEqualMsg(ti.isConnected, true, "TI not connected");
	
	create connectParams transient;

	beginLoad;	
	pxyTi := ti.pxyCreateUpdateProxy();
	
	endLoad;

	connectParams.noCharge := false;
	connectParams.myTerminal := ti.myTerminal;
	connectParams.myTrackedItem := pxyTi;
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation; 
	endif;

	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_DISCONNECT;
	connectParams.gapController := null; 
	

	create tiTxnControllerSet transient;
    tiTxnControllerSet.add(connectParams);
	// Disconnect Reefer
	app.myTrxUA.trxUpdateDisconnectReefers(tiTxnControllerSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create tiArray transient;
	tiArray.add(ti);
	//app.myTrxUA.trxUpdateTIAddStorageDays( ti, 5, "UT Extra Days", app.myPassport);
	app.myTrxUA.trxUpdateTIAddStorageDays( tiArray, 7, "UT Extra Days", app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.additionalStorageDays,7);
epilog

	endLoad;
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge(); // proxies
		delete connectParams;
	endif;
	delete tiTxnControllerSet;
	delete pxyTi;
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEditGetNewVolumeFromStrings" id="5be0359d-d570-4523-afab-174c15a713cd">
        <source>tEditGetNewVolumeFromStrings();
/*

Date		Who		Reason
22 June 2015	cnwer1	Initial creation PAR 36422

*/

vars
	pxyTI,
	ti : CM_TrackedItem;
	e : CM_Edit;
begin
	

	ti := self.addContainer("EDIT2206151", self.getOperator("ANL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	//self.addContainer
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTI.setMyCargoVolume("5.00".Decimal);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	
	self.assertNotNull(ti.allTransactions.last);
	self.assertTrue(ti.allTransactions.last.isKindOf(CM_Edit));
	e:=ti.allTransactions.last.CM_Edit;
	self.assertEqual(e.getNewVolumeFromStrings,"5.00".Decimal);
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEditTiSubTerminal" id="91d34ba1-7fb6-4862-ba24-1831cf82ba31">
        <source>tEditTiSubTerminal();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation	Par 23991 / CCMS 1895

*/
constants

	SubTerm1Code : String = "UT_DepotA";
	SubTerm2Code : String = "UT_DepotB";
	TiId1 : String = "SUBT0001001";
	AvailGradeCode : String = "UT_AvailZ";
	ToDoTaskCode : String = "UT_ToDoZ";
	
vars

	term : CM_Terminal;
	resetSubTerm : Boolean;

	subTermProxy : CM_SubTerminal;
	subTerm1 : CM_SubTerminal;
	subTerm2 : CM_SubTerminal;
	ti1 : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	toDoTaskDesc : CM_ToDoTaskDesc;
	availGrade : CM_MTGrade;
	tiTask : CM_ToDoTask;
	selectedSubTerms : CM_SubTerminalByCodeDict;
	subTerm : CM_SubTerminal;
	error : CM_Error;
	resetSubTermAreaDefined : Boolean;
	subTerminalAreaDefined : Boolean;
	
begin
	subTerminalAreaDefined := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);

	// ensure sub terminals is turned on...
	term := self.getTerminal;
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	
/*	if not app.isSubTerminalsOn(term) then
		exclusiveLock(term);
		beginTransaction;
		term.setConfig(IsSubTerminalsOn, true);
		commitTransaction;
		resetSubTerm := true;
	endif; */
	
	self.assertTrueMsg( app.isSubTerminalsOn(term), "'" &amp; term.name &amp; "' terminal, not set up for sub terminals!");
	
	//create subTerms
	self.deleteSubTerminal( SubTerm1Code );
	self.deleteSubTerminal( SubTerm2Code );
	
	subTerm1 := addSubTerminal( SubTerm1Code, SubTermType_Depot_Int );
	subTerm2 := addSubTerminal( SubTerm2Code, SubTermType_Depot_Int );
	
	if self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined( false );	
	endif;
							
	//setup new todo task desc with all sub terms available.
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey( ToDoTaskCode );
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription( toDoTaskDesc );
		self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Unable to delete old ToDo Task Desc during set up. " &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr() );
	endif;
	toDoTaskDesc := self.createToDoTaskDesc( ToDoTaskCode );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), "Unable create ToDo Task Desc during set up. " &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr() );
	
	//setup new availability grade with all sub terms available.
	availGrade := self.createAvailabilityGrade( AvailGradeCode );
	
	//create tracked item.
	self.deleteContainer(TiId1);
	ti1 := createContainer(	TiId1,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertTrueMsg(ti1 &lt;&gt; null, "Container " &amp; TiId1 &amp; " not created!");
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.setPxyFromFieldValue(CM_EDICargoFieldUpdateTI.F_AvailabilityGrade, availGrade.code.String, null, app.myPassport);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginTransaction;
	tiTask := ti1.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	self.assertTrueMsg(tiTask &lt;&gt; null, "Task '" &amp; toDoTaskDesc.description.trimBlanks &amp; "' not created for '" &amp; TiId1 &amp; "'.");	
	
	//change the sub terminal on tracked item, ensure no error due to change of sub terminal.
	delete pxyTI;
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.zSetPxySubTerminal( subTerm1 );
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(ti1.mySubTerminal = subTerm1, "Sub Term edit 1. Sub terminal not set to  '" &amp; subTerm1.code &amp; "' on '" &amp; TiId1 &amp; "'.");
	
	//change todo task to not include subTerm2 (i.e. not allowed).
	create selectedSubTerms transient;
	foreach subTerm in term.allSubTerminals do
		if subTerm = subTerm2 then
			continue;
		endif;
		selectedSubTerms.add(subTerm);
	endforeach;
	beginTransaction;
	toDoTaskDesc.setAllAllowedEditSubTerms( selectedSubTerms );
	commitTransaction;
	
	//attempt change the sub terminal on tracked item ( to subTerm2 the not allowed one), ensure error relative to todo task occurs.
	delete pxyTI;
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.zSetPxySubTerminal( subTerm2 );
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null and error.errorCode = 86569, "Sub Term edit 2. Not the error we expected.  Got a '" &amp; error.errorCode.String &amp; "' instead of a '86569'");
	self.assertTrueMsg(error &lt;&gt; null, "Sub Term edit 2. No error raised against editing sub terminal on ti with a todo task set when sub term not selected as allowed on ToDo Description.");
	self.assertTrueMsg(ti1.mySubTerminal &lt;&gt; subTerm2, "Sub Term edit 2. Sub terminal got set to  '" &amp; subTerm2.code &amp; "' on '" &amp; TiId1 &amp; "'.");
	app.myPassport.clearErrorsWarnings;
	
	//change availability grade to not include subTerm2 (i.e. not allowed), and restore todo task.
	beginTransaction;
	toDoTaskDesc.setAllAllowedEditSubTerms( term.allSubTerminals );	// set this back to all again.
	availGrade.setAllAllowedEditSubTerms( selectedSubTerms );
	commitTransaction;
	
	//attempt change the sub terminal on tracked item ( to subTerm2 the not allowed one), ensure error relative to the availability grade occurs.
	delete pxyTI;
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.zSetPxySubTerminal( subTerm2 );
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null and error.errorCode = 86570, "Sub Term edit 3. Not the error we expected.  Got a '" &amp; error.errorCode.String &amp; "' instead of a '86570'");
	self.assertTrueMsg(error &lt;&gt; null, "Sub Term edit 3. No error raised against editing sub terminal on ti with non releasable availability grade set when sub term not selected as allowed on ToDo Description.");
	self.assertTrueMsg(ti1.mySubTerminal &lt;&gt; subTerm2, "Sub Term edit 3. Sub terminal got set to  '" &amp; subTerm2.code &amp; "' on '" &amp; TiId1 &amp; "'.");

	app.myPassport.clearErrorsWarnings;
	
	//restore availability grade.
	beginTransaction;
	availGrade.setAllAllowedEditSubTerms( term.allSubTerminals ); // set this back to all again.
	commitTransaction;
	
	//attempt change the sub terminal on tracked item ( to subTerm2 ), should be allowed now.
	delete pxyTI;
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.zSetPxySubTerminal( subTerm2 );
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(ti1.mySubTerminal = subTerm2, "Sub Term edit 4. Sub terminal not set to  '" &amp; subTerm2.code &amp; "' on '" &amp; TiId1 &amp; "'.");
	
epilog

	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( true );
	endif;

	self.setTerminalConfig(IsSubTerminalsOn, subTerminalAreaDefined);
	
	delete subTermProxy;
	delete pxyTI;
	delete selectedSubTerms;

	// delete the new tracked item
	self.deleteContainer(TiId1);
	
	// delete the new todo task
	self.deleteToDoTaskDescription( toDoTaskDesc );
	
	// delete the new availability grade
	self.deleteAvailabilityGrade( availGrade );
	
	//delete the sub terminals
	self.deleteSubTerminal( SubTerm1Code );
	self.deleteSubTerminal( SubTerm2Code );

end;</source>
    </JadeMethod>
    <JadeMethod name="tEditTransaction" id="0bb2ac06-300a-4364-9b9b-4cd63053e7a4">
        <source>tEditTransaction();
/*

Purpose:			Test that edits to transactions behave as expected

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2019	jlgzm1	Initial creation TFS 47361 Error 1310 when editing transactions

*/
constants

	ContainerId1				: String = "UTTXN000001";
	ContainerId2				: String = "UTTXN000002";
	ContainerId3				: String = "UTTXN000003";
	BlockStackId				: String = "UTBLS1";
	
vars

	container1					: CM_Container;
	container2					: CM_Container;
	container3					: CM_Container;
	operator					: CM_Operator;
	blockStack					: CM_BlockStack;
	txn1						: CM_Receive;
	txn2						: CM_TITransaction;
	orderNo1					: Integer;
	orderNo2					: Integer;
	txnController				: CMIF_TITransactionController;
	controllers 				: CM_ObjectSet;
	date						: Date;
	time						: Time;
	theDateTime					: TimeStamp;
	oldDateTime					: TimeStamp;
	idx							: Integer;
	user						: CM_User;

	
begin
	// set up any default stuff
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the container's 
	self.deleteContainer(ContainerId1);
	container1 := self.addContainerAtLocation(ContainerId1, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container1);
	
	self.deleteContainer(ContainerId2);
	container2 := self.addContainerAtLocation(ContainerId2, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container2);
	
	// TEST 1 - Vanilla update, check transaction has updated, and edit transaction created
	
	// Get transactions
	txn1 := container1.getTransReceiveFirst();
	self.assertNotNull(txn1);
	txn2 := container1.getTransactionOfType(TRANS_TYPE_MOVE);
	self.assertNotNull(txn2);
	
	create controllers transient;
	// create the proxy for the txn
	// creates the txnController as a transient, so need to delete in the epilog
	global.createTxnControllerForType(txn1.type, txnController);
	controllers.add(txnController);
	self.initTxnControllerForEdit(txnController, txn1);
	oldDateTime := txn1.dateTime;
	date := txn1.dateTime.date();
	time := txn1.dateTime.time();
	time.setTime(time.hour, time.minute, 0, 0);
	theDateTime.setDate(date);
	theDateTime.setTime(time);
	user := app.myRoot.allUsers["ADMIN"];
	txnController.dateTime:= theDateTime;
	txnController.myTrackedItem := container1;
	txnController.userId := user.code;
	app.myTrxUA.trxUpdateTITransaction(txnController, txn1, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(txn1.dateTime &lt;&gt; oldDateTime, "value has not been updated");
	self.assertEqualMsg(txn1.dateTime, theDateTime, "dateTime value has been updated incorrectly");
	self.assertEqualMsg(txn1.userId, user.code, "userID value has been updated incorrectly");
	
	global.createTxnControllerForType(txn2.type, txnController);
	controllers.add(txnController);
	self.initTxnControllerForEdit(txnController, txn2);
	
	txnController.dateTime:= theDateTime;
	txnController.myTrackedItem := container1;
	txnController.CMIF_MoveTransactionController.sourceLocn := txn2.CM_Move.sourceLocn;
	txnController.CMIF_MoveTransactionController.targetLocn := txn2.CM_Move.targetLocn;
	txnController.CMIF_MoveTransactionController.machineId := txn2.CM_Move.machineId;
	app.myTrxUA.trxUpdateTITransaction(txnController, txn2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(txn1.dateTime &lt;&gt; oldDateTime, "value has not been updated");
	self.assertEqualMsg(txn1.dateTime, theDateTime, "value has been updated incorrectly");
	
	self.assertEqualMsg(container1.getNumOfTransOfType(TRANS_TYPE_EDIT), 2, "Every edit should have an edit transaction");
	
	
	// TEST 2 - Try to replicate error from TFS 47361
	// Editing older transaction would cause its order number to increment until
	// it matched another transaction, then editing the other transaction to the same
	// dateTime of the first would cause a 1310 - duplicate key error
	
	txn1 := container2.getTransReceiveFirst();
	self.assertNotNull(txn1);
	txn2 := container2.getTransactionOfType(TRANS_TYPE_MOVE);
	self.assertNotNull(txn2);
	
	orderNo1 := txn1.orderNo;
	orderNo2 := txn2.orderNo;
	self.assertTrueMsg(orderNo2 &gt; orderNo1, "order numbers on transactions are incorrect");
	
	foreach idx in orderNo1 to orderNo2 - 1 do
		global.createTxnControllerForType(txn1.type, txnController);
		controllers.add(txnController);
		self.initTxnControllerForEdit(txnController, txn1);
		txnController.dateTime:= theDateTime;
		txnController.myTrackedItem := container2;
		app.myTrxUA.trxUpdateTITransaction(txnController, txn1, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertEqualMsg(txn1.dateTime, theDateTime, "value has been updated incorrectly");
	endforeach;
	
	
	global.createTxnControllerForType(txn2.type, txnController);
	controllers.add(txnController);
	self.initTxnControllerForEdit(txnController, txn2);
	
	txnController.dateTime:= theDateTime;
	txnController.myTrackedItem := container2;
	txnController.CMIF_MoveTransactionController.sourceLocn := txn2.CM_Move.sourceLocn;
	txnController.CMIF_MoveTransactionController.targetLocn := txn2.CM_Move.targetLocn;
	txnController.CMIF_MoveTransactionController.machineId := txn2.CM_Move.machineId;
	app.myTrxUA.trxUpdateTITransaction(txnController, txn2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(txn1.dateTime &lt;&gt; oldDateTime, "value has not been updated");
	self.assertEqualMsg(txn1.dateTime, theDateTime, "value has been updated incorrectly");
	
	// Clean up at end of test
	self.deleteContainer(ContainerId1);
	self.deleteContainer(ContainerId2);
	self.deleteContainer(ContainerId3);
	
epilog
	if controllers &lt;&gt; null then
		controllers.purge();
		delete controllers;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHSCodes" id="a3480a38-70d2-4c32-a47c-5f348d2ebd22">
        <source>tHSCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 January 2023		jlizm1	Initial creation TFS 56027 HS Code Tests

*/
constants
	SectionCode 	: String = "00";
	ChapterCode 	: String = "00";
	HeadingCode 	: String = "0000";
	HSCodeCode 		: String = "000000";
	HSCodeCode2		: String = "000001";
	SubCodeCode 	: String = "00000000";
	ContId			: String = "ZJMU2301231";
	TIID1			: String = "ZMBB2301231";
	TIID2			: String = "ZMBK2301231";
	BSTACKID		: String = 'BS54673';
	BBCargoType 	: String = "UTREBAR"; 	// Pre existing Break Bulk cargo type allows duplicates
	BULKCargoType	: String = "UTDRBULK";	// new bulk cargo type for test
	
vars
	section,
	chapter,
	heading,
	code,
	code2,
	currentHS		: CM_HarmonizedSystem;
	operator 		: CM_Operator;
	bbCargoType 	: CM_CargoType;
	bulkCargoType 	: CM_CargoType;
	cont 			: CM_Container;
	ti1				: CM_TrackedItem;
	ti2				: CM_TrackedItem;
	bs				: CM_BlockStack;
	
begin
	// Get Base Data
	self.opts.purge();
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	bulkCargoType := addCargoType(BULKCargoType, false);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBCargoType &amp; "' not found during setup.");
	
	// Clean up before starting test
	self.deleteContainer(ContId);
	self.deleteCargo(TIID1, bbCargoType);
	self.deleteCargo(TIID2, bulkCargoType);
	self.deleteHSCode(SectionCode, true); // should delete all child hs codes too
	self.deleteTerminalArea(BSTACKID);
	
	// Create codes
	section := self.addHSCode(SectionCode, "UT Section", "An HS Code section created by unit test", CM_HarmonizedSystem.HS_Section, false);
	self.assertTrueMsg(section &lt;&gt; null, "Failed to create section - " &amp; app.myPassport.getErrorsAsString());
	
	self.opts.purge();
	self.opts.addAssoc("Parent", section);
	chapter := self.addHSCode(ChapterCode, "UT Chapter", "An HS Code chapter created by unit test", CM_HarmonizedSystem.HS_Chapter, true);
	self.assertTrueMsg(chapter &lt;&gt; null, "Failed to create chapter - " &amp; app.myPassport.getErrorsAsString());
	
	self.opts.purge();
	heading := self.addHSCode(HeadingCode, "UT Heading", "An HS Code heading created by unit test", CM_HarmonizedSystem.HS_Heading, true);
	self.assertTrueMsg(heading &lt;&gt; null, "Failed to create heading - " &amp; app.myPassport.getErrorsAsString());
	
	code := self.addHSCode(HSCodeCode, "UT Code", "An HS Code code created by unit test", CM_HarmonizedSystem.HS_Code, true);
	self.assertTrueMsg(code &lt;&gt; null, "Failed to create code - " &amp; app.myPassport.getErrorsAsString());
	
	code2 := self.addHSCode(HSCodeCode2, "UT Code", "An HS Code code created by unit test", CM_HarmonizedSystem.HS_Code, true);
	self.assertTrueMsg(code &lt;&gt; null, "Failed to create code - " &amp; app.myPassport.getErrorsAsString());
	
	// Create cargo
	bs := self.addBlockStack(BSTACKID, 32, null);
	cont := self.addContainerAtLocation(ContId, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, bs);
	ti1	:= self.addCargoAtLocation(TIID1, bbCargoType, operator, bs.myLocationsController);
	ti2 := self.addCargoAtLocation(TIID2, bulkCargoType, operator, bs.myLocationsController);
	
	// check initial codes on cargo
	currentHS := cont.myHSCode;
	self.assertTrueMsg(currentHS = null, "contianer shouldn't have an hs code yet");
	currentHS := ti1.myHSCode;
	self.assertTrueMsg(currentHS = null, "TI1 shouldn't have an hs code yet");
	currentHS := ti2.myHSCode;
	self.assertTrueMsg(currentHS = null, "TI2 shouldn't have an hs code yet");
	
	// add codes to cargo
	self.opts.purge();
	self.opts.addAssoc("HSCode", HSCodeCode);
	self.updateTrackedItem(cont);
	self.updateTrackedItem(ti1);
	self.updateTrackedItem(ti2);
	
	currentHS := cont.myHSCode;
	self.assertTrueMsg(currentHS = code, "contianer should have hs code " &amp; HSCodeCode &amp; " referenced");
	currentHS := ti1.myHSCode;
	self.assertTrueMsg(currentHS = code, "TI1 should have hs code " &amp; HSCodeCode &amp; " referenced");
	currentHS := ti2.myHSCode;
	self.assertTrueMsg(currentHS = code, "TI2 should have hs code " &amp; HSCodeCode &amp; " referenced");
	
	// update codes on cargo
	self.opts.purge();
	self.opts.addAssoc("HSCode", HSCodeCode2);
	self.updateTrackedItem(cont);
	self.updateTrackedItem(ti1);
	self.updateTrackedItem(ti2);
	
	currentHS := cont.myHSCode;
	self.assertTrueMsg(currentHS = code2, "contianer should have hs code " &amp; HSCodeCode2 &amp; " referenced");
	currentHS := ti1.myHSCode;
	self.assertTrueMsg(currentHS = code2, "TI1 should have hs code " &amp; HSCodeCode2 &amp; " referenced");
	currentHS := ti2.myHSCode;
	self.assertTrueMsg(currentHS = code2, "TI2 should have hs code " &amp; HSCodeCode2 &amp; " referenced");
	
	// Clean up after ourselves
	self.deleteContainer(ContId);
	self.deleteCargo(TIID1, bbCargoType);
	self.deleteCargo(TIID2, bulkCargoType);
	self.deleteTerminalArea(BSTACKID);
	self.deleteHSCode(SectionCode, true); // should delete all child hs codes too
	self.deleteCargoType(BULKCargoType);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tHasValidId" id="453c6239-91f5-45df-a37e-c356c79a27b6">
        <source>tHasValidId();
/*
Purpose: To test the boolean value return by the method hasValidId() on the following 5 major types of CM_TrackedItem
		 1. CM_Cargo (always return TRUE because checkDigit algorithm does NOT APPLY)
		 2. CM_CargoGroup (always return TRUE because checkDigit algorithm does NOT APPLY)
		 3. CM_Container (checkDigit algorithm applied)
			case 1 - valid id ((last digit in the id matched with the algorithm))
			case 2 - invalid id (last digit in the id failed to match with the algorithm)
			case 3 - invalid id (id length is more than the maximum allowable length of an Id)
			case 4 - invalid id (Purely letters are not allowed)
			case 5 - valid id (Purely digits are allowed)
		 4. CM_Machinery (always return TRUE because checkDigit algorithm does NOT APPLY)
		 5. CM_TILC (always return TRUE because checkDigit algorithm does NOT APPLY)

Parameters:			

Return Value:		

Date		Who		TFS		Reason
20 Nov 2019	jlgdi1	47604	Initial creation
02 Jan 2025	navhl20 Task MTN-33743: MTN - 22.0.24.12 - Unit Tests Review - [3]
*/

constants
	Id_WithIn_Length : String = "OCLU0240556";
	Id_WrongLastDigit : String = "OCLU0240559";
	Id_ExceedMaxLen : String = "ZZZZ19111913";		//02.01.2025 navhl20 #33743
	Commodity_MT : String = "MT";
	Id_AllLetters : String = "ZXCASDQWERT";
	Id_AllDigits : String = "12345678910";
	
vars
	ti : CM_TrackedItem;
	container : CM_Container;
	operator : CM_Operator;
	cargo : CM_Cargo;
	cargoType : CM_CargoType;
	blockStack	: CM_BlockStack;
	
begin
	// Arrange
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// ##### CM_BreakBulk ####
	// Case : type of CM_BreakBulk - ID length is valid
	// Expected return value : True (checkDigit algorithm does not apply to CM_BreakBulk)
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
	self.deleteCargo(Id_WithIn_Length, cargoType);
	ti := self.addCargoOpts(Id_WithIn_Length, "", 'TYRE', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_BreakBulk),"Failed to create CM_BreakBulk type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WithIn_Length &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_BreakBulk]");
	self.deleteCargo(Id_WithIn_Length, cargoType);
	
	// Case : type of CM_BreakBulk - last digit in ID is wrong (based on checkDigit algorithm)
	// Expected return value : True (checkDigit algorithm does not apply to CM_BreakBulk)
	self.deleteCargo(Id_WrongLastDigit, cargoType);
	ti := self.addCargoOpts(Id_WrongLastDigit, "", 'TYRE', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_BreakBulk),"Failed to create CM_BreakBulk type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WrongLastDigit &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_BreakBulk]");
	self.deleteCargo(Id_WrongLastDigit, cargoType);

	// Case : type of CM_BreakBulk - Id exceeds maximum allowable length (greater than 11)
	// Expected return value : True (checkDigit algorithm does not apply to CM_BreakBulk)
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	ti := self.addCargoOpts(Id_ExceedMaxLen, "", 'TYRE', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_BreakBulk),"Failed to create CM_BreakBulk type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_ExceedMaxLen &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_BreakBulk]");
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
		
	// ##### CM_CargoGroup ####
	// Case : type of CM_CargoGroup - ID length is valid
	// Expected return value : True (checkDigit algorithm does not apply to CM_CargoGroup)
	cargoType := self.getCargoType("Unit Test Cargo Group");
	self.deleteCargo(Id_WithIn_Length, cargoType);
	ti := self.addCargoOpts(Id_WithIn_Length, "", '', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_CargoGroup),"Failed to create CM_CargoGroup type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WithIn_Length &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_CargoGroup]");
	self.deleteCargo(Id_WithIn_Length, cargoType);

	// Case : type of CM_CargoGroup - last digit in ID is wrong (based on checkDigit algorithm)
	// Expected return value : True (checkDigit algorithm does not apply to CM_CargoGroup)
	self.deleteCargo(Id_WrongLastDigit, cargoType);
	ti := self.addCargoOpts(Id_WrongLastDigit, "", '', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_CargoGroup),"Failed to create CM_CargoGroup type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WrongLastDigit &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_CargoGroup]");
	self.deleteCargo(Id_WrongLastDigit, cargoType);

	// Case : type of CM_CargoGroup - Id exceeds maximum allowable length (greater than 11)
	// Expected return value : True (checkDigit algorithm does not apply to CM_CargoGroup)
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	ti := self.addCargoOpts(Id_ExceedMaxLen, "", '', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_CargoGroup),"Failed to create CM_CargoGroup type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_ExceedMaxLen &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_CargoGroup]");
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	
	// ##### CM_Machinery ####
	// Case : type of CM_Machinery - ID length is valid
	// Expected return value : True (checkDigit algorithm does not apply to CM_Machinery)
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Generator];
	self.deleteCargo(Id_WithIn_Length, cargoType);
	ti := self.addCargoOpts(Id_WithIn_Length, "", 'AIRC', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Machinery),"Failed to create CM_Machinery type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WithIn_Length &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_Machinery]");
	self.deleteCargo(Id_WithIn_Length, cargoType);
	
	// Case : type of CM_Machinery - last digit in ID is wrong (based on checkDigit algorithm)
	// Expected return value : True (checkDigit algorithm does not apply to CM_Machinery)
	self.deleteCargo(Id_WrongLastDigit, cargoType);
	ti := self.addCargoOpts(Id_WrongLastDigit, "", 'AIRC', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Machinery),"Failed to create CM_Machinery type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WrongLastDigit &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_Machinery]");
	self.deleteCargo(Id_WrongLastDigit, cargoType);

	// Case : type of CM_Machinery - Id exceeds maximum allowable length (greater than 11)
	// Expected return value : True (checkDigit algorithm does not apply to CM_Machinery)
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	ti := self.addCargoOpts(Id_ExceedMaxLen, "", 'AIRC', operator, cargoType.id);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Machinery),"Failed to create CM_Machinery type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_ExceedMaxLen &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_Machinery]");
	self.deleteCargo(Id_ExceedMaxLen, cargoType);

	// ##### CM_TILC ####
	// Case : type of CM_TILC - ID length is valid
	// Expected return value : True (checkDigit algorithm does not apply to CM_TILC)
	blockStack := self.addBlockStack("UTBS", 99, null);
	self.assertNotNull(blockStack);
	
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Chassis];
	self.deleteCargo(Id_WithIn_Length, cargoType);
	ti := self.createTrackedItem(Id_WithIn_Length, cargoType.id, '', operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_TILC),"Failed to create CM_TILC type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WithIn_Length &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_TILC]");
	self.deleteCargo(Id_WithIn_Length, cargoType);
	
	// Case : type of CM_TILC - last digit in ID is wrong (based on checkDigit algorithm)
	// Expected return value : True (checkDigit algorithm does not apply to CM_TILC)
	self.deleteCargo(Id_WrongLastDigit, cargoType);
	ti := self.createTrackedItem(Id_WrongLastDigit, cargoType.id, '', operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_TILC),"Failed to create CM_TILC type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WrongLastDigit &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_TILC]");
	self.deleteCargo(Id_WrongLastDigit, cargoType);

	// Case : type of CM_TILC - Id exceeds maximum allowable length (greater than 11)
	// Expected return value : True (checkDigit algorithm does not apply to CM_TILC)
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	ti := self.createTrackedItem(Id_ExceedMaxLen, cargoType.id, '', operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_TILC),"Failed to create CM_TILC type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_ExceedMaxLen &amp; " | Id is VALID [checkDigit algorithm does not apply to CM_TILC]");
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	
	// ##### CM_Container ####
	// Case : type of CM_Container - ID length is valid
	// Expected return value : TRUE (checkDigit algorithm applies to CM_Container)
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.deleteCargo(Id_WithIn_Length, cargoType);
	ti := self.createTrackedItem(Id_WithIn_Length, TI_CargoType_Container, Commodity_MT, operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Container),"Failed to create CM_Container type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WithIn_Length &amp; " | Id is VALID");
	self.deleteCargo(Id_WithIn_Length, cargoType);
	
	// Case : type of CM_Container - last digit in ID is wrong (does not match with the checkDigit algorithm)
	// Expected return value : FALSE (checkDigit algorithm APPLIES to CM_Container)
	self.deleteCargo(Id_WrongLastDigit, cargoType);
	ti := self.createTrackedItem(Id_WrongLastDigit, TI_CargoType_Container, Commodity_MT, operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Container),"Failed to create CM_Container type");
	self.assertFalseMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_WrongLastDigit &amp; " | Id is INVALID [Last Digit in ID does not match with the algorithm]");
	self.deleteCargo(Id_WrongLastDigit, cargoType);

	// Case : type of CM_Machinery - Id length exceeds the maximum allowable length (more than 11)
	// Expected return value : FALSE (checkDigit algorithm APPLIES to CM_Container)
	self.deleteCargo(Id_ExceedMaxLen, cargoType);
	ti := self.createTrackedItem(Id_ExceedMaxLen, TI_CargoType_Container, Commodity_MT, operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Container),"Failed to create CM_Container type");
	self.assertFalseMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_ExceedMaxLen &amp; " | Id is INVALID [Id length exceeds the allowable Max Len]");
	self.deleteCargo(Id_ExceedMaxLen, cargoType);	

	// Case : type of CM_Machinery - Id contains purely letters
	// Expected return value : FALSE (checkDigit algorithm APPLIES to CM_Container)
	self.deleteCargo(Id_AllLetters, cargoType);
	ti := self.createTrackedItem(Id_AllLetters, TI_CargoType_Container, Commodity_MT, operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Container),"Failed to create CM_Container type");
	self.assertFalseMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_AllLetters &amp; " | Id is INVALID [Purely letters are not allowed]");
	self.deleteCargo(Id_AllLetters, cargoType);
	
	// Case : type of CM_Machinery - Id contains purely digits
	// Expected return value : TRUE (checkDigit algorithm APPLIES to CM_Container)
	self.deleteCargo(Id_AllDigits, cargoType);
	ti := self.createTrackedItem(Id_AllDigits, TI_CargoType_Container, Commodity_MT, operator, false, blockStack.myLocationsController);
	self.assertNotNullMsg(ti, "Failed to create tracked item");
	self.assertTrueMsg(ti.isKindOf(CM_Container),"Failed to create CM_Container type");
	self.assertTrueMsg(ti.hasValidId(), ti.cargoTypeDescr &amp; " type | ID = " &amp; Id_AllDigits &amp; " | Id is VALID [Purely digits are allowed]");
	self.deleteCargo(Id_AllDigits, cargoType);
end;</source>
    </JadeMethod>
    <JadeMethod name="tInterModalTransit" id="516b3930-2bce-44f7-97e6-2a9a2c3f443b">
        <source>tInterModalTransit();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo

*/

constants
	// Voyages/Vessels
	VesselCodeA 	: String = 'UT_HOLD_IM1';
	VoyagecodeA 	: String = 'IMHOLDVOY1';
	
	//Terminal Areas
	BlockStackID	: String = "UTBLS1";
	
	// Cargo IDs
	ContId1 		: String = "IMSS0009001";
	ContId2 		: String = "IMSS0009002";
	ContId3 		: String = "IMSS0009003";
	
vars
	operator 		: CM_Operator;
	shipLineStr 	: String;
	vesselA			: CM_Vessel;
	voyageA 		: CM_Voyage;
	holdLC 			: CM_LocationsController;
	block 			: CM_BlockStack;
	contTI1			: CM_Container;
	contTI2			: CM_Container;
	contTI3			: CM_Container;
	contCargoType 	: CM_CargoType;
	ti				: CM_TrackedItem;
	pxyTI			: CM_TrackedItem;

begin

	//##########################
	//### Get Base Data
	//##########################
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	
	//##########################
	//### Clean up old data
	//##########################
	self.deleteVoyage(VoyagecodeA);
	self.deleteVessel(VesselCodeA);
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	
	self.deleteTerminalArea(BlockStackID);
	
	//##########################
	//### Set up new data
	//##########################
	vesselA := self.addVesselWithHolds(VesselCodeA, 2, 1);
	self.assertNotNullMsg(vesselA, "Vessel A not created during setup");
	voyageA := self.addVoyageWithGeneralCargoStruc(VoyagecodeA, VesselCodeA, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(vesselA, "Voyage A not created during setup");
	
	holdLC := voyageA.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	assertNotNullMsg(holdLC, "VoyageA doesn't have any holds");
	
	// need an onsite target to create discharge job, create block stack just for planning, nothing actually needs to be moved there
	block:=self.addBlockStack(BlockStackID, 100, null);
	self.assertNotNullMsg(block, block.id);
	
	
	//##########################
	//### Create Cargo on Ship
	//##########################
	contTI1 := self.addContainerAtLocation(ContId1, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, block);
	self.assertTrueMsg(contTI1 &lt;&gt; null, "'" &amp; ContId1 &amp; "' on site import cargo not created during setup");
	
	contTI2 := self.addContainerAtLocation(ContId2, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, block);
	self.assertTrueMsg(contTI1 &lt;&gt; null, "'" &amp; ContId2 &amp; "' on site export cargo not created during setup");
	
	contTI3 := self.addContainerAtLocation(ContId3, operator, "2200", "MT", TI_IMEX_STATUS_TRANSHIP, block);
	self.assertTrueMsg(contTI1 &lt;&gt; null, "'" &amp; ContId3 &amp; "' on site tranship cargo not created during setup");

	
	//##########################
	//### Perform the test
	//##########################
	
	pxyTI := app.createUpdateProxy(contTI1).CM_TrackedItem;
	app.myTrxUA.trxUpdateTITransitStatus(pxyTI,TI_TransitStatusInterModal,app.myPassport);
	self.assertFalseMsg(app.myPassport.noErrors, "Should only be able to set Intermodal on Tranship not Import");
	delete pxyTI;
	
	self.assertNotEqualMsg(contTI1.getTransitStatus(), TI_TransitStatusInterModal, "container 1 should not have intermodal transit status");
	
	pxyTI := app.createUpdateProxy(contTI2).CM_TrackedItem;
	app.myTrxUA.trxUpdateTITransitStatus(pxyTI,TI_TransitStatusInterModal,app.myPassport);
	self.assertFalseMsg(app.myPassport.noErrors, "Should only be able to set Intermodal on Tranship not Export");
	delete pxyTI;
	
	self.assertNotEqualMsg(contTI2.getTransitStatus(), TI_TransitStatusInterModal, "container 2 should not have intermodal transit status");
	
	pxyTI := app.createUpdateProxy(contTI3).CM_TrackedItem;
	app.myTrxUA.trxUpdateTITransitStatus(pxyTI,TI_TransitStatusInterModal,app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Should be able to set Intermodal on Tranship");
	delete pxyTI;
	
	self.assertEqualMsg(contTI3.getTransitStatus(), TI_TransitStatusInterModal, "container 3 has unexpected transit status");
	
	//############################
	//### Clean up after yourself
	//############################
	self.deleteVoyage(VoyagecodeA);
	self.deleteVessel(VesselCodeA);
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	
	self.deleteTerminalArea(BlockStackID);
	
	
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMachines" id="796ae5aa-029e-4fbc-8498-3987a11ea13d">
        <source>tMachines();
/*

Purpose:		testlink test 01-149	

Date		Who		Reason
17 February 2017	cnwmk3	Initial creation
10 Mar 2023			jlika1	TFS 56923 - Add width to Trailer
*/
constants
	RMGName					= "R149";
	RMGAreaName				= "RA149";
	QueueName				= "Q149";
	RTGName					= "R150";
	RTGAreaName				= "RT150";
	ForkliftName			= "F151";
	IMVName					= "I149";
	TrailerId				= "TRAIL149";
	Cargo_Type				= "TIR";
vars
	rmgArea					: CM_TerminalArea;
	rmgMachine				: CM_Machine;
	taAccess				: StringArray;
	queue					: CM_RadioTelemetryQueue;
	rtgArea					: CM_TerminalArea;
	rtgMachine				: CM_Machine;
	forklift				: CM_Machine;
	imv						: CM_Machine;
	trailer					: CM_TILCType;
	ct						: CM_CargoType;
begin
	//  Add machines with machine type Rail Mounted Gantry and access to RMG Area

	rmgArea := self.addRMGArea(RMGAreaName, 5, 5, 5);
	self.assertNotNull(rmgArea);
	
	create taAccess transient;
	taAccess.add(rmgArea.id);
	
	queue := self.addQueueFromTA(QueueName, rmgArea.id);
	self.assertNotNull(queue);
	
	rmgMachine := self.addRMG(RMGName, 149, taAccess, queue.id);
	self.assertNotNull(rmgMachine);
	
	// Add machines with machine type Rubber Tired Gantry and access to RTG area
	self.deleteTerminalArea(RTGAreaName);
	rtgArea := self.addRTGArea(RTGAreaName, 5, 5, 5);
	self.assertNotNull(rtgArea);
	
	taAccess.clear();
	taAccess.add(rtgArea.id);
	
	queue := self.addQueueFromTA(QueueName, rtgArea.id);
	self.assertNotNull(queue);
	
	rtgMachine := self.addMachine(MACHINETYPE_RTG, RTGName, 150, taAccess, queue.id);
	self.assertNotNull(rtgArea);

	// Create ForkLift and IMV machines

	forklift := self.addForkLift(ForkliftName, 151, taAccess, queue.id);
	self.assertNotNull(forklift);
	
	imv := self.addIMV(IMVName, 152, taAccess, queue.id);
	self.assertNotNull(imv);

	// Define Machine Rules for all of these

	self.addMachineRule(rmgArea, rtgArea, RTMoveMethod_14);

	// MAFI Trailer- create, update delete
	ct	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( ct &lt;&gt; null, "No Cargo type of '" &amp; Cargo_Type &amp; "' found");
	trailer :=self.addTrailerType(TrailerId,TrailerId,ct,500,1,50,30000,13000,null,null,null);
//	self.assertNotNull(trailer);
	self.assertTrueMsg( trailer &lt;&gt; null, "No trailer '" &amp; TrailerId &amp; "' created " &amp; app.myPassport.getErrorsAndWarningsAsString);

	self.opts.addAssoc("TrailerLenght",650);
	self.updateTrailerType(trailer);
	self.assertEqual(trailer.length.asStringJMT,"650.0000");


epilog
	delete taAccess;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTIShift" id="8f844d27-8bf5-488f-89e4-74e722e0debb">
        <source>tMoveTIShift();
/*

Purpose:	Shift Tracked Item		

Date		Who		Reason
16/05/2014	cnwma1	Initial creation

*/

constants
	STADArea="S600";
	CNTR="CLHU5080";
	FRK= "F600";
	
vars
	moveController : CMIF_MoveController;
	straddleArea : CM_StraddleStack;
	ti		: CM_TrackedItem;
	swapLC,origSource, origTarget : CM_LocationsController;
	primLC, targetLC : CM_GridController;
	wh : CM_BlockStack;
	forkLift : CM_Machine;
	ta : StringArray;
begin

	self.deleteMachine(FRK);
	//deleteTerminalArea
	self.deleteTerminalArea(STADArea);
	self.deleteContainer(CNTR);
	straddleArea:= self.addStraddleStack(STADArea,11,6,2);
	self.assertNotNull(straddleArea);
	
	ti := self.addContainer(CNTR, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti);
	self.move(ti, straddleArea.allGridControllersByRowColumn[2, 1]);
	
	create moveController transient;
	
	primLC := ti.myPrimaryActualLocation.CM_GridController;
	moveController.setMoveMode(REAL_MODE);
	targetLC := primLC.getPreviousControllerOfType(CM_GridController);
	moveController.setMyTrackedItem( ti);
	moveController.setMyOriginatingLocation(primLC);

	targetLC := straddleArea.allGridControllersByRowColumn[2, 5];
	moveController.setMyToPrimaryLocation(targetLC);
	moveController.isShiftMove := true;
	moveController.setMyPassport(app.myPassport);

			
	app.myTrxUA.trxMoveTrackedItemShift(moveController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.myPrimaryActualLocation.ident,"020005");
	
	/*create ta transient;
	ta.add(straddleArea.id.asStringJMT);
	forkLift := self.addMachine(2,FRK,65,ta,null);
	self.assertNotNull(forkLift);
	*/

epilog
	delete moveController;
	delete ta;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReadyToLoadFlag" id="7e3366af-4c66-4d01-a4d3-7bf104e7df4c">
        <source>tReadyToLoadFlag();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 December 2023
TFS#		: 61650
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	ContainerId1 : String = 'UT_RTL_001';
	BlockStackId : String = "UTBLS1";
vars
	blockStack	: CM_BlockStack;
	container1	: CM_Container;
	operator	: CM_Operator;
	lastTrans	: CM_TITransaction;
	field		: String;
	oldField	: String;
	newField	: String;
begin
	// set up any default stuff
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the container's 
	self.deleteContainer(ContainerId1);
	container1 := self.addContainerAtLocation(ContainerId1, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container1);
	
	self.opts.addAssoc("ReadyToLoad",true);
	
	self.updateTI(container1);
	
	//Check modify worked correctly
	
	self.assertTrueMsg(container1.readyToLoad, "Ready To Load Flag should be True");
	self.assertTrueMsg(container1.readyToLoadManual, "Ready To Load has manually overrided should be True");
	
	lastTrans := container1.allTransactions.last;
	
	self.assertTrueMsg(lastTrans.isKindOf(CM_Edit), ContainerId1 &amp; "'s last transaction should be a CM_Edit");	
	
	lastTrans.CM_Edit.getFieldValues(1, field, oldField, newField);
	
	self.assertNotEqual(oldField, newField);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReadyToShipCheck" id="59520edd-65f5-4574-8924-a8b7c2a14aff">
        <source>tReadyToShipCheck();
// CNWMA1
// cnwjo3 - par 24146 - 13/5/2010
// check that if a TrackItem is 'ready to ship' then error message is raised.  par 24146
// cnwjo3 - 12/7/2010 - change, previously there wasn't a problem when deleting proxy objs, but now there is.
// 		When creating trackedItem with reefer details 2 proxies were being created and only 1 was being deleted
//		(because reefer details are a seperate obj now.  fix was to clear out all proxy since deleteProxy wasn't clearing child items)
// 30/11/2011	cnwmh5	Change so that doesn't rely on a carrier being there.
// 14 Nov 2019	jlgdi	47400 Added readyToShip Cargo validation check when changing cargo weight
constants
	ContainerId1	= 'UT_RTSC_1';
	VoyageId		= "UT_JO1";
vars
	testStr				: String;
	tempStr				: String;
	container			: CM_Container;
	tiRTS				: CM_TIArray;
	proxyTI				: CM_TrackedItem;
	passport 			: CM_Passport;
	newVoyage			: CM_Voyage;
	newDischargePort	: String;
	newDestinationPort	: String;
	newCarrier			: CM_Carrier;
	vessel				: CM_Vessel;
	proxyLink			: CM_ProxyLink;
	
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	
begin

	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	passport := app.myPassport;
	
	create tiRTS transient;
	
	testStr	:= ContainerId1 &amp; Space &amp; ETRow_CustomsReference;
	
	self.deleteContainer( ContainerId1 );
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container );	

	// and add the container with required values.
	self.opts.addAssoc( ETRow_CustomsReference, testStr );
	
	// and add the container with required values.
	self.opts.addAssoc( ETRow_CustomsReference, testStr );
	container	:= self.addContainerOpts(	ContainerId1,
										'2010',
										'MT',
										self.getOperator( self.getProfileSetting( UT_Profile.P_OPERATOR ).asString )).CM_Container;
	
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;	
	tiRTS.add(container);
	app.myTrxUA.trxUpdateTIsReadyToShip(tiRTS, true, passport);
	
	proxyTI := app.createUpdateProxy(container).CM_TrackedItem;

	// create the new voyage
	// 11/05/2011 cnwmh5 - Changed to use this as was using newVoyage := app.myRoot.allTerminals.last().allVoyagesByCode.last();
	// which may not return (86118) which it needs to return for a test
	deleteVoyage(VoyageId);
	deleteVessel(VoyageId);
	vessel := addVesselCellular(VoyageId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	newVoyage := addVoyageWithContainerStructur(VoyageId, VoyageId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	///newVoyage := app.myRoot.allTerminals.last().allVoyagesByCode.last();
	
	proxyTI.setMyVoyage(newVoyage,passport);
	self.assertNoTrxErrorsOrWarnings();  //no errors at this point
	app.myTrxUA.trxUpdateTrackedItem(proxyTI,'Unit Test', TI_UPDMODE_NORMAL, null, passport);
	self.assertTrxErrorMsg(ERR_READY_TO_SHIP, app.getErrorString1(ERR_READY_TO_SHIP,proxyTI.id));
	self.assertEqual(passport.allErrors.size,1);
	passport.clearErrorsWarnings();
	
	foreach proxyLink in app.myProxyManager.allReals do 
		//app.myProxyManager.deleteProxyLink(proxyTI);
		app.myProxyManager.deleteProxyLink(proxyLink.myProxyObject);
	endforeach;
	
	delete proxyTI;
	proxyTI := app.createUpdateProxy(container).CM_TrackedItem;
	
	newDischargePort := app.myRoot.allPorts.last().code;
	proxyTI.setDischargePort(newDischargePort);
	app.myTrxUA.trxUpdateTrackedItem(proxyTI,'Unit Test', TI_UPDMODE_NORMAL, null, passport);
	self.assertTrxErrorMsg(ERR_READY_TO_SHIP, app.getErrorString1(ERR_READY_TO_SHIP,proxyTI.id));
	self.assertEqual(passport.allErrors.size,1);
	passport.clearErrorsWarnings();
	
	//app.myProxyManager.deleteProxyLink(proxyTI);
	foreach proxyLink in app.myProxyManager.allReals do 
		//app.myProxyManager.deleteProxyLink(proxyTI);
		app.myProxyManager.deleteProxyLink(proxyLink.myProxyObject);
	endforeach;

	delete proxyTI;
	proxyTI := app.createUpdateProxy(container).CM_TrackedItem;
	
	newDestinationPort := app.myRoot.allPorts.last().code;
	proxyTI.setDestinationPort(newDestinationPort);
	app.myTrxUA.trxUpdateTrackedItem(proxyTI,'Unit Test', TI_UPDMODE_NORMAL, null, passport);
	self.assertTrxErrorMsg(ERR_READY_TO_SHIP, app.getErrorString1(ERR_READY_TO_SHIP,proxyTI.id));
	self.assertEqual(passport.allErrors.size,1);
	passport.clearErrorsWarnings();
	
	delete proxyTI;
	proxyTI := app.createUpdateProxy(container).CM_TrackedItem;
	
	proxyTI.setTotalWeightWithoutTrans(9000.0);
	app.myTrxUA.trxUpdateTrackedItem(proxyTI,'Unit Test', TI_UPDMODE_NORMAL, null, passport);
	self.assertTrxErrorMsg(ERR_READY_TO_SHIP, app.getErrorString1(ERR_READY_TO_SHIP,proxyTI.id));
	self.assertEqual(passport.allErrors.size,1);
	passport.clearErrorsWarnings();	
	
	foreach proxyLink in app.myProxyManager.allReals do 
		app.myProxyManager.deleteProxyLink(proxyLink.myProxyObject);
	endforeach;
	
	delete proxyTI;
	proxyTI := app.createUpdateProxy(container).CM_TrackedItem;
	
	//newCarrier := app.myRoot.allCarriers.last().code;
	create pinEmailAddresses transient;
	self.deleteCarrier("UTCAR2");
	newCarrier := self.addCarrier("UTCAR2", "Unit Test Carrier", pinEmailAddresses, false, false, true, null);
	self.assertNotNull(newCarrier);	
	
	proxyTI.setCarrier(newCarrier.code);
	app.myTrxUA.trxUpdateTrackedItem(proxyTI,'Unit Test', TI_UPDMODE_NORMAL, null, passport);
	self.assertEqual(passport.allErrors.size,0);
	passport.clearErrorsWarnings();

	foreach proxyLink in app.myProxyManager.allReals do 
		app.myProxyManager.deleteProxyLink(proxyLink.myProxyObject);
	endforeach;
	
epilog
	delete tiRTS;
	delete proxyTI;
	delete pinEmailAddresses;
end;</source>
