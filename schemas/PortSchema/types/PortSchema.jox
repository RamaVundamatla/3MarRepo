    <JadeMethod name="workOrderPermitsString" id="4c285dcb-1ac8-43f4-b371-b41a211ed36c">
        <source>workOrderPermitsString(_code : Integer):String;
/*
Purpose:			
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	if _code = INV_WO_PERMIT_MANUALETMAL then
		return app.getErrorString(STR_WO_PERMIT_METMAL);
	elseif _code = INV_WO_PERMIT_CARGOPENALTY then
		return app.getErrorString(STR_WO_PERMIT_CARPEN);
	elseif _code = INV_WO_PERMIT_CARGONOPENALTY then
		return app.getErrorString(STR_WO_PERMIT_CARNOPEN);
	elseif _code = INV_WO_PERMIT_CONTINUNOPENALTY then
		return app.getErrorString(STR_WO_PERMIT_CONNOPEN);
	elseif _code = INV_WO_PERMIT_CONTINUEPENALTY then
		return app.getErrorString(STR_WO_PERMIT_CONPEN);
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_code" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="workOrderStatusEnumToString" id="4b716271-40aa-442d-8538-a1efbcbe2d89">
        <source>workOrderStatusEnumToString(_status : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	str : String;
begin

	if _status = WO_STATUS_USERENTRY then							//01
		return app.getErrorString(WO_STATUS_USERENTRY_DESC);		//15.02.2023 navma1 #56561		
	endif;
	
	if _status = WO_STATUS_PENDING then								//02
		return app.getErrorString(WO_STATUS_PENDING_DESC);			//15.02.2023 navma1 #56561		
	endif;
	
	if _status = WO_STATUS_NOTAPPROVED then							//03		
		return app.getErrorString(WO_STATUS_NOTAPPROVED_DESC);		//15.02.2023 navma1 #56561	
	endif;	
	
	if _status = WO_STATUS_APPROVED then							//04			
		return app.getErrorString(WO_STATUS_APPROVED_DESC);			//15.02.2023 navma1 #56561	
	endif;	
	
	if _status = WO_STATUS_PARTCOMPLETE then 						//05     
		return app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC);		//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_COMPLETE then							//06
		return app.getErrorString(WO_STATUS_COMPLETE_DESC);			//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_PENDING_CANCEL then						//07
		return app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC);	//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_CANCELLED then							//08
		return app.getErrorString(WO_STATUS_CANCELLED_DESC);		//15.02.2023 navma1 #56561
	endif;
		
	if _status = WO_STATUS_PENDING_HOLD then						//09
		return app.getErrorString(WO_STATUS_PENDING_HOLD_DESC);		//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_HELD then								//10
		return app.getErrorString(WO_STATUS_HELD_DESC);				//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_PENDING_FIN then							//11      	 
		return app.getErrorString(WO_STATUS_PENDING_FIN_DESC);		//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_REJECTED_FIN then						//12      
		return app.getErrorString(WO_STATUS_REJECTED_FIN_DESC);		//15.02.2023 navma1 #56561
	endif;
	
	if _status = WO_STATUS_INAPORTNET then							//13    
		return app.getErrorString(WO_STATUS_INAPORTNET_DESC);		//15.02.2023 navma1 #56561
	endif;
		
	if _status = WO_STATUS_ACTIONED then      						//15
		return app.getErrorString(WO_STATUS_ACTIONED_DESC);			//15.02.2023 navma1 #56561
	endif;
	
	return 'Unknown';												//15.02.2023 navma1 #56561
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="workOrderStatusStringToEnum" id="ebfb15b7-01b6-49e8-b803-6686b1a82174">
        <source>workOrderStatusStringToEnum(_status:String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navma1 ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order

*/

vars

begin
	
	if _status = app.getErrorString( WO_STATUS_USERENTRY_DESC) then				//01
		return WO_STATUS_USERENTRY;											
		
	elseif _status = app.getErrorString( WO_STATUS_PENDING_DESC) then			//02
		return WO_STATUS_PENDING;		
		
	elseif _status = app.getErrorString( WO_STATUS_NOTAPPROVED_DESC) then		//03
		return WO_STATUS_NOTAPPROVED;		
	
	elseif _status = app.getErrorString( WO_STATUS_APPROVED_DESC) then			//04
		return WO_STATUS_APPROVED;
	
	elseif _status = app.getErrorString( WO_STATUS_PARTCOMPLETE_DESC) then		//05
		return WO_STATUS_PARTCOMPLETE;
	
	elseif _status = app.getErrorString( WO_STATUS_COMPLETE_DESC) then			//06
		return WO_STATUS_COMPLETE;		
	
	elseif _status = app.getErrorString( WO_STATUS_PENDING_CANCEL_DESC) then	//07
		return WO_STATUS_PENDING_CANCEL;		
	
	elseif _status = app.getErrorString( WO_STATUS_CANCELLED_DESC) then			//08
		return WO_STATUS_CANCELLED;			
	
	elseif _status = app.getErrorString( WO_STATUS_PENDING_HOLD_DESC) then		//09
		return WO_STATUS_PENDING_HOLD;
	
	elseif _status = app.getErrorString( WO_STATUS_HELD_DESC) then				//10
		return WO_STATUS_HELD;
	
	elseif _status = app.getErrorString( WO_STATUS_PENDING_FIN_DESC) then 		//11 
		return WO_STATUS_PENDING_FIN;
	
	elseif _status = app.getErrorString( WO_STATUS_REJECTED_FIN_DESC) then 		//12
		return WO_STATUS_REJECTED_FIN;
	
	elseif _status = app.getErrorString( WO_STATUS_INAPORTNET_DESC) then 		//13		
		return WO_STATUS_INAPORTNET;
	
	elseif _status = app.getErrorString( WO_STATUS_ACTIONED_DESC) then 			//15		
		return WO_STATUS_ACTIONED;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_status" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="workorderDetailTypeEnumToStr" id="c248ec3d-1eea-4c6f-b73c-30f5d44afc08">
        <source>workorderDetailTypeEnumToStr(_type  : Integer;
							 _id	: Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
22 Dec 2022 navhl20 Defect 56025[56637]: EUP - VAS Work order details type are missing from WMAST
20 Feb 2023 navma1  ChangeRequest 56637: EUP - Add VAS WorkOrder Detail Types
*/

vars
	str : String;
begin
	if _type = WorkOrderMode_Cargo then
		if _id =  WO_TASK_MOVE then					
			str := WOD_NAME_MOVE;
		elseif _id = WO_TASK_PACK then
			str := WOD_NAME_PACK;
		elseif _id = WO_TASK_UNPACK then
			str := WOD_NAME_UNPACK;
		elseif _id = WO_TASK_EXPORTRETURN then
			str := WOD_NAME_EXPORTRETURN;	
		elseif _id = WO_TASK_CHANGEVOYAGE then
			str := WOD_NAME_CHANGEVOYAGE;
		elseif _id = WO_TASK_RECEIVE then
			str := WOD_NAME_RECEIVE;
		elseif _id = WO_TASK_RELEASE then
			str := WOD_NAME_RELEASE;
		elseif _id = WO_TASK_TODO then
			str := WOD_NAME_TODO;
		elseif _id = WO_TASK_RELEASEEXTENSION then
			str := WOD_NAME_RELEASEEXT;
		endif;
	elseif _type = WorkOrderMode_Voyage then
		
		if _id = WO_TASK_SHIFTMOVEMENT then
			str := WOD_NAME_SHIFTMOVEMENT;
		elseif _id = WO_TASK_CARGOREQUEST then  //Sub
			str := WOD_NAME_CARGOREQUEST;
		elseif _id = WO_TASK_TIMECHANGE then
			str := WOD_NAME_TIMECHANGE;
		elseif _id = WO_TASK_EXTENSION then
			str := WOD_NAME_EXTENSION;	
		elseif _id = WO_TASK_WATER then
			str := WOD_NAME_WATER;
		elseif _id = WO_TASK_HMSCANCEL then
			str := WOD_NAME_HMSCANCEL;
		elseif _id = WO_TASK_NEWVOYAGE then
			str := WOD_NAME_NEWVOYAGE;
		elseif _id = WO_TASK_CARGOINITIAL then
			str := WOD_NAME_CARGOINITIAL;	
		elseif _id = WO_TASK_MARINE then       //Sub
			str := WOD_NAME_MARINE;
		elseif _id = WO_TASK_MARINEINITIAL then
			str := WOD_NAME_MARINEINITIAL;	
		elseif _id = WO_TASK_MARINEDEPART then
			str := WOD_NAME_MARINEDEPART;
		elseif _id = WO_TASK_PERMIT then
			str := WOD_NAME_PERMIT;
		elseif _id =  WO_TASK_BILLINGADJ then
			str := WOD_NAME_BILLINGADJ;
		
		endif;
		
	elseif _type = WorkOrderMode_ToDo then						//20.02.2023 navma1 #56637
		if _id = WO_TASK_ToDo_NONOPS then
			str := WOD_NAME_ToDo_NONOPS;
		elseif _id = WO_TASK_ToDo_WAGON then  //Sub
			str := WOD_NAME_ToDo_WAGON;
		elseif _id = WO_TASK_ToDo_TRAIN then
			str := WOD_NAME_ToDo_TRAIN;
		elseif _id = WO_TASK_ToDo_VOYAGE then
			str := WOD_NAME_ToDo_VOYAGE;	
		elseif _id = WO_TASK_ToDo_TRUCK then
			str := WOD_NAME_ToDo_TRUCK;
		elseif _id = WO_TASK_ToDo_VBS then
			str := WOD_NAME_ToDo_VBS;						
		endif;
	endif;														//20.02.2023 navma1 #56637
	
	return str;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_id" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeBinaryToFile" id="1aed0c25-6827-4532-8afa-dbdbb1d12fd2">
        <source>writeBinaryToFile(_header : CM_FileDataStorageHeader; _specificFolder : String) : String;

/*

Date		Who		Reason
16 Aug 2010	cnwmh5	PAR #25358 - Return actual filename when duplicate filename detected
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods

*/

constants
	IDENTIFIER = 'JMT_';
	
vars
	name,
	iniFileName,
	fileName,
	fileName2,
	filePath	: String;
	fileFolder	: FileFolder;
	file		: File;
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;
	timeStamp	: TimeStamp;

begin
	app.writeLog('Setting up file for emailing', LogINFO);
	if not  _header.allFileDataStorageDetail.size &gt; 0 then
		return null;
	endif;
	
	name := _header.fileName.doInvalidCharacterSweep();
	// Put this here rather than in invalid character sweep
	// because invalid character method is called else where
	// where commas are valid.
	name := name.cnEcRemoveSubstring(',');
	name := name.cnEcRemoveSubstring('&amp;');  //28 Jan 2020 NDL TFS 48390 Embedded ampersand causes issues with pdf file name.

	if _specificFolder &lt;&gt; null then
		filePath := _specificFolder;
	else
		filePath :=  app.getApplicationTempDirectory();
	endif;
	
	create fileFolder transient;
	fileFolder.fileName := filePath;
	
	if not fileFolder.isAvailable() then
		app.raiseCMException1(BackgroundErrorGeneral, 'File path ' &amp; fileName &amp; ' is invalid', null, null);
		return null;
	endif;

//	fileName := filePath &amp; name.doInvalidCharacterSweep();
	fileName := filePath &amp; name;
	
	create file transient;
	file.mode		:=	File.Mode_Output;
	file.shareMode	:=	File.Share_Exclusive;
	file.kind		:=	File.Kind_Binary;
	file.fileName	:= 	fileName;
	
	// Create file.
	if not file.tryOpen() then
		app.writeLog('Duplicate file name. Trying for unique ide', LogINFO);
		fileName2 := filePath &amp;  IDENTIFIER &amp; self.getInstanceIdForObject64(process).String &amp; timeStamp.Time.second.String &amp; timeStamp.Time.milliSecond.String &amp; '_' &amp; name;		
		file.fileName	:= 	fileName2;
		
		if not file.tryOpen() then
			app.raiseCMException1(BackgroundErrorGeneral, 'Could not open file ' &amp;  fileName, null, null);
			return null;
		endif;
	endif;

	foreach fileDtl in _header.allFileDataStorageDetail do
		if fileDtl.csvBlob.length() &gt; 0 then
// cnwdad1 25/02/2009 - PAR #18366.
//			tmpBin := fileDtl.csvBlob.uncompress;
			tmpBin := fileDtl.csvBlob.uncompressToBinary();
			app.writeLog('Writing ' &amp; file.fileName, LogINFO);
			file.writeBinary(tmpBin);
		endif;
	endforeach;
	
	return file.fileName;			// PAR #25358
epilog
	// Want to get different second for dup file names.
//	process.sleep(500);
	if file &lt;&gt; null then
		file.close();
	endif;
	
	delete file;
	delete fileFolder;
end;</source>
        <Parameter name="_header" type="CM_FileDataStorageHeader"/>
        <Parameter name="_specificFolder" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeCnLog" id="5a5a9f3b-d6e0-41ed-a1d4-55eec63e3641">
        <source>writeCnLog(_entryType : Integer; _msg : String);

/*


					This logging method should only be used where the error occurs BEFORE the 'initialize' during app initiation
					
					USE app.writeLog every where else.   NDL 29 NOV 2019  TFS 47053






Purpose:			Write the passed in message to the CardSchema log file

Parameters:			Entry Type (see CnCntrl::cnWriteLog for details), and message

Return Value:		None


Date		Who		Reason
03 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition


					This sucker writes to a log file called something like
					cn_cnwdmast_log_&lt;pc name&gt;_2.log
*/

vars
	cntrl			: CnCntrl;
	
begin
	cntrl := app.myCnCntrl;
	if cntrl &lt;&gt; null then
		cntrl.cnWriteLog(_entryType, _msg, null);
	endif;
	
	if app.myLoggingForm &lt;&gt; null then
		self.doFormLogging( method, _msg, null );
	endif;
	
	
epilog

end;</source>
        <Parameter name="_entryType" type="Integer"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeCurrentStack" id="fa79d390-afdb-43c1-9ec7-780aacad34a1">
        <source>writeCurrentStack();
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	callStack    : ProcessStackArray;
	methCallDesc : MethodCallDesc;

begin

	create callStack transient;
	// get the stack for the current process
	process.currentStack(callStack);
	// iterate through the process stack array and display each 
	// MethodCallDesc
	foreach methCallDesc in callStack do
	    app.writeStatement( methCallDesc.display);
	endforeach;

epilog
	// before finishing, delete the transient MethodCallDesc 
	// objects created by the currentStack method

	callStack.purge;
	delete callStack;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeFileToBinary" id="d374b73f-6248-4e4c-9f65-4d76f65b40dc">
        <source>writeFileToBinary(_filePath : String;
					_deleteFile, _isTransient : Boolean; 
					_specificFileName : String;
					_raiseException : Boolean) : CM_FileDataStorageHeader;

// cnwdvb1 20 August 2003 

vars
	file		: File;
	str,
	name		: String;
	offset,
	fileLength	: Integer;
	dataLength	: Integer;
	fileData	: Binary;
	detail		: CM_FileDataStorageDetail;
	header		: CM_FileDataStorageHeader;

begin
	create file transient;
	file.fileName					:= _filePath;
	file.mode						:=	File.Mode_Input;
	file.shareMode					:=	File.Share_ReadWrite;
	file.kind						:=	File.Kind_Binary;
	
	if not file.isAvailable() then
		if _raiseException then
			app.raiseCMException1(BackgroundErrorGeneral, 'File ' &amp; _filePath &amp; ' is unavailable', null, null);
		endif;
		return null;
	endif;

	file.open();
	if _specificFileName &lt;&gt; null then
		name := _specificFileName;
	else
		name := self.getFileName(_filePath);
	endif;
	
	if name = null then
		name := 'attachment.txt';
	endif;
	
	if _isTransient then
		create header transient;
	else
		create header persistent;
	endif;
	
	header.set(name, 0);
	fileLength	:=	file.fileLength();
	/* Commented out - need to actually send an empty file for CAMS.  See below	JC	21/06/2004
	if not fileLength &gt; 0 then
		return null;
	endif;
	*/
	dataLength	:=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;

	while offset &lt;= fileLength do
		if (fileLength - offset) &lt; dataLength then
			dataLength	:=	fileLength - offset;
		endif;
		
		if offset &lt;&gt; 0 then
			file.seek(offset);
		endif;
		
		fileData	:=	file.readBinary(dataLength);
		offset		:=	offset + fileData.length;
		
		//need this to send an empty file for CAMS.  See above JC	21/06/2004
		if fileData.length() &lt; 1 then
			fileData := CrLf.Binary;
		endif;
		
// cnwdad1 25/02/2009 - PAR #18366.
//		fileData	:=	fileData.compress();
		fileData	:=	fileData.compressToBinary(Binary.Compression_ZLib);
		
		if _isTransient then
			create detail transient;
		else
			create detail persistent;
		endif;
		
		detail.set(name, fileData, null, header);
		
		if offset &gt;= fileLength then
			break;
		endif;
	endwhile;
	
	app.writeLog('File (' &amp; _filePath &amp; ') loaded.  Size = ' &amp; fileLength.String, LogINFO);
	file.close();
epilog
	if file &lt;&gt; null and _deleteFile then
		file.purge();
	endif;
	
	delete file;
	return header;
end;</source>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_deleteFile" type="Boolean"/>
        <Parameter name="_isTransient" type="Boolean"/>
        <Parameter name="_specificFileName" type="String"/>
        <Parameter name="_raiseException" type="Boolean"/>
        <ReturnType type="CM_FileDataStorageHeader"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="dd4a6cc5-be24-4fbf-9e52-93a117d65492">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeLog(message : String; messageLevel : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Jan 2010	cnwkpd1		PAR #22185 - Fix up timestamp logging
// 08 May 2018	jlgkpd1		TFS 38556 - added clientExecution to signature
// 22 Nov 2019	NDL	TFS 47053
// ---------------------------------------------------------------------------
/*

	This writes to a log file called something like 
	
	jmterminal_&lt;pc name&gt;_ltl_&lt;number&gt;.log
	
*/
vars

	ts : TimeStamp;
	logStr : String;
	callingMethod: String;
	dateTimeStr : String;
	logLevelStr : String;
	threadId : String;

begin

	if messageLevel &gt; self.logLevel then
		return;
	endif;

	if self.myLogFile = null then
		self.initLogFile;
	endif;

	ts := app.actualTimeServer();	
	dateTimeStr :=  ts.date.format("dd-MM-yy") &amp; ' ' &amp; ts.time.format("HH:mm:ss") &amp; '.' &amp; ts.time.milliSecond.stringWithLeadingZeros(3);
	
	logLevelStr := app.getLoggingLevelString( messageLevel );
	
	threadId := app.name &amp; "/" &amp; self.cnGetInstanceId64(process).String;
			  
	logStr := dateTimeStr &amp; ' ' &amp; logLevelStr &amp; ' ' &amp; threadId &amp; ' ' &amp; message;
			  
	if app.myLoggingForm &lt;&gt; null then
		self.doFormLogging( method, logStr, logLevelStr );
	endif;

	self.myLogFile.log(logStr);
	self.log(logStr);
end;</source>
        <Parameter name="message" type="String"/>
        <Parameter name="messageLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeLogLockException" id="0bde1ce1-cf95-4cc2-8b57-257b9122bd42">
        <source>writeLogLockException(exObj : Exception);
// ---------------------------------------------------------------------------
// Created:     20 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	stack 		: HugeStringArray;
	userInfo		: String;
begin

	// notify LockKeeper that a lock exception has occurred
	create stack transient;
	app.getStackDisplayStringArray(stack, 2);

	userInfo := app.userInfoStringLockExEncode(exObj, stack);

	system.causeEvent(LockKeeper_LockEx_Event, true, userInfo);
	
epilog
	delete stack;
end;</source>
        <Parameter name="exObj" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="writeLogProcessStack" id="b8900b8f-2d33-41d3-83e3-210440e1bb2b">
        <updating/>
        <source>writeLogProcessStack() updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	pc 		: ProcessStackArray;
	md		: MethodCallDesc;
	meth	: Method;
	str		: String;
	
begin

	create pc transient;
	process.currentStack(pc);
	
	foreach md in pc do
		meth := md.method;
		str := str &amp; CrLf &amp; md.display &amp; '  (' &amp; meth.class.name &amp; ')';

	endforeach;

	self.writeLog(str , LogINFO);

epilog
	if pc &lt;&gt; null then		// PAR #18009
		pc.purge();
		delete pc;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="writeStatement" id="cafba1d6-e478-4f57-94d5-5ff17d53673e">
        <source>writeStatement(_theString : String);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	executeWhen JMTDevelopmentEnvironment;		  
		if (not app.hideDebug and app.isSpecial) then
			write _theString;
		endif;
	endExecuteWhen;
	
	if app.myLoggingForm &lt;&gt; null then
		self.doFormLogging( method , _theString, null );
	endif;
	
	self.log(_theString);
end;</source>
        <Parameter name="_theString" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeToUserLog" id="d026afc6-9611-4007-a564-d82767351fda">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeToUserLog(_log: JadeLog io; _msg : String) clientExecution, updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	t : TimeStamp;
	s : String;
	logline : String;
	
begin
	s := t.date.shortFormatJMT() &amp; " " &amp; t.time.formatAsHHmmSS() &amp; "." &amp; t.time.milliSecond.String.padLeadingZeros(3);
    logline := s &amp; " : " &amp; app.name &amp; "/" &amp; process.String &amp; ": " &amp; _msg &amp; CrLf;

	_log.log(logline);
	
	if app.myLoggingForm &lt;&gt; null then
		self.doFormLogging( method, logline, null );
	endif;
	
end;</source>
        <Parameter name="_log" type="JadeLog" usage="io"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeTransientsNow" id="d4b005d4-a1fb-4dd2-a898-679760c20363">
        <source>writeTransientsNow( _class : Class );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2011	cnwndl1	Initial creation

*/

vars

	transObjArray : ObjectArray;
	obj : Object;

begin

	if _class = null then
		write "********** No class selected for " &amp; method.qualifiedName;
		return;
	endif;

	create transObjArray transient;
	process.allTransientInstances(transObjArray, 0);
	
	write "*** Transients of class " &amp; _class.name;
	foreach obj in transObjArray do
		if obj.isKindOf(_class) then
			write obj.String;
		endif;
	endforeach;
	write "*** end. ";
	write " ";
	
epilog

	delete transObjArray;

end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="writeVoyageLog" id="c0952060-e92e-44bc-aaae-b41e0c7a5f0c">
        <source>writeVoyageLog(_voyageBased : CM_Object; _message : String);
/*
Purpose:			 // PAR 31878 - logging
Date		Who		Reason
04 July 2013	cnwab1	Initial creation
22 Nov 2019	NDL	TFS 47053
*/
constants
	VOYAGE = "VOYAGE: ";
vars
	voy : CM_Voyage;
	deckItem : CM_DeckItem;
begin
	if _voyageBased = null then
		app.writeLog(VOYAGE  &amp; _message, LogDEBUG);
		return;
	endif;
	
	voy := _voyageBased.getMyVoyageObject();
	
	if voy = null then
		app.writeLog(VOYAGE &amp;  Tab &amp; app.getMyUserCode() &amp; Tab &amp; _voyageBased.class.name &amp; Tab &amp; _voyageBased.getNiceName() &amp; Tab  &amp; _message, LogDEBUG);
		return;
	endif;
	app.writeLog(VOYAGE &amp; voy.code &amp; Tab &amp; 	app.getMyUserCode() &amp; Tab &amp; _voyageBased.class.name &amp; Tab &amp; _voyageBased.getNiceName() &amp; Tab  &amp; _message, LogDEBUG);

epilog

end;</source>
        <Parameter name="_voyageBased" type="CM_Object"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerUncompress" id="888aecb9-17ff-4f24-b115-db2ced9ea67d">
        <source>xHandlerUncompress(_exceptionObj:Exception; _isRetry:Boolean output):Integer;
// --------------------------------------------------------------------------------
// Created:		25 February 2009 by cnwdad1
//
// Purpose:		This exception handler will set a flag to indicate that the uncompress
//				failed, most likely becuase the wrong uncompress method was used, therefore
//				the code trying to uncompress a BLOB should try an alternate uncompress
//				method.
//
//				NOTE: Prior to JADE 6.3, JADE used methods called "compress", "uncompress"
//				and "uncompressString".  From JADE 6.3, these methods are replaced by
//				"compressToBinary", "uncompressToBinary" and "uncompressToString".
//
//				The two version of compression methods use difference algorithms, hence
//				a BLOB that was compressed with one version cannot be uncompressed
//				with the other version.
//
// Parameters:	_exceptionObj - A reference to the exception object.
//				_isRetry - If true, then the calling code should try uncompressing
//					with an alternate method.
//
// Returns:		A resume next code if a retry is appropriate, otherwise a pass-back code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07 Jul 2010	cnwkpd1		PAR #24906 - add additional exception code 1112, to 
//							handle the exception returned when attempting to run
//							in a 64-bit JADE environment
// --------------------------------------------------------------------------------
constants
	INVALID_FORMAT		: Integer = 1002;
	UNCOMPRESS_FAILED	: Integer = 1410;
	FEATURE_DEPRECATED	: Integer = 1112;				// PAR #24906
	
begin
	if _exceptionObj.errorCode = INVALID_FORMAT
	or _exceptionObj.errorCode = UNCOMPRESS_FAILED
	or _exceptionObj.errorCode = FEATURE_DEPRECATED
	then
		_isRetry	:=	true;
		return Ex_Resume_Next;
	else
		_isRetry	:=	false;
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_isRetry" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xmlExceptionHandler" id="bda9161e-719f-4a18-9a2d-38c926d6612e">
        <source>xmlExceptionHandler(_exception: JadeXMLException): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation PAR 31289

*/

vars
	msg	: String;
	
begin
	msg := 	" XML Error: " &amp; _exception.errorCode.String &amp; " - " &amp; _exception.extendedErrorText &amp;
			" on line " &amp; _exception.lineNumber.String &amp; CrLf &amp; CrLf &amp; _exception.errorItem;
	
	//ok to do this in the exception handler as this is only for JadeXMLExceptions				
	app.raiseCMException2(Err_XMLFile, "XML", msg, null, null);

	return Ex_Abort_Action;

epilog

end;</source>
        <Parameter name="_exception" type="JadeXMLException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xmlExceptionMsgHandler" id="fcde0ce1-6981-4a77-b6dc-88a2c3ee09f7">
        <source>xmlExceptionMsgHandler(_exception: JadeXMLException): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/02/2023 navmv20 CR 55650 Task 55702: Jade - Contracts XML Load TRX 

*/

vars
	msg	: String;
	
begin
	msg := 	app.getErrorString(Error_parsing) &amp; " "&amp; app.getErrorString(XML_Error) &amp; ": " &amp; _exception.errorCode.String &amp; " - " &amp; _exception.extendedErrorText &amp;
			" on line " &amp; _exception.lineNumber.String &amp; CrLf &amp; CrLf &amp; _exception.errorItem;
	
	app.msgBox(msg, app.getErrorString(XML_Error),MsgBox_OK_Only + MsgBox_Information_Icon);

	return Ex_Abort_Action;

epilog

end;</source>
        <Parameter name="_exception" type="JadeXMLException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="yaExpiryFlagToString" id="caed2a2f-087d-4f1f-99b0-697b88df0ba3">
        <source>yaExpiryFlagToString(_expiryFlag:Integer):String;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 08/04/2021	navdap1		TFS 50946 PRP Auto Delete of Yard Allocations
begin
	if _expiryFlag = YAExpiryType_Never then
		return "Never" ;
	elseif _expiryFlag = YAExpiryType_VoyageDepart then
		return "Voyage Depart";
		
	//29 Jun 2011	NDL	Par 27786
	elseif _expiryFlag = YAExpiryType_VoyageClear then
		return "Voyage Clear";
		
	elseif _expiryFlag = YAExpiryType_WhenEmpty then
		return "When Empty";
	elseif _expiryFlag = YAExpiryType_SpecifiedDate then
		return "Specified Date";
	elseif _expiryFlag = YAExpiryType_NoCargo then				// TFS 50946
		return "No Matching Cargo";								// TFS 50946
	endif;
end;</source>
        <Parameter name="_expiryFlag" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="yaFillOptionToInteger" id="4ecc7391-1446-42c6-beed-aee3dee417af">
        <source>yaFillOptionToInteger(pFillOption:String):Integer;
// --------------------------------------------------------------------------------
// Created:		10 March 2005 by cnwdad1
//
// Purpose:		Converts a Yard Allocation Fill Option global constant String value
//				to the corresponding constant's Integer value.
