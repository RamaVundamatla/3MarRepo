    <JadeMethod name="xCheckGCDCorrect2" id="67f56aff-9285-4367-912e-1bf6d3e57e9e">
        <source>xCheckGCDCorrect2(_mode, _modeView : Integer; _deck : CM_DeckVoyage; _failedArray : HugeStringArray io);

/*

Purpose:		Check that the details from getCargoDetails is correct

Date			Who		Reason
07/09/2012		cnwmh5	Initial creation

*/

vars

	locnDefnVoyage 				: CM_ROROLocnDefnVoyage;
	job 						: CM_VoyageJob;
	aReq 						: CM_RORORequest;
	slotDefn 					: CM_ROROSlotDefn;
	slotLC 						: CM_ROROSlotController;

	locationArray				: StringArray;
	statusArray					: HugeStringArray;
	
	detailsToCheck				: String;
	detailsToCheckFromMethod	: String;
	locationStr					: String;
	mode						: String;
	index 						: Integer;
	modeWritten					: Boolean;

begin

	create statusArray transient;
	create locationArray transient;
	
	// setup the locations and details we are expecting
	if _mode = ShpDisplayMode_Actual then
		if _modeView = ShpDisplayMode_ColCodeDisch then
			mode := "Dischage";
			locationArray.clear();
			locationArray.add("D4108");
			statusArray.add("D4108 D4108 |  Fwd: D4113 | 1 x CONT NZPOE  U20G | UTMDHYB0001");
			locationArray.add("D4113");
			statusArray.add("D4113 D4113 | Aft: D4108 Fwd: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0002");
			locationArray.add("D4098");
			statusArray.add("D4098 D4098 | Aft: D4113 Fwd: D4103 | 1 x CONT NZPOE  U20G | UTMDHYB0004");
			locationArray.add("D4103");
			statusArray.add("D4103 D4103 | Aft: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0003");
			locationArray.add("D4099");
			statusArray.add("D4099 D4099 | Aft: D4114 Fwd: D4104 | 1 x CONT NZPOE  U40G | UTMDHYB0011");
			locationArray.add("D4115");
			statusArray.add("D4115 D4115 | Aft: D4110 Fwd: D4100 | 1 x CONT NZPOE  U20G | UTMDHYB0006");
			locationArray.add("D4105");
			statusArray.add("D4105 D4105 | Aft: D4100 | 1 x CONT NZPOE  U40G | UTMDHYB0012");
			locationArray.add("D4106");
			statusArray.add("D4106 D4106 | Aft: D4101 | 1 x CONT NZPOE  U40G | UTMDHYB0013");
			locationArray.add("D4118");
			statusArray.add("D4118 D4118 |  Fwd: D4119 | 1 x CONT NZPOE  U20G | UTMDHYB0008");
			locationArray.add("D4119");
			statusArray.add("D4119 D4119 | Aft: D4118 Fwd: D4120 | 1 x CONT NZPOE  U20G | UTMDHYB0007");
			locationArray.add("D4121");
			statusArray.add("D4121 D4121 | Aft: D4120 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYB0010, UTMDHYB0014, UTMDHYB0009");
		else
			mode := "Actual";
			locationArray.clear();
			locationArray.add("D4108");
			statusArray.add("D4108 |  Fwd: D4113 | 1 x CONT NZPOE  U20G | UTMDHYB0001");
			locationArray.add("D4113");
			statusArray.add("D4113 | Aft: D4108 Fwd: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0002");
			locationArray.add("D4098");
			statusArray.add("D4098 | Aft: D4113 Fwd: D4103 | 1 x CONT NZPOE  U20G | UTMDHYB0004");
			locationArray.add("D4103");
			statusArray.add("D4103 | Aft: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0003");
			locationArray.add("D4099");
			statusArray.add("D4099 | Aft: D4114 Fwd: D4104 | 1 x CONT NZPOE  U40G | UTMDHYB0011");
			locationArray.add("D4115");
			statusArray.add("D4115 | Aft: D4110 Fwd: D4100 | 1 x CONT NZPOE  U20G | UTMDHYB0006");
			locationArray.add("D4105");
			statusArray.add("D4105 | Aft: D4100 | 1 x CONT NZPOE  U40G | UTMDHYB0012");
			locationArray.add("D4106");
			statusArray.add("D4106 | Aft: D4101 | 1 x CONT NZPOE  U40G | UTMDHYB0013");
			locationArray.add("D4118");
			statusArray.add("D4118 |  Fwd: D4119 | 1 x CONT NZPOE  U20G | UTMDHYB0008");
			locationArray.add("D4119");
			statusArray.add("D4119 | Aft: D4118 Fwd: D4120 | 1 x CONT NZPOE  U20G | UTMDHYB0007");
			locationArray.add("D4121");
			statusArray.add("D4121 | Aft: D4120 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYB0010, UTMDHYB0014, UTMDHYB0009");
		endif;
	elseif _mode = ShpDisplayMode_Proposed then
		if _modeView = ShpDisplayMode_ColCodeLoad then
			mode := "Load";
			locationArray.clear();
			locationArray.add("D4108");
			statusArray.add("D4108 D4108 |  Fwd: D4113 | 1 x CONT NZPOE  U20G | UTMDHYB0001");
			locationArray.add("D4113");
			statusArray.add("D4113 D4113 | Aft: D4108 Fwd: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0002");
			locationArray.add("D4098");
			statusArray.add("D4098 D4098 | Aft: D4113 Fwd: D4103 | 1 x CONT NZPOE  U20G | UTMDHYB0004");
			locationArray.add("D4103");
			statusArray.add("D4103 D4103 | Aft: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0003");
			locationArray.add("D4099");
			statusArray.add("D4099 D4099 | Aft: D4114 Fwd: D4104 | 1 x CONT NZPOE  U40G | UTMDHYB0011");
			locationArray.add("D4115");
			statusArray.add("D4115 D4115 | Aft: D4110 Fwd: D4100 | 1 x CONT NZPOE  U20G | UTMDHYB0006");
			locationArray.add("D4105");
			statusArray.add("D4105 D4105 | Aft: D4100 | 1 x CONT NZPOE  U40G | UTMDHYB0012");
			locationArray.add("D4106");
			statusArray.add("D4106 D4106 | Aft: D4101 | 1 x CONT NZPOE  U40G | UTMDHYB0013");
			locationArray.add("D4118");
			statusArray.add("D4118 D4118 |  Fwd: D4119 | 1 x CONT NZPOE  U20G | UTMDHYB0008");
			locationArray.add("D4119");
			statusArray.add("D4119 D4119 | Aft: D4118 Fwd: D4120 | 1 x CONT NZPOE  U20G | UTMDHYB0007");
			locationArray.add("D4121");
			statusArray.add("D4121 D4121 | Aft: D4120 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYB0010, UTMDHYB0014, UTMDHYB0009");
		else
			mode := "Proposed";
			locationArray.clear();
			locationArray.add("D4108");
			statusArray.add("D4108 |  Fwd: D4113 | 1 x CONT NZPOE  U20G | UTMDHYB0001");
			locationArray.add("D4113");
			statusArray.add("D4113 | Aft: D4108 Fwd: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0002");
			locationArray.add("D4098");
			statusArray.add("D4098 | Aft: D4113 Fwd: D4103 | 1 x CONT NZPOE  U20G | UTMDHYB0004");
			locationArray.add("D4103");
			statusArray.add("D4103 | Aft: D4098 | 1 x CONT NZPOE  U20G | UTMDHYB0003");
			locationArray.add("D4099");
			statusArray.add("D4099 | Aft: D4114 Fwd: D4104 | 1 x CONT NZPOE  U40G | UTMDHYB0011");
			locationArray.add("D4115");
			statusArray.add("D4115 | Aft: D4110 Fwd: D4100 | 1 x CONT NZPOE  U20G | UTMDHYB0006");
			locationArray.add("D4105");
			statusArray.add("D4105 | Aft: D4100 | 1 x CONT NZPOE  U40G | UTMDHYB0012");
			locationArray.add("D4106");
			statusArray.add("D4106 | Aft: D4101 | 1 x CONT NZPOE  U40G | UTMDHYB0013");
			locationArray.add("D4118");
			statusArray.add("D4118 |  Fwd: D4119 | 1 x CONT NZPOE  U20G | UTMDHYB0008");
			locationArray.add("D4119");
			statusArray.add("D4119 | Aft: D4118 Fwd: D4120 | 1 x CONT NZPOE  U20G | UTMDHYB0007");
			locationArray.add("D4121");
			statusArray.add("D4121 | Aft: D4120 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYB0010, UTMDHYB0014, UTMDHYB0009");
		endif;
	endif;
	
	
	
	// time to check the details
	index := 1;
	foreach index in 1 to locationArray.size do
		job := null;
		aReq := null;
		locnDefnVoyage := _deck.allROROLocnDefnByCode[locationArray[index]].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		detailsToCheck := statusArray[index];
		detailsToCheckFromMethod := locnDefnVoyage.getCargoDetails(_mode, _modeView, ShpDisplayModeSub_ExportsHide);
		if _modeView = ShpDisplayMode_ColCodeLoad or _modeView = ShpDisplayMode_ColCodeDisch then
			detailsToCheckFromMethod := locnDefnVoyage.code &amp; " " &amp; detailsToCheckFromMethod;
		endif;
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if _modeView = ShpDisplayMode_ColCodeLoad then
				aReq := slotLC.myRORORequestLoad;
				if aReq &lt;&gt; null then
					job := aReq.myJob.CM_VoyageJob;
					break;
				endif;
			elseif _modeView = ShpDisplayMode_ColCodeDisch then
				aReq := slotLC.myRORORequestDischarge ;
				if aReq &lt;&gt; null then
					job := aReq.myJob.CM_VoyageJob;
					break;
				endif;
			endif;
			
		endforeach;
		if job &lt;&gt; null then
			detailsToCheckFromMethod := detailsToCheckFromMethod &amp; " " &amp; app.getErrorString(Job) &amp; ": " &amp; job.jobNum;
		endif;
		
		//cnwmc5 - added the below for statement for new error checking
		if detailsToCheckFromMethod &lt;&gt; detailsToCheck then
			if not modeWritten then
				_failedArray.add(mode);
				modeWritten := true;
			endif;
			_failedArray.add("Actual:    " &amp; detailsToCheckFromMethod);
			_failedArray.add("Expected:  " &amp; detailsToCheck);
		endif;
	endforeach;
	
epilog

	delete locationArray;
	delete statusArray;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_failedArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
