    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="9158bfad-753d-47b6-868f-332cc1ba0e38">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "TOL Discharge List";
	self.type	:= EDIFileType_CSVTOL;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="7e034cba-78cb-4e26-b775-4d7b1a075e8c">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
// ---------------------------------------------------------------------------
// Created:		30 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	_ediDataClass := CM_EDIDataBayPlan;
	_dataType := EDIDataType_BayPlan;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="0ccecc65-2551-448c-b610-35a67a350455">
        <source>getCommodity(_code: String; _temperature :Real): String;
//----------------------------------------------------------------
//	Created:	17 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - COMMODITY XLATIONS
vars
	sysCode		: String;
	operator	: CM_Operator;
	foundMatch	: Boolean;
begin
	operator := self.getMyOperator();	// TOL
	
	if operator &lt;&gt; null then
		sysCode := operator.getXlationSystemCode_Commodity(_code[1:30].trimBlanks(), foundMatch, _temperature)[1:4];
	else
		sysCode := _code[1:4];
	endif;
	
	return sysCode;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_temperature" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="7b9557c0-8e4e-4223-880b-446d1a1ad4ed">
        <source>getMyOperator(): CM_Operator;
// ---------------------------------------------------------------------------
// Created:		30 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	return app.myRoot.allOperators["TOL"];
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getTIInfo" id="233d738c-1974-4e66-9397-a7f227724662">
        <source>getTIInfo(_record: String;  _tiInfo: StringArray input);
//-------------------------------------------------------------------
//	See super class
//	Expecting a csv record with 9 fields:
//	BOL#, CargoID, ISOType, Discharge Port, Commod, Weight, Seal Number, Remarks, Empty(null = full)

vars
	mtStr	: String;
begin
	inheritMethod(_record, _tiInfo);
	

	while _tiInfo.size &lt; 9 do
		_tiInfo.add("");
	endwhile;
	
	mtStr := _tiInfo[9].trimBlanks;

	
	//translate empty field - tends to be some bizare character
	if mtStr.length &gt; 0 and mtStr[1].Character.isPrintable then
		_tiInfo[9] := "E";
	else
		_tiInfo[9] := "F";
	endif;
	
end;</source>
        <Parameter name="_record" type="String"/>
        <Parameter name="_tiInfo" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasValidTI" id="49d24f3b-64de-45e3-9138-0d42d687166f">
        <source>hasValidTI(_record: String): Boolean;
// check for a container number and ISO type and ...
vars
	field,
	length,
	endPos,
	startPos	: Integer;
	id,
	isoType,
	value,
	strRec		: String;
begin
	strRec := _record;
	
	startPos := 1;
	endPos := 1;
	
	field := 1;
	// look at the second and third fields  (ID and ISO)
	while field &lt; 4 do
		endPos := strRec.pos("," , startPos) - 1;
		if endPos &gt; startPos then
			length := (endPos+1)- startPos;	
			
			value := strRec[startPos:length];
			if field = 2 then
				id := value;
			elseif field = 3 then
				isoType := value;
			endif;
		
		endif;
		startPos := endPos + 2;
		field := field + 1;
	endwhile;	

	if id.trimBlanks.length &gt; 3 and id.trimBlanks.length &lt;= 11 and isoType.trimBlanks.length = 4 then
		return true;
	endif;

	return false;
	
end;</source>
        <Parameter name="_record" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isIgnoredValue" id="acad817d-7ac8-4c3b-8477-748f73179180">
        <source>isIgnoredValue(_strValue: String): Boolean;
// ---------------------------------------------------------------------------
// Created:		30 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if _strValue = "-" then
		return true;
	elseif _strValue = "_" then
		return true;
	else
		return inheritMethod(_strValue);
	endif;
	
end;</source>
        <Parameter name="_strValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="0f44ea1d-ef3d-43d7-be38-f7d3aae0d3b0">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	infoTI					: StringArray;
	container				: CM_EDIBayPlanTI;
	ediDataBayPlan			: CM_EDIDataBayPlan;
	message					: String;
	int						: Integer;
	generatedContainerNo	: Integer;
	group					: Integer;
	mtCmdty					: String;
	defCmdty				: String;
	refCmdty				: String;
	hazCmdty				: String;
	portDestCode			: String;
	pISOType 				: CM_ISOType;
	operator				: CM_Operator;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	terminal				: CM_Terminal;
	fileCmdty				: String;
//	binaryLine				: Binary;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	
	app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	
	portDestCode 	:= terminal.getConfig(PortDestCode).String;	
	ediDataBayPlan 	:= _ediFile.ediData.CM_EDIDataBayPlan;
	
	ediDataBayPlan.loadRecordsForPort := 0;

	create infoTI transient;

	ediDataBayPlan.operatorCode := self.getMyOperator().code;
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		int := int + 1;
		
		//infoTI := longString.string.cnGetTokens(","); //not perfect, now:
		self.getTIInfo(message, infoTI);
		
		create container persistent;
		container.setForCreateNew(ediDataBayPlan);
		
		container.operatorCode 	:= "TOL";	
		container.locationId 	:= "";		
		container.bol 			:= infoTI[1];
		container.setId(infoTI[2]);
		
		container.setISOType(infoTI[3], self.getMyOperator);
		
		container.dischargePort 	:= portDestCode;
		fileCmdty 					:= infoTI[5].trimBlanks;
		container.weight 			:= infoTI[6].Decimal; //cnwrd1 ccms 1060 12.1.09
		container.sealNum 			:= infoTI[7];
		container.remarks 			:= infoTI[8];
		container.fullOrMT 			:= infoTI[9];
		container.destinationPort 	:= portDestCode;
		container.temperature 		:= NULL_TEMPERATURE;
		container.exportImport 		:= "I";
		
		if container.id = null then // if the last container has no id
			self.addFileErrors("Container has no id, using generated number" &amp; Tab &amp; group.String &amp; Tab &amp; message, msgCount, _ediFile);
			generatedContainerNo 	:= generatedContainerNo + 1;
			container.setIdDefault(generatedContainerNo.String);
		endif;
		
		operator := app.myRoot.allOperators[container.operatorCode];

		ediDataBayPlan.loadRecordsForPort := ediDataBayPlan.loadRecordsForPort + 1;

		if container.weight &lt; 100 then
			//probably in tonnes
			container.weight := (container.weight * 1000);
		endif;
		//FD the bay file should handle different cargo types based on isoType;

		pISOType := app.myRoot.allISOTypes[container.isoType];

		if(pISOType &lt;&gt; null) then
			container.setCargoType(pISOType.myCargoType.id);
		else
			container.setCargoType(TI_CargoType_Container);
		endif;
		
		// PAR 31259 - COMMODITY XLATION NEES TO BE DONE AFTER TEMPERTURE SET.
		container.commodityDescription := fileCmdty[1:30];
		
		if container.fullOrMT = "E" then
			container.commodity := mtCmdty;
		elseif fileCmdty &lt;&gt; null and operator &lt;&gt; null then
			container.commodity := self.getCommodity(fileCmdty, container.temperature);
		else
			if container.temperature = NULL_TEMPERATURE then
				container.commodity := defCmdty;
			else
				container.commodity := refCmdty;
			endif;
		endif;
		//anything else?
	endforeach;
epilog
	delete theLines;
	delete infoTI;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
