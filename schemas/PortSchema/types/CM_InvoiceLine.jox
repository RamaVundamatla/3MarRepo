    <JadeMethod name="getGLCode" id="c51b5cd1-6380-47d7-86b8-5c57632fa091">
        <source>getGLCode(): CM_GLCode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/07/2018  cnwma1	ChangeRequest 38633: PEL1 - SAP Send Invoice and Associated Data Interfaces

*/

vars
	gLCode : CM_GLCode;
	iter : Iterator;
	charge : CM_Charge;
	service : CM_Service; 
begin
	iter := self.charges.createIterator;
	while iter.next( charge ) do
		service := charge.service;
		if service = null then
			continue;
		endif;
		gLCode := service.genLCode;
		if gLCode &lt;&gt; null then
			break;
		endif;
	endwhile;
	
	return gLCode;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_GLCode"/>
    </JadeMethod>
    <JadeMethod name="getGLCodesString" id="01cc00b4-14c9-4507-8fc7-7a412617397e">
        <source>getGLCodesString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation

*/

vars

	strArray : StringArray;
	iter : Iterator;
	charge : CM_Charge;
	service : CM_Service; 
	glCode : CM_GLCode;
	glCodeStr : String;
	allGlCodes : String;

begin

	create strArray transient;
	iter := self.charges.createIterator;
	while iter.next( charge ) do
		service := charge.service;
		if service = null then
			continue;
		endif;
		glCode := service.genLCode;
		if glCode = null then
			continue;
		endif;
		glCodeStr := glCode.code;
		if strArray.includes(glCodeStr) then
			continue;
		endif;
		strArray.add( glCodeStr );
	endwhile;
	
	if strArray.isEmpty then
		return null;
	endif;
	
	foreach glCodeStr in strArray do
		if allGlCodes &lt;&gt; null then
			allGlCodes := allGlCodes &amp; ", ";
		endif;
		allGlCodes := allGlCodes &amp; glCodeStr;
	endforeach;
	
	return allGlCodes;

epilog

	delete iter;
	delete strArray;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHarbourResourceType" id="8d6954a1-083c-4d94-adad-0cf5d0434fba">
        <source>getHarbourResourceType():String;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#		Description
==========================================================================
14 May 2014	cnwndl1	Par 34142	Initial creation	
28/09/2018	jlgka1	40200		Change return value from description to code.
//----------------------------------------------------------------------*/


vars
	trans 	: HMS_VTMISTransaction;
	resType : HMS_ResourceType;
begin
	trans := self.myTransactionHMS;
	if trans = null or trans.myResourceUsed = null then
		return null;
	endif;
	
	resType := trans.myResourceUsed.myResourceType;
	if resType = null then
		return null;
	endif;
	
	return resType.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
