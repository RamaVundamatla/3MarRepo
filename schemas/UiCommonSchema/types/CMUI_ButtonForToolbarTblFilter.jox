    <JadeMethod name="click" id="da6037c9-b09b-4efb-99af-3f8453e5553f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	
	if self.parentControl &lt;&gt; null then
		if self.parentControl.isKindOf(CMUI_ToolbarFrameTableFilter) then
			self.parentControl.CMUI_ToolbarFrameTableFilter.doClearFilter();
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enabled" id="774892de-58ef-4e18-9158-3f08c7c5e7fc">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>enabled(set: Boolean; value: Boolean io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/
vars
	btn	: CMUI_ToolbarButtonTblFilter;

begin
    
	inheritMethod(set, value);
	
	
	btn := self.myToolbarButtonTblFilter;

	if set and btn &lt;&gt; null then
		if btn.enabled &lt;&gt; value then
			btn.enabled := value;
			if (not value) then
				btn.clearGraphics();
			endif;
			if self.fontCharacter &lt;&gt; null then
					// need to force a redraw of the character
					btn.drawCharacter(self.fontName, self.fontCharacter.Character, self.fontColour);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
