    <JadeMethod name="setupThumbnailDetails" id="8757108b-d9f4-4ffb-9449-60235b43ec81">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_VoyageProcessDetail);
	form.shtTblInput1.caption := app.getErrorString(Details);
	form.initTblInput(form.tblInput1, ETDef_VoyageProcessThumb);
	form.shtTblInput1.visible := true;
epilog

end;</source>
