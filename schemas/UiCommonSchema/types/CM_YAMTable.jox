    <JadeMethod name="click" id="f0275c0c-ed2e-4566-8ff3-6410b11d5b4c">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		1 February 2009 by cnwjo3
//
// Purpose:		this method is used only for expanding YAs
//
vars
	obj: Object;
	expandColumn: Integer;
begin
	expandColumn := self.getColumnByRowName(ETRow_HideShow);

	if table.column = expandColumn then
		if table.row = 1 then
			self.selectAllYA();					//+cnwml2 PAR25701
		elseif table.row = 2 then
			//do nothing
		else
						
			obj := table.accessRow(table.row).itemObject;
			if obj.isKindOf(CM_YardAllocation) then
				if table.column = 1 then
					self.expandYALocations(obj.CM_YardAllocation, not self.isYAExpanded());
					inheritMethod(table);
				endif;
			endif;
			
		endif;
	endif;
	
	inheritMethod(table);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="a1dee358-438a-492b-85b3-e45d86490484">
