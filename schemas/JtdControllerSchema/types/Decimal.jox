<PrimType name="Decimal">
    <JadeMethod name="asKilobytes" id="69671f46-ebdb-47e0-8599-729e0f036d26">
        <source>asKilobytes() : Real;

constants
	BytesPerKilobyte = 1024;
	
begin
	return self / BytesPerKilobyte;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asMegabytes" id="a2dcc0e9-d81c-45bd-b301-3c3f51613314">
        <source>asMegabytes() : Real;

constants
	BytesPerMegabyte = 1048576;
	
begin
	return self / BytesPerMegabyte;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
