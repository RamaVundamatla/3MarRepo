        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBay_dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin


//self.frmScrollBackgrd.dragOver(self.frmScrollBackgrd, win, self.left + x, self.top + y, state);
//self.frmScrollable.dragOver(self.frmScrollable, win, self.left + x, self.top + y, state);
	if self.workingMode = WorkMode_Plan
	or self.displayMode = ShpDisplayMode_Actual
	then
		if app.myMoveController &lt;&gt; null then
			self.setFocus();
			self.zOrder(1);
			self.windowState := WindowState_Normal;
		endif;	
	endif;
end;</source>
