    <JadeMethod name="canBeDeleted" id="0f304696-1348-467b-98c9-fdd24a6d569d">
        <source>canBeDeleted() : Boolean;
/*

Date		Who		Reason
03 December 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myEventType = null then
		return true;
	endif;
	
	if  self.myEventType.isSystemEventType then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
