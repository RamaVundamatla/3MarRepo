    <JadeMethod name="cnEcDoOpenConnection" id="b016e16d-ef20-4fc4-ad7b-77095189e2e0">
        <updating/>
        <source>cnEcDoOpenConnection(pServerName:String; pPortNumber:Integer; pFillReadBuffer:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Opens the TcpIp connection.
//
// Parameters:	pServerName - The URL of the Web Server.
//				pPortNumber - The Web Server's ort number (typically "80").
//				pFillReadBuffer - Iindicates whether to wait for the requested
//				 buffer length before notifying of a receipt (to a readBinary[Asynch].
//
// Returns:		A flag to indicate the success of the connection to the remote device.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hasSucceeded	: Boolean;

begin
	hasSucceeded		:=	false;

	self.name			:=	pServerName;
	self.port			:=	pPortNumber;
	self.fillReadBuffer	:=	pFillReadBuffer;
	self.open();

	hasSucceeded	:=	true;
epilog
	return hasSucceeded;
end;</source>
        <access>protected</access>
        <Parameter name="pServerName" type="String"/>
        <Parameter name="pPortNumber" type="Integer"/>
        <Parameter name="pFillReadBuffer" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoReadAsynchBuffer" id="786b6dca-f499-41c5-a25a-ea63bbc251a2">
        <updating/>
        <source>cnEcDoReadAsynchBuffer(	pBufferLength:Integer;
						pTheReceiver:Object;
						pCallBackMethodName:String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Reads a chunk of binary data from the read buffer.
//
// Parameters:	pBufferLength - The length of data to read.
//				pTheReceiver - The receiver of the callback method (self in this case).
//				pCallBackMethodName - The method to call when the chunk of binary
//				 data from the read buffer is received.
//
// Returns:		A flag to indicate whether the read was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hasSucceeded	: Boolean;

begin
	hasSucceeded	:=	false;
	self.readBinaryAsynch(pBufferLength, pTheReceiver, pCallBackMethodName);
	hasSucceeded	:=	true;
epilog
	return hasSucceeded;
end;</source>
        <access>protected</access>
        <Parameter name="pBufferLength" type="Integer"/>
        <Parameter name="pTheReceiver" type="Object"/>
        <Parameter name="pCallBackMethodName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoReadCallBack" id="3c9028f4-adea-4f41-b6a4-0385d029fd06">
        <updating/>
        <source>cnEcDoReadCallBack(pTcpConnectionObj:TcpIpConnection; pBuffer:Binary) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2000 by cnwdad1
//
// Purpose:		This is the callback method that is invoked when some data is received
//				from the read buffer as a result of the "readBinaryAsynch" request.
//
// Parameters:	pTcpConnectionObj - The TcpIp connection instance.
//				pBuffer - The binary data that was received from the read buffer.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/09/2000	cnwdad1		Changed to convert the buffer contents from ANSI to
//							Unicode if a Unicode version of JADE is running.
// --------------------------------------------------------------------------------
begin
//	self.fillReadBuffer			:=	false;
//	self.cnEcReceiveBuffer		:=	self.cnEcReceiveBuffer &amp; pBuffer;	// Append the buffer contents.
//	self.cnEcLastReceiveTime	:=	app.clock();						// Set current clock time.
//	self.readBinaryAsynch(self.cnEcGetBufferLength(), pTcpConnectionObj, method.name);			// Request the next buffer...

	self.fillReadBuffer			:=	false;

	if app.isUnicode() then
		// Convert the buffer contents to Unicode and then append it.
		self.cnEcReceiveBuffer	:=	self.cnEcReceiveBuffer &amp; pBuffer.ansiToUnicode().Binary;
	else
		// Append the buffer contents.
		self.cnEcReceiveBuffer	:=	self.cnEcReceiveBuffer &amp; pBuffer;	// Append the buffer contents.
	endif;

	// Set current clock time.
	self.cnEcLastReceiveTime	:=	app.clock();
	
	// Request the next buffer...
	self.readBinaryAsynch(self.cnEcGetBufferLength(), pTcpConnectionObj, method.name);
end;</source>
        <access>protected</access>
        <Parameter name="pTcpConnectionObj" type="TcpIpConnection"/>
        <Parameter name="pBuffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWaitForReceiveBuffer" id="0dfd5651-29f8-4eb2-a12a-5b128509c8c0">
        <updating/>
        <source>cnEcDoWaitForReceiveBuffer(pTimeoutPeriod:Integer):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Once a "readBinaryAsynch" request has been made, we need to wait
//				for a response from the read buffer (via the callback method).
//				This method is a wrapper for this process of waiting for a response;
//				note that an exception handler is armed at this level so that if
//				the connection has been closed by the remote device (in which case
//				an exception will be raised), we can assume that all of the read
//				buffer has been received, and we can safely continue on our merry way.
//
// Parameters:	pTimeoutPeriod - The number of seconds to wait for a response before
//				 assuming that all of the read buffer has been received.
//
// Returns:		A flag to indicate that the read buffer has been successfully received.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hasSucceeded		: Boolean;
	minutesSinceLast	: Integer;

begin
	on ConnectionException do self.cnEcExHandlerWebReceiveWait(exception);

	hasSucceeded				:=	false;
	self.cnEcLastReceiveTime	:=	app.clock();

	self.cnEcDoWaitLoop(pTimeoutPeriod);

	hasSucceeded	:=	true;
epilog
	return hasSucceeded;
end;</source>
        <access>protected</access>
        <Parameter name="pTimeoutPeriod" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWaitLoop" id="9ff56f42-1eec-40b6-a096-b8ba772113c4">
        <source>cnEcDoWaitLoop(pTimeoutPeriod:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		This method waits for a response from the read buffer (via the
//				callback method) after a "readBinaryAsynch" request has been made.
//				If the connection has been closed by the remote device, an exception
//				will be raised and will be handled by the exception handler that was
//				armed by the caller of this method.
//
// Parameters:	pTimeoutPeriod - The number of seconds to wait for a response before
//				 assuming that all of the read buffer has been received.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	minutesSinceLast	: Integer;
	startTime			: Integer;

begin
	startTime	:=	app.clock();

	while (self.state = Connection.Connected) do
		process.sleep(1000);

		// If the connection has been closed by the remote device, then the following
		// "doWindowsEvents" call will result in an exception that should be handled
		// by the caller of this method (such an exception should indicate that all
		// of the read buffer has been received from the remote device).
		app.doWindowEvents(0);

		minutesSinceLast	:=	(app.clock - self.cnEcLastReceiveTime) div 1000;

		if minutesSinceLast &gt; pTimeoutPeriod then
			// We've timed out, so we'll assume that all of the read buffer has been received.
			break;
		endif;
	endwhile;
epilog
	cnEcMonitor(process.userCode &amp; " - " &amp; self.class().name &amp; ": Read buffer done after " &amp; ((app.clock - startTime) div 1000).String &amp; " seconds.");
end;</source>
        <access>protected</access>
        <Parameter name="pTimeoutPeriod" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWebGetRequest" id="d2151d52-c90d-4598-a879-7c9c2386420f">
        <updating/>
        <source>cnEcDoWebGetRequest(pServer:String;
					pFilePath:String;
					pMessage:String;
					pTimeout:Integer;
					pResponse:String io):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2000 by cnwdad1
//
// Purpose:		GET's a message from the requested Web Server (assumes Port 80).
//
// Parameters:	pServer - The URL of the Web Server to which we're sending the message.
//				pFilePath - The path (on the Web Server) of a file or application to
//					which we're sending the message.
//				pMessage - The actual message to be sent to the Web Server.
//				pTimeout - The number of seconds to wait for a response before
//					assuming that all of the read buffer has been received.
//				pResponse - The response received from the remote Web Server.
//
// Returns:		A flag to indicate whether the sent message was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageToSend		: String;
	errorPrefix			: String;

begin
	on ConnectionException do self.cnEcExHandlerWebRequest(exception);

	self.cnEcErrorMessage	:=	null;
	self.cnEcReceiveBuffer	:=	null;
	errorPrefix				:=	self.class().name &amp; "::" &amp; method.name &amp; ":";

	if pTimeout &lt; 1 then
		self.cnEcErrorMessage	:=	errorPrefix &amp; " Invalid timeout period - must be greater than zero.";
		return false;
	endif;

	self.fillReadBuffer	:=	false;

	if self.cnEcDoOpenConnection(pServer, self.cnEcGetServerPort(), self.fillReadBuffer) then
//		messageToSend	:=	pFilePath &amp; messageToSend;		// cnwdad1 16/05/2001.
		messageToSend	:=	pFilePath &amp; pMessage;			// cnwdad1 16/05/2001.

		if self.cnEcDoWebWriteBuffer(CNEC_WEB_GET, messageToSend) then
			if self.cnEcDoReadAsynchBuffer(self.cnEcGetBufferLength(), self, CnEcTcpConnection::cnEcDoReadCallBack.name) then
				self.cnEcLastReceiveTime	:=	app.clock();

				if self.cnEcDoWaitForReceiveBuffer(pTimeout) then
					pResponse	:=	self.cnEcReceiveBuffer.String;
				else
					return false;
				endif;
			else
				return false;
			endif;
		else
			return false;
		endif;
	else
		return false;
	endif;

	return true;
epilog
	self.close();
end;</source>
        <Parameter name="pServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pTimeout" type="Integer"/>
        <Parameter name="pResponse" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWebPostRequest" id="6dd3d0b6-6b9f-4957-b31c-ef86054adb27">
        <updating/>
        <source>cnEcDoWebPostRequest(	pServer:String;
						pFilePath:String;
						pMessage:String;
						pTimeout:Integer;
						pResponse:String io):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2000 by cnwdad1
//
// Purpose:		POST's a message to the requested Web Server (assumes Port 80).
//
// Parameters:	pServer - The URL of the Web Server to which we're sending the message.
//				pFilePath - The path (on the Web Server) of a file or application to
//					which we're sending the message.
//				pMessage - The actual message to be sent to the Web Server.
//				pTimeout - The number of seconds to wait for a response before
//					assuming that all of the read buffer has been received.
//				pResponse - The response received from the remote Web Server.
//
// Returns:		A flag to indicate whether the sent message was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/01/2001	cnwdad1		Now using new encode method to encode the HTTP string
//							and strip out Cr and Lf characters all in one go to
//							save processing time.
// --------------------------------------------------------------------------------
vars
	messageToSend		: String;
	errorPrefix			: String;

begin
	on ConnectionException do self.cnEcExHandlerWebRequest(exception);

	self.cnEcErrorMessage	:=	null;
	self.cnEcReceiveBuffer	:=	null;
	errorPrefix				:=	self.class().name &amp; "::" &amp; method.name &amp; ":";

	if pTimeout &lt; 1 then
		self.cnEcErrorMessage	:=	errorPrefix &amp; " Invalid timeout period - must be greater than zero.";
		return false;
	endif;

	self.fillReadBuffer	:=	false;


	// When POST'ing messages to a remote program, we must strip out all Carriage
	// Return and LineFeed characters, and then encode the message (but not the path).
	messageToSend	:=	pMessage;
//	messageToSend.cnReplaceChar(Cr, null);								// Now done by new encode method.
//	messageToSend.cnReplaceChar(Lf, null);								// Now done by new encode method.
//	messageToSend	:=	pFilePath &amp; messageToSend.cnEcEncodeWebData;	// Now using new encode method to encode and strip all in one go.
//	messageToSend	:=	pFilePath &amp; messageToSend.cnEcEncodeWebDataAndStripCrLf;	// cnwdad1 02/02/2001.
	messageToSend	:=	pFilePath &amp; messageToSend.cnEcUrlEncode(String.CNEC_URL_ENCODE_JADE);	// cnwdad1 02/02/2001.

	if self.cnEcDoOpenConnection(pServer, self.cnEcGetServerPort(), self.fillReadBuffer) then
// 19/01/2001 - The following is now performed before the connection is opened because
// for large messages the connection was timing out before this string processing was
// finished.
//		// When POST'ing messages to a remote program, we must strip out all Carriage
//		// Return and LineFeed characters, and then encode the message (but not the path).
//		messageToSend	:=	pMessage;
//		messageToSend.cnReplaceChar(Cr, null);
//		messageToSend.cnReplaceChar(Lf, null);
//		messageToSend	:=	pFilePath &amp; messageToSend.cnEcEncodeWebData;

		if self.cnEcDoWebWriteBuffer(CNEC_WEB_POST, messageToSend) then
			if self.cnEcDoReadAsynchBuffer(self.cnEcGetBufferLength(), self, CnEcTcpConnection::cnEcDoReadCallBack.name) then
				self.cnEcLastReceiveTime	:=	app.clock();

				if self.cnEcDoWaitForReceiveBuffer(pTimeout) then
					pResponse	:=	self.cnEcReceiveBuffer.String;
				else
					return false;
				endif;
			else
				return false;
			endif;
		else
			return false;
		endif;
	else
		return false;
	endif;

	return true;
epilog
	self.close();
end;</source>
        <Parameter name="pServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pTimeout" type="Integer"/>
        <Parameter name="pResponse" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWebWriteBuffer" id="a6637494-2114-4e3b-8578-a8df6882443b">
        <updating/>
        <source>cnEcDoWebWriteBuffer(pCommand:String; pMessage:String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Writes a message to the buffer, i.e. sends the message to the
//				remote device.
//
// Parameters:	pCommand - The command to indicate the type of HTTP message (GET of POST).
//				pMessage - The message to send to the remote device.
//
// Returns:		A flag to indicate the success of the sent message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/09/2000	cnwdad1		Changed to convert the buffer contents from Unicode
//							into ANSI if a Unicode version of JADE is running.
// --------------------------------------------------------------------------------
vars
	hasSucceeded	: Boolean;
	webMessage		: String;
	writeBuffer		: Binary;

begin
	hasSucceeded	:=	false;

	if pCommand = self.CNEC_WEB_GET then
		webMessage	:=	pCommand &amp; " " &amp; pMessage &amp; self.CNEC_WEB_GET_TRAILER;
	elseif pCommand = self.CNEC_WEB_POST then
		webMessage	:=	pCommand &amp; " " &amp; pMessage &amp; self.CNEC_WEB_POST_TRAILER;
	else
		self.cnEcSetError("Invalid request type: " &amp; pCommand);
		self.cnEcLog("Invalid request type: " &amp; pCommand);
		return false;
	endif;

//cnEcMonitor(self.name &amp; " @ " &amp; self.port.String &amp; ":" &amp; webMessage);
	if app.isUnicode() then								// cnwdad1 04/09/2000.
// cnwdad1 14/11/2001 - Put back CardSchema's cnUnicodeToAnsi which is now included in the current CardSchema release.
// cnwdad1 29/01/2001
		writeBuffer	:=	webMessage.cnUnicodeToAnsi();	// cnwdad1 04/09/2000.		// cnwdad1 14/11/2001.
//		writeBuffer	:=	webMessage.cnEcUnicodeToAnsi;	// cnwdad1 29/01/2001.		// cnwdad1 14/11/2001.
	else												// cnwdad1 04/09/2000.
		writeBuffer	:=	webMessage.Binary;
	endif;												// cnwdad1 04/09/2000.

	self.writeBinary(writeBuffer);

	hasSucceeded	:=	true;
epilog
	return hasSucceeded;
end;</source>
        <access>protected</access>
        <Parameter name="pCommand" type="String"/>
        <Parameter name="pMessage" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcExHandlerWebReceiveWait" id="416cc19a-aaea-4c24-87d8-6f6ab13bb444">
        <updating/>
        <source>cnEcExHandlerWebReceiveWait(pExceptionObj:ConnectionException):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Exception handler to be armed specifically when waiting for a
//				callback from a readBinaryAsynch request.  If the connection has
//				been closed by the remote device, then we'll assume that all of
//				the message has been returned to the read buffer, otherwise an
//				error has occurred.
//
// Parameters:	pExceptionObj - The ConnectionException object.
//
// Returns:		The exception return value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	TCP_CONNECT_CLOSED		: Integer = 31017;

begin
	if not pExceptionObj.connection.isKindOf(CnEcTcpConnection) then
		// Exception is not one I can handle, so pass it back...
		return Ex_Pass_Back;
	endif;

	if pExceptionObj.errorCode = TCP_CONNECT_CLOSED and pExceptionObj.continuable then
		// The Connection was closed by other (remote) side.
		return Ex_Resume_Next;
	else
		self.cnEcSetError(method.name &amp; ": " &amp; pExceptionObj.text());
		return Ex_Resume_Next;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcExHandlerWebRequest" id="0b3dc79e-2041-4567-bb29-e103627097a3">
        <updating/>
        <source>cnEcExHandlerWebRequest(pExceptionObj:ConnectionException):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2000 by cnwdad1
//
// Purpose:		General exception handler for TcpIp exceptions.
//
// Parameters:	pExceptionObj - The ConnectionException object.
//
// Returns:		The exception return value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	TCP_NETWORK_FAILED		: Integer = 31001;
	TCP_NAME_NOT_FOUND		: Integer = 31002;
	TCP_CONNECT_FAILED		: Integer = 31004;
	TCP_BIND_FAILED			: Integer = 31005;
	TCP_READ_ERROR			: Integer = 31008;
	TCP_SENDER_ERROR		: Integer = 31009;
	TCP_READ_IN_PROGRESS	: Integer = 31012;
	TCP_CONNECT_CLOSED		: Integer = 31017;

vars
	tcpConnectObj	: CnEcTcpConnection;
	errorPrefix		: String;

begin
	if pExceptionObj.currentMethodDesc = null then
		errorPrefix	:=	"Unknown caller: ";
	else
		errorPrefix	:=	pExceptionObj.currentMethodDesc.getName &amp; ": ";
	endif;

	if not pExceptionObj.connection.isKindOf(CnEcTcpConnection) then
		// Exception is not one I can handle, so pass it back...
		return Ex_Pass_Back;
	endif;

	tcpConnectObj	:=	pExceptionObj.connection.CnEcTcpConnection;

	if pExceptionObj.errorCode = TCP_CONNECT_FAILED then
		self.cnEcSetError(errorPrefix &amp; "Unable to open a connection to " &amp; tcpConnectObj.name &amp; "/" &amp; tcpConnectObj.port.String);
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_NETWORK_FAILED then
		// No target host name specified (Tcp/Ip Network failed to initialize).
		self.cnEcSetError(errorPrefix &amp; "No target host name was specified, or the Tcp/Ip Network has failed to initialize.");
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_NAME_NOT_FOUND then
		// No target host name not found.
		self.cnEcSetError(errorPrefix &amp; "The Server name (" &amp; tcpConnectObj.name &amp; ") could not be found on the host's file, or was not available on your DNS server.");
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_BIND_FAILED then
		self.cnEcSetError(errorPrefix &amp; "Unable to bind to " &amp; tcpConnectObj.name &amp; "/" &amp; tcpConnectObj.port.String);
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_READ_ERROR then
		self.cnEcSetError(errorPrefix &amp; "TCP/IP read error [" &amp; tcpConnectObj.remoteIpAddress &amp; "/" &amp; tcpConnectObj.port.String);
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_READ_IN_PROGRESS then
		// read request all ready sent
		self.cnEcSetError(errorPrefix &amp; "A Read request has already been sent or is still in progress.");
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_SENDER_ERROR then
		// write error...
		self.cnEcSetError(errorPrefix &amp; "TCP/IP (sender) write error [" &amp; tcpConnectObj.remoteIpAddress &amp; "/" &amp; tcpConnectObj.port.String);
		return Ex_Resume_Next;

	elseif pExceptionObj.errorCode = TCP_CONNECT_CLOSED then
		// connection closed by other side
		self.cnEcSetError(errorPrefix &amp; "The connection was closed by the remote device.");
		return Ex_Resume_Next;
	endif;

	self.cnEcSetError(errorPrefix &amp; pExceptionObj.text());
	return Ex_Abort_Action;
epilog
	if self.cnEcErrorMessage &lt;&gt; null then
		self.close();
		cnEcLog(self.cnEcErrorMessage);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetBufferLength" id="060f8843-a5b1-4a21-838a-f76857c0bcd3">
        <source>cnEcGetBufferLength():Integer protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Returns the size of binary data to read from the connection buffer.
//				To use a different buffer length, subclass this class and
//				reimplement this method.
//
// Parameters:	None
//
// Returns:		The length of data to read from the buffer.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return 4000;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetServerPort" id="3edaad2f-80f3-4abe-be14-c4f64a1b9efa">
        <source>cnEcGetServerPort():Integer protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		80 is the default port for Web Servers.  To use a different port
//				number, subclass this class and reimplement this method.
//
// Parameters:	None
//
// Returns:		80, which is the standard port for Web Servers.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return 80;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetError" id="71a55405-d847-4018-95a5-3c420686b1fa">
        <updating/>
        <source>cnEcSetError(pErrorMessage:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 June 2000 by cnwdad1
//
// Purpose:		Sets the requested error message attribute.
//
// Parameters:	pErrorMessage - The error mesage.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.cnEcErrorMessage	:=	pErrorMessage;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
