<Class name="CMQF_VehicleReport">
    <JadeMethod name="setFromAgent" id="b89402b8-1abe-4302-9767-75385bbe5521">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------------
// 03/01/2014	cnwdap1		PAR #32849 CCMS PEN 2321 Security Gate
// 06/06/2014	cnwdap1		PAR #34297 Vehicle Visit Report missing some visits
// 25/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
vars

	dateStr : String;
	tplType : Integer;
	tplFactor : Integer;

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_VisitNumber) then
		self.selectedGatePass := _agent.getValueByName(ETRow_VisitNumber).asStringJMT();
	else																					// PAR #32849
		self.selectedGatePass := Any_String;												// PAR #32849
	endif;
	if self.selectedGatePass = null then					// PAR #34297
		self.selectedGatePass := Any_String;				// PAR #34297
	endif;													// PAR #34297
	
	if _agent.isRowIncluded(ETRow_CarrierCode) then
		self.selectedCarrierCode := _agent.getValueByName(ETRow_CarrierCode).asStringJMT();
	endif;
	
	//Start 25/05/2022 navhl20 TFS 53430 
	if _agent.isRowIncluded(ETRow_SubCarrierCode) then
		self.selectedSubCarrierCode := _agent.getValueByName(ETRow_SubCarrierCode).asStringJMT();
	endif;
	//End 25/05/2022 navhl20 TFS 53430 
	
	//28 Feb 2018	NDL	TFS 37184
	if _agent.isRowIncluded(ETRow_FilterDateIn) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		   dateStr := _agent.getValueForTemplateDates(ETRow_FilterDateIn);
			self.setTemplateDateFields( dateStr, tplType, tplFactor, ETRow_FilterDateIn);
			self.dateFromType := tplType;
			self.dateFromFactor := tplFactor;
		else
			self.dateFrom := _agent.getValueByNameIfVisible(ETRow_FilterDateIn).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterDateOut) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		   dateStr := _agent.getValueForTemplateDates(ETRow_FilterDateOut);
			self.setTemplateDateFields( dateStr, tplType, tplFactor, ETRow_FilterDateOut);
			self.dateToType := tplType;
			self.dateToFactor := tplFactor;
		else
			self.dateTo := _agent.getValueByNameIfVisible(ETRow_FilterDateOut).Date;
		endif;
	endif;
	
	
end;
</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
