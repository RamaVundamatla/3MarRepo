    <JadeMethod name="setdownForm" id="565ef2d3-822b-41f3-9c33-100858702018">
        <updating/>
        <source>setdownForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 May 2008 by cnwdad1
//
// Purpose:		Standard for shutdown method (not sure why it's called "setDown").
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.aAllBlockGroupsIn.purge();
	self.aAllBlockGroupsOut.purge();
	self.aAllSelectedCriteria.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupCombo" id="b7c3e49f-1301-4196-9a1c-de25821c3a94">
        <source>setupCombo(critTypeObj : CM_YACriteriaType; combo : CMUI_YACriteriaValue input; label : Label input);
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	obj : CM_Object;
	proc : Boolean;
begin
	//label.cnEcSet(critTypeObj.getTypeName() &amp; ":");
	label.cnEcSet(critTypeObj.description &amp; ":");	//09 Oct 2013	NDL	Par 32456
	label.visible		:=	true;
	combo.setCriteriaType(critTypeObj);
	combo.visible	:=	true;
	
	if myTrackedItem &lt;&gt; null then
		critTypeObj.getCriteriaObjectForTi(myTrackedItem, obj, proc);
	endif;
	combo.listIndex := combo.findObject(obj);
end;</source>
        <Parameter name="critTypeObj" type="CM_YACriteriaType"/>
        <Parameter name="combo" type="CMUI_YACriteriaValue" usage="input"/>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupCriteriaTypes" id="72d28027-3504-4e29-b98d-1f4b13d7fdcb">
        <source>setupCriteriaTypes() protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		Set up the receiver's Yard Allocation Criteria Type fields.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// adm 270509 Par 19483 myTerminal
vars
	terminalObj		: CM_Terminal;
	critTypeObj		: CM_YACriteriaType;
	typeCount		: Integer;
	loopCount		: Integer;
	loopStart		: Integer;
	
begin
	terminalObj	:=	self.myTerminal();
	terminalObj.allRTAllocationCriteriaTypes.copy(self.aAllCriteriaTypes);
	typeCount	:=	0;
	
	foreach critTypeObj in self.aAllCriteriaTypes do
		typeCount	:=	typeCount + 1;
		if typeCount &gt; CM_Terminal.RT_CriteriaLimit then
			break;
		endif;
		
		if typeCount = 1 then
			setupCombo(critTypeObj, cmbCriteria1, lblLabel1);
		elseif typeCount = 2 then
			setupCombo(critTypeObj, cmbCriteria2, lblLabel2);
		elseif typeCount = 3 then
			setupCombo(critTypeObj, cmbCriteria3, lblLabel3);
		elseif typeCount = 4 then
			setupCombo(critTypeObj, cmbCriteria4, lblLabel4);
		endif;
	endforeach;
	
	loopStart	:=	typeCount + 1;
	
	foreach loopCount in loopStart to CM_Terminal.RT_CriteriaLimit do
		if loopCount = 1 then
			lblLabel1.visible		:=	false;
			cmbCriteria1.visible	:=	false;
			
		elseif loopCount = 2 then
			lblLabel2.visible		:=	false;
			cmbCriteria2.visible	:=	false;
			
		elseif loopCount = 3 then
			lblLabel3.visible		:=	false;
			cmbCriteria3.visible	:=	false;
			
		elseif loopCount = 4 then
			lblLabel4.visible		:=	false;
			cmbCriteria4.visible	:=	false;
			
		endif;
	endforeach;
	
	self.doSpaceControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0ee1105e-c82c-4078-9af6-3fd0bf68840c">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.setupCriteriaTypes();
	self.modalResult	:=	self.MB_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2aa737c6-a749-422c-ab65-55b2b26011d9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017595, locale);
	btnCancel.translateCaption(Xlat_0012954, locale);
	btnOK.translateCaption(Xlat_0012955, locale);
	lblCode.translateCaption(Xlat_0012956, locale);
	lblLabel1.translateCaption(Xlat_0012957, locale);
	lblLabel2.translateCaption(Xlat_0012958, locale);
	lblLabel3.translateCaption(Xlat_0012959, locale);
	lblLabel4.translateCaption(Xlat_0012960, locale);
	lblLocation.translateCaption(Xlat_0012961, locale);
	lblTitle.translateCaption(Xlat_0012962, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="857d8972-4301-4335-888b-fefaea94a200">
        <source>validateForm():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		13 May 2008 by cnwdad1
//
// Purpose:		Validates the users inputs/selections.
//
// Parameters:	None
//
// Returns:		True if the user inputs/selections are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMsg		: String;
	message			: String;
	criteriaCode	: String;
	location		: String;
	typeNames		: String;
	
begin
	criteriaCode	:=	txtCode.cnEcString();
	location		:=	txtLocation.cnEcString();
	
	if criteriaCode = null then
		message	:=	"Please enter a Yard Allocation Code.";
	endif;
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;
	
	if location = null then
		message	:=	"Please enter the Location for the Yard Allocation.";
	endif;
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;

	//cnwo3 par 22890.  I'm 99.9% sure there is no point in forcing a user
	//to enter all criteria values for a YA.
	/*
	if cmbCriteria1.listIndex = CNEC_NULL_INDEX
	and cmbCriteria2.listIndex = CNEC_NULL_INDEX
	and cmbCriteria3.listIndex = CNEC_NULL_INDEX
	and cmbCriteria4.listIndex = CNEC_NULL_INDEX
	then
		if cmbCriteria1.visible then
			if typeNames = null then
				typeNames	:=	"- " &amp; cmbCriteria1.getTypeName();
			else
				typeNames	:=	typeNames &amp; CrLf &amp; "- " &amp; cmbCriteria1.getTypeName();
			endif;
		endif;
		
		if cmbCriteria2.visible then
			if typeNames = null then
				typeNames	:=	"- " &amp; cmbCriteria2.getTypeName();
			else
				typeNames	:=	typeNames &amp; CrLf &amp; "- " &amp; cmbCriteria2.getTypeName();
			endif;
		endif;
		
		if cmbCriteria3.visible then
			if typeNames = null then
				typeNames	:=	"- " &amp; cmbCriteria3.getTypeName();
			else
				typeNames	:=	typeNames &amp; CrLf &amp; "- " &amp; cmbCriteria3.getTypeName();
			endif;
		endif;
		
		if cmbCriteria4.visible then
			if typeNames = null then
				typeNames	:=	"- " &amp; cmbCriteria4.getTypeName();
			else
				typeNames	:=	typeNames &amp; CrLf &amp; "- " &amp; cmbCriteria4.getTypeName();
			endif;
		endif;
		
		message	:=	"Please enter one or more of the following Criteria:" &amp; CrLf &amp; typeNames;
	endif;
	*/
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;
	
	if errorMsg = null then
		return true;
	else
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
