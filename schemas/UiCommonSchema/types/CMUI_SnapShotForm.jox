    <JadeMethod name="loadLGDOperatorCombo" id="6608cbe3-5172-4457-a130-e5629407dc9d">
        <source>loadLGDOperatorCombo(_lgd: CM_LineGroupDebtor);
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyOp,
	op	: CM_Operator;
begin

	if _lgd &lt;&gt; null then
		foreach op in _lgd.debtor.CM_Debtor.operators do
			self.cmbLGDOperators.addItemObject(op.code &amp; ' ' &amp; op.description, op);
		endforeach;
	endif;		
	
	if self.cmbLGDOperators.listCount &lt; 1 then
		voyOp := self.myVoyage.myOperator;
		//stick the voyage operator in there
		self.cmbLGDOperators.addItemObject(voyOp.code &amp; ' ' &amp; voyOp.description, voyOp);
	endif;

end;</source>
        <Parameter name="_lgd" type="CM_LineGroupDebtor"/>
    </JadeMethod>
