    <JadeMethod name="setMyTrackedItem" id="b48645a7-b88a-41f3-b0d6-9a7c106900c9">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
/*
Purpose:			

Date		Who		Reason
10 June 2022	navab1	TFS 53105
*/

vars
	ti : CM_TrackedItem;
begin
	inheritMethod(pTI, _tiTransCntrl);

	ti := pTI;
	if ti.isPreNote() 
	or ti.isOnShipState() then  // ### TFS 53105 03AUG2022 NAVAB1
		if not ti.isContainer() then
			if app.myPassport.isOpsViewEnabled(self.myTerminal) then 
				ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM,ti); 
			endif;
		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
</Class>
