    <JadeMethod name="getKeyLengthForXTABDictionary" id="2e6e5f78-1569-493c-9f09-bc48be8dd96b">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	return CM_PaymentMethod::description.length;

epilog

end;</source>
        <ReturnType type="Integer"/>
