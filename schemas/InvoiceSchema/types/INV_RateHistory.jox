    <JadeMethod name="loadRateHistoryBerth" id="ba151b56-484b-4269-92fd-076b2dfdee92">
        <source>loadRateHistoryBerth(_berth : HMS_Berth; _table : Table io; _service : CM_Service);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	savedChargedEffTS : TimeStamp;
	rate : CM_Rate;
	iter : Iterator;
	rateEntry : CM_RateEntry;
	str : String;
	i : Integer;

begin
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate(self.effectiveDate.TimeStamp);
	
	rate := _berth.allServiceRates[_service];
	if rate &lt;&gt; null then
		iter := rate.rateEntries.createIterator;
		while iter.back(rateEntry) do
			str := rateEntry.getAttributeStringForDefArray(_table.CM_DataTable.allTblDataEntRows);
			i := _table.addItem(str);
			_table.accessRow(i).itemObject := rateEntry;
		endwhile;
	endif;

epilog
	delete iter;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_table" type="Table" usage="io"/>
        <Parameter name="_service" type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="loadRateHistoryDebtor" id="ca8830bd-cba5-4d54-a005-f128867193db">
        <source>loadRateHistoryDebtor(_debtorNode : CM_DebtorNode; _theTable : Table io; _theService : CM_Service);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str : String;
	rate : CM_Rate;
	rateEntry : CM_RateEntry;
	iter : Iterator;
	i : Integer;
	savedChargedEffTS : TimeStamp;
begin
	
	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	rate := _debtorNode.serviceRates[_theService];
	if rate &lt;&gt; null then
		iter := rate.rateEntries.createIterator;
		while iter.back(rateEntry) do
			str := rateEntry.getAttributeStringForDefArray(_theTable.CM_DataTable.allTblDataEntRows);
			/* 23582 replaced by code above, make tblData a proper ent table
			str := _debtorNode.getListName() &amp; Tab;  // so default debtor is not 'RDG'
			str := str &amp; rateEntry.costPerUnit.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; Tab;
			str := str &amp; rateEntry.startTimestamp.String &amp; Tab;
			str := str &amp; rateEntry.userId;	//NFS GD Xpose 1342
			*/
			i := _theTable.addItem(str);
			_theTable.accessRow(i).itemObject := rateEntry;
		endwhile;
	endif;

	if _debtorNode.myParentDebtorNode &lt;&gt; null then
		self.loadRateHistoryDebtor(_debtorNode.myParentDebtorNode, _theTable, _theService);
	endif;
epilog
	delete iter;
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <Parameter name="_theTable" type="Table" usage="io"/>
        <Parameter name="_theService" type="CM_Service"/>
    </JadeMethod>
