    <JadeMethod name="getExtraInfo" id="31e4fa8c-7e55-4ef7-b578-fb6f10a7eb46">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Name", DC_Label, 1, self);
	block.addNewItem(self.name, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Business Unit", DC_Label, 1, self.bank);
	block.addNewItem(self.bank.code, DC_Data, 1, self.bank);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="d177b9ca-07fb-413e-baa2-b57de5bb14bd">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:		TFS 2682	
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars

begin
	if bank = null then
		return null;
	endif;
	
	
	return bank.getMyTerminal();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTaxCode" id="2ffa14d8-b153-4cfb-b7dd-7996f3b8411f">
        <source>getTaxCode(_description: Boolean) : String;
/*
Purpose:			
Date				Who			Reason
NOV 2017		CNWAB1		Initial creation
*/


vars
	taxCode : String;
	theBank : CM_Bank;
begin
	theBank := self.bank;
	
	if theBank.terminal.getConfig(InvoiceMultiTaxRates).Boolean then
		if self.myTaxCode&lt;&gt; null then
		   if _description then
				taxCode := self.myTaxCode.description;
			else
				taxCode := self.myTaxCode.code;
			endif;
		else
			taxCode := "";
		endif;
	else
		taxCode := theBank.parentCompany.taxNarration;
	endif;
	
	
	return taxCode;
end;</source>
        <Parameter name="_description" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxCodeString" id="85a713db-6e22-45d1-b057-efe6f5926592">
        <source>getTaxCodeString(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		18 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myTaxCode = null then
		return null;
	else
		if _short then
			return self.myTaxCode.code;
		else
			return self.myTaxCode.description;
		endif;
	endif;
		
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
