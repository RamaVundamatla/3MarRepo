    <JadeMethod name="setNarration" id="9d77157e-cce5-41ac-80ff-a4e280569b7d">
        <updating/>
        <source>setNarration(_narration : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 June 2022		jlizm1	Initial creation TFS 52495 void invoice line should only be able to edit narration

*/

vars

