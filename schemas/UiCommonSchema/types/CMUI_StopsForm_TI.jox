    <JadeMethod name="loadStops" id="5ece3a14-5ee5-45cb-99af-62f9e779cf77">
        <updating/>
        <source>loadStops( _ti : CM_TrackedItem ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	clearanceExpiry	: Date;
	strDate			: String;
	strCaption		: String;
	strInfo			: String;
	row				: Integer;
	maxLength		: Integer;
	case			: Integer;
	col				: Integer;
	gotException	: Boolean;
	overrideStr		: String;						// cnwrl1 30/08/2010 PAR 23697
	overridenReason	: CM_StopOverridenReason;		// cnwrl1 30/08/2010 PAR 23697
	table			: CM_DataTable;
	stopTable		: CM_StopsTable;
	passport		: CM_Passport;
	terminal		: CM_Terminal;
	user			: CM_User;
	viewColl		: CM_StopsTableByIdDict;
	maintColl		: CM_StopsTableByIdDict;
	cancelColl		: CM_StopsTableByIdDict;
begin
	on Exception do app.handleDeletedObject (exception, _ti, gotException);
	
	// this next line will cause an exception if _ti is invalid
	self.expectedEdition := _ti.edition;
	
	if gotException then
		// display message and close form
		self.unloadFormWithMessage;
	endif;
	
// cnwdad1 01/07/2010.
//	self.expectedStops	:= self.getStopsString (_ti.getAllStops);
	self.expectedStops	:= self.getStopsString();
	passport 			:= app.myPassport;
	user				:= passport.myUser;
	terminal			:= self.myTerminal;
	table				:= self.tblStopsAdd;
	
	table.rows	:= table.fixedRows;
	
	viewColl 	:= user.getStopsToViewForTerminal(terminal);
	maintColl 	:= user.getStopsToMaintForTerminal(terminal);
	cancelColl 	:= user.getStopsToCancelForTerminal(terminal);
	
	// load stops to be added/updated first
	foreach stopTable in maintColl do
		if not stopTable.isAvailable then
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; stopTable.heading &amp; " is not available", LogDEBUG);
			continue;
		endif;
		if not stopTable.isStopRelevant (_ti) then
			// this stop not relevant for current ti
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; stopTable.heading &amp; " is not relevant", LogDEBUG);
			continue;
		endif;
		
		if _ti.isStopSet( stopTable.id ) then
			// can't add it again
		app.writeLog(method.qualifiedName &amp; " STOPS " &amp; stopTable.heading &amp; " is already set", LogDEBUG);
			continue;
		endif;
		
		// Get this stops override reason if it exists.
		overridenReason	:= _ti.getStopOverrideReason( stopTable.id );	// cnwrl1 30/08/2010 PAR 23697
		if overridenReason = null then
			overrideStr	:= null;
		else
			overrideStr	:= overridenReason.description;
		endif;
		
		strDate := null;
		
		if stopTable.allowClearanceExpiryDate then 
			// stop can have a future clearance expiry
			clearanceExpiry := _ti.getStopClearanceExpiry( stopTable.id );
			
			if clearanceExpiry &lt;&gt; null then
				// stop has a future clearance expiry
				strDate := clearanceExpiry.asStringJMT();
				row := table.addItemObject (stopTable, null.String);	// add this entry with blank details
				
				table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
				table.setCellValueByName (ETRow_ClearanceExpiryDate, row, strDate);
				
				if not self.canUpdate then
					// over ride default of checkbox
					col := table.getColumnByRowName (ETRow_Add);
					
					if col &lt;&gt; null then
						table.accessCell (row, col).inputType 	:= Table.InputType_None;
						table.accessedCell.text					:= null;
					endif;
					
					col := table.getColumnByRowName (ETRow_Update);
					
					if col &lt;&gt; null then
						table.accessCell (row, col).inputType	:= Table.InputType_None;
						table.accessedCell.text					:= null;
					endif;
				endif;
				
				// cnwrl1 26/08/2010 PAR 23697 - start of coding
				if overrideStr &lt;&gt; null then
					table.setCellValueByName( ETRow_OverrideReason, row, overrideStr );
				endif;
				// cnwrl1 26/08/2010 PAR 23697 - end of coding
				
				continue;
			endif;
		endif;
		
		row := table.addItemObject (stopTable, null.String);		// add this entry with blank details
		
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		
		if not self.canUpdate then
			// over ride default of checkbox
			col := table.getColumnByRowName (ETRow_Add);
			
			if col &lt;&gt; null then
				table.accessCell (row, col).inputType 	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
		
		col := table.getColumnByRowName (ETRow_Update);
		
		if col &lt;&gt; null then
			table.accessCell (row, col).inputType	:= Table.InputType_None;
			table.accessedCell.text					:= null;
		endif;
		
		// cnwrl1 30/08/2010 PAR 23697 - start of coding
		// If this stop has an override reason then allow update if the user has correct permissions.
		if overrideStr &lt;&gt; null then
//			table.setCellValueByName( ETRow_OverrideReason, row, overrideStr );
			col	:= table.getColumnByRowName( ETRow_OverrideReason );
			if col &lt;&gt; null then
				table.accessCell( row, col ).itemObject	:= overridenReason;
				table.accessCell( row, col ).text		:= overrideStr;
			endif;
			col	:= table.getColumnByRowName( ETRow_Update );
			if col &lt;&gt; null then
				if self.canOverride then					// canOverride already includes canUpdate
					table.accessCell( row, col ).inputType	:= Table.InputType_CheckBox;
				else
					table.accessCell( row, col ).inputType	:= Table.InputType_None;
					table.accessedCell.text					:= null;
				endif;
			endif;
		endif;
		// cnwrl1 30/08/2010 PAR 23697 - end of coding
	endforeach;
	
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; null then
		table.sortColumn [1] := col;
		table.resort;
	endif;
	
	// now load stops that can be cancelled/deleted/overridden
	table 		:= self.tblStopsClear;
	table.rows 	:= table.fixedRows;
	
	foreach stopTable in viewColl do
		if not _ti.isStopSet( stopTable.id ) then 
			// it's not set
			continue;
		endif;
		
		row := table.addItemObject (stopTable, null.String);		// add this entry with blank details
		
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		// cnwrl1 20/09/2010 PAR 23697 - start of coding
		// If this stop had a clearance expiry date then now show it.
		if stopTable.allowClearanceExpiryDate then
			clearanceExpiry	:= _ti.getStopClearanceExpiry( stopTable.id );
			
			if clearanceExpiry &lt;&gt; null then
				// stop has a clearance expiry date so show it
				strDate	:= clearanceExpiry.asStringJMT();
				table.setCellValueByName( ETRow_ClearanceExpiryDate, row, strDate );
			endif;
		endif;
		// cnwrl1 20/09/2010 PAR 23697 - end of coding
		
		// can they clear the stop
		if maintColl.includes (stopTable) then
			// cnwrl1 26/08/2010 PAR 23697 - start of coding
			// Can the user override this stop? For this they need to be able to do maint and have canOverride.
			col	:= table.getColumnByRowName( ETRow_Override );
			if col &lt;&gt; null then
				if self.canOverride then				// canOverride already includes canUpdate
					table.accessCell( row, col ).inputType	:= Table.InputType_CheckBox;
				else
					table.accessCell( row, col ).inputType	:= Table.InputType_None;
					table.accessedCell.text					:= null;
				endif;
			endif;
			// cnwrl1 26/08/2010 PAR 23697 - end of coding
			
			if stopTable.requiresInfo then		
				stopTable.getDetailsForRequiredInfo (strCaption, strInfo, maxLength, case, _ti);
				
				table.setCellValueByName (ETRow_Info, row, strCaption); 
				table.setCellValueByName (ETRow_Input, row, strInfo); 
				
			endif;
			// check whether user has permission to maintain required infor for this stop
			col := table.getColumnByRowName (ETRow_Clear);
			
			if col &lt;&gt; 0 then
				if self.canUpdate and stopTable.userCanModify(terminal ) then
					table.accessCell (row, col).inputType	:= Table.InputType_CheckBox;
				else
					table.accessCell (row, col).inputType	:= Table.InputType_None;
					table.accessedCell.text					:= null;
				endif;
			endif;
		else
			// cnwrl1 26/08/2010 PAR 23697 - start of coding
			// The user cannot override this stop without maint access.
			col	:= table.getColumnByRowName( ETRow_Override );
			if col &lt;&gt; null then
				table.accessCell( row, col ).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
			// cnwrl1 26/08/2010 PAR 23697 - end of coding
			
			col := table.getColumnByRowName (ETRow_Clear);
			
			if col &lt;&gt; 0 then
				table.accessCell (row, col).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
			
			col := table.getColumnByRowName (ETRow_Cancel);
			
			if col &lt;&gt; null then
				table.accessCell (row, col).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
		// can they cancel it
		col := table.getColumnByRowName (ETRow_Cancel);
		
		if col &lt;&gt; 0 then
			if self.canUpdate and cancelColl.includes (stopTable) then
				table.accessCell (row, col).inputType	:= Table.InputType_CheckBox;
			else
				table.accessCell (row, col).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
	endforeach;	
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; 0 then
		table.sortColumn [1] := col;
		table.resort;	
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setExpiryDateForRow" id="f19cbd9b-fe73-4643-92e9-7364e0fbfd9e">
        <source>setExpiryDateForRow(_table :CM_DataTable input; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     14 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stopsTable	:CM_StopsTable;
	ti			:CM_TrackedItem;
	date		:Date;
begin
	stopsTable	:= _table.accessRow (_row).itemObject.CM_StopsTable;
	ti			:= self.myTrackedItem;
	date 		:= ti.getStopClearanceExpiry( stopsTable.id );
	
	if date &lt;&gt; null then
		_table.setCellValueByName (ETRow_ClearanceExpiryDate, _row, date.asStringJMT);
	else
		_table.setCellValueByName (ETRow_ClearanceExpiryDate, _row, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOverrideReasonForRow" id="dcd48132-0e48-4b5d-8e3d-26b55100b71e">
        <source>setOverrideReasonForRow( _table : CM_DataTable input; _row : Integer; _reset : Boolean ) protected;

/*
Date			Who		Reason
24 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	stop				: CM_Stops;
	stopsTable			: CM_StopsTable;
	overrideReason		: CM_StopOverridenReason;
	
begin
	stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
	stop		:= self.myTrackedItem.getStop( stopsTable.id );
	if stop = null then
		// should not happen?
		return;
	endif;
	
	overrideReason	:= stop.getStopOverrideReason();
	
	// set the override reason entry, resetting to the original value if so required.
	if overrideReason = null then
		_table.setCellValueByName( ETRow_OverrideReason, _row, null );
	else
		if _reset then
			_table.setCellValueByName( ETRow_OverrideReason, _row, overrideReason.description );
		else
			_table.accessCell( _row, _table.column ).itemObject	:= overrideReason;
			self.cmbOverrideRsons.listIndex	:= self.cmbOverrideRsons.findObject( overrideReason );
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_reset" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRowForAdd" id="1178a03c-0bf3-4049-bcb4-2c509b4bf1ae">
        <source>setRowForAdd( _table : CM_DataTable input; _row : Integer ) protected;

/*
Date			Who		Reason
30 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	value, isForCustDocs	: Boolean;
	col		: Integer;
	stop : CM_StopsTable;
begin
	// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
	stop := _table.accessRow(_row).itemObject.CM_StopsTable;
	if stop &lt;&gt; null 
	and stop.allCustomDocumentTypesForApply.isNotEmpty() then
		isForCustDocs := true;
	endif;
	
	value	:= _table.getCellValueByName (ETRow_Add, _row).Integer.Boolean;
	
	if value then
		// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
		if isForCustDocs then
			app.msgBox(app.getErrorString1(Stop_confi_custo_docum_canno_a,stop.heading),app.getErrorString(Custom_documents),MsgBox_OK_Only);
			_table.setCellValueByName(ETRow_Add, _row,"0");
			return;
		
		endif;
		
		// add and update are mutually exclusive
		col := _table.getColumnByRowName (ETRow_Update);
		
		if col &lt;&gt; null and
			_table.accessCell (_row, col).inputType = Table.InputType_CheckBox then
			_table.setCellValueByName (ETRow_Update, _row, null.String);
		endif;
		// can not change expiry date while adding
		col := _table.getColumnByRowName (ETRow_ClearanceExpiryDate);
		if col &lt;&gt; 0 then
			_table.accessCell (_row, col).inputType := Table.InputType_None;
		endif;
		// make sure expiry date is set to current value for stop
		self.setExpiryDateForRow (_table, _row);

		// cnwrl1 03/09/2010 PAR 23697 - start of coding
		// Cannot change overridden reason and reset to current value if has been changed.
		col	:= _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
		endif;
		self.setOverrideReasonForRow( _table, _row, true );
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForCancel" id="3982fbfa-beac-4692-ad10-4a9e347ce7b7">
        <source>setRowForCancel(_table :CM_DataTable input; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/09/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	value, isForCustDocs	: Boolean;
//	col		: Integer;
	
	stop : CM_StopsTable;
begin
	// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
	stop := _table.accessRow(_row).itemObject.CM_StopsTable;
	if stop &lt;&gt; null 
	and stop.allCustomDocumentTypesForApply.isNotEmpty() then
		isForCustDocs := true;
	endif;

	value	:= _table.getCellValueByName( ETRow_Cancel, _row ).Integer.Boolean;
	
	if value then
		// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
		if isForCustDocs then
			app.msgBox(app.getErrorString1(Stop_confi_custo_docum_canno_c,stop.heading),app.getErrorString(Custom_documents),MsgBox_OK_Only);
			_table.setCellValueByName(ETRow_Cancel, _row,"0");
			return;
		
		endif;
		
		// cancel, clear and override are mutually exclusive
		self.setTblClearCkboxesAndInputType( ETRow_Cancel, _table, _row );

	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForClear" id="cd5f08ab-f545-46e5-ab17-c7bb4619dfa9">
        <source>setRowForClear( _table : CM_DataTable input; _row : Integer ) protected;

/*
Date				Who		Reason
02 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	value, isForCustDocs		: Boolean;
	col			: Integer;
	stopsTable	: CM_StopsTable;
	
	stop : CM_StopsTable;
begin
	// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
	stop := _table.accessRow(_row).itemObject.CM_StopsTable;
	if stop &lt;&gt; null 
	and stop.allCustomDocumentTypesForApply.isNotEmpty() then
		isForCustDocs := true;
	endif;

	value 		:= _table.getCellValueByName( ETRow_Clear, _row ).Integer.Boolean;
	stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
	
	if value then
		// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
		if isForCustDocs then
			app.msgBox(app.getErrorString1(Stop_confi_custo_docum_canno_b,stop.heading),app.getErrorString(Custom_documents),MsgBox_OK_Only);
			_table.setCellValueByName(ETRow_Clear, _row,"0");
			return;
		
		endif;
		// cancel, clear and override are mutually exclusive
		self.setTblClearCkboxesAndInputType( ETRow_Clear, _table, _row );
		
		// now set up the allowed data to be entered
		col := _table.getColumnByRowName( ETRow_Input );
		if col &lt;&gt; 0 then
			if stopsTable.requiresInfo then		
				// let them enter it
				_table.accessCell( _row, col ).cellControl	:= self.txtExtraInfo;
			else
				_table.accessCell( _row, col ).cellControl	:= null;
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			if stopsTable.allowClearanceExpiryDate then
				// stop can have a future clearance expiry - so enable input for the cell
				_table.accessCell( _row, col ).inputType	:= Table.InputType_EditMask;
				_table.accessedCell.editMask				:= app.getDateEditMaskForShortFormat;
			else
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
	else
		// can not input any required info or expiry date
		col := _table.getColumnByRowName( ETRow_Input );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl		:= null;
			_table.accessCell( _row, col ).inputType		:= Table.InputType_None;
		endif;
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).inputType		:= CM_BaseTable.InputType_None;
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForOverride" id="26ed51fd-ae51-4955-bd6e-ae54cf893e11">
        <source>setRowForOverride( _table : CM_DataTable input; _row : Integer ) protected;

/*
Purpose:	If the Override checkbox is clicked then do required processing.

Date			Who		Reason
25 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	value, isForCustDocs				: Boolean;
	col					: Integer;
	stop				: CM_Stops;
	stopsTable			: CM_StopsTable;
	overrideReason		: CM_StopOverridenReason;
begin
	value		:= _table.getCellValueByName( ETRow_Override, _row ).Integer.Boolean;
	stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
	stop		:= self.myTrackedItem.getStop( stopsTable.id );
	if stop &lt;&gt; null then
		overrideReason	:= stop.getStopOverrideReason();
		// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
		if stopsTable.allCustomDocumentTypesForApply.isNotEmpty() then
			isForCustDocs := true;
		endif;
	endif;
	
	if value then
		// ### TFS CR 60516 TASK 60517 18SEP2023 NAVAB1
		if isForCustDocs then
			app.msgBox(app.getErrorString1(Stop_confi_custo_docum_canno_o,stopsTable.heading),app.getErrorString(Custom_documents),MsgBox_OK_Only);
			_table.setCellValueByName(ETRow_Override, _row,"0");
			return;
		
		endif;
		// cancel, clear and override are mutually exclusive
		self.setTblClearCkboxesAndInputType( ETRow_Override, _table, _row );
		
		// now allow the override reason data to be entered
		col := _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= self.cmbOverrideRsons;
			_table.accessCell( _row, col ).itemObject	:= overrideReason;
			self.cmbOverrideRsons.setObject( overrideReason );
		endif;
	else
		// clear any previously setup override reason
		col := _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).text			:= null;
			_table.accessCell( _row, col ).itemObject	:= null;
			self.cmbOverrideRsons.setObject( null );
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForOverrideUpdate" id="6ce31c05-cb91-4ee2-8b29-3b112a9f5784">
        <source>setRowForOverrideUpdate( _table : CM_DataTable input; _row : Integer ) protected;

/*
Purpose:	This allows the previously set Overridden Reason to be updated in the add/update table.

Date			Who		Reason
30 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	value				: Boolean;
	col					: Integer;
	
begin
	value	:= _table.getCellValueByName( ETRow_Update, _row ).Integer.Boolean;
	// if the Update checkbox is not on then ignore this combo.
	if not value then
		return;
	endif;
	
	// if this stop does not have an overridden reason set then ignore this table column click.
	col := _table.getColumnByRowName( ETRow_OverrideReason );
	if col &lt;&gt; null and _table.accessCell( _row, col ).text &lt;&gt; null then
		_table.accessCell( _row, col ).cellControl	:= self.cmbOverrideRsons;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForUpdate" id="f74d223c-f3f1-4710-a578-a4318347c217">
        <source>setRowForUpdate( _table : CM_DataTable input; _row : Integer ) protected;
// ---------------------------------------------------------------------------
// Created:     14 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	value			: Boolean;
	date			: Date;
	col				: Integer;
	overrideStr		: String;						// cnwrl1 30/08/2010 PAR 23697
	overridenReason	: CM_StopOverridenReason;		// cnwrl1 30/08/2010 PAR 23697
	stopsTable		: CM_StopsTable;				// cnwrl1 03/09/2010 PAR 23697
	
begin
	value := _table.getCellValueByName( ETRow_Update, _row ).Integer.Boolean;
	
	if value then
		// add and update are mutually exclusive
		_table.setCellValueByName( ETRow_Add, _row, 0.String );
		
		// can change expiry date while updating
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
			if stopsTable.allowClearanceExpiryDate then
				// stop can have a future clearance expiry - so enable input for the cell
				_table.accessCell( _row, col ).inputType	:= Table.InputType_EditMask;
				_table.accessedCell.editMask				:= app.getDateEditMaskForShortFormat;
			else
				_table.accessCell( _row, col ).cellControl	:= null;
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
		
		// cnwrl1 03/09/2010 PAR 23697 - start of coding
		// Can only change the overridden reason if it has already been set.
		overrideStr	:= _table.getCellValueByName( ETRow_OverrideReason, _row );
		if overrideStr &lt;&gt; null then
			col	:= _table.getColumnByRowName( ETRow_OverrideReason );
			if col &lt;&gt; null then
				_table.accessCell( _row, col ).inputType	:= Table.InputType_ComboBox;
			endif;
			// Make sure the override reason is set to the selected combo entry
			self.setOverrideReasonForRow( _table, _row, false );
			// can not change expiry date if an override reason exists
			col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
			if col &lt;&gt; null then
				_table.accessCell( _row, col ).cellControl	:= null;
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
		// cnwrl1 03/09/2010 PAR 23697 - end of coding
	else
		// can not change expiry date if not updating
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType		:= Table.InputType_None;
		endif;
		
		// make sure expiry date is set to current value for stop
		self.setExpiryDateForRow( _table, _row );
		
		// cnwrl1 24/08/2010 PAR 23697 - start of coding
		// Cannot change overridden reason and reset to current value if has been changed.
		col	:= _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
		endif;
		self.setOverrideReasonForRow( _table, _row, true );
		// cnwrl1 24/08/2010 PAR 23697 - end of coding
	endif;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTblClearCkboxesAndInputType" id="8c0f5d50-f552-495a-9d40-5c691a8103b6">
        <source>setTblClearCkboxesAndInputType(
	_checkboxStr	: String;
	_table			: CM_DataTable input;
	_row			: Integer ) protected;

/*
Purpose:	Only one of the 3 checkboxes on the clear table can be ON at any one time.
			This method will set the other 2 checkboxes off for the one selected and
			also disable for input any other columns that are not allowed plusr clearing data if appropriate.

Date				Who		Reason
02 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	col		: Integer;
	
begin
	if _checkboxStr = ETRow_Cancel then
		_table.setCellValueByName( ETRow_Clear, _row, null.String );
		_table.setCellValueByName( ETRow_Override, _row, null.String );
		
		// can not change any required info, expiry date or override reason
		col := _table.getColumnByRowName( ETRow_Input );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			// clear any previously setup Input details
			_table.accessCell( _row, col ).text			:= null;
		endif;
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			// clear any previously setup Expiry Date details
			_table.accessCell( _row, col ).text			:= null;
		endif;
		
		col := _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			// clear any previously setup Override Reason
			_table.accessCell( _row, col ).text			:= null;
			_table.accessCell( _row, col ).itemObject	:= null;
			self.cmbOverrideRsons.setObject( null );
		endif;
	
	elseif _checkboxStr = ETRow_Clear then
		_table.setCellValueByName( ETRow_Cancel, _row, null.String );
		_table.setCellValueByName( ETRow_Override, _row, null.String );
		
		// can not change the override reason
		col := _table.getColumnByRowName( ETRow_OverrideReason );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			// clear any previously setup Override Reason
			_table.accessCell( _row, col ).text			:= null;
			_table.accessCell( _row, col ).itemObject	:= null;
			self.cmbOverrideRsons.setObject( null );
		endif;
		
	elseif _checkboxStr = ETRow_Override then
		_table.setCellValueByName( ETRow_Cancel, _row, null.String );
		_table.setCellValueByName( ETRow_Clear, _row, null.String );
		// can not change required info and expiry date but leave the previously entered data
		col := _table.getColumnByRowName( ETRow_Input );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
		endif;
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
		endif;
		
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_checkboxStr" type="String"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e9f75f0b-bf4a-44e0-afc9-e9372bddc8ff">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti :CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	
	// make sure we have the selecetd TI in our coll
	self.allTrackedItems.addNoDuplicates (ti, false);
	
	inheritMethod();
	
	self.loadStops (ti);
	
	self.setCaption (ti.id);

	self.beginNotification (ti, Object_Update_Event, Response_Continuous, null);
	self.beginNotification (ti, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="33ba0c07-a080-49b7-95a9-b9472ffb9a8c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016220, locale);
end;</source>
    </JadeMethod>
</GUIClass>
