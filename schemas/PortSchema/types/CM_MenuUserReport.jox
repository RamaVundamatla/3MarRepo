    <JadeMethod name="getLevel" id="f8739cc2-b4e8-4243-bfc0-4d3ae65dd4fc">
        <source>getLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:     07 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myParent &lt;&gt; null then
		return self.myParent.getLevel +1;
	endif;	
	
	return 2;	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLineColour" id="848e0d01-2fd1-463f-b68d-e3bf436bd183">
        <source>getLineColour() : Integer;
// ---------------------------------------------------------------------------
// Created:     17 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.completedDateTime.isValid then
		return self.ROW_COLOUR_COMPLETED;
	
	elseif self.errorString = app.getErrorString(Report_Not_Yet_Processed) then
		return self.ROW_COLOUR_NOT_YET_PROCESSED;
	
	elseif self.errorString = self.MSG_NO_ITEMS_FOUND then
		return self.ROW_COLOUR_NOTHING_FOUND;
	
	elseif self.errorString = self.MSG_ERR_PROCESSING then
		return Red;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyUser" id="cd25f66b-c1c0-4b81-8874-afa9ce5db6af">
        <source>getMyUser() : CM_User;

// cnwdvb1 06 June 2003 

vars

	root : CM_MenuRoot;

begin

	root := self.getMyMenuRoot;
	if root = null or root.isKindOf(CM_MenuUserReportRootForRoot) then
		return null;
	endif;
	
	if root.isKindOf(CM_MenuRootUserBackgroundReps) then
		return root.CM_MenuRootUserBackgroundReps.myUser;
	endif;
	
	if root.isKindOf(CM_MenuRootUserTemplates) then
		return 	root.CM_MenuRootUserTemplates.myUser;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
