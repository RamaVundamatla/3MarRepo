<Class name="Object">
    <JadeMethod name="exportAttrIgnorePDXML" id="235c25fe-0010-4d35-9b1b-ce3b7a4e2ae6">
        <source>exportAttrIgnorePDXML(_attrName:String) :Boolean;
// ---------------------------------------------------------------------------
// Created:     March 2004	cnwrs1
//
// Purpose:		inherit and return true for any attributes you want ignored  
//			 
// ----------   ----------  --------------------------------------------------
//
vars

begin
	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportPDXML" id="44fea343-4ef8-4628-94d7-dc6aeb9c5620">
        <source>exportPDXML(_file:File; _objArray:ObjectArray io; _exportReferences, _exportCollections : Boolean);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	property: Property;
	propColl: PropertyNDict;
	object: Object;
	str, message: String;
	int: Integer;
	time: Time;
//	decimal: Decimal[5,2];
	real: Real;
	boolean: Boolean;
	binary: Binary;
	point: Point;
begin
	// check if we have already been called. if so bugger off. 
	if _objArray.includes(self) then
		return;
	else
		_objArray.add(self);
	endif;
	create propColl transient;
	self.class.getPropertiesAllSuperclassPD(propColl);
	_file.writeLine("&lt;" &amp; self.class.name &amp; "&gt;");
	if self.isKindOf(CMIF_Config) then
		_file.writeLine("&lt;theKey&gt;" &amp; self.CMIF_Config.myObject.theKey &amp; "&lt;/theKey&gt;");
	endif;	
	_file.writeLine("&lt;" &amp; self.class.name &amp; "Attributes&gt;");
	property := propColl[CM_Terminal.name];
	if property &lt;&gt; null and
	   not self.exportAttrIgnorePDXML(property.getName()) then
		_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).Object.theKey&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
//		_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
	endif;
	self.exportPDXMLCode(_file);
	foreach property in propColl do
		message := null;
		if (not property.isKindOf(Attribute)) or
//		   (not self.shouldAuditProperty(self.class, property)) or
		   (property.virtual) or 
		   self.exportAttrIgnorePDXML(property.getName()) or
		   property.name = CM_Terminal.name then
			continue;
		endif;
		
		if property.type = StringArray then
			foreach str in self.getPropertyValue(property.getName).StringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_StringArray then
			foreach str in self.getPropertyValue(property.getName).CM_StringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_LabelArray then
			foreach str in self.getPropertyValue(property.getName).CM_LabelArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_ConsignCodeArray then
			foreach str in self.getPropertyValue(property.getName).CM_ConsignCodeArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = HugeStringArray then
			foreach str in self.getPropertyValue(property.getName).HugeStringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = IntegerArray then
			foreach int in self.getPropertyValue(property.getName).IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_IntegerArray then
			foreach int in self.getPropertyValue(property.getName).CM_IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = PointArray then
			foreach point in self.getPropertyValue(property.getName).PointArray do
				message := message &amp; point.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_PointArray then
			foreach point in self.getPropertyValue(property.getName).CM_PointArray do
				message := message &amp; point.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = TimeArray then
			foreach time in self.getPropertyValue(property.getName).TimeArray do
				message := message &amp; time.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = DecimalArray then
			foreach real in self.getPropertyValue(property.getName).DecimalArray do
				message := message &amp; real.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = BooleanArray then
			foreach boolean in self.getPropertyValue(property.getName).BooleanArray do
				message := message &amp; boolean.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = BinaryArray then
			foreach binary in self.getPropertyValue(property.getName).BinaryArray do
//				write binary.String;
				message := message &amp; binary.ansiToString() &amp; ':';// 11/3/16  cnwns1 PAR 36286 unicode version
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif (property.type = TimeStamp or
			    property.type = Time or 
			    property.type = Date) and
			    self.getPropertyValue(property.getName) = null then
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		else
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		endif;
	endforeach;
	_file.writeLine("&lt;/" &amp; self.class.name &amp; "Attributes&gt;");
	
	if _exportReferences then
		_file.writeLine('&lt;' &amp; self.class.name &amp; 'References&gt;');
		self.exportPDXMLReferences(_file, _objArray);
		_file.writeLine('&lt;/' &amp; self.class.name &amp; 'References&gt;');
	endif;
	
	if _exportCollections then
		_file.writeLine('&lt;' &amp; self.class.name &amp; 'Collections&gt;');
		self.exportPDXMLCollections(_file, _objArray);
		_file.writeLine('&lt;/' &amp; self.class.name &amp; 'Collections&gt;');
	endif;
	
	_file.writeLine("&lt;/"&amp;self.class.name&amp;"&gt;");
//	write("&lt;/"&amp;self.class.name&amp;"&gt;");

epilog
	delete propColl;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLCode" id="866a904a-4d80-4c17-8762-b7f77572205d">
        <source>exportPDXMLCode(_file: File);

vars

begin

end;
</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLCollections" id="c3d6044d-8183-46ee-9fe5-0f621a0c2bde">
        <source>exportPDXMLCollections(_file:File; _objArray:ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	property: Property;
	propColl: PropertyNDict;
	object: Object;
	name: String;
begin
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	foreach property in propColl do
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
		object := self.getPropertyValue(property.getName()).Object;
		if object &lt;&gt; null and 
		   global.isValidObject(object) then
//write class.name&amp;'::'&amp;method.name&amp;" name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
			if not (object.isKindOf(Collection)) then
				continue;
			endif;
			self.exportPDXMLMyCollections(_file, _objArray, property, object);
		endif;
	endforeach;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLMyCollections" id="a9e81405-76c9-4f15-87ab-a2dd41841b3b">
        <source>exportPDXMLMyCollections(_file:File; _objArray:ObjectArray io; _property:Property; _object:Object);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     reimplement for indivual classes as necassary
//				the default action is to write out nothing
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	obj: Object;
	coll: Collection;
	iter: Iterator;
	objectSet: ObjectSet;
	str, message : String;
	int : Integer;
	time : Time;
	decimal: Decimal[5,2];
	boolean: Boolean;
	binary: Binary;
	point: Point;
begin
	_file.writeLine('&lt;'&amp;_property.getName&amp;'&gt;');
	coll := self.getPropertyValue(_property.getName).Collection;
	if coll &lt;&gt; null then
		if _property.type = StringArray then 
			foreach str in self.getPropertyValue(_property.getName).StringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = CM_StringArray then 
			foreach str in self.getPropertyValue(_property.getName).CM_StringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = CM_LabelArray then 
			foreach str in self.getPropertyValue(_property.getName).CM_LabelArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = CM_ConsignCodeArray then 
			foreach str in self.getPropertyValue(_property.getName).CM_ConsignCodeArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = HugeStringArray then
			foreach str in self.getPropertyValue(_property.getName).HugeStringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = IntegerArray then
			foreach int in self.getPropertyValue(_property.getName).IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = CM_IntegerArray then
			foreach int in self.getPropertyValue(_property.getName).CM_IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = PointArray then
			foreach point in self.getPropertyValue(_property.getName).PointArray do
				message := message &amp; point.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = CM_PointArray then
			foreach point in self.getPropertyValue(_property.getName).CM_PointArray do
				message := message &amp; point.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = TimeArray then
			foreach time in self.getPropertyValue(_property.getName).TimeArray do
				message := message &amp; time.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = DecimalArray then
			foreach decimal in self.getPropertyValue(_property.getName).DecimalArray do
				message := message &amp; decimal.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = BooleanArray then
			foreach boolean in self.getPropertyValue(_property.getName).BooleanArray do
				message := message &amp; boolean.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif _property.type = BinaryArray then
			foreach binary in self.getPropertyValue(_property.getName).BinaryArray do
//				write binary.String;
				message := message &amp; binary.ansiToString() &amp; ':';// 11/3/16  cnwns1 PAR 36286 unicode version
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
		elseif coll.isKindOf(VirtualColl) then
			create objectSet transient;
			coll.copy(objectSet);
			iter := objectSet.createIterator();
		else
			iter := coll.createIterator();
		endif;
		if iter &lt;&gt; null then
			while (iter.next(obj)) do
			if global.isValidObject(obj) then
				_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
				_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
			endif;
			endwhile;
		endif;
	endif;
	_file.writeLine('&lt;/'&amp;_property.getName&amp;'&gt;');
	
epilog
	delete iter;		// PAR #26678
		
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLMyReferences" id="0a526e65-9d22-429d-b477-007f4ae3299b">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     reimplement for indivual classes as necassary
//				the default action is to write out each non collection reference
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
//write("&lt;"&amp;property.getName&amp;"&gt;"&amp;object.Object.theKey&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
	_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;_object.Object.theKey&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLReferences" id="26e40ea8-39ce-45f8-97e4-32d77087465d">
        <source>exportPDXMLReferences(_file:File; _objArray:ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	property: Property;
	propColl: PropertyNDict;
	object: Object;
	name: String;
begin
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	foreach property in propColl do //write all the terminal refs first
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
		object := self.getPropertyValue(property.getName()).Object;
		if object &lt;&gt; null and 
		   global.isValidObject(object) then
//write " name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
			if (object.isKindOf(Collection)) then
				continue;
			endif;
			if object.isKindOf(CM_Terminal) then
				_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;object.Object.theKey&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
			endif;
		endif;
	endforeach;
	foreach property in propColl do //do all the rest this pass
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
		object := self.getPropertyValue(property.getName()).Object;
		if object &lt;&gt; null and 
		   global.isValidObject(object) then
//write " name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
			if (object.isKindOf(Collection)) then
				continue;
			endif;
			if not object.isKindOf(CM_Terminal) then
				self.exportPDXMLMyReferences(_file, _objArray, property, object);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handlePLXMLException" id="0cc0abbe-c50f-402c-8ee2-c1db6221e5c3">
        <updating/>
        <source>handlePLXMLException(_ex: Exception; _pName: String) : Integer updating;

vars

begin
	on NormalException do null global;

//	app.writeLog("&lt;"&amp;self.String&amp;"&gt;&lt;"&amp;_pName&amp;"&gt;",0);
	if _ex.errorCode = 75831 then
		return Ex_Resume_Next;
	endif;

    return Ex_Pass_Back;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_pName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importPLXML" id="098d942e-3191-49a0-b1ee-7a8677bba530">
        <updating/>
        <source>importPLXML(_classXMLname, _classBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	attributesBlock,
	referencesBlock,
	collectionsBlock: String;
begin

	attributesBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'Attributes');		
	referencesBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'References');
	collectionsBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'Collections');
			
	if attributesBlock &lt;&gt; null then
		self.importPLXMLMyAttributes(attributesBlock);
	endif;

	self.importPLXMLFixupPre();
		
	if referencesBlock &lt;&gt; null then
		self.importPLXMLMyReferences(referencesBlock);
	endif;
	
	if collectionsBlock &lt;&gt; null then
		self.importPLXMLMyCollections(collectionsBlock);
	endif;

	self.importPLXMLFixupPost();

end;</source>
        <Parameter name="_classXMLname" type="String"/>
        <Parameter name="_classBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLAttrName" id="635e9d61-eda8-4180-9259-f54714e4734c">
