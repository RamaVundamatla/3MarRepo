    <JadeMethod name="getSanitisedVoyageCode" id="d261cb59-caf1-4479-b0b6-950678e5efc0">
        <source>getSanitisedVoyageCode() : String;
//
// cnwrs1 feb 2008 dont allow the Null voyage to be used in cams messages.
//
vars
	str : String;
begin
	if self.voyage = NULL_VOYAGE_CODE then
		str := null;
	else
		str := self.voyage.trimRight;
	endif;
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageOperatorCode" id="2ead95e3-8fb2-4f6f-8a34-f53a1fcb5417">
        <source>getVoyageOperatorCode():String;
// ---------------------------------------------------------------------------
// Created:     21 March 2011 by cnwcs5 CCMS pnl 2057/ PAR 27231
// Returns:     Carrier for voyage or if NULL VYAGE then the 'No info carrier'
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2012	cnwcs5		par 29517 - use 'No info operator' for carrier if voyage is 'No info voyage'
// ---------------------------------------------------------------------------
vars
	voyage		:CM_Voyage;
	operator	:CM_Operator;
	result		:String;		// par 29517
begin
	voyage := self.voyageOid;
	
	if voyage = null then
		return null;
	endif;
	
	if voyage.code = NULL_VOYAGE_CODE then
		result := voyage.myTerminal.getDefaultOperatorCode;
	else	
		operator  := voyage.myOperator;
		
		if operator &lt;&gt; null then
			result := operator.code;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageVoyageCode" id="a2c60f40-9a28-4cc3-98a2-26fb36a7845a">
        <source>getVoyageVoyageCode() : String;
//
//25 May 2017	cnwrs1	TFS 4470
//
vars
	str : String;
begin
	if self.voyage = NULL_VOYAGE_CODE then
		str := null;
	else
		str := self.voyageCodeVoyOp.trimRight;
	endif;
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
