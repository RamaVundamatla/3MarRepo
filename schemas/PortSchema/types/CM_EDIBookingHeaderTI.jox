    <JadeMethod name="processAttributeDependencies" id="adae632b-b0fe-4055-ba7f-6a262c66c475">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
/*
// Date			Who		Reason
// 11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 20 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/
vars
	ediTI : CM_EDITrackedItem;
	str : String;
begin
	inheritMethod(_ediUserDefinedAssist ,_strIdentifier, _reset, _xlationOperator);
	if _reset then 
		foreach ediTI in _ediUserDefinedAssist.allChildrenEDITIs do
			str := str &amp; ediTI.String&amp;' ';
			if ediTI.id = null then
				ediTI.setId(self.id);
			endif;
			if ediTI.getBookingId() = null or
			   ediTI.isIdDefault then
				ediTI.setBookingId(self.getBookingId());
			endif;
		endforeach;
		_ediUserDefinedAssist.allChildrenEDITIs.clear;
	else
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setRawVoyageCode( self.getRawVoyageCode() );						// cnwrl1 11/06/2010 PAR 24299
		self.setTranshipOriginalVoyage( self.getTranshipOriginalVoyage() );		// cnwrl1 11/06/2010 PAR 24299
	endif;
epilog
	
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8c1d0306-6a4c-402c-aedf-1195d2871402">
        <updating/>
        <source>setForUpdate( _proxy : SelfType ) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
// 05/03/2013	cnwcs5	par 30849 - add carrierReference
// 28 May 2013	cnwrs1	Par 31596 add freight forwarder to EDI booking
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
vars
	
begin
	inheritMethod( _proxy );
	
	self.carrierCode 			:= _proxy.carrierCode;
	self.carrierReference		:= _proxy.carrierReference;				// par 30849 March 2013
	self.consignee 				:= _proxy.consignee;
	self.consignor				:= _proxy.consignor;
	self.freightForwarder := _proxy.freightForwarder;
	self.destinationPort 		:= _proxy.destinationPort;
	self.dischargePort 			:= _proxy.dischargePort;
	
	self.isStockBookingRef 		:= _proxy.isStockBookingRef;
	self.bookingRemarks 		:= _proxy.bookingRemarks;
	self.vesselName 			:= _proxy.vesselName;
	self.customerRef 			:= _proxy.customerRef;
	self.releaseRequestNumber 	:= _proxy.releaseRequestNumber.toUpper;	// just in case the users have entered lower case anywhere
	self.operatorCode 			:= _proxy.operatorCode.toUpper;			// just in case the users have entered lower case anywhere
	self.remarks 				:= _proxy.remarks;
	
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setRawVoyageCode( _proxy.getRawVoyageCode() );
	
	self.shippingRef 			:= _proxy.shippingRef;
	self.ediFileIssueDateTime	:= _proxy.ediFileIssueDateTime;
	
	// cnwrl1 18/02/2010 PAR 22393 - start of coding
	self.customsAgent			:= _proxy.customsAgent.toUpper;
	self.receiveAsTranship		:= _proxy.receiveAsTranship;

	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setTranshipOriginalVoyage( _proxy.getTranshipOriginalVoyage().toUpper );
	
	self.packAs					:= _proxy.packAs;		// cnwrl1 16/04/2010 PAR 23624
	self.stevedore              := _proxy.stevedore;    //02.10.2020 cnwma1 TFS #50112
epilog
	
end;
</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setRawVoyageCode" id="7d99cb96-4692-4fe5-8605-a2787917413d">
        <updating/>
        <source>setRawVoyageCode( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	value	:String;
	config	:CM_EDIConfig;
	coll	:CM_EDITIsByVoyageCodeDict;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	value 	:= self.rawVoyageCode.toUpper;
	config	:= self.myEDIConfig;
	// remove the previous non-null value from this collection
	if value &lt;&gt; null and config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
		
		if coll.includesKey( value, self ) then
			coll.removeKeyEntry( value, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	value				:= _value[ 1 : self.rawVoyageCode.maxLength ];
	self.rawVoyageCode	:= value;
	value				:= value.toUpper;
	
	if value &lt;&gt; null and coll &lt;&gt; null then
		if not coll.includesKey( value, self ) then
			coll.putAtKey( value, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTranshipOriginalVoyage" id="cdd053f3-39a2-4a1b-88e1-056504dfd3d2">
        <updating/>
        <source>setTranshipOriginalVoyage( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
	
vars
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.transhipOriginalVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.transhipOriginalVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.transhipOriginalVoyage.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.transhipOriginalVoyage	:= _value[ 1 : self.transhipOriginalVoyage.maxLength ];
	if not self.isTransient and
	   self.transhipOriginalVoyage &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.transhipOriginalVoyage.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.transhipOriginalVoyage.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="df96791e-3cec-4e30-a50e-9d23ff2e43cc">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
*/
//24 jul 2013	cnwrs1	Par 32048 - dont allow no voyage bookings to be loaded	
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	if code = null then	//24 jul 2013	cnwrs1	Par 32048 - dont allow no voyage bookings to be loaded	
		code := self.getMyTerminal().getNullVoyage().code;
	endif;
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
