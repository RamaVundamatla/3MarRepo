<Class name="CMQF_WOTransactions">
    <JadeMethod name="setFromAgent" id="041567a1-02c1-403b-aea7-75cf8957fd3f">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error
14 Aug 2023   navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
20 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/
vars
	
	aTime		: Time;
	string 		: String;
	dateStr 	: String;
	tplType 	: Integer;
	tplFactor 	: Integer;
	
begin
	inheritMethod(_agent);
	
	aTime := null;
		
	if _agent.state = _agent.STATE_TEMPLATE_SAVE or  _agent.state = _agent.STATE_TEMPLATE_EDIT then
		
		if _agent.isRowIncluded(ETRow_StartDate) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_StartDate), 
								self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
		elseif _agent.isRowIncluded(ETRow_DateFromWO) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DateFromWO), 
								self.startDateTplType, self.startDateTplFactor, ETRow_DateFromWO);
		endif;
		
		if _agent.isRowIncluded(ETRow_EndDate) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_EndDate), 
								self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);
		elseif _agent.isRowIncluded(ETRow_DateToWO) then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DateToWO), 
								self.endDateTplType, self.endDateTplFactor, ETRow_DateToWO);
		endif;
	
	else
		
		if _agent.isRowIncluded(ETRow_StartDate) then
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
		elseif _agent.isRowIncluded(ETRow_DateFromWO) then												//19.06.2024 navhl20 #64718
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_DateFromWO);					//19.06.2024 navhl20 #64718
		endif;
		
		
		if _agent.isRowIncluded(ETRow_EndDate) then
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_EndDate);
		elseif _agent.isRowIncluded(ETRow_DateToWO) then												//19.06.2024 navhl20 #64718
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_DateToWO);						//19.06.2024 navhl20 #64718
		endif;
		
	
	endif;
	
	if _agent.isRowIncluded(ETRow_TimeFromWO) then
		aTime := _agent.getValueByName(ETRow_TimeFromWO).Time;	
	endif;
	
	if aTime.isValid then
		self.startTime.setTime(aTime.hour, aTime.minute, aTime.second, 0);
	else
		self.startTime.setTime(0, 0, 0, 0);
	endif;
	
	aTime := null;
	if _agent.isRowIncluded(ETRow_TimeToWO) then
		aTime := _agent.getValueByName(ETRow_TimeToWO).Time;
	endif;
	
	if _agent.isRowIncluded(ETRow_WorkOrderId) then
		self.workOrderId := _agent.getValueByName(ETRow_WorkOrderId).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_TrainCode) then
		self.train := _agent.getValueByName(ETRow_TrainCode).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_VoyageCodeWO) then
		self.voyage := _agent.getValueByName(ETRow_VoyageCodeWO).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_VVRCodeWO) then
		self.vehicleVisitRecord := _agent.getValueByName(ETRow_VVRCodeWO).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_TruckPlateNoWO) then										//20.06.2024 navhl20 #64718
		self.truckPlateNumber := _agent.getValueByName(ETRow_TruckPlateNoWO).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_VBSCodeWO) then
		self.vehicleBookingSlot := _agent.getValueByName(ETRow_VBSCodeWO).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_RRNumberWO) then
		self.releaseRequestNumber := _agent.getValueByName(ETRow_RRNumberWO).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_WagonCodeWO) then
		self.wagon := _agent.getValueByName(ETRow_WagonCodeWO).String;
	endif;
	
	self.allToDoTaskDescs.clear;												//14.8.2023 navhl20 #59284[59664]
	if _agent.isRowIncluded(ETRow_TskType) then
		_agent.getSelectedToDoTaskDescs(self.allToDoTaskDescs);
	endif;
	
	if aTime.isValid then
		self.endTime.setTime(aTime.hour, aTime.minute, aTime.second, 0);
	else
		self.endTime.setTime(0, 0, 0, 0);
	endif;
	
	
	self.allTransTypes.clear;
	if _agent.isRowIncluded(ETRow_AllWOTransTypes) then
		_agent.getSelectedWOTransTypes(self.allTransTypes);
	endif;
	
	self.allUsers.clear;
	if _agent.isRowIncluded(ETRow_AllUsers) then
		_agent.getSelectedUsers(self.allUsers);
	endif;
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
