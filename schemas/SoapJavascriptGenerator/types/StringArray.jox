<CollClass name="StringArray">
    <JadeMethod name="stringify" id="6ace037c-8a20-4050-a6f5-08663f2356c2">
        <source>stringify():String;

vars
	s,t : String;
begin
	foreach t in self do
		s := s &amp; t &amp; CrLf;
	endforeach;
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
