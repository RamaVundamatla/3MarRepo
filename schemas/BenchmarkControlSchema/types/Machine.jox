    <JadeMethod name="hostNameShort" id="c1820780-5dbd-40b8-9f21-317b350f6dec">
        <source>hostNameShort():String;

begin
	return hostName.replace("cnwchc",null).replace("wynchc",null);
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="queuesUpdatedInDb" id="65a522dd-4fa6-4bf8-a327-3695ee470c2d">
        <updating/>
        <source>queuesUpdatedInDb(queues:String):Boolean updating;

vars
	i,j:Integer;
	s,t:String;
	sa:StringArray;
	ok:Boolean;
begin
	i:=1;
	create sa transient;
	t:=queues.toLower&amp;";";  // allow for ill-formed string
	while i &lt; t.length do
		s:=t.scanUntil(";", i); i:=i+1;
		if s.trimBlanks &lt;&gt; null then
			sa.add(s);
		endif;
	endwhile;
	
	self.queuesToProcess.purge;
	foreach s in sa do
		self.queuesToProcess.add(s);
	endforeach;
	ok:=true;
epilog
	delete sa;
	return ok;
end;
</source>
        <Parameter name="queues" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="respondsToPing" id="a64bf0a3-0246-4010-bf08-3ab08b84dc84">
        <executionLocation>server</executionLocation>
        <source>respondsToPing():Boolean serverExecution;

vars
	ph:PingHost;
begin
	create ph;
	return ph.pingHim(hostName.StringUtf8) = 99;
epilog
	delete ph;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setQueuesFromConf" id="7c423777-61f5-4bd4-b7c2-c090a1341d20">
        <updating/>
        <source>setQueuesFromConf() updating;
//	This updates all queuesToProcess from the machine's .conf file
vars
	f:File;
	s,t,queues,oldQueues,queue:String;
begin
	// show the user the current list
	foreach queue in self.queuesToProcess do
		queues:=queues&amp;queue&amp;";";
	endforeach;
	oldQueues:=queues;

	//get the list from the config file
	create f transient;
	f.usePresentationFileSystem:=false;
	f.fileName:=app.miscPath&amp;"\QueueLists\"&amp;self.hostName&amp;".conf";
	s:=f.readString(f.fileLength);
	queues:=s.getXMLValue("queuestoprocess");
	f.close;
	
	if queues &lt;&gt; null and queuesUpdatedInDb(queues) then
		app.logMessage(process.getUserCode[4:3]&amp;' changed queues for '&amp;self.hostName&amp;' from '&amp;oldQueues&amp;' to '&amp;queues);
	endif;/**/
epilog
	delete f;
end;
</source>
    </JadeMethod>
</Class>
