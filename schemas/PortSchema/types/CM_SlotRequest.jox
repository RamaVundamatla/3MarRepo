    <JadeMethod name="removeSurplusWLE" id="37c96feb-4970-47c7-919b-b4799f1e6fba">
        <updating/>
        <source>removeSurplusWLE() updating;
// ---------------------------------------------------------------------------
// Created:		23 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aWLE : CM_WorkListEntry;
	numTI : Integer;
	objectSet : ObjectSet;
begin
	// PAR 15293, a Load colour code should not have more than one WLE, if it has, then delete all the empty WLEs i.e. the ones without a TI
	// However there must be at least 1 WLE with a TI before we delete the WLEs
	// Load WLEs do not have a TI until teh TI has been planned to it.
	 if self.isLoad then
		if self.allWorkListEntries.size &gt; 1 then
			create objectSet transient;
			foreach aWLE in self.allWorkListEntries discreteLock do
				if aWLE.myTrackedItem &lt;&gt; null then
					numTI := numTI + 1; // It must have 1 or more TIs
				else
					objectSet.add(aWLE);
				endif;
			endforeach;
		endif;
	endif;
epilog
	if objectSet &lt;&gt; null and numTI &lt;&gt; 0 then
		objectSet.purge;
		delete objectSet;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="4d42e395-5e71-4cb5-abe6-03a1adbca3de">
        <updating/>
        <source>removeWLE(_wle : CM_VoyageWLE io; _ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		removes a WLE from the request. IF you do not know the WLE then pass in the TI instead
// ---------------------------------------------------------------------------

vars
	jobType: Integer;
	associatedRequest: CM_SlotRequest;
	tmpLC: CM_LocationsController;
	aWLE, removeWLE : CM_WorkListEntry;
begin

	if _wle &lt;&gt; null then
		if self.allWorkListEntries.includes(_wle) then
			_wle.erase(NORMAL_ERASE);
		endif;
	else
		if _ti = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_NO_WLE_TI, self.myJob.jobId, null, null);
			return;
		endif;
		removeWLE := null;
		foreach aWLE in self.allWorkListEntries do
			if aWLE.myTrackedItem = _ti then
				removeWLE := aWLE;
				break;
				
			endif;
		endforeach;
		if removeWLE &lt;&gt; null then
			removeWLE.erase(NORMAL_ERASE);
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="set40AttribsFromFrontEnd" id="fbf877c2-4c3a-4290-aabb-0d5ee6a70605">
        <updating/>
        <source>set40AttribsFromFrontEnd(_fromSR : CM_SlotRequest) updating;
/*
------------------------------------------------------------------------
Created:			07 March 2003 by cnwdwq1
Purpose:			Copies the attributes of a passed in slot request
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	is40 : Boolean; //cnwas3 PAR 24273
		voyAlloc : CM_VoyageAllocation;
begin
	if _fromSR = null then // PAR7592 AKB2004FEB
		app.raiseCMException2(MethodWithNullParam,self.class.name &amp; "::" &amp; method.name,"Master Slot Request", null, null); // PAR7592 AKB2004FEB
		return; // PAR7592 AKB2004FEB
	endif;
	//------------------------
	// Replicate the contents of me
	//------------------------
	is40 := _fromSR.getAttrIs40();		//cnwas3 PAR 24273
	if is40				//cnwas3 PAR 24273 
	or _fromSR.isOversizedFrontend() then
		if self.mySlotRequestForward = null then
			self.mySlotRequestForward := _fromSR;
		endif;
	else
		self.mySlotRequestForward := null;
	endif;
	
// PAR 25636	if _fromSR.allAllocations.size() &gt; 0 then
	if _fromSR.useVoyageAllocations then
		voyAlloc := _fromSR.allAllocations.first.CM_VoyageAllocation;
		if voyAlloc &lt;&gt; null and voyAlloc.isColourCodedForLength() &lt;&gt; 0 then
			self.isBackend := true;
		endif;
		
		return;
	endif;
	
	self.myCargoType := _fromSR.getAttrCargoType();
	self.myCommodityGroup := _fromSR.getAttrCommodityGroup();
	self.myDischargePort := _fromSR.getAttrDischargePort();
	
	self.commodity := _fromSR.commodity;
	self.dischargePort := _fromSR.dischargePort;
	self.doorsDirection := _fromSR.doorsDirection;
	self.empty := _fromSR.getAttrEmpty();
	
	 // PAR 16415 CCMS 1029
	self.is30 := _fromSR.getAttrIs30();
	self.is45 := _fromSR.getAttrIs45();
	self.is53 := _fromSR.getAttrIs53();
	if self.is53 then	//cnwas3 PAR 24273
		self.is30 := false;
		self.is45 := false; // PAR 18682 CCMS SFW 1055
		self.fortyBack := false;
		self.fortyFront := false;
		self.isBackend := true;
	endif;
	if _fromSR.getAttrIs30()  then
		self.is53 := false;
		self.is45 := false; // PAR 18682 CCMS SFW 1055
		self.isBackend := true;
		self.fortyBack := false;
		self.fortyFront := false;
	endif;
	
	 // PAR 18682 CCMS SFW 1055
	if _fromSR.getAttrIs45()  then
		self.is30 := false;
		self.is53 := false;
		self.isBackend := true;
		self.fortyBack := false;
		self.fortyFront := false;
	endif;
	
	is40 := _fromSR.getAttrIs40();		//cnwas3 PAR 24273
	if is40 then				//cnwas3 PAR 24273
		self.fortyBack := true;
		self.fortyFront := false;
		self.is30 := false;
		self.is53 := false;
		self.isBackend := false;
	else
		self.fortyBack := _fromSR.fortyBack;
		self.fortyFront := is40;			//cnwas3 PAR 24273
	endif;
	self.halfHeight := _fromSR.getAttrHalfHeight();
	self.flat := _fromSR.getAttrFlatRack();
	self.tank := _fromSR.getAttrTank();
	self.crib := _fromSR.getAttrCrib();
	self.frame := _fromSR.getAttrFrame();	//05 Feb 2018	NDL	TFS 36752
	self.opentop := _fromSR.getAttrOpenTop();
	self.fantainer := _fromSR.getAttrFantainer();
	self.hazardous := _fromSR.getAttrHazardous();
	self.highCubed := _fromSR.getAttrHiCubed();
	self.motorDirection := _fromSR.motorDirection;
	self.setMoveType(_fromSR.moveType);
	self.overDimension := _fromSR.getAttrOverDimensioned();
	self.power := _fromSR.getAttrPowerRequired();
// PAR7496 AKB2004FEB		self.reefer := _fromSR.reefer;
	self.unavailable := _fromSR.unavailable;
	self.waterCooled := _fromSR.getAttrWaterCooled();
	
	
end;</source>
        <Parameter name="_fromSR" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="setCustomSeqNumber" id="4b6e7220-8d9f-4354-bad3-b9419f236c2e">
