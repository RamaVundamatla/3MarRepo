    <JadeMethod name="canBeConfirmed" id="c68eee31-7732-49de-ad5f-23c1f55bef53">
        <source>canBeConfirmed() : Boolean;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagon 	: CM_Wagon;
begin
	foreach wagon in self.allWagonsByIdInward discreteLock do
		if wagon.myRailLine = null then
			return false;
		endif;
	endforeach;

	return true;


epilog

end;</source>
