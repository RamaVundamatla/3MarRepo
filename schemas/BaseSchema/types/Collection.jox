    <JadeMethod name="cnEcGetMemberType" id="7e656a25-085b-40cc-a0cf-17cbb66e904c">
        <source>cnEcGetMemberType():Type;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Type of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Type of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.class().CollClass.getMemberType();
end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsNotEmpty" id="cee35108-65cc-41ff-9c4a-440c908690e0">
        <source>cnEcIsNotEmpty():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		To check whether the receiver has any members.
//
// Parameters:	None
//
// Returns:		True if the receiver has any members, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isEmpty());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMove" id="d7af75b5-6af4-4926-887f-a6805082138e">
        <lockReceiver/>
        <updating/>
        <source>cnEcMove(pTargetCollObj:Collection input):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		19 April 2005 by cnwdad1
//
// Purpose:		Moves the receiver's members into the specified collection (parameter).
//
// Parameters:	pTargetCollObj - A reference to the collection to move the receiver's
//					members into.
//
// Returns:		True if the move was successful, otherwise false, and the populated
//				collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	
	self.copy(pTargetCollObj);
	self.clear();
	
	isSuccessful	:=	true;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTargetCollObj" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
