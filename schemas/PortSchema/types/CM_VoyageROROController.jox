    <JadeMethod name="getLoadPlannedTIs" id="9a058e2f-2df1-4484-bf38-81a9e81657ad">
        <source>getLoadPlannedTIs(_currentTIs : CM_TIArray input);
/*
Date		    Who			Reason
27 October 2011	cnwas3	  Initial creation: par 28545
*/

vars
	tis			: CM_TIArray;
	allWLETIs	: CM_TISet;			
	sr			: CM_RORORequest;
	ti			: CM_TrackedItem;
	fm			: CM_FutureMove;
	include		: Boolean;
begin	
	
	
	create tis transient;
	create allWLETIs transient;

	
	foreach sr in self.allRequestsLoad do
		sr.getAllUnworkedTIs(tis);	
		foreach ti in tis do
			if ti.allPlannedFutureMoves.isEmpty then			
				if not _currentTIs.includes(ti) then
					_currentTIs.add(ti);
				endif;
			elseif not allWLETIs.includes(ti) then
				allWLETIs.add(ti);
			endif;
		endforeach;
	endforeach;	
	foreach ti in allWLETIs do
		include := false;
		foreach fm in ti.allPlannedFutureMoves do
			if not CM_FutureMovePlanned.hasInstance(fm) 
			or CM_FutureMovePlannedEDI.hasInstance(fm) then 
				continue;
			endif;
			
			if fm.CM_FutureMovePlanned.allLocationsControllers.includes(self) then				
				include := true;
				break; 
			else			
				include := false;
			endif;
		endforeach;

		if include then			
			if not _currentTIs.includes(ti) then
				_currentTIs.add(ti);
			endif;
		else			
			if _currentTIs.includes(ti) then
				_currentTIs.remove(ti);
			endif;
		endif;
		
	endforeach;

epilog
	delete tis;
	delete allWLETIs;
end;</source>
        <Parameter name="_currentTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
