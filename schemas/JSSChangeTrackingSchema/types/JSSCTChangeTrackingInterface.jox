    <JadeMethod name="finalizeChangeTracker" id="0384e905-670f-49d1-a788-5c7877e5ab12">
        <updating/>
        <source>finalizeChangeTracker() updating;
/*
//09 Dec 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
*/
begin
	if self.myNibblerManager &lt;&gt; null then
		self.myNibblerManager.finalize();
		self.unlock(self.myNibblerManager.myPersistentInstance);
	endif;
	delete self.myNibblerManager;
	delete self.mySelectionManager;
	delete self.myJadeLog;

	delete self;
end;</source>
    </JadeMethod>
