    <JadeMethod name="create" id="bad06d79-87fb-4551-a2ff-de0ab846a717">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 12 	PJS			PAR # 30631 Voyage rationalisation
// ---------------------------------------------------------------------------

vars

begin

	// 30631 - no longer on menu - so permissions rolled into order of work

	self.permissionView  := PmAdmOrdworkView;
	self.permissionMaint := PmAdmOrdworkMaint;
	
	self.helpFileName := HelpFile_Voyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="bf9a277d-4cb1-4995-88ca-72ba66f92d7a">
        <updating/>
        <source>doCmbVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	
	self.cmbVoyage.clear;
	self.cmbVoyage.sorted := true;
	
	create theVoyages transient;
	if app.isAllowedToInspect then
		self.myTerminal.allVoyagesByCode.copy(theVoyages);
	else
		self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);
	endif;
	foreach aVoyage in theVoyages do
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;	
		idx := self.cmbVoyage.addItem(aVoyage.getDisplayDetails(false));
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();
	
	if aVoyage &lt;&gt; null then
		self.setCaption(aVoyage.description.trimBlanks &amp; " " &amp; app.getErrorString(PlanningGuide));
		self.setNavigatorHeading(self.caption);
		idx := self.cmbVoyage.findObject(aVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listIndex := idx;
		endif;
	else
		self.setNavigatorHeading(app.getErrorString(PlanningGuide));
	endif;
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageClick" id="593bb3e4-1cce-4af4-a038-498ead750363">
        <updating/>
        <source>doComboVoyageClick() updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	lblString : String;
	aBay : CM_Bay;
	i : Integer;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Delete_Event));
		
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(BayRemarks_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(RORODeckRemarks_Event));
	endif;
	self.myCurrentVoyage := self.cmbVoyage.listObject.CM_Voyage;
	
	//app.myCurrentVoyage := self.myCurrentVoyage;
	//cnwjo3 par 23105
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Create_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Delete_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(BayRemarks_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(RORODeckRemarks_Event), Response_Continuous, null);
		lblString := app.getErrorString(PlanningGuide) &amp; " "  &amp; self.myCurrentVoyage.code.trimBlanks &amp; " " &amp; self.myCurrentVoyage.description.trimBlanks;
	else
		lblString := app.getErrorString(PlanningGuide) &amp; " ";
	endif;
	
	self.setCaption(lblString);
	self.setNavigatorHeading(lblString);
	self.doQuery();
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="a5f2b841-24c3-485a-936a-8f53a91b128d">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.inspectModal;
	else
		inheritMethod();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="2df05747-8b11-41ad-a32c-d7b172e61a38">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="777b1626-e59d-458b-8d21-78dd8ddefa3d">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	pxyJadeReport	: JadeReport;

	theReturn : Integer;
	theLeft : Real;
	theReport : CMUI_ReportLine;
	theString : String;
	theVoyage : CM_Voyage;
	lNow : TimeStamp;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.myCurrentVoyage = null then
		return;
	endif;
	lNow := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	theVoyage := self.myCurrentVoyage;

	create pxyJadeReport transient;

	create theReport;
	theReport.initReport;
	theReport.initReportForLandscape;
	
	theReport.lblTitle01.caption :=  "Planning Guide ";
	theReport.lblTitle02.caption :=  self.systemToLocalTime(lNow).asStringJMT;	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support

	theReport.lblTitle04.caption :=  app.getMyUserCode;

	if theVoyage &lt;&gt; null then
		theString := theVoyage.code &amp; " (" &amp; theVoyage.vesselCode &amp;")";
		theReport.lblTitle03.caption :=  theString;
		theReport.lblPrintedBy.caption := self.systemToLocalTime(theVoyage.arrivedDT).asStringJMT;	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
		theReport.lblPrintedBylbl.caption :=  "Estimated Time Of Arrival";
	else
		theReport.lblTitle03.caption :=  self.myCurrentVoyage.code &amp; " " &amp; self.myCurrentVoyage.description;
	endif;
	
	app.printer.setReport(pxyJadeReport);
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.printPreview := false;
	app.printer.suppressDialog := true;
	app.printer.setMargins(Print_Landscape,1,1,1,1);
	self.doPrintTableData();
	app.printer.close();
	app.printPreview(pxyJadeReport, true);
epilog
	self.caption := "Planning Guide " &amp; self.myCurrentVoyage.code &amp; " " &amp; self.myCurrentVoyage.description;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintTableData" id="89a79721-500c-4b49-aad4-1367ae653e06">
        <source>doPrintTableData();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	LEFT_START = 15;
	COL_COUNT = 30;
vars
	lRow, lCol, colStart,idx,colCount, lLeft, newPage : Integer;
	lLine : String;
	lControl : Control;
	lNow : TimeStamp;
	theEnd : Boolean;
	lFontSize, lScale2, lWidth, lWidth2 : Real;
	lScale : Decimal[9,6];
begin
	
	self.doPrintTableInit();
	lNow := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	lLeft := LEFT_START;
	foreach lCol in 1 to self.tblData.columns do
		lLeft := lLeft + self.tblData.accessColumn(lCol).width;
	endforeach;
	if lLeft &lt;= self.frmReport.width then
		lFontSize := self.tblData.fontSize;
		lScale := 1;
	else
		lFontSize := self.tblData.fontSize;
		lScale := 1;
	endif;

	lLeft := 0;
	foreach lCol in 1 to COL_COUNT do
		lControl :=  self.lblReport.getControl(lCol);
		if lControl = null then
			lControl := self.lblReport.loadControl(lCol);
		endif;
		lControl.width := 32;
		if lCol = 1 then
			lControl.width := 120;
		endif;
		lControl.left := lLeft;
		lLeft := lLeft + lControl.width.Integer - 1;
		lControl.height := 16;
		lControl.top := 0;
		lControl.fontName := "Arial";
		lControl.Label.caption := null;
		lControl.fontSize := lFontSize * lScale;
		lControl.visible := true;
		lControl.enabled := true;
		lControl.backColor := White;
		lControl.parent := self.lblReport.parent;
		lControl.foreColor := Black;
		lControl.borderStyle := Window.BorderStyle_Single;
		if lCol &gt; 1 then
			lControl.Label.alignment := Label.Alignment_Center_Top;
		endif;
	endforeach;

	colStart := 2;
	colCount := self.tblData.columns;
	if colCount &gt; COL_COUNT then
		colCount := COL_COUNT;
	endif;
	while true do : outerLoop
	
		newPage := newPage + 1;
		foreach lRow in 1 to self.tblData.rows do
			// ignore any hidden rows
			if not self.tblData.accessRow(lRow).visible then
				continue;
			endif;
			lLine := null;
			idx := 1;

			// always print the 1st column labels
			lControl := self.lblReport.getControl(1);
			lControl.Label.caption := " " &amp; self.tblData.accessCell(lRow,1).text;
			lControl.fontBold := true;
			
			foreach lCol in colStart to colCount do : colLoop
				idx := idx + 1;
				lControl := self.lblReport.getControl(idx);
				if lControl = null then
					break colLoop;
				endif;
				lControl.Label.caption := "";
				// ignore any hidden columns
				
				if self.tblData.columns &lt; lCol or  not self.tblData.accessColumn(lCol).visible then
					lControl.borderStyle := Window.BorderStyle_None;
					theEnd := true;
					continue;
				endif;

				lControl.Label.caption := self.tblData.accessCell(lRow,lCol).text;

				if lRow &lt;= self.tblData.fixedRows then
					lControl.fontBold := true;
				else
					lControl.fontBold := false;
				endif;
				
				// only so many columns per page
				if lCol = colCount then
					break colLoop;
				endif;
			endforeach; // colLoop
			
			// NOTE: in the print the numbers are printed in a grid. This is done by setting the cloned labels' border to 'single'
			//	However this creates a thick double line between each line. SO we clip the bottom of the cloned label by reducing the size of the frmReport
			//	However this leaves the last line with no line, so on the last line we raise the height of the frame by 1
			if lRow = Row_Remarks then
				self.frmReport.height := 16;
			else
				self.frmReport.height := 15;
			endif;				
			app.printer.print(self.frmReport);
		endforeach; // row

		if colCount &gt; self.tblData.columns then
			break outerLoop;
		endif;
		if newPage = 2 and not theEnd then
			newPage := 0;
			app.printer.newPage();
		endif;

		colStart := colCount + 1;
		if colCount mod COL_COUNT = 0 and colCount &lt; self.tblData.columns then
	 		colCount := colCount + COL_COUNT;
			self.doPrintTableNull();
	 	else
	 		break outerLoop;
	 	endif;
	endwhile; // outerLoop
epilog
	
	foreach lCol in 1 to self.tblData.columns do
		lControl := self.lblReport.getControl(lCol);
		if lControl &lt;&gt; null then
			delete lControl;
		endif;
	endforeach;

	self.frmReport.visible := false;
	self.lblReport.visible:= false;
	app.printer.close;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintTableInit" id="aa04636a-51d5-402e-a078-f36f8af65d2d">
        <source>doPrintTableInit();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	LEFT_START = 15;
	COL_COUNT = 33;
vars
	lNow : TimeStamp;

begin
	lNow := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if app.printer.orientation = Print_Landscape then
		self.frmReport.width := 1100;
	else
		self.frmReport.width := 690;
	endif;
	self.frmReport.height := 15;
	self.frmReport.top := 0;
	self.frmReport.left := LEFT_START;
	self.frmReport.visible := true;
	self.frmReport.backColor := White;
	self.frmReport.boundaryWidth := 0;
	self.frmReport.bevelInnerWidth := 0;
	self.frmReport.bevelOuterWidth := 0;

	self.lblReport.width := self.frmReport.width;
	self.lblReport.top := 0;
	self.lblReport.left := 0;
	self.lblReport.height := self.frmReport.height;
	self.lblReport.visible := true;
	self.lblReport.caption := null; //lNow.String &amp; " Planning Guide " &amp; app.getMyUserCode;
	self.lblReport.fontBold := true;
	self.lblReport.backColor := White;
	self.lblReport.foreColor := Black;
	self.lblReport.fontName := "Arial"; //self.tblData.fontName;
	self.lblReport.fontSize := 10;
//	app.printer.print(self.frmReport);
//	self.lblReport.caption := null;
//	app.printer.print(self.frmReport);
	self.lblReport.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintTableNull" id="2550b0c6-e55a-447b-be2f-11b45f23d010">
        <source>doPrintTableNull();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE: in the print the numbers are printed in a grid. This is done by setting the cloned labels' border to 'single'
//						However this creates a thick double line between each line. SO we clip the bottom of the cloned label by reducing the size of the frmReport
//						However this leaves the last line with no line, so on the last line we raise the height of the frame by 1
// ---------------------------------------------------------------------------
vars
	lControl : Control;
	lCol : Integer;
	lastPoint : Integer;
begin

	foreach lCol in 1 to 100 do : colLoop
		lControl := self.lblReport.getControl(lCol);
		if lControl = null then
			break colLoop;
		endif;
		lControl.Label.visible := false;
//		if lControl.Label.caption &lt;&gt; null then
//			lastPoint := (lControl.left + lControl.width).Integer;
//		endif;
	endforeach;
	self.lblReport.caption := null;
	self.frmReport.caption := null;
//	self.frmReport.autoRedraw := true;
//	self.frmReport.drawLine(0,0,lastPoint,1,Black);
	
	app.printer.print(self.frmReport);
//	self.frmReport.autoRedraw := false;

	self.lblReport.visible := false;
	foreach lCol in 1 to 100 do : colLoop
		lControl := self.lblReport.getControl(lCol);
		if lControl = null then
			break colLoop;
		endif;
		lControl.Label.visible := true;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessBayRefreshTimer" id="d94beaa5-c972-4b4b-9d6b-91b8af3b71aa">
        <updating/>
        <source>doProcessBayRefreshTimer() updating, protected;

/*

Purpose:			Process the required refresh on any of the queued bays

Parameters:			None

Return Value:		None


Date		Who		Reason
08 Jun 2010	cnwkpd1	PAR #21995 - System performance enhancements
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	theGuide 		: CMIF_PlanningGuideBay;
	theVoyage 		: CM_Voyage;
	theBay 			: CM_BayVoyage;
	idx 			: Integer;
	doUpdate,
	invalidBay,
	invalidVoyage	: Boolean;
	id40			: String;
	cellStruct		: CM_CellularVoyageStructure;
	currentVoyage	: CM_Voyage;
begin
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage);
	cellStruct := currentVoyage.myCellularVoyageStructure;
	
	if invalidVoyage then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, theBay, invalidBay);
	
	foreach theBay in self.allBaysToUpdate do
	
		idx := 0;
		self.tblData.findObjectInColumn(theBay, idx);
		if idx &gt; self.tblData.fixedColumns then
			
			delete theGuide;
			create theGuide transient;
			self.doQueryUpdateBayColumn(theBay, theGuide, idx);

			//### AKB2005JUNE
			if theBay.canHandle4045() then
				id40 := theBay.idBay40.trimBlanks();
				
				if id40 &lt;&gt; null then
					theGuide.id := id40;
					theGuide.is40Bay := true;
					cellStruct.getPlanningGuideForBay(theGuide);
					theGuide.id := "[" &amp; id40 &amp; "]";
					self.doQueryDisplayBay(theGuide, idx + 1);
				endif;
			endif;
			//###	

			doUpdate := true;
		endif;
		
	endforeach;
	
	// If we actually changed any bay, then update the totals just once
	if doUpdate then
		self.doQueryUpdateTotals();
	endif;

	self.doResetBayRefreshTimer();
	

epilog
	delete theGuide;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="ea57a423-d611-466a-acac-f2d2c0684c5d">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Jun 2010	cnwkpd1		PAR #21995 - Ship Planning Guide performance
// ---------------------------------------------------------------------------
constants
	TimeBetweenRefreshes	= 3000;
	
vars
	loadTotal, 
	dischTotal,
	numBays,
	idx,
	theCol,
	aftTotal, 
	fwdTotal, 
	perCent, 
	totBays,
	bayCnt,
	roroDecks,
	deckCount,
	bridgeCol 				: Integer;
	theGuide 				: CMIF_PlanningGuideBay;
	structure 				: CM_CellularVoyageStructure;
	theBay	 				: CM_BayVoyage;
	theDeck,theSubDeck		: CM_DeckVoyage;
	bridgeUp 				: Boolean;
	tmpStr                  : String;
	processStackArray       : ProcessStackArray;
	methodCallDesc          : MethodCallDesc;
	lastRefresh				: Decimal[20];
	id40					: String;
	roroStructure 			: CM_ROROVoyageStructure;
	

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if self.myCurrentVoyage = null then
		return;
	endif;

	// PAR 21787
	create processStackArray transient;
	process.currentStack(processStackArray);

	if processStackArray.size &gt; 2 then
		methodCallDesc := processStackArray[3];
		tmpStr := methodCallDesc.method.qualifiedName;
	else
		tmpStr := method.qualifiedName;
	endif;
	
	self.cnStartTransaction(tmpStr[1:50]);

	self.lblModalMessage.caption := "Loading Voyage - " &amp; self.myCurrentVoyage.code &amp; " - " &amp; self.myCurrentVoyage.vesselName;
	self.frmModalDialog.visible := true;

	self.lblModalInfo.caption := "Getting Planning Guide";

	//self.initTableData(null);
	structure := self.myCurrentVoyage.myCellularVoyageStructure;
	if structure = null then
		return;
	endif;
	roroStructure := self.myCurrentVoyage.myROROStructure;
	if roroStructure &lt;&gt; null then
		roroDecks := roroStructure.getDecksTotal();
	endif;

	numBays := structure.allBayVoyagesById.size + structure.allBayVoyagesById40.size;
	self.tblData.columns := 1;
	self.tblData.columns :=  numBays + roroDecks + 2; // add 2 1 for the bridge and 1 for the labels
	if roroDecks &gt; 0 then 
		self.tblData.columns := self.tblData.columns + 1;
	endif;
	if numBays &gt; 0 then
		self.initTableData(null);
		idx := 2;
	else
		idx := 1;
	endif;
//	idx := 2; // fixed column

	bridgeUp := false;
	create theGuide transient;	
	totBays := structure.allBayVoyagesByOrdinal.size;
	
	lastRefresh := app.relativeMachineTime();	// PAR #21995 - only refresh if necessary
	
	foreach theBay in structure.allBayVoyagesByOrdinal do
		if structure.bridgeAfterBay.trimBlanks = theBay.id.trimBlanks then
			bridgeUp := true;
		endif;
		
		self.doQueryUpdateBayColumn(theBay,theGuide,idx);
		
		bayCnt := bayCnt + 1;
		perCent := ((bayCnt / totBays) * 100).Integer;
		self.lblModalInfo.caption := "Getting Planning Guide - Bay " &amp; theGuide.id &amp; " - " &amp; bayCnt.String &amp; " of " &amp; totBays.String &amp; " (" &amp; perCent.String &amp; "%)";
		
		// PAR #21995 - replace app.doWindowEvents with refresh every 3 seconds
		if (app.relativeMachineTime() - lastRefresh) &gt; TimeBetweenRefreshes then
			self.refreshNow();
			lastRefresh := app.relativeMachineTime();
		endif;
//		app.doWindowEvents(0);
			
		if bridgeUp then
			idx := idx + 1;
			self.tblData.accessCell(Row_BayID,idx).text := "*B*";
			bridgeCol := idx;
			bridgeUp := false;
		endif;
		
		// PAR #21995 - reworked for performance
		if theBay.canHandle4045() then			//JC 30/04/2004
			id40 := theBay.idBay40.trimBlanks();
			if id40 &lt;&gt; null then
				idx := idx + 1;
				theGuide.id := id40;
				theGuide.is40Bay := true;
				structure.getPlanningGuideForBay(theGuide);
				theGuide.id := "[" &amp; id40 &amp; "]";
				self.doQueryDisplayBay(theGuide, idx);
			endif;
		endif;
		idx := idx + 1;		
	endforeach;
	
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	if roroStructure &lt;&gt; null and roroDecks &gt; 0 then
		if numBays &gt; 0 then
			self.addDecksColumn(idx);
		else
			self.addOnlyDecksColumn();
		endif;
		idx := idx + 1;
		foreach theDeck in roroStructure.allDecksByCode do				
			self.doQueryUpdateDeckColumn(theDeck,theGuide,idx);			
			deckCount := deckCount + 1;
			perCent := ((deckCount / roroDecks) * 100).Integer;
			self.lblModalInfo.caption := "Getting Planning Guide - Deck " &amp; theGuide.id &amp; " - " &amp; deckCount.String &amp; " of " &amp; roroDecks.String &amp; " (" &amp; perCent.String &amp; "%)";				
			if (app.relativeMachineTime() - lastRefresh) &gt; TimeBetweenRefreshes then
				self.refreshNow();
				lastRefresh := app.relativeMachineTime();
			endif;				
			idx := idx + 1;		
			if not theDeck.allSubDecks.isEmpty() then
				foreach theSubDeck in theDeck.allSubDecks do
					self.doQueryUpdateDeckColumn(theSubDeck,theGuide,idx);			
					deckCount := deckCount + 1;
					perCent := ((deckCount / roroDecks) * 100).Integer;
					self.lblModalInfo.caption := "Getting Planning Guide - SubDeck " &amp; theGuide.id &amp; " - " &amp; deckCount.String &amp; " of " &amp; roroDecks.String &amp; " (" &amp; perCent.String &amp; "%)";				
					if (app.relativeMachineTime() - lastRefresh) &gt; TimeBetweenRefreshes then
						self.refreshNow();
						lastRefresh := app.relativeMachineTime();
					endif;				
					idx := idx + 1;
				endforeach;
			endif;
		endforeach;
	endif;
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//	idx := idx + 1;
	if idx &lt;= self.tblData.columns then
		foreach theCol in idx to self.tblData.columns do
			self.tblData.accessColumn(theCol).visible := false;
		endforeach;
	endif;
	self.doQueryUpdateTotals();

	if bridgeCol &gt; 1 then
		self.tblData.accessColumn(bridgeCol).backColor := Gray;
	endif;
	
	// PAR #21995 - Following complete table rebuild, need to clear any pending bay refreshes
	self.doResetBayRefreshTimer();
	
	
epilog
	self.frmModalDialog.visible := false;
	app.mousePointer := Window.MousePointer_Default;
	delete theGuide;
	// PAR 21787
	if processStackArray &lt;&gt; null then
		processStackArray.purge;
		delete processStackArray;
	endif;

	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDisplayBay" id="029360f8-c4f5-4388-bdbc-48c6d31087f6">
        <source>doQueryDisplayBay(theGuide : CMIF_PlanningGuideBay input;_columnNum : Integer);
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	loadTotal, dischTotal,numBays,idx,theCol,aftTotal, fwdTotal, perCent, totBays,bayCnt,bridgeCol : Integer;
	tbl				: CM_DataTable;
begin
	tbl := self.tblData;
	tbl.accessCell(Row_BayID,_columnNum).text := theGuide.id;
	if theGuide.myBay &lt;&gt; null then
		tbl.accessColumn(_columnNum).itemObject := theGuide.myBay;
	else
		tbl.accessColumn(_columnNum).itemObject := theGuide.myDeck;
	endif;
	tbl.accessCell(Row_DischODImp,_columnNum).text := theGuide.dischargeImportOD.zeroNotAllowed();
	tbl.accessCell(Row_DischODSOB,_columnNum).text := theGuide.dischargeSOBOD.zeroNotAllowed();
	tbl.accessCell(Row_DischODDLR,_columnNum).text := theGuide.dischargeDLROD.zeroNotAllowed();
	tbl.accessCell(Row_DischUDImp,_columnNum).text := theGuide.dischargeImportUD.zeroNotAllowed();
	tbl.accessCell(Row_DischUDSOB,_columnNum).text := theGuide.dischargeSOBUD.zeroNotAllowed();
	tbl.accessCell(Row_DischUDDLR,_columnNum).text := theGuide.dischargeDLRUD.zeroNotAllowed();
	dischTotal := (theGuide.dischargeImportOD + theGuide.dischargeSOBOD + theGuide.dischargeDLROD + theGuide.dischargeImportUD + theGuide.dischargeSOBUD + theGuide.dischargeDLRUD);
	tbl.accessCell(Row_DischTotal,_columnNum).text := dischTotal.zeroNotAllowed();
	tbl.accessCell(Row_LoadODExp,_columnNum).text := theGuide.loadExportOD.zeroNotAllowed();
	tbl.accessCell(Row_LoadODDLR,_columnNum).text := theGuide.loadDLROD.zeroNotAllowed();
	tbl.accessCell(Row_LoadUDExp,_columnNum).text := theGuide.loadExportUD.zeroNotAllowed();
	tbl.accessCell(Row_LoadUDDLR,_columnNum).text := theGuide.loadDLRUD.zeroNotAllowed();
	loadTotal := (theGuide.loadExportOD + theGuide.loadExportUD + theGuide.loadDLROD + theGuide.loadDLRUD);
	tbl.accessCell(Row_LoadTotal,_columnNum).text := loadTotal.zeroNotAllowed();
	tbl.accessCell(Row_HatchLids,_columnNum).text := theGuide.hatchLids.zeroNotAllowed();
	tbl.accessCell(Row_BayTotals,_columnNum).text := (loadTotal + dischTotal).zeroNotAllowed();
	
	tbl.accessCell(Row_FwdAft,_columnNum).text := null;
	tbl.accessCell(Row_AftFwd,_columnNum).text := null; 
	if theGuide.hasRemarks then
		tbl.accessCell(Row_Remarks,_columnNum).text := "Yes";
	else
		tbl.accessCell(Row_Remarks,_columnNum).text := "";
	endif;
end;</source>
        <Parameter name="theGuide" type="CMIF_PlanningGuideBay" usage="input"/>
        <Parameter name="_columnNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryUpdateBayColumn" id="a26a74ae-5585-4a87-a6b6-ebc0439a4ef7">
        <source>doQueryUpdateBayColumn(_theBay : CM_BayVoyage;_theGuide : CMIF_PlanningGuideBay input;_columnNum : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_theGuide.id := _theBay.id.trimBlanks;
	_theGuide.is40Bay := false;
	_theGuide.myBay := _theBay;
	self.myCurrentVoyage.myCellularVoyageStructure.getPlanningGuideForBay(_theGuide);
	
	self.doQueryDisplayBay(_theGuide,_columnNum);

end;</source>
        <Parameter name="_theBay" type="CM_BayVoyage"/>
        <Parameter name="_theGuide" type="CMIF_PlanningGuideBay" usage="input"/>
        <Parameter name="_columnNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryUpdateDeckColumn" id="e96c5214-7dc6-459f-8629-8b2c0e9e1f4f">
        <source>doQueryUpdateDeckColumn(_theDeck : CM_DeckVoyage;_theGuide : CMIF_PlanningGuideBay input;_columnNum : Integer);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars

begin
	_theGuide.id := _theDeck.code.trimBlanks;
	_theGuide.is40Bay := false;
	_theGuide.myDeck := _theDeck;
	self.myCurrentVoyage.myROROStructure.getPlanningGuideForDeck(_theGuide);
	
	self.doQueryDisplayBay(_theGuide,_columnNum);

end;</source>
        <Parameter name="_theDeck" type="CM_DeckVoyage"/>
        <Parameter name="_theGuide" type="CMIF_PlanningGuideBay" usage="input"/>
        <Parameter name="_columnNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryUpdateTotals" id="8bd75672-61b4-45bd-8c9e-ca1f8fd902e4">
        <source>doQueryUpdateTotals();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numRows,
	numCols,
	idx,
	fwdTotal,
	aftTotal 	: Integer;
	tbl			: CM_DataTable;
begin
	tbl := self.tblData;
	numCols := tbl.columns;
	numRows := tbl.rows;
	
	foreach idx in 2 to numCols reversed do
		if tbl.accessColumn(idx).itemObject = null then
			continue;
		endif;
		fwdTotal := fwdTotal + tbl.accessCell(Row_BayTotals,idx).text.Integer;
		tbl.accessCell(Row_AftFwd,idx).text := fwdTotal.zeroNotAllowed(); 
	endforeach;
	
	foreach idx in 2 to numCols do
		if tbl.accessColumn(idx).itemObject = null then
			continue;
		endif;
		aftTotal := aftTotal + tbl.accessCell(Row_BayTotals,idx).text.Integer;
		tbl.accessCell(Row_FwdAft,idx).text := aftTotal.zeroNotAllowed();
	endforeach;	

end;</source>
    </JadeMethod>
