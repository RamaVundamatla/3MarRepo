    <Function name="getCommandLine" id="fd86d38c-309f-4e25-8163-3a7fa76c3e7e">
        <entrypoint>GetCommandLineA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="kernel32"/>
        <source>getCommandLine():String is GetCommandLineA in kernel32;
// use serverExecution on the caller to get rap commandLine</source>
