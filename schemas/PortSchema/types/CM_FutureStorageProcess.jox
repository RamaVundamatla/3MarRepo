    <JadeMethod name="getRequestDetail" id="0c1f5900-6558-465f-8566-4bf391b67b90">
        <source>getRequestDetail() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64732 - 25th June 2024

*/

vars
	actionDT : Date;
begin
	actionDT:= self.actionTimeStamp.date;
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem .getCOOOperatorByDate(actionDT);		
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
