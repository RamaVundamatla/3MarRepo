    <JadeMethod name="setUpCombos" id="0055a081-b28f-435c-a14d-dc57d09e3b2a">
        <source>setUpCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	index : Integer;

begin

	self.cmbFiltNA.clear();
	index := self.cmbFiltNA.addItem( app.getErrorString(Both) );
	self.cmbFiltNA.itemData[index] := 2;
	index := self.cmbFiltNA.addItem( app.getErrorString(Available_entry_only2) );
	self.cmbFiltNA.itemData[index] := 1;
	index := self.cmbFiltNA.addItem( app.getErrorString(Not_availab_entry_only) );
	self.cmbFiltNA.itemData[index] := 0;
	
	self.cmbFiltCarr.initialise(false);
	self.cmbCarrier.initialise(false);

epilog

end;</source>
