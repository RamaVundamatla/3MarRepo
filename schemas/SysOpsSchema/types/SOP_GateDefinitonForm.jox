    <JadeMethod name="tblGateLanes_dblClick" id="e74b7a07-de79-47e9-8a86-b0f6c669c636">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGateLanes_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	printer		: CM_PrinterDef;
	reader 		: CM_RFIDTagReader;
	kiosk		: CM_Kiosk;
	boom		: CM_Boom;
	weighBridge : CM_WeighBridgeObj;
	gateLane	: CM_GateAreaLaneController;
	
begin
	if self.mode = self.Mode_View then
		return;
	endif;

	if table.column = table.getColumnByRowName (ETRow_Lane_printer) then
		printer		:= table.accessedCell.cellControl.ComboBox.listObject.CM_PrinterDef;
		gateLane	:= table.accessedRow.itemObject.CM_GateAreaLaneController;
		self.doPrinter(self.Mode_Update, printer, gateLane);
		
	elseif table.column = table.getColumnByRowName (ETRow_Lane_rfid_tag_read) or
	 	   table.column = table.getColumnByRowName (ETRow_Lane_rfid_tag_assign) then
		reader 		:= table.accessedCell.cellControl.ComboBox.listObject.CM_RFIDTagReader;
		gateLane	:= table.accessedRow.itemObject.CM_GateAreaLaneController;
		self.doRFIDTagReader(self.Mode_Update, reader, gateLane);
		
	//19 Mar 2019 NDL	TFS 43811 - remove add / update of ther Boom object
/*	elseif table.column = table.getColumnByRowName (ETRow_Lane_boom_in) or
		   table.column = table.getColumnByRowName (ETRow_Lane_boom_out) then
		boom 		:= table.accessedCell.cellControl.ComboBox.listObject.CM_Boom;
		gateLane	:= table.accessedRow.itemObject.CM_GateAreaLaneController;
		self.doBoom(self.Mode_Update, boom, gateLane);
	*/	
	elseif table.column = table.getColumnByRowName (ETRow_Lane_kiosk) then
		// belt and braces - should not be here without kiosk license
	/*	if not app.myRoot.canDo(PmRoadGateKiosk) then 	
			return;
		endif; */	//07 Oct 2019	NDL	TFS 46169
		kiosk 		:= table.accessedCell.cellControl.ComboBox.listObject.CM_Kiosk;
		gateLane	:= table.accessedRow.itemObject.CM_GateAreaLaneController;
		self.doKiosk(self.Mode_Update, kiosk, gateLane);
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e34b465e-49bf-4010-a73f-69090b8dab1f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 May 2023 09:18:45.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011632, locale);
	btnEditTV.translateBubbleHelp(Xlat_0010628, locale);
	btnEditTV.translateCaption(Xlat_0010629, locale);
	btnExtraDelete.translateBubbleHelp(Xlat_0011633, locale);
	btnExtraDelete.translateCaption(Xlat_0011634, locale);
	btnICAreas.translateBubbleHelp(Xlat_0011635, locale);
	btnICAreas.translateCaption(Xlat_0011636, locale);
	btnNewTV.translateBubbleHelp(Xlat_0010632, locale);
	btnNewTV.translateCaption(Xlat_0010633, locale);
	chkBarrierCodes.translateCaption(Xlat_0026071, locale);
	chkEntry.translateCaption(Xlat_0011637, locale);
	chkExit.translateCaption(Xlat_0011638, locale);
	chkPrompt.translateCaption(Xlat_0014264, locale);
	grpGate.translateCaption(Xlat_0011639, locale);
	grpGateArea.translateCaption(Xlat_0011640, locale);
	lblHelp.translateCaption(Xlat_0011641, locale);
	lblICArea.translateCaption(Xlat_0011642, locale);
	lblName.translateCaption(Xlat_0011643, locale);
	lblPickColor.translateBubbleHelp(Xlat_0011644, locale);
	lblTroubleIn.translateCaption(Xlat_0011645, locale);
	mnuColumnOrganiserA.translateCaption(Xlat_0011646, locale);
	mnuColumnOrganiserL.translateCaption(Xlat_0011647, locale);
	mnuPopupA.translateCaption(Xlat_0011648, locale);
	mnuPopupAddGateArea.translateCaption(Xlat_0011649, locale);
	mnuPopupL.translateCaption(Xlat_0011650, locale);
	mnuPopupRemoveGateArea.translateCaption(Xlat_0011651, locale);
end;</source>
