    <JadeMethod name="createProxyWorkOrder" id="208fab91-7b9c-4f1e-9593-ce236aceb5c8">
        <source>createProxyWorkOrder(): CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars
	pxyWorkOrder : CM_WodPack;

begin
	create pxyWorkOrder transient;
	return pxyWorkOrder;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="be8bcf02-7138-43a9-8a02-ea29655e3f2b">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodPack) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	invalidBooking : Boolean;
	ti             : CM_TrackedItem;
	failedDAC	   : CM_DataAccessController;
	woTI		   : WS_WorkOrderTrackedItem;
begin
	inheritMethod(_object);
	
	on Exception do app.handleDeletedObject(exception,_object.myBookingRef,invalidBooking);
	
	if _object.myBookingRef &lt;&gt; null then
		self.bookingOid := _object.myBookingRef.getOidAsString;
		if not invalidBooking then
			self.bookingNum:= _object.myBookingRef.bookingReference;
		endif;
	endif;
	
	self.commodity 		:= _object.commodity;
	self.imexStatus 	:= _object.imexStatus;
	
	if _object.myContentsStatus &lt;&gt; null then
		self.contentStatus := _object.myContentsStatus.code;
	endif;
	if _object.myConsignee &lt;&gt; null then
		self.consigneeOid := _object.myConsignee.getOidAsString;
	endif;
	
	if _object.myConsignor &lt;&gt; null then
		self.consignorOid := _object.myConsignor.getOidAsString;
	endif;

	if _object.myVoyage &lt;&gt; null then
		self.voyageOid := _object.myVoyage.getOidAsString;
	endif;
	
	if _object.myOperator &lt;&gt; null then
		self.operatorCode := _object.myOperator.code;
	endif;
	
	if _object.myDischargePort &lt;&gt; null then
		self.dischargePort := _object.myDischargePort.getOidAsString;
	endif;
	
	foreach ti in  _object.CM_WodPack.allPackingTIs do
		if not ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then 
			continue;
		endif;
		
		/*	29.09.2021 navma1 #51925
		self.allCargoIds.add(ti.id);
		self.allCargoOids.add(ti.getOidAsString);
		*/
		//29.09.2021 navma1 #51925
		create woTI transient;
		woTI.setProxyFromObject(ti);
		self.allChildTIs.add(woTI);
		
	endforeach;
	
	self.setProxyToDoTasks(_object);  //29.09.2021 navma1 #51925
epilog

end;</source>
        <Parameter name="_object" type="CM_WodPack"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="2afde683-70f5-4959-945c-143059252428">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	passport        : CM_Passport;
	bookingRef  	: CM_BookingRef;
	consignee,
	consignor		: CM_ConsigneeConsignor;
	contentStatus   : CM_ContentsStatus;
	dischargePort   : CM_Port;
	operator        : CM_Operator;
	voyage          : CM_Voyage;
	tiSet           : CM_TISet;
	root			: CM_Root;
begin
	
	inheritMethod(_pxyWorkOrder);
	
	root			:= app.myRoot;
	passport        := app.myPassport;

	bookingRef 		:= passport.getObjectOfTypeFromOid(self.bookingOid,CM_BookingRef).CM_BookingRef;
	consignee  		:= passport.getObjectOfTypeFromOid(self.consigneeOid,CM_ConsigneeConsignor).CM_ConsigneeConsignor;
	consignor  		:= passport.getObjectOfTypeFromOid(self.consignorOid,CM_ConsigneeConsignor).CM_ConsigneeConsignor;
	voyage          := passport.getObjectOfTypeFromOid(self.voyageOid,CM_Voyage).CM_Voyage;
	contentStatus	:= root.allContentsStatuses[self.contentStatus]; 
	dischargePort   := root.allPorts[self.dischargePort]; 
	operator        := root.allOperators[self.operatorCode];
	

	//29.09.2021 navma1 #51925
	create tiSet transient;
	self.allChildTIs.getTIs(tiSet);
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	childStr :=  self.allChildTIs.asDelimitedString(Comma);
	if not tiSet .isEmpty then
		packingCargoType := tiSet.first.CM_TrackedItem.myCargoType;
	endif;
	*/
	_pxyWorkOrder.CM_WodPack.allPackingTIs.clear;
	_pxyWorkOrder.CM_WodPack.setProxyWodPack(tiSet,
											bookingRef,
											consignee,
											consignor,
											contentStatus,
											dischargePort,
											operator,
											null,
											voyage,
											self.commodity,
											self.imexStatus,
											null,										//18.4.2023 navhl20 #55442[57629]
											null, 										//05.07.2024 navhl20 #61368
											false);
	/*
	12.01.2023 navma1 #56141 Task#56147
	if _pxyWorkOrder.CM_WodPack.mySource &lt;&gt; null then
		realTISource := _pxyWorkOrder.CM_WodPack.mySource.pxyGetRealObject().CM_WorkOrderTISource;
	endif;
	
	if realTISource &lt;&gt; null then
		proxySource := realTISource.pxyGetProxyObject();
	else
		create proxySource transient;
	endif;

	if packingCargoType &lt;&gt; null then
		proxySource.setProxy(packingCargoType.id,childStr);
	endif;

	proxySource.setMyParent(_pxyWorkOrder);	
	*/
	self.updateProxyToDoTasks(_pxyWorkOrder);     //29.09.2021 navma1 #51925
epilog
	delete tiSet;
	
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
