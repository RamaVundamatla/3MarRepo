end;</source>
    </JadeMethod>
    <JadeMethod name="createHeader" id="75c0ae63-3607-4dbb-9050-4aca55b34c79">
        <updating/>
        <source>createHeader(_pictureButton,
			_pictureButtonDown : String) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2003		cnwth2	
//
// Purpose:     _pictureStringButton and _pictureStringButtonDown can be null - and
//				will be for the example of report folders being created, where the
//				default listbox picture types are used
//			 
// ----------   ----------  --------------------------------------------------
vars
	heading				: String;
	inputBox			: CMUI_InputBox;
	newHeader,
	pxyHeader			: CM_MenuUserHdr;
	theParent,
	childEntity,
	menuEntity			: CM_MenuEntity;
	cnt,
	subScript			: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	
	menuEntity := self.listObject.CM_MenuEntity;
	theParent := menuEntity.myParent;
	
	if (menuEntity.isKindOf(CM_MenuUserDtl)) or
		(menuEntity.isKindOf(CM_MenuUserReport)) or
		(menuEntity.isKindOf(CM_MenuUserQuery)) then	
		//find the subscript of where to add it. 
		foreach cnt in 1 to theParent.allChildren.size do
			if theParent.allChildren[cnt] = menuEntity then
				subScript := cnt;
				break;
			endif;
		endforeach;
	else
		theParent := menuEntity;
	endif;

	if subScript &lt;= 0 then
		subScript := 1;
	endif;

	create inputBox transient;
	create pxyHeader transient;
	
//	inputBox.init(app.getErrorString(LBLCreateHeader),app.getErrorString(LBLEnterFolderName), null, 20, TextBox.DataType_AlphaNumeric, false);	// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	app.getErrorString(LBLCreateHeader), app.getErrorString(LBLEnterFolderName),
					null, 20, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	heading := inputBox.txtInput.text;
	if heading = null then
		return;
	endif;
	
	pxyHeader.setProxy(heading,
						_pictureButton,
						_pictureButtonDown,
						null,
						null,
						null,//does not have a myMenuItem!!
						null);
						
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateMenuUserHdr(pxyHeader, 
									theParent,
									newHeader,
									subScript,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.displayTree(true, null);
			break;
		else
			theResult := app.showErrorWarningDialog('Create Folder', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	delete pxyHeader;
	
	if inputBox &lt;&gt; null then
		delete inputBox;
	endif;
end;</source>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="711ef198-e512-4a06-b929-13db2388cb00">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
