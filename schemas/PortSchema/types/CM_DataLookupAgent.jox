    <JadeMethod name="resolveCollectionMember" id="bd7625dc-0582-4ab7-ac3c-c7e00a3cf54f">
        <source>resolveCollectionMember(
    _className: String
   ) : ObjectArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
	objArr : ObjectArray;
	coll		: MemberKeyDictionary;
	iter		: Iterator;
	obj : Object;
	
begin
	create objArr transient;
    if _className = CM_BlockStack.name then
		coll := app.myPassport.myTerminal.allTerminalAreasByTypeId;
		foreach obj in coll do
			if obj.getPropertyValue(CM_BlockStack::type.name).Integer = TA_TYPE_BLOCK_STACK then
				objArr.add(obj);
			endif;
		endforeach;
		
	elseif _className = CM_ForkLiftStack.name then
		coll := app.myPassport.myTerminal.allTerminalAreasByTypeId;
		foreach obj in coll do
			if obj.getPropertyValue(CM_BlockStack::type.name).Integer = TA_TYPE_FORK_LIFT_STACK then
				objArr.add(obj);
			endif;
		endforeach;
	elseif _className = CM_Commodity.name then
		app.myRoot.allCommodities.copy(objArr);
	elseif _className = CM_Carrier.name then
		app.myRoot.allCarriers.copy(objArr);
	elseif _className = CM_EventType.name then
		app.myRoot.allEventTypesByCategory.copy(objArr);
	elseif _className = CM_TerminalAreaView.name then
		coll := app.myPassport.myTerminal.allTerminalAreaViews;
		iter := coll.createIterator();
		//coll.startKeyGeq(app.myPassport.myUser,null,iter);
		while iter.next(obj) do
			objArr.add(obj);
		endwhile;
	endif;
	return objArr;
epilog
end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
