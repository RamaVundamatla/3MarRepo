    <JadeMethod name="isVoyageType" id="e212f310-3f6b-42c2-bbd0-a65c0c4fb790">
        <source>isVoyageType() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//











// Purpose:		used in CONVERSION jadsescript only








// ### &gt;&gt;&gt;&gt;&gt;&gt;		use CM_Calculation.isVoyageCalcType
















//
// ---------------------------------------------------------------------------

constants
	TagType = "TYPE";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	calTypeValue, descPos, catPos : Integer;
	lenTagLabel, len : Integer;
	label : String;

begin
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return null;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return null;
	endif;

	foreach const in category.getConstants do
		calTypeValue := const.GlobalConstant.valueAsInteger;
		if self.calculationType = calTypeValue then
			return const.text.String.cnEcGetTagValueOfName(TagType) = "VTMIS";
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeightBased" id="a1414f20-fd9b-4d43-84fa-1c39f52c23ba">
        <source>isWeightBased() : Boolean;
// return true if the calculation type is weight-based
vars
	result	: Boolean;
begin
	if self.calculationType = INV_CALC_TYPE_VESSEL_TON or
	   self.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT or
	   self.calculationType = INV_CALC_TYPE_DAYS_WEIGHT or
	   self.calculationType = INV_CALC_TYPE_EVENT_GRT or
	   self.calculationType = INV_CALC_TYPE_REVENUE_TONS or
	   self.calculationType = INV_CALC_TYPE_VESSEL_TON or
	   self.calculationType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
	   self.calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE or
	   self.calculationType = INV_CALC_TYPE_WEIGHT or
	   self.calculationType = INV_CALC_TYPE_BOL_WEIGHT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_INVENT_WEIGHT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_UNIT_DEADWEIGHT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_UNIT_GRT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_UNIT_NRT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_WO_CARGOWEIGHT or  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	   self.calculationType = INV_CALC_TYPE_WEIGHT_TON then
		result := true;
	endif;

	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e8c2d96b-e23a-4820-b667-e5bc088fb523">
        <source>pxyCreateUpdateProxy(): SelfType;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate, create proxies for the hook codes if present
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
begin
	proxyObj	:=	inheritMethod();
	
	if self.myHookCodeQuantity &lt;&gt; null then
		proxyObj.myHookCodeQuantity	:=	self.myHookCodeQuantity.pxyCreateUpdateProxyWithCode();
	endif;
	if self.myHookCodeRate &lt;&gt; null then
		proxyObj.myHookCodeRate	:=	self.myHookCodeRate.pxyCreateUpdateProxyWithCode();
	endif;
	if self.myHookCodeRemarks &lt;&gt; null then
		proxyObj.myHookCodeRemarks	:=	self.myHookCodeRemarks.pxyCreateUpdateProxyWithCode();		// 22/2/18 MAP TFS37124
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
