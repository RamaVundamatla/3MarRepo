    <JadeMethod name="doExtract" id="f255c7df-70af-4732-865e-fc964c14777f">
        <updating/>
        <source>doExtract(_cargoTypes : CM_CargoBOLTypeArray) : Boolean updating, protected;
// extract persistent cargo config for current user and selected  cargo types
vars
	filePath	: String;
	file		: File;
	user		: CM_User;
	extractAgent	: CM_ExtractLoadAgent;
begin
	// pass null path so that opens where last open at
	filePath := app.getFilePath(null, "*.csv", null, false);
	if filePath = null then
		return true;
	endif;
	
	if filePath.toLower.pos(".csv", 1) &lt;= 0 then
		filePath := filePath &amp; ".csv";
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;
	
	if not file.tryOpen() then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return false;
	endif;
	
	user := self.allUsers.first;
	if user = null then
		return true;
	endif;
	
	create extractAgent;
	extractAgent.extractUserCargoConfig(file, user, _cargoTypes);

	return true;
epilog
	if file &lt;&gt; null then
		file.close();
		delete file;
	endif;
	delete extractAgent;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoTypes" type="CM_CargoBOLTypeArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="0b3be56a-7178-46e1-ad1a-0e3257df77b1">
        <updating/>
        <source>doOK() updating, protected;
// copy or extract
vars
	status		: Boolean;
	indx		: Integer;
	type		: CM_CargoBOLType;
	cargoTypes	: CM_CargoBOLTypeArray;
	fromUser,
	toUser		: CM_User;
	listBox		: ListBox;
begin
	create cargoTypes transient;
	listBox := self.lstTypesTo;
	foreach indx in 1 to listBox.listCount do
		type := listBox.itemObject[indx].CM_CargoBOLType;
		cargoTypes.add(type);
	endforeach;
	if cargoTypes.size = 0 then
		return;
	endif;
	// extract
	if self.isExtract then
		status := self.doExtract(cargoTypes);
		if status then
			unloadForm();
			return;
		else
			return;
		endif;
	endif;
	// copy from/to user(s)
	if self.copyFrom then
		fromUser := self.allUsers.first;
		self.allUsers.clear;
		self.allUsers.add(app.myPassport.myUser);
	else
		fromUser := app.myPassport.myUser;
	endif;
	app.myTrxUA.trxCopyEnquiryConfig(fromUser, self.allUsers, cargoTypes, app.myPassport);
	
	unloadForm();
epilog
	delete cargoTypes;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTypeAdd" id="21836f0a-270a-4349-8374-f5bea5bb6156">
        <updating/>
        <source>doTypeAdd(_all : Boolean) updating, protected;
// all selected types
vars
	indx,
	indx2	: Integer;
	ia		: IntegerArray;
	type	: CM_CargoBOLType;
	listBox	: ListBox;
begin
	listBox := self.lstTypesFrom;
	create ia transient;
	foreach indx in 1 to listBox.listCount do
		if _all or
		   listBox.itemSelected[indx] then
			type := listBox.itemObject[indx].CM_CargoBOLType;
			indx2 := self.lstTypesTo.addItem(type.description);
			lstTypesTo.itemObject[indx2] := type;
			ia.add(indx);
		endif;
	endforeach;
	
	foreach indx in ia reversed do
		listBox.removeItem(indx);
	endforeach;
	listBox.clearAllSelected();
	self.btnOK.enabled := (self.lstTypesTo.listCount &gt; 0);

epilog
	delete ia;
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
