<GUIClass name="CM_DataTable_FixedColumns" id="d0e00b0f-2bf4-4f23-b307-798acb6bb5eb">
    <superclass name="CM_DataTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Same as CM_DataTable except table can have fixed columns that 
are maintained by developer while non fixed columns contain ETRow data</text>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="getEntRowColumnByRowName" id="efd42bcb-d1ad-4c21-b42d-b08839b1e86d">
        <source>getEntRowColumnByRowName(_rowName: String; _column: Integer output): EntTableRow;
/*
Date		Who		Reason
23 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	etRow : EntTableRow;
begin
	_column := 0;
	
	foreach etRow in self.allTblDataEntRows do
		_column := _column + 1;
		
		if etRow.name = _rowName then
			_column := _column + self.fixedColumns;
			
			return etRow;
		endif;
	endforeach;
	
	return null; // not found
	
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_column" type="Integer" usage="output"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRowAtColumn" id="bddeb39a-dcfc-434e-b8e5-101f01e7a495">
        <source>getEntTableRowAtColumn(_column: Integer): EntTableRow;
/*
Parameters;	_column	- column # in table

Date		Who		Reason
23 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	fixedColumns, idx : Integer;
begin
	fixedColumns 	:= self.fixedColumns;

	if _column &lt;= fixedColumns then
		// dont know anything about my fixed columns
		return null;
	else
		idx := _column - fixedColumns;
		
		if idx &lt;= self.allTblDataEntRows.size then
			return self.allTblDataEntRows[idx];
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_column" type="Integer"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColWidths" id="e370b6b1-5437-42b8-97e0-3797ea4efd00">
        <updating/>
        <source>getXMLStrForColWidths(): String updating;
/*
Date		Who		Reason
20 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
*/
vars
	widths 			: String;
	idx , columns,
	fixedColumns	: Integer;
begin
	columns 		:= self.columns;
	fixedColumns	:= self.fixedColumns;
	
	if columns &lt;= fixedColumns then
		// nothing to save
		return null;
	endif;
	
	foreach idx in fixedColumns + 1 to columns do
		if widths = null then
			widths := self.accessColumn(idx).width.String;
		else
			widths := widths &amp; ',' &amp; self.accessColumn(idx).width.String;
		endif;
	endforeach;
	
	return widths;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setColWidthsFromArray" id="96bce89c-3fb6-4f43-9543-fe5797cfe1a9">
        <updating/>
        <source>setColWidthsFromArray(_array :StringArray) updating, protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	columns, fixedColumns, 
	idx		:Integer;
	str		:String;
begin
	columns			:= self.columns;
	fixedColumns	:= self.fixedColumns;
	
	foreach str in _array do
		idx := idx + 1;
		
		if (idx + fixedColumns) &gt; columns then
			break;
		endif;
		
		self.accessColumn(idx + fixedColumns).width := str.Integer;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setColWidthsFromUserWindow" id="0aa336f0-f695-4c09-9cd4-a52bcc7fac54">
        <updating/>
        <source>setColWidthsFromUserWindow(_userWindow: CM_UserWindow) updating, protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	xmlTable, columnWidths	: String;
	startPos, pos			: Integer;
	array					: StringArray;
	
begin
	if _userWindow = null then
		return;
	endif;
	
	pos 		:= 1;	
	startPos 	:= 1;
	xmlTable 	:= _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Table &amp; self.name, startPos);
	
	if xmlTable &lt;&gt; null then
		columnWidths := xmlTable.cnEcGetNextTagValueOfName(XMLTag_ColWidth, pos);
		
		if columnWidths &lt;&gt; null then
			create array transient;
			
			columnWidths.getTokensForDelimiter(',', array);
			
			self.setColWidthsFromArray (array);
		endif;
	endif;	

epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setColWidthsFromXMLStr" id="ca96aeb9-c47e-429a-97f6-4003229529f0">
        <updating/>
        <source>setColWidthsFromXMLStr(_xmlStr: String) updating, protected;
/*
Date		Who		Reason
21 August 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
*/
vars
	columnsWidths	: String;
	pos				: Integer;
	array			: StringArray;
	
begin
	if _xmlStr = null then
		return;
	endif;

	pos 			:= 1;
	columnsWidths 	:= _xmlStr.cnEcGetNextTagValueOfName(XMLTag_ColWidth, pos);

	if columnsWidths = null then
		return;
	endif;
	
	create array transient;
	columnsWidths.getTokensForDelimiter(',', array);
	
	self.setColWidthsFromArray (array);

epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSetup" id="0a4120fc-0c81-4841-b6ed-de31534cd8d7">
        <updating/>
        <source>zTblDataSetup() updating, protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	fixedColumns, numHeadings,
	inputType, idx				: Integer;
	col							: JadeTableColumn;
	headingColl					: StringArray;
	heading, tblHeading			: String;
	entRow						: EntTableRow;
begin
	// Do this to force table column widths to be auto-resized
	// when new data is redisplayed
	fixedColumns	:= self.fixedColumns;

	numHeadings		:= self.allTblDataColHeadings.size;
	self.columns 	:= fixedColumns + numHeadings;
	headingColl		:=  self.allTblDataColHeadings;
	
	// only setting column headings for non-fixed columns
	foreach idx in 1 to numHeadings do
		col 		:= self.accessColumn(idx + fixedColumns);
		inputType 	:= self.allTblDataColInputTypes[idx];
		
		if inputType = SortColInputType then
			col.inputType 	:= InputType_None;
			col.visible 	:= false;
			col.width 		:= 0;
			heading 		:= SortColHeadingPrefix &amp; headingColl[idx];
		else
			entRow := self.allTblDataEntRows[idx];
			
			if entRow &lt;&gt; null then
				col.visible := entRow.visible;
			else
				col.visible := true;
			endif;
			
			col.inputType	:= inputType;
			heading 		:= headingColl[idx];
		endif;

		if idx = 1 then 
			tblHeading := heading;
		else
			tblHeading := tblHeading &amp; Tab &amp; heading;
		endif;
	endforeach;

	if tblHeading &lt;&gt; null then
		if self.rows &lt; 1 then
			self.rows 		:= 1;
			self.fixedRows 	:= 1;
		endif;
		
		self.accessCell(self.fixedRows, fixedColumns + 1).text := tblHeading;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
