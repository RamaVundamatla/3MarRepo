    <JadeMethod name="doShowVehicle" id="5ecdfec4-98c3-41f8-aa6f-3f851189c9c1">
        <source>doShowVehicle(_obj : CM_VehicleVisitRecord);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	navhl20	Defect 57173: MTN - 75776 exception when double clicking on the Vehicle on the Info table

*/

vars
	vehicleForm : CMUI_VehicleEnquiryForm;
begin
	vehicleForm := app.getForm(CMUI_VehicleEnquiryForm.name).CMUI_VehicleEnquiryForm;
	if vehicleForm = null then
		vehicleForm := app.loadForm(CMUI_VehicleEnquiryForm, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_VehicleEnquiryForm;
	endif;
	
	if vehicleForm = null then
		return;
	endif;
	
	vehicleForm.centreWindow;
	vehicleForm.setMyTerminal(self.myTerminal);
	vehicleForm.show;
	vehicleForm.addVehicleToTable(_obj.vehicle.CM_Vehicle);
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_obj" type="CM_VehicleVisitRecord"/>
