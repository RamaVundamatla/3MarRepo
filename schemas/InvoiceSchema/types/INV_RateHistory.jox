    <JadeMethod name="create" id="0118720f-6962-4755-8947-b446ab155b69">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmRatehistoryView;
	self.permissionMaint := PmAdmRatehistoryMaint;
	
	self.helpFileName := HelpFile_Invoicing;

end;</source>
