    <JadeMethod name="checkForActiveResponse" id="2373bd7d-b384-4cb0-97f0-6f37c007416c">
        <source>checkForActiveResponse(_queueEntry : CM_RTQueueEntry);

/*

Purpose:			This method creates an Internal Request to tidy up active responses for a changed Queue Entry

Parameters:			The changed Queue Entry.

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	response	: CM_ITSInterfaceResponse;

begin
	
	
	
	foreach response in _queueEntry.allITSInterfaceResponses do
		if response.isActive() and
		   response.messageType &lt;&gt; ITS_MESSAGETYPE_DELETEQE then
			// Create Internal Request to tidy up active responses for this entry
			self.createAddUpdateQueueEntry(_queueEntry);
			return;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="createAddUpdateQueueEntry" id="cd029f2d-bd7c-4a3a-a479-59b1b160478a">
        <source>createAddUpdateQueueEntry(_queueEntry : CM_RTQueueEntry);

/*

Purpose:			Create Internal Request to handle Add/Update of Queue Entry

Parameters:			New/changed Queue Entry

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
11 Mar 2011	cnwkpd1	PAR #27058 - Prevent deadlock from Queue Monitor app

*/

vars
	lastRequest		: CM_ITSInterfaceReqAddQEntry;
	proxyRequest	: CM_ITSInterfaceReqAddQEntry;
	realRequest		: CM_ITSInterfaceRequest;
//	lockedQEntry	: CM_RTQueueEntry;
	invalidQE		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, _queueEntry, invalidQE);
	
	// PAR #27058 - change to just dereference queue entry here - leave locking until in
	// trx to prevent deadlocks
//	self.reserveLock(_queueEntry);
	
//	lockedQEntry := _queueEntry;
	
	lastRequest := _queueEntry.allITSInternalAddRequests.last;

	if invalidQE then
		return;
	endif;
		
	// Exit when there is already a request waiting to be actioned
	if lastRequest &lt;&gt; null and
	   lastRequest.isToBeActioned() then
		return;
	endif;

	create proxyRequest transient;
	proxyRequest.setProxy(_queueEntry, self.myInterfaceDefinition);
	
	// Record Request
	self.initialiseForNewRequest();
	app.myTrxCA.trxCreateITSInterfaceRequest(proxyRequest, realRequest, app.myPassport);
//	lockedQEntry := null;
	
epilog
	delete proxyRequest;
	
//	if lockedQEntry &lt;&gt; null then
//		self.unlock(lockedQEntry);
//	endif;
	
end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="createDeleteQueueEntry" id="cbe64b97-91be-41ed-b6a2-e856a48c0f5e">
        <source>createDeleteQueueEntry(_queueEntry : CM_RTQueueEntry);

/*

Purpose:			Create Internal Request to handle deleted Queue Entry

Parameters:			Deleted Queue Entry

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	invalidQE		: Boolean;
	proxyRequest	: CM_ITSInterfaceReqDelQEntry;
	realRequest		: CM_ITSInterfaceRequest;
	qeStatus		: Integer;
	queueEntryID	: Integer;

begin
	on Exception do app.handleDeletedObject(exception, _queueEntry, invalidQE);

	qeStatus := _queueEntry.status;

	// Exit when the queue entry hasn't been deleted.  The update processing will do the tidy up for it.
	if not invalidQE then
		return;
	endif;

	queueEntryID := self.getInstanceIdForObject(_queueEntry).Integer;

	create proxyRequest transient;
	proxyRequest.setProxy(queueEntryID, self.myInterfaceDefinition);
	
	//  Record Request
	self.initialiseForNewRequest();
	app.myTrxCA.trxCreateITSInterfaceRequest(proxyRequest, realRequest, app.myPassport);

epilog
	delete proxyRequest;
end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="createRefreshMachine" id="7d7bd1a4-4b49-4f61-8135-7dc53a0b3018">
        <source>createRefreshMachine(_machine : CM_Machine);

/*

Purpose:			Create Internal Request to refresh the displayed Queue Entries for a machine

Parameters:			Machine to refresh

Return Value:		None


Date		Who		Reason
21 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	proxyRequest	: CM_ITSInterfaceReqRefreshMach;
	realRequest		: CM_ITSInterfaceRequest;

begin
	if _machine.myITSInterfaceLoggedOn &lt;&gt; self.myInterfaceDefinition then
		return;
	endif;

	create proxyRequest transient;
	proxyRequest.setProxy(_machine, null, self.myInterfaceDefinition);
	
	//  Record Request
	self.initialiseForNewRequest();
	app.myTrxCA.trxCreateITSInterfaceRequest(proxyRequest, realRequest, app.myPassport);

epilog
	delete proxyRequest;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="handleMoveOverstowQueueEntry" id="787d1724-721a-41c7-aef6-b950d7fd8eae">
        <source>handleMoveOverstowQueueEntry(_entry : CM_RTQueueEntry);

/*

Purpose:			Handle a notification that the Queue Entry passed in has had the
					"Move Overstowing Cargo" done for it.
					If this has happened, then any Machine which has been sent this Queue 
					Entry needs to be "refreshed" because Queue Entries will have been
					inserted above it.

Parameters:			Queue Entry which was overstowed

Return Value:		None


Date		Who		Reason
09 Nov 2010	cnwkpd1	PAR #26113 - Handle overstowed Queue Entries better in ITS

*/

vars
	invalidEntry	: Boolean;
	response		: CM_ITSInterfaceResponse;
	
begin
	on Exception do app.handleDeletedObject(exception, _entry, invalidEntry);
	
	foreach response in _entry.allITSInterfaceResponses do
		if response.isActive() and response.myMachine &lt;&gt; null then
			self.createRefreshMachine(response.myMachine);
		endif;
	endforeach;
	
		
epilog

end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="handleNewQueueEntry" id="4a661bd2-ac1f-40a1-81fd-120a48fc9859">
        <source>handleNewQueueEntry(_queueEntry : CM_RTQueueEntry);

/*

Purpose:			This method creates an Internal Request to handle a new Queue Entry.
					Also handles Queue Entries assigned to machines by Control.

Parameters:			_queueEntry 	: New Queue Entry.

Return Value:		None


Date		Who		Reason
22 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	invalidQE		: Boolean;
	previousEntry	: CM_RTQueueEntry;
	qeStatus		: Integer;

begin
	on Exception do app.handleDeletedObject(exception, _queueEntry, invalidQE);
	
	qeStatus := _queueEntry.status;
	
	if invalidQE then
		return;
	endif;
	
	if _queueEntry.status = ENTRY_UNACTIONED then
		if _queueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			return;
		endif;
		// For a new move via multiple machines, we only want the first queue entry at this point in time.
		// The subsequent related Queue Entries will be handled by the update notification processing as the job progresses.
		previousEntry := _queueEntry.myPreviousRelatedEntry;
		if previousEntry &lt;&gt; null and
		   previousEntry.status = ENTRY_UNACTIONED then
		    return;
		endif;
	endif;
	
	if invalidQE then
		return;
	endif;
	
	self.createAddUpdateQueueEntry(_queueEntry);
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="handleUpdateQueueEntry" id="7f519406-0e03-476b-a299-c26d90404680">
        <source>handleUpdateQueueEntry(_queueEntry : CM_RTQueueEntry);

/*

Purpose:			This method creates Internal Requests to handle the Update of 
					active Queue Entry Requests	at ITS when a Queue Entry is updated.
					Also checks if a subsequent related queue entry is now active.

Parameters:			A changed Queue Entry.

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	invalidQE	: Boolean;
	relatedQE	: CM_RTQueueEntry;
	response	: CM_ITSInterfaceResponse;
	qeStatus	: Integer;

begin
	on Exception do app.handleDeletedObject(exception, _queueEntry, invalidQE);
	on Exception do app.handleDeletedObject(exception, relatedQE, invalidQE);
	
	qeStatus := _queueEntry.status;
	
	if invalidQE then
		return;
	endif;

	// Check active Queue Entry Requests
	
	if _queueEntry.machineTypeGroup = MACHINETYPEGRP_IMV and
	   _queueEntry.myPreviousRelatedEntry &lt;&gt; null then
	    relatedQE := _queueEntry.myPreviousRelatedEntry;
		if _queueEntry.status = ENTRY_UNACTIONED then
			if not _queueEntry.allTasks.first.allRejectionMachines.isEmpty() then
				// The target location for the previous Queue Entry may have changed due to
				// an IMV rejecting this job. Create an Internal Request to check the target
				// location on active Queue Entry Responses.
				self.checkForActiveResponse(relatedQE);
			endif;
		elseif _queueEntry.status = ENTRY_WORKING then
			// Create Internal Request to handle re-display of active Queue Entry Responses for the
			// previous Queue Entry when the target location is changed due to IMV being offered the job.
			self.checkForActiveResponse(relatedQE);
		endif;
	endif;
	
	self.checkForActiveResponse(_queueEntry);

	// Check if a subsequent related queue entry is now active
	
	if _queueEntry.status = ENTRY_WORKING then
		if _queueEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			if _queueEntry.myPreviousRelatedEntry = null then
				relatedQE := _queueEntry.myNextRelatedEntry;
				if relatedQE &lt;&gt; null and
				   relatedQE.status = ENTRY_UNACTIONED then
					// Create Internal Request to check queue of entry that is picking up from the IMV (after crane set down)
					self.createAddUpdateQueueEntry(relatedQE);
				endif;
			endif;
			// Create Internal Request to handle a TI being placed on to the IMV
			self.createAddUpdateQueueEntry(_queueEntry);
			return;
		endif;		
	elseif _queueEntry.status = ENTRY_COMPLETE then
		if _queueEntry.myNextRelatedEntry &lt;&gt; null then
			relatedQE := _queueEntry.myNextRelatedEntry;
			if relatedQE.machineTypeGroup = MACHINETYPEGRP_IMV then
				relatedQE := relatedQE.myNextRelatedEntry;
			endif;
			if relatedQE &lt;&gt; null and
			   relatedQE.status = ENTRY_UNACTIONED then
				// Create Internal Request to check queue of entry that is picking up from the IC area or IMV
				self.createAddUpdateQueueEntry(relatedQE);
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="initialiseForNewRequest" id="1c784619-5cef-4cb5-bd73-0a56931f3044">
        <source>initialiseForNewRequest() protected;

/*

Purpose:			Perform any processing required to initialise Agent state at the start of
					a new request

Parameters:			None

Return Value:		None


Date		Who		Reason
03 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	passport.initialiseTransaction();
	
	// Default to warnings ignored
	passport.setWarningsIgnored(true);
	
	// Default to automatic acceptance of warnings (interface does not have a dialog to manually acknowledge them)
	passport.warningsAcknowledged := true;
	
	// Set defaults as an anonymous user, because we don't know who the message is coming
	// from until it has been decoded
	passport.setMyUserFromCode( SUPERUSER_Str );
	
	// Unconditionally set terminal and locale from interface definition
	app.setMyTerminal(self.myInterfaceDefinition.myTerminal);
	app.setLocale(self.myInterfaceDefinition.myLocale);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyInterfaceDefinition" id="a8aafb49-5d0d-4eb3-98eb-8e947fa7149c">
        <updating/>
        <source>setMyInterfaceDefinition(_interface : CM_ITSInterfaceDefinition) updating;

/*

Purpose:			

Parameters:			

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myInterfaceDefinition	:= _interface;
	
epilog

end;</source>
        <Parameter name="_interface" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
</Class>
