    <JadeMethod name="trxAdjustBreakBulkUnloaded" id="889cd6ca-65ff-4ba4-aaa4-cc10c1a2727b">
        <updating/>
        <source>trxAdjustBreakBulkUnloaded( _targetTi : CM_Cargo input;
							_sourceTi : CM_Cargo input;
							_quantity : Integer;
							_weight : Decimal;
							_truck : CM_Vehicle;
							_isMoveAllCargoBack : Boolean;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

	newTi : CM_Cargo;
	targetLocation : CM_LocationsController;
	moveController	: CMIF_MoveController;
	wle : CM_WorkListEntry;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	wleToProcess : CM_YardWLE;
	newWLE : CM_YardWLE;

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	vvr := _truck.getCurrentVisit;
	roadJob := vvr.myRoadJob;
	wleToProcess := roadJob.getWLEforTIwithStatus( _sourceTi, null, true, true, null ).CM_YardWLE;
	targetLocation := _truck.locationsController;

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	// split off piece back to its truck location, where it will be merged into the bit still on the truck;
	create moveController transient;
	moveController.setMyTrackedItem( _sourceTi );
	moveController.setMyToPrimaryLocation( targetLocation );
	moveController.setMoveMode( REAL_MODE );
	moveController.setQuantity( _quantity );
	moveController.setWeight( _weight );
	moveController.setMyWorkListEntry( wleToProcess );
	moveController.setJobForMove( roadJob );


	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _targetTi = null then
		// This only happens when there was none of this cargo left on the truck.
		// use the completed wle from the trucks job and create queued move off the truck for the new ti that we just split off and put back
		newTi := moveController.myTrackedItem.CM_Cargo;
		newTi.returnExtraToPreNote( wleToProcess, vvr, _isMoveAllCargoBack ); 
		
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	_passport.doDeferredUpdates();	
	
epilog

	delete moveController;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_targetTi" type="CM_Cargo" usage="input"/>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_isMoveAllCargoBack" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAggregateBreakBulk" id="6b2f619d-e9e0-4e24-ba2b-cc327c59dd7d">
        <updating/>
        <source>trxAggregateBreakBulk(	_targetTi : CM_Bulk;
						_pkgWeight : Decimal;
						_id : String;
						_cargoType : CM_CargoType;
						_product : CM_Product;
						_operator : CM_Operator;
						_location : CM_LocationsController;
						_allItemsToBeAggregated : CM_TISet;
						_aggregateTi : CM_TrackedItem output;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	aggregateTi : CM_Bulk;
	ti : CM_TrackedItem;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	app.myValUA.valBreakBulkAggregate(	_targetTi,	//_targetTi : CM_Bulk io;
										_id,	//_id : String;
										_cargoType,	//_cargoType : CM_CargoType;
										_product,	//_product : CM_Product;
										_operator,	//_operator : CM_Operator;
										_location,	//_location : CM_LocationsController;
										_allItemsToBeAggregated,	//_allItemsToBeAggregated : CM_TISet;
										_passport	//_passport : CM_Passport input
										);
											
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;
	
	if _targetTi &lt;&gt; null then
		//ti to aggregate into has been passed in
		aggregateTi := _targetTi;
	else
		//ti to aggregate into has to be created and moved to a location
		aggregateTi := _location.createNewCargoForLocation(_cargoType, _product, _id, _operator).CM_Bulk;
	endif;
	
	foreach ti in _allItemsToBeAggregated do

		if _passport.hasErrors then
			break;
		endif;
		
		app.myUtilityUA.utlAggregateBreakBulk( aggregateTi, ti.CM_Cargo, _pkgWeight, _passport );
	
	endforeach;
	
	_aggregateTi := aggregateTi;	//02 Oct 2017	NDL	TFS 5744

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_targetTi" type="CM_Bulk"/>
        <Parameter name="_pkgWeight" type="Decimal"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_allItemsToBeAggregated" type="CM_TISet"/>
        <Parameter name="_aggregateTi" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
