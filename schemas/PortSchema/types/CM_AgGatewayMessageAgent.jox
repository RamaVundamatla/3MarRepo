<Class name="CM_AgGatewayMessageAgent" id="c3969a6c-ccb3-45af-8c20-70990dcb1b6f">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmui"/>
    <JadeMethod name="processAgMessage_V5" id="cf676bff-abd5-4b73-aab2-b0fd91f945a0">
        <source>processAgMessage_V5(_requestType : String; _requestBody : String ; _resp : CMIF_StandardMessageProcResp io; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars	
	term 								: CM_Terminal;	
	pxyRequest							: BGP_AgGatewayWSRequest;
	realRequest							: BGP_ExternalWSRequest;
	
begin	
	
	//get the terminal from the user who sent the request's authentication
	term := app.myPassport.myTerminal;	
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Going to add to BGP queue", LogINFO);
	
	if term = null then
		app.writeLog("Could not find the terminal to which this request was posted, so not doing anything", LogERROR);
		return;
	endif;
	
	if not app.isJMTUnitTest then		
		create pxyRequest transient;
		
		pxyRequest.setDetails(_requestBody, term, app.getMyUserCode(),app.getMyUserName());
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, realRequest, app.myPassport);		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from trxCreateBGPRequestExtWS is " &amp; app.myPassport.getAllErrorsWarningsAsString, LogDEBUG);
	endif;

epilog
	delete pxyRequest;
	

end;
	</source>
        <Parameter name="_requestType" type="String"/>
        <Parameter name="_requestBody" type="String"/>
        <Parameter name="_resp" type="CMIF_StandardMessageProcResp" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
