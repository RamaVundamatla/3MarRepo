    <JadeMethod name="getExtraInfo" id="59973bbf-4a8d-403c-b014-888ea9f2df00">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		24 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		Display thumbnail info on maintenance form
//
// ---------------------------------------------------------------------------

vars
	block 		: CM_DataContainerBlock;
	translation	: XLAT_Translation;
begin

	inheritMethod(_dataContainer);

	foreach translation in allTextByLocale do
		block := _dataContainer.addNewBlock;
		block.addNewItem(translation.myLocale.localeId, DC_Label, 1, translation.myLocale);
		block.addNewItem(translation.myLocale.localeDescription, DC_Label, 1, translation.myLocale);
		block.addNewItem(translation.text, DC_Data, 1, translation);
	endforeach;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGlobalConstantName" id="9bd869e8-2d4f-4009-8572-9cfba0311630">
        <source>getGlobalConstantName() : String;
// ---------------------------------------------------------------------------
// Created:     13 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
vars
	invalidClobalConstant : Boolean;
begin

	if self.myGlobalConstant = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myGlobalConstant, invalidClobalConstant); //cnwrd1 9.2.09
	
	//par 18483
	return self.myGlobalConstant.name;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslatedText" id="8a5dc7b0-60a2-455d-a75c-62f2f647404c">
        <source>getTranslatedText(_locale : CM_Locale) : String;
// ---------------------------------------------------------------------------
// Created:     04 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	defLocale,
	tmpLocale	: CM_Locale;
	xlatTrans	: XLAT_Translation;
	tmpStr		: String;
	
begin
	if _locale &lt;&gt; null then
		xlatTrans := self.allTextByLocale[_locale.localeId];
	endif;
	if xlatTrans = null then
		defLocale := app.getDefafultLocale();
		xlatTrans := self.allTextByLocale[defLocale.localeId];
		if xlatTrans = null and defLocale.localeId &lt;&gt; StandardTextLocaleStr then
			xlatTrans := self.allTextByLocale[StandardTextLocaleStr];
		endif;
	endif;
		
	if xlatTrans &lt;&gt; null then
		return xlatTrans.getTranslationText(app.useShortErrorMsg); 
	endif;
	
	return null;
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslation" id="4fa8b98b-75d4-4376-bfd8-ba682d3f7c8f">
        <source>getTranslation(_locale : CM_Locale):XLAT_Translation;

vars

begin
	return self.allTextByLocale[_locale.localeId];
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="getTranslationText" id="d727e1d6-e4fb-4e8f-a200-9d90c5f78710">
        <source>getTranslationText(_locale : CM_Locale; _constantName:String output; _text: String output; _shortText : String output):XLAT_Translation;

vars
	translation 	: XLAT_Translation;
	locale			: CM_Locale;
	
begin
	translation := getTranslation(_locale);
	
	if translation = null then
		_constantName	:=	null;
		_text			:=	null;
		_shortText		:=	null;
	else
		if translation.myTranslatableText = null then
			_constantName	:=	null;
		else
			_constantName	:=	translation.myTranslatableText.vConstantName;
		endif;
		
		_text			:=	translation.text;
		_shortText		:=	translation.shortText;
	endif;
	
	return translation;
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_constantName" type="String" usage="output"/>
        <Parameter name="_text" type="String" usage="output"/>
        <Parameter name="_shortText" type="String" usage="output"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="getUniqueNumber" id="34c4993a-0e17-41a9-919f-075ed6d35e54">
        <source>getUniqueNumber(_category : XLAT_Category; _constant : GlobalConstant):Integer protected;

// assign a unique number (key) when creating a Translatable Text object

vars
	lastTranslatableText : XLAT_TranslatableText;
begin
	if _constant &lt;&gt; null then
		// create from constant
		return _constant.valueAsInteger;
	else
		app.raiseUnexpectedProgramError(class.name, method.name,
			'unable to get number for ' &amp; self.String);
		return -1;
		
		/*
		Never want to just assign a number as this causes problems when
		extract translation file from one system and try to load into 
		another or between upgrades.
		// assign next unique number
		lastTranslatableText := _category.allTranslatableText.last.XLAT_TranslatableText;
		if lastTranslatableText = null then
			return 1;
		else
			return lastTranslatableText.number + 1;
		endif;
		*/
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasGlobalConstant" id="dedbfe3b-e595-4709-a178-857d06b30b05">
        <source>hasGlobalConstant() : Boolean;
// ---------------------------------------------------------------------------
