    <JadeMethod name="setTableDataFromOrganiser" id="5a086251-a690-487d-9695-cd3a073a5ae5">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//06 August 2009	cnwdw1	
//
vars

begin
	
	if _theTable = self.tblExpected then
		self.xmlStrTblExpected := self.tblExpected.getXmlStrForColumns(true);
		self.loadExpectedTable();
	endif;
	
	if _theTable = self.tblActual then
		self.xmlStrTblActual := self.tblActual.getXmlStrForColumns(true);
		self.loadActualTable();
	endif;

	if _theTable = self.tblUnreconciled then
		self.xmlStrTblUnreconciled := self.tblUnreconciled.getXmlStrForColumns(true);
		self.loadUnreconciledTable();
	endif;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblDataDetailCellText" id="06eda4d0-9ebb-40fb-8ea5-a3514de53a91">
        <updating/>
        <source>setTblDataDetailCellText(_tbl : CM_DataTable input) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//----------------------------------------------------------------------

vars
	cntrl : Control;
	table : CM_DataTable;
begin
	table := _tbl;
	
	if (not table.userInputEnabled)
	or table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="d48629ca-486f-435a-8e07-25fd400d31a1">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//06 August 2009	cnwdw1	
//
vars
	tmpMenu : MenuItem;
begin
	inheritMethod(conwin);
	
	self.mnuTblVShowHideData.visible := false;
	self.mnuTblVShowHideSearch.visible := false;
	self.mnuTblVShowHideThumb.visible := false;
	self.mnuTblVDockSearch.visible := false;
	
	if self.tblExpectedMacro.visible then
		self.mnuMacro.caption := "Hide Macro";
	else
		self.mnuMacro.caption := "Show Macro";
	endif;
	
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuMacro, false );

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="daad620b-bb35-41c9-9047-330daef5a30c">
        <updating/>
        <source>setupForm() updating;
//05 August 2009	cnwdw1	
//
vars

begin
	inheritMethod();
	
	self.frmComplete.visible := false;
	self.sptMain.visible := false;
	sptLeft.cnEcResizeContents();
	
	self.tblExpectedMacro.rows := 0;
	self.tblExpectedMacro.columns := 0;
	self.tblActualMacro.rows := 0;
	self.tblActualMacro.columns := 0;
	self.tblUnreconMacro.rows := 0;
	self.tblUnreconMacro.columns := 0;
	
	self.chkShowAllCargo.value := false;
	
	self.frmExpected.setMinimumWidth(250);
	self.frmActual.setMinimumWidth(250);
	self.frmUnreconciled.setMinimumWidth(375);
	
	if self.frmExpected.width &lt; self.frmExpected.minimumWidth then
		self.frmExpected.width := self.frmExpected.minimumWidth;
		//self.resize();
		self.sptLeft.cnEcResizeContents();
		//self.sptRight.cnEcResizeContents();
		endif;
	
	if self.frmActual.width &lt; self.frmActual.minimumWidth then
		self.frmActual.width := self.frmActual.minimumWidth;
	//	self.sptLeft.cnEcResizeContents();
	//	self.sptRight.cnEcResizeContents();
	endif;
	
	if self.frmUnreconciled.width &lt; self.frmUnreconciled.minimumWidth then
		self.frmUnreconciled.width := self.frmUnreconciled.minimumWidth;
	//	self.sptLeft.cnEcResizeContents();
	//	self.sptRight.cnEcResizeContents();
	endif;
	
	self.minimumWidth := self.frmExpected.minimumWidth + self.frmActual.minimumWidth + self.frmUnreconciled.minimumWidth + 20;
	
	self.minimumHeight := 420;	
end;</source>
    </JadeMethod>
