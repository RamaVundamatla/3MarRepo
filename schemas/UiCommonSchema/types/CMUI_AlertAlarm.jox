    <JadeMethod name="loadAlerts" id="99118dc9-190f-4724-91b2-02b96eff4e6a">
        <source>loadAlerts();
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 August 2006	cnwer1	Initial creation - PAR#xxxx
12 Sep 2017		cnwma1	TFS # 6789 NXL - Table error
*/
vars
	user		: CM_User;
	alertType	: CM_SystemAlertType;
	alert		: CM_SystemAlert;
	iter		: Iterator;
	rowNo		: Integer;
	tblRow		: JadeTableRow;
	
begin
	user	:=	app.myPassport.myUser;
	
	if user = null then
		return;
	endif;
	
	tblData.clear();
	
	foreach alertType in user.allSystemAlertTypes  discreteLock do
		 delete iter;
		 iter	:=	alertType.allSystemAlerts.createIterator();
		 
		 while iter.next(alert) do
		 	if alert.reviewed then
		 		continue;
		 	endif;
			
			
			if self.tblData.rows = JadeTableRowLimit then   // 12/09/2017  cnwma1 TFS #6789
				break;
			endif;
			
		 //	tblData.fitTextToCell(alert.details, tmpStr, tblData.width.Integer, cellHeight);
			rowNo	:=	tblData.addItem(alert.details);
			tblRow	:=	tblData.accessRow(rowNo);
			tblRow.itemObject	:=	alert;
			tblRow.foreColor	:=	Red;
		//	tblRow.height := cellHeight;
		 endwhile;	
	endforeach;
epilog
	delete iter;
end;</source>
    </JadeMethod>
