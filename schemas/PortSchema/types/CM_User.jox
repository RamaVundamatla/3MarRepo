    <JadeMethod name="resetSysEntMenuFromSysDefault" id="42d5800d-d204-48f3-b03e-215babd1f799">
        <updating/>
        <source>resetSysEntMenuFromSysDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;		
begin
	create agent transient;
	
	if self.myMenuRootForSysEntities = null then
		self.createMenuRootForSysEntities();
	endif;
	
	agent.trxSaveToSourceMenuRoot(agent.mySystemMenuRootForSysEntities, self.myMenuRootForSysEntities, self, _clearFirst);
	self.checkSysMenuAgainstPermissions(true);
epilog
	delete agent;
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetToolbarMenuFromJMTDefault" id="c8c575ab-bda6-40b7-b7ea-970b9d4a8c21">
        <source>resetToolbarMenuFromJMTDefault();
// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     It is assumed we are already in transaction state when called
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTool			: CM_MenuUserToolbar;
	toolbarRoot			: CM_MenuRootToolbar;
	menuEntity			: CM_MenuEntity;
begin
	self.myMenuUserToolbarRoot.allMenuUserToolbarItems.purge;
	toolbarRoot := app.myRoot.myToolbarJMTRoot;
	foreach menuEntity in toolbarRoot.allChildren do
		if not menuEntity.isKindOf(CM_MenuUserToolbar) then
			continue;
		endif;
		
		create userTool persistent;
		userTool.setFromSystemToolbar(menuEntity.CM_MenuUserToolbar.mySystemToolbar);
		self.myMenuUserToolbarRoot.allMenuUserToolbarItems.add(userTool);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetToolbarMenuFromSysDefault" id="015b0e83-77b2-475c-a06a-383794db86e8">
        <updating/>
        <source>resetToolbarMenuFromSysDefault() updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     It is assumed we are already in transaction state when called
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTool			: CM_MenuUserToolbar;
	toolbarRoot			: CM_MenuRootToolbar;
	menuEntity			: CM_MenuEntity;
begin
	
	self.myMenuUserToolbarRoot.allMenuUserToolbarItems.purge;
	
	toolbarRoot := app.myRoot.myToolbarSysRoot;
	foreach menuEntity in toolbarRoot.allChildren do
		if not menuEntity.isKindOf(CM_MenuUserToolbar) then
			continue;
		endif;
		    
		create userTool persistent;
		userTool.setFromSystemToolbar(menuEntity.CM_MenuUserToolbar.mySystemToolbar);
		self.myMenuUserToolbarRoot.allMenuUserToolbarItems.add(userTool);	
	endforeach;

	self.myMenuUserToolbarRoot.causeEvent( Event_MenuUserToolbarRoot, false, null );	//Par15018
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetUserLockH" id="c4de43bf-7873-4c7f-9744-845cc56267c8">
        <source>resetUserLockH();
/*
 ------------------------------------------------------------------------
Created:			24 July 2001 by cnwdwq1
Purpose:			Raise the event, the server is listening for it. The server will attempt to send 
							a "do nothing" to the unit.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.causeEvent(EVENT_USER_RESET_LOCKH, true, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="sendPasswordResetEmail" id="265ec2f5-b679-4e4a-82f9-f099c28d234c">
        <source>sendPasswordResetEmail( _userPwDefEmail : CM_UserPasswordDefaultEmail; _tempPassword : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlgndl1	Initial creation	TFS 38768

*/

vars

	fromAddress	: String;
	toAddress	: String;
	messageBody : String;
	
	str				: String;
	entTableDef		: EntTableDef;
	entRow			: EntTableRow;
	heading			: String;
	strObjStr		: CM_StringWithString;
	strObj			: CM_String;
	strDict			: CM_StringDict;
	index			: Integer;

begin

	if _userPwDefEmail = null then
		return;
	endif;

	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	toAddress := self.getEmailAddress();
	
	//Set up the message body
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ ETDef_UserEmailTemp ];
	
	create strDict transient;
	
	foreach entRow in entTableDef.allEntTableRows do
		heading := entRow.getHeading(null, null, app.myCurrentLocale);
		if _userPwDefEmail.allIncludedFields.includes(heading) then
			index := _userPwDefEmail.allIncludedFields.indexOf(heading);
			create strObjStr transient;
			if entRow.name = ETRow_EmailTemplatePwd then
				strObjStr.set(index.String, heading &amp; ": " &amp;  _tempPassword );
			else
				strObjStr.set(index.String, heading &amp; ": " &amp;  self.getDisplayStringForAttribute(entRow.name, false));
			endif;
			strDict.add(strObjStr);	
		endif;
	endforeach;
	
	foreach strObj in strDict do
		str := str &amp; strObj.CM_StringWithString.strString &amp; CrLf &amp; CrLf;
	endforeach;
	

	messageBody :=  str &amp; CrLf &amp; CrLf &amp; _userPwDefEmail.message &amp; CrLf;
	
	app.myUtilityCA.utlCreateEmailSendRequest(	true,
												null,
												toAddress,
												fromAddress,
												_userPwDefEmail.ccAddresses,
												_userPwDefEmail.bccAddresses,
												_userPwDefEmail.subjectLine,
												messageBody,
												null,
												null,
												null,
												null,
												EmailSource_UserPW,
												null,
												app.myPassport);

epilog

	strDict.purge;
	delete strDict;	

end;</source>
        <Parameter name="_userPwDefEmail" type="CM_UserPasswordDefaultEmail"/>
        <Parameter name="_tempPassword" type="String"/>
    </JadeMethod>
