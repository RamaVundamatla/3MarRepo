    <JadeMethod name="unplanSlot" id="ce35300f-d10b-44ea-9de4-e0ef7ef22315">
        <updating/>
        <source>unplanSlot(slotController: CM_SlotController) updating;
// Unplan the slot
vars
	moveMode : Integer; 
	theTI : CM_TrackedItem;
	isLoad : Boolean;
	theTIs : CM_TIArray;
begin
	
	if slotController.isBulkRelease() then
		self.doUnplanBulkReleaseSlot(slotController);
	else
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			moveMode := REAL_MODE;
			isLoad := false;
		else
			moveMode := PLANNING_MODE;
			isLoad := true;
		endif;
		create theTIs transient;
		slotController.getTIs(theTIs, moveMode, true); // PAR 27749
		foreach theTI in theTIs do
			//skip anything not planned
			if theTI.myPrimaryPlannedLocation &lt;&gt; null then
				self.doUnplanTI(theTI,isLoad);
			endif;
		endforeach;
	endif;

epilog	
	delete theTIs;
end;</source>
        <Parameter name="slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="updateSlotDefnAttibute" id="045658ab-d03c-4d42-9a0e-ce86ca5caf2e">
        <updating/>
        <source>updateSlotDefnAttibute(_theAttribute : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	theReturn	: Integer;
	theSlots	: CM_SlotControllerSet;
	tmpObj			: Object;
	tmpController	: SHP_BayDrawingController;	
begin

	tmpController := self.myBayDrawingController;

	create theSlots transient;
	tmpController.getSelectedSlotControllers(theSlots);

	while true do
		app.myTrxUA.trxUpdateSlotDefnsAttribute(theSlots, tmpController.allObjectEditions, _theAttribute, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			tmpController.updateEditionForSelectedObjs(theSlots);
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog('Assign Slot Definition Attribute', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete theSlots;
end;</source>
        <access>protected</access>
        <Parameter name="_theAttribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttribDLRSoB" id="7dc135d3-7684-4ad7-9116-c007fe3397df">
        <updating/>
        <source>updateSlotRequestAttribDLRSoB(_moveType : Integer) updating;
vars

	isLoad : Boolean;
	theReturn : Integer;
	theSlots,
	theSlotsAlt,
	sortSlots: CM_LCArray;
	editions : CM_ObjectByOidEditionDict;
begin

	isLoad := (self.displayMode = ShpDisplayMode_ColCodeLoad);
	// NOTE. SLOT are always Discharge, Alt Slots are always Load
	
	create theSlotsAlt transient;
	create theSlots transient;
	create sortSlots transient;
	create editions transient;
	
	app.getSelectedDLRSOBSlots(theSlots, theSlotsAlt, editions, isLoad); // PAR 31144
	
	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif; 
		app.myTrxUA.doRORORequestDLRSoB(theSlots, theSlotsAlt, isLoad,_moveType, editions, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			self.myBayDrawingController.updateEditionForSelectedObjs(theSlots);
			if theSlotsAlt &lt;&gt; null then
				self.myBayDrawingController.updateEditionForSelectedObjs(theSlotsAlt);
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(VoyJob_DLR), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete theSlots;
	delete theSlotsAlt;
	delete sortSlots;
	delete editions;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttribute" id="420b3f3d-bfc8-40bc-a442-0caf924f4b6d">
        <updating/>
        <source>updateSlotRequestAttribute(_attribute : String) updating, protected;
vars
begin
	updateSlotRequestAttributeEx(_attribute, null);
end;</source>
        <access>protected</access>
        <Parameter name="_attribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttributeEx" id="18268033-2678-4a81-aaa7-97e21a472ee5">
        <updating/>
        <source>updateSlotRequestAttributeEx(_attribute : String; _obj : Object) updating, protected;
vars

	tmpObject : Object;
	isLoad : Boolean;
	theReturn : Integer;
	theSlots,
	theSlotsAlt		: CM_SlotControllerArray;
	tmpDrawController	: SHP_BayDrawingController;
	tmpLoadCC	: CMIF_LoadColorCode;
	editions 	: CM_ObjectByOidEditionDict;
begin

	tmpDrawController := self.myBayDrawingController;
	isLoad := (self.displayMode = ShpDisplayMode_ColCodeLoad);
	create theSlots transient;
	create editions transient;
	 //epr par 29903 if we pass in a slotController in the _obj parameter then use that 
	 // slotController not the allselectedObjects
	 if _obj &lt;&gt; null and _obj.isKindOf(CM_SlotController) then
		theSlots.add(_obj.CM_SlotController);
		editions.add(_obj);
	 else
		foreach tmpObject in tmpDrawController.allSelectedObjects do
			if tmpObject.isKindOf(CM_SlotController) then			
					theSlots.add(tmpObject.CM_SlotController);				
			endif;
		endforeach;
		tmpDrawController.allObjectEditions.copy(editions);
	endif;
	
	// When assigning a release need the bulk release reserve detail
	if _attribute = CM_SlotRequest.Attribute_AssignRelease and
			_obj.isKindOf(CM_ReserveDetail) then
		create tmpLoadCC transient;
		self.setLoadColorCodeAttributes(tmpLoadCC, _obj.CM_ReserveDetail);
		
		//epr par 35187 11/11/14 
		if theSlots.first &lt;&gt; null and theSlots.first.CM_SlotController.mySlotRequestLoad &lt;&gt; null then
			tmpLoadCC.myVoyageAllocation:=theSlots.first.CM_SlotController.mySlotRequestLoad.getFirstAllocation;
		endif;
	endif;
	
	// #### Get all the ALT key selected points
	if _attribute = CM_SlotRequest.Attribute_DLR or 
	   _attribute = CM_SlotRequest.Attribute_SOB then
		create theSlotsAlt transient;
		foreach tmpObject in tmpDrawController.allSelectedObjectsAlt do
			if tmpObject.isKindOf(CM_SlotController) then
				theSlotsAlt.add(tmpObject.CM_SlotController);
			endif;
		endforeach;
		
		if isLoad then
			// need to get the load cc attributes as if the slot has not yet
			// has these set we do it from here
			create tmpLoadCC transient;
			if _obj &lt;&gt; null then
				self.setLoadColorCodeAttributesVA(tmpLoadCC, _obj.CM_VoyageAllocation);
			else
				self.setLoadColorCodeAttributes(tmpLoadCC, null);
			endif;
		endif;
	elseif (not tmpDrawController.allSelectedObjectsAlt.isEmpty) then
		app.msgBox('You can only select ALT slots for DLR and SOB pens', "Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif;
		app.myTrxUA.trxUpdateSlotRequestAttribute(theSlots, theSlotsAlt, isLoad,
						editions, _attribute, tmpLoadCC, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			tmpDrawController.updateEditionForSelectedObjs(theSlots);
			if theSlotsAlt &lt;&gt; null then
				tmpDrawController.updateEditionForSelectedObjs(theSlotsAlt);
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog('Assign Slot Request Attribute', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete theSlots;
	delete theSlotsAlt;
	delete tmpLoadCC;
	delete editions;
end;</source>
        <access>protected</access>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttributes" id="94de35c2-27d2-4ddc-b04b-2e14ccac22f6">
        <updating/>
        <source>updateSlotRequestAttributes(_voyAllocation : CM_VoyageAllocation) updating,protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwas3	Initial creation
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding
					Tidy up transient leak
*/

vars
	tmpDrawController	: SHP_BayDrawingController;
	isLoad : Boolean;
	theSlots,
	theSlotsAlt		: CM_SlotControllerArray;
	tmpObject : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn : Integer;
	
begin
	tmpDrawController := self.myBayDrawingController;
	
	isLoad := (self.displayMode = ShpDisplayMode_ColCodeLoad);

	create theSlots transient;
	
	foreach tmpObject in tmpDrawController.allSelectedObjects do
		if tmpObject.isKindOf(CM_SlotController) then			
				theSlots.add(tmpObject.CM_SlotController);				
		endif;
	endforeach;
	
	// #### Get all the ALT key selected points
	
	create theSlotsAlt transient;
	
	foreach tmpObject in tmpDrawController.allSelectedObjectsAlt do
		if tmpObject.isKindOf(CM_SlotController) then
			theSlotsAlt.add(tmpObject.CM_SlotController);
		endif;
	endforeach;
		
	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif;
		app.myTrxUA.trxUpdateSlotRequestVA(theSlots, theSlotsAlt, isLoad,
					tmpDrawController.allObjectEditions, _voyAllocation, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			tmpDrawController.updateEditionForSelectedObjs(theSlots);
			if theSlotsAlt &lt;&gt; null then
				tmpDrawController.updateEditionForSelectedObjs(theSlotsAlt);
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog('Assign Slot Request Attribute', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
					theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete theSlots;			// PAR #30964
	delete theSlotsAlt;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="30c63e8f-32e1-43d7-aa8a-ee1fbf966975">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 May 2008	cnwkpd1		PAR #16814 - Replace global.commonResumInvalidObjHandler
// 20/11/2018 	jlgrh7 		TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	lController 	: CM_LocationsController;
	event 			: Integer;
	gotException	: Boolean;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	// this is eventType
	if eventType = EVENT_PLANNING_GET_NEXT_IN_SEQ then
		if self.workingMode &lt;&gt; WorkMode_Plan then
			return;
		endif;
		if not userInfo.isKindOf(CM_LocationsController) then // AKB2007JULY - DCT EXCEPTION
			return;
		endif;
		lController := userInfo.CM_LocationsController;
		if lController &lt;&gt; null then
			self.doPlanningGetNextPointInSeq(lController);
		endif;
	elseif event = EVENT_VOYAGE_BERTHING_CHANGED then
		if theObject.isKindOf(CM_Voyage) then
			if theObject.CM_Voyage = self.myCurrentVoyage then
				// reset these so that the sequence number are re loaded 
				self.handleBerthingChangeNote();
			endif;
		endif;
	elseif event = Voyage_NewEDI_Event then
        if theObject.isKindOf(CM_Voyage) then
        	if theObject.CM_Voyage = self.myCurrentVoyage then
        		self.doMnuWorkEDIFilesBuild();
				self.doMnuWorkEDIDeleteBuild();
			endif;
		endif;
	
	elseif event = EVENT_VOY_ALLOC_UPDATE then							//+TFS41374							
		if theObject.isKindOf(CM_Voyage) then
			if theObject.CM_Voyage = self.myCurrentVoyage then
				self.doRefresh;
			endif;
		endif;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewForMode" id="184a8534-32b3-4435-a48e-1b23b618beb0">
        <updating/>
        <source>viewForMode(_theIndex : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Changed By	Par			Reason
// -----------  ----------  ----------  --------------------------------------
// 12/10/2009	cnwmh5		PAR 21297	Change so that Title Bar and Status Line
//										show ISO Type/ISO Group correctly when 
//										selected
// ---------------------------------------------------------------------------
vars

begin

	if _theIndex &lt;= VIEW_TEMPERATURE or 
	   _theIndex = VIEW_WEIGHT or 
	   _theIndex = VIEW_LOADPORT then

		if (not self.toolbarClickPreProcessing(VIEW_SEQUENCE)) then
			return;
		endif;

		self.frmStatusLine.myFrameCaption.caption := self.myBayDrawingController.setViewMode(_theIndex);
		self.redraw();

		if _theIndex = VIEW_IMPORT or 
		   _theIndex = VIEW_EXPORT then
		else
			self.setCaptionForModes(self.displayMode);
			self.doNotesForLegendStartStop(_theIndex);
		endif;
			
		// 12/10/2009 cnwmh5 #21297 - Start
		if _theIndex = VIEW_ISOGROUP and self.frmColLegendTIs.myLegendTable.getCellText(1, 1).trimBlanks = "ISO Type" then
			self.frmStatusLine.myFrameCaption.caption := self.frmStatusLine.myFrameCaption.caption.replaceString("Group", "Type");
			self.caption := self.caption.replaceString("Group", "Type");
		endif;
		// 12/10/2009 cnwmh5 #21297 - End
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _index (' &amp; _theIndex.String &amp; ')');
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="voyageDrawGridAreasForMode" id="fdd6298f-769b-4623-af1d-f5a5b7bf329d">
        <updating/>
        <source>voyageDrawGridAreasForMode() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	theMode		: Integer;
	endTime,
	startTime : TimeStamp;
	ediIndex,
	st			: Integer;
begin
	theMode	:= self.displayMode;

	startTime := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	self.tblGridAreaInfo.rows := 0;
	self.picCargo.picture := null;
	
	self.modalDialogUpdateInfo("Getting Bay Data");	
	
	self.doClearAllSelectedPoints();
	self.myBayDrawingController.drawSelf(true);

	if theMode &lt;&gt; ShpDisplayMode_ColCodeLoad and 
	   theMode &lt;&gt; ShpDisplayMode_ColCodeDisch then
		// displayViewModeCodes attempts to build a legend of only the colours used in drawing the grid area else it will carry on as usual
		self.frmColLegendTIs.viewMode := null;
		self.doNotesForLegendStartStop(self.myBayDrawingController.viewMode);
	endif;

epilog
	self.frmModalDialog.visible := false;
	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="voyageDrawMessage" id="505e5f58-66d0-46c7-99ee-09da14f99b38">
        <source>voyageDrawMessage(_message : String);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.lblModalInfo.caption := _message;
	self.lblModalInfo.refreshNow();

end;</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageLoad" id="5330b17e-cdc9-4d04-bc71-a378e9a3e3fd">
        <updating/>
        <source>voyageLoad(_displayMode : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	st			: Integer;
	aBay 		: CM_Bay;
	aHold 		: CM_Hold;
	newVoyage 	: Boolean;
begin
	if self.myCurrentVoyage = null then
		return false;
	endif;

	self.switchDisplayMode(_displayMode, false);

	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.btnActual.value := false;
	endif;
	
	self.setCaptionForModes(_displayMode);
	
	self.initProgressDialog('Setting up voyage details ...');

	self.doCmbPortDisBuild();

	if (self.selectMode = self.SelectModeHold) then
		if self.allSelectedHolds.isEmpty then
			app.msgBox("Please select some holds to display", "Select Holds Error", MsgBox_OK_Only);
			app.mousePointer := Window.MousePointer_Default;
			self.doMnuWorkDisplayViewVisible(false);
			return false;
		endif;
	elseif (self.selectMode = self.SelectModeOne) then
		//Par13681 - 1311UHE when Bay had not Hold
		if self.allSelectedHolds.isEmpty then
			app.msgBox("The selected Bay has not been allocated to a Hold." &amp; CrLf &amp; "Please allocate the Bay to a Hold and retry.",
			"Select Holds Error", MsgBox_OK_Only);
			app.mousePointer := Window.MousePointer_Default;
			self.doMnuWorkDisplayViewVisible(false);
			return false;
		endif;
	else
		if self.allSelectedBays.isEmpty then
			app.msgBox("Please select some bays to display", "Select Bay Error", MsgBox_OK_Only);
			app.mousePointer := Window.MousePointer_Default;
			self.doMnuWorkDisplayViewVisible(false);
			return false;
		endif;
	
	endif;
		
	self.myBayDrawingController.init(self.myCurrentVoyage, self.allSelectedHolds, self.myTerminal);

	self.doMnuWorkEDIFilesBuild();
	self.doMnuWorkEDIDeleteBuild();
	self.doMnuGlobalVoyageBuild();
	
	self.myBayDrawingController.drawInReverse := self.myCurrentVoyage.starboardBerthed;
	//self.frmDrawing.doZoom(self.xmlZoomFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF
	self.setMyCurrentDrawingController(self.myBayDrawingController, false);
	// set up the notes for this voyage
	self.myBayDrawingController.notableObjectsClear();
	self.myBayDrawingController.notableObjectAdd(self.myCurrentVoyage);
	self.doMnuWorkDisplayViewVisible(true);
	
	self.myBayDrawingController.myDrawingAttrController.clear();
	self.myBayDrawingController.myDrawingAttrController.myTerminal := self.myTerminal;
	self.myBayDrawingController.myDrawingAttrController.shipShowISOType := self.myTerminal.getConfig(ShipShowISOType).Boolean;
	
	self.myBayDrawingController.drawSelf(true); 
	self.layoutRedraw(false);

	self.doScrollToCorners(VIEW_LEFT_TOP);

	self.doNotesForLegendStartStop(self.myBayDrawingController.viewMode);
	self.doMnuWorkRemarksBayBuild();
	self.doBuildMnuZoom(self.mnuWorkDisplayZoom);


	self.frmModalDialog.visible := false;
	if self.frmScrollBackgrd.myDragSelectFrame &lt;&gt; null then
		self.frmScrollBackgrd.myDragSelectFrame.zOrder(1);
		self.frmScrollBackgrd.resizeDragFrame();
	endif;

	return true;

epilog
	self.frmModalDialog.visible := false;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="workModeJob" id="0509ff70-c224-4d2f-8754-e9238a83d357">
        <updating/>
        <source>workModeJob(_needRedraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	dispString : String;
	useAlloc : Boolean;
begin
	useAlloc := false;
	if self.myCurrentVoyage &lt;&gt; null then
		useAlloc := self.myCurrentVoyage.useVoyageAllocations;
	endif;

	
	self.mnuWorkCCMain.visible := true;
	self.mnuWorkCCJobNew.visible := true;
	self.mnuWorkViewMain.visible := false;
	self.mnuWorkDisplayMain.visible := true;
	self.mnuWorkCCJobMain.visible := true;

	self.hideShowPens(not useAlloc, true);
	self.hideShowViewModes(false);
	self.frmToolbar2.visible := true;
	
	self.enableDisableAttributePens(false);
	self.enableDisableDrawingPens(false);
	
	self.btnColorCodeDish.enabled	:= true;
	self.btnColorCodeLoad.enabled	:= true;

	self.btnSaveBase.visible	:= true;
	self.btnDelete.visible		:= true;
	self.btnEdit.visible		:= true;	

	self.cmbCargoType.visible	:=	false;
	self.cmbCommodity.visible	:=	false;
	self.cmbPortDis.visible		:=	false;
	self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkShipTLHeight.visible := true;
	self.chkShipTLWeight.visible := true;

	self.cmbCrane.visible := true;
	self.cmbJob.visible := true;
	
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.txtJobLinkLoad.visible := true;
	else
		self.txtJobLinkLoad.visible := false;
	endif;

	self.setToolbarCombosWidth();
	self.frmToolbarCombos.visible := true;
	self.frmToolbarChk.visible := true;
	self.chkIgnoreWeightV.visible := false;	// cnwdad1 09/08/2010 - PAR #25353.

	self.tblGridAreaInfo.rows := 0;
	if _needRedraw then
		self.myBayDrawingController.drawSelf(true);
	endif;
	
	self.setWorkingModeBubble();

end;</source>
        <Parameter name="_needRedraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="workModeNone" id="d137084a-e2eb-4d30-be57-6f77b3b0e32b">
        <updating/>
        <source>workModeNone(_needRedraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	self.btnSaveBase.visible	:= false;
	self.btnDelete.visible		:= false;
	self.btnEdit.visible		:= false;	

	self.cmbCargoType.visible	:=	false;
	self.cmbCommodity.visible	:=	false;
	self.cmbPortDis.visible		:=	false;
	self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;
	
	self.frmToolbarCombos.visible := false;
	self.frmToolbarChk.visible := false;
	// reset the width to 0 so display of other buttons works correctly
	self.frmToolbarCombos.width := 0;
	
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.displayModeColourDischarge();
		
	elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.displayModeColourLoad();
	endif;
	
	//epr TFS 3284
	if self.workingMode = self.WorkMode_Plan then
		self.workModePlanning();
	endif;
	
	self.chkIgnoreWeightV.visible :=	false;				// cnwdad1 02/08/2010 - PAR #24045.
	
	if app.myMoveController &lt;&gt; null then
		app.myMoveController.ignoreWeightValidation	:=	false;	// cnwdad1 02/08/2010 - PAR #24045.
	endif;
	
	if _needRedraw then
		self.myBayDrawingController.drawSelf(true);
	endif;

	self.setWorkingModeBubble();
end;</source>
        <Parameter name="_needRedraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="workModePlanning" id="7beabe9d-fd8b-4311-aa51-1f10873c737e">
        <updating/>
        <source>workModePlanning() updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	useAlloc : Boolean;
	
begin
	useAlloc := false;
	if self.myCurrentVoyage &lt;&gt; null then
		useAlloc := self.myCurrentVoyage.useVoyageAllocations;
	endif;

	self.doMnuEDIEnable(false);
		self.frmToolbarCombos.visible := false;
	self.frmToolbarChk.visible := false;

	self.mnuWorkCCMain.visible := true;
	self.mnuWorkCCJobNew.visible := true;
	self.mnuWorkViewMain.visible := false;
	self.mnuWorkDisplayMain.visible := true;
	self.mnuWorkCCJobMain.visible := true;

	self.hideShowPens(not useAlloc, true);
	self.hideShowViewModes(false);
	self.frmToolbar2.visible := true;
	
	self.enableDisableAttributePens(false);
	self.enableDisableDrawingPens(false);
	
	self.btnColorCodeDish.enabled	:= true;
	self.btnColorCodeLoad.enabled	:= true;
	self.btnTwinLiftCrane.visible := true;
	self.btnTwinLiftCrane.enabled := false; // PAR 14810 
	self.btnTwinLiftCrane.userObject := self.btnTwinLiftCrane; // PAR 14810 
	self.btnSaveBase.visible	:= false;
	self.btnDelete.visible		:= false;
	self.btnEdit.visible		:= false;	

	self.cmbCargoType.visible	:=	false;
	self.cmbCommodity.visible	:=	false;
	self.cmbPortDis.visible		:=	false;
	self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible	:=	true;	// cnwdad1 30/07/2010 - PAR #24045.
	
	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;

	self.tblGridAreaInfo.rows := 0;
	
	self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_PLAN);
	self.frmStatusLine.myFrameDisplayMode.enabled := false;
	self.frmStatusLine.myFrameMoveMode.enabled := true;
	self.myBayDrawingController.drawSelf(true);
	self.setWorkingModeBubble();
end;</source>
    </JadeMethod>
    <JadeMethod name="workModeSequence" id="623407c3-6521-486a-94f9-56b134501b03">
        <updating/>
        <source>workModeSequence() updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	saveJob		: CM_VoyageJob;

begin
	self.frmToolbarChk.visible := false;
	self.btnTwinLiftCrane.enabled := true; // PAR 14810 
	self.btnTwinLiftCrane.userObject := null; // PAR 14810 
	self.showHideSequenceToolbar(true);
	self.myBayDrawingController.drawSelf(true);
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.displayModeColourDischarge();
	else
		self.displayModeColourLoad();
	endif;
	
	self.lblSeqNum.visible := true;
	self.txtSeqNum.visible := true;
	self.chkIgnoreWeightV.visible := false;		// 28890 Dec 2011 hide 'Ignore Weight Validation' check box
	
	if self.myCurrentJob &lt;&gt; null then
		// do this to force creation of seq transient objects
		self.setCurrentJob(self.myCurrentJob);
	endif;

	self.setWorkingModeBubble();

end;</source>
    </JadeMethod>
