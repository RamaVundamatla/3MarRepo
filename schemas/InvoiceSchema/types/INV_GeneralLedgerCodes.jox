    <JadeMethod name="doSave" id="7e8a7c6c-8440-4c15-ab06-9904ab886e48">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pxyGLCode		: CM_GLCode;
	theReturn		: Integer;
	table			: CM_EntryTable;
begin

	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyGLCode transient;
	elseif self.mode = Mode_Update then
		pxyGLCode := self.myProxyObject.CM_GLCode;
	else
		return false;
	endif;
	
	
	pxyGLCode.setProxy(self.myCurrentBank,
					   self.tblEntDetail.getValueByName(ETRow_CodeGL).String,
					   self.tblEntDetail.getValueByName(ETRow_Remarks).String,
					   self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean,
					   self.tblEntDetail.getValueByName(ETRow_ExternalReference).String	//28 May 2018	NDL	TFS 38896
					   );

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateGLCode(pxyGLCode,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateGLCode(pxyGLCode, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("General Ledger Code", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyGLCode;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
