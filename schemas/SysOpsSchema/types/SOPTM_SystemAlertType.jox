    <JadeMethod name="doSave" id="a29d975b-7fd9-4eae-bc52-835e8045480b">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwmd1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
	description : String;
	emailAddresses : CM_EmailEntityByTypeNameDict;
	proxySysAlertType : CM_SystemAlertType;
	rtnValue : Boolean;
begin
	theForm := self.myForm;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;
		
	create emailAddresses transient;
	theForm.mulSelect1.getSelected(emailAddresses);   

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Should never be able to add a System Alert Type');
			return false;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxySysAlertType := theForm.myProxyObject.CM_SystemAlertType;
	proxySysAlertType.setProxy(proxySysAlertType.type, proxySysAlertType.name, description, proxySysAlertType.area, app.myRoot, emailAddresses);

	if theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateSystemAlertType(proxySysAlertType, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	endif;

epilog
	delete emailAddresses;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
