    <JadeMethod name="addExtraInformationRow" id="b714e740-1678-4909-9df0-1fe029db4b70">
        <source>addExtraInformationRow(_theTable : Table input; theLine : String; anObjectArray : ObjectArray) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		11 June 2003 by cnwsgp1
//
// Purpose:		Adds theLine and the relevant objects to theTable
// ---------------------------------------------------------------------------
vars
	row : Integer;
	tblCols : Integer;
	objArraySize : Integer;
	idx : Integer;	

begin
	row := _theTable.addItem(theLine);
	
	// add in the objects so that the user can double click for maintenance
	tblCols := _theTable.columns;
	if tblCols &gt; 0 then
		if _theTable.accessCell(row,1).text.trimBlanks = GridPointStringMoreCargo then
			_theTable.accessCell(row,1).backColor := Black;
			_theTable.accessCell(row,1).foreColor := White;
		endif;
		objArraySize := anObjectArray.size;
		
		foreach idx in 1 to tblCols do
			if idx &gt; objArraySize then
				break;
			endif;

			_theTable.accessCell(row,idx).itemObject := anObjectArray[idx];
		endforeach;
	endif;
	
	return row;
end;</source>
        <access>protected</access>
        <Parameter name="_theTable" type="Table" usage="input"/>
        <Parameter name="theLine" type="String"/>
        <Parameter name="anObjectArray" type="ObjectArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addExtraInformationString" id="62dd3834-3d41-4bc5-9e0b-855e2520e135">
        <source>addExtraInformationString(_str : String; _theObjectArray : ObjectArray;
		_idx : Integer; _numColumns : Integer; _newLine : Boolean;
		_theTable : Table input; _column : Integer io;
		_theLine : String io; _lineObjectArray : ObjectArray input) protected;
// ---------------------------------------------------------------------------
// Created:      23 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	obj : Object;
	i : Integer;

begin
	if _newLine then
		// output the currently held line so the header can be added
		// on a new line
		self.addExtraInformationRow(_theTable, _theLine, _lineObjectArray);
		_column := 0;
		_lineObjectArray.clear;
	endif;
	
	// setup and display the header
	_theLine := _str;
	
	// hold the object to be put behind the table cell
	if _theObjectArray.size &gt;= _idx then
		obj := _theObjectArray[_idx];
	else
		obj := null;
	endif;
	// add the object to the array for each column the
	// object is to be displayed over
	foreach i in 1 to _numColumns do
		_lineObjectArray.add(obj);
	endforeach;
	
	_column := _column + _numColumns;
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_theObjectArray" type="ObjectArray"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_numColumns" type="Integer"/>
        <Parameter name="_newLine" type="Boolean"/>
        <Parameter name="_theTable" type="Table" usage="input"/>
        <Parameter name="_column" type="Integer" usage="io"/>
        <Parameter name="_theLine" type="String" usage="io"/>
        <Parameter name="_lineObjectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
