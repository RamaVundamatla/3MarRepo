	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000004");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000004", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('id', 'range', "UUT");
