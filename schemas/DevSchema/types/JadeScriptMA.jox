    <JadeMethod name="eUr54539" id="ccd01724-8603-4b6e-b83c-a9c5ed0fbdcb">
        <source>eUr54539();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2022		navma1	Initial creation

*/

vars
	cargoType 		  : CM_CargoType;
	voyage	  		  : CM_Voyage;
	ti		  	  	  : CM_TrackedItem;
	cargoTypeSet      : CM_CargoTypeSet; 
	iter			  : Iterator;
begin

	voyage := "4480.2069398".asOid.CM_Voyage;
	
	iter := voyage.allOnsiteTIsByCargoTypeId.createIterator();
	
	create cargoTypeSet transient;
	foreach ti in voyage.allOnsiteTIsByCargoTypeId discreteLock do 
		
		cargoTypeSet.addNoDuplicates(ti.myCargoType,false);	
	endforeach;
	
	foreach cargoType in cargoTypeSet discreteLock do
		write cargoType.abbreviation &amp; Tab &amp; cargoType.description;
	endforeach;
epilog

end;</source>
    </JadeMethod>
