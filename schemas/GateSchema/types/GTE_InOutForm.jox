    <JadeMethod name="tblLogDocketData_dblClick" id="8abd343d-6c13-48bd-898b-c29815d0c34c">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLogDocketData_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (not table.accessRow(table.row).selected) or
	   (table.row = 1) then
		self.doLogDocketDataSort();
	else
		self.doLogDocketDataPrefill(null);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
