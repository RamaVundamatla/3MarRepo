	folderName:="G:\results\manual\JHP\q_DbBufferOverflow.wip\104728_OK_63_2g_95%_400_1200\dbhost\dbdrive_server_logs";
	folderName:="\\cnwchcm24\cnwpod$\JBL\BenchMarkResults\mtl\20111115_s25\jmt_kpd_792_20111114_jmtl792a";
	folderName:="\\cnwchcm24\cnwpod$\JBL\BenchMarkResults\mtl\20111114_s25\jmt_kpd_792_20111114_jmtl791a";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\StartStopTest\20120205_s55\upg_d";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\Autodino\20120204_s55\upg_b";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\CMIS\20120206_s55\upg_f";
	folderName:="\\cnwchcs55\u$\jmtl811\logs";
	folderName:="\\cnwchcs79\u$\marpreg\logs";
	folderName:="\\cnwchcs118.cnw.co.nz\results\20130728\jade7007.021\x64-msoft-win64\Release_Ansi\unittestwebservice\2058112930_FAIL\LogFiles97\W3SVC1";
	folderName:="C:\a\jade71\logs";
	folderName:="T:\plant\TestingTools\FunctionalTests\jade";
	folderName:="T:\plant\TestingTools\FunctionalTests\jade";

	folderMask:="*_jommon_*.log";
	folderMask:="*reportserver*.log";
	folderMask:="*cn_log_cnwchcs*.log";
	folderMask:="*results.txt";
	folderMask:="*.*";
	folderMask:="jommon_20101217_cnwjhp1.log";
	folderMask:="webservice*.log";
	folderMask:="_jtd_*.log";
	folderMask:="cn_dump_*.log";
	folderMask:="*profiler*.log";
	folderMask:="allcurrent.conf";
	folderMask:="NUnitTestResult.xml";
	folderMask:="*"&amp;folderName[folderName.length]&amp;"_msg*.log";
	folderMask:="*jommsg*.log";
	folderMask:="msg*.log";
	folderMask:="*.conf";

	include:="";
	include:=": Deadlock Retry number";
	include:="** Record not on file **";
	include:="loaded message number";
	include:="Profiled Time";
	include:="currently held by";
	include:="locked by";
	include:="key=51;level=2";  // queued locks
	include:="in application ";
	include:="JadApp: Application server closed via window close.";
	include:="Check Point";
	//include:="70"; exclude:="7050";
	//include:="&gt;%-is"; orInclude:="&gt;%-isnot";
	include:="&lt;inifile&gt;"; exclude := "IniFiles\AutoQual.ini";

	//hitsmax:=1;
	//linesmax:=50;
	//include:="looking for a move to make"; hitsmax:=1;  // jmt start time
	//include:="Stopping profile"; hitsmax:=1;                 // jmt stop time
	//include:="startup finished"; exclude:="Timeout";  // UoC enrolment start time
	//include:="Stopping profile";                              // UoC enrolment stop time
	//include:="Starting profile"; andInclude:="/299/";  // investigator start time
	//include:="Stopping profile"; andInclude:="/0/";  // investigator stop time
	//include:="Starting profile"; andInclude:="/419/";  // tui start time
	//include:="Stopping profile"; andInclude:="/0/";  // tui stop time
	//andInclude:="Check Point";
	//orInclude:="Check Point";
	//exclude:="completed";
	showFileName:=true;
	
	presentationFileSystem:=true;
	create f;
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=32000;
	f.kind:=File.Kind_Unknown_Text;
	create g;
	g.mode:=File.Mode_Output;
	create ff;
	ff.fileName:=folderName;
	ff.mask:=folderMask;
	ff.usePresentationFileSystem:=presentationFileSystem;
	g.fileName:=folderName&amp;"\grep_"&amp;include.replace('"',"_").replace(":","_").replace("&lt;","_").replace("/","_").replace("\","_").replace(Tab,"_").replace("*","_").replace("&gt;","_")&amp;"_"&amp;ts.date.format("yyyyMMdd")&amp;"_"&amp;ts.time.format("HHmmss")&amp;".log";
	g.usePresentationFileSystem:=true;
	s:="searching "&amp;folderName&amp;"\"&amp;folderMask&amp;" for '"&amp;include&amp;"'";
	if exclude &lt;&gt; null then s:=s&amp;" excluding '"&amp;exclude&amp;"'"; endif;
	if andInclude &lt;&gt; null then s:=s&amp;" and '"&amp;andInclude&amp;"'"; endif;
	if orInclude &lt;&gt; null then s:=s&amp;" or '"&amp;orInclude&amp;"'"; endif;
	g.writeLine(s&amp;CrLf);
	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
	and fn.name[1:5]&lt;&gt;"grep_"
	do
		f.fileName:=fn.fileName;
		//f.maxRecordSize:=64*1024;  // kills static file optimisation
		f.usePresentationFileSystem:=presentationFileSystem;
		if not f.isAvailable then continue; endif;
		hits:=0;
		lines:=0;
		while not f.endOfFile do
			s:=f.readLine&amp;" ";
			if s.pos(include,1) &lt;&gt; 0  // include condition
			and (andInclude = null or s.pos(andInclude,1) &lt;&gt; 0)
			//and (s.contains("S_Rford::preLincLogic "))  // extra include condition
			//and (s.contains("Ordqt"))  // extra include condition
			//and (s.contains("/35:") or s.contains("/39:") or s.contains("/50:") or s.contains("/51:") or s.contains("/56:") or s.contains("/68:") or s.contains("/82:") or s.contains("/89:") or s.contains("/102:") or s.contains("/106:") or s.contains("/128:") or s.contains("/129:") or s.contains("/150:") or s.contains("/173:") or s.contains("/208:"))  // extra include condition
			//and (s.contains("/57:") or s.contains("/76:") or s.contains("/81:") or s.contains("/93:") or s.contains("/99:") or s.contains("/112:") or s.contains("/121:") or s.contains("/135:") or s.contains("/154:") or s.contains("/156:") or s.contains("/209:") or s.contains("/337:") or s.contains("/391:") or s.contains("/402:") or s.contains("/416:"))  // extra include condition
			//and (s.contains("/71:") or s.contains("/72:") or s.contains("/76:") or s.contains("/94:") or s.contains("/100:") or s.contains("/108:") or s.contains("/111:") or s.contains("/114:") or s.contains("/116:") or s.contains("/119:") or s.contains("/124:") or s.contains("/125:") or s.contains("/132:") or s.contains("/139:") or s.contains("/148:") or s.contains("/149:") or s.contains("/155:") or s.contains("/159:") or s.contains("/160:") or s.contains("/169:") or s.contains("/177:") or s.contains("/185:") or s.contains("/187:") or s.contains("/199:") or s.contains("/205:") or s.contains("/206:") or s.contains("/214:") or s.contains("/216:") or s.contains("/220:") or s.contains("/222:") or s.contains("/235:") or s.contains("/240:") or s.contains("/241:") or s.contains("/244:") or s.contains("/247:") or s.contains("/250:") or s.contains("/253:") or s.contains("/254:") or s.contains("/256:") or s.contains("/272:") or s.contains("/273:") or s.contains("/275:") or s.contains("/280:") or s.contains("/285:") or s.contains("/287:") or s.contains("/289:") or s.contains("/293:") or s.contains("/308:") or s.contains("/318:") or s.contains("/341:"))
			//and (s.contains("/46:") or s.contains("/63:") or s.contains("/71:") or s.contains("/78:") or s.contains("/89:") or s.contains("/92:") or s.contains("/103:") or s.contains("/106:") or s.contains("/107:") or s.contains("/115:") or s.contains("/116:") or s.contains("/124:") or s.contains("/126:") or s.contains("/141:") or s.contains("/144:") or s.contains("/145:") or s.contains("/152:") or s.contains("/159:") or s.contains("/162:") or s.contains("/163:") or s.contains("/167:") or s.contains("/169:") or s.contains("/178:") or s.contains("/183:") or s.contains("/184:") or s.contains("/189:") or s.contains("/194:") or s.contains("/195:") or s.contains("/203:") or s.contains("/204:") or s.contains("/205:") or s.contains("/210:") or s.contains("/216:") or s.contains("/224:") or s.contains("/227:") or s.contains("/233:") or s.contains("/235:") or s.contains("/236:") or s.contains("/237:") or s.contains("/243:") or s.contains("/245:") or s.contains("/249:") or s.contains("/254:") or s.contains("/257:") or s.contains("/261:") or s.contains("/266:") or s.contains("/268:") or s.contains("/275:") or s.contains("/410:") or s.contains("/425:"))
			and (exclude = null or s.pos(exclude,1) = 0)
			or (orInclude &lt;&gt; null and s.pos(orInclude,1) &lt;&gt; 0)
			then
				if showFileName then
					s:=fn.name&amp;": "&amp;s;  // prepend filename
				endif;
				g.writeLine(s);
//				write fn.name&amp;": "&amp;s;
				hits:=hits+1;
				if hitsmax &gt; 0 and hits &gt;= hitsmax then break; endif;
			endif;
			lines:=lines+1;
			if linesmax &gt; 0 and lines &gt;= linesmax then break; endif;
		endwhile;
		f.close;
	endforeach;
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="logProfCnTranlogStats" id="08133710-6caf-42b9-9210-3f98935ea5b7">
        <source>logProfCnTranlogStats();
//	creates a cn_tranlog_stats file from profiler logs
vars
	s,t,folderName,folderMask,include,exclude,methud:String;
	i,j,k,l,subtime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts:TimeStamp;
	f,g:File; fn:FileNode; ff:FileFolder;
	methods:StringArray; aa:Analysis;
begin
	create methods transient;
	folderName:="C:\a\jmt\772 vs 781 test\work\781";
	folderName:="G:\BenchMarkResults\mtl\20100309_s54\6217_772a";
	folderName:="G:\BenchMarkResults\mtl\20100408_s55\32Va";
	folderName:="G:\BenchMarkResults\mtl\20100412_s55\64Salla";
	folderName:="C:\a\tui\work\profilers\R35";
	folderName:="C:\a\tui\work\profilers\R37noCSF";
	folderName:="G:\BenchMarkResults\mtl\20100420_s55\64Sjpa";
	folderName:="G:\BenchMarkResults\mtl\20100421_s55\64Sjpua";
	folderName:="G:\BenchMarkResults\tui\20100423_s54\R37_280a\profilers";
	folderName:="G:\BenchMarkResults\tui\20100503_s54\R37CSFa\profilers";
	folderName:="G:\BenchMarkResults\mtl\20100526_s55\782x64a";
	folderName:="G:\BenchMarkResults\mtl\20100624_s55\782x32a";
	folderName:="G:\BenchMarkResults\mtl\20100624_s55\772a";
	folderName:="G:\BenchMarkResults\tui\20100706_s54\R37a\profilers";
	folderName:="\\cnwchcs55\u$\jmtl791\logsf";
	folderName:="G:\BenchMarkResults\mtl\20110202_s55\782a";
	folderName:="G:\BenchMarkResults\CMIS3\20110322_s25\M1020a\profilers";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\mtl\20110520_s25\base_a";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\mtl\20110523_s25\base_a";
	folderName:="\\cnwchcm24\cnwpod$\JBL\BenchMarkResults\mtl\20111115_s25\jmt_kpd_792_20111115_jmtl791a";
	folderName:="\\cnwchcm24\cnwpod$\JBL\BenchMarkResults\mtl\20111116_s25\jmt_kpd_792_20111115_jmtl792a";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\CMIS\20120206_s55\upg_a";
	folderName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\CMIS\20120206_s55\upg_d";
	

	//folderMask:="*profiler_receiptsrfgun*.log";
	//folderMask:="*profiler_receiptsadmin*.log";
	//folderMask:="*profiler_receipts*.log";
	//folderMask:="*profiler_searchcn*.log";
	folderMask:="*profiler_*.log";
	
	//logProfMethodsJMT(methods);  // keep creator shadow copy up to date too
	//logProfMethodsTUI(methods);
	logProfMethodsIVG(methods);
	
	create aa transient;
	aa.inFile.fileName:=folderName&amp;"\cn_tranlog"&amp;"_"&amp;ts.date.format("yyyyMMdd")&amp;"_"&amp;ts.time.format("HHmmss")&amp;".csv";
	create f;
	f.kind:=File.Kind_Unknown_Text;
	f.mode:=File.Mode_Input;
	f.shareMode:=File.Share_Read;  // "optimisation" for static files
	create g;
	g.mode:=File.Mode_Output;
	create ff;
	ff.fileName:=folderName;
	ff.mask:=folderMask;
	ff.usePresentationFileSystem:=presentationFileSystem;
	g.fileName:=folderName&amp;"\grep_"&amp;ts.time.format("HHmmss")&amp;".log";
	g.usePresentationFileSystem:=presentationFileSystem;
	g.writeLine("searching "&amp;folderName&amp;"\"&amp;folderMask&amp;" for '"&amp;include&amp;"'"&amp;CrLf);
	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
	and fn.name[1:5]&lt;&gt;"grep_"
	do
		i:=i+1;
		f.fileName:=fn.fileName;
		f.usePresentationFileSystem:=presentationFileSystem;
		//g.writeLine(fn.name&amp;":");
		foundSection:=false;
		while not f.endOfFile do
			s:=f.readLine&amp;";";
			if s.cnContains("Methods ordered by total method load time:") then
				break;
			endif;
			if s.cnContains("Methods ordered by total time:") then
				foundSection:=true;
				s:=f.readLine;
				s:=f.readLine;
				s:=f.readLine&amp;";";
			endif;
			if not foundSection then
				continue;
			endif;
			foreach methud in methods do
				//write methud&amp;" "&amp;f.fileName;
				if methud &lt;&gt; null and s.cnContains(methud&amp;";") then
					g.writeLine(s);  // detail line
					aa.profAddThis(methud, s);
				endif;
			endforeach;
		endwhile;
		f.close;
	endforeach;
	//aa.allTranStats1.inspectModal;
	aa.profDoTotals;
	aa.writeStatsFile;
	//g.writeLine("Totals");
	//g.writeLine(tottime.String.rightAlign(9)&amp;Tab&amp;totcount.String.rightAlign(9));
	g.writeLine(i.String&amp;" files processed");
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
	delete methods;
	delete aa;
end;</source>
    </JadeMethod>
