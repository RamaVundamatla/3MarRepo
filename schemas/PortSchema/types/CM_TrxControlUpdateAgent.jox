    <JadeMethod name="trxUpdateTerminalAreaView" id="8253e902-488d-4cb2-9fe2-baf8c49a414e">
        <updating/>
        <source>trxUpdateTerminalAreaView( _proxyAreaView: CM_TerminalAreaView input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars
	realAreaView	: CM_TerminalAreaView;
	expectedEdition	: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_proxyAreaView.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_proxyAreaView.pxyGetRealObjectAndEdition(realAreaView, expectedEdition);
	if realAreaView = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalAreaView.name, null, null);
		return;
	endif;
	
	reserveLock(realAreaView);
	
	if _passport.noErrors() and realAreaView.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Terminal Area View", null, null);
		return;
	endif;
	
	app.myUtilityUA.utlUpdateTerminalAreaView(_proxyAreaView, realAreaView, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyAreaView" type="CM_TerminalAreaView" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
