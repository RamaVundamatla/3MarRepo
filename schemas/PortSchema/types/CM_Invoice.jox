    <JadeMethod name="getStevedoreCode" id="c80a40d3-46e1-4ddb-a733-fc549514d354">
        <source>getStevedoreCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars
	invline 	: CM_InvoiceLine;
	ti      	: CM_TrackedItem;
	bookingRef  : CM_BookingRef;
begin
	
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
	else
		foreach invline in self.invoiceLines discreteLock do
			if invline.trackedItem &lt;&gt; null then
				ti := invline.trackedItem;
				break;
			endif;
		endforeach;
	endif;
	
	if ti &lt;&gt; null then
		if ti.myBookingRef &lt;&gt; null then
			bookingRef := ti.myBookingRef;
			if bookingRef.myStevedore &lt;&gt; null then
				return bookingRef.myStevedore.code;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringForPrintInvGeneration" id="beb7b6cd-4423-4fdc-ab63-afe47fa42df6">
        <source>getStringForPrintInvGeneration( _invAmount : Decimal output; _debtorMaxLength : Integer ) : String;
/* ---------------------------------------------------------------------------
Created:	10 November 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	strOut		: String;
	debtorName	: String;
	
begin
	
	// Invoice Number
	strOut := strOut &amp; self.sequenceNum.asStringJMT() &amp; Tab;
	// Invoice Status
	strOut := strOut &amp; self.getStatusDescription(self.status) &amp; Tab;
	//Debtor
	debtorName := self.debtor.name;
	if _debtorMaxLength &gt; 0 and debtorName.length() &gt; _debtorMaxLength	// truncating debtor name if required
	then
		debtorName := debtorName[1:_debtorMaxLength-2] &amp; "...";
	endif;
	strOut := strOut &amp; debtorName &amp; Tab;
	
	//number of invoice lines
	strOut := strOut &amp; self.invoiceLines.size.asStringJMT() &amp; Tab;
	//amount
	_invAmount	:= self.getTotalAmount();
	strOut := strOut &amp; _invAmount.asStringJMT() &amp; Tab;
	//Start Date
	strOut := strOut &amp; self.fromDT.date.asStringJMT() &amp; Tab;
	//End Date
	strOut := strOut &amp; self.toDT.date.asStringJMT();
	
	
	return strOut;

end;</source>
        <Parameter name="_invAmount" type="Decimal" usage="output"/>
        <Parameter name="_debtorMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForInvoice" id="5593b9f6-319e-4a4b-88ad-7e7d3e52749e">
        <source>getTaxAmountForInvoice() : Real;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwab1
// PAR 25720
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	taxAmount : Real;
	theInvoiceLine : CM_InvoiceLine;
	charge : CM_Charge;
begin
	foreach theInvoiceLine in self.invoiceLines do
		foreach charge in theInvoiceLine.charges do
			taxAmount := taxAmount + charge.getTaxAmountForCharge();
		endforeach;
	endforeach;

	return taxAmount;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxCodesDescAsString" id="d4e81891-6496-47af-a7ec-bdc69792049a">
        <source>getTaxCodesDescAsString(_desc: Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navlc30 ChangeRequest 59481: EUP | New Scope 54831 [15] - Total Tax Display on Invoice List Screen

*/

vars
	invoiceLine : CM_InvoiceLine;
	str			: String;
	taxCode		: String;
begin
	foreach invoiceLine in self.invoiceLines do	
		taxCode := invoiceLine.getTaxCode(_desc); 
		if taxCode &lt;&gt; null then
			if not str.cnContains(taxCode)then
				if str &lt;&gt; null then
					str :=  str &amp; Comma &amp; taxCode ;				
				else
					str := taxCode;
				endif;
			endif;
		endif;
	endforeach;
	
	return str;
	
epilog

end;</source>
        <Parameter name="_desc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxForInvoice" id="5e0b7e9f-8087-4498-9251-5f2e43742ca7">
        <source>getTaxForInvoice(_useSplitTax : Boolean; _total : Decimal; _codes : StringArray input; _rates  : RealArray input; _amounts : RealArray input);
// ---------------------------------------------------------------------------
// Created:		18 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//	Total parameter and code to use it added Dec 2010 for par 25978 invoice rounding
// ---------------------------------------------------------------------------
vars
	count,
	idx		: Integer;
	charge	: CM_Charge;
	theInvoiceLine : CM_InvoiceLine;
begin
	
	_codes.clear;
	_rates.clear;
	_amounts.clear;
	
	if _useSplitTax then
		foreach theInvoiceLine in self.invoiceLines do
			foreach charge in theInvoiceLine.charges do
				charge.getTaxForInvoice(true, _codes, _rates, _amounts);
			endforeach;
		endforeach;
		// if only one tax rate, use the passed-in total to avoid rounding issues with the taxable total
		foreach idx in 1 to _codes.size do
			if _amounts[idx] &lt;&gt; 0 then
				count := count + 1;
			endif;
		endforeach;
		if count = 1 then
			foreach idx in 1 to _codes.size do
				if _amounts[idx] &lt;&gt; 0 then
					_amounts[idx] := _total;
					break;
				endif;
			endforeach;
		endif;
	else
		_codes.add(self.bank.parentCompany.taxNumber);
		_rates.add(self.bank.parentCompany.taxPercentageRate);
		_amounts.add(_total);
		//_amounts.add(self.getTotalAmount());
	
	endif;	
end;</source>
        <Parameter name="_useSplitTax" type="Boolean"/>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="_codes" type="StringArray" usage="input"/>
        <Parameter name="_rates" type="RealArray" usage="input"/>
        <Parameter name="_amounts" type="RealArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaxRateForInvoice" id="0759ce18-6663-4eab-b3bc-12ccca41a39d">
        <source>getTaxRateForInvoice() : Real;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwab1
// This method works out the tax rate across multiple tax rates used on the invoice lines.
// PAR 25720
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	invAmount, taxAmount : Real;
begin
	taxAmount := self.getTaxAmountForInvoice();
	invAmount := self.getTotalAmount();
	
	if invAmount = 0 then // PAR 25864
		return 0;
	else
		return ((taxAmount/invAmount) * 100);
	endif;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxRatesAsString" id="dab0046c-9feb-4bd5-91e7-4621ac0231d9">
        <source>getTaxRatesAsString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navlc30 ChangeRequest 59481: EUP | New Scope 54831 [15] - Total Tax Display on Invoice List Screen

*/

vars
	invoiceLine : CM_InvoiceLine;
	str,
	taxRate     : String;
begin

	foreach invoiceLine in self.invoiceLines do 
		taxRate := invoiceLine.getTaxRateForLine().String;
		if taxRate &lt;&gt; null then
			if not str.cnContains(taxRate) then
				if str &lt;&gt; null then
					str := str &amp; Comma &amp; taxRate;
				else
					str := taxRate;
				endif;	
			endif;
		endif;
	endforeach;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxValueForInvoice" id="bfe34840-63f1-4ad2-9666-81b94509b9c7">
        <source>getTaxValueForInvoice() : Real;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371
*/

vars
	taxAmount : Real;
	theInvoiceLine : CM_InvoiceLine;
	charge : CM_Charge;
begin
	foreach theInvoiceLine in self.invoiceLines do
			taxAmount := taxAmount + theInvoiceLine.taxValue;
	endforeach;

	return taxAmount;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTermsOfTradeStr" id="faa9c8ac-cca0-49d5-93e3-e714bb440ed6">
        <source>getTermsOfTradeStr(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		18 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.debtor &lt;&gt; null then
		if self.debtor.myTermsOfTrade &lt;&gt; null then
			return self.debtor.getTermsOfTrade(_short);
		endif;
	endif;
	
	if self.invoiceType.myInvTermsOfTrade &lt;&gt; null then
		if _short then
			return self.invoiceType.myInvTermsOfTrade.code;		
		else
			return self.invoiceType.myInvTermsOfTrade.description;
		endif;
