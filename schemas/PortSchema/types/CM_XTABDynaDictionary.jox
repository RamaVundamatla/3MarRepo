    <JadeMethod name="handleError1314" id="cda47962-0655-4def-b83d-ce01be432726">
        <source>handleError1314(_exception :Exception; _error :Boolean output):Integer;
// ---------------------------------------------------------------------------
//	exception 1314 The ordinal position of the requested key is out of range
//
// Created:     02 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _exception.errorCode = 1314 then
		_error := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException1322" id="95fb3bcf-e625-40b1-aa01-f5168e0831dd">
        <source>handleException1322( _exception : Exception; _error1322 : Boolean output ) : Integer protected;

/*

Purpose:		This exception handler will trap UE 1322 - Total key size exceeds 512 characters.
				This error is raised by the dynamic dictionary addMemberKey method or addExternalKey method
				if the total size of your keys when concatenated exceeds the dictionary limit of 512 character units.
Parameters:		The exception object
Return Value:	_error1322 will be set to true if this error occurs.

Date				Who		Reason
21 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if _exception.errorCode = 1322 then		// Total key size exceeds 512 characters.
		_error1322	:= true;	// Use this in the arming method.
		// from 36979 doing msgBox in load/transaction state, as from background, just raises a second error which gets in the way so don't do it
		if not process.isInLoadState and not process.isInTransactionState then
			app.msgBox(	app.getErrorString( SummaryDefn_TotalKeysTooLong ),
						app.getErrorString1( WARN_GENERIC, 'Failed to produce full report' ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		endif;
		return Ex_Resume_Next;	// Passes control back to the method that armed the exception handler.
	endif;
	
	return Ex_Pass_Back;		// Pass control back to the prior local/global exception handler for any other exceptions.
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error1322" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purge" id="04b20465-2519-40fd-8cc7-2bbc3a32a960">
