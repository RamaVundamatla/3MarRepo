        <updating/>
        <source>tblJobs_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

	self.tblJobsChange(table.row);

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled:= false;
		self.btnDeleteTV.enabled:= false;
		self.btnNewTV.enabled:= false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
