        <source>utlCreateEventStreamDef(_proxyEventStreamDef	: CM_EventStreamDefinition input;
						_newEventStreamDef		: CM_EventStreamDefinition output;
						_proxyESEventTypes		: CM_EventStreamEventTypeDict input;
						_passport 				: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	pxyESEventType 			: CM_EventStreamEventType;
	eventStreamEventType 	: CM_EventStreamEventType;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valEventStreamDefinition(_proxyEventStreamDef);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif; 
	
	app.setContinueCMExceptions(false);
	
	create _newEventStreamDef persistent;
	_newEventStreamDef.setForCreate(_proxyEventStreamDef);
	
	foreach pxyESEventType in _proxyESEventTypes do
		create eventStreamEventType persistent;
		eventStreamEventType.setForCreate(pxyESEventType, _newEventStreamDef);
	endforeach;
	
epilog

end;</source>
