    <JadeMethod name="setFromBOLOut" id="5195ae75-4b3b-4271-ad97-a00a4c947d25">
        <updating/>
        <source>setFromBOLOut(_bolOut : CM_BOLOut; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _bolOut = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No Parent passed in", null, null);
		return;		
	endif;
	
	exclusiveLock(self);

	if self.myReleaseBOL &lt;&gt; null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_ATTACHED, 'Docket No.' &amp; _bolOut.number, 'has Log ' &amp; self.id, null, null);		
		return;
	endif;

	self.myReleaseBOL 	:= _bolOut;
	self.setMyOperator(_bolOut.myOperator);
	self.myTerminal 	:= _bolOut.myTerminal;
	self.destinationPort := _bolOut.destinationPort;
	
	//29 Jan 2013	NDL	Par 31102
	if _bolOut &lt;&gt; null then
		self.setDirectDelivery( _bolOut.directDelivery, true );
	endif;

end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
