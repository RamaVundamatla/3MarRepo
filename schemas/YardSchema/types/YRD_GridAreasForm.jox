    <JadeMethod name="showRestrictionsForm" id="882430f0-2183-404c-b9af-6feefa534c25">
        <source>showRestrictionsForm(_theTerminalArea : CM_TerminalArea;_areaMode : Integer; _initObject : CM_Object);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	aForm.sendMsgWithParams("setInitializeWithObject", theTerminalArea, _areaMode, _initObject, self.xmlFlipH, self.xmlFlipV);
	aForm.show;	


end;</source>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_initObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="104d7271-2990-4398-a169-a3a24c4023e7">
        <updating/>
        <source>showSelectorForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theSelector				: CMUI_Selector;
	cargoType				: CM_CargoType;
	
begin
	
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	if theSelector = null then
		return;
	endif;
	
	self.setSelector(theSelector);//this will set the default mode
	theSelector.show;

end;</source>
    </JadeMethod>
    <JadeMethod name="showYardAllocation" id="89fb1fee-39cd-4ab2-bea6-76d801c7c82e">
        <updating/>
        <source>showYardAllocation( _ya : CM_YardAllocation ) updating;

/*

Purpose:			Position to given Yard Allocation in YAM table

Parameters:			

Return Value:		


Date				Who		Reason
13 November 2008	consw1	Initial creation

*/

vars
	row	: Integer;
	
begin
	if not self.tblYAM.findObjectInRow( _ya, row ) then
		return;
	endif;
	
	self.tblYAM.topRow := row;
	
	// PAR 19142
	self.tblYAM.clearAllSelected();
	self.tblYAM.row := row;
	self.tblYAM.selected := true;
	
	self.frmStatusLine.myFrameCaption.caption := _ya.code;
	
	// PAR 19142
	//self.myCurrentDrawingController.setBubbleHelp(_ya.code);

epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="830f2bb3-14f3-4116-8127-029fe0a55cc9">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject: Object;
begin

	anObject := theObject;
	self.showExtraInfoForObject(anObject);
	
epilog
	// belts and braces to ensure any possible locks are cleared.
	// We should not be in loadstate anyway
	endLoad;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblGridAreaInfo_contextMenu" id="45869ef7-22b6-4662-b045-587d20353579">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_contextMenu(_table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	showAll : Boolean;
begin
	
	self.doTurnOffContextMenus();
	//epr par 15087
	if self.myCurrentDrawingController = null then
		return false;
	endif;
	showAll := true;
	
	self.mnuGridSeperator02.visible := showAll;
	self.mnuZoomSub.visible := showAll;
	self.mnuGridSelector.visible := showAll;
	
	self.mnuGridHideLegend.visible := true;
	self.mnuHideSelectorPanel.visible := true;	//28 Jul 2011	NDL	Par 27890
	self.mnuGridHideMacro.visible := true;
	self.mnuGridBigFont.visible := true;
	self.mnuGridSeperator01.visible := false;

	if _table.row &gt; 0 then
		theObject := _table.accessCell(_table.row,_table.column).itemObject;
		if theObject &lt;&gt; null then
			if theObject.isKindOf(CM_SlotController) 
			or theObject.isKindOf(CM_BayVoyage) 
			or theObject.isKindOf(CM_SlotDefn) then
				theObject.inspect;
			else
				if theObject.isKindOf(CM_TrackedItem)  then
					self.doBuildMnuContainer(theObject.CM_TrackedItem, null);
				endif;
			endif;
		endif;
	endif;
	if self.myCurrentDrawingController.getOverlayFrame(false).visible then
		self.mnuZoomSub.visible := true;
		self.mnuGridSelector.visible := false;
	endif;

	return self.showContextMenu(mnuGridAreaContext, _table, conwin, mouse, x, y);
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
