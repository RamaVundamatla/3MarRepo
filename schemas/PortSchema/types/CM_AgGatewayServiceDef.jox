    <JadeMethod name="getDisplayStringForAttribute" id="e3dd95a7-05d0-4a29-8138-44a52e4000d7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15th July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025
09 September 2025	navnk30	JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages
*/
vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceAgGateway;	
	elseif _attrName = ETRow_Terminal then
		return self.myTerminal.code;
	elseif _attrName = ETRow_InboundEwsHistoryEnable then
		return self.recordInboundEwsHistory.String;
	elseif _attrName = ETRow_OutboundEwsHistoryEnable then
		return self.recordOutboundEwsHistory.String;
	elseif _attrName = ETRow_AgMsgRetentionPeriod then
		return self.msgRetentionPeriod.String;
	endif;
	
	return inheritMethod(_attrName, _short);	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndpointsView" id="8c6212d5-d2fc-4aee-b122-4e5d03cb06fe">
        <source>getEndpointsView(): EntTableView;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2024	navnk30	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars
	def : EntTableDef;
begin
	def := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ExtWebService];
	if def = null then
		return null;
	endif;
	
	return def.allEntTableViews[ETView_EndPointAgGateway];

epilog

end;</source>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
