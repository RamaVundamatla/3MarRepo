    <JadeMethod name="calculateFormatPrecision" id="f4607bcb-9af3-417c-bdb3-d732322c6f59">
        <source>calculateFormatPrecision(_format : Decimal):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type

*/

vars
	value  : Integer;
	str    : String;
	pos	   : Integer;
	decSep : String;
begin
	decSep := Period;																	
	
	str := _format.String.stripTrailingChar("0");
	pos := str.reversePos(decSep);
	
	if pos &lt;&gt; null and pos &lt;&gt; str.length then
		value := str[pos+1:end].Integer;
	else
		value := null;
	endif;
	
	return value;
epilog

end;</source>
        <Parameter name="_format" type="Decimal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkForDefault" id="9b47ec1b-f1cd-4382-b948-e59d850a772e">
        <updating/>
        <source>checkForDefault() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	measure : CM_MeasurementType;

begin
	if self.isDefault then
		foreach measure in self.myRoot.allMeasurementTypesByShortName where measure.measurementType = self.measurementType do
			if measure &lt;&gt; self and measure.isDefault then
				measure.setIsDefaultToFalse;
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertMeasurementForDisplay" id="51bd5ae2-ce91-492d-a8b0-e74737238e80">
        <source>convertMeasurementForDisplay( _value : Decimal ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2013	cnwndl1	Initial creation	Par 32624 - Moved from app...
14 March 2014	cnwdap1	PAR #33603 Don't need to use lcoale-sensitive decimal separator here,
						we're dealing with the database value which always has a "." as the decimal 
*/

vars

	decimalSep		: String;
	result			: Decimal [23,10];
	pos				: Integer;
	inches			: Decimal [12,10];
	retVal			: String;
	buildResult		: String;
	overFlowed 		: Boolean;
	msg 			: String;
begin

	decimalSep 	:= app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	on Exception do app.handlePrecisionError(exception, overFlowed );	//23 Dec 2013	NDL found during testing
	
	if self.measurementType = Type_Displacement and _value = NULL_VENTILATION then
		//result := null;															//21.11.2022 navma1 #55424
		return null;																//21.11.2022 navma1 #55424
	else
	
		result := (_value / self.conversionRate).roundedTo(self.formatPrecision);	//21.11.2022 navma1 #55424
		if overFlowed then
			msg := app.getErrorString( Precision_overflow_error );
			msg := msg &amp; "  " &amp; app.getErrorString3( Unable_convert_for_display, _value.String, self.conversionRate.String, self.name );
			app.createAlertWithProcessStack(msg, true);
			return "&lt;?????&gt;";
		endif;

		if self.shortName = System_Type_Feet then								//21.11.2022 navma1 #55424							
			pos 	:= result.String.reversePos(Period);						// PAR #33603
			inches 	:= result.String[pos:end].Decimal;
			inches 	:= (12 * inches).roundedTo(0);
			
			if inches = 12 then
				result := result + 1;
				inches := 0;
			endif;
			
			buildResult := result.truncatedTo(0).String &amp; Period &amp; inches.Integer.String;			// PAR #33603
			result 		:= buildResult.Decimal;
		endif;
	endif;
	
	
	if result = null then
		// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		if self.measurementType = Type_Weight or self.measurementType = Type_Volume then
			retVal := "0";
		else
			retVal := null;
		endif;
	else
		retVal := result.asStringJMTWithPrecision(self.formatPrecision, false);						//21.11.2022 navma1 #55424
		
		if self.shortName = System_Type_Feet then													//21.11.2022 navma1 #55424
			if  inches &gt; 0 and inches &lt; 10 then
				retVal := retVal[1:retVal.length-1];
			elseif  inches = 0 then
				retVal := retVal[1:retVal.length-3];
			endif;
		endif;
	endif;
	
	return retVal;
	
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertValueAsValue" id="0cf7d08a-538a-4507-8965-153cec90db65">
        <source>convertValueAsValue(_value : Decimal) : Decimal;
/*
	TFS 51393 - just give the number

*/
vars


begin
	return (_value / self.conversionRate).roundedTo(self.getDecimalPrecision);
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="convertValueToDefault" id="7229f10f-67b4-4307-8d47-88a622242ad9">
        <source>convertValueToDefault(_value : Decimal) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Impeial Measurements
*/
vars
	str 	: String;

begin
	str := (_value / self.conversionRate).roundedTo(self.getDecimalPrecision).asStringJMT;
	return str;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="95e2e028-590e-4d10-8267-1ca77599fb4c">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/08/2014	cnwdap1		Initial creation PAR #33235 Update Summaries if measurement type deleted
//
vars

begin
	if not self.isTransient then
		self.updateQueryDefinitions(false, false, true, self.shortName);
	endif;
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
