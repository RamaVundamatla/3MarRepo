    <JadeMethod name="getVoyCutoffEarliest" id="281b6cd8-7263-49e0-befb-b89c4c45283d">
        <source>getVoyCutoffEarliest(): TimeStamp;

/*
Date		Who		Reason
28 May 2009	cnwar2	Initial creation

*/
vars
	item 			: CM_BookingRefItem;
	ts, earliestTS	: TimeStamp;
	cutoffFound		: Boolean;
	
begin
	foreach item in self.allBookingRefItems do
		ts := item.cutoffTS;
		if ts &lt;&gt; null then
			if not cutoffFound 
			or ts &lt; earliestTS then
				earliestTS := ts;
			endif;
			cutoffFound := true;
		endif;		
	endforeach;
	
	if cutoffFound then
		return earliestTS;
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getVoyCutoffEarliestLocalTZ" id="7d6458b5-7e6f-4750-9e24-dd73382ebe3d">
        <source>getVoyCutoffEarliestLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return self.systemToLocalTime(self.getVoyCutoffEarliest());
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getVoyEarliestRecLatest" id="f141313f-bbcf-48b7-a891-4b6170c3ce7b">
        <source>getVoyEarliestRecLatest(): TimeStamp;

/*
Date		Who		Reason
29 May 2009	cnwar2	Initial creation

*/
vars
	item 				: CM_BookingRefItem;
	ts, latestTS		: TimeStamp;
	earliestRecFound	: Boolean;
	
begin
	foreach item in self.allBookingRefItems do
		ts := item.earliestReceivalTS;
		if ts &lt;&gt; null then
			if not earliestRecFound 
			or ts &gt; latestTS then
				latestTS := ts;
			endif;
			earliestRecFound := true;
		endif;		
	endforeach;
	
	if earliestRecFound then
		return latestTS;
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
