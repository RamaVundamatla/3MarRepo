    <JadeMethod name="isVoyageVessel_Match" id="83325986-2b43-47cf-8853-06a2246620ef">
        <source>isVoyageVessel_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/

vars
	vesselType 	   : HMS_VesselType;
	str			   : String;
	trackedItem    : CM_TrackedItem;
	voyage 		   : CM_Voyage;
begin
	voyage := self.myTransaction.getVoyage();
	if voyage &lt;&gt; null 
	and voyage.myVessel &lt;&gt; null
	and voyage.myVessel.myHMSVesselData &lt;&gt; null then
		vesselType := voyage.myVessel.myHMSVesselData.myVesselType;
		if vesselType &lt;&gt; null then
			str := vesselType.code;
		endif;
		
	else
		trackedItem := self.myTransaction.myTrackedItem;
	
		if trackedItem &lt;&gt; null then
			vesselType := trackedItem.getVoyageVessel();
			if vesselType &lt;&gt; null then
				str := vesselType.code;
			endif;
		endif;
	endif;
	// Only priorities will be empty.
	if str &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isVoyageVessel_Compare, str);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyage_Match" id="3967afd6-2a85-42e2-b09f-99b119e7e8f8">
        <source>isVoyage_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			
Date		Who		Reason
MARCH 2015	CNWAB1	Initial creation
24 May 2019 cnwma1	Bug 44887: STWO - Resynching transaction incorrectly uses updated data 
*/
vars

begin

	// We don't have a voyage so no match.
	if self.myTransaction.getVoyage = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(self.myTransaction.getVoyage);													

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
