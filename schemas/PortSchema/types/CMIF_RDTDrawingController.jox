    <JadeMethod name="setLabelsFrames" id="b2919f0a-5c96-4741-b55c-c90a132db8eb">
        <updating/>
        <source>setLabelsFrames( _topHLabelsFrame, _bottomHLabelsFrame, _leftVLabelsFrame, _rightVLabelsFrame, _topLeftLabelFrame, _topRightLabelFrame, _bottomLeftLabelFrame, _bottomRightLabelFrame : Frame) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2010	cnwdz2	Initial creation 25642

*/

vars

begin
	self.myTopHLabelsFrame := _topHLabelsFrame;
	if self.myTopHLabelsFrame &lt;&gt; null then
		self.myTopHLabelsFrame.autoRedraw := true;
		self.myTopHLabelsFrame.zOrder(1);
		self.hLabelsFrameHeight := self.myTopHLabelsFrame.height; //21/06/2011 cnwdz2 27732
	endif;
	
	self.myBottomHLabelsFrame := _bottomHLabelsFrame;
	if self.myBottomHLabelsFrame &lt;&gt; null then
		self.myBottomHLabelsFrame.autoRedraw := true;
		self.myBottomHLabelsFrame.zOrder(1);
	endif;
	
	self.myLeftVLabelsFrame := _leftVLabelsFrame;
	if self.myLeftVLabelsFrame &lt;&gt; null then
		self.myLeftVLabelsFrame.autoRedraw := true;
		self.vLabelsFrameWidth := self.myLeftVLabelsFrame.width;//21/06/2011 cnwdz2 27732
	endif;
	
	self.myRightVLabelsFrame := _rightVLabelsFrame;
	if self.myRightVLabelsFrame &lt;&gt; null then
		self.myRightVLabelsFrame.autoRedraw := true;
	endif;
	
	//21/06/2011 cnwdz2 27732
	self.myTopLeftLabelFrame := _topLeftLabelFrame;
	if self.myTopLeftLabelFrame &lt;&gt; null then
		self.myTopLeftLabelFrame.autoRedraw := true;
	endif;
	
	self.myTopRightLabelFrame := _topRightLabelFrame;
	if self.myTopRightLabelFrame &lt;&gt; null then
		self.myTopRightLabelFrame.autoRedraw := true;
	endif;
	
	self.myBottomLeftLabelFrame := _bottomLeftLabelFrame;
	if self.myBottomLeftLabelFrame &lt;&gt; null then
		self.myBottomLeftLabelFrame.autoRedraw := true;
	endif;
	
	self.myBottomRightLabelFrame := _bottomRightLabelFrame;
	if self.myBottomRightLabelFrame &lt;&gt; null then
		self.myBottomRightLabelFrame.autoRedraw := true;
	endif;
epilog

end;</source>
        <Parameter name="_topHLabelsFrame" type="Frame"/>
        <Parameter name="_bottomHLabelsFrame" type="Frame"/>
        <Parameter name="_leftVLabelsFrame" type="Frame"/>
        <Parameter name="_rightVLabelsFrame" type="Frame"/>
        <Parameter name="_topLeftLabelFrame" type="Frame"/>
        <Parameter name="_topRightLabelFrame" type="Frame"/>
        <Parameter name="_bottomLeftLabelFrame" type="Frame"/>
        <Parameter name="_bottomRightLabelFrame" type="Frame"/>
