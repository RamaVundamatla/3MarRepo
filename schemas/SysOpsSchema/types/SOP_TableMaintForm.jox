    <JadeMethod name="loadFonts" id="16ae225b-f9fd-456d-aabc-175924c1e3f5">
        <source>loadFonts();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
//
vars

begin
	self.cmbFont.clear();
	self.cmbFont.addItem("");
	self.cmbFont.addItem("Courier");
