/*

Purpose:			


Return Value:		


Date		Who		Reason
12 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.openTiMasterMaintForm(true);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="3b911ae5-ef3c-415b-b618-d7d80147b620">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
