    <JadeMethod name="getReleaseRequestRef" id="2e143c86-22c7-44fd-8db6-6c8598ef950a">
        <source>getReleaseRequestRef(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodRelease.myReleaseRequest = null then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodRelease.myReleaseRequest.code;
epilog

end;</source>
