    <JadeMethod name="processEIDOLine" id="03a90f77-9d64-4745-a2dc-cd86c146aa18">
        <source>processEIDOLine(	_xmlElementLine : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ti : CM_TrackedItem output;
					_voyage : CM_Voyage;
					_por : String output
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwndl1	Initial creation	TFS 2718 / 2536

*/

vars

	cargoElement : JadeXMLElement;
	mtReturnElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	
	cargoTypeStr : String;
	cargoTypeObj : CM_CargoType;
	cargoId : String;
	
	allTis : CM_TISet;
	str : String;
	por : String;
	porDate : Date;
	porTime : Time;
	porTs : TimeStamp;

begin

	cargoElement := null;
	cargoElement := _xmlElementLine.getElementByTagName(self.TagCargo);
	if cargoElement = null then
		self.addErrorMessTagSetMissing( self.TagEIDOLine, self.TagCargo, _ediFile );
		
	else
		xmlSubElement := null;
		xmlSubElement := cargoElement.getElementByTagName(self.TagCargoType);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( self.TagCargo, self.TagCargoType, _ediFile );
		else
			cargoTypeStr := xmlSubElement.textData.trimBlanks;
			if cargoTypeStr = null then
				self.addErrorMessEmptyTag( self.TagCargo, self.TagCargoType, _ediFile );
				return false;
			endif;
		endif;
		
		if cargoTypeStr.toUpper = "C" then
			cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(1); // container
		elseif cargoTypeStr.isInteger then
			cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(cargoTypeStr.Integer);
		else
			cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr(cargoTypeStr);
		endif;
		if cargoTypeObj = null then
			self.addErrorMessNoMatchingObj( "Cargo Type", self.TagCargo, self.TagCargoType, cargoTypeStr, _ediFile );
			return false;
		endif;
		
		xmlSubElement := null;
		xmlSubElement := cargoElement.getElementByTagName(self.TagCargoNumber);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( self.TagCargo, self.TagCargoNumber, _ediFile );
		else
			cargoId := xmlSubElement.textData.trimBlanks;
			if cargoId = null then
				self.addErrorMessEmptyTag( self.TagCargo, self.TagCargoNumber, _ediFile );
				return false;
			endif;
		endif;
		
	endif;
	
	create allTis transient;
	_voyage.allOnshipTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeObj.id, allTis, null);
	if allTis.isEmpty then
		_voyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeObj.id, allTis, null);
	endif;
	if allTis.isEmpty then
		_ti := _voyage.allNotifiedTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeObj.id );
		if _ti &lt;&gt; null and _ti.id = cargoId and _ti.cargoType = cargoTypeObj.id then
			_ti := null;
		endif;
	elseif not allTis.isEmpty then
		_ti := allTis.first;
	endif;
	
	if _ti = null then
		self.addErrorMessNoMatchingObj( "Cargo Item", self.TagCargo, self.TagCargoNumber, cargoId, _ediFile );
		return false;
	endif;
	
	mtReturnElement := null;
	mtReturnElement := _xmlElementLine.getElementByTagName(self.TagEmptyReturnInfo);
	if mtReturnElement &lt;&gt; null then
	
		xmlSubElement := null;
		xmlSubElement := mtReturnElement.getElementByTagName(self.TagEmptyPlaceOfReturnCode);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null then
				por := str;
			endif;
		endif;
	
		xmlSubElement := null;
		xmlSubElement := mtReturnElement.getElementByTagName(self.TagEmptyPlaceOfReturnName);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null then
				if por &lt;&gt; null then
					por := por &amp; ", ";
				endif;
				por := por &amp; str;
			endif;
		endif;
	
		xmlSubElement := null;
		xmlSubElement := mtReturnElement.getElementByTagName(self.TagEmptyReturnDueDateTime);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null then
				str := xmlSubElement.textData.trimBlanks;
				if str.length = 14 then
					porDate.setDate( str[7:2].Integer, str[5:2].Integer, str[1:4].Integer);
					porTime.setTime( str[9:2].Integer, str[11:2].Integer, str[13:2].Integer, 0);
					porTs.setDate(porDate);
					porTs.setTime(porTime);
				elseif str.length = 8 then
					porDate.setDate( str[7:2].Integer, str[5:2].Integer, str[1:4].Integer);
					porTime.setTime( 0, 0, 0, 0);
					porTs.setDate(porDate);
					porTs.setTime(porTime);
				endif;
				if porDate.isValid then
					if por &lt;&gt; null then
						por := por &amp; ", ";
					endif;
					por := por &amp; porTs.asStringJMT;
				endif;
			endif;
		endif;
		
		if por &lt;&gt; null then
			_por := "Empty Place Of Return = " &amp; por;
		endif;
	
	endif;
	
	return true;

epilog

	delete allTis;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementLine" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_por" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="436ecf48-4f1c-4806-851f-c377f8ba9672">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwndl1	Initial creation	TFS 2718 / 2536
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars

	message : String;
	xmlDoc : CM_XMLDocument;
	rootElement : JadeXMLElement;
	
	xmlElementMH : JadeXMLElement;
	xmlElementELs : JadeXMLElement;
	xmlElements : JadeXMLElementArray;
	xmlElementEL : JadeXMLElement;
	
	theXMLStr : String;
	term : CM_Terminal;
	delOrderNum : String;
	ti : CM_TrackedItem;
	placeOfReturnStr : String;
	fileTs : TimeStamp;
	voyage : CM_Voyage;
	
	operStopTI : CM_EDIOperatorStopTI;

begin

	create xmlDoc transient;			
	
	message := _ediFile.getRawDataString();
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	theXMLStr := message.extractXML();
	if theXMLStr = null then	//05 Apr 2017	NDL	TFS 3971 - The raw message didn't have an XML header record on it.
		theXMLStr := message;
	endif;
	
	if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		if xmlDoc.rootElement.tagName = self.TagEIDO then
			rootElement := xmlDoc.rootElement;
		else
			rootElement := xmlDoc.rootElement.getElementByTagName(self.TagEIDO);
		endif;
		
		if rootElement &lt;&gt; null then
		
			xmlElementMH := rootElement.getElementByTagName(self.TagEIDOHeader);
			
			if xmlElementMH = null then
				self.addErrorMessTagSetMissing( self.TagEIDO, self.TagEIDOHeader, _ediFile );
				return;
			endif;
			
			term := _ediFile.ediData.ediConfig.myTerminal;
			
			if not self.processMessageHeader( xmlElementMH, _ediFile, term, delOrderNum, fileTs, voyage ) then
				return;
			endif;
			
			xmlElementELs := rootElement.getElementByTagName(self.TagEIDOLines);
			
			if xmlElementELs = null then
				self.addErrorMessTagSetMissing( self.TagEIDO, self.TagEIDOLines, _ediFile );
				return;
			endif;
			
			
			
			create xmlElements transient;
			xmlElementELs.getAllElementsByTagName(self.TagEIDOLine, xmlElements);
			
			foreach xmlElementEL in xmlElements do
			
				if not self.processEIDOLine( xmlElementEL, _ediFile, ti, voyage, placeOfReturnStr ) then
					continue;
				endif;
				
				create operStopTI;
				operStopTI.setMyEDIData( _ediFile.ediData );
				operStopTI.setMyEDIFile( _ediFile );
				operStopTI.setId(ti.id);
				operStopTI.setCargoType(ti.cargoType);
				operStopTI.setVoyageCode( ti.voyageCode );
				operStopTI.vesselName := ti.vesselName;
				operStopTI.setTrackedItem( ti );
				operStopTI.entryNumber := delOrderNum;
				operStopTI.setPlaceOfReturn( placeOfReturnStr );
				operStopTI.setFileDate( fileTs.Date, fileTs.Time );
				
				//EDIFileType_XMLOneStopEIDO.String,	//_responseStatus,
				
			endforeach;
			
		endif;

		
	endif;

epilog

	delete xmlDoc;
	delete xmlElements;

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessageHeader" id="11598e21-5c64-42e3-a983-73b3a27eeae2">
        <source>processMessageHeader(	_xmlElementMH : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_term : CM_Terminal;
						_delOrderNum : String output;
						_fileTs : TimeStamp output;
						_voyage : CM_Voyage output
						):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwndl1	Initial creation	TFS 2718 / 2536

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	refElement : JadeXMLElement;
	sentDate : Date;
	sentTime : Time;
	arriveElement : JadeXMLElement;
	voyageCode : String;
	lloydsNumber : String;
	vesselName : String;
	vessel : CM_Vessel;
	operator : CM_Operator;
	xlVoyageCode : String;
	foundMatch : Boolean;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagOneStopEventDateTime);
	if xmlSubElement = null then
		_fileTs := app.actualTimeServer;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str.length = 14 then
			sentDate.setDate( str[7:2].Integer, str[5:2].Integer, str[1:4].Integer);
			sentTime.setTime( str[9:2].Integer, str[11:2].Integer, str[13:2].Integer, 0);
			_fileTs.setDate(sentDate);
			_fileTs.setTime(sentTime);
		endif;
	endif;

	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagMessageName);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks.toUpper;
		if str &lt;&gt; "DELIVERY ORDER" then
			return false;
		endif;
	endif;
	
	refElement := null;
	refElement := _xmlElementMH.getElementByTagName(self.TagReferences);
	if refElement = null then
		self.addErrorMessTagSetMissing( self.TagEIDOHeader, self.TagReferences, _ediFile );
	else
		xmlSubElement := null;
		xmlSubElement := refElement.getElementByTagName(self.TagDeliveryorder);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( self.TagReferences, self.TagDeliveryorder, _ediFile );
		else
			_delOrderNum := xmlSubElement.textData.trimBlanks;
		endif;
	endif;
	
	arriveElement := null;
	arriveElement := _xmlElementMH.getElementByTagName(self.TagArrivalCarrier);
	if arriveElement = null then
		self.addErrorMessTagSetMissing( self.TagEIDOLine, self.TagArrivalCarrier, _ediFile );
		
	else
		//13 Mar 2017	NDL	TFS 3710
		xmlSubElement := null;
		xmlSubElement := arriveElement.getElementByTagName(self.TagLloydsNumber);
		if xmlSubElement &lt;&gt; null then
			lloydsNumber := xmlSubElement.textData.trimBlanks;
			//20 Mar 2017	NDL	TFS 3710 - get the vessel operator for potential transalation
			if lloydsNumber &lt;&gt; null then
				vessel := app.myRoot.allVesselsByLloydsNumber.getAtKey( lloydsNumber );
				if vessel &lt;&gt; null then
					operator := vessel.myOperator;
				endif;
			endif;
		endif;
		
		xmlSubElement := null;
		xmlSubElement := arriveElement.getElementByTagName(self.TagVoyageNumber);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( self.TagArrivalCarrier, self.TagVoyageNumber, _ediFile );
		else
			voyageCode := xmlSubElement.textData.trimBlanks;
			if voyageCode = null then
				self.addErrorMessEmptyTag( self.TagArrivalCarrier, self.TagVoyageNumber, _ediFile );
				return false;
			endif;
			_voyage := _term.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
			if _voyage &lt;&gt; null and _voyage.code &lt;&gt; voyageCode then
				_voyage := null;
			endif;
			if _voyage = null and operator &lt;&gt; null then	//20 Mar 2017	NDL	TFS 3710 - Try and find transalated voyage code.
				xlVoyageCode := operator.getXlationSystemCode_Voyage(voyageCode, null, lloydsNumber, null, foundMatch);
				_voyage := _term.allVoyagesByCode.getAtKeyGeq(xlVoyageCode, null);
				if _voyage &lt;&gt; null and _voyage.code &lt;&gt; xlVoyageCode then
					_voyage := null;
				endif;
			endif;
			if _voyage = null then
				self.addErrorMessNoMatchingObj( "Voyage", self.TagArrivalCarrier, self.TagVoyageNumber, voyageCode, _ediFile );
				return false;
			endif;	
		endif;
		
	endif;
	

	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementMH" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_delOrderNum" type="String" usage="output"/>
        <Parameter name="_fileTs" type="TimeStamp" usage="output"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
