    <JadeMethod name="addSeperatorAt" id="f47bcf57-0fb0-458c-b94b-cb9237a1be68">
        <updating/>
        <source>addSeperatorAt(_idx, _alignment : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     Returns an idx which can be used to refer to reference the seperator if required
// ---------------------------------------------------------------------------
vars
	seperatorIdx	: Integer;
	theSeperator	: CMUI_ToolbarSeperator;
	pic				: Binary;
	
begin

	seperatorIdx := self.getNextControlIndex();
	
	if self.form &lt;&gt; null and self.form.isKindOf(CM_BaseForm) then
		pic := self.form.CM_BaseForm.picSeperatorBase.picture;
	endif;

	theSeperator := self.myMasterToolbarSeperator.loadControl(seperatorIdx).CMUI_ToolbarSeperator;
	theSeperator.init(pic, self.showCaptions);

	self.addToolbarControlAt(theSeperator, _idx, _alignment);

	return seperatorIdx;
	
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_alignment" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControlAt" id="d27686f9-7d5d-49b4-9112-184ee590a61f">
        <updating/>
        <source>addToolbarControlAt(_control : CMUI_ToolbarControl input; _idx, _alignment : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	controlArray		: CMUI_ToolbarControlArray;
	existingControl		: CMUI_ToolbarControl;
	newIdx,
	tmpOffset,
	numControls,
	i					: Integer;

begin

	if _alignment = Control_Alignment_Left then
		newIdx := _idx;
		controlArray := self.allLeftControls;
	else
		controlArray := self.allRightControls;
	endif;

	if self.isPositionsCalculated then
		if _idx &gt; 0 and _idx &lt;= controlArray.size then
			existingControl := controlArray[_idx];
		else
			existingControl := controlArray.last;
		endif;
		
		if existingControl = null then
			tmpOffset := 0;
		else
			tmpOffset := existingControl.left.Integer;
		endif;
	endif;
	
	if _idx = 0 then
		controlArray.add(_control);
		newIdx := controlArray.size;
	else
		controlArray.insert(_idx, _control);
		newIdx := _idx;
	endif;
	
	if self.isPositionsCalculated then
		tmpOffset := _control.positionSelf(self.showCaptions, tmpOffset);
		numControls := controlArray.size;
		if newIdx &lt; numControls then
			// will need to position all other controls
			foreach i in newIdx + 1 to numControls do
				tmpOffset := controlArray[i].positionSelf(self.showCaptions, tmpOffset);
			endforeach;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMUI_ToolbarControl" usage="input"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_alignment" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="6ab59466-bdca-4b51-a7e2-4848d8adeea4">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	control		: CMUI_ToolbarControl;
	rightOffset,
	rightMargin,
	leftOffset	: Real;

begin
	if (not self.isPositionsCalculated) then
		return;
	endif;
	
	self.allMoreToShowControls.clear;

	rightOffset := self.positionRightControls();
	if self.priorityRight then
		rightMargin := rightOffset;
	else
		rightMargin := self.clientWidth;
	endif;
	leftOffset	:= self.positionLeftControls(rightMargin);

	if (not self.priorityRight) and
	   leftOffset &gt; rightOffset then
		// need to knobble some right controls
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="createMasterButton" id="8d0fef7f-5608-46f5-bb00-421f3f39f7b3">
        <updating/>
        <source>createMasterButton() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	toolbarButton			: CMUI_ToolbarButton;
begin
	create toolbarButton transient;
	self.myMasterToolbarButton := toolbarButton;
	
	toolbarButton.visible := false;

	toolbarButton.parent := self;
	self.form.addControl(toolbarButton);
	
end;</source>
