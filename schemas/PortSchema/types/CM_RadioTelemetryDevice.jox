    <JadeMethod name="canDoIScaleWeighting" id="3d49925c-cd0c-4003-90ef-a7a6d89f3c42">
        <source>canDoIScaleWeighting() : Boolean ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2016	cnwrh7	Initial creation

*/

vars

begin
	
	if self.useLocalTCPConnection = false then
		return false;
	endif;
	
	if self.myTCPConnectionDetails  = null then
		return false;
	endif;
	
	if self.myTCPConnectionDetails.tcpDeviceType &lt;&gt; TCPDeviceType_iScale then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoLoadriteWeighing" id="ed73fb7d-6e88-40fe-90a1-8dfda8eb4bab">
        <source>canDoLoadriteWeighing() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation
22 /08/2016 		cnwrh7	TFS	2501

*/

vars

begin
	
	if self.useSerialConnection = false then	//+2207 
		return false;
	endif;
	
	if self.myWinCESerialDetails = null then
		return false;
	endif;
	
	if self.myWinCESerialDetails.serialDeviceType &lt;&gt; DeviceType_LoadRite then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
