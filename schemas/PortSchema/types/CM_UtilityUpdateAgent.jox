    <JadeMethod name="utlUpdateSourceLocationFSC" id="10291b9a-783f-4209-b358-b8019a961cc7">
        <source>utlUpdateSourceLocationFSC(_realSource: CM_SourceLocation; _passport: CM_Passport);
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	CCMS JML 1105, PAR 21535. Need to apply FSC vlaue for all children.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realSourceChild			: CM_Code;
	valueFSC				: Boolean;
	
begin

	self.initialiseActivity();
	
	valueFSC := _realSource.isFSC;

	foreach realSourceChild in _realSource.allSubLocations do

		if _passport.hasErrors() then
			return;
		endif;

		if realSourceChild.CM_SourceSubLocation.isFSC = valueFSC then	// value is the same - no need to change
			continue;
		endif;

		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realSourceChild, true);
		endif;
		
		if _passport.noErrors then
			realSourceChild.CM_SourceSubLocation.setIsFSC(valueFSC);
		endif;
	
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realSourceChild, false);
		endif;
	
		if _passport.noErrors then
			self.utlUpdateSourceSubLocationFSC(realSourceChild.CM_SourceSubLocation, _passport);
		endif;
	
	endforeach;

end;</source>
        <Parameter name="_realSource" type="CM_SourceLocation"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSourceSubLocation" id="3832d13b-fa08-4986-be56-12d793939098">
