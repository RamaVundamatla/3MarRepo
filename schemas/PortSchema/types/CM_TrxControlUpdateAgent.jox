    <JadeMethod name="trxUpdateStopStartJobActivty" id="7449db78-ba9d-42b0-ac40-927662306f06">
        <updating/>
        <source>trxUpdateStopStartJobActivty(_job : CM_Job;_start, _stop : TimeStamp; _ti : CM_TrackedItem; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
/*
Purpose - 	
Who - NAVAB1
Date - 21MAR2024
ADO -  CR 62696 TASK 62945 
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
18 Oct 2024	navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander
*/

vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTIDictDeferUpdate 		  := true;										//14.10.2024 navhl20 #12389
	_passport.useTITransactionDeferUpdate := true;										//14.10.2024 navhl20 #12389
	_passport.useWOTransactionDeferUpdate := true;										//21.10.2024 navnk30 JIRA #19927

	beginTransaction;

	app.myUtilityUA.utlUpdateStopStartJobActivty(_job, _start, _stop, _ti, _passport);	//08.10.2024 navhl20 #12389
	
	if _passport.noErrors then															//14.10.2024 navhl20 #12389
		_passport.doDeferredUpdates();	
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_stop" type="TimeStamp"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
