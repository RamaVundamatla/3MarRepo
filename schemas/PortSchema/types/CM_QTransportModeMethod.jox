    <JadeMethod name="setComboValues" id="89c8b69e-23c2-424e-8a6f-2decdf01225c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars

begin
	_combo.clear();
	
	_combo.addItem(app.transModeToString(TI_TRANSMODE_SHIP));
	_combo.addItem(app.transModeToString(TI_TRANSMODE_ROAD));
	_combo.addItem(app.transModeToString(TI_TRANSMODE_RAIL));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.transModeToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.transModeToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ebd7e414-ec21-442a-9eaa-ae8a7db8dcf6">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_TRANSMODE_SHIP);
	intArray.add(TI_TRANSMODE_ROAD);
	intArray.add(TI_TRANSMODE_RAIL);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_TRANSMODE_Constant);	

epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="01d176ad-6142-439e-ab04-53fc94f936ad">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="f4d61d20-f736-4e35-af90-b95f9623459e">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars
	receiptTransportMode : Integer;
	
begin

	if _value.String.isInteger then
		return _value;
	endif;
	
	receiptTransportMode := app.transportModeStringToENum(_value.String);
	
	if receiptTransportMode = null and _value &lt;&gt; null then
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return receiptTransportMode;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
