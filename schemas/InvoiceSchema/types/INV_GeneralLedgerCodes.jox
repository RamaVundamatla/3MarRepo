    <JadeMethod name="setupForm" id="e891894a-e665-46de-b543-b7d3387d6a96">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doCmbBankBuild();

	inheritMethod();

	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	beginClassNotification(CM_GLCode, false, Object_Create_Event, Response_Continuous, 0); 

//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " GL Codes";
	self.setCaption("GL Codes " &amp; self.myCurrentBank.code);
	self.frmTableFilter.setCallbackMethod(INV_GeneralLedgerCodes::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
end;</source>
