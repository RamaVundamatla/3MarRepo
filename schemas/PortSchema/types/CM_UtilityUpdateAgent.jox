    <JadeMethod name="utlUpdateProformaCriteria" id="e7985d7a-71b7-422a-8591-d69d80dd7e6a">
        <source>utlUpdateProformaCriteria(_pxyProformaCriteria: CM_ProformaTransactionCriteria; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	realProformaCriteria : CM_ProformaTransactionCriteria;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	_pxyProformaCriteria.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyProformaCriteria.pxyGetRealObjectAndEdition(realProformaCriteria, expectedEdition);
	
	if realProformaCriteria = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ProformaTransactionCriteria.name, null, null);
		return;
	endif;

	app.myValUA.valProformaCriteria(realProformaCriteria, _pxyProformaCriteria);
	
