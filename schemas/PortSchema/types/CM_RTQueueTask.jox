    <JadeMethod name="setProxyAllocMachine" id="b1545bbc-7632-44e1-ad16-18dffa37536b">
        <updating/>
        <source>setProxyAllocMachine(pMachine : CM_Machine; pQueue : CM_RTQueueEntry; pSource, pTarget : CM_LocationsController; lTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.intendedMachine := pMachine;
	self.myEntry := pQueue;
	//self.sourceLocation := pSource;
	self.setSourceLocation(pSource); //cnwrd1 par 24169 3.6.2010
	self.targetLocation := pTarget;
	self.ti := lTI;
	
end;</source>
        <Parameter name="pMachine" type="CM_Machine"/>
        <Parameter name="pQueue" type="CM_RTQueueEntry"/>
        <Parameter name="pSource" type="CM_LocationsController"/>
        <Parameter name="pTarget" type="CM_LocationsController"/>
        <Parameter name="lTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setSourceLocation" id="2dc06ebe-5da3-412c-b16c-d2ed6e4ae52f">
        <updating/>
        <source>setSourceLocation(_sourceLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwer1	Initial creation

*/

vars
	aTA : CM_TerminalArea;
	aGC : CM_GridController;
	aGO : CM_GridObject;
	firstLC : CM_LocationsController;
	entry : CM_RTQueueEntry;
begin	

	
		
	if _sourceLocation &lt;&gt; null then
		self.setMySourceTerminalArea( _sourceLocation.getMyTerminalArea() ); //cnwrd1 par 24169
			
		//cnwrd1 par 28628 4.11.11	
		aTA := _sourceLocation.myTerminalArea;
		
		if aTA &lt;&gt; null and aTA.isGridArea then
			if _sourceLocation.isKindOf(CM_GridController) then		
			
				firstLC := aTA.allLocationsControllers.first; //this is oddly the last??
				
				if _sourceLocation &lt;&gt; firstLC then // if we were meant to have a grid object it will be the (correct)first one
					aGC := _sourceLocation.CM_GridController;
					if aTA.CM_GridArea.areLocationIdsColThenRow then
						aGO := aGC.myGridColumn;
					else
						aGO := aGC.myGridRow;
					endif;
				endif;
			endif;
			
			//set this for our inverse from the area/gridobj
			self.setMyGridObject(aGO);
			
		endif;
	endif;
	
	if self.sourceLocation &lt;&gt; _sourceLocation then
		self.sourceLocation:=_sourceLocation;
	endif;
epilog

end;</source>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="bd94d503-e47c-43b2-9493-8d2dd6cfbb8c">
        <updating/>
        <source>setStatus(_newStatus : Integer) updating;
//Update the status on this task entry.
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	newStatus : Integer;
	task	:	CM_RTQueueTask;
	makeSystemHeld : Boolean;
	reason : String;
begin
	newStatus := _newStatus;	//21 Apr 2015	NDL	Par 36014
	
	if newStatus &lt; TASK_UNACTIONED and newStatus &gt; TASK_ALLOCATED  then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_ESTATUS, null, null);
		return;
	endif;
	
	//21 Apr 2105	NDL	Par 36014
	if newStatus = TASK_UNACTIONED then
		if status = TASK_USER_HELD then
			makeSystemHeld := self.requiresSystemHold(false, null, reason);
			if not makeSystemHeld then
				if self.myEntry &lt;&gt; null then
					if self.myEntry.myQueue &lt;&gt; null then
						if self.myEntry.myQueue.status = QSTATUS_HELD then
							status := TASK_UNACTIONED;	//its a fiddle to handlle resuming queues when previously manually held
							makeSystemHeld:= true;
						endif;
					endif;
				endif;
			endif;
		endif;
		if makeSystemHeld then
			newStatus := TASK_SYS_HELD;
		endif;
	endif;
	
	//-------------
	//If nothing to do, quit now.
	//-------------
	if self.status = newStatus then
		return;
	endif;
	exclusiveLock(self);
	exclusiveLock(self.myEntry);
	/*
	-----------
	Check status change is valid
	Progression is 
	unactioned to..
	offered to.. 
	accepted (or back to unactioned) to..
	working to..
	complete.
	In addition, the status can change to error as needed.
	-----------
	*/
	
	if newStatus = TASK_UNACTIONED then
		self.setStatusUnactioned();
		//------------------
		//Set all others unactioned
		//------------------
		foreach task in self.relatedTasks do
			if task &lt;&gt; self then
				//epr CCMS 1391 13/8/13 problem is with overstow related tasks that are complete we just want to reject the current move and leave the complete tasks
				if task.status = TASK_COMPLETE then
					continue;
				endif;
				
				//epr par 31716 10/6/13 multi leg director task can assign second leg to a machine when unassigning ignore the completed director task
				if task.taskType = TASK_DIRECTOR  then
					continue;
				endif;
				exclusiveLock(task);
				task.setStatusUnactioned();
			endif;
		endforeach;

	elseif newStatus = TASK_OFFERED then
		self.setStatusOffered();
 	elseif newStatus = TASK_ACCEPTED then
 		self.setStatusAccepted();
 	elseif newStatus = TASK_WORKING then
 		self.setStatusWorking();
 	elseif newStatus = TASK_COMPLETE then
 		self.setStatusComplete();
 	elseif newStatus = TASK_ERROR then
 		self.setStatusError();
 	elseif newStatus = TASK_USER_HELD then
 		self.setStatusUserHeld();
 	elseif newStatus = TASK_MACH_OFFLINE then
		self.setStatusMachineOffline();
	elseif newStatus = TASK_PENDING then
 	 	self.setStatusPending();
	elseif newStatus = TASK_SYS_HELD then
 		self.setStatusSystemHeld();
 	elseif newStatus = TASK_ALLOCATED then
 		self.setStatusAllocated();
	endif;

	//--------------
	//Let our Entry know we've been updated
	//--------------
	self.myEntry.updateStatus(self.status);

	if self.ti &lt;&gt; null then
		self.updateObjectEdition (self.ti);	// par 30292
	endif;

epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatusAccepted" id="29a58b67-e89b-4a9f-af05-7459f30ee62a">
        <updating/>
        <source>setStatusAccepted() updating;
/*
Checks this status can be accepted.
We can do this from : 
Offered
The task must be a pickup type.
In addition, at this point we set all other tasks to "pending"

01/11/2010	cnwcs5	par 23714/ccms 1132 - record accepts in machine history
01/09/2011	cnwdap1	PAR #28047 CCMS POL 2095 Interchange areas should not generate swap jobs
*/
vars
	aTask			: CM_RTQueueTask;
	needSwap		: Boolean;
	tmpLC			: CM_LocationsController;	
	moveController	: CMIF_MoveController;
	trackedItem		: CM_TrackedItem;
	targetId		: String;					// 01/11/0201 cnwcs5 par 23714/ccms 1132
begin
	if (status &lt;&gt; TASK_OFFERED and 
		status &lt;&gt; TASK_SYS_HELD and
		status &lt;&gt; TASK_ALLOCATED  and 
		status &lt;&gt; TASK_PENDING ) or 
		(taskType &lt;&gt; TASK_PICKUP and taskType &lt;&gt; TASK_DIRECTOR and taskType &lt;&gt; TASK_MOVE and taskType &lt;&gt; TASK_BREAKBULK) then
		//We are not happy!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_ACCEPTED), null, null);
		return;
	endif;
	if machine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_NO_MACHINE, null, null);
		return;
	endif;
	self.status := TASK_ACCEPTED;
	// -----------------------
	// save target for when we create history
	// -----------------------
	targetId	:= self.targetLocationId;	// 01/11/2010 cnwcs5 par 23714/ccms 1132
	
	if taskType = TASK_DIRECTOR then

		//Director tasks are special. They basically tell machine to goto a locn, and enquire on
		//TI's. When one is found, the director task is nuked, and replaced with move types.
		//--------------------
		//If this is a self replicating job, then replicate as required at this point. DQ 29/8/2002
		//--------------------
		self.myEntry.replicate();
		machine.addAcceptMoveHistory (self, targetId);
		return;	
	endif;
	//if self.targetLocation &lt;&gt; null and targetLocation.getParent.isKindOf(CM_TerminalArea) then																// PAR #28047
	if self.targetLocation &lt;&gt; null and targetLocation.getParent.isKindOf(CM_TerminalArea) and not targetLocation.getParent.isKindOf(CM_InterchangeArea) then	// PAR #28047
		//if app.getMyTerminal().isAutoPlanGenerateSwapJob then   //SFW1030 04/08/2008
		if self.getMyTerminal().isAutoPlanGenerateSwapJob then		// change to get proper terminal
			needSwap := (machine.canMachineAccessTAObj(targetLocation.getParent.CM_TerminalArea, true)  = false);
		endif;
	else
		//to ship..
		needSwap := false;
	endif;
	//---------------
	//Set all related tasks to "Pending"
	//---------------

	foreach aTask in relatedTasks do
		if aTask &lt;&gt; self then
			exclusiveLock(aTask);
			if aTask.status &lt;&gt; TASK_COMPLETE then
				aTask.setStatusPending();
			endif;
		endif;
	endforeach;
	//--------------
	//Now also need to over-ride the source/Target locations for these tasks
	//as we now have a machine (with a machineController). The move is TO the machine,
	//the set-down is FROM the machine.
	//This means that the pickup will be from source to machine
	//the setdown will be from machine to target
	//--------------
	//We are pickup task, so update target to the Machine's locations Controller

	if taskType &lt;&gt; TASK_MOVE and not self.isPlanOnPickupNoTarget then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		self.setTargetLocation(machine.myMachineController);
		if self.targetLocation = null then
			app.raiseCMException1(ERR_NO_OBJECT, "Machine does not have machine controller", null, null);
		endif;
		//------------
		//Grab the setDown task
		//------------
		aTask := self.myEntry.getTaskOfType(TASK_SETDOWN, null);
		if aTask = null then  
			//hmmm, no set-down task!
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_SETDOWN_DESC, queueId, null, null);
			return;
		endif;
		//-------------
		//SetDown's source is the machine machine...
		//-------------
		aTask.setSourceLocation( machine.myMachineController);
		// -----------------------
		// update target for when we create history with target for setdown
		// -----------------------
		targetId	:= aTask.targetLocationId;	// 01/11/2010 cnwcs5 par 23714/ccms 1132
	endif;

	//-------------
	//If this requires a swapStack set down, then the setdown target is set
	//to the original target's swapStack object.
	//-------------
	if needSwap then
		tmpLC := aTask.targetLocation.getSwapStackLC;
		if tmpLC = null then
			//hmmm, no swapStack!
			app.raiseCMException1(ERR_NO_OBJECT, "No Swap Stack for target ", null, null);
			return;
		endif;
		//----------------
		//Store off the target's location pre-swap
		//----------------
		aTask.targetLocationPreSwap := aTask.targetLocation;
		//--------------
		//Set target to the SwapStack's LC.
		//--------------
		
		trackedItem := self.ti;
		create moveController transient;
		moveController.setMoveMode(QUEUE_MODE);
		moveController.isRadioTelemetryMove := true;
		moveController.setMyTrackedItem(trackedItem);
		moveController.setMyToPrimaryLocation(tmpLC);
		moveController.updatePassportAndUser(app.myPassport);
		// Do some funky validation.
		app.myValUA.valRTTaskTarget(moveController, tmpLC);
		if app.myPassport.hasErrors() then
			return;
		endif;
		self.changeTargetLocation(moveController,true);
		aTask.setTargetLocation(tmpLC);
	endif;
	// 01/11/2010 cnwcs5 par 23714/ccms 1132 - start
	machine.addAcceptMoveHistory (self, targetId);	
	// 01/11/2010 cnwcs5 par 23714/ccms 1132 - end
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusAllocated" id="85ca7da0-5f02-48a1-b61a-76f96d4fe0ae">
        <updating/>
        <source>setStatusAllocated() updating;
//Sets the current status of the task to allocated ie, has been assigned to this machine
//by CONTROL, who are saying, "this is you next job buddy"
//The task must be in an unactioned state 1st.
begin
	//if (status &lt;&gt; TASK_UNACTIONED and status &lt;&gt; TASK_SYSTEM_HELD) then
//	if (status &lt;&gt; TASK_UNACTIONED and status &lt;&gt; TASK_SYSTEM_HELD and self.status &lt;&gt; TASK_USER_HELD ) then	// 07 Mar 2011	NDL	Par 27156	/ CCMS 2030
	if (status &lt;&gt; TASK_UNACTIONED and self.status &lt;&gt; TASK_USER_HELD ) then	//22 Apr 2015	NDL	Par 36014
		//We are not happy!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_ALLOCATED), null, null);
		return;
	endif;
	if intendedMachine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_NO_MACHINE, null, null);
		return;
	endif;
	status := TASK_ALLOCATED;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusComplete" id="0821cfdb-2ad9-41cb-9726-32d93801225c">
        <updating/>
        <source>setStatusComplete() updating;
/*
Checks this status can be completed.
We can do this from : 
Working or accepted (if an accepted pickup task)
*/
vars
	shipLC				: CM_LocationsController;
	alert 				: CM_SystemAlert;
	primLocn,
	plannedLocn			: CM_LocationsController;
	futureMove			: CM_FutureMove;
	futureMoveQueued	: CM_FutureMoveQueued;
	term				: CM_Terminal;
	queueEntry			: CM_RTQueueEntry;
	raiseNonPlannedError: Boolean;
	voyageJob 			: CM_VoyageJob;
begin

	if self.taskType = TASK_DIRECTOR and self.ti = null and self.tiId &lt;&gt; null and self.status = TASK_UNACTIONED then 
		if self.myEntry.myWorkListEntry.myTrackedItem = null and 
		   self.myEntry.myWorkListEntry.queue = self.queue then
			create alert;
			alert.details := self.tiId &amp; ": Director task set to Complete from Unactioned, but no tracked Item is associated";
			alert.addLogEntry(self.tiId &amp; " No tracked Item is associated so task has been set to complete and the job has been dis associated from queue entry");
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
			alert.setLinkedTo(self.myEntry);
		endif;
	endif;
	
	
	if ti &lt;&gt; null then
		sharedLock(ti);
		primLocn := ti.getPrimaryLocation(REAL_MODE);
		if primLocn.isKindOf(CM_SlotController) 
			or primLocn.isKindOf(CM_ShipBlockController)
			or primLocn.isKindOf(CM_VoyageController) then
			shipLC := primLocn;
		endif;
		
		//cnwrd1 par 26507 multimachine director moves to ship planning done elsewhere 2.12.2010

		if (self.taskType = TASK_SETDOWN or self.taskType = TASK_MOVE  )
		 and self.myEntry.myWorkListEntry.isBulkRelease 
		 and self.myEntry.getNextRelatedEntry() = null   //epr par 35702 CCMS 2457 17/2/15
		 and ( self.queue.isCraneQueue or self.queue.isWorkPointQueue) then //cnwrd1 ccms 1310 par 30807
		 //cnwrd1 ermoved for par 30222 30/8/2012
			self.myEntry.myWorkListEntry.completeBulkRelease(ti);
			
		endif;
		
		if 	primLocn.isKindOf(CM_SlotController)  and 
			self.targetLocation &lt;&gt; null and
			self.targetLocation.isVoyageController and
			self.myEntry.myWorkListEntry.job.isAllowOutOfOrderLoading then //cnwrd1 par 30626 ccms 2209 23.10.12
			//need to possibly replan the box here.
			
			self.myEntry.myWorkListEntry.completeOutOfOrderLoad(ti);
		endif;

		//PAR 3415 AJA 23/3/00: If we are loading to ship, we must have a planned location on the ship
		if self.myEntry.allBreakBulkMoves.isEmpty and self.myEntry.myBreakBulkMaster = null and //epr par 35702 CCMS 2457 17/2/15
			not self.myEntry.myJob.isKindOf(CM_VoyageROROJob) // PAR 23189
				
		and not self.myEntry.myJob.isNotNotifiedJob	//12 Sep 2011	NDL	Par 28173
		and self.myEntry.myJob.isKindOf(CM_VoyageJob) and self.myEntry.myJob.CM_VoyageJob.isDischarge = false
			and self.isOverstowTask = false and 
			// PAR 23819 (not primLocn.isKindOf(CM_SlotController)) and 
			shipLC = null and // PAR 23819 
			not self.myEntry.myJob.hasBulkReleaseItem then
			
			voyageJob:=self.myEntry.myJob.CM_VoyageJob;
  			/* Manual completions from Q window	result in box being moved on pickup task, so it's 
  			already on the ship when the setdown is completed. Also, overstowing items must not 
  			get caught up in this check. AJA 26/4/00) */
  			plannedLocn := ti.getPrimaryLocation(PLANNING_MODE);
			//epr par #28529 27/10/11 - when setting to complete the planned move may of already been deleted so check the queue locn
			if plannedLocn = null then
				plannedLocn:=ti.getPrimaryLocation(QUEUE_MODE);
			endif;
			//epr CCMS 1033 23/8/11 if voyage deck job must be planned to voyage controller
			if plannedLocn = null then
				raiseNonPlannedError:=true;
			else
				if voyageJob.isKindOf(CM_VoyageHoldJob) then	//16 Feb 2018	NDL	TFS 37115
					raiseNonPlannedError:=not plannedLocn.isKindOf(CM_VoyageController);
				elseif voyageJob.isKindOf(CM_VoyageDeckJob) then
					raiseNonPlannedError:=not plannedLocn.isKindOf(CM_VoyageController);
				else
					raiseNonPlannedError:=not plannedLocn.isKindOf(CM_SlotController);
				endif;
				
				//epr par 36986 16/11/15
				if raiseNonPlannedError and self.isVoyageLoadToCTA() then
					raiseNonPlannedError:=false;
				endif;
			endif;
			
			if raiseNonPlannedError = true and self.myEntry.myJob.isAllowOutOfOrderLoading then
				raiseNonPlannedError := false;
			endif;
			
			
			if raiseNonPlannedError then //cnwrd1 1303 15.11.12
		  		/* Must abort the whole thing: if we complete then we leave the TI in the crane lane, 
 		 		the wle &amp; the job will be complete but we will not have loaded the TI ! */
		  		self.myEntry.setEntryStatus(QSTATUS_HELD);
				app.setContinueCMExceptions(false);
				app.raiseCMException(VB_NOT_PLANNED, null, null);
				return;
			endif;
		endif;
	endif;
	//-----------------
	//Null out the intended machine reference as well (belts and braces)(even if is null)
	//-----------------
	self.intendedMachine := null;

	status := TASK_COMPLETE;
	self.setMachine(null);  
	if self.isOverstowTask and self.taskType = TASK_SETDOWN then
		if ti &lt;&gt; null then				
			term := self.queue.getMyTerminal();
			if term &lt;&gt; null then
				foreach futureMove in ti.allQueuedFutureMoves discreteLock do
					futureMoveQueued := futureMove.CM_FutureMoveQueued;
					if futureMoveQueued.myTrackedItem = ti then
						//cnwrd1 par 28725 25.11.11
						// we want to look at out Ti here and check if any future move RT entries are held
						// and if they are held because we were part of an overstow move
						// if so we will unhold them					
						foreach queueEntry in futureMoveQueued.allRTQueueEntries discreteLock do							
							//want to check we are held &amp; look at the alerts here make sure we have one generated by the auto helf due to overstow move.
							if queueEntry.hasHeldTasks and queueEntry.isHeldFromOverstowMove then
								queueEntry.restoreTaskStatuses();
							endif;
							
							queueEntry.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
						endforeach;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusDirectorUndo" id="9f27fbc7-885f-4005-848b-53de1269cca4">
        <updating/>
        <source>setStatusDirectorUndo( _status : Integer)updating;

/*

Purpose:	To turn a current queued direcor task with an asigned TI (therefore we are complete and there is/was a pickup/setdown + QFM) back to a straight director.

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2011	cnwrd1	Initial creation

*/

vars
	theMachine : CM_Machine;
begin
	if status = TASK_UNACTIONED then
		return;
	endif;
	

	/*if not (status = TASK_COMPLETE and self.taskType = TASK_DIRECTOR ) then 
		return;	
	endif;*/
	
	
	status := _status;
	
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatusError" id="2f41a9ff-3b77-4c01-9f38-14ffd4c6d3fe">
        <updating/>
        <source>setStatusError() updating;
/*
Checks this status can be accepted.
We can do this from : 
 ** Anywhere! **
*/
vars
	alert: CM_SystemAlert;
	task: CM_RTQueueTask;
begin
	if self.status = TASK_ERROR then
		return; 	//Already in error, quit here.
	endif;
	//Raise a System Alert Error! Something is WRONG!!!
	//Create a System Alert
	create alert;
	alert.details := app.getErrorString2(ALERT_TASK_ERROR, queueId &amp; " from Machine " &amp; machineId.trimRight, getStatusStr(self.status));
	alert.setSeverity(SEVERE_WARNING);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
	//-----------
	//Store off the current Task status for restore later
	//-----------
	if status &lt;&gt; TASK_SYS_HELD and status &lt;&gt; TASK_MACH_OFFLINE then
		//But only if not's not being set from another error state!
		statusToRestoreTo := status;
	endif;
	status := TASK_ERROR;
	//------------
	//Better tell all the other tasks that they are also now in this state.
	//------------
	foreach task in self.relatedTasks do
		if task &lt;&gt; self then
			exclusiveLock(task);
			task.setStatusError(); 
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusMachineOffline" id="a6a0a6bd-9af9-4847-9c55-70c07584f76b">
        <updating/>
        <source>setStatusMachineOffline() updating;
/*
Checks this status can be accepted.
Attempts to set the status to machine offline. This means that the
machine has called us, and told us its going offline.
We can do this from : 
Offered
Accepted
Working
Error
Held (maybe not?)
*/

vars
	alert			: CM_SystemAlert;
	task	:	CM_RTQueueTask;
begin
	if status = TASK_MACH_OFFLINE then
		return;	//Nothing to do
	endif;
	if status &lt;&gt; TASK_OFFERED and 
		status &lt;&gt; TASK_ACCEPTED and
		status &lt;&gt; TASK_WORKING and
		status &lt;&gt; TASK_PENDING and
		status &lt;&gt; TASK_ERROR and
		status &lt;&gt; TASK_USER_HELD and
		status &lt;&gt; TASK_SYS_HELD	then
		//We are not happy!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_MACH_OFFLINE), null, null);
		return;
	endif;
	if machine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_NO_MACHINE, null, null);
		return;
	endif;

	create alert;
	alert.details := app.getErrorString2(ALERT_MACH_OFFLINE, queueId, machine.id);
	alert.setSeverity(SEVERE_INFO);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
	//-----------
	//Store off the current Task status for restore later
	//-----------
	if status &lt;&gt; TASK_ERROR and status &lt;&gt; TASK_SYS_HELD then
		//But only if not's not being set from another error state!
		statusToRestoreTo := status;
	endif;
	status := TASK_MACH_OFFLINE;
	//------------
	//Better tell all the other tasks that they are also now in this state.
	//------------
	foreach task in relatedTasks do
	//epr CCMS 1032 2/2/09 we know if machine is null it will cause an exception and we only usually work one task at a time
		if task &lt;&gt; self and task.machine &lt;&gt; null then 
			exclusiveLock(task);
			task.setStatusMachineOffline(); 
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusOffered" id="587fbd14-0e42-471a-85e7-0a9edb438062">
        <updating/>
        <source>setStatusOffered() updating;
/*
	Checks this status can be accepted.
	We can do this from : 
	Unactioned
*/
begin
	//To get to offered, we MUST be in unactioned state AND a pickup or director task.
	if (status &lt;&gt; TASK_UNACTIONED and status &lt;&gt; TASK_SYS_HELD and status &lt;&gt; TASK_ACCEPTED ) or 
		(taskType &lt;&gt; TASK_PICKUP and taskType &lt;&gt; TASK_DIRECTOR and taskType &lt;&gt; TASK_MOVE and taskType &lt;&gt; TASK_BREAKBULK ) then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_OFFERED), null, null);
		return;
	endif;
	if machine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_NO_MACHINE, null, null);
		return;
	endif;
	status := TASK_OFFERED;
	//NOTE: All other tasks are still UNACTIONED
	//We only update other related tasks when we switch to ACCEPTED.
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusPending" id="1609ef7d-76f6-4359-ab33-1df912c8807d">
        <updating/>
        <source>setStatusPending() updating;
//Sets the current status of the task to pending (about to be worked)
//No other dependancies.
//The task must be in an unaction state 1st.
begin
	if (self.status &lt;&gt; TASK_UNACTIONED and 
		self.status &lt;&gt; TASK_SYS_HELD and
		self.status &lt;&gt; TASK_USER_HELD and	// 17 Mar 2011	NDL	Par 27156	/ CCMS 2030
		self.status &lt;&gt; TASK_PENDING) then
		//We are not happy!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_PENDING), null, null);
		return;
	endif;
/*	if machine = null then
		create exception;
		exception.resetMsgParams;
		exception.errorCode := VB_NO_MACHINE;
		raise exception;
	endif; */
	status := TASK_PENDING;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusSystemHeld" id="060b26bf-4c9e-4da1-bc92-0598b4b4c787">
        <updating/>
        <source>setStatusSystemHeld() updating;
//Discharge jobs from the ship get this set if crane has no R/T.
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------------
// 21/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 System Held is now used to differentiate a manually-held item
// 02/09/2025	jlizm1		MTN 35800 RT entries not set to system held if follow a director task
vars
	task	:	CM_RTQueueTask;
begin
	if status = TASK_SYS_HELD then
		return;
	endif;
	
	if status = TASK_COMPLETE and self.taskType = TASK_DIRECTOR then
		// ignore completed director task if it exists
		return;
	endif;
	
	if status = TASK_UNACTIONED
	or status = TASK_USER_HELD //21 Apr 2015	NDL	Par 36014
	then
		//we are happy
	else
		//We are not happy!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_SYS_HELD), null, null);
		return;
	endif;
	
	self.statusToRestoreTo := status;
	status := TASK_SYS_HELD;
	//------------
	//Better tell all the other tasks that they are also now in this state.
	//------------
	foreach task in relatedTasks do
		if task &lt;&gt; self then
			exclusiveLock(task);
			task.setStatusSystemHeld(); 
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusToRestoreTo" id="17773e05-35f1-4821-8628-dbed9a20db58">
        <updating/>
        <source>setStatusToRestoreTo(_value : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.statusToRestoreTo &lt;&gt; _value then
		self.statusToRestoreTo:=_value;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatusUnactioned" id="9a08c97e-1207-44c6-94ad-1c9be661d5a1">
        <updating/>
        <source>setStatusUnactioned() updating;
/*
Checks this status can be accepted.
We can do this from : 
Offered (means rejected)
Allocated (means control have decided to unallocate!)
*/

/*

Date		Who		Reason
20 Feb 2009	cnwkpd1	PAR #18796 - Also need completed overstow tasks like Director tasks,
					and not set them back to unactioned

*/
vars
	theMachine : CM_Machine;
begin
	if status = TASK_UNACTIONED then
		return;
	endif;
	
	//epr par 26986 16/3/2011
	if status = TASK_COMPLETE then
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_UNACTIONED), null, null);
		return;
	endif;
	
	//trying to set to unactioned while on the ti is on the machine controller
	if ti &lt;&gt; null then
		if self.machine &lt;&gt; null and self.ti.myPrimaryActualLocation = self.machine.myMachineController and  self.ti.myPrimaryActualLocation &lt;&gt; self.targetLocation then
			app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_UNACTIONED), null, null);
			return;
		endif;
	endif;
	
	theMachine:=self.machine;
	
	if status = TASK_OFFERED then
		//The machine has rejected this task, update machine with this rejection.
		if machine &lt;&gt; null then
			machine.addRejectedRTQueueTask(self);
			self.setMachine(null);
			//Null out machine reference.
		//	machine.setMachineStatus(STATUS_IDLE  , "", false);
			
		endif;
	else
		if status &lt;&gt; TASK_ALLOCATED and status &lt;&gt; TASK_PENDING then
				//-------------
				//Clear out machine, is a FORCED update
				//There are other issues here.. eg, what happens to any TI on the machine?
				//jobs etc?
				//TI should be ok, can be manually moved to wherever.
				//Jobs should be ok, as long as setcomplete works in terms of force.				
				//-------------
				self.setMachine(null);
				
				
	//		endif;
		endif;
	endif;
	
	//ccms 1099 epr 5/5/10 wasn't checking mchines current queue tasks
	if theMachine  &lt;&gt; null then
		if theMachine.allCurrentQueueTasks.size = 0 then
			theMachine.setMachineStatus(STATUS_IDLE  , "", false);
		endif;
	endif;
	
	status := TASK_UNACTIONED;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusUserHeld" id="e058254b-ccc2-48e8-bfda-daf38f80a01b">
        <updating/>
        <source>setStatusUserHeld() updating;
/*
Checks this status can be accepted.
We can do this from : 
 ** Anywhere!, ** (including error!)
*/
vars
	alert: CM_SystemAlert;
	task: CM_RTQueueTask;
begin

	if status = TASK_USER_HELD then
		return;	//Nothing to do.
	endif;

	//-----------
	//Store off the current Task status for restore later
	//-----------
	if status &lt;&gt; TASK_ERROR and status &lt;&gt; TASK_MACH_OFFLINE then
		//But only if not's not being set from another error state!
		self.statusToRestoreTo := status;
	endif;

	status := TASK_USER_HELD;
	//------------
	//Better tell all the other tasks that they are also now in this state.
	//------------
	foreach task in relatedTasks do
		if task &lt;&gt; self then
			exclusiveLock(task);
			task.setStatusUserHeld(); 
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusWorking" id="cb9ba13c-5ea1-4b27-a1f9-8efa95489dc8">
        <updating/>
        <source>setStatusWorking() updating;
/*
Checks this status can be accepted.
We can do this from : 
Accepted or pending
*/
begin
	if status = TASK_MACH_OFFLINE then
		self.statusToRestoreTo := TASK_WORKING ;
		return;
	endif;
	
	if status &lt;&gt; TASK_ACCEPTED and status &lt;&gt; TASK_PENDING then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TASK_STATUS_CHANGE, getStatusStr(status), getStatusStr(TASK_WORKING), null, null);
		return;
	endif;
	if machine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_NO_MACHINE, null, null);
		return;
	endif;
	//-----------------
	//Null out the intended machine reference now, he's working (even if is null)
	//-----------------
	self.intendedMachine := null;

	status := TASK_WORKING;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTargetLocation" id="99e1c3de-2c40-4df3-ac34-2573bf3f8993">
        <updating/>
        <source>setTargetLocation(_targetLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.targetLocation &lt;&gt; _targetLocation then
		self.targetLocation:=_targetLocation;
		
		self.updateMachineCoverage();
	endif;
epilog

end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="1c02005c-cad2-4296-aafb-920858094493">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

// cnwdvb1 03 June 2003 

vars
	propName	: String;
	
begin
	propName := _property.name;

	if propName = 'parent'  then
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sourceIncludesTI" id="0e05f4c5-38bc-4289-a4a7-1b8dc55cb5e4">
        <source>sourceIncludesTI(_ti : CM_TrackedItem; _mode : Integer)	: Boolean;
// 23099 director task from gridded area - check whole area, otherwise the specific location
vars
	result	: Boolean;
	ta	: CM_TerminalArea;
	lc	: CM_LocationsController;
begin
	if self.sourceLocation = null then
		return false;
	endif;
	if self.taskType = TASK_DIRECTOR and
	   self.sourceLocation.isGridLocation() then
		ta:= self.sourceLocation.myTerminalArea;
		foreach lc in ta.allLocationsControllers do
			result := lc.includesTI(_ti, _mode);
			if result = true then
				break;
			endif;
		endforeach;
	else
		result := self.sourceLocation.includesTI(_ti, _mode);
	endif;

	return result;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sourceLocationId" id="a5cb3032-9c71-4594-aa92-5c147c5e172d">
        <methodInvocation>mapping</methodInvocation>
        <source>sourceLocationId(set: Boolean; value: String io) mapping;
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
//06 Mar 2025 	navma1 	MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
vars
	location,
	groundLocation		: CM_LocationsController;
	invalid 			: Boolean;
	theTI 				: CM_TrackedItem;//epr par 34257 16/6/14
	groundLocaSourceId  : String;
begin
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.status = TASK_COMPLETE then
		if self.sourceLocation &lt;&gt; null then
			value:= self.sourceLocation.getFullIdForTI(true)[1:20]; 
			return;
		endif;
	endif;
	
	value := self.getSpecialTargetDisplay(true);

	if value &lt;&gt; null then
		return;
	endif;
		
	if self.ti = null then
		location := self.sourceLocation;
		if location &lt;&gt; null then
			value := location.getFullSourceId();	// 28771 Dec 2011 restore interchange content count
		endif;
	else
		theTI := self.ti;
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		value := self.ti.getPrimaryLocationId(REAL_MODE)[1:20]; 
		
		if self.sourceLocation &lt;&gt; null and  self.sourceLocation.isKindOf(CM_TILCController)   then //source is a trailer tell them where it is jlier1 TFS 54675 9/11/22
			groundLocation := self.sourceLocation.CM_TILCController.getGroundLC(REAL_MODE);
			if groundLocation &lt;&gt; null then
				groundLocaSourceId := groundLocation.getFullSourceId();					//06.03.2025 navma1 #MTN-34179
				if  groundLocaSourceId &lt;&gt; value then
					value := (value &amp; " in " &amp; groundLocaSourceId)[1:30];
				endif;
			endif;	
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="8d87f802-eda0-4499-a295-f1c938a6fa92">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; value: String io) mapping;
vars

begin
	value := "";
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	value := getStatusStr(status);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="swapTaskOrder" id="85834954-882b-4a49-9393-1d8e5a97c37e">
        <updating/>
        <source>swapTaskOrder(_secondTask : CM_RTQueueTask input) updating;
/*

Purpose:		the order of the machines allCurrentTasks determines the order they are
				setdown for tandem lifts.
				
				In this case we need to swap unfortunately it is automatic on the machine end

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	cnwer1	Initial creation

*/

vars
	idxSelf,
	idxSecond : Integer;
	machine 	: CM_Machine;
begin
	
	if _secondTask.machine &lt;&gt; self.machine then 
		return;
	endif;
	
	machine:=self.machine;
	idxSelf:=machine.allCurrentQueueTasks.indexOf(self);
	
	idxSecond:=machine.allCurrentQueueTasks.indexOf(_secondTask);
	
	self.machine:=null;
	_secondTask.machine:=null;
	
	//if before secondTask then add second task first then self
	if idxSelf &lt; idxSecond then
		_secondTask.machine:=machine;
		self.machine:=machine;
		
	else
	
		self.machine:=machine;
		_secondTask.machine:=machine;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_secondTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="targetLocationId" id="4bbe9dab-ab52-41cd-8634-3fa88d5d14fb">
        <methodInvocation>mapping</methodInvocation>
        <source>targetLocationId(set: Boolean; value: String io) mapping;
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
//
//18 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
//20 Feb 2024 jlizm1	TFS 62467 CUX Warning when setdown to MAFI heap
//16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
vars
	tmpStr,
	aStr 				: String;
	numTI				: Integer;
	loadLaneLocation	: CM_LocationsController;
	voyageCraneQueue	: CM_VoyageCraneQueue;
	workPointQueue		: CM_VoyageWorkPointQueue;
	invalidLc 			: Boolean;
	length 				: Real;
	theTI 				: CM_TrackedItem;//epr par 34257 16/6/14
	edition 			: Integer;
	targetLc			: CM_LocationsController;
	termArea			: CM_TerminalArea;
	invalidTI			: Boolean;
	voyage				: CM_Voyage;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
 	
	targetLc := self.targetLocation;
	
	if targetLc = null then
		value := self.getSpecialTargetDisplay(false);
 		return;
 	endif;
	
	//08 Jan 2020	NDL	TFS 48204
	on Exception do app.handleDeletedObject( exception, targetLc, invalidLc );
	
	edition := targetLc.edition;
	
	if invalidLc then
		value := app.getErrorString( Invalid );
		return;
	endif;
	
	termArea :=  targetLc.myTerminalArea;										//16.10.2024 navma1 #MTN-33090
	theTI	 :=  self.ti;														//16.10.2024 navma1 #MTN-33090
	
	//epr par 34257 16/6/14 use local var for ti now self.ti was causing nested exception
	on Exception do app.handleDeletedObject(exception, theTI, invalidTI);		//16.10.2024 navma1 #MTN-33090
	
	//jlier1 TFS 54701 19/9/22
	if self.machineTypeGroup = MACHINETYPEGRP_MAFI then
		//get the terminal area id 
		if termArea &lt;&gt; null then		
			value := self.TASK_TARGET_MAFI &amp; Space &amp; termArea.id;
			return;
		elseif targetLc.isTILCController then
			loadLaneLocation := targetLc.getGroundLC(REAL_MODE);
			if loadLaneLocation &lt;&gt; null then
				value := (self.TASK_TARGET_MAFI &amp; Space &amp; loadLaneLocation.getFullIdTI(theTI))[1:30];
				return;
			endif;
		endif;		
		value := (self.TASK_TARGET_MAFI &amp; Space &amp; targetLc.getFullIdTI(theTI))[1:30];
		return;
	endif;
	
	//epr par 35029 if director task let drop into the ship target stuff before returning the target
	if theTI &lt;&gt; null and targetLc.includesTI(theTI, REAL_MODE) then 
		//----------------
		//Box is in position, display normal stuff.
		//----------------
		theTI.edition;
		if invalidTI then
			return;
		endif;
		
		value := theTI.locationId[1:30];
		return;
	endif;
	
 	if targetLc.isWagon then
		if ti = null then
			value := targetLc.getFullId()[1:30];
			return;
		endif;
 		//Attempt to get the N/C/S portion of the location
 		if ti.getPrimaryLocation(QUEUE_MODE) = targetLc then
 			if ti.getPrimaryLocation(PLANNING_MODE) = targetLc then
				if targetLc.CM_WagonController.isWellcarCont then
					value := targetLc.getFullIdTI(theTI)[1:30];
				elseif ti.plannedLocnId &lt;&gt; null then
					value := ti.plannedLocnId;
				else	//06 Aug 2019	NDL	TFS 42876	
					value := targetLc.CM_WagonController.getFullId;
				endif;
	 			return;
	 		endif;
 		endif;
 	endif;
 	
	if targetLc.isSlotController then
		//epr par 24877 6/7/10 
		voyageCraneQueue:= self.getVoyageCraneQueue;
		if voyageCraneQueue &lt;&gt; null and voyageCraneQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			loadLaneLocation := voyageCraneQueue.getFirstAvailableLoadLane();
			if loadLaneLocation &lt;&gt; null then
				value := loadLaneLocation.getFullIdForTIForMode(QUEUE_MODE)[1:30];
	 			return;
			endif;
		endif;
		
		voyage := targetLc.CM_SlotController.myVoyage;
		if  voyage &lt;&gt; null then											//16.10.2024 navma1 #MTN-33090
			tmpStr := voyage.code.trimRight;							//16.10.2024 navma1 #MTN-33090
		endif;
		value :=  tmpStr &amp; " " &amp; targetLc.getStowageId(theTI)[1:20];
		return;
	//epr CCMS 1033 30/8/2011 
	//epr TFS 8055 1/12/17
	elseif targetLc.isVoyageROROController() or targetLc.isShipBlockStack() or targetLc.isGeneralCargoController() then
		workPointQueue := self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			loadLaneLocation := workPointQueue.getFirstAvailableLoadLane();
			if loadLaneLocation &lt;&gt; null then
				value := loadLaneLocation.getFullIdForTIForMode(QUEUE_MODE)[1:30];
	 			return;
			endif;
		endif;
	// PAR 23189
		if  targetLc.isShipBlockStack()  then
			voyage := targetLc.CM_ShipBlockController.myVoyage;   //16.10.2024 navma1 #MTN-33090
			if voyage &lt;&gt; null then								  //16.10.2024 navma1 #MTN-33090
				tmpStr := voyage.code.trimRight;
			endif;
			value :=  tmpStr;
			return;
		endif;
		
	elseif theTI &lt;&gt; null and targetLc.isGridLocation() and not targetLc.isLaneController()  then           //04.07.2025 navma1 #35185
		//if it is for a grid controller and is not going to an interchange area and it is a40ft container
		
		theTI.edition;
		if invalidTI then
			return;
		endif;
		length := theTI.getLengthInUnits;
		if length = 4 then
			//---------------------
			//Try and get a 40' location to display if we are a 40'
			//---------------------
			aStr := theTI.queuedLocnId;
			if aStr &lt;&gt; null then
				if aStr.length &gt; 0 then
					value := aStr[1:30];
				endif;

				//cnwrd1 par 32214
				if termArea &lt;&gt; null and termArea.isStraddleStack then
					numTI := targetLc.numTIs + 1;
					value := value &amp; " " &amp; numTI.String;	
					value := value[1:30];
				endif;
				return;
			endif; 		
		endif;
	endif;
	
	//epr par 35029 if director task let drop into the ship target stuff before returning the target
	if theTI = null then		//AJA 22/3/00: Extra protection
 		value := targetLocation.getFullId()[1:30];
 		return;
 	endif;

	//we want to display the height for straddle stacks still cnwrd1 31239
	if termArea &lt;&gt; null and termArea.isStraddleStack then
		numTI  := targetLc.numTIs + 1;
		value  := targetLc.getFullIdTI(theTI)[1:30]; 
		value  := value &amp; " " &amp; numTI.String;
	else
		//cnwer1 par 31174  11/3/13 - height is not going to show at all for target location
		value := targetLc.getFullIdTI(theTI)[1:30]; 
	endif;
	
	
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="targetLocationId40" id="2b6dd37a-bdf9-4751-a1f2-c4f517874761">
        <methodInvocation>mapping</methodInvocation>
        <source>targetLocationId40(set: Boolean; value: String io) mapping;
//Returns the 40' target location Id (if applicable) which indicates that
//a 40' TI straddles 2 pads
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
//06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
vars
	aStr 				: String;
	numTI, 
	machineTypeGroup	: Integer;
	invalid 			: Boolean;
	theTI 				: CM_TrackedItem;	//epr par 34257 16/6/14
	termArea 			: CM_TerminalArea;
begin
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
 	
	if targetLocation = null then
		value:= self.getSpecialTargetDisplay(false);
 		return;
 	endif;

 	if self.ti = null then		//AJA 22/3/00: Extra protection
 		value := targetLocation.getFullId();
 		return;
 	endif;

	theTI:=self.ti;
	if self.targetLocation.includesTI(self.ti, REAL_MODE) then 
		//----------------
		//Box is in position, display normal stuff.
		//----------------
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		value := self.ti.locationId;
		return;
	endif;
 	if targetLocation.isKindOf(CM_WagonController) then
 		//Attempt to get the N/C/S portion of the location
 		if ti.getPrimaryLocation(QUEUE_MODE) = targetLocation then
 			if ti.getPrimaryLocation(PLANNING_MODE) = targetLocation then
	 			value := ti.plannedLocnId;
	 			return;
	 		endif;
 		endif;
 	endif;

	machineTypeGroup := self.getMachineTypeGroup();
	if self.ti.getLengthInUnits = 4 and (machineTypeGroup &lt;&gt; MACHINETYPEGRP_RTG and machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV) then
		//---------------------
		//Try and get a 40' location to display if we are a 40'
		//---------------------
		aStr := self.ti.queuedLocnId;
		if aStr &lt;&gt; null then
			if aStr.length &gt; 0 then
				value := aStr[1:30];
			endif;
			return;
		endif; 		
	endif;

	//epr par 6/8/07 14555
	termArea := self.targetLocation.myTerminalArea;															//06.03.2025 navma1 #MTN-34179
	
	if termArea &lt;&gt; null and not termArea.isKindOf(CM_GridArea) and  termArea.isHeightRequiredForLabel then	//06.03.2025 navma1 #MTN-34179
		numTI := self.targetLocation.numTIs + 1; // PAR 15547
	endif;
	
	// must use this to get the 40 foot ID
	value:=self.targetLocation.getFullIdTI(self.ti);
	if numTI &lt;&gt; null then
		value:=value &amp; " " &amp; numTI.String;// PAR 14387 NOW
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="taskDescription" id="2f2e8009-9897-4033-a093-981a7bb39864">
        <methodInvocation>mapping</methodInvocation>
        <source>taskDescription(set: Boolean; value: String io) mapping;
//Returns a nice description of the task.
vars
	aStr	:	String;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	aStr := self.taskTypeId;
	aStr := aStr &amp; " task to be picked up from ";
	aStr := aStr &amp; self.sourceLocationId.trimRight;
	aStr := aStr &amp; " and set down to " &amp; self.targetLocationId;
	value := aStr;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="taskTypeId" id="41680a07-5fbb-4bf6-9c14-b831baa1f9ee">
        <methodInvocation>mapping</methodInvocation>
        <source>taskTypeId(set: Boolean; value: String io) mapping;
vars
	req : CM_Request;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if  taskType = TASK_MOVE then
		value := TASK_MOVE_DESC;
	elseif taskType = TASK_PICKUP then
		value :=TASK_PICKUP_DESC;
	elseif taskType = TASK_SETDOWN then
		value :=TASK_SETDOWN_DESC;
	elseif taskType = TASK_DIRECTOR then
		value := TASK_DIRECTOR_DESC;
	elseif taskType = TASK_BREAKBULK then //cnwrd1 ccms 2274
		req:= self.getTaskRequest;
		value := TASK_BREAKBULK_DESC;
		if req  &lt;&gt; null then
			if req.isBulkMulti then
				value := TASK_BULK_DESC;
			endif;
		endif;
	else
		value := "Unknown!";
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tiISOType" id="c7e7d7a1-83c0-4ce2-9044-ba26b45fb776">
        <methodInvocation>mapping</methodInvocation>
        <source>tiISOType(set: Boolean; value: String io) mapping;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	value := "";
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if ti = null then
		return;
	endif;
	
	if ti.isKindOf(CM_Container) then
		value := ti.CM_Container.isoType.trimRight;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tiId" id="6bef1482-95ee-43c0-9443-f3014d8481dc">
        <methodInvocation>mapping</methodInvocation>
        <source>tiId(set: Boolean; value: String io) mapping;
vars
	tStr	: String;
begin
	value := "";
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.ti = null then
		if self.taskType = TASK_DIRECTOR or self.taskType = TASK_BREAKBULK then
			tStr := self.myEntry.myWorkListEntry.myRequest.getId(); 
			//value := tStr[1 : TI_ID_LEN];
			if tStr.length &gt; 20 then
				tStr := tStr[1:20]; // DVB
			endif;
			value := tStr;
		endif;
	else
		// PAR9510 AKB2005JAN
		tStr := ti.id.trimBlanks;
		if tStr.length &gt; 20 then
			tStr := tStr[1:20];
		endif;
		value := tStr;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="ultimateTargetLocation" id="96868675-0f32-44b6-9b45-e96df3190f32">
        <source>ultimateTargetLocation() : CM_LocationsController;
// -------------------------------------------
// Created 10 February 2006 by cnwdvb1
// -------------------------------------------
vars
	
	nextTask	:	CM_RTQueueTask;
	
begin

	if self.taskType = TASK_PICKUP then
		nextTask := getNextMachineTask();
		if nextTask = null then
			return self.targetLocation;
		endif;
		return nextTask.targetLocation;
	else
		return self.targetLocation;
	endif;


end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="ultimateTargetLocationId" id="38df4874-4c3f-4e6e-a93e-0ee7bec05a6d">
        <methodInvocation>mapping</methodInvocation>
        <source>ultimateTargetLocationId(set: Boolean; _value: String io) mapping;
//Returns the ULTIMATE target location of a Set Down task.
//If we are a pickup task, then we show set-down's target.
//If we are a set down, then show normal target.
//If we are a director, then show target.
//PAR 3504 AJA 8/5/00: Accomodate the new display of 40' positions
vars
	nextTask	:	CM_RTQueueTask;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.taskType = TASK_PICKUP then
		nextTask := getNextMachineTask();
		if nextTask = null then
			_value := targetLocationId40;
			return;
		endif;
		_value := nextTask.targetLocationId40[1 : 30];
	else
		_value := targetLocationId40[1:30];
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMachineCoverage" id="e2e4fc60-cd0e-4595-97e6-15cc5bae1fbe">
        <source>updateMachineCoverage();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars
	localBoolean : Boolean;
begin
		
	if not self.isTransient and 
		self.queue &lt;&gt; null then
		self.myEntry.setHasMachineCoverage(self.queryMachineCoverage(null));
	endif; 
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdateAllocMachine" id="2508e3b8-2c89-4e72-814c-ad3653b8a4b9">
        <source>validateForUpdateAllocMachine();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Change to user queryMachineAssign
					
*/

vars
	lMachine : CM_Machine;
	terminal	: CM_Terminal;
	messageLogger : CM_MachineRTQueueEntryLogger;
	isOverstowed,
	isOverstowedAtMoveTime : Boolean;
	sideAccessDirection : Integer;
	vehicleConfig : CM_RTVehicleConfig;
	arbiter	: CM_RTQueueArbiter;
begin
	lMachine := self.intendedMachine;
	if lMachine = null then
		//We need a machine
		app.raiseCMException1(ERR_NO_OBJECT, "No Machine", null, null);
		return;
	endif;
	
	if self.taskType &lt;&gt; TASK_PICKUP then
	 if self.taskType &lt;&gt; TASK_DIRECTOR and
		self.taskType &lt;&gt; TASK_MOVE then
			//Must be a pickup task.
			app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC, queueId, null, null);
			return;
		endif;
	endif;

	
	if self.status &lt;&gt; TASK_UNACTIONED 
		and self.status &lt;&gt; TASK_ALLOCATED  
		and self.status &lt;&gt; TASK_USER_HELD then	//22 Apr 2015	NDL Par 36014
		//Not unactioned
		app.raiseCMException2(ERR_TASK_NOT_STATUS, sourceLocationId.trimBlanks &amp; " to " &amp; targetLocationId.trimBlanks, "direct machine allocation, as NOT unactioned", null, null);
		return;	
	endif;
	//----------------
	//If we have a problem, generate a log automatically
	//----------------
	lMachine.setLoggedSearch(true);

	create messageLogger transient;
	messageLogger.myMachine:=lMachine;
	if not self.queryMachineAssign(lMachine, true, false,false, true,true,messageLogger) then
		//----------------
		//Error! Machine cannot pickup
		//----------------
		app.raiseCMException2(ERR_MACH_ASSIGN, lMachine.id.trimRight, "Machine is unsuitable, see Alert Log for details...", null, null);
		return;
	endif;
	lMachine.setLoggedSearch(false);	//Reset logging.
	
	// 07 Mar 2011	NDL	Par 27156	/ CCMS 2030
	if self.status = TASK_USER_HELD then	
		create arbiter transient;
		arbiter.validateForHeldStatusDirectUpd( self );
		app.raiseCMWarning1(Task_held_assign_anyway, lMachine.id, null, null, self);
	endif;

	if self.ti &lt;&gt; null then
		
		terminal := self.getMyTerminal();
		
		vehicleConfig:=terminal.getRTVehicleConfigForObject(lMachine);
		//epr CCMS 1099 25/5/10
		//epr par 23174 17/3/10
		// Par 13447
		if  vehicleConfig.overstowMoveMode &lt;&gt; CM_RTVehicleConfig.OSTOW_AUTOPLAN then   //SFW1030 04/08/2008	
			isOverstowed:=true;
			isOverstowedAtMoveTime:=true;
			sideAccessDirection:=null;
			self.isOverStowedRTQueue(isOverstowed,isOverstowedAtMoveTime,sideAccessDirection);	
		
			if isOverstowed then
				app.raiseCMWarning1(ERR_OVERSTOWED, self.ti.id,null,null,null);	//13 Jan 2011 NDL	Par 26746 / CCMS 1997
			endif;
		endif;
	
	endif;	

	
epilog
	delete messageLogger;
	delete arbiter;
	
end;</source>
    </JadeMethod>
</Class>
