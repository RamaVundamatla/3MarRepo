    <JadeMethod name="addExceptionHandler" id="b9491f6e-cc0e-45be-b55d-1807659c4f0b">
        <updating/>
        <source>addExceptionHandler(exObj : Exception; _passport : CM_Passport input) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index : Integer;
	obj   : Object;

begin

	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
		
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTI_old" id="1aba3612-dcf5-43db-9226-1345d0f4aaed">
        <updating/>
        <source>addTI_old() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	idx, theRow			: Integer;
	id				: String;
	ti, ti2			: CM_TrackedItem;
	tmpTIRequest	: CM_TIRequest;
	tmpBulkRelease	: CM_BulkRelease;
	anObject : Object;
begin
	app.myPassport.clearErrorsWarnings();

	self.isEmptyOnly := self.tblInput.getValueByName(ETRow_MtRelease).Boolean;
	
	while not self.tblListAll.allSelectedObjects.isEmpty do
		theRow := 0;
		
		anObject := self.tblListAll.allSelectedObjects.first;
		if anObject = null then
			self.tblListAll.allSelectedObjects.remove(anObject);
			continue;
		endif;
		ti := anObject.CM_TrackedItem;
		
		self.tblListAll.findObjectInRow(anObject, theRow);
		
		id := ti.id;
		
		// check all fields have been entered
	
		on CM_Exception do addExceptionHandler(exception, app.myPassport);
	
		app.setContinueCMExceptions(true);
		
		if ti = null then
			self.tblListAll.allSelectedObjects.remove(anObject);
			app.raiseCMException1(ObjectDeletedByOtherUser, 'tracked item', 'id', null);
			continue;
		else
			if ti.releaseRequest &lt;&gt; null then
				tmpBulkRelease := ti.releaseRequest.bulkRelease;
				if tmpBulkRelease &lt;&gt; null then
					if self.tblListAll.allSelectedObjects.includes(anObject) then
						self.tblListAll.allSelectedObjects.remove(anObject);
					endif;
					app.raiseCMException2(ERR_TI_HAS_BULK_REL, ti.id, tmpBulkRelease.code, 'id', null);
					continue;
				else
					if self.tblListAll.allSelectedObjects.includes(anObject) then
						self.tblListAll.allSelectedObjects.remove(anObject);
					endif;
					app.raiseCMException2(ERR_TI_HAS_BULK_REL, ti.id, ti.releaseRequest.deliveryNumber, 'id', null);
					continue;
				endif;
			endif;
		endif;
	
		if ti.isFull and self.isEmptyOnly then
			if app.msgBox("Container " &amp; ti.id &amp; " is NOT empty. Do you wish to continue?","Not Empty!",
						MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
				if self.tblListAll.allSelectedObjects.includes(anObject) then
					self.tblListAll.allSelectedObjects.remove(anObject);
				endif;
				continue;
			endif;
		endif;	
		
		// ### PAR 9374
		if ti.hasStops then
			if app.msgBox("Container " &amp; ti.id &amp; " has STOPS present. Do you wish to continue?","Has Stops!",
						MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
				if self.tblListAll.allSelectedObjects.includes(anObject) then
					self.tblListAll.allSelectedObjects.remove(anObject);
				endif;
				continue;
			endif;
		endif;	
	
		foreach ti2 in self.allTrackedItems do
			if ti2.id = ti.id then
				if self.tblListAll.allSelectedObjects.includes(anObject) then
					self.tblListAll.allSelectedObjects.remove(anObject);
				endif;
				app.raiseCMException1(VB_DUPLICATED_ITEM, 'Tracked Item ' &amp; ti.id, 'id', null);
				continue;
			endif;
		endforeach;
	
		if app.myPassport.hasErrors then
			if self.tblListAll.allSelectedObjects.includes(anObject) then
				self.tblListAll.allSelectedObjects.remove(anObject);
			endif;
			app.showErrorWarningDialog('Add Containers', app.myPassport, ErrWarnMode_Add);
			continue;
		endif;
	
		if not self.allTrackedItems.includes(ti) then
			self.allTrackedItems.add(ti);
		endif;
		if theRow &lt;= self.tblListAll.rows then
			self.tblListAll.removeItem(theRow);
		endif;
		self.tblList_ShowTI(ti, 0,self.tblList);
	endwhile;

epilog
	self.tblInput.setFocus;
	self.tblInput.goToRowByName(ETRow_IdCombo);
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addTIs" id="d4132708-fbff-4f88-bf7d-0c9773f243cb">
        <updating/>
        <source>addTIs() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm						: GTE_ReleaseRequests;
	pxyBulkRelease			: CM_BulkRelease;
	allSelectedItems		: ObjectArray;
	reserveDetail			: CM_ReserveSelection;
	obj						: Object;
	row						: Integer;
	lstIndex				: Integer; //par 19073
begin
	frm := self.myParentForm.GTE_ReleaseRequests;
	if frm = null or (not app.isValidObject(frm)) then
		app.msgBox(app.getErrorString(Edit_screen_closed) &amp;
					app.getErrorString(Drag_drop),app.getErrorString(Error_parent_screen_closed), MsgBox_Exclamation_Mark_Icon); // Par 16947 AER 21/07/2008
		return;
	endif;

	if frm.mode = CMUI_TreeViewForm.Mode_View then
		app.msgBox(app.getErrorString(ReleaseRequestNOTinEditMode),app.getErrorString(NOT_EDIT_MODE), MsgBox_Exclamation_Mark_Icon); // Par 16947 AER 21/07/2008
		return;
	endif;
	
	create allSelectedItems transient;
	self.tblListAll.allSelectedObjects.copy(allSelectedItems);
	
	
	if allSelectedItems.isEmpty then
		app.msgBox(app.getErrorString(CARGO_NOT_SELECTED),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);//  Par 16947 AER 21/07/2008
		return;
	endif;
	
	pxyBulkRelease := frm.myMasterProxyObject.CM_BulkRelease;
	if pxyBulkRelease.releaseByType then
		//if pxyBulkRelease.allReserveDetails.size = 1 then                                   //AER 01/07/2008 - Par 17312
		//	reserveDetail := pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection;      // taken out because it was forcing all the cargo to be attached 
		//else																				  // to the parent reserve if one existed.
		if CM_ReserveSelection.hasInstance(frm.lstTree.listObject) then
			reserveDetail := frm.lstTree.listObject.CM_ReserveSelection;
		elseif CM_BulkRelease.hasInstance(frm.lstTree.listObject) then						// Par 16947 21/07/2008 AER
			if (pxyBulkRelease.allReserveDetails.size + pxyBulkRelease.allReservePackingChildren.size) &gt; 1 then
				app.msgBox(app.getErrorString(Select_Request_Line), app.getErrorString(ERR_RequestLineNotSelected), MsgBox_Exclamation_Mark_Icon); // Par 16947 AER 21/07/2008
				return;
			elseif (pxyBulkRelease.allReserveDetails.size + pxyBulkRelease.allReservePackingChildren.size) = 0 then
				app.msgBox(app.getErrorString(No_Request_Line), app.getErrorString(NO_Request_Lines), MsgBox_Exclamation_Mark_Icon);//  Par 16947 AER 21/07/2008
				return;
			else // ther is ONE Reserve Selection, so use that
				if pxyBulkRelease.allReserveDetails.first &lt;&gt; null then
					reserveDetail := pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection;
				else
					reserveDetail := pxyBulkRelease.allReservePackingChildren.first.CM_ReserveSelection;
				endif;
			endif;
		endif;
		
		foreach obj in allSelectedItems do
			frm.dropTIOnReserveSelection(reserveDetail, obj.CM_TrackedItem);	
		endforeach;
		
	else//it's a release by ID
		foreach obj in allSelectedItems do
			frm.dropTIOnRelease(obj.CM_TrackedItem);
		endforeach;
	endif;
	
	foreach obj in allSelectedItems do
		row := -1;
		self.tblListAll.findObjectInRow(obj,row);
		if row &gt; 0 then
			self.tblListAll.removeItem(row);//this also removes from allSelectedObjects collection
		endif;
	endforeach;
	
	//par 19073
	//need to get current index before we do a table clear
	lstIndex := frm.lstTree.listIndex;
	frm.loadTree();
	
	//par 19073
	//reset the current index after the table clear
	if frm.lstTree.listCount &gt; 0 then
		if lstIndex &gt; frm.lstTree.listCount or lstIndex &lt; 1 then
			frm.selectObject(frm.lstTree.itemObject[1].CM_Object);
		else
			frm.selectObject(frm.lstTree.itemObject[lstIndex].CM_Object);
		endif;
	endif;
	
	self.updateNumSelectedLabel();
epilog
	delete allSelectedItems;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="e3cb27b6-65fe-44fa-a9f5-dc17d6d0e10b">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);		
	if app.isSpecial() then
		toolbar.addButton(self.btnCargoEnq, CMUI_Toolbar.Control_Alignment_Left);		
	endif;
	toolbar.addFrame(self.frmToolbarChk	, CMUI_Toolbar.Control_Alignment_Left);	
	
	toolbar.addFrame(self.frmToolbarColOrg, CMUI_Toolbar.Control_Alignment_Left); //14 Jun 2021	NDl	TFS 51338
	
	//28 Aug 2019	NDL	TFS 46118
	if app.getMyUser().canDo(self.myTerminal, PmAdmSelectorView) then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
