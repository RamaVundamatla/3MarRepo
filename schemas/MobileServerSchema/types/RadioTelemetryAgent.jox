    <JadeMethod name="recoverFromDisruptedState" id="8568a688-4f31-41a2-9468-7b4563e33d16">
        <updating/>
        <source>recoverFromDisruptedState(_dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

	ti  : CM_TrackedItem;

begin

	if self.myMediator.isOnHold then
		return self.resetFromOnHold(_dto, _stateInfo);
	endif;
	
	if (self.myMediator.state = self.OfferedTask or
	self.myMediator.state = self.AcceptedTask or
	self.myMediator.state = self.ActionedPickupWithTask) and 
	(global.isValidObject(self.myMediator.task)) then
		_dto.setFromMediator(self.myMediator);
		_stateInfo.guiState	:= self.myMediator.state;
		return true;
	elseif self.myMediator.state = self.ActionedPickup then
		ti := self.myMediator.myCurrentTi;
		if ti = null then
			_stateInfo.guiState := self.LoggedOn_Reset;
			return true;
		else
			_dto.setFromTI(ti);
			_stateInfo.guiState	:= self.myMediator.state;
			return true;
		endif;
		
	else
		_stateInfo.guiState := self.LoggedOn_Reset;
		return true;
	endif;

end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rejectTask" id="b402a4d6-c483-4a00-b0dd-dbe0d4e7e98e">
        <updating/>
        <source>rejectTask(_stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	
begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxRejectTask(self.myMediator, null, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	self.setMediatorState(self.LoggedOn_Reset);
	_stateInfo.guiState	:= self.LoggedOn_Reset;
		
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requestTask" id="e3166ec9-2570-4ac1-82d3-910964452b33">
        <updating/>
        <source>requestTask(_dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 10 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	task		: CM_RTQueueTask;
	guiState,
	extraInfo	: Integer;

begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
		
	extraInfo := app.myTrxRT.trxRequestTask(self.myMediator, null, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromMediator(self.myMediator);
	
	if extraInfo = 1 then
		guiState := self.AcceptedTask;
	else
		guiState	:= self.OfferedTask;
	endif;
		
	self.setMediatorState(guiState);
	_stateInfo.guiState := guiState;
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetFromOnHold" id="532ed9b7-c0cd-4a81-b767-1306f8f70ad7">
        <updating/>
        <source>resetFromOnHold(_dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	
begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxManipulateOnHold(false, self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromMediator(self.myMediator);
	
	_stateInfo.guiState	:= self.myMediator.state;
		
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));

end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetMediator" id="da300f84-fe8b-4fee-8ac0-98de267d3f1d">
        <updating/>
        <source>resetMediator(_clientConnectionDetails: String; _stateInfo : DTO_StateInfo input): Boolean updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

	rtnValue	: Integer;
	passport	: CM_Passport;
	user		: CM_User;
begin
	
	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	if not global.isValidObject(self.myMediator) then
		//process.debug;
	endif;

	user := self.myMediator.user;
	
	app.myPassport.setMyUser(user);
	
	rtnValue := app.myTrxRT.trxLogon(self, _clientConnectionDetails, true, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	if rtnValue &lt;&gt; 0 then
		_stateInfo.guiState 	:= rtnValue;
		_stateInfo.extraInfo	:= self.myMediator.state;
		_stateInfo.lastUpdateTs := self.myMediator.lastUpdateTs;
	else
		self.setMediatorState(self.LoggedOn_Reset);
		_stateInfo.guiState := self.LoggedOn_Reset;
	endif;
	return true;

epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMediatorState" id="b32d4277-ac53-474b-a9c6-29a498ab15aa">
        <updating/>
        <source>setMediatorState(_state: Integer) : Boolean updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars


	passport	: CM_Passport;

begin

	passport := app.myPassport;
	
	app.myTrxRT.trxSetMediatorState(self.myMediator, _state,  passport);
	if not passport.trxCompletedOK then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_state" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUserColors" id="01431d68-5bfc-4eb4-a41e-f25e73299917">
        <updating/>
        <source>setUserColors(_dtoColors : DTO_Colours input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
