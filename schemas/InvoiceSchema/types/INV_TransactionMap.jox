    <JadeMethod name="addToolbarControls" id="942faf8f-cdd7-44dc-bbeb-305229ce1fee">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
//	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintList, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnProperties, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCopy, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnReplace, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowPics, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowPopup,CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExtractCSV,CMUI_Toolbar.Control_Alignment_Left);	// 23659
	frm.addButton(self.btnLoadCSV,CMUI_Toolbar.Control_Alignment_Left);		// 23659
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// ### TFS 51912 14Sep2021 NAVPW1
	frm.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);			// ### TFS 51912 14Sep2021 NAVPW1
	frm.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);	// ### TFS 51912 14Sep2021 NAVPW1
	
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmListToolbar;
	frm.addButton(self.btnListSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnListCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmCopyToolbar;
	frm.addButton(self.btnCopySave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCopyCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmReplToolbar;
	frm.addButton(self.btnReplaceSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnReplaceCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmListMvToolbar;
	frm.addButton(self.btnMoveSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnMoveCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmQtyToolbar;
	frm.addButton(self.btnQtySave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQtyCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmQtyRngToolbar;
	frm.addButton(self.btnQtyRangeSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQtyRangCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

	// 24051
	frm := self.frmDebtorsToolba;
	frm.addButton(self.btnDebtorsSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDebtorsCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmCopyDebtTool;
	frm.addButton(self.btnCDSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCDCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	self.setupShowPictures();
	self.setupShowBubble();
	// 32674 set button up/down state from the saved values
	self.btnShowPics.value := not self.showPictures;
	self.btnShowPopup.value := not self.showBubbleHelp;

	
	frm := self.frmSeachToolbar; // PAR 25833
	frm.addButton(self.btnSearchSearch, CMUI_Toolbar.Control_Alignment_Left); // PAR 25833
	frm.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Right); // PAR 25833
	frm.positionToolbarControls(); // PAR 25833
	frm.visible := true; // PAR 25833
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCDCancel_click" id="340f3a1e-8ea0-4c1d-93cd-1b53e52a8b5e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCDCancel_click(btn: Button input) updating;

vars

begin
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	self.frmCopyDebtors.visible := false;
	self.modePropertyUpdate := INV_TransactionMap.ModeProperty_Debtor;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCDSave_click" id="b86679ec-4230-45c7-b1e9-1a088e4b5dde">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCDSave_click(btn: Button input) updating;

vars

begin
	// make sure a valid selection has been made.
	if self.lstCopyDebtList.listObject = null then
		app.msgBox(	app.getString( Selection_value_required, app.getString( Debtors ) ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	endif;
	if self.myCurrentMapTM &lt;&gt; null and
	   self.cmbCopyDebtTypes.listObject = null then
		app.msgBox(	app.getString( Selection_value_required, app.getString( Charges ) ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	endif;
	
	self.doCopyEntry();

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
