        <source>utlCreateRTGTelegram(	_proxy : CM_RTGTelegram input;
						_real 	: CM_RTGTelegram output;
						_machine : CM_Machine input;
						_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	_proxy.validateForCreate(_machine);
	
	if _machine.allRTGTelegrams.size &lt;&gt; 0 then
	/*check the last telegram was 
		if _proxy.isTwistLockClosed and not _machine.allRTGTelegrams.last.CM_RTGTelegram.isTwistLockOpen then 
			app.raiseCMException2(ERR_FIELD_VALUE,_proxy.twistlock, 'TwistLock', null, null);
		elseif _proxy.isTwistLockOpen and not _machine.allRTGTelegrams.last.CM_RTGTelegram.isTwistLockClosed then 
			app.raiseCMException2(ERR_FIELD_VALUE,_proxy.twistlock, 'TwistLock', null, null);
		endif; */
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	
	
	
	app.setContinueCMExceptions(false);

	create _real persistent;
	_real.setForCreate(	_proxy,
						_machine);
	
epilog

end;</source>
