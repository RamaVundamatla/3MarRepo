/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin

	if self.doTableHandlePassword( table.CM_EntryTable, newRow, newCol ) then
		return false;
	endif;
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
