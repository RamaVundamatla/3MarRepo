<Class name="CMIF_ConfigTerminal">
    <JadeMethod name="exportAttrIgnorePDXML" id="aadf6604-73dd-43ce-838d-ac6b890a6ccb">
        <source>exportAttrIgnorePDXML(_attrName:String) :Boolean;

vars

begin
	if _attrName = CMIF_ConfigTerminal::portLogoPic.name or
	   _attrName = CMIF_ConfigTerminal::rtPortLogoPic.name then
		return true;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="8487a81d-f5ac-475f-b917-04625220e6b5">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CMIF_Config::myObject.name then
		return app.myRoot.allTerminals[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
