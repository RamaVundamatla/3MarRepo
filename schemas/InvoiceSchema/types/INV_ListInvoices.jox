    <JadeMethod name="doMnuInvApiActivity" id="6fa0fdfd-67c5-4159-8cc5-eae611b6e9e5">
        <updating/>
        <source>doMnuInvApiActivity(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2023	navra1	Initial creation for TFS 54090 CR 61414 - Task 61416 &amp; 61415

*/

vars
	form : INV_APIActivity;
	invoice : CM_Invoice;	
	ewsParent : CM_ExternalWebServiceActivity;
	ewsChild : CM_EWSActivityInvoiceAPIParts;
	parentDesc:String;
	parentListBox : CMUI_ListBox;
	childrenListBox : CMUI_ListBox;
	listPointer : Integer;
begin
	if self.myCurrentInvoice = null then
		app.msgBox("Choose an invoice to view activity", "Choose API Invoice", MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form := app.loadForm(INV_APIActivity, INV_Assistant, false, false,false, self.myTerminal,null).INV_APIActivity;	
	
	if form &lt;&gt; null then				
		parentListBox := form.lstEwsParent;
		childrenListBox := form.lstEwsChildren;		
		
		invoice	:= self.myCurrentInvoice;
		form.caption := "API Activity for Invoice Number : "&amp; invoice.sequenceNum.String &amp; " - ";
		
		parentListBox.clear();
		childrenListBox.clear();
		
		foreach ewsParent in invoice.allEWSInvoiceAPIActivities do
			parentDesc := "Invoice :" &amp; invoice.sequenceNum.String &amp; "-" &amp; "Attempt :" &amp; ewsParent.CM_EWSActivityInvoiceAPI.attemptNumber.String;
			
			listPointer	:=	parentListBox.addItem(parentDesc);
			parentListBox.itemObject[listPointer]	:=	ewsParent;
			parentListBox.itemLevel[listPointer]	:=	1;			
			
			if ewsParent.CM_EWSActivityInvoiceAPI.fullMsgStatusStr = CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SENT then			
				parentListBox.itemBackColor[listPointer]:=Cn_Orange;
				parentListBox.itemForeColor[listPointer]:=Black;		
			elseif ewsParent.CM_EWSActivityInvoiceAPI.fullMsgStatusStr = CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_ERROR or
				ewsParent.CM_EWSActivityInvoiceAPI.fullMsgStatusStr = CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SEND_ERROR then			
				parentListBox.itemBackColor[listPointer]:=Red;
				parentListBox.itemForeColor[listPointer]:=Black;		
			elseif ewsParent.CM_EWSActivityInvoiceAPI.fullMsgStatusStr = CM_EWSActivityInvoiceAPI.INV_API_FULL_STAT_SUCCESS then
				parentListBox.itemBackColor[listPointer]:=Green;		
				parentListBox.itemForeColor[listPointer]:=White;		
			endif;
			
		endforeach;	
		
		form.show();		
	endif;
	
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
