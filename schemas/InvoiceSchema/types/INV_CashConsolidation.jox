    <JadeMethod name="populateFrmManual" id="52ba25f6-f738-4e4d-a957-d02816fcb52f">
        <source>populateFrmManual();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	theCombo : CMUI_ComboBox;
	anInvLineType : CM_InvoiceLineDesc;
	cashPayment : CM_CashPayment;
	proForma : CM_ProformaDetails;

begin

	theCombo := self.cmbInvLineType;
	theCombo.clear;
	theCombo.sorted := true;

	foreach anInvLineType in self.myCurrentTrackedItem.companyOid.invoiceLineDescriptors where not anInvLineType.isNotAvailableForEntry do
		if anInvLineType.isCargoCalcType() then
			if anInvLineType.services.isNotEmpty() then
				theCombo.addItemObject(anInvLineType.narration.String, anInvLineType);
			endif;
		endif;
	endforeach;
	
	cashPayment := self.tblUnassCashP.allSelectedObjects.first.CM_CashPayment;
	proForma := cashPayment.myProformaDetail;
	if proForma &lt;&gt; null and proForma.myInvoiceLineType &lt;&gt; null then
		theCombo.listIndex := theCombo.findObject( proForma.myInvoiceLineType );
	endif;
	
	self.txtNarration.text := self.btnAssignMa.caption &amp; " - " &amp; self.caption;
	
	self.optFinancial.value := true;
	self.txtFinancial.text := cashPayment.cashValue.asStringJMT;
	self.txtQtyManual.text := null;
	
	self.changeOption(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblCargoInvL" id="ec29fbe6-b333-4fbc-96b7-5b2494091399">
        <updating/>
        <source>populateTblCargoInvL( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	terminal : CM_Terminal;
	invLine : CM_InvoiceLine;

begin


	self.tblCargoInvL.rows := self.tblCargoInvL.fixedRows;
	self.tblCargoInvL.allSelectedObjects.clear();
	
	self.selectCargoInvoiceLine();
	
	if _ti = null then
		return;
	endif;
	
	terminal := _ti.myTerminal;
	
	//All cash invoice lines for the selected cargo item
	foreach invLine in _ti.invoiceLines discreteLock do
		if invLine.debtor.isCashOnlyDebtor( terminal ) then
			self.tblCargoInvL.addObject( invLine );
		endif;
	endforeach;
	
epilog

	self.enableActionButtons();


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populateTblUnassCashP" id="562aef38-c2ea-4462-9d33-b22231504554">
        <source>populateTblUnassCashP( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;

begin

	self.tblUnassCashP.rows := self.tblUnassCashP.fixedRows;
	self.tblUnassCashP.allSelectedObjects.clear();
	
	if _ti = null then
		return;
	endif;
	
	//all cash payments that have 'myInvLine = null' for the cargo

	foreach cashPayment in _ti.allCashPayments discreteLock do
		if cashPayment.cashValue = 0 then
			continue;
		endif;
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // tax payment ignore
			continue;
		endif;
		if cashPayment.myInvoiceLine = null then
			self.tblUnassCashP.addObject( cashPayment );
		endif;
	endforeach;
	
epilog

	self.enableActionButtons();

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="refreshObjectDisplay" id="0411874e-4619-4e29-9f8b-74f240e95887">
        <source>refreshObjectDisplay( _obj : CM_Object ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	ti : CM_TrackedItem;
	invLine : CM_InvoiceLine;
	relatedObject : CM_Object;
	
	rowIndex : Integer;
	entRow : EntTableRow;
	tmpStr : String;
	firstTime : Boolean;
	replaceStr : String;

begin

	if _obj = null then
		return;
	endif;
	
	firstTime := true;
	rowIndex := 0;
	
	if _obj.isKindOf( CM_TrackedItem ) then
		ti := _obj.CM_TrackedItem;
		
		self.tblRelCargo.findObjectInRow( ti, rowIndex );
		if rowIndex &gt; self.tblRelCargo.fixedRows and rowIndex &lt;= self.tblRelCargo.rows then
			foreach entRow in self.tblRelCargo.allTblDataEntRows do			
				tmpStr := ti.getDisplayStringForAttribute(entRow.name, true);
				if firstTime then
					firstTime := false;
					replaceStr := tmpStr;
				else
					replaceStr := replaceStr &amp; Tab &amp; tmpStr;
				endif;
			endforeach;
			self.tblRelCargo.setCellText( rowIndex, 1, replaceStr );
		endif;
		
	elseif _obj.isKindOf( CM_InvoiceLine ) then
		invLine := _obj.CM_InvoiceLine;
		if invLine.invoice &lt;&gt; null then
			relatedObject := invLine.invoice.myTrackedItem;
		endif;
		
		self.tblCargoInvL.findObjectInRow( invLine, rowIndex );
		if rowIndex &gt; self.tblCargoInvL.fixedRows and rowIndex &lt;= self.tblCargoInvL.rows then
			foreach entRow in self.tblCargoInvL.allTblDataEntRows do			
				tmpStr := invLine.getDisplayStringForAttribute(entRow.name, true);
				if firstTime then
					firstTime := false;
					replaceStr := tmpStr;
				else
					replaceStr := replaceStr &amp; Tab &amp; tmpStr;
				endif;
			endforeach;
			self.tblCargoInvL.setCellText( rowIndex, 1, replaceStr );
		endif;
		
	endif;

	if relatedObject &lt;&gt; null then
		self.refreshObjectDisplay( relatedObject );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="reselectCargoInvLines" id="435212bd-cb42-410e-9376-2c093c37ae83">
        <updating/>
        <source>reselectCargoInvLines(	_selectedInvLine : CM_InvoiceLine;
						_allSelectedAssigned : CM_CashPaymentSet
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	selectedRowIndex : Integer;
	
begin

	if _selectedInvLine &lt;&gt; null then
			
		selectedRowIndex := 1;
		self.tblCargoInvL.findObjectInRow( _selectedInvLine, selectedRowIndex );
		if selectedRowIndex &gt; self.tblCargoInvL.fixedRows then
			self.tblCargoInvL.accessRow( selectedRowIndex ).selected := true;
			self.tblCargoInvL.allSelectedObjects.add( _selectedInvLine );
			self.selectCargoInvoiceLine();
		endif;
		
		self.reselectInvLineCashPas( _allSelectedAssigned );
		
	endif;

epilog

end;</source>
        <Parameter name="_selectedInvLine" type="CM_InvoiceLine"/>
        <Parameter name="_allSelectedAssigned" type="CM_CashPaymentSet"/>
    </JadeMethod>
    <JadeMethod name="reselectInvLineCashPas" id="505e59f6-d886-4f29-a97b-1801beda5f04">
        <source>reselectInvLineCashPas( _allSelectedAssigned : CM_CashPaymentSet );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;
	selectedRowIndex : Integer;

begin

	if not _allSelectedAssigned.isEmpty then
		foreach cashPayment in _allSelectedAssigned do
			selectedRowIndex := 1;
			self.tblInvLineCashP.findObjectInRow( cashPayment, selectedRowIndex );
			if selectedRowIndex &gt; self.tblInvLineCashP.fixedRows then
				self.tblInvLineCashP.accessRow( selectedRowIndex ).selected := true;
				self.tblInvLineCashP.allSelectedObjects.add( cashPayment );
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_allSelectedAssigned" type="CM_CashPaymentSet"/>
    </JadeMethod>
    <JadeMethod name="reselectReleasedCargo" id="059cb21f-ccf0-436b-812f-58ea04a303e8">
        <updating/>
        <source>reselectReleasedCargo(	_selectedTi : CM_TrackedItem;
						_selectedInvLine : CM_InvoiceLine;
						_allSelectedAssigned : CM_CashPaymentSet;
						_allSelectedUnassigned : CM_CashPaymentSet
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	selectedRowIndex : Integer;

begin

	if _selectedTi &lt;&gt; null then
			
		selectedRowIndex := 1;
		self.tblRelCargo.findObjectInRow( _selectedTi, selectedRowIndex );
		if selectedRowIndex &gt; self.tblRelCargo.fixedRows then
			self.tblRelCargo.accessRow( selectedRowIndex ).selected := true;
			self.tblRelCargo.allSelectedObjects.add( _selectedTi );
			self.selectReleasedCargoItem();
		endif;
		
		self.reselectCargoInvLines(	_selectedInvLine, _allSelectedAssigned );
					
		self.reselectUnassignedCashPs( _allSelectedUnassigned );
		
	endif;

epilog

end;</source>
        <Parameter name="_selectedTi" type="CM_TrackedItem"/>
        <Parameter name="_selectedInvLine" type="CM_InvoiceLine"/>
        <Parameter name="_allSelectedAssigned" type="CM_CashPaymentSet"/>
        <Parameter name="_allSelectedUnassigned" type="CM_CashPaymentSet"/>
    </JadeMethod>
    <JadeMethod name="reselectUnassignedCashPs" id="e6dfdff2-0088-46d3-9f32-abe1f1271f7d">
        <source>reselectUnassignedCashPs( _allSelectedUnassigned : CM_CashPaymentSet );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;
	selectedRowIndex : Integer;

begin

	if not _allSelectedUnassigned.isEmpty then
		foreach cashPayment in _allSelectedUnassigned do
			selectedRowIndex := 1;
			self.tblUnassCashP.findObjectInRow( cashPayment, selectedRowIndex );
			if selectedRowIndex &gt; self.tblUnassCashP.fixedRows then
				self.tblUnassCashP.accessRow( selectedRowIndex ).selected := true;
				self.tblUnassCashP.allSelectedObjects.add( cashPayment );
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_allSelectedUnassigned" type="CM_CashPaymentSet"/>
    </JadeMethod>
    <JadeMethod name="resizeDockContainers" id="9a042a15-d9f6-4063-aea9-e48ca8d3d367">
        <updating/>
        <source>resizeDockContainers(_dock : JadeDockContainer input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

begin

	if _dock.isFloating then
		_dock.userObject.INV_CashConsolidation.doResize;
	else
