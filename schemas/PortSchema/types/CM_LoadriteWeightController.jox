<Class name="CM_LoadriteWeightController" id="48128083-da07-4df6-8fa6-107e1258f578">
    <superclass name="CM_WeightIntController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="getWeight" id="1eaaca37-6607-4880-a318-f6600a4bf2b7">
        <source>getWeight(_binResponse: Binary): Decimal protected;


// --------------------------------------------------------------------------------
// Created:		12 May 2010 by cnwjo3
//
// Purpose:		parse the commands from device, eg 'AD1 12.4' calls sendWeight, everything else
//				logs to file
//
/*

Date		Who		Reason
19 Apr 2016	cnwkpd1	TFS 1870 - Remove the exception condition for an empty string, which is the norm for 
					a timed out readAsynch
	
*/

constants
	SEPARATOR		: String = " ";
	ADD				: String = "AD";
	SUBTRACT		: String = "SB";
	TIMEDOUT		: String = "TO";
	ZEROED			: String = "Z0";  //thats the '0' number.  Not the O letter.
	TARE			: String = "TA";
	RECALLED		: String = "RC";
	SHORTTOTAL		: String = "ST";
	LONGTOTAL		: String = "LT";
	PRODUCT			: String = "SP";
	USER1			: String = "U1";
	USER2			: String = "U2";
	USER3			: String = "U3";
	USER4			: String = "U4";
	USER5			: String = "U5";
	ID				: String = "ID";
	TIME			: String = "TM";
	NW				: String = "NW";  //undocumented value
	DATE			: String = "DT";
	BINSIZE			: String = "BN";
	COMMENTTEXT 	: String = "CM";
	STATUSMESSAGE 	: String = "SI";
	USERMESSAGE		: String = "SU";
	END				: String = "E";
	
vars
	command : String;
	sequence : Integer;
	commandLength : Integer;
	info : String;
	pos : Integer;
	weight : Decimal[15,3];
	_commandLine : String;
begin	
	_commandLine:=_binResponse.ansiToString();
	pos := _commandLine.pos(SEPARATOR,1);

	self.diagnosticLog(method.qualifiedName &amp; " _commandLine=|" &amp; _commandLine &amp; "| pos=" &amp; pos.String &amp; " length=" &amp; _commandLine.length.String);
	
	//self.raiseWeightICException(0,"Parser OK: '" &amp; _commandLine &amp; "'" &amp; " pos: " &amp; pos.String);	

	//COMMAND IS CODE + SPACE + DATA
	if pos &gt; 1 and _commandLine.length &gt; 1 then
		//separated with data
		commandLength := command.length;
		command := _commandLine[1:2];
		if command = ADD then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			info := info.trimWhiteSpace();  //remove Cr at end of line so isDecimal works!
			
			if info.isDecimal() then
				weight := info.Decimal;
				weight := weight * 1000;  //convert to KGs
				return weight;
			else
				self.raiseWeightICException(0,"Invalid decimal value received: '" &amp; _commandLine &amp; "'");
			endif;
			
		elseif command = NW then  //this NW code is not in documentation
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.			
			
		elseif command = SUBTRACT then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = TIMEDOUT then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = ZEROED then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = RECALLED then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = SHORTTOTAL then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = LONGTOTAL then
			sequence := _commandLine[pos-1:1].Integer;
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = USER1 then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = USER2 then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = USER3 then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = USER4 then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = USER5 then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = DATE then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = BINSIZE then
			info := _commandLine[pos:end];
			//do nothing.
			
		elseif command = COMMENTTEXT then
			info := _commandLine[pos:end];
			//do nothing.
		
		elseif command = PRODUCT then
			info := _commandLine[pos:end];
			//do nothing.
			
		else
			self.raiseWeightICException(0,"Unknown command received from device (1): '" &amp; _commandLine &amp; "'");
		endif;
	elseif _commandLine.length = 2 then
		command := _commandLine;
		if command[1:1] = END then
			command := command[1:1];
			//do nothing.
		else
			self.raiseWeightICException(0,"Unknown command received from device (2): '" &amp; _commandLine &amp; "'");
		endif;
	elseif _commandLine.length &gt; 1 then
		command := _commandLine[1:2];
		if command = TARE then
			info := _commandLine[TARE.length+1:end];
			//do nothing.
			
		elseif command = PRODUCT then
			info := _commandLine[PRODUCT.length+1:end];
			//do nothing.
			
		elseif command = ID then
			info := _commandLine[ID.length+1:end];
			//do nothing.
			
		elseif command = STATUSMESSAGE then
			info := _commandLine[STATUSMESSAGE.length+1:end];
			//do nothing.
			
		elseif command = USERMESSAGE then
			info := _commandLine[USERMESSAGE.length+1:end];
			//do nothing.

		elseif command = TIME then
			info := _commandLine[3:end];
			//do nothing.
		else
			self.raiseWeightICException(0,"Unknown command received from device (3): '" &amp; _commandLine &amp; "'");
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
</Class>
