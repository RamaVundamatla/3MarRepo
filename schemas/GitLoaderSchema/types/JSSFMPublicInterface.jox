    <JadeMethod name="create" id="0fb3e332-31e4-4530-b9f8-9c1f1ac3885d">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Constructor to instantiate the File Manager schema's service object
//				class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SCHEMA_NAME		: String = "JSSFileManagerSchema";
	CLASS_NAME		: String = "JSSFMFileManagerService";
	
vars
	theRemoteSchema	: Schema;
	theRemoteClass	: Class;
	theRemoteObject	: Object;
	
begin
	theRemoteSchema	:=	rootSchema.getSchema(SCHEMA_NAME);
	
	if theRemoteSchema = null then
		Exception.raise_(99999, "Could not locate the remote schema (" &amp; SCHEMA_NAME &amp; ").");
	else
		theRemoteClass	:=	theRemoteSchema.getClass(CLASS_NAME);
		
		if theRemoteClass = null then
			Exception.raise_(99999, "Could not locate the service interface class (" &amp; CLASS_NAME &amp; ").");
		else
			create theRemoteObject as theRemoteClass transient;
			self.myServiceObject	:=	theRemoteObject;
			self.setAppServerAccess(true);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDirectory" id="d27ddf0c-4bc8-4feb-9d93-adcd62926c3f">
        <source>createDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Creates a new directory of the specified name.
//
// Parameters:	pDirectoryName - The pathname of the new directory.
//				pNodeOptions - Specifies destination node, i.e. Client, AppServer
//					or DB Server.  This must be a target node constant, not a
//					source node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pDirectoryName, pNodeOptions).Boolean;
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
