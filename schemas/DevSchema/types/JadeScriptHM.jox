    <JadeMethod name="clearInvalidVoyageTi" id="8961dc69-71e7-4e13-967a-3dd43301fa6a">
        <source>clearInvalidVoyageTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2025	navhl20 Bug MTN-35323: MSL - Cargo Enquiry search Fails for ?Anywhere? or ?Offsite? Locations

*/

vars
	term 	: CM_Terminal;
	ti		: CM_TrackedItem;
	lFile	: File;
begin
	app.initialize();
	term := app.myRoot.allTerminals['IMT'];
	create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp; term.code &amp;"VoyageData-1.csv";
    lFile.open;
	
	lFile.writeLine("Release Date"  			&amp; Comma &amp;
					"TrackedItem Code"  		&amp; Comma &amp;
					"TrackedItem Oid"  			&amp; Comma &amp;
					"cargo Type"
					);
	
	foreach ti in term.allOffsiteTIsByCargoTypeId discreteLock do
		if ti.myVoyage &lt;&gt; null and not app.isValidObject(ti.myVoyage) then
			lFile.writeLine(ti.releasedDT.asStringJMT  			&amp; Comma &amp;
							ti.id  								&amp; Comma &amp;
							ti.getOidAsString  					&amp; Comma &amp;
							ti.myCargoType.id.asStringJMT
							);
		endif;
	endforeach;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
