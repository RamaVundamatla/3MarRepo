    <JadeMethod name="getFullIdTI" id="ef540bfe-ba9a-4aca-a823-43cad6c38dca">
        <source>getFullIdTI(_ti: CM_TrackedItem): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//if _ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then
	if  (_ti.isAttributeTrue(TI_Attrib_IsForty) or _ti.isOverSizedContainer) then

		return self.getFullId40(); 
	else
		return self.getFullId(); 
	endif;



epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
