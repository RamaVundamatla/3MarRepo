/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2010	cnwrd1	Initial creation

*/

vars

	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstMTGrade.getSelectedString(CM_MTGrade::description.name);
	str := self.truncateDisplayString(str, -1);
	self.txtMTGrades.text := str;
	self.txtMTGrades.visible := true;
	self.lstMTGrade.visible := false;
	self.lstMTGrade.parent := _fieldFrame;
epilog

end;</source>
