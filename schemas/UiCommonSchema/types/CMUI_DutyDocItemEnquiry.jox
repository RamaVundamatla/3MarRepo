    <JadeMethod name="doDelete" id="d245b28b-cd4a-4e52-a07f-41ac4c7e529c">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	dutyDoc : Object;
	dutyDocArr : CM_ObjectArray;
	theReturn : Integer;
	invalidObject	: Boolean;	
begin
	//inheritMethod();
	if self.tblData.allSelectedObjects.isEmpty then
		return false;
	endif;
	
	//dutyDoc := self.tblData.allSelectedObjects.first.CM_Object;
	create  dutyDocArr transient;
	
	self.tblData.allSelectedObjects.copy(dutyDocArr);
	
	on Exception do app.handleDeletedObject(exception, dutyDoc, invalidObject);		// 15/08/2011 cnwmh5 #27286

	while true do
		foreach dutyDoc in dutyDocArr do
			app.myTrxDA.trxDeleteCMObject(dutyDoc.CM_Object,app.myPassport);
			if not app.myPassport.trxCompletedOK then
	
				theReturn := app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;	
			endif;
		endforeach;
		break;
	endwhile;
	
	return true;

epilog
	delete dutyDocArr;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
