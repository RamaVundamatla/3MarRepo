    <JadeMethod name="trxCreateLogDocketAndData" id="9c246911-da4d-4111-8674-d072ca8cf47a">
        <updating/>
        <source>trxCreateLogDocketAndData(	_logDocketData : CM_LogDocketData; 
							_logDocketDataNew : CM_LogDocketData output; 
							_intFaceCommon : CMIF_InOutCommon input;
							_intFaceArray : CMIF_TIObjectArray;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwmc5	Initial creation
15 Nov      2017    cnwma1  TFS #7354: C3 - Urgent - createLogDocket and updateLogDocket webservice returning the wrong JadeOID
*/

vars
	bol : CM_BOLIn;
	cmifBol : CMIF_BOLIn;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateInOutVehicle(_intFaceCommon, _passport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	
	if _passport.noErrors() then											//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myUtilityCA.utlCreateLogDocketData(_logDocketData, _logDocketDataNew, _passport);
	endif;																	//cnwmc5 - 22 Jan 2015 - PAR 35518
	
	if _passport.noErrors() then
		app.myUtilityCA.utlCreateInOut(_intFaceCommon, _intFaceArray, _passport, null);	//TFS 53107, AjitM, navam1
		
		if _passport.noErrors() then
			//bol := app.getMyTerminalDO_NOT_USE().getBOLInByNumber(_logDocketDataNew.docketNumber, BOLType_Log); //15/11/2017 cnwma1 TFS #7354
			
			//15/11/2017 cnwma1 TFS #7354
			if not _intFaceArray.isEmpty then
				cmifBol := _intFaceArray.first.CMIF_BOLIn;
				if cmifBol &lt;&gt; null and cmifBol.myPersistentBOL &lt;&gt; null  then
					bol := cmifBol.myPersistentBOL.CM_BOLIn;
				endif;
			endif;
			//15/11/2017 cnwma1 TFS #7354
			if bol &lt;&gt; null then
				app.myUtilityUA.utlUpdateLogDocketDataArchive(_logDocketDataNew, bol, _passport);
			endif;
		endif;
	endif;
	
epilog	
	self.finaliseActivityWithPassport(_passport); 
end;</source>
        <Parameter name="_logDocketData" type="CM_LogDocketData"/>
        <Parameter name="_logDocketDataNew" type="CM_LogDocketData" usage="output"/>
        <Parameter name="_intFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
