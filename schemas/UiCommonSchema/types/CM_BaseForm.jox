    <JadeMethod name="activate" id="711d3acf-3b09-4d5f-b1c5-c05418251cab">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
09 Sep 2008 cnwdz2	Par16842
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/
vars
	invalidEWForm : Boolean;
begin
	app.currentHelpKeyword := self.helpKeyword.truncatedAt(30);		// PAR #34210

	if (not self.isKindOf(CM_WarningsForm)) then
		app.setMyTerminal(self.myTerminal);
	endif;

	if (not self.isFirstActivateComplete) then
		self.loadDataForFirstTime();
	endif;
	
	self.selectMenuActionForSelf();
	
epilog
	if (not self.isFirstActivateComplete) then
		// set the flag here because we don't want to repeat the load
		// on the next activate if the load has an exception
		self.isFirstActivateComplete := true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="addAllErrorWarnings" id="dc66a037-81df-4abf-bf28-d7beddcc6e01">
        <updating/>
        <source>addAllErrorWarnings(_passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err	: CM_Error;
	
begin

	if _passport = null then
		return;
	endif;
	
	_passport.allErrorWarnings.copy(self.allErrorWarnings);
	foreach err in self.allErrorWarnings do
		err.removeFromPassport();
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addEntRowIfNotFound" id="6f79d313-d2d0-49e1-80c2-449ff2d3f8d3">
        <source>addEntRowIfNotFound() : Boolean;
/*
Purpose:			

Date		Who		Reason
