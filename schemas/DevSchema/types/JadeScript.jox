    <JadeMethod name="eprFixupVesselCellTiers" id="3d1d2712-664d-4ede-93d1-f9a8b0a1edf9">
        <source>eprFixupVesselCellTiers();
/*

Date		Who		Reason
29 August 2014	cnwer1	Initial creation PAR

*/

vars
	fwdTier : CM_TierDefn;
	bay : CM_BayDefn;
	realCellDefn:CM_CellDefn;
	realTierDefn:CM_TierDefn;
	i:Integer;
begin
	
	bay:="2157.12140".asOid.CM_BayDefn;

	beginTransaction;
	/*i:=1;
	foreach  realTierDefn in bay.allTiersOnDeck do
		realTierDefn.setPropertyValue("ordinal",i);
		i:=i+1;
	endforeach;*/
	
	foreach realCellDefn in bay.allCellsOnDeckByOrdinal do
		foreach  realTierDefn in bay.allTiersOnDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if bay.checkAndResetOrdinals(realCellDefn,realTierDefn,true)then
				break;
			endif;
		endforeach;
	endforeach;
	foreach realCellDefn in bay.allCellsUnderDeckByOrdinal do
		foreach  realTierDefn in bay.allTiersUnderDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if bay.checkAndResetOrdinals(realCellDefn,realTierDefn,false)then
				break;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprGetCargoTypesForVoyage" id="0b091284-d0ce-4ae5-8e2c-e001e849d0e0">
        <source>eprGetCargoTypesForVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2022	jlier1	Initial creation

*/

vars
	voyage : CM_Voyage;
	iter: Iterator;
	cargoTypeID,lastCargoTypeID : Integer;
	ti ,nextTi: CM_TrackedItem;
	allCargoTypes : IntegerArray;
begin
	voyage:="4480.66976".asOid.CM_Voyage;
	voyage.inspectModal;
	
	create allCargoTypes transient;
	iter:=voyage.allOnsiteTIsByCargoTypeId.createIterator;
	
	while iter.next(ti) do
		cargoTypeID:=iter.getCurrentKey(1).Integer;
		//if lastCargoTypeID = null then
		allCargoTypes.add(cargoTypeID);
		nextTi:=voyage.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoTypeID+1,null);
		if nextTi = null or nextTi.cargoType = cargoTypeID  then
			break;
		endif;
		iter.startAtObject(nextTi);	
	endwhile;
	
	delete iter;
	iter:=voyage.allOnshipTIsByCargoTypeId.createIterator;
	
	while iter.next(ti) do
		cargoTypeID:=iter.getCurrentKey(1).Integer;
		//if lastCargoTypeID = null then
		if not allCargoTypes.includes(cargoTypeID) then
			allCargoTypes.add(cargoTypeID);
		endif;
		nextTi:=voyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(cargoTypeID+1,null);
		if nextTi = null or nextTi.cargoType = cargoTypeID  then
			break;
		endif;
		iter.startAtObject(nextTi);	
	endwhile;
	
	write allCargoTypes.asCSV(false);
	
epilog
	delete iter;
	delete allCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprIncrementID" id="71c634aa-6a77-48c0-8b59-e33ab9f589d7">
        <source>eprIncrementID();
