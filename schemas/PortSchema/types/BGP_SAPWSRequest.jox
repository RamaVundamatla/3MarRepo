        <source>processSAPPreBillCheckLimitReq(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.002 Perform Credit Check for Pre-Billing Customer
	WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
	PaymentType_PrePay
Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process

*/
vars
	request  	: CMIF_SAPPreBillCheckLimitReq;
	response 	: CMIF_SAPWSResponse;
	result   	: Boolean;
	respStatus,
	msg			: String;
	cashInv     : CM_Invoice;
begin
	
	if self.myCashReceipt.myCashInvoice &lt;&gt; null then          //23.01.2019 cnwma1 TFS #42942
		cashInv := self.myCashReceipt.myCashInvoice;
	endif;
	
	create request transient;
	request.copyToSAPPreBillCheckLimitReq(cashInv );        //23.01.2019 cnwma1 TFS #42942
	response := _agent.preBillCheckLimitRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											self.myCashReceipt,	//_cashReceipt : CM_CashReceipt input;
											cashInv,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;
	
	msg :=  method.qualifiedName &amp; 
			' ' &amp; BGP_SAPWSRequest.WSDL14  &amp;
			' ' &amp; "Invoice : " 	   	       &amp; cashInv.exportCurrencyCode &amp;
			' ' &amp; "Response Status :" 	   &amp; respStatus &amp;
			' ' &amp; "isProcessed : "    	   &amp; self.isProcessed.asStringJMT &amp;
			' ' &amp; "Result :" 		       &amp; result.asStringJMT;
	
	app.writeLog(msg,LogINFO);
	return result;
epilog
	delete request;
	delete response;
end;</source>
