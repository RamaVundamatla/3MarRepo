        <source>makeMessageDTM_VGM(_protocol: CM_CamProtocol; _group: HugeStringArray input; _ti: CM_TrackedItem): String protected;
//
// 20 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
