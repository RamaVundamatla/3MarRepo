    <JadeMethod name="utlUpdateRoRoLaneTiOrder" id="535be843-3d5c-4c43-b0c9-a06abb0a5713">
        <source>utlUpdateRoRoLaneTiOrder( _roroLane : CM_RoRoController; _theTIsNewOrder : CM_TIArray; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2020	jlgndl1	Initial creation	TFS 48270  

*/

vars

	ti : CM_TrackedItem;

begin

	self.initialiseActivity();
	
	//remove each one and add back, this should change the existing order to be the new order.
	
	foreach ti in _theTIsNewOrder do
		if ti.allLocations[1] = _roroLane then 
		// We only want to reorder using this method not remove from or add to the collection, so only do thise already in this location
			ti.allLocations[1] := null; // clears the primary position against the ti, which automatically removes it from the _roroLane.allTrackedItems collection, moving all others forward in the collection
			ti.allLocations[1] := _roroLane; //adds it back the same as it was on the ti, but adds back as the last one in the _roroLane.allTrackedItems collection
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_roroLane" type="CM_RoRoController"/>
        <Parameter name="_theTIsNewOrder" type="CM_TIArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
