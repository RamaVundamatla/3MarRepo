    <JadeMethod name="buildSelf" id="40565dcd-9206-4ae8-8cf3-4d1d81a477d3">
        <updating/>
        <source>buildSelf() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	doorsDirBtn	: GTE_FlexiDoorsDirMask;	

begin

	self.normalBackColor 	:= 15642292;
	self.selectedBackColor 	:= 11312639;
	
	if self.backColor &lt;&gt; self.selectedBackColor then
		self.backColor := self.normalBackColor;
	endif;

	if self.myFlexiDoorsDirBtn = null then
		create doorsDirBtn transient;
		doorsDirBtn.parent := self;
		form.addControl(doorsDirBtn);

		if isInPainter then
			doorsDirBtn.actualEnabled := false;
		endif;
		self.myFlexiDoorsDirBtn := doorsDirBtn;
	else
		doorsDirBtn := self.myFlexiDoorsDirBtn;
	endif;

	doorsDirBtn.height	:=	20;
	doorsDirBtn.width	:=	20;
	doorsDirBtn.top		:= self.clientHeight - doorsDirBtn.height - 5;
	self.positionDoorsDirBtn();	// sets the left position
	
	doorsDirBtn.foreColor		:=	foreColor;
	doorsDirBtn.fontName		:=	fontName;
	doorsDirBtn.fontSize		:=	fontSize;
	doorsDirBtn.fontBold		:=	fontBold;
	doorsDirBtn.fontItalic		:=	fontItalic;
	doorsDirBtn.fontUnderline	:=	fontUnderline;
	doorsDirBtn.fontStrikethru	:=	fontStrikethru;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearDetails" id="464617e6-6235-4cbe-9a5d-e57eb38d5e67">
        <updating/>
        <source>clearDetails() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	needRefresh	: Boolean;
	
begin

	self.id		:= null;
	self.length := 0;
	self.myContainer := null;
	
	if self.visible then
		needRefresh := true;
	endif;
	
	self.visible := false;
	
	if needRefresh and self.myFlexiTruckLayoutFrame &lt;&gt; null then
		self.myFlexiTruckLayoutFrame.repositionAfterResize();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="34df2a41-c76a-403a-a5fd-d5c7e709e4fd">
        <controlMethod name="Frame::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(frame: Frame input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwas3	Initial creation

*/


begin
	inheritMethod(frame);
	if self.myContainer &lt;&gt; null then
		self.select();
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="b6feef52-83f4-4ec4-8e69-0f37bc1d8379">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.isBuilt := false;
	
	self.alignment			:= Alignment_Center_Top;
	self.bevelInner			:= Bevel_Inset;
	self.bevelInnerWidth	:= 1;
	self.bevelOuter			:= Bevel_Raised;
	self.bevelOuterWidth	:= 1;
	self.boundaryWidth		:= 1;//cnwas3
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="a1737ebb-26d9-4ff7-8b1e-316bfd942d2a">
        <updating/>
        <source>dblClick(frame: Frame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwas3	Initial creation

*/

vars
	idx : Integer;
	mainForm : GTE_FlexiGateForm;
begin

	if self.myContainer &lt;&gt; null then
		self.select();	
		mainForm:=self.myFlexiTruckLayoutFrame.parent.CMUI_Sheet.parent.CMUI_Folder.parent.GTE_FlexiGateForm;
		//idx:=mainForm.myRealVVR.allGateEntities.getIdxFromId(self.myContainer.getID());
		idx := self.myContainer.jobQueueNum;
		mainForm.tblItems.selectRow(idx+1,false);
		mainForm.doTblItemsDblClick();
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deSelect" id="17d38f4b-3e39-4dba-ba1f-c1f0833985b1">
