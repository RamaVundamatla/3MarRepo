    <JadeMethod name="setSelectedValues" id="dd8d4844-d021-48e5-b4f1-320c8b9a1021">
        <updating/>
        <source>setSelectedValues( _taList : CM_TerminalAreaArray ; _goList : CM_GridObjectArray; _fifo : Boolean ; _bestPick : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwrd1	Initial creation

*/

vars

begin

// need to set booleans 
	if _fifo then
		self.optFIFO.value := true;
	else
		self.optSelected.value := true;
	endif;
	
	_taList.copy(self.allSelectedTAs);	
	if self.allSelectedGridObjects &lt;&gt; null then
		_goList.copy(self.allSelectedGridObjects);
	endif;
	//self.doSelectedTAChange(self.allSelectedTAs);	
	self.chkBestPick.value := _bestPick;
	
	
	
	
	

epilog

end;</source>
        <Parameter name="_taList" type="CM_TerminalAreaArray"/>
        <Parameter name="_goList" type="CM_GridObjectArray"/>
        <Parameter name="_fifo" type="Boolean"/>
        <Parameter name="_bestPick" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6c4eb16f-ccbc-47a9-ae61-bdb78bfffc88">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.hideBestPick then
		self.chkBestPick.visible := false;
	else
		if self.myTerminal.isAutoPlanUseBestPickDirector then
			self.chkBestPick.visible := false;
		else
			self.chkBestPick.visible := true;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupListAreas" id="51b04ffb-ca34-4034-912a-4181b63d5e39">
        <updating/>
        <source>setupListAreas() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/
vars
	allTermAreas : CM_ObjectArray;
	allSelectedAreas : CM_ObjectArray;	
begin

	create allTermAreas	transient;
	create allSelectedAreas	transient;
	
	self.mltTermAreas.userInputEnabled 				:= true;
	self.mltTermAreas.formDisplayEntryMethodName 	:= CMUI_SelectISOSourceMulti::displayTA.name;
	self.mltTermAreas.displayOrderBtns(true, true);
	self.mltTermAreas.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltTermAreas.myAvailableListBox.sorted 	:= false;		
	self.mltTermAreas.mySelectedListBox.sorted 		:= false;
	//self.mltTermAreas.setTabIndex();
	self.mltTermAreas.myBaseForm 					:= self;
	self.mltTermAreas.myAvailableListBox.sorted	:= true;
	
	self.mltTermAreas.selectedHeading := app.getErrorString(Selected_terminal_areas);
	self.mltTermAreas.availableHeading := app.getErrorString(TerminalAreas);
		
	self.doPopulateTerminalAreas( allTermAreas );	
	self.mltTermAreas.setAvailable( allTermAreas , true);
	
	self.getSelectedObjects(allSelectedAreas);
	
	//self.mltTermAreas.setSelected(self.allSelectedTAs );
	self.mltTermAreas.setSelected( allSelectedAreas );
	self.mltTermAreas.cnEcResizeContents();
	
	//cnwmc5 - 15 Feb 2016 - PAR 37511
	self.mltTermAreas.setVisibleButtons(true, true, false);
	
epilog
	delete allTermAreas;
	delete allSelectedAreas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="02e8dd60-9236-4500-adee-0ff460e9bf38">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015071, locale);
	btnCancel.translateCaption(Xlat_0015072, locale);
	btnOK.translateCaption(Xlat_0015073, locale);
	chkBestPick.translateCaption(Xlat_0016188, locale);
	grpAreaSchOrder.translateCaption(Xlat_0015074, locale);
	lblDesc.translateCaption(Xlat_0015076, locale);
	optFIFO.translateCaption(Xlat_0015077, locale);
	optSelected.translateCaption(Xlat_0015078, locale);
end;</source>
    </JadeMethod>
