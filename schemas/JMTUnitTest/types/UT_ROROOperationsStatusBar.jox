	dischargeLocn.add("D4250984");
	dischargeLocn.add("D4250986");
	
	beginTransaction;
	foreach locnDefn in dischargeLocn do
		strs.clear();
		strs.add(locnDefn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		theSlot.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
	endforeach;
