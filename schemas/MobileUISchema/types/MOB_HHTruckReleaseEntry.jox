    <JadeMethod name="doResizeControls" id="f488e386-442c-42a2-8035-baa64819963f">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/

vars
	stdWidth,
	stdHeight,
	top 		: Real;
begin
	return;
	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="bc507a1e-d4fe-442a-918c-ccf3b58e73ec">
        <source>findTruck( errMsg : String output ) : CM_Vehicle;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	truckString : String;
	term : CM_Terminal;
	truck : CM_Vehicle;
begin
	
	truckString := txtTruck.text;
	
	if truckString.trimBlanks = null  and self.txtBAT.text.trimBlanks &lt;&gt; null then
	
		//20 Dec 2013	NDL	Par 32849
		truck := self.findTruckFromBatNumber();
		if truck = null then
			errMsg := app.getErrorString(Number_no_current_truck);
		endif;		
	else
		// identify the truck from the value entered.
		term := self.myMobileDataAgent.myTerminal;
		truck := term.vehicles[truckString.toUpper, null];
		
		if truck = null then			
			errMsg := app.getErrorString2( ERR_Truck_Unknown, truckString, null );		
		endif;
		
	endif;

	if truck &lt;&gt; null then
		self.isValidTruckForAction( truck,  errMsg);
	endif;
	
	return truck;
	
epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="findTruckFromBatNumber" id="c772e042-692e-4b8c-b836-1913cd41e99f">
        <source>findTruckFromBatNumber():CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2013	cnwndl1	Initial creation	Par 32849

*/

vars

	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	batNum : String;

begin

	batNum := self.txtBAT.text.toUpper;
	if batNum = null then
		return null;
	endif;

	term := self.myMobileDataAgent.myTerminal;
	if term &lt;&gt; null then
		vvr := term.getVehicleVisitForBatNumber( batNum );
		if vvr &lt;&gt; null then
			return vvr.vehicle;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="4cd38e13-d64d-46b9-b433-34acc9426fd6">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/

vars
	errMsg : String;
	truck : CM_Vehicle;
begin
	truck:=self.findTruck( errMsg ) ;
	
	if errMsg &lt;&gt; null then
		self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	if self.txtDoor.text = null then
		errMsg:=app.getErrorString(Input_required_door);
		self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.txtDoor.setFocus();
		return;
	endif;
	
	self.myMobileGenericAgent.setTruck(truck );
	self.myMobileGenericAgent.setWarehouseDoor(self.txtDoor.text);

	self.gotoForm(MOB_HHTruckReleaseSelect, false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="da8ebc07-e6b5-4d5e-a3d9-f7820ae32f63">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/

vars

begin
	self.myMobileGenericAgent.clearAll();
	self.gotoHomeForm();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isValidTruckForAction" id="1e22c4f7-f63a-44a5-98b0-5cc37fd4c595">
        <source>isValidTruckForAction( _truck : CM_Vehicle io;errMsg : String output);

/*

Purpose:			
	
Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	job : CM_RoadJob;
	visitRecord : CM_VehicleVisitRecord;
	request 	: CM_Request;
begin

	if _truck &lt;&gt; null then
		if not _truck.isOnsite or not _truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
			// can't load/unload  it if its not in the yard eh!
			errMsg := app.getErrorString(Truck_Not_In_Yard);
			_truck := null;
			return;
		endif;
	endif;
	
	visitRecord:=_truck.getCurrentVisit;
	if visitRecord = null then
	
		errMsg := app.getErrorString(Truck_has_no_visit_record);
		_truck := null;
		return;
	endif;
		
	if visitRecord.myRoadJob.getMyBulkRelease = null then
		errMsg := app.getErrorString1(Truck_not_relea_cargo_relea_re,_truck.regNumber);
		_truck:=null;
	endif;
	
epilog

end;</source>
        <Parameter name="_truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="05ad3057-33eb-47c6-8aab-92435d75e7e8">
        <source>setupControls();
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/

vars
	truck : CM_Vehicle;
begin
	truck := self.myMobileGenericAgent.myTruck;
	if truck &lt;&gt; null then
		self.txtTruck.text := truck.regNumber;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="24bcdb20-ddc7-4bec-9539-424720cda068">
        <updating/>
        <source>setupForm() updating, protected;
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/

vars

begin
	
	self.myMobileGenericAgent.clearAll(); // to reset 'terminal' on the agent..
	inheritMethod();
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f5f81b65-c9b0-4550-a217-6b930f4066cf">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:49:54.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023442, locale);
	lblBAT.translateCaption(Xlat_0020951, locale);
	lblDoor.translateCaption(Xlat_0020952, locale);
	lblTruck.translateCaption(Xlat_0020953, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
