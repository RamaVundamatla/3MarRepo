/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgndl1	Initial creation	TFS 44651

*/

vars

begin

	if _invoice = null then
		global.setExtraData( self.allExtraData, self, self.PEL1_MATCHING_INVOICE, null );
	else
		global.setExtraData( self.allExtraData, self, self.PEL1_MATCHING_INVOICE, _invoice );
	endif;

epilog

end;</source>
