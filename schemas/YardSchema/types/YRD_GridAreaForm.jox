begin
	self.doRefresh();

end;</source>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="a4a7e9bc-0ea9-4b1f-881c-dcef278b1b9e">
        <updating/>
        <source>doDropFromGridAreaForm(frame: CMUI_GridAreaFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridPoint	: CMUI_GridPoint;
	fromLocation,
	theController : CM_LocationsController;
	logDocket: CM_BOLIn;
	ti: CM_TrackedItem;
begin
	gridPoint := frame.myGridArea.convertPositionToGridPoint(x, y);
	if gridPoint &lt;&gt; null then
		if frame.myGridArea.flipHorizontal then
			if not self.myTerminal.getConfig(YardFlippedDropOnRight).Boolean then
				if app.myDraggedTrackedItem = null then
					return;
				endif;
				if app.myDraggedTrackedItem.isAttributeTrue(TI_Attrib_IsForty) then
					theController := gridPoint.myLocationsController;
					gridPoint := frame.myGridArea.allGridRows[gridPoint.row].allGridPointsByColumn[gridPoint.column + 1];
					if gridPoint = null then
						app.raiseCMException1(Suitabl_contain_longer_than, theController.getFullId,null,null); // PAR 17386
						return;
					endif;
				endif;
			endif;
		endif;

		theController := gridPoint.myLocationsController;
		
		// is this a sub block stack?
		if theController.isKindOf(CM_GridController) then
			if theController.CM_GridController.mySubBlockStack &lt;&gt; null then
				theController := theController.CM_GridController.mySubBlockStack.myLocationsController;
			endif;
		endif;

		if app.myMoveController.isLogWagonDrag then		// TFS 2533
			logDocket := app.myDraggedTrackedItem.myReceivalBOL;
			fromLocation := app.myDraggedTrackedItem.myPrimaryActualLocation;
			foreach ti in logDocket.allTrackedItems do
				if ti &lt;&gt; app.myMoveController.myTrackedItem then
					app.myMoveController.allOtherTrackedItems.add(ti);
				endif;
			endforeach;
			app.myMoveController.isLogWagonDrag := false;
		else
			self.myDroppedTI := app.myDraggedTrackedItem;
		endif;
		self.moveTrackedItemTarget(theController); //app.myDraggedTrackedItem, gridPoint.myLocationsController
	endif;

	if self.autoMask and self.myCurrentSDF &lt;&gt; null then
		self.myCurrentSDF.drawSelf();
	endif;
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFlipH" id="a3e3b6cb-1cc8-4b3e-99ed-bc05ac1402fb">
        <updating/>
        <source>doFlipH() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theGridArea : CMUI_GridArea;
	theFrame : CMUI_GridAreaFrame;
	flipString : String;
	theGridFrame : CMUI_GridAreaFrame;

begin

	if self.areaType = self.Area_Type_Log then
		return;
	endif;
	theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
	theGridArea := theFrame.myGridArea;
	self.xmlFlipH := not self.xmlFlipH;
	theGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
	theGridArea.doFlipH();
	self.sdf01.doZoom(self.sdf01.scaleFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF
	self.sdf01.doCentreOnSelectedPoint();

	if self.allTerminalAreas.size &gt;= 2 then
		theFrame := self.frmGridArea.getControl(2).CMUI_GridAreaFrame;
		theGridArea := theFrame.myGridArea;
		theGridArea.setFlips(not theGridArea.flipHorizontal,theGridArea.flipVertical);
		theGridArea.doFlipH();
		self.sdf02.doZoom(self.sdf02.scaleFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF
		self.sdf02.doCentreOnSelectedPoint();
	endif;			
	if self.allTerminalAreas.size = 3 then
		theFrame := self.frmGridArea.getControl(3).CMUI_GridAreaFrame;
		theGridArea := theFrame.myGridArea;
		theGridArea.setFlips(not theGridArea.flipHorizontal,theGridArea.flipVertical);
		theGridArea.doFlipH();
		self.sdf03.doZoom(self.sdf03.scaleFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF
		self.sdf03.doCentreOnSelectedPoint();
	endif;
	theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
	if theFrame &lt;&gt; null then
		theGridArea := theFrame.myGridArea;
		self.doSetCaption(theGridArea);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFlipV" id="427bf1ff-4eb1-4573-b5fe-c599797b9896">
        <updating/>
        <source>doFlipV() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theGridArea : CMUI_GridArea;
	theFrame : CMUI_GridAreaFrame;
	flipString : String;
	theGridFrame : CMUI_GridAreaFrame;

begin

	if self.areaType = self.Area_Type_Log then
		return;
	endif;

	theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
	theGridArea := theFrame.myGridArea;
	self.xmlFlipV := not self.xmlFlipV;
	theGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
	theGridArea.doFlipV();
	self.sdf01.drawSelf();
	self.sdf01.doCentreOnSelectedPoint();

	if self.allTerminalAreas.size &gt;= 2 then
		theFrame := self.frmGridArea.getControl(2).CMUI_GridAreaFrame;
		theGridArea := theFrame.myGridArea;
		theGridArea.setFlips(theGridArea.flipHorizontal,not theGridArea.flipVertical);
		theGridArea.doFlipV();
		self.sdf02.drawSelf();
		self.sdf02.doCentreOnSelectedPoint();
	endif;			
	if self.allTerminalAreas.size = 3 then
		theFrame := self.frmGridArea.getControl(3).CMUI_GridAreaFrame;
		theGridArea := theFrame.myGridArea;
		theGridArea.setFlips(theGridArea.flipHorizontal,not theGridArea.flipVertical);
		theGridArea.doFlipV();
		self.sdf03.drawSelf();
		self.sdf03.doCentreOnSelectedPoint();
	endif;

	theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
	if theFrame &lt;&gt; null then
		theGridArea := theFrame.myGridArea;
		self.doSetCaption(theGridArea);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropEvent" id="6f47fa80-163e-4bfc-891d-a28ff1985c69">
        <updating/>
        <source>doGridAreaDragDropEvent(frame: CMUI_GridAreaFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTIs : CM_TIArray;
begin
	self.myDroppedTI := null;
	if win &lt;&gt; null then
		if win.userObject &lt;&gt; null then
			if win.userObject.class.name = "SHP_LoadList" then
				app.raiseCMException1(INVALID_MOVE_REQUEST, 'Cannot drag drop from Load List form.', null, null);
				return;
			endif;
		endif;
	endif;
	if self.myCurrentSDF.displayMode = DISPLAY_MODE_PLAN and self.myCurrentSDF.moveMode = REAL_MODE then
		app.raiseCMException1(INVALID_MOVE_REQUEST, Cr &amp;  'Cannot drag drop in INSTANT mode whilst displaying PLANNED cargo.', null, null);
		return;
	
	endif;

	if win.isKindOf(CMUI_GridAreaForm) or 
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CMUI_GridAreaForm2) or
	   win.isKindOf(CMUI_GridAreaDrawingFrame) then
		if self.myPreviousSDF &lt;&gt; null then
			create theTIs transient;
			self.myPreviousSDF.getAllSelectedTIs(theTIs);
			if  theTIs.size &gt; 1 then
				self.doGridAreaDragDropEventQdOS(theTIs,app.myDraggedTrackedItem);
				if theTIs.isEmpty then
					return;
				endif;
			endif;
		endif;

		self.doDropFromGridAreaForm(frame,win, x,y);
	endif;
	
	if win.isKindOf(YRD_RoadOperationsForm) or win.isKindOf(CM_DataTable) then 
		self.doDropFromGridAreaForm(frame,win, x,y); // they basically do the same. This one is more comprehensive
//		self.doDropFromRoadOpsForm(frame,win, x,y);
	endif;
	if app.myPassport.trxCompletedOK then
		app.isDragging := true;
	else
		app.isDragging := false;
	endif;
	frame.dragMode := DragMode_None;
epilog
	delete theTIs;
	frame.enableEvent("mouseMove",false);

end;</source>
        <Parameter name="frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropEventQdOS" id="3ca921e7-7785-4b4b-a144-ca21a4e83f64">
        <updating/>
        <source>doGridAreaDragDropEventQdOS(_theTIs : CM_TIArray input;_theDragTI : CM_TrackedItem) updating; 
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is for handling Queued Overstow multi select moves.
//				IF they have a stack of TIs Qd, but they want the TI at the bottom first, this code is to allow them to select 2 TIs and drag drop them 
//				elsewhere in the yard. If they are both already Qd, then the top TI will have an additional Qd move added to the other TIs Q Entry
//
// ---------------------------------------------------------------------------

vars
	theTI1, theTI2,theTI3	: CM_TrackedItem;
	theReturn,indTI1,indTI2,
	escKey, numQd			: Integer;
	anLC					: CM_LocationsController;
	notOverstow				: Boolean;
begin

	if self.moveModeForm &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	if _theTIs.size = 1 then
		return;
	endif;
	
	if _theTIs.size &lt;&gt; 2 then
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		self.keyDown(escKey,null); 
		return;
	endif;
	
	notOverstow := false;
	escKey := CMUI_Key_Esc;
	
	// DVB I think you should be able to attach an overstow move manually even if 
	// it isn't already queued up. 19/01/04
/*	foreach theTI1 in _theTIs do
		if theTI1.myPrimaryQueuedLocation &lt;&gt; null then
			numQd := numQd + 1;
		endif;
	endforeach;
	
	if _theTIs.size &lt;&gt; numQd then
		self.keyDown(escKey,null); 
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		return;
	endif;*/
	theTI1 := _theTIs[1];
	theTI2 := _theTIs[2];
	
	if theTI1.myPrimaryActualLocation = theTI2.myPrimaryActualLocation then
		anLC := theTI1.myPrimaryActualLocation;
		indTI1 := anLC.allTrackedItems.indexOf(theTI1);
		indTI2 := anLC.allTrackedItems.indexOf(theTI2);
		if indTI2 &gt; indTI1 then
			theTI3 := theTI1;
			theTI1 := theTI2;
			
			theTI2 := theTI3;
		endif;
		//at this point theTI1 is the one on top
	else
		notOverstow := true;
		/*	if theTI1 &lt;&gt; _theDragTI then	// changed to =
			theTI3 := theTI1;
			theTI1 := _theDragTI;
			theTI2 := theTI3;
		endif;
		*/
	endif;

	if theTI2.queueTask = null then
		app.msgBox(theTI2.id  &amp; " is not Queued.  Not valid for Manual Overstow Queue.",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	elseif notOverstow then
		app.msgBox(theTI2.id  &amp; " is not overstowed by " &amp; theTI1.id &amp; ".",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;

	if app.myDraggedTrackedItem &lt;&gt; theTI1 then	//they must drag the top container - this is the one that will be queued
		app.msgBox(app.myDraggedTrackedItem.id  &amp; " is the overstowed item.  You must drag the item to be queued (" &amp; theTI1.id &amp; ").",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;
		

	theReturn := app.msgBox("Create overstow Queued move for " &amp; theTI1.id  &amp; " and attach to queue entry for " &amp; theTI2.id &amp; "?",
							"Manual Overstow Queue Confirm",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);

	if theReturn = MsgBox_Return_No then
		_theTIs.clear;
		return;
	endif;

	app.myMoveController.myRTQueueEntry := theTI2.queueTask.myEntry;
	app.myMoveController.isOverstowMove := true;
	app.myMoveController.setMyWorkListEntry(null);

end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragOverAutoMask" id="4f768faf-6ff8-4614-818d-6fcfd2019d77">
        <source>doGridAreaDragOverAutoMask(_sdf: CMUI_ScrollableDrawingFrame input; _theMaskTI : CM_TrackedItem;_theTermArea : CM_TerminalArea);
//-----------------------------------------
// Created: September 2003 By: cnwgd1
//-----------------------------------------
vars
	dischargePort,
	commodityGroup,
	voyageCode	: String;
	mode 		: Integer;
	ts : TimeStamp;
begin

	if (not self.autoMask) then
		return;
	endif;
	
	if _theMaskTI = null then
		return;
	endif;
	
	if _theTermArea = null then
		return;
	endif;
	mode 			:= self.getDisplayMode();
	dischargePort 	:= _theMaskTI.dischargePort;
	commodityGroup	:= _theMaskTI.commodityGroup;
	voyageCode 		:= _theMaskTI.voyageCode;	
	
	_sdf.allSelectorTIs.clear();
			
	_sdf.getAutoMaskTIs(_sdf.allSelectorTIs, mode, dischargePort, commodityGroup, voyageCode);
	

epilog
	_sdf.allSelectorTIs.clear;		
end;</source>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_theMaskTI" type="CM_TrackedItem"/>
        <Parameter name="_theTermArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseContextEvent" id="33f45e39-536f-422a-9bc5-bef0acfb993b">
        <updating/>
        <source>doGridAreaMouseContextEvent(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients

*/

vars
	gridPoint	: CMUI_GridPoint;
	lTI : CM_TrackedItem;
	theLogController : CM_LogController;
	gridController : CM_GridController;
	anLC : CM_LocationsController;
	aRestriction : CM_Restriction;
	aTiDict : CM_TIByIdDict;
	aOK : Boolean;
	termArea : CM_TerminalArea;
	locnString : String;
	theGridArea : CMUI_GridArea;
	thePlanMove : CM_FutureMove;
	tiArray		: CM_TIArray;
	canMaint : Boolean;
begin
	theGridArea := cntrl.CMUI_GridAreaFrame.myGridArea;
	gridPoint := theGridArea.convertPositionToGridPoint(x, y); //self.frmGridArea
	self.setMyCurrentSDF(theGridArea.mySDF,true);
	self.doTurnOffContextMenus();
	
	
	// TFS 2198 CNWAB1
	canMaint := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	
	if gridPoint &lt;&gt; null then
		termArea := gridPoint.myLocationsController.myTerminalArea;
		self.myCurrentTerminalArea := termArea;
		// # ROW AREAS
		if gridPoint.isKindOf(YRD_RowAreaPoint) then
			self.mnuLog.visible := true;
			
			if gridPoint.canUserAccessSelf() then
				self.mnuStockMovements.visible	:= true;
				self.mnuLogEnquire.visible := true;
				self.mnuLogEdit.visible := canMaint;

				theLogController := gridPoint.myLocationsController.CM_LogController;
				self.mnuLog.caption := "Row " &amp; theLogController.getID;
				self.mnuLogWidth.visible := canMaint;
				self.mnuLogWidth.userObject := theLogController.myRow;
				self.mnuLogRecalc.visible := false;
				self.mnuLogRecalc.userObject := theLogController;
				if self.myCurrentTerminalArea.CM_RowArea.isGapManaged then
					self.mnuLogPrevious.visible := canMaint;
					self.mnuLogPrevious.userObject := theLogController.myRow;
				else
					self.mnuLogPrevious.visible := false;
				endif;			
				self.mnuLogEnquire.caption := "Enquire On " &amp; theLogController.getID;
				self.mnuLogEnquire.userObject := theLogController;
				self.mnuLogEdit.caption := "Edit " &amp; theLogController.getID;
				self.mnuLogEdit.userObject := theLogController;
				self.mnuStockMovements.userObject	:= theLogController;
			else
				self.mnuLog.visible := false;
				self.mnuStockMovements.visible	:= false;
				self.mnuLogEnquire.visible := false;
				self.mnuLogEdit.visible := false;
				self.mnuLogRecalc.visible := false;
				self.mnuLogWidth.visible := false;
				self.mnuLogPrevious.visible := false;
			endif;
		else
			// ######## STRADDLES AND FORK LFT STACKS
			gridController := gridPoint.myLocationsController.CM_GridController;
			
			self.doBuildMnuLocation(termArea,gridController);
			
			lTI := gridPoint.YRD_GridPoint.getTI(x, y);
			if lTI &lt;&gt; null then
				self.mnuCargo.visible := true;
				// #######################
				self.doBuildMnuContainer(lTI);
				
				create tiArray transient;
				theGridArea.allSelectedTrackedItems.copy(tiArray);
				self.mnuCargoMoveIt.userObject	:= tiArray;
				if theGridArea.allSelectedTrackedItems.size &gt; 1 then
					self.mnuGridBulkEdit.visible := true;
					create aTiDict transient;
					theGridArea.allSelectedTrackedItems.copy(aTiDict);
					self.mnuGridBulkEdit.userObject := aTiDict;
				endif;
			else
				//if app.myCurrentVoyage &lt;&gt; null then
				//cnwjo3 par 23105
				if app.getMyCurrentVoyage() &lt;&gt; null then
					self.mnuGridTBA.visible := true;
					self.mnuGridTBA.userObject := gridPoint.myLocationsController;
				endif;
			endif;
			// #####################
			// PLANNING FROM SHIP?
			// #####################

			if app.myMoveController &lt;&gt; null then
				// DISCHARGE
				if app.myDraggedTrackedItem &lt;&gt; null then
					thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge);
					if thePlanMove = null then
						thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
					endif;
//					thePlanLocation := app.myDraggedTrackedItem.getPrimaryLocation(PLANNING_MODE);
					if thePlanMove &lt;&gt; null then
						self.mnuGridPlanDischarge.userObject := null;
						self.mnuGridPlanDischarge.visible := false;
					else
						if app.myMoveController.mySlotRequest &lt;&gt; null and 
						   app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
							// YES!
							if app.myMoveController.mySlotRequest.isDischarge  then
								self.mnuGridPlanDischarge.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
								self.mnuGridPlanDischarge.userObject := gridController;
								self.mnuGridPlanDischarge.visible := true;
							endif;
						endif;
					endif;
				// LOAD
				else
					if lTI &lt;&gt; null then
//						if not lTI.isPlanned(PLANNING_MODE) then
							if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
								// YES!
								if app.myMoveController.mySlotRequest.isLoad then
									if lTI &lt;&gt; null then
										app.myMoveController.setMyTrackedItem(lTI);
									endif;
									// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
									// we must have the primary location of teh 40 so that the screen draws correctly
									if  lTI.isAttributeTrue(TI_Attrib_IsForty) then
										if lTI.isRehandle then
											thePlanMove := lTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
											if thePlanMove &lt;&gt; null then
												anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
												if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
													gridController := anLC.CM_GridController;
												endif;
											endif;
										else
											// if a plain export load then we need the primary actual location
											anLC := lTI.myPrimaryActualLocation;
											if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
												gridController := anLC.CM_GridController;
											endif;
										endif;
									endif;									

									app.myMoveController.setMyOriginatingLocation(gridController);
									locnString := app.myMoveController.mySlotRequest.mySlotController.myVoyage.code &amp; " ";
									locnString := locnString &amp; app.myMoveController.mySlotRequest.mySlotController.getStowageId(lTI);
									self.mnuGridPlanLoad.caption := "Plan Load To " &amp; locnString;
									self.mnuGridPlanLoad.userObject := gridController;
									self.mnuGridPlanLoad.visible := true;
								endif;
							endif;
						endif;
					endif;
//				endif;
			endif;
			
		endif;
	else
		// we are not actually clicking on anything, so check for the nearest column to the right
		gridPoint := theGridArea.convertPositionToFirstColumn(x, y); 
		if gridPoint &lt;&gt; null then
			// In Log Row Areas this allows us to click on 'gaps'
			if gridPoint.isKindOf(YRD_RowAreaPoint) then
				self.mnuLog.visible := true;
				self.mnuStockMovements.visible	:= false;
				self.mnuLogEnquire.visible := false;
				self.mnuLogEdit.visible := false;
				self.mnuLogRecalc.visible := false;
	
				theLogController := gridPoint.myLocationsController.CM_LogController;
				self.mnuLog.caption := "Row " &amp; theLogController.getID;
				self.mnuLogWidth.visible := true;
				self.mnuLogWidth.userObject := theLogController.myRow;
	
				if self.myCurrentTerminalArea &lt;&gt; null and self.myCurrentTerminalArea.CM_RowArea.isGapManaged then
					self.mnuLogPrevious.visible := true;
					self.mnuLogPrevious.userObject := theLogController.myRow;
				endif;			
			
			endif;
		endif;
	endif;

	self.mnuGridBigFont.visible := true;
	self.doBuildMnuZoom(self.mnuZoomSub);
	self.doBuildMnuZoom(self.mnuWorkDisplayZoom);
	self.mnuGridAreaContext.visible := false;
	self.mnuGridAreaContext.enabled := false;
	self.doHideSeperator();
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, x, y);
	

epilog
	delete aTiDict;		// PAR #18664
	delete tiArray;
	
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseDBClickEvent" id="eccaeb39-1295-4339-995a-569e595703da">
        <updating/>
        <source>doGridAreaMouseDBClickEvent(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions, replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars
	gridPoint 	: CMUI_GridPoint;
	ti			: CM_TrackedItem;
	aYardPoint 	: YRD_GridPoint;
	theLabour 	: CM_LabourRestriction;
	startTime 	: Time;
begin 
	
	app.mousePointer 	:= MousePointer_HourGlass;
	gridPoint 			:= frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos); 
	
	if gridPoint = null or (not gridPoint.isKindOf(YRD_GridPoint)) then 
		return;
	endif;
	
	aYardPoint := gridPoint.YRD_GridPoint;
	
	// ### TRACKED ITEM ENQUIRY
	ti := aYardPoint.getTI(self.origXPos, self.origYPos);
	
	if ti &lt;&gt; null then 
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);	
	
	// ### SUB BLOCK STACK 
	elseif aYardPoint.mySubBlockStack &lt;&gt; null then 
		self.myAssistant.showLocationEnquiryForm(aYardPoint.mySubBlockStack, self.myMasterMenuAction, false, false);
	
	// ### LABOUR RESTRICTION
	elseif aYardPoint.letter = GridPointType_RestLab then
		theLabour := self.myCurrentTerminalArea.allRestrictionsLabour[aYardPoint.labourRestrictionID];

		if theLabour &lt;&gt; null then
			// DVB changed 17/02/04 To use assistant.
			self.myAssistant.showRestrictionsForm(self.myCurrentTerminalArea,YRD_PadArea.AreaMode_Labour,theLabour,
													self.xmlFlipH,self.xmlFlipV, self.myMasterMenuAction);
		endif;
		
	elseif aYardPoint.letter = GridPointType_Light then
	elseif aYardPoint.letter = GridPointType_ReeferGantry then
	elseif aYardPoint.letter = GridPointType_Building then

	else 
		return;
//		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Unknown DOUBLE CLICK");
	endif;
epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseDownEvent" id="28cb654e-2585-40dd-a6d6-d1d68fe671a3">
        <updating/>
        <source>doGridAreaMouseDownEvent(frame: Frame input;button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.origXPos := x;
	self.origYPos := y;
	frame.enableEvent("mouseMove",true);
	frame.CMUI_GridAreaFrame.isDrawDeskTopRectangle := false;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseMoveEvent" id="da8cb646-93ec-4a68-a392-965c797dab07">
        <updating/>
        <source>doGridAreaMouseMoveEvent(frame: CMUI_GridAreaFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	theTIs : CM_TIArray;
	theGridArea : CMUI_GridArea;
	anLC : CM_LocationsController;
	thePlanMove : CM_FutureMove;
begin
	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		if shift.isControlKeyPressed then
			frame.isDrawDeskTopRectangle := true;
			frame.firstMouseX := self.origXPos.Integer;
			frame.firstMouseY := self.origYPos.Integer;
			frame.lastMouseX := self.origXPos.Integer;
			frame.lastMouseY := self.origYPos.Integer;
			frame.dragMode := DragMode_Drag;
			frame.dragCursor := self.chkCursorMulti.dragCursor;
			return;
		endif;
		
		theGridArea := frame.CMUI_GridAreaFrame.myGridArea;
		gridPoint := theGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos); 
		if gridPoint &lt;&gt; null then
			self.setMyCurrentSDF(theGridArea.mySDF,true);
			theTI := gridPoint.getTI(self.origXPos, self.origYPos);
		endif;

		// initiate a drag/drop
		self.myPreviousSDF := self.myCurrentSDF;
		create theTIs transient;
//		self.myCurrentSDF.getAllSelectedTIs(theTIs);
//		if not theTIs.isEmpty then
//			self.doGridAreaMouseMoveEventQdOS(theTIs,theTI);
//			if theTIs.isEmpty then
//				return;
//			endif;
//		endif;
		if theTIs.isEmpty then
			if theTI &lt;&gt; null then
				theGridArea.addTIToSelected(theTI);
				theTIs.add(theTI);
			endif;
		endif;
		if not theTIs.isEmpty then
			theTI := theTIs.first;
			theTIs.remove(theTI);
			self.moveModeForm := self.sdf01.moveMode;
			if self.moveModeForm &lt;&gt; QUEUE_MODE then
				theTIs.clear;
			endif;
			app.myDraggedTrackedItem := theTI;
			self.setMoveControllerSource(theTI);
			if gridPoint = null then
				return;
			endif;

			app.myMoveController.setMyOriginatingLocation(gridPoint.myLocationsController);
			// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
			// we must have the primary location of teh 40 so that the screen draws correctly
			if theTI.isRehandle and theTI.isAttributeTrue(TI_Attrib_IsForty) then
				thePlanMove := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
				if thePlanMove &lt;&gt; null then
					anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
					if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
						app.myMoveController.setMyOriginatingLocation(anLC);
					endif;
				endif;
			endif;									

			
			if not theTIs.isEmpty then
				app.myMoveController.setAllOtherTrackedItems(theTIs);
			endif;
			frame.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				frame.dragCursor := lPicture.picture;
			endif;
		endif;
	endif;
epilog
	delete lPicture;
	delete theTIs;
end;</source>
        <Parameter name="frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseUpEvent" id="2c0116e8-97bc-4aaf-9533-6f108c153a72">
        <updating/>
        <source>doGridAreaMouseUpEvent(frame: Frame input;button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove references to CM_LocationRestrictContainer
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	thePIC 		: CMIF_PopupInfoController;
	theSBS 		: CM_BlockStack;
	theLabRest 	: CM_LabourRestriction;
	theTermArea : CM_TerminalArea;
	theCMObject : CM_Object;
	theTI 		: CM_TrackedItem;
	theGridArea : CMUI_GridArea;
begin
	theGridArea := frame.CMUI_GridAreaFrame.myGridArea;

	if theGridArea = null then
		return;
	endif;
	
	self.setMyCurrentSDF(theGridArea.mySDF,true);

	gridPoint := theGridArea.convertPositionToGridPoint(x, y); //frmGridArea
	
	if gridPoint &lt;&gt; null then
		theTI := gridPoint.getTI(x, y);
		
		if theTI &lt;&gt; null then
			self.frmStatusLine.myFrameCaption.caption := theTI.id;
		else
			self.frmStatusLine.myFrameCaption.caption := null;
		endif;
		
		self.setMyCurrentSDF(gridPoint.myGridArea.mySDF,true);
		
		if frame.CMUI_GridAreaFrame.longLeftClick 
		and self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
			create thePIC transient;
			
			theTermArea := gridPoint.myLocationsController.myTerminalArea;
			
			if theTermArea.isKindOf(CM_LogArea) then // PAR 8410
				theCMObject := theTermArea.CM_LogArea.allLocationsControllers.first; // PAR 8410
			else
				theSBS 		:= gridPoint.YRD_GridPoint.mySubBlockStack;
				theLabRest 	:= theTermArea.allRestrictionsLabour[gridPoint.YRD_GridPoint.labourRestrictionID];
				
				if theTI &lt;&gt; null then
					theCMObject := theTI;
				
				elseif theSBS &lt;&gt; null then
					thePIC.showEnquiryButton 		:= true;
					self.frmPopupInfo.userObject 	:= theSBS;
					self.btnPopupEnq.bubbleHelp 	:= app.getErrorString(CMUI_Enquire_On) &amp; theSBS.id;
					theCMObject 					:= theSBS;
					
				elseif theLabRest &lt;&gt; null then
					thePIC.showEnquiryButton 		:= true;
					self.frmPopupInfo.userObject 	:= theLabRest;
					self.btnPopupEnq.bubbleHelp 	:= app.getErrorString(CMUI_Enquire_On) &amp; theLabRest.id;
					theCMObject 					:= theLabRest;
				endif;
			endif;

			thePIC.setForCreate(theCMObject, self.myCurrentSDF.displayMode, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
									self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
			self.showPopupInfoFrame(thePIC);

		elseif button &lt;&gt; Button.MouseButton_Right then	//do only for left btn - JC 26/01/04
			self.showExtraInfo(gridPoint,x,y);
			self.picCargo.picture := self.showCargoPicture(gridPoint.getTI(x, y));
		endif;

	endif;
epilog
	frame.enableEvent("mouseMove",false);
	app.isDragging := false;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doInitSDF" id="f76b48bc-dfae-4dd2-9982-067facc77398">
        <updating/>
        <source>doInitSDF(_theSDF : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	_theSDF.width := self.width - self.frmLegend.width - 10;
	_theSDF.setHLabelDetails(30);
	_theSDF.setVLabelDetails(30);
	_theSDF.labels := ScrollBars_Both;
	_theSDF.myTerminal := self.myTerminal;
	_theSDF.setupFrame();
	_theSDF.myParentForm := self;
	_theSDF.scaleFactor := null; // this is set from XML user savings 
	_theSDF.moveMode := self.moveModeForm;
	_theSDF.myDrawingFrame.backColor := Gray;
	_theSDF.displayMode := self.frmStatusLine.displayMode;	

	if self.areaType = self.Area_Type_Log then
		_theSDF.viewMode := VIEW_OPERATOR;
	else
		_theSDF.viewMode := VIEW_VOYAGE;

		_theSDF.myTopLeftFillerFrame.drawFontSize := 8;
		_theSDF.myTopLeftFillerFrame.drawFontBold := true;
		_theSDF.myTopLeftFillerFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		_theSDF.myTopLeftFillerFrame.autoRedraw := true;
		_theSDF.myTopLeftFillerFrame.clearGraphics();
		
		_theSDF.myTopLeftFillerFrame.width := _theSDF.myVLabels.width + 6;
		_theSDF.myTopLeftFillerFrame.height := _theSDF.myHLabels.height + 6;

	endif;



end;</source>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doInitializeWithObject" id="e4ed97f4-59bd-4c1b-95a4-baad157c94ef">
        <updating/>
        <source>doInitializeWithObject(_anObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK METHOD - no references
// ---------------------------------------------------------------------------
vars
	theTA : CM_TerminalArea;
	theLC : CM_LocationsController;
begin
	if _anObject.isKindOf(CM_LocationsController) then
		theLC := _anObject.CM_LocationsController;

		theTA := theLC.myTerminalArea;
		
		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
			self.myInitializeLocation := theLC;
		endif;
	elseif _anObject.isKindOf(CM_GridArea) then
		theTA := _anObject.CM_GridArea;

		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
		endif;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doInitializeWithTI" id="e8412376-8409-416e-867d-58849594763c">
        <updating/>
        <source>doInitializeWithTI(_anArea : CM_TerminalArea;_aLocation : CM_LocationsController; _aTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK METHOD - no references
// ---------------------------------------------------------------------------
vars
	theTA : CM_TerminalArea;
	theLC : CM_LocationsController;
begin
	if _aLocation.isKindOf(CM_LocationsController) then
		theLC := _aLocation.CM_LocationsController;

		theTA := theLC.myTerminalArea;
		
		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
			self.myInitializeLocation := theLC;
			self.myInitializeTI := _aTI;
		endif;
	elseif _anArea.isKindOf(CM_GridArea) then
		theTA := _anArea.CM_GridArea;

		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
		endif;
	elseif _anArea.isKindOf(CM_LogArea) then
		theTA := _anArea.CM_LogArea;

		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_LogArea) then
			self.myInitializeObject := theTA.CM_LogArea;
		endif;
	endif;
end;</source>
        <Parameter name="_anArea" type="CM_TerminalArea"/>
        <Parameter name="_aLocation" type="CM_LocationsController"/>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuAttachClick" id="22352bfa-fc3e-4b8d-a11e-fde53c24f3f3">
        <updating/>
        <source>doMnuAttachClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
