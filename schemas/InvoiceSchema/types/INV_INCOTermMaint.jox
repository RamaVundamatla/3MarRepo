    <JadeMethod name="btnAdd_click" id="82a6d624-45c5-4ec2-aee8-02a36e9858bc">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	form : INV_INCOTermMapping;
begin
	form := app.loadForm(INV_INCOTermMapping, INV_Assistant, false, false,false, self.myTerminal,null).INV_INCOTermMapping;
	if form &lt;&gt; null then
		form.mode := false;
		form.setINCOTerm(myINCOTerm);
		form.setMyCurrentBank(myCurrentBank);
		form.centreWindow();
		form.show;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAudits_click" id="211ec073-c659-4bf4-895d-4fdff774b19d">
