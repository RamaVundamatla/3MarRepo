    <JadeMethod name="trxApplyDeckingRule" id="f20d0990-6325-41aa-b606-274fa945d6ef">
        <updating/>
        <source>trxApplyDeckingRule(_pxyDeckingOptions: CM_YADeckingOptions; _updateToLevel: Integer; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isSetup					: Boolean;
	realDeckingOptions,
	pxyDeckingOptions		: CM_YADeckingOptions;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	pxyDeckingOptions := _pxyDeckingOptions;

	if pxyDeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'proxy rules are null');
		return;
	endif;
	

beginTransaction;

	pxyDeckingOptions.validateForDecking();	//add validation - test if NOK for decking

	if _passport.hasErrors then
		return;
	endif;
	app.myUtilityUA.utlUpdateDeckingOptions(pxyDeckingOptions, realDeckingOptions, _updateToLevel, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	self.raiseExceptionIfNull(realDeckingOptions, "Persistent DeckingOptions");
	
	//apply rules to YALocationCells
	app.myUtilityUA.utlApplyDeckingRule(realDeckingOptions, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_updateToLevel" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxArchiveEmptyLocation" id="ae239d5a-fe30-4ead-bda7-f5e6bf9efb33">
        <updating/>
        <source>trxArchiveEmptyLocation(_lc : CM_LocationsController input; _emptySince : TimeStamp;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
30/05/2019	jlgka1	TFS 44953	C3 - Archive Rows - Recent Rows being Archived.
								Add more audit logging information.
============================================================================*/
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	app.myPassport.useTITransactionDeferUpdate := true; // jlgka1 TFS 44958
	
	beginTransaction;

	app.myUtilityUA.utlArchiveEmptyLocation(_lc, _emptySince, _passport);
	
	// jlgka1 TFS 44958 --&gt;
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
	// jlgka1 TFS 44958 &lt;--

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_lc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_emptySince" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxArchiveVoyage" id="fe1dcaa3-d51a-497b-af56-123f16ec847b">
        <updating/>
        <source>trxArchiveVoyage(_voyage : CM_Voyage input; _controller : CMIF_ArchiveVoyage; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Archives a voyage
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

