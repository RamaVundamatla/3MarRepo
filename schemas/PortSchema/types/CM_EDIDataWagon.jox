    <JadeMethod name="verifyEDIDataTIs" id="eadc9043-bdfc-4a29-96d3-6194c1899205">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input) : Integer updating;

/*
Purpose:	To verify the EDI Data loaded.

Changes

Date		Name	TFS#		Description
============================================================================
28 Sep 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return passport.allErrorWarnings.size();
	endif;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException(UnknownUser, null, null);
		return passport.allErrorWarnings.size();
	endif;
	
	progressStr	:= app.getString(Verifying_Loaded_Details, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
		// now validate each ediTrackedItem
		self.zValidateEdiData(ediTI.CM_EDIWagonTI, terminal, passport);
	endforeach;
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	return passport.allErrorWarnings.size();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLoadDB" id="bed9ee95-3a2a-40b5-b925-d456a6820f7b">
        <updating/>
        <source>zLoadDB(_ediWagonTI : CM_EDIWagonTI input;
		_terminal : CM_Terminal input;
		_passport : CM_Passport input) updating;
	

/*
Purpose:	This method will do the required action for this EDI Wagon data.

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 4
jlier1 TFS 54366 12/10/22	
12 October 2023		jlizm1	TFS 60861 EDI Wagons not being displayed if wagon id doesn't match wagon class
*/
vars
	ediWagonTI			: CM_EDIWagonTI;
	realWagon			: CM_Wagon;
	prxyWagon			: CM_Wagon;
	foundWagon			: CM_Wagon;
	foundTrain			: CM_Train;
	wagonUpdateCtrl		: CMIF_WagonUpdateController;
	plannedRailLine 	: CM_RailLine;
	wagonMoveController : CMIF_WagonMoveController; 
	mode 				: Integer;
	wagonClass			: CM_WagonClass;
	
begin
	create wagonUpdateCtrl transient;
	ediWagonTI	:= _ediWagonTI;		// to reduce dereferencing set a local variable

	// only matching on train code here?
	foundTrain	:= self.getRealTrain(_terminal, ediWagonTI.trainCode, ediWagonTI.scheduledArrivalDT); //par 22668 cnwrs1 8 Feb 2010
	
	if foundTrain = null then
		app.raiseCMException2(	Delete_Train_Does_Not_Exists,
								ediWagonTI.trainCode,
								ediWagonTI.scheduledArrivalDT.cnEcShortFullFormat,//par 22668 cnwrs1 8 Feb 2010
								ETRow_TrainCode,
								null);
		return;
	endif;
	
	// the wagon needs to be unique for the train itself.
	foundWagon	:= self.getRealWagon(foundTrain, ediWagonTI.wagonNumber);
	
	if ediWagonTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		// delete the wagon.
		app.myUtilityDA.utlDeleteWagon(foundWagon, false, false, true, _passport);
		return;
	endif;
	
	// now an action of Add or Update are treated as if it is the "correct" one
	// ie we do not care what action the user entered we only care if the Wagon exists or not.
	if foundWagon = null then
		// does not exist create it
		
		wagonClass := null;
		if ediWagonTI.wagonClass &lt;&gt; null then
			wagonClass := app.myRoot.allWagonClasses[ediWagonTI.wagonClass];
		endif;
		
		create prxyWagon as app.getWagonVisitClassToCreate( wagonClass, ediWagonTI.myEDIData.ediConfig.myTerminal, ediWagonTI.wagonNumber, null ) transient;	//15 Mar 2013	NDL	Par 31278
		ediWagonTI.setWagonProxy(prxyWagon);
		
		if _passport.hasErrors() then
			return;
		endif;
		mode:= CMIF_WagonUpdateController.Mode_Add;
	else
		// else update it.
		prxyWagon	:= app.createUpdateProxy(foundWagon).CM_Wagon;
		ediWagonTI.setWagonProxy(prxyWagon);
		
		if _passport.hasErrors() then
			return;
		endif;
		mode:= CMIF_WagonUpdateController.Mode_Update;
	endif;
	
	wagonUpdateCtrl.setBasicDetails(mode,
									null,												// rake
									foundTrain,
									foundTrain.allWagonsByIdInward.size + 1,			// wagon position
									true);												// isTrainMode

	//27Feb2023 navsp1 TFS 56763
	//Add existing items to wagonPositions
	if foundWagon &lt;&gt; null then
		wagonUpdateCtrl.populateFromExistingWagonAddTi( foundWagon, null, 0 );
	endif;
	
	wagonUpdateCtrl.myProxyWagon			:= prxyWagon;
	if foundWagon &lt;&gt; null then
		wagonUpdateCtrl.expectedEditionWagon	:= foundWagon.edition;
		app.myUtilityUA.utlUpdateWagonFromCMIF(wagonUpdateCtrl, false, true, _passport);
	else
		app.myUtilityCA.utlCreateWagonFromCMIF(wagonUpdateCtrl, realWagon, false, true, _passport);
		foundWagon:=realWagon;
	endif;
	//13 Mar 2015	NDL	Par 35828
	if _passport.hasErrors() then
		return;
	elseif ediWagonTI.hasSealData then
		// need to take the data off the edi obj and set the seals on the wagon.
		ediWagonTI.doUpdateWagonSeals( foundWagon );
	endif;
		
	if _passport.hasErrors then
		return;
	endif;
	//jlier1 TFS 54366 12/10/22
	plannedRailLine:=_ediWagonTI.getPlannedRailLine;
	if plannedRailLine &lt;&gt; null then
		create wagonMoveController transient;
		wagonMoveController.setMoveMode(PLANNING_MODE);
		wagonMoveController.myTargetRailLine:=plannedRailLine;
		wagonMoveController.allWagons.add(foundWagon);
		wagonMoveController.setEffectiveTimeStampOverride(app.actualTimeServer);
		app.myUtilityUA.utlMoveWagons(wagonMoveController,_passport);
	endif;
		
		
epilog
	delete prxyWagon;
	delete wagonUpdateCtrl;
	delete wagonMoveController;
end;</source>
        <Parameter name="_ediWagonTI" type="CM_EDIWagonTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zValidateEdiData" id="9898509b-34e7-4a47-93c4-99345a44075d">
        <source>zValidateEdiData(
	_ediWagonTI	: CM_EDIWagonTI input;
	_terminal	: CM_Terminal input;
	_passport	: CM_Passport input ) protected;

/*
Purpose:	Do the required validation for the EDI Wagon data.
			This checks that certain required fields are filled in thoses that the CM_Wagon validation does not check.
			
			Note: This method assumes that the terminal has already been checked to see that it exists.

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/

	
vars
	action				: String;
	errorNumber			: Integer;
	foundTrain			: CM_Train;
	foundWagon			: CM_Wagon;
	prxyWagon			: CM_Wagon;
	ediWagonTI			: CM_EDIWagonTI;
	plannedRailLine 	: CM_RailLine;
begin
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	ediWagonTI	:= _ediWagonTI;				// to reduce dereferencing set a local variable
	errorNumber	:= _passport.allErrors.size();
	
	// check that the action is valid
	action	:=  ediWagonTI.messageMode;
	
	if action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_MessageMode, null);
		return;
	endif;
	
	// only matching on train code here?
	foundTrain	:= self.getRealTrain(_terminal, ediWagonTI.trainCode, ediWagonTI.scheduledArrivalDT); //par 22668 cnwrs1 8 Feb 2010
	
	if foundTrain = null then
		app.raiseCMException2(	Train_DoesNotExist_ForTerminal,
								ediWagonTI.trainCode,
								_terminal.code,
								ETRow_TrainCode,
								null);
		return;
	endif;
	
	// the wagon needs to be unique for the train itself.
	foundWagon	:= self.getRealWagon(foundTrain, ediWagonTI.wagonNumber);
	
	if action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if foundWagon = null then
			app.raiseCMException2(	Wagon_DoesNot_Exist_On_Train,
									ediWagonTI.wagonNumber,
									ediWagonTI.trainCode,
									ETRow_WagonNumber,
									null);
			return;
		endif;
		app.myValDA.valWagon(foundWagon, false);
		return;
	endif;
	
	//jlier1 TFS 54366 7/10/22
	if ediWagonTI.plannedLocn &lt;&gt; null then
		plannedRailLine:= ediWagonTI.getPlannedRailLine();
		if plannedRailLine = null  then
			app.raiseCMException1(ERR_INVALID_LOCN,_ediWagonTI.plannedLocn,ETRow_LocationID,null);
			return;
		endif;
	endif;
	
	// ediWagonTI.carrierCodeVerify;	// MES1008 setWagonProxy sets a ref so we need to validate here

	// now an action of Add or Update are treated as if it is the "correct" one
	// ie we do not care what action the user entered we only care if the Wagon exists or not.
	if foundWagon = null then
		//create prxyWagon as CM_Wagon transient;
		create prxyWagon as app.getWagonVisitClassToCreate( null, ediWagonTI.myEDIData.ediConfig.myTerminal, ediWagonTI.wagonNumber, null ) transient;	//15 Mar 2013	NDL	Par 31278
		
		ediWagonTI.setWagonProxy(prxyWagon);
		
		if _passport.allErrors.size() &gt; errorNumber then
			// have one or more new errors
			return;
		endif;
		
		app.myValCA.valWagon(prxyWagon);
		return;
	endif;
	
	prxyWagon	:= app.createUpdateProxy(foundWagon).CM_Wagon;
	ediWagonTI.setWagonProxy(prxyWagon);
	
	if _passport.allErrors.size() &gt; errorNumber then
		// have one or more new errors
		return;
	endif;
	
	app.myValUA.valWagon(prxyWagon);
epilog
	delete prxyWagon;
end;</source>
        <access>protected</access>
        <Parameter name="_ediWagonTI" type="CM_EDIWagonTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
