    <JadeMethod name="getButtonForNewXTABElement" id="df2e37ae-56c9-4b98-b0d0-76c3cd463f8a">
        <source>getButtonForNewXTABElement():Button protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	btn	:Button;
begin
	btn := self.allButtons_spare.first.Button;
	
	if btn &lt;&gt; null then
		self.allButtons_spare.remove (btn);
		return btn;
	endif;
	
	// nothing available so we need to create one - once we have created these we just keep re-using them
	btn := self.btnField.loadControl (self.getNextButtonIndex).Button;
	
	self.setButtonProperties (btn);
	
	return btn;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Button"/>
    </JadeMethod>
    <JadeMethod name="getDefaultFunctionForProperty" id="ff296ebf-1b5d-4210-80a1-299b9dbee098">
        <source>getDefaultFunctionForProperty(_property : CM_QueryProperty):Integer protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
