    <JadeMethod name="doMnuColourLegend" id="0f6a83ae-327a-40f2-ac4f-492c738e0d93">
        <source>doMnuColourLegend(menuItem: MenuItem input);
//--------------------------------------------------------------
//Created: 21 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
begin
	// Update the navigator
	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Job Unactioned",					Black,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Returned",						Red,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Part Complete",				Black,				White,				"picJobPartComp", false);
	colLegend.addLegendItem("Job Complete",						Black,				White,				"picJobComp", false);
	colLegend.addLegendItem("Unactioned Receipt Job",			CM_Job.Colour_ReceiptUnactioned,				White,				null, false);
	colLegend.addLegendItem("Unactioned Release Job",			CM_Job.Colour_ReleaseUnactioned,				White,				null, false);
	colLegend.addLegendItem("Partially Worked Receipt Job",		CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem("Partially Worked Release Job",		CM_Job.Colour_ReleasePartComplete,			White,				null, false);
	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Job is Overstowed",				White,				Red,				null, true);	
	colLegend.addLegendItem("Matched up to a TBA Contaner",		Black,				 LightGreen,		null, false);
	colLegend.addLegendItem("Returned Job",						Black,				Red,				null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowDark,	null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowLight,	null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations",	Black,				CM_VoyageJob.Colour_JobLoaded, null, false);
	colLegend.addLegendItem("Voyage Job Not Loaded to Operations", Black,			CM_VoyageJob.Colour_JobNotLoaded, null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow1,		null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow2,		null, false);
	//par13201 Mohammad 25/1/2006
	colLegend.addLegendItem("Unactioned Receipt Twin Lift Job", Black,	LightSkyBlue,		null, false);
	colLegend.addLegendItem("Unactioned Release Twin Lift Job", Black,	LightOrange,		null, false);
	colLegend.addLegendItem("Other",							White,				Mauve,				null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuEditTransferType" id="abe982af-e7a9-4dd6-9445-fe2603deaa33">
        <source>doMnuEditTransferType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
*/

vars

	
begin
	if self.myCurrentJob = null then
		return;
	endif;
	self.doCmbTransferTypeBuild();
	self.frmTransferType.visible:=true;
	self.frmTransferType.centreWindow();
	self.frmTransferType.zOrder(1);	
	self.lblJobValue.caption := self.myCurrentJob.id;
	
	self.cmbTransferType.listIndex := self.cmbTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[self.myCurrentJob.transferType]);	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuLoadLanes" id="bc9d7416-20f9-4d0e-855e-4e7896ddb84e">
        <updating/>
        <source>doMnuLoadLanes(menuItem : MenuItem input) updating, protected;
//--------------------------------------------------
// Created:	15 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	voyageWLE	: CM_VoyageWLE;
	theProxyJob : CM_VoyageJob;
	loadLane 	: CM_BlockController;
	theReturn 	: Integer;
	ls			: Boolean;
	wleArray 	: CM_WLEArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if menuItem = self.mnuLoadLane then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	loadLane := menuItem.userObject.CM_BlockController;	
	
	theReturn := app.msgBox(app.getErrorString(StartFromFirst), "Load Lanes",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_Yes then
		//voyageWLE := self.myCurrentTableWLE.accessRow(myCurrentTableWLE.fixedRows + 1).itemObject.CM_VoyageWLE;
		create wleArray transient;
		self.getAllWLEsInCurrentTbl(wleArray);
		voyageWLE := wleArray.first.CM_VoyageWLE;
	else
		voyageWLE := self.myCurrentWLE;
	endif;
	
	if voyageWLE &lt;&gt; null then
		app.cmsBeginLoad(ls);
		theProxyJob := voyageWLE.job.pxyCreateUpdateProxy().CM_VoyageJob;
		app.cmsEndLoad(ls);		
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageJobLoadLanes(theProxyJob, loadLane, voyageWLE, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Job Operations', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	delete theProxyJob;
	delete wleArray;
	app.cmsEndLoad(ls);			
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRecClick" id="57f2aedc-5d49-4d85-8b86-e797882c0d5a">
        <updating/>
        <source>doMnuRecClick(_sealCheck : Integer)  updating;
//27 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 30 Apr 2012	cnwer1		PAR 29487 - doing the CM_Voyage setForUpdate here was purging the voyage cut-offs because they hadn't been proxied
vars
	voyage : CM_Voyage;
	result : Integer;
begin
	voyage := self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateVoyageSealCheckRec(voyage,_sealCheck,app.myPassport); 
		if app.myPassport.trxCompletedOK then
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
	endwhile;

epilog
	
	
end;</source>
        <Parameter name="_sealCheck" type="Integer"/>
    </JadeMethod>
