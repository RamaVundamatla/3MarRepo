    <JadeMethod name="getTIs" id="f3c04537-6def-4cb0-89ab-371cedf9310e">
        <source>getTIs(tis: CM_TIArray input; _mode: Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2011	cnwrd1	Initial creation

*/

vars
	lc : CM_GridController;
	ti : CM_TrackedItem;
begin
	inheritMethod(tis, _mode);
	foreach lc in self.allControllersByRow do
		if lc.numTIs &gt; 0 then
			foreach ti in lc.allTrackedItems do
				if not tis.includes(ti) then	//40' are in 2 positions
					tis.add(ti);
				endif;
			endforeach;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasReeferWalkPaths" id="6931bd26-1f06-4969-b17d-3a8afb2ef201">
        <source>hasReeferWalkPaths( _firstPathFound : CM_ReeferBlock output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2021	navndl1	Initial creation	TFS 51042

*/

vars

	ta : CM_TerminalArea;
	iter : Iterator;
	reeferBlock : CM_ReeferBlock;
	iter2 : Iterator;
	reeferBlockPosition : CM_ReeferBlockPosition;
	lc : CM_GridController;

begin

	ta := self.myGridArea;
	iter := ta.allReeferBlocks.createIterator;
	while iter.next( reeferBlock ) do
		iter2 := reeferBlock.allReeferPositions.createIterator;
		while iter2.next( reeferBlockPosition ) do
			lc := reeferBlockPosition.myLocationController.CM_GridController;
			if self.allControllersByRow.includes( lc ) then
				_firstPathFound := reeferBlock;
				return true;
			endif;
		endwhile;
		delete iter2;
	endwhile;
	
	return false;

epilog

	delete iter;
	delete iter2;

end;</source>
        <Parameter name="_firstPathFound" type="CM_ReeferBlock" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="cd5e4818-d25e-4c48-a1fd-e6c1e7754713">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:	N4 SECTION		

Date		Who		Reason
08 February 2022	navab1	TFS 51854
*/

vars
	opsviewtable : CMIF_SpatialBins;

begin
	opsviewtable := _opsViewTable.CMIF_SpatialBins;
	
	opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
		
	opsviewtable.bin_level := opsviewtable.SpatialBinLevel_3; // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.bin_subclass := "YSN";
	opsviewtable.block_type_enum := ""; // not set at this level
	opsviewtable.internal_pos_name := self.myGridArea.getNiceName() &amp;" "&amp; self.label; // ### TFS 51854 08FEB2022 NAVAB1 //TFS#53369 21APR2022 NVSP1
	opsviewtable.label_scheme_full_position := self.getFullLabel(); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.life_cycle_state := opsviewtable.n4LifeCycleState(self); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.parent_bin_gkey := opsviewtable.generateFullGKey(self.myGridArea,""); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.yard_gkey := 0;  // ### TFS 53369 28APR2022 NAVAB1 only for the terminal - bin_level 1 //  opsviewtable.generateFullGKey(self.myGridArea.myTerminal, ""); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.z_index_last := 0; // not set at this level
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isGap" id="149614a9-305e-4cdd-9bce-5ff625864d53">
        <source>isGap() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMaxWidth		: Real;
	tmpGridController : CM_GridController;
begin

	foreach tmpGridController in self.allControllersByRow do
		if not tmpGridController.isKindOf(CM_GapController) then
		//if (not CM_GapController.hasInstance(tmpGridController)) then
			return false;
		endif;
	endforeach;

	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInUse" id="87040c12-d7f7-4b87-a23c-86167ae2948a">
        <source>isInUse(): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aGridController : CM_GridController;
begin

	foreach aGridController in self.allControllersByRow do
		if aGridController.hasTIs() then
			return true;
		elseif aGridController.hasRestrictions(LOCATION_RESTRICTION) then
			return true;
		elseif aGridController.hasRestrictions(LABOUR_RESTRICTION) then
			return true;
		elseif aGridController.mySubBlockStack &lt;&gt; null then
			return true;
		endif;
	endforeach;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInUseForInsert" id="1496ff4a-6910-4d07-92a5-f6afc7e2f94f">
        <source>isInUseForInsert(): Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2006 By Andrew Bishop cnwab1
//
// Purpose:		We insert columns before us, so need to check for 40 backend on us.
//
// ---------------------------------------------------------------------------
vars
	aGridController : CM_GridController;
begin

	foreach aGridController in self.allControllersByRow do
		// check for 40 backends on us.
		if aGridController.hasTIsOfMode40(REAL_MODE,false) then
			return true;
		endif;
	endforeach;

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isZeroWidth" id="4f8f6322-387d-44b4-821e-5dc32d6dbae7">
        <source>isZeroWidth() : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMaxWidth		: Real;
	tmpGridController : CM_GridController;
begin

	foreach tmpGridController in self.allControllersByRow do
		if (not CM_GapController.hasInstance(tmpGridController)) then
			tmpMaxWidth := 1;
			break;
		else
			tmpMaxWidth := tmpMaxWidth.max(tmpGridController.width);
		endif;
	endforeach;

	return (tmpMaxWidth = 0);
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
