    <JadeMethod name="moveEvent" id="083bac35-1bb2-4062-91fa-ed2a5dffa27b">
        <updating/>
        <source>moveEvent(_moveController : CMIF_MoveController)updating;
//--------------------------------------------------------------
//Created: 20 May 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
// 14/11/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
// 28/01/2025	navpw1		JIRA: MTN-33663 - Added move controller parameter to method &amp; added code to set the quantity from the move controller as that is what we have moved plus refactored code
//--------------------------------------------------------------
vars
	oldJobStatus	: Integer;
	linkedWLE		: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	ct				: CM_CargoType;
	wowle			: CM_WOWLE;				// ### JIRA: MTN-33663 28Jan2025 NAVPW1
	
begin
	if self.job = null then // AKB2003DEC added voyage wles may not have a job
		return;
	endif;
	
	oldJobStatus := self.job.status;

	linkedWLE := self.getLinkedWLE();	//other wle to rebuildStatus on

	if self.job.workListEntries.size = 1 then
		// Job only has self to do, let the job do the work.
		self.job.rebuildStatus();
	else
		self.rebuildStatus();
		if linkedWLE &lt;&gt; null then
			linkedWLE.rebuildStatus();
		endif;
		self.job.updateStatus();
	endif;

	if oldJobStatus &lt;&gt; self.job.status then
		self.job.causeTerminalEvent(self.job.Event_Mode_Update);
	endif;
	
	ti := self.myTrackedItem;
	
	// TFS 54118
	if self.status = WLE_COMPLETED and self.isAnyAmount and ti &lt;&gt; null then
		ct := ti.myCargoType;
		if ct &lt;&gt; null and ct.isBulkMulti then
			self.setWeight(ti.totalWeight);
		else
			//self.setQuantity(ti.totalQuantity.max(1));
			// ### JIRA: MTN-33663 28Jan2025 NAVPW1
			//Wle should always be set to the amount that has been moved. Not the tracked item total.
			//This used to break if the tracked item was partially loaded twice
			self.setQuantity(_moveController.quantity);
			wowle := self.myWorkOrderWLE;
			//Wowle quantity can be based off the tracked item during a setStatus(WLE_COMPLETED) when self.rebuildStatus(); called before this part of the method that sets the quantity
			if wowle &lt;&gt; null and wowle.quantity &lt;&gt; _moveController.quantity then
				wowle.setQuantity(_moveController.quantity);
			endif;
			// ### JIRA: MTN-33663 28Jan2025 NAVPW1
		endif;
	endif;

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="moveToNewRequest" id="838f4c3c-e770-464e-b0fb-fe720b004a76">
        <updating/>
        <source>moveToNewRequest( _request : CM_Request) updating;

/*

Purpose:	For shifting a voyage WLE to a new request as part of the voyage dynamic allocation loading 1303

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2012	cnwrd1	Initial creation

*/

vars
	anEntry : CM_RTQueueEntry;
begin

	self.updateRequest(_request);	
	self.job := _request.myJob;
	foreach anEntry in self.allRTQueueEntries do
		anEntry.switchJob(_request.myJob);
	endforeach;
epilog

end;</source>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="origBulkReleaseIsPacking" id="9d47fdbe-d04c-4197-866c-e3204a37c336">
        <source>origBulkReleaseIsPacking() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwpjs1	Initial creation  PAR #31294

*/

vars

begin

	if myRequest = null then
		return false;
	endif;
	
	return myRequest.origBulkReleaseIsPacking;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bac1896e-abad-4c9d-81cf-66ffab2e0f7c">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 17 January 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyWle	: SelfType;
	completedOK		: Boolean;
begin
	pxyWle := inheritMethod();
	pxyWle.setMyTrackedItem(self.myTrackedItem);
	pxyWle.myBOL		:= self.myBOL;
	pxyWle.myRequest	:= self.myRequest;
	pxyWle.job			:= self.job;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyWle;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyWle;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queue" id="32ef1c18-6909-4c7c-8a89-37b83c766715">
        <methodInvocation>mapping</methodInvocation>
        <source>queue(set: Boolean; value: CM_RadioTelemetryQueue io) mapping;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.allRTQueueEntries.isEmpty then
		return;
	endif;
	value := self.allRTQueueEntries.first.myQueue;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="CM_RadioTelemetryQueue" usage="io"/>
    </JadeMethod>
    <JadeMethod name="queueId" id="2219f0f4-c1ec-4815-b74b-ea02469191ef">
        <methodInvocation>mapping</methodInvocation>
        <source>queueId(set: Boolean; value: String io) mapping;
vars
	que : CM_RadioTelemetryQueue;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	que := self.queue;	//Virtual, store value eslse is recalcd below.
	if que = null then
		return;
	endif;
	value := que.id.trimBlanks;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="rebuildStatus" id="c62ba3bc-769a-4acc-ad62-c98d67bc3b2b">
        <updating/>
        <source>rebuildStatus() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 Feb 2011	cnwer1	PAR#25573 - changes for multi machine move completing

*/
vars
	status : Integer;
begin

	if self.isCompleteForJob() then
		status:=WLE_COMPLETED;
		
 // ### TFS 51855 27JAN2022 NAVAB1		if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 51855 24JAN2022 NAVAB1
 // ### TFS 51855 27JAN2022 NAVAB1			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, self); // ### TFS 51855 24JAN2022 NAVAB1
 // ### TFS 51855 27JAN2022 NAVAB1		endif;

	else
		status:=self.getStatusBasedOnRTTasks();
	endif;
	
	self.setStatus(status);

end;</source>
    </JadeMethod>
    <JadeMethod name="removeFromAlerts" id="ae9efdb8-93b6-42ea-b3e0-5ea84a718dfe">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::removeFromAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>removeFromAlerts(alert: CM_SystemAlert) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal : CM_Terminal;
begin
	if not self.alerts.includes(alert) then
		return;
	endif;
	alerts.remove(alert);

	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null and not alert.reviewed then
		//terminal.causeEvent(alert.mySystemAlertType.type,true,alert);			//- cnwmd1, CCMS 1871
		app.causeEventForSystemAlertType(alert, terminal); 					//+ cnwmd1 CCMS 1871
	endif;


epilog

end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
