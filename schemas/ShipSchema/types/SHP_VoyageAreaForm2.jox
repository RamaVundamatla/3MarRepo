    <JadeMethod name="initCmbCrane" id="e2879a4f-64a9-4ba2-949e-a8d7c62f0055">
        <source>initCmbCrane() protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyageJS : CM_VoyageJobSheet;
	aCrane : CM_Machine;
begin
	
	self.cmbCrane.clear;
	self.cmbCraneJS.clear;
	
	self.cmbCrane.sorted := true;
	self.cmbCraneJS.sorted := true;
	
//	self.cmbCrane.bubbleHelp := "Select a Crane...";
	self.cmbCrane.addItem("Unallocated Jobs");
	self.cmbCraneJS.addItem("");
	
	// DVB changed 06/09/04
	foreach aCrane in self.myTerminal.machines 
	where (aCrane.available and not aCrane.isNotAvailableForEntry) do
		if aCrane.machineType = MACHINETYPE_PORTAINER_CRANE then 
			idx := self.cmbCrane.addItem(aCrane.id &amp; " - " &amp; aCrane.description);
			self.cmbCrane.itemObject[idx] := aCrane;
			
			//for jobseed updater
			idx := self.cmbCraneJS.addItem(aCrane.id &amp; " - " &amp; aCrane.description);
			self.cmbCraneJS.itemObject[idx] := aCrane;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initCmbSeqAppliesTo" id="37df7b81-498c-4ef9-9ac5-e8af85c992bb">
        <source>initCmbSeqAppliesTo() protected;
// ---------------------------------------------------------------------------
// Created:     25 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCombo	: CMUI_ComboBox;
	
begin
	tmpCombo := self.cmbSeqAppliesTo;
	tmpCombo.addItemWithData($SeqAppliesTo_Job, self.SeqAppliesTo_Job);
	tmpCombo.addItemWithData($SeqAppliesTo_Selected_Slots, self.SeqAppliesTo_SelectedSlots);
	tmpCombo.addItemWithData($SeqAppliesTo_Individual_Slot, self.SeqAppliesTo_IndividualSlots);
	tmpCombo.listIndex := 1;
	
	tmpCombo := self.cmbSeqBoth;
	tmpCombo.addItemWithData('Current Lift Mode', 0);
	tmpCombo.addItemWithData('Single And Twin Lift Modes', 1);
	tmpCombo.listIndex := 2;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFrmAutoDischCC" id="e67e0523-3f99-4d38-8384-76b08cf4c0a3">
        <source>initFrmAutoDischCC();
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//centre, enable object etc.
	self.frmAutoDischCC.centreWindow();
	
	self.chkImportTasks.value 	:= false;
	self.chkCustomsEDI.value 	:= false;
			
	if app.myPassport.myUser.canDo(self.myTerminal, PmShipRunImportTasks) then
		self.chkImportTasks.enabled := true;
		
		if self.myCurrentVoyage &lt;&gt; null and self.myTerminal.getConfig(ShipImportTaskOptions).Boolean then
			self.chkImportTasks.value := self.myCurrentVoyage.importTasksLastRunDT.isValid;
		endif;
	endif;
	
	if app.myPassport.myUser.canDo(self.myTerminal, PmShipProcessEDI) then
		self.chkCustomsEDI.enabled := true;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFrmGlobalMode" id="64976ed2-4700-49b5-bb89-8db30f436416">
        <updating/>
        <source>initFrmGlobalMode(_otherVoyage: CM_Voyage) updating;
//----------------------------------------------------------------
//	Created:	02 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin

	self.myCurrentVoyageInterTerm := _otherVoyage;
	self.myBayDrawingController.setVoyageInterTerminal(_otherVoyage);
	
	if self.myCurrentVoyageInterTerm = null then
		return;
	endif;
	
	self.lblGlobalView.caption := self.myCurrentVoyageInterTerm.myTerminal.name &amp; " " &amp; self.myCurrentVoyageInterTerm.code;
	self.frmVoyGlobalMode.zOrder(1);
	
	if not self.frmVoyGlobalMode.visible then
		self.frmVoyGlobalMode.visible := true;
		self.frmVoyGlobalMode.centreWindow();
	endif;
end;</source>
        <Parameter name="_otherVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="initModalFrame" id="c2a2e683-6979-450e-8c8b-1c25b3371cde">
        <source>initModalFrame();

vars

begin
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.top := 100;
	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 400;
	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.lblModalMessage.move(0,10,self.frmModalDialog.width,40);
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.move(0,55,self.frmModalDialog.width,20);
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.visible := false;
	self.frmModalDialog.visible := true;
	self.frmModalDialog.backColor := self.backColor;
end;</source>
