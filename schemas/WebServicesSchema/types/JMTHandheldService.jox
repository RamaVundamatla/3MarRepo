<Class name="JMTHandheldService" id="b9c97974-ba8a-4383-888a-2583fbd5ba54">
    <superclass name="WS_RestWebServiceProvider"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>DEPRECATED in 20.0.21.
"Internal" methods used by OUR applications should go under MTNInternalAPIService</text>
    <DbClassMap file="webservice"/>
    <JadeMethod name="deleteCargoQueuedMove" id="290218fa-5d78-4ab9-91b6-64f4f0a5f3cb">
        <updating/>
        <source>deleteCargoQueuedMove(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	moveAgent 		: CMIF_MobileGenericAgent;
	location 		: String;
	dummyHeight 	: Integer;
	failedDAC  		: CM_DataAccessController;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " passport has errors", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmWebCargoDelQueuedMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	// Get the parameters
	location := request.location;
	
	
	
	
	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
	
	if targetLocation = null or  not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	create moveAgent transient;	
	moveAgent.doUnqueueTI(cargo, targetLocation);
	
	return response;
epilog
	delete moveAgent;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="deleteTasksOnCargo" id="c102252e-b38b-4f84-9587-032c71a1d117">
        <updating/>
        <source>deleteTasksOnCargo( request : WS_CargoTaskDescRequest ; cargoOid : String ) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
30 Oct 2019 cnwma1	Bug 47285: PNL - API Remove Tasks records the To Do Completed transaction
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
*/

vars
	response 	 		: WS_Response;
	cargo		 		: CM_TrackedItem;
	wsTask       		: WS_CargoTask;
	toDoTaskDesc 		: CM_ToDoTaskDesc;
	terminal     		: CM_Terminal;
	user		 		: CM_User;
	allTasks	 		: WS_CargoTaskArray;
	cmifToDoTask        : CMIF_TiToDoTasks;
	cmifToDoTaskArray   : CMIF_TiToDoTasksArray;
	infoMessage			: WS_InfoMessage;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
		
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	
	user 		:= app.myPassport.myUser;
	terminal	:= app.myPassport.myTerminal;
	allTasks 	:= request.allTasks;
	
	create cmifToDoTaskArray transient;
	
	foreach wsTask in allTasks do 
		
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[wsTask.code];
		
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, wsTask.code.String, null, null);
			return response;
		endif;
			
		if not cargo.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
			create infoMessage transient;	
			infoMessage.text :=app.getErrorString1(ERR_NO_TODO_TASK,toDoTaskDesc.description);
			response.allInfo.add(infoMessage);
		endif;
			

		create cmifToDoTask transient;
		cmifToDoTask.myToDoTaskDesc := toDoTaskDesc;

		cmifToDoTaskArray.add(cmifToDoTask);

		
	endforeach;
	
	
	if not cmifToDoTaskArray.isEmpty then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxDA.trxDeleteToDoTasks(cargo,cmifToDoTaskArray,app.myPassport);
	endif;
	
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoTaskDescRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getCargoAvailableForPicking" id="e2652f87-5da8-450d-884c-fb4f428a633f">
        <updating/>
        <source>getCargoAvailableForPicking(reserveDetailOid :String ): WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 - Order Picking app

*/

vars
	response : WS_CargoSummaryResponse;
	realResDet 		 : CM_ReserveDetail;
	tiSet 	: CM_TISet;
	ti : CM_TrackedItem;
	firstStagedLC , lc: CM_LocationsController;
	failedDAC  		 : CM_DataAccessController ;
	wsCargo 		 : WS_CargoSummary;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if realResDet = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	
	create tiSet transient;
	realResDet.getStagingLocationSummary(tiSet,firstStagedLC);
	
	foreach ti in tiSet discreteLock do
		lc := ti.myPrimaryActualLocation;
		if lc = null or lc.isMachineController then
			continue;
		endif;
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
	
		response.allCargoSummaries.add(wsCargo);
					
	endforeach;
	
	return response;
	
epilog
	delete tiSet;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoById" id="02b94048-81b4-4bd2-ad1d-85b57e134a75">
        <updating/>
        <source>getCargoById(cargoId : String ; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
*/

vars
	response 	: WS_CargoSummaryResponse;
	wsCargo 	: WS_CargoSummary;
	failedDAC	: CM_DataAccessController ;
	cargoID     : String;
	cargoTypeID : Integer;
	terminal 	: CM_Terminal;
	cargoType	: CM_CargoType;
	allTIs		: CM_TISet;
	ti			: CM_TrackedItem;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	cargoTypeID := parseParameterList(optionalParam, 1, Integer).Integer;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoId.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	if cargoTypeID &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[cargoTypeID.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, cargoTypeID.String, null, null);
			return response;
		endif;
	endif;
	//epr TFS 46632 23/9/19 
	cargoID:=cargoId.trimBlanks.asStringRESTFUL;
	
	create allTIs transient;
	terminal.lookupAllTIsOfIdCargoType(cargoID,cargoTypeID,allTIs,false,false,null);
	
	foreach ti in allTIs discreteLock do
		
		if ti.id.toUpper &lt;&gt; cargoID.toUpper then
			continue;
		endif;
		
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;

	return response;
epilog
	delete allTIs;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoForCargoGroupAssign" id="ba67f18b-5251-4113-babd-2a6d1d007ed4">
        <updating/>
        <source>getCargoForCargoGroupAssign(cargoId : String; groupAssignOid : String;optionalParam : ParamListType) : WS_CargoForGroupAssignResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2021	jlier1	Initial creation 51683

*/

vars

	response : WS_CargoForGroupAssignResponse;
	terminal : CM_Terminal;
	cmifID			: CMIF_IDConversion;	
	altId	,convertedID, cgOid		: String;
	cga : CM_CargoGroupAssignment;
	cg 	: CM_CargoGroup;
	ti : CM_TrackedItem;
	obj : Object;
	cargoIdLength,altIdLength : Integer;	
	wsCargoSummary : WS_CargoSummary;
	info 	: String;
	desc1, desc2 : String;
	pos : Integer;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoId.trimBlanks = "" then
	//need to change to appriopriate error
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	cga:=app.myPassport.getObjectOfTypeFromOid(groupAssignOid,CM_CargoGroupAssignment).CM_CargoGroupAssignment;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	cgOid := parseParameterList(optionalParam, 1, String).String;
	if cgOid &lt;&gt; null then
		cg:=app.myPassport.getObjectOfTypeFromOid(cgOid,CM_CargoGroup).CM_CargoGroup;
	endif;
	

	create cmifID transient;
	cmifID.scannedValue :=  cargoId.asStringRESTFUL.toUpper();
	cmifID.myTerminal := terminal;
	convertedID:=app.convertScannedCargoId( null, null, false, cmifID );
	if convertedID = null then
		convertedID:=cargoId;
	endif;
	altId := app.convertScannedCargoId( null, null, true, cmifID );
	

	cargoIdLength := convertedID.length;
	
	ti:=terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( convertedID, null );
	if ti &lt;&gt; null and ti.id[1:cargoIdLength] &lt;&gt; convertedID then	
		ti := null;
	endif;
	altIdLength := altId.length;
	if ti = null and altIdLength &gt; 0 then
		ti := terminal.allOnsiteTIsByAlternativeId.getAtKeyGeq(altId);
		if ti &lt;&gt; null and ti.alternativeId[1:altIdLength] &lt;&gt; altId then	
			ti := null;
		endif;
	endif;
	
	if ti = null then
		 app.raiseCMException1( Cargo_item_not_found_site, convertedID,null,null );
		 return response;
	endif;
	
	obj := cga.getAssignedObject( ti.id );
	if obj = null then
		//new exception Cargo %1 not part of Cargo Group Assignment
		app.raiseCMException1(Cargo_not_cargo_group_assign,convertedID, null, null);
		return response;
	endif;
	
	
	if ti &lt;&gt; null and cga &lt;&gt; null and  ti.myCargoGroup &lt;&gt; null and   cga.allProcessedTis.includes(ti) then
		info:= app.getErrorString2( Cargo_item_already_assigne, ti.id, ti.myCargoGroup.id);
	endif;
	
	if cg = null then
		obj   :=cga.getAssignedObject( ti.id );
		if obj &lt;&gt; null and obj.isKindOf(CM_CargoGroup) then
			cg:=obj.CM_CargoGroup;
		endif;
		if cg = null and info = null then
			info:= app.getErrorString( Must_select_notifi_cargo_group);
		endif;
	endif;
	
	
	
	create wsCargoSummary transient;
	wsCargoSummary.setProxyFromObject(ti);
	response.myCargo:=wsCargoSummary;
	//jlier1 24/9/21 from functional review
	ti.getShortDescriptions(desc1,desc2);
	if desc1 &lt;&gt; null   then
		pos:=desc1.pos("(",1);
		if pos &gt; 0 then
			desc1:=desc1[1:pos-1];
		endif;
		wsCargoSummary.productDescription:=desc1;
	endif;
	
	if cg = null then
		cg:= ti.myCargoGroup;
	endif;
	
	if  info = null and  ti.myCargoGroup &lt;&gt; null then 
		info:= app.getErrorString2( Cargo_item_already_assigne, ti.id, ti.myCargoGroup.id);
	endif;
	
	if cg &lt;&gt; null  then		
		response.selectedCargoGroupOid:=obj.getOidAsString;
	endif;
	
	return response;
epilog
	response.addInfo(info);
	self.finaliseResponse(response);


end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="groupAssignOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoForGroupAssignResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoForRelease" id="e60ca942-4327-4b51-a7a1-c2d0a5c873eb">
        <updating/>
        <source>getCargoForRelease(releaseOid :String ; reserveDetailOid : String; sourceAreaId : String; ordering : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
15/08/2019	jlgka1	45924		JMT - Pack by Request - Webservice. 
								BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
								and use a Dictionary instead of TIArray.
21/08/2019	jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list	
30/08/2019	jlger1	45291       Fixed searching with a starting index 
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

constants
	All_STR = "-1";
vars
	limit 			 : Integer ;
	index 			 : Integer ;
	realRelease		 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 			 : CM_TrackedItem;
	count 			 : Integer;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoSummaryResponse ;
	tiDD 			 : DynaDictionary;					// jlgka1 TFS 45924 --&gt;
	realArea 		 : CM_TerminalArea;
	failedDAC  		 : CM_DataAccessController ;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	limit 			:= parseParameterList(optionalParam, 1, Integer).Integer;
	index 			:= parseParameterList(optionalParam, 2, Integer).Integer;

	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	app.writeLog("param list ="   &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceAreaId &amp; ",/" &amp; ordering&amp; ",/" &amp; limit.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	if sourceAreaId &lt;&gt; All_STR then
		realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(sourceAreaId);
				
		if realArea &lt;&gt; null then
			if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),sourceAreaId, null,null);
				return response;
			endif;
				
		endif;
	endif;
	// jlgka1 TFS 45924 --&gt;	
	create tiDD  transient; 
	tiDD.setMembership(CM_TrackedItem);
	
	if ordering = "FIFO" then
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	else
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	endif;
	tiDD.endKeys(true);
	
	realRelease.getProspectiveCargo(realResDet, realArea, null,null, tiDD, ordering &lt;&gt; "FIFO", limit, index, count);	// MTN-34024
	
	// jlgka1 TFS 45924 &lt;--
	
	iter := tiDD.createIterator;	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
	
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;
	
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
				
	endwhile;
		
	return response;

epilog
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="reserveDetailOid" type="String"/>
        <Parameter name="sourceAreaId" type="String"/>
        <Parameter name="ordering" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupAssignById" id="f6ffbc51-4dd1-4f8e-9b61-d4c028204139">
        <updating/>
        <source>getCargoGroupAssignById(groupAssignId : String) : WS_CargoGroupAssignResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2021	jlier1	Initial creation 51683

*/

vars
	response 	: WS_CargoGroupAssignResponse;
	terminal 	: CM_Terminal;
	cargoGroupAssign : CM_CargoGroupAssignment;
	wsCargoGroupAssign : WS_CargoGroupAssign;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	terminal := app.myPassport.myTerminal;
	
	if groupAssignId.trimBlanks = "" then
	//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	cargoGroupAssign:= terminal.findCargoGroupAssignment( groupAssignId.asStringRESTFUL.trimBlanks );	
	
	if cargoGroupAssign = null then
		//need to change to appriopriate error
		app.raiseCMException1(Not_find_cargo_group_assig_wit,groupAssignId.asStringRESTFUL.trimBlanks , null, null);
		return response;
	endif;
	
	if cargoGroupAssign &lt;&gt; null then
		create wsCargoGroupAssign transient;
		wsCargoGroupAssign.setProxyFromObject(cargoGroupAssign);	
		response.myCargoGroupAssign:= wsCargoGroupAssign;
	endif;
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupAssignId" type="String"/>
        <ReturnType type="WS_CargoGroupAssignResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupById" id="abb360da-f898-4d43-8c7b-bb5cb1657f29">
        <updating/>
        <source>getCargoGroupById(groupId : String; optionalParam : ParamListType) : WS_CargoGroupResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2021	jlier1	Initial creation 51684
*/

vars
	response 	: WS_CargoGroupResponse;
	terminal 	: CM_Terminal;
	cargoGroup : CM_CargoGroup;
	wsCargoGroup : WS_CargoGroup;
	locationOid : String;
	location	: CM_LocationsController;
	lcs : CM_LCSet;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if groupId.trimBlanks = "" then
		app.raiseCMException(Cargo_group_required, null, null);
		return response;
	endif;
	cargoGroup:= terminal.getCargoGroupItem( groupId.asStringRESTFUL );
	if cargoGroup = null then
		app.raiseCMException1(Cargo_group_not_found,groupId.asStringRESTFUL, null, null);
		return response;
	endif;
	
	// Get the optional parameters
	locationOid := parseParameterList(optionalParam, 1, String).String;
	if locationOid.trimBlanks &lt;&gt; "" then
		location:=app.myPassport.getObjectOfTypeFromOid(locationOid,CM_LocationsController).CM_LocationsController;
	endif;
		 
	if cargoGroup &lt;&gt; null then
		if location &lt;&gt; null then
			//check location part of cargo group
			create lcs transient;
			cargoGroup.getAllLocations( lcs );
			if not lcs.includes( location ) then
				 app.raiseCMException2(Does_not_inclu_cargo_that_curr,cargoGroup.id,location.getFullId,null,null);
				 return response;
			endif;
		endif;
	
		create wsCargoGroup transient;
		wsCargoGroup.setProxyFromObject(cargoGroup);
		response.myCargoGroup:= wsCargoGroup;
	endif;
	
	return response;
epilog
	delete lcs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoGroupResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoInArea" id="92317d39-edc6-4bb6-bb48-56ed3210ff7c">
        <updating/>
        <source>getCargoInArea(areaID : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	jlgrr1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
*/

vars
	limit : Integer;
	index : Integer;
	iter : Iterator;
	cargo : CM_TrackedItem;
	count : Integer;
	rsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	realArea : CM_TerminalArea;
	tiDD : DynaDictionary;
	cargoItems : ObjectSet;
	failedDAC  :CM_DataAccessController ;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the optional parameters
	limit := parseParameterList(optionalParam, 1, Integer).Integer;
	index := parseParameterList(optionalParam, 2, Integer).Integer;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	

	// ======================
	// Actually get the cargo
	
	create cargoItems transient;
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name, false,false);
	tiDD.endKeys(false);
	
	if areaID.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	
	realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(areaID);
	
	
	if realArea = null then
		app.raiseCMException1(Location_invalid,areaID, null,null);
		return response;
	endif;	
	
	
	if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),areaID, null,null);
		return response;
	endif;
	
		
	realArea.getAllLocationsTrackedItems(cargoItems);
	cargoItems.copy(tiDD);
	iter := tiDD.createIterator;	
		
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog
	delete cargoItems;
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="areaID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoInLocation" id="9a6afbc7-5bc1-4c4f-a990-b63f622971a7">
        <updating/>
        <source>getCargoInLocation(locationId : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2021	jlier1	Initial creation TFS  51684

*/

vars
	iter : Iterator;
	cargo : CM_TrackedItem;
	rsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	failedDAC  :CM_DataAccessController ;
	terminal : CM_Terminal;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	tiArray : CM_TIArray;
	cargoGroup : CM_CargoGroup;
	cargoGroupOid : String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// ======================
	// Actually get the cargo
		
	if locationId.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	terminal.findLocationFromString(locationId.asStringRESTFUL ,true,foundLC,foundHeight);
	
	if foundLC = null then
		app.raiseCMException1(Location_NotFound,locationId.asStringRESTFUL,null,null);
		return response;
	endif;	
	
	// Get the optional parameters
	cargoGroupOid:=parseParameterList(optionalParam, 1, String).String;
	if cargoGroupOid &lt;&gt; null then
		cargoGroup:=app.myPassport.getObjectOfTypeFromOid(cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
	endif;
	
	create tiArray transient;
	foundLC.getTIs(tiArray, REAL_MODE, true);
	
	iter := tiArray.createIterator;	
		
	while iter.next(cargo)   do
		if cargoGroup &lt;&gt; null then
			if cargo.myCargoGroup &lt;&gt; cargoGroup then
				continue;
			endif;
		endif;
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
			
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);	
		response.allCargoSummaries.add(rsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog
	delete iter;
	delete tiArray;
	finaliseResponse(response);

end;</source>
        <Parameter name="locationId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnMachine" id="7b5beaa8-e091-4bbf-a9e4-d1af7a22a3ef">
        <updating/>
        <source>getCargoOnMachine(machineOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	machine : CM_Machine;
	wsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	cargo : CM_TrackedItem;
	iter  : Iterator;
	failedDAC  :CM_DataAccessController ;
begin	
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated		
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	machine:=app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
		
	if machine = null then
		return response;
	endif;
			
	// ======================
	// Actually get the cargo

	iter:=machine.myMachineController.allTrackedItems.createIterator;
	
	while iter.next(cargo)  do
	
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);	
	
		response.allCargoSummaries.add(wsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog

	delete iter;
	finaliseResponse(response);

end;</source>
        <Parameter name="machineOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnSite" id="50aaa084-c6eb-4179-954c-eb3f520a6672">
        <updating/>
        <source>getCargoOnSite(cargoId : String ;optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
12/Nov 2020 cnwma1  Bug 50299: MTN - CargoOnSite API (JMTAppHandHeld) not allowing lowercase cargo ID

*/

vars
	response 	: WS_CargoSummaryResponse;
	wsCargo 	: WS_CargoSummary;
	failedDAC	: CM_DataAccessController ;
	cargoTypeID : Integer;
	terminal 	: CM_Terminal;
	cargoType	: CM_CargoType;
	allTIs		: CM_TISet;
	ti			: CM_TrackedItem;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	cargoTypeID := parseParameterList(optionalParam, 1, Integer).Integer;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoId.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	if cargoTypeID &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[cargoTypeID.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, cargoTypeID.String, null, null);
			return response;
		endif;
	endif;
	
	create allTIs transient;
	
	terminal.lookupAllOnsiteTrackedItems(cargoTypeID, cargoId.toUpper, allTIs, false, null);	//12.11.2020 cnwma1 #50299
	
	foreach ti in allTIs discreteLock do
		
		if ti.id.toUpper &lt;&gt; cargoId.toUpper then
			continue;
		endif;
		
		
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;
	
	return response;
epilog
	delete allTIs;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnTrailer" id="a22f3c78-2cc6-4dbd-8733-a96bb4ecba6e">
        <updating/>
        <source>getCargoOnTrailer(trailerOid : String): WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	jlier1	Initial creation 51879

*/

vars
	trailer : CM_TILC;
	wsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	cargo : CM_TrackedItem;
	iter  : Iterator;
	failedDAC  :CM_DataAccessController ;
	lc : CM_TILCController;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	trailer:=app.myPassport.getObjectOfTypeFromOid(trailerOid,CM_TILC).CM_TILC;
		
	if trailer = null then
		return response;
	endif;
	// ======================
	// Actually get the cargo
	
	foreach lc in trailer.allLCs discreteLock do
		
		foreach cargo in lc.allTrackedItems discreteLock do
			if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;
			
			
			create wsCargo transient;
			wsCargo.setProxyFromObject(cargo);	
			response.allCargoSummaries.add(wsCargo);
		endforeach;
	endforeach;
	// =========================
	
	return response;

epilog
	delete iter;
	finaliseResponse(response);

end;</source>
        <Parameter name="trailerOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnTruck" id="ee00672c-8c8a-493c-98b6-a874cf175519">
        <updating/>
        <source>getCargoOnTruck(truckOid : String): WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	jlier1	Initial creation 51879

*/

vars
	truck : CM_Vehicle;
	wsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	cargo : CM_TrackedItem;
	iter  : Iterator;
	failedDAC  :CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated		
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	truck:=app.myPassport.getObjectOfTypeFromOid(truckOid,CM_Vehicle).CM_Vehicle;
		
	if truck = null then
		return response;
	endif;
			
	// ======================
	// Actually get the cargo
	iter:=truck.locationsController.allTrackedItems.createIterator;
	
	while iter.next(cargo)  do
	
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);	
		response.allCargoSummaries.add(wsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog

	delete iter;
	finaliseResponse(response);

end;</source>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnWagon" id="3db9a3c3-f150-4a4f-a9b8-e996d8f6f5dd">
        <updating/>
        <source>getCargoOnWagon(wagonOid : String) : WS_WagonCargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlger1	Initial creation TFS 45291

*/

vars
	response : WS_WagonCargoSummaryResponse;
	wagon : CM_Wagon;
	wc : CM_WagonController;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	wsCargoSummary : WS_CargoSummary;
	failedDAC : CM_DataAccessController;	
	cargoWeight			: Decimal[12, 2];
	wagonMaxCargoWeight : Decimal[12, 2];
	allowWagonWeights	: Boolean;
	measureType			: CM_MeasurementType;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return response;
	endif;	
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if wagon = null then
		return response;
	endif;
	
	if app.myPassport.myTerminal &lt;&gt; null then
		allowWagonWeights := app.myPassport.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	if allowWagonWeights then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		wagonMaxCargoWeight := wagon.maxCargoWeight;
	endif;
	
	
	create tiArray transient;
	foreach wc in wagon.allLocationsControllersArray do
		foreach ti in wc.allTrackedItems discreteLock do
			if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;	
			
			if not tiArray.includes(ti) then	
				create wsCargoSummary transient;
				wsCargoSummary.setProxyFromObject(ti);
				response.allCargoSummaries.add(wsCargoSummary);		
				tiArray.add(ti);
				
				if allowWagonWeights then
					cargoWeight := cargoWeight + ti.weightCargo;
				endif;
			endif;
		endforeach;
	endforeach;
	
	if allowWagonWeights then
		response.remainingCargoWeight := app.convertMeasurementForDisplay(measureType.shortName, wagonMaxCargoWeight - cargoWeight) &amp; " " &amp; measureType.shortName;
	endif;
	
	
	return response;
epilog
	delete tiArray;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_WagonCargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPacked" id="29a198e6-ac8e-444b-b0df-9efc7566511c">
        <updating/>
        <source>getCargoPacked(cargoOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879

*/

vars
	response	: WS_CargoSummaryResponse;
	terminal  : CM_Terminal;	
	parent , ti : CM_TrackedItem;
	failedDAC	: CM_DataAccessController ;
	wsCargo 	: WS_CargoSummary;
begin	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;

	parent := app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parent = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	
	
	foreach ti in parent.allChildren discreteLock do			
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPickedForRelease" id="50b352a9-e699-423c-9ec9-ca78d195a021">
        <updating/>
        <source>getCargoPickedForRelease(reserveDetailOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 - Release Staging STW
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	response : WS_CargoSummaryResponse;
	reserveDetail : CM_ReserveDetail;
	reserveTI 	 : CM_ReserveTI;
	ti : CM_TrackedItem;
	failedDAC  		 : CM_DataAccessController ;
	wsCargo 		 : WS_CargoSummary;
	release : CM_BulkRelease;
	allTis	: CM_TISet;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	release:=reserveDetail.myReserveHeader;
	if reserveDetail.isKindOf( CM_ReserveTI ) then
		reserveTI:=reserveDetail.CM_ReserveTI;
	endif;
	
	reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in reserveDetail.allTrackedItems discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		if not release.allTrackedItemsAssigned.includes(ti) then
			continue;
		endif;
		if ti.isStagedFor( release ) then
			
			if reserveTI &lt;&gt; null and reserveTI.getTI &lt;&gt; ti then
				continue;
			endif;
			if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;
					
			create wsCargo transient;
			wsCargo.setProxyFromObject(ti);
			response.allCargoSummaries.add(wsCargo);
		
		
		endif;
	endforeach;
	
	return response;
	
epilog

	self.finaliseResponse(response);
	delete allTis;
end;</source>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPreviousLocation" id="513e5ff2-61a2-4ff9-b92f-f512e8a0b72d">
        <updating/>
        <source>getCargoPreviousLocation(cargoOid : String) : WS_LocationResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationResponse;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
	cargo : CM_TrackedItem;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	
	foundLC:=cargo.getPriorLocationLC;
	
	if foundLC &lt;&gt; null  then
		create wsLC transient;
		wsLC.setProxyFromObject(foundLC);
		response.myLocation:=wsLC;
	endif;
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoQueuedToArea" id="6b9a2261-ee7c-4077-a019-37f59e9c86ed">
        <updating/>
        <source>getCargoQueuedToArea(areaID : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
*/

vars
	limit 	: Integer;
	index 	: Integer;

	iter 	: Iterator;
	cargo 	: CM_TrackedItem;
	count 	: Integer;
	rsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	realArea : CM_TerminalArea;
	tiDD 	: DynaDictionary;
	lcArray : ObjectArray;
	obj 	: Object;
	lc 		: CM_LocationsController;
	tiArray : CM_TIArray;
	failedDAC : CM_DataAccessController ;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return response;
	endif;	
		
	// Get the parameters
	limit := parseParameterList(optionalParam, 1, Integer).Integer;
	index := parseParameterList(optionalParam, 2, Integer).Integer;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults

	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	
	if areaID.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	
	realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(areaID);
	
	
	if realArea = null then
		app.raiseCMException1(Location_invalid,areaID, null,null);
		return response;
	endif;	
	
	if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),areaID, null,null);
		return response;
	endif;
	
	
	
	// ======================
	// Actually get the cargo
	
	create tiArray transient;
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, false);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name, false,false);
	tiDD.endKeys(false);
	

			
	create lcArray transient;		
	realArea.getAllLocationsControllers(lcArray);
	foreach obj in lcArray do
		lc := obj.CM_LocationsController;
		lc.getAllQueuedTrackedItems(tiArray	,true);
		tiArray.copyNoDups(tiDD);
	endforeach;
	
	iter := tiDD.createIterator;	
	
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
	
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
	// =========================
	
	return response;

epilog
	delete tiArray;
	delete tiDD;
	delete iter;
	delete lcArray;
	finaliseResponse(response);
end;
</source>
        <Parameter name="areaID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToLoadForRelease" id="86b81887-05fb-443a-9775-2f143b13af5e">
        <updating/>
        <source>getCargoToLoadForRelease(releaseOid :String ;   targetLocOid : String; optionalParam : ParamListType) :WS_CargoToLoadResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2021	jlier1	Initial creation 51879

*/

vars
	realRelease		 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 			 : CM_TrackedItem;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoToLoadResponse ;
	tiArray 			 : CM_TIArray;
	tiSet				: CM_TISet;
	sourceLC, targetLC : CM_LocationsController;
	failedDAC  		 : CM_DataAccessController ;
	cmifMobile 		: 	CMIF_MobileGenericAgent;
	stwRule 		: Integer;
	sourceLocOid : String;
	resSelection : CM_ReserveSelection;
	reserveDetailOid : String;
	truck : CM_Vehicle;
	trailer : CM_TILC;
	wagon : CM_Wagon;
	checkContext : Integer;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	reserveDetailOid :=  parseParameterList(optionalParam, 1, String).String;
	sourceLocOid := parseParameterList(optionalParam, 2, String).String;

	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	app.writeLog("param list ="   &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceLocOid &amp; ",/"  , LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
				
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	sourceLC := app.myPassport.getObjectOfTypeFromOid(sourceLocOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	truck:= app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_Vehicle).CM_Vehicle;
	if truck &lt;&gt; null then
		targetLC:=truck.locationsController;
		checkContext :=CARGO_CHECK_CONTEXT_TRUKLOAD;
	else
		if app.myPassport.hasErrors then 
			app.myPassport.clearErrorsWarnings;
		endif;
		trailer:=app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_TILC).CM_TILC;
		if trailer &lt;&gt; null then
			targetLC:=trailer.allLCs.first;
			checkContext :=CARGO_CHECK_CONTEXT_TRUKLOAD;
		else
			if app.myPassport.hasErrors then 
				app.myPassport.clearErrorsWarnings;
			endif;	
			wagon:=app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_Wagon).CM_Wagon;
			if wagon &lt;&gt; null then
				targetLC:=wagon.allLocationsControllersArray.first;
				checkContext :=CARGO_CHECK_CONTEXT_RAIL_REL;
			endif;
			if app.myPassport.hasErrors then 
				app.myPassport.clearErrorsWarnings;
			endif;	
		endif;
	endif;
	if targetLC = null then
		app.raiseCMException(No_Target_location_found,null,null);
		return response;
	endif;
	
	create tiArray transient; 	
	
	create cmifMobile transient;
	cmifMobile.setMyTerminal( app.myPassport.myTerminal);
	if realResDet.isKindOf(CM_ReserveSelection) then
		resSelection:=realResDet.CM_ReserveSelection;
	endif;
	cmifMobile.getCargoBasedOnSTW12Rules(realRelease,resSelection, sourceLC, targetLC,stwRule,tiArray);
	
	create tiSet transient;
	
	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		if  tiSet.includes(cargo) then
			continue;
		endif;
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
	
		response.allCargoSummaries.add(rsCargo);
		tiSet.add(cargo);		
	endwhile;
	
	response.setCanLoadAll(checkContext,tiSet);
	response.setWeightAndCounts(realRelease,targetLC);
		
	return response;

epilog
	delete tiArray;
	delete iter;
	delete cmifMobile;
	delete tiSet;
	finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="targetLocOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoToLoadResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToPackForRelease" id="3b418ff9-9d71-4cde-9657-4c5717d5f056">
        <updating/>
        <source>getCargoToPackForRelease(releaseOid :String ;  parentCargoOid : String; optionalParam : ParamListType) : WS_CargoToPackResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879

*/

vars
	realRelease		 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo , ti	,ultParent, parentCargo		 : CM_TrackedItem;
	count 			 : Integer;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoToPackResponse ;
	tiArray 			 : CM_TIArray;	
	tempTiArray : CM_TIArray;
	sourceLC : CM_LocationsController;
	failedDAC  		 : CM_DataAccessController ;
	cmifMobile 		: 	CMIF_MobileGenericAgent;
	stwRule 		: Integer;
	sourceLocOid , targetLocOid: String;
	reserveDetailOid : String; 
	tiSet				: CM_TISet;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	reserveDetailOid:=parseParameterList(optionalParam, 1, String).String;
	sourceLocOid := parseParameterList(optionalParam, 2, String).String;
	

	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	app.writeLog("param list ="   &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceLocOid , LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	sourceLC := app.myPassport.getObjectOfTypeFromOid(sourceLocOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	parentCargo:= app.myPassport.getObjectOfTypeFromOid(parentCargoOid, CM_TrackedItem).CM_TrackedItem;
	
	if parentCargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	create tiArray transient; 	
	
	create cmifMobile transient;
	cmifMobile.setMyTerminal( app.myPassport.myTerminal);
	cmifMobile.setPackContainerDetails(null,null,null,null,parentCargo);
	cmifMobile.getCargoBasedOnSTW12Rules(realRelease,realResDet, sourceLC, null,stwRule,tiArray);
	
	create tiSet transient;

	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		if  tiSet.includes(cargo) then
			continue;
		endif;
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		
		response.allCargoSummaries.add(rsCargo);
				
		tiSet.add(cargo);
	endwhile;
	
	response.setCanPackAll(tiSet);
	response.setWeightAndCounts(realRelease,parentCargo);
		
	return response;

epilog
	delete tiArray;
	delete iter;
	delete cmifMobile;
	delete tiSet;
	finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="parentCargoOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoToPackResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToScanForGroupAssign" id="a94a514b-9488-4b66-adb1-7e8341a5d6c2">
        <updating/>
        <source>getCargoToScanForGroupAssign(groupAssignId : String ) : WS_CargoToScanForCargoGroupRes updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2021	jlier1	Initial creation 51683

*/

vars
	response : WS_CargoToScanForCargoGroupRes;
	terminal : CM_Terminal;
	cga : CM_CargoGroupAssignment;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	terminal := app.myPassport.myTerminal;
	
	cga:= terminal.findCargoGroupAssignment( groupAssignId.asStringRESTFUL.trimBlanks );
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	cga.getNotYetScanned( response.cargoIDsToScan, true );
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupAssignId" type="String"/>
        <ReturnType type="WS_CargoToScanForCargoGroupRes"/>
    </JadeMethod>
    <JadeMethod name="getCargoToStageForRelease" id="e63a775c-9cb5-419d-9712-82ec4e6944e8">
        <updating/>
        <source>getCargoToStageForRelease(releaseOid :String ; reserveDetailOid : String; sourceAreaId : String; ordering : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Who		Reason
02/08/2019	jlgns1	Initial creation
06/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
15/08/2019	jlgka1	45924		JMT - Pack by Request - Webservice. 
								BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
								and use a Dictionary instead of TIArray.
21/08/2019	jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list								
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

constants
	All_STR = "-1";
vars
	limit 			 : Integer ;
	index 			 : Integer ;
	realRelease 	 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 			 : CM_TrackedItem;
	count 			 : Integer;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoSummaryResponse ;
	tiDD 			 : DynaDictionary;					//jlgka1 TFS 45924
	tiArea 			 : CM_TerminalArea;
	realArea 		 : CM_TerminalArea;	
	failedDAC  		 : CM_DataAccessController ;
	mode			 : String;
	isQueueMode		 : Boolean;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	limit 			:= parseParameterList(optionalParam, 1, Integer).Integer;
	index 			:= parseParameterList(optionalParam, 2, Integer).Integer;
	mode			:= parseParameterList(optionalParam, 3, String).String;
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	if mode	 = "queued" then
		isQueueMode := true;
	endif;
	
	
	
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
			
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
		
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	if sourceAreaId &lt;&gt; All_STR then
		realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(sourceAreaId);
		if realArea &lt;&gt; null then
			if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),sourceAreaId, null,null);
				return response;
			endif;		
		
		endif;
	endif;
	// jlgka1 TFS 45924 --&gt;		
	create tiDD  transient;
	tiDD.setMembership(CM_TrackedItem);
	
	if ordering = "FIFO" then
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	else
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	endif;
	tiDD.endKeys(true);					
	
	realRelease.getProspectiveCargo(realResDet, realArea, null,null, tiDD, ordering &lt;&gt; "FIFO", limit, index, count);	// MTN-34024
	// jlgka1 TFS 45924 &lt;--
	
	iter := tiDD.createIterator;	
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
		
		if cargo.myPrimaryActualLocation = null then
			continue;
		endif;
		tiArea := cargo.myPrimaryActualLocation.myTerminalArea;	
		if tiArea &lt;&gt; null and tiArea.isInterchangeArea then	
			continue;
		endif;
		
		if isQueueMode then
			if cargo.myPrimaryQueuedLocation &lt;&gt; null then
				tiArea := cargo.myPrimaryQueuedLocation.myTerminalArea;	
				if tiArea &lt;&gt; null and tiArea.isInterchangeArea then	
					continue;
				endif;	
			endif;	
		endif;
		
		
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
			
	return response;

epilog	
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="reserveDetailOid" type="String"/>
        <Parameter name="sourceAreaId" type="String"/>
        <Parameter name="ordering" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypes" id="5886a055-1d4f-46dc-9d08-d49bc4eea80b">
        <updating/>
        <source>getCargoTypes()	:	WS_CargoTypeDescResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	response 		: WS_CargoTypeDescResponse;
	cargoBOLType	: CM_CargoBOLType;
	cargoType       : WS_CargoTypeDesc;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	foreach cargoBOLType in app.myPassport.myTerminal.allCargoBOLTypes discreteLock do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then 
			continue;
		endif;
		
		if cargoBOLType.CM_CargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		create cargoType transient;
		cargoType.setProxyFromObject(cargoBOLType.CM_CargoType);
		
		response.allCargoTypes.add(cargoType);
		
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_CargoTypeDescResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoValidForRelease" id="56a5dab9-9b6b-486d-a5d8-15a9a79f3743">
        <updating/>
        <source>getCargoValidForRelease(cargoID : String; releaseOid : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list								
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	reserveDetailOid : String;
	realRelease 	: CM_BulkRelease;
	realResDet 		: CM_ReserveDetail;
	otherResDet 	: CM_ReserveDetail;
	iter 			: Iterator;
	cargo 			: CM_TrackedItem;
	rsCargo 		: WS_CargoSummary;
	response 		: WS_CargoSummaryResponse;
	tiDD 			: DynaDictionary;
	trItem			: CM_TrackedItem;
	startTi 		: CM_TrackedItem;
	reason 			: String;
	errorReason 	: String;
	failedDAC  		: CM_DataAccessController ;
	allTis			: CM_TISet;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmGteMTReleaseView);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	// Get the parameters
	reserveDetailOid:= parseParameterList(optionalParam, 1, String).String;


	if cargoID = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		return response;
	endif;
	
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
				
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, false);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name,false,false);
	tiDD.endKeys(false);
	
	
	foreach otherResDet in realRelease.allReserveDetails do
		if realResDet &lt;&gt; null and otherResDet &lt;&gt; realResDet then
			continue;
		endif;
		
		
		if otherResDet.isComplete then	
			continue;
		endif;
		
		otherResDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach trItem in otherResDet.allTrackedItems do
		foreach trItem in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		
			if trItem.id &lt;&gt; cargoID then
				continue;
			endif;
		
		
			if realRelease.isPackingType then
				if trItem.isContainer or trItem.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			if trItem.isChild then
				//already packed
				continue;
			endif; 
			if trItem.myPrimaryActualLocation = null or not trItem.isOnSite then	
				if errorReason = null then
					errorReason := app.getErrorString1( ERR_TI_NOT_ONSITE,trItem.id);
				endif;	
				continue;
			endif;
			
			if realRelease.isRoadType then    
				if trItem.myPrimaryActualLocation.isVehicle then
					continue;
				elseif trItem.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			endif;
			
			tiDD.add( trItem );
		endforeach;
		
		if tiDD.size = 0 then			
			if otherResDet.isKindOf(CM_ReserveSelection) then
				iter := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
				startTi := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( cargoID, null );
				if startTi &lt;&gt; null and startTi.id = cargoID then
					iter.startAtObject( startTi );
					while iter.next(trItem) do
						if trItem.id &lt;&gt; cargoID then
							break;
						endif;
						if not trItem.isOnSite then
							// protect against crap data in DMAST
							continue;
						endif;
									
						if not trItem.testAgainstReserveSelection( otherResDet.CM_ReserveSelection, reason, true, null ) then
							if errorReason = null then
								errorReason := reason;
							endif;
							continue;
						endif;
				
					
						if trItem.myPrimaryActualLocation.isVehicle then	
							if not trItem.allBulkReleasesAssigned.isEmpty then
								//apparently assigned and already loaded...
								if errorReason = null then
									errorReason := app.getErrorString1( Cargo_already_assigned_load,trItem.getBulkReleaseAssignedCode);
								endif;	
								continue;
							endif;
						endif;
						tiDD.addNoDuplicates( trItem, false );
					endwhile;
				endif;
				delete iter;
			else
				if realResDet &lt;&gt; null and otherResDet = realResDet then
					app.raiseCMException1(Relea_not_relas_type_not_match,realResDet.myReserveHeader.code ,null,null); 
				endif;	
			endif;
		endif;
	endforeach;	
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	
			
	iter := tiDD.createIterator;	
	
	while iter.next(cargo)  do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;		
	
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
		
	if response.allCargoSummaries.size = 0 then
		if trItem = null then
			app.raiseCMException1(Follow_cargo_items_could_found,cargoID,null,null);
		else
			app.raiseCMException2(Warn_Request_Line_Match, errorReason, cargoID,null,null);
		endif;
	endif;
			
	return response;

epilog
	delete tiDD;
	delete iter;
	finaliseResponse(response);
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="cargoID" type="String"/>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getGrades" id="5b5a6184-40c3-4c72-8909-fb23efe2bb2b">
        <updating/>
        <source>getGrades(): WS_AvailabilityGradeResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	response : WS_AvailabilityGradeResponse;
	avGrade  : WS_AvailabilityGrade;
	grade    : CM_MTGrade;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	foreach grade in app.myRoot.allAvailableAvailabilityGrades do
		
		create avGrade transient;
		avGrade.setProxyFromObject(grade);
		response.allAvailabilityGrades.add(avGrade);
	endforeach;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_AvailabilityGradeResponse"/>
    </JadeMethod>
    <JadeMethod name="getInterchangeAreas" id="c9306dfa-4c25-4102-92ca-c540b61e9e61">
        <updating/>
        <source>getInterchangeAreas() : WS_TerminalAreaMasterResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	response 	: WS_TerminalAreaMasterResponse;
	area 		: WS_TerminalAreaMaster;
	theTAs		: CM_TAByTypeIdDict;
	iter		: Iterator;
	terminalArea: CM_TerminalArea;
	failedDAC	: CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	theTAs	:=	app.myPassport.myTerminal.allTerminalAreasByTypeId;
	iter	:=	theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_YARD_INTERCHANGE, null, iter);
	
	while iter.next(terminalArea) do
		if terminalArea.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		
		if not terminalArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
			
		
		create area transient;
		area.setProxyFromObject(terminalArea);
		response.allTAMasters.add(area);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeMethod>
    <JadeMethod name="getMachinesForPicking" id="c324eaff-bb72-48c9-9814-fa505ae7aa10">
        <updating/>
        <source>getMachinesForPicking(): WS_MachineResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 STW Release Staging App

*/

vars
	terminal : CM_Terminal;
	response : WS_MachineResponse;
	iter : Iterator;
	machine : CM_Machine;
	wsMachine : WS_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	iter := terminal.machines.createIterator;

	while iter.next( machine ) do
	
		if machine.hasRadioTelemetry then  //we don't want these showing
			continue;
		endif;
	
		if machine.isNotAvailableForEntry then
			continue;
		endif;
		
		if machine.machineType = MACHINETYPE_PORTAINER_CRANE
		or machine.machineType = MACHINETYPE_IMV
		or machine.machineType = MACHINETYPE_TRUCK_TRACTOR
		then
			continue;
		endif;
		
		create wsMachine transient;
		wsMachine.setProxyFromObject(machine);
		response.allMachines.add(wsMachine);
	endwhile;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);


end;</source>
        <ReturnType type="WS_MachineResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackLoadReleaseSummaries" id="ed311688-7dbd-4500-b180-81b0b879bc74">
        <updating/>
        <source>getPackLoadReleaseSummaries(releaseID : String) : WS_ReleaseSummariesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Aug 2021	jlier1	Initial creation 51879
28 Oct 2021	jlier1	TFS 52263 - needed to exclude packing parent
04 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response : WS_ReleaseSummariesResponse;
	terminal : CM_Terminal;
	roadRelease,
	packRelease,
	railRelease : CM_BulkRelease;
	releaseSummary	: WS_ReleaseRequestSummary;
	theReleaseID  : String;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	// if has both pack and road must return both and let user decide
	theReleaseID:=releaseID.trimBlanks.toUpper.asStringRESTFUL;
	roadRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_ROAD);
	packRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_PACKING);
	railRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_RAIL);	
		
	if packRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(packRelease);
		releaseSummary.setProxyForStaging(packRelease,false, false);	// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	if roadRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(roadRelease);
		releaseSummary.setProxyForStaging(roadRelease,true, false);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	if railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(railRelease);
		releaseSummary.setProxyForStaging(railRelease,true, false);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseID" type="String"/>
        <ReturnType type="WS_ReleaseSummariesResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackLoadSourceArea" id="c9cb66eb-8191-48d3-b729-df9df8ec6d1a">
        <updating/>
        <source>getPackLoadSourceArea(optionalParam : ParamListType) : WS_LocationsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879

*/

vars
response : WS_LocationsResponse;
	firstTa : CM_TerminalArea;
	term : CM_Terminal;
	iter : Iterator;
	ta : CM_TerminalArea;
	wsLC : WS_LocationsController;
	lc,selectedStageArea  : CM_LocationsController;
	allLCs 		: CM_LCSet;
	releaseOid,  reserveOid : String;
	cmifMobile : CMIF_MobileGenericAgent;
	release : CM_BulkRelease;
	reserve : CM_ReserveDetail;
	stwRuleNum : Integer;
	allVehicles : CM_VehicleArray;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term:=app.myPassport.myTerminal;
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	if firstTa = null then
		return response;
	endif;
	create allLCs transient;
	iter := term.allTerminalAreasByTypeId.createIterator;
	iter.startAtObject( firstTa );
	while iter.next( ta ) do
		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		lc := null;
		if ta.isKindOf( CM_InterchangeArea ) then
			lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089	
		endif;
		if lc = null then
			continue;
		endif;
		allLCs.add(lc);
		create wsLC transient;
		wsLC.setProxyFromObject(lc);
		response.allLocationsControllers.add(wsLC);
	endwhile;
	
	releaseOid 			:= parseParameterList(optionalParam, 1, String).String;
	reserveOid 			:= parseParameterList(optionalParam, 2, String).String;
	if releaseOid &lt;&gt; null then
		release:= app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;
	
	if release = null then
		return response;
	endif;
	if reserveOid &lt;&gt; null then
		reserve:=app.myPassport.getObjectOfTypeFromOid(reserveOid, CM_ReserveDetail).CM_ReserveDetail;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;
	
	
	if release.isRoadType then
		create allVehicles transient;
		release.getAssociatedTrucks(allVehicles);
		if allVehicles.size = 1 then
			selectedStageArea:=null;
			release.getAllPreStagedLocations(selectedStageArea);
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
			endif;
		endif;
	endif;
	if term.getConfig(UseAltSelectRulesTL).Boolean and app.isCargoGroupEnabled then
		create cmifMobile transient;
		cmifMobile.getCargoStagingDispRuleSTW(release,reserve,selectedStageArea,stwRuleNum);
		if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
			response.selectedLocationOid:=selectedStageArea.getOidAsString;
		endif;
	else
		if selectedStageArea = null and reserve &lt;&gt; null and allLCs.first &lt;&gt; null then
			reserve.getTotalStaged(null, selectedStageArea, null);
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
			endif;
		endif;
	endif;
	
	
	return response;
	
epilog
	delete iter;
	delete cmifMobile;
	delete allLCs;
	delete allVehicles;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeMethod>
    <JadeMethod name="getPackingParentsForRelease" id="ac57aa5c-d7af-4986-8cd1-6b68131d1a9c">
        <updating/>
        <source>getPackingParentsForRelease(releaseOid  : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_CargoSummaryResponse;
	terminal : CM_Terminal;
	release 	: CM_BulkRelease;
	truckArray : CM_VehicleArray ;
	allTIs 	: CM_TIArray;
	ti : CM_TrackedItem;
	wsCargoSummary : WS_CargoSummary;
	truck : CM_Vehicle;
	failedDAC : CM_DataAccessController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create truckArray transient;
	release.getAssociatedTrucks(truckArray);
	
	create allTIs transient;
	
	foreach truck in truckArray discreteLock do
		foreach ti in truck.locationsController.allTrackedItems where not (ti.isROB or ti.isChassis) do
			allTIs.add(ti);
		endforeach; 
	endforeach;
	
	release.getProspectiveParentCargo(allTIs,false);
	
	foreach ti in allTIs discreteLock do 
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
		create wsCargoSummary transient;
		wsCargoSummary.setProxyFromObject(  ti );
		
		//jlier1 TFS 52366
		if ti.isContainer then
			wsCargoSummary.productDescription:= ti.myCargoType.description &amp; ", " &amp; ti.getISOType();
		endif;
		
		response.allCargoSummaries.add( wsCargoSummary );
	endforeach;
	
	return response;
epilog
	delete truckArray;
	delete allTIs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getPickingReleaseSummaries" id="c897f436-9385-426d-968c-ac20fc68b22b">
        <updating/>
        <source>getPickingReleaseSummaries(releaseID : String) : WS_ReleaseSummariesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2021	jlier1	Initial creation TFS 51626
28 Oct 2021	jlier1	TFS 52263 - needed to exclude packing parent
04 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response : WS_ReleaseSummariesResponse;
	terminal : CM_Terminal;
	roadRelease,
	packRelease,
	shipRelease,
	railRelease : CM_BulkRelease;
	releaseSummary	: WS_ReleaseRequestSummary;
	theReleaseID  : String;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	// if has both pack and road must return both and let user decide
	theReleaseID:=releaseID.trimBlanks.toUpper.asStringRESTFUL;
	roadRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_ROAD);
	packRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_PACKING);
	shipRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_SHIP);
	railRelease:=terminal.getBulkReleaseActiveFromCode(theReleaseID, BR_TYPE_RAIL);
	
	if packRelease &lt;&gt; null and ( roadRelease &lt;&gt; null or shipRelease &lt;&gt; null or railRelease &lt;&gt; null ) then
		if packRelease &lt;&gt; null then
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(packRelease);
			releaseSummary.setProxyForStaging(packRelease,true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if roadRelease &lt;&gt; null then
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(roadRelease);
			releaseSummary.setProxyForStaging(roadRelease,true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if shipRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(shipRelease);
			releaseSummary.setProxyForStaging(shipRelease,true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		if railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			create releaseSummary transient;
			releaseSummary.setProxyFromObject(railRelease);
			releaseSummary.setProxyForStaging(railRelease,true, true);		// MTN-34024
			response.allReleaseSummaries.add(releaseSummary);
		endif;
		
		
	elseif packRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(packRelease);
		releaseSummary.setProxyForStaging(packRelease,true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif roadRelease &lt;&gt; null then
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(roadRelease);
		releaseSummary.setProxyForStaging(roadRelease,true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif shipRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(shipRelease);
		releaseSummary.setProxyForStaging(shipRelease,true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	elseif railRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
		create releaseSummary transient;
		releaseSummary.setProxyFromObject(railRelease);
		releaseSummary.setProxyForStaging(railRelease,true, true);		// MTN-34024
		response.allReleaseSummaries.add(releaseSummary);
	endif;
	
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseID" type="String"/>
        <ReturnType type="WS_ReleaseSummariesResponse"/>
    </JadeMethod>
    <JadeMethod name="getPickingTargetAreas" id="b3125fce-5a0b-4c77-aea5-5371ed6e4ad1">
        <updating/>
        <source>getPickingTargetAreas(optionalParam : ParamListType) : WS_LocationsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2021	jlier1	Initial creation TFS 51626 - Release Staging STW

*/

vars
	response : WS_LocationsResponse;
	firstTa : CM_TerminalArea;
	term : CM_Terminal;
	iter : Iterator;
	ta : CM_TerminalArea;
	wsLC : WS_LocationsController;
	lc,selectedStageArea  : CM_LocationsController;
	allLCs 		: CM_LCSet;
	releaseOid : String;
	release : CM_BulkRelease;
	reserve : CM_ReserveDetail;
	tiSet : CM_TISet; 
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term:=app.myPassport.myTerminal;
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	if firstTa = null then
		return response;
	endif;
	create allLCs transient;
	iter := term.allTerminalAreasByTypeId.createIterator;
	iter.startAtObject( firstTa );
	while iter.next( ta ) do
		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		lc := null;
		if ta.isKindOf( CM_InterchangeArea ) then
			lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
		endif;
		if lc = null then
			continue;
		endif;
		allLCs.add(lc);
		create wsLC transient;
		wsLC.setProxyFromObject(lc);
		response.allLocationsControllers.add(wsLC);
	endwhile;
	
	releaseOid 			:= parseParameterList(optionalParam, 1, String).String;
	if releaseOid &lt;&gt; null then
		release:= app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
			return response;
		endif;
	endif;
	
	if release = null or allLCs.isEmpty  then
		return response;
	endif;
	
	create tiSet transient;
	if not release.isPackingType then
		release.getTotalStaged(tiSet, selectedStageArea);
		if selectedStageArea &lt;&gt; null then
			response.selectedLocationOid:=selectedStageArea.getOidAsString;
		endif;
	endif;
	
	if selectedStageArea =  null then
		foreach reserve in release.allReserveDetails discreteLock where not reserve.isFullyStaged do
			selectedStageArea:=reserve.getFirstStagingLocation;
			if selectedStageArea &lt;&gt; null and allLCs.includes(selectedStageArea) then
				response.selectedLocationOid:=selectedStageArea.getOidAsString;
				break;
			endif;
		endforeach;
	endif;
	return response;
	
epilog
	delete tiSet;
	delete iter;
	delete allLCs;
	self.finaliseResponse(response);
end;
</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailReleaseSummary" id="c84b3752-ff65-4b7a-842b-2dd7f5dd4c50">
        <updating/>
        <source>getRailReleaseSummary(releaseNo : String): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2019	jlger1	Initial creation TFS 45291
17 July 2019	jlgrr1	

*/

vars
	response 		: WS_ReleaseSummaryResponse;
	releaseSummary	: WS_ReleaseRequestSummary;
	bulkRelease		: CM_BulkRelease;
	failedDAC : CM_DataAccessController;
	releaseNumber : String;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	if releaseNo = null then
		app.raiseCMException(Input_required_field_relNum,null,null);
		return response;
	endif;
	
	//epr TFS 46632 23/9/19 
	releaseNumber:=releaseNo.trimBlanks.toUpper.asStringRESTFUL;
	
	bulkRelease := app.myPassport.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_RAIL,BR_ACTIVE,releaseNumber, null );

	if bulkRelease = null or bulkRelease.type &lt;&gt; BR_TYPE_RAIL or bulkRelease.status &lt;&gt; BR_ACTIVE or bulkRelease.code &lt;&gt; releaseNumber then
		app.raiseCMException1(Bulk_Release_Not_Found,releaseNumber ,null,null);
		return response;
	endif;
	
	if not bulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.userName,bulkRelease.code,null, null,null);
		return response;
	endif;
	
	
	create releaseSummary transient;
	releaseSummary.setProxyFromObject(bulkRelease);
	releaseSummary.setProxyReserveDetails(bulkRelease); // jlier1 26/7/21 TFS 51626 
	response.releaseRequestSummary := releaseSummary;
		
	return response;
epilog
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseNo" type="String"/>
        <ReturnType type="WS_ReleaseSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getRailReleaseWagons" id="3e750a42-00cb-4c58-8215-4d94920d6031">
        <updating/>
        <source>getRailReleaseWagons(releaseOid: String) : WS_WagonsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlger1	Initial creation TFS 45291

*/

vars

	response : WS_WagonsResponse;
	releaseRequest : CM_BulkRelease;
	wagonArray : CM_WagonArray;
	wagon : CM_Wagon;
	wsWagon : WS_Wagon;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return response;
	endif;	
	
	releaseRequest:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if releaseRequest = null then
		app.raiseCMException1(Bulk_Release_Not_Found,releaseOid ,null,null);
		return response;
	endif;
	
	if releaseRequest.type &lt;&gt;  BR_TYPE_RAIL then
		return response;
	endif;
	
	create wagonArray transient;
	releaseRequest.getAssociatedWagons(wagonArray, true );
	
	foreach wagon in wagonArray discreteLock do
		create wsWagon transient;
		wsWagon.setProxyFromObject(wagon);
		response.allWagons.add(wsWagon);
		
	endforeach;
	
	return response;
epilog
	delete wagonArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeMethod>
    <JadeMethod name="getReleaseSummary" id="b8e49d89-c09a-4eab-8a65-5b5e0a0d6464">
        <updating/>
        <source>getReleaseSummary(releaseOid : String ): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2021	jlier1	Initial creation TFS 52444
04 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response 		: WS_ReleaseSummaryResponse;
	releaseSummary 	: WS_ReleaseRequestSummary;
	bulkRelease		: CM_BulkRelease;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
		
	create response transient;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
			
	if bulkRelease = null  then
		app.raiseCMException(Bulk_Release_Not_Found,null,null);
		return response;
	endif;
	
	
	create releaseSummary transient;
	releaseSummary.setProxyFromObject(bulkRelease);
	releaseSummary.setProxyForStaging(bulkRelease, true, false);		// MTN-34024
	response.releaseRequestSummary := releaseSummary;
		
	return response;
epilog
	
	self.finaliseResponse(response);


end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_ReleaseSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getRoadReleaseSummary" id="95072104-00c8-41ff-8e33-c41ac1ea29d0">
        <updating/>
        <source>getRoadReleaseSummary(releaseID : String): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2019	jlger1	Initial creation
