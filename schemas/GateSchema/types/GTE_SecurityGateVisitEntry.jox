    <JadeMethod name="doBaseFormSave" id="8a7ad594-bb21-42e8-8c82-0bb7ff7c18ef">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 12/03/2014	cnwdap1		PAR #33639 Carry Arrival Date/Time through to Vehicle Visit Record
// 27/06/2018	JLGNS1		Bug 39463: STWR - RE: Ticket 39428 - Steinweg Rotterdam - Error when trying to open Road Operations
// 13/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//
vars
	proxyVVR,
	realVVR		: CM_VehicleVisitRecord;
	batNumber	: String;
	result		: Integer;
	updateOK	: Boolean;
	systemTimeIn,
	localTimeIn,
	oldestTimeIn	: TimeStamp;

begin
	localTimeIn.setDate(self.txtArrivalDate.getDate());
	localTimeIn.setTime(self.txtArrivalTime.getTime());	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support
	systemTimeIn := self.localToSystemTime(localTimeIn);
	
	oldestTimeIn := null;																											//Bug 39463
	oldestTimeIn.setDate(app.actualTimeServer.Date - self.numberOfDays);															//Bug 39463
	
	if systemTimeIn = null or not systemTimeIn.isValid or systemTimeIn &gt; app.actualTimeServer or systemTimeIn &lt; oldestTimeIn then	//Bug 39463
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, app.getErrorString(Arrival), null, null);										//Bug 39463
	endif;																															//Bug 39463
	
	create proxyVVR transient;
	proxyVVR.setProxyFlexiGate(	self.txtDriverCode.text, 
								self.lblDriverName.caption, 
								null,
								null,						//13/05/2022 navhl20 TFS 53430 
								self.txtRegistration.text, 
								self.txtState.text, 
								null, 
								self.myTerminal, 
								null, 
								null, 
								null	);
	
	proxyVVR.setVisitType(proxyVVR.VisitType_SecurityGate);
	proxyVVR.setIsUpdatable(true);
	proxyVVR.setTimeIn(systemTimeIn.Date, systemTimeIn.Time);			// PAR #33639
	
	if self.cmbBatNumber.listIndex &gt; 0 then
		batNumber := self.cmbBatNumber.itemObject[self.cmbBatNumber.listIndex].CM_RFIDTag.code;
	endif;
	
	while true do
		app.myTrxCA.trxCreateVVRSecurityGate(proxyVVR, realVVR, batNumber, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			updateOK := true;
			break;
		else
			result := app.showErrorWarningDialog('Vehicle Visit - Security Gate', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
	if updateOK then
		self.unloadForm();
	endif;
epilog
	delete proxyVVR;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="dca0e6cb-2c9e-4e51-9b86-5978496722c7">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			Repositions everything if captions are shown

Parameters:			

Return Value:		


Date			Who		Reason
11 January 2018	jlgmd1	Initial Creation - TFS #36554 - PEN - Security Gate Screen

*/
constants
	BaseFormHeight 	= 200;
	VertDist		= 10;  // ### TFS 50421 27SEP2021 NAVAB1 24;
vars
	hideBAT, hideDriver, hideState	: Boolean;
	offset : Real;
begin
	inheritMethod();

	if self.frmToolbar.showCaptions then
		self.frmToolbar.height := self.frmToolbar.height - VertDist;
		offset := (CMUI_Toolbar.HeightWithCaptions - CMUI_Toolbar.HeightWithoutCaptions) - VertDist;
	endif;
	
	// Set Initial Positions
	/* // ### TFS 50421 27SEP2021 NAVAB1
	self.lblBATNbr.top := 32 + offset;
	self.cmbBatNumber.top := 32 + offset;
	self.lblDriverCode.top := 56 + offset;	
	self.lblDriverName.top := 56 + offset;
	self.txtDriverCode.top := 56 + offset;
	self.lblRegistration.top := 80 + offset;
	self.lblState.top := 80 + offset;
	self.txtRegistration.top := 80 + offset;
	self.txtState.top := 80 + offset;
	self.lblArrivalDate.top := 104 + offset;
	self.txtArrivalDate.top := 104 + offset;
	self.txtArrivalTime.top := 104 + offset;
	TFS 50421 NOW */
	
	self.lblBATNbr.top := 42 + offset;
	self.cmbBatNumber.top := 42 + offset;
	self.lblDriverCode.top := 66 + offset;	
	self.lblDriverName.top := 66 + offset;
	self.txtDriverCode.top := 66 + offset;
	self.lblRegistration.top := 90 + offset;
	self.lblState.top := 90 + offset;
	self.txtRegistration.top := 90 + offset;
	self.txtState.top := 90 + offset;
	self.lblArrivalDate.top := 114 + offset;
	self.txtArrivalDate.top := 114 + offset;
	self.txtArrivalTime.top := 114 + offset;

	
	
	// show the BAT number field only if we're using BAT numbers
	hideBAT := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	
	// show the driver name field only if we're using driver names
	hideDriver := self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean;
	
	// show state only if requested
 // ### TFS 50421 17SEP2021 NAVAB1	hideState := not self.myTerminal.getConfig(ShowVehicleState).Boolean;
	
	self.height := BaseFormHeight + offset;
	
	if hideBAT then
		self.txtDriverCode.top 		:= self.txtDriverCode.top - VertDist;
		self.lblDriverCode.top 		:= self.lblDriverCode.top - VertDist;
		self.lblDriverName.top 		:= self.lblDriverName.top - VertDist;
		self.txtRegistration.top 	:= self.txtRegistration.top - VertDist;
		self.lblRegistration.top 	:= self.lblRegistration.top - VertDist;
		self.txtState.top 			:= self.txtState.top - VertDist;
		self.lblState.top 			:= self.lblState.top - VertDist;
		self.lblArrivalDate.top		:= self.lblArrivalDate.top - VertDist;
		self.txtArrivalDate.top		:= self.txtArrivalDate.top - VertDist;
		self.txtArrivalTime.top		:= self.txtArrivalTime.top - VertDist;
		
		self.height					:= self.height - VertDist;
	endif;
	
	if hideDriver then
		self.txtRegistration.top 	:= self.txtRegistration.top - VertDist;
		self.lblRegistration.top 	:= self.lblRegistration.top - VertDist;
		self.txtState.top 			:= self.txtState.top - VertDist;
		self.lblState.top 			:= self.lblState.top - VertDist;
		self.lblArrivalDate.top		:= self.lblArrivalDate.top - VertDist;
		self.txtArrivalDate.top		:= self.txtArrivalDate.top - VertDist;
		self.txtArrivalTime.top		:= self.txtArrivalTime.top - VertDist;
		
		self.height					:= self.height - VertDist;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNotifications" id="daa4e1a1-ee96-4148-8012-63553651a69d">
        <updating/>
        <source>doUserNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	localEvent 	: Integer;
	invalidObj 	: Boolean;
	rfid 		: CM_RFIDTag;

begin
	localEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if localEvent = Event_RFIDTagFree then
		rfid := userInfo.CM_RFIDTag;
		if self.cmbBatNumber.findObject( rfid ) &lt; 1 then
			self.cmbBatNumber.itemObject[self.cmbBatNumber.addItem(rfid.code)] := rfid;
		endif;
		
	elseif localEvent = Event_RFIDTagInUse then	//23 Apr 2012	NDL	Par 29417
		rfid := userInfo.CM_RFIDTag;
		if self.cmbBatNumber.findObject( rfid ) &gt; 0 then
			self.cmbBatNumber.removeObject( rfid );
		endif;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4a1bf0a4-5703-41b4-8df9-e27a1abf351c">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 11/01/2018	jlgmd1		TFS #36554 PEN - Security Gate Screen
//							Moved the field positioning code to doResize so the form is still usable with captions enabled
//
vars
	hideBAT, hideDriver, hideState	: Boolean;

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	// show the BAT number field only if we're using BAT numbers
	hideBAT := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	
	// show the driver name field only if we're using driver names
	hideDriver := self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean;
	
	// show state only if requested
	hideState := not self.myTerminal.getConfig(ShowVehicleState).Boolean;
	
	if hideBAT then
		self.cmbBatNumber.visible 	:= false;
		self.lblBATNbr.visible		:= false;
	else
		// load the combo with all RFID tags / bat numbers
		self.myAssistant.comboBoxRFIDTag(self.cmbBatNumber,self.myTerminal, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	endif;
	
	if hideDriver then
		self.txtDriverCode.visible	:= false;
		self.lblDriverCode.visible	:= false;
		self.lblDriverName.visible	:= false;
	endif;
	
	if hideState then
		self.txtState.visible 		:= false;
		self.lblState.visible 		:= false;
	endif;
	
	self.txtArrivalDate.setDate(self.systemToLocalTime(app.actualTimeServer).Date);	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support
	self.txtArrivalTime.setTime(self.systemToLocalTime(app.actualTimeServer).Time);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8c18658c-9acd-493d-a6b2-462a513d20e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:46:13.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019528, locale);
	lblArrivalDate.translateCaption(Xlat_0019449, locale);
	lblBATNbr.translateCaption(Xlat_0019450, locale);
	lblDriverCode.translateCaption(Xlat_0019451, locale);
	lblRegistration.translateCaption(Xlat_0023356, locale);
	lblState.translateCaption(Xlat_0023355, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtDriverCode_lostFocus" id="df392dbb-dc53-4258-9b17-7a6afdee9cfa">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDriverCode_lostFocus(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	driver	: CM_DriverDetails;

begin
	if textbox.text.trimBlanks = null then
		self.lblDriverName.caption := null;
		return;
	endif;
	
	driver := self.myTerminal.findDriver(textbox.text.trimBlanks);
	if driver &lt;&gt; null then
		self.lblDriverName.caption := driver.name;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="1a261d50-c906-437d-9280-caf87612dbf6">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	self.doUserNotifications(eventType, theObject, eventTag, userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
