    <JadeMethod name="clickStoreOnPallet" id="2fd5b659-a033-4c66-b7a9-6e60daea42d7">
        <updating/>
        <source>clickStoreOnPallet( _enabled : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2020	jlgndl1	Initial creation	TFS 48246

*/

vars

	palletType : CM_PalletType;
	handlingType : CM_HandlingType;
	clearHeatTreated : Boolean;

begin

	if not _enabled then
		self.cmbPallettType.listIndex := 1;
		self.chkHeatTreated.value := false;	//23 Jan 2019	NDL	TFS 48246
	endif;
	
	self.lblPalletType.enabled := _enabled;
	self.cmbPallettType.enabled := _enabled;
	self.lblHeatTreated.enabled := _enabled;
	self.chkHeatTreated.enabled := _enabled;
	
	if _enabled and self.cmbPallettType.listObject = null then
		if self.myPxyBreakBulkGeneric.myPalletDetailsTI &lt;&gt; null then
			palletType := self.myPxyBreakBulkGeneric.myPalletDetailsTI.getPalletTypeObj;
		endif;
		if palletType = null then
			handlingType := self.myPxyBreakBulkGeneric.getHandlingType();
			if handlingType &lt;&gt; null and handlingType.isPallet then
				palletType := handlingType.getDefaultSubHandlingType.CM_PalletType;
				clearHeatTreated := true;
			endif;
		endif;
		if palletType &lt;&gt; null then
			self.cmbPallettType.listIndex := self.cmbPallettType.findObject( palletType );
		endif;
	endif;
	
	//17 Jan 2019	TFS 48247
	if clearHeatTreated then
		self.chkHeatTreated.value := false;
	endif;
	
	//21 Jan 2020	NDL TFS 48246
	if self.isReadOnly then
		self.setReadOnly();
	endif;

epilog

end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbPallettType_change" id="dd0570d7-746a-46a6-81ee-0d1b732638c6">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPallettType_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

	handlingSubType : CM_HandlingSubType;

begin

	handlingSubType := self.cmbPallettType.listObject.CM_HandlingSubType;
	if handlingSubType = null then
		self.chkHeatTreated.value := false;
		self.chkStoreOn.value := false;
	else
		self.chkHeatTreated.value := handlingSubType.CM_PalletType.heatTreated;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
