    <JadeMethod name="closeWorkbook" id="1d523435-305c-425a-81fb-0ca62c7af3ce">
        <updating/>
        <source>closeWorkbook() updating;

/*****************************************************
	Written by	:	cnwpra1		03 June 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myExcelApplication &lt;&gt; null then
	
		doingClose := true;
		
		if myExcelApplication.workbooks.count &gt; 0 then
			myExcelApplication.activeWorkbook.save();
			myExcelApplication.activeWorkbook.saved := true;
		endif;
		myExcelApplication.quit();
		delete myExcelApplication;
		
		doCleanupProcessing;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e90c937b-0c72-44e9-8404-e84758c9277b">
        <updating/>
        <source>delete() updating;

vars

begin
	
	if myExcelApplication &lt;&gt; null then
		if excelCreatedOK then
			doingClose := true;
			myExcelApplication.quit; 
			delete myExcelApplication;
		endif;
	endif;
	
	if myFileManagementDA &lt;&gt; null then
		delete myFileManagementDA;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCleanupProcessing" id="aed43775-4d61-4e7d-a9fb-f5ac9c93a1e5">
        <updating/>
        <source>doCleanupProcessing() updating;

/*****************************************************
	Written by	:	cnwpra1		24 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	
	if myExcelApplication &lt;&gt; null then
		myExcelApplication.quit; 
		delete myExcelApplication;
	endif;
	
	self.beginTimer(2000, Timer_OneShot, 1);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDataAndTopSheet" id="81378096-955c-491b-ae3a-23b5d10e237d">
        <updating/>
        <source>getDataAndTopSheet() : Boolean updating;

/*****************************************************
	Written by	:	cnwpra1		12 May 2004
	Description	:	Get the sheet references required.

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	dataSheet		: Boolean;
	topSheet		: Boolean;
	dispatch		: IDispatch;
	str				: String;
	count			: Integer;
	int				: Integer;

begin
	count := myExcelApplication.activeWorkbook.sheets.count;
	
	myWorksheetTopsheet := null;
	myChartTopsheet := null;
	myWorksheetTopsheet := null;
	
	while int &lt; count do
		int := int + 1;
		dispatch := myExcelApplication.activeWorkbook.sheets.item(int);
		
		if dispatch.isKindOf(I_Worksheet) then
			if dispatch.I_Worksheet.name = myWorkbookDefinition.topWorksheet then
				topSheet := true;
				myWorksheetTopsheet := dispatch.I_Worksheet;
			endif;
			if dispatch.I_Worksheet.name = myWorkbookDefinition.dataWorksheet then
				dataSheet := true;
				myDataWorksheet := dispatch.I_Worksheet;
			endif;
		elseif dispatch.isKindOf(I_Chart) then
			if dispatch.I_Chart.name = myWorkbookDefinition.topWorksheet then
				topSheet := true;
				myChartTopsheet := dispatch.I_Chart;
			endif;
			if dispatch.I_Chart.name = myWorkbookDefinition.dataWorksheet then
				return false;
			endif;
		endif;
	endwhile;
	
	if not dataSheet then
		return false;
	endif;
	
	if not topSheet then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataRequestFromWorksheet" id="f979f9cc-ff9a-46bd-a052-54642457f90b">
        <source>getDataRequestFromWorksheet();

vars
	sht : I_Worksheet;
	cont : Boolean;
	int	: Integer;
	str, opt : String;
	sa	: StringArray;
begin
	cont := true;
	int := 1;
	sht := getWorksheet('Source Data');
	while cont do
		str := sht.range("A" &amp; int.String, null).getValue.String;
		if str &lt;&gt; null then
			sa.add(str);
			opt := sht.range("B" &amp; int.String, null).getValue.String;
			int := int + 1;
		else
			cont := false;
		endif;
	endwhile;
	

end;</source>
    </JadeMethod>
