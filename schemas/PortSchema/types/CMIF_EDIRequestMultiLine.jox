    <JadeMethod name="loadOrVerifyForDB" id="d06debdd-a935-446b-8f96-437bdb2f9531">
        <updating/>
        <source>loadOrVerifyForDB(_passport: CM_Passport input; _verifyOnly: Boolean) updating;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//28 Jan 2016   cnwma1  Par 37438 [RELATED TO TFS1192] Error 70092 while loading EDI Release Request by Type
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 22 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 15 Dec 2017	jlgrs1	TFS 8281 - SNO - 
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
// 20 Mar 2023	navdap1	TFS 56795 PRP - Suzano EDI - Release Order
// 23 Jun 2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// 19 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
// 15 Aug 2023	navdap1	TFS 59844 EUP FR | 53824 - Manifest EDI - Work order must have at least one tracked item error
// 12 Oct 2023	navdap1	TFS 58928 EUP | Calloff Zimmer DB Load
// 17 Oct 2023	navdap1	TFS 60850 Not Able To DB Load CallOff File - Cancel Type
// 26 Oct 2023	navdap1	TFS 58929 EUP | Calloff Cancel Processing
// 23 Nov 2023	navhn30	TFS 61041 EUP | FR 54084 - CallOff - VBS slot remains visible
// 06 May 2025	naviv1	MTN-34689 - EUP FR | 54084 - CallOff - Weight is not populated on the release detail line in CallOffStockMove
// 26 May 2025	naviv1	MTN-34693 - EUP FR | 54084 - CallOff - 1090 Error when accessing Vehicle Booking after cancelling release request
vars
	terminal : CM_Terminal;
	object : Object;
	obj : Object;
	ediRequestHeaderTI : CM_EDIRequestHeaderTI;
	ediRequestDetailTI : CM_EDIRequestDetailTI;
	ediRequestCriteriaTI : CM_EDIRequestCriteriaTI;
	realBulkRelease : CM_BulkRelease;
	pxyBulkRelease : CM_BulkRelease;
	releasesBeingProcessed : ObjectSet; 
	releasesToAdd : ObjectSet;
	releasesToUpdate : ObjectSet;
	releasesToDelete : ObjectSet;
	pxyReserve : CM_ReserveDetail;
	matchedReserve : CM_ReserveDetail;
	reservesToDelete : CM_ReserveDetailSet;
	reservesToKeep : CM_ReserveDetailSet;
	ti : CM_TrackedItem;
	partsDone, partsInJob : Integer;
	progressStr : String;
	progressTS : TimeStamp;
	doPartial : Boolean;
	errorSet : CM_ErrorSet;
	newStatus : Integer;
	emailTo : String;
	emailFrom : String;
	senderCode : String;
	coparnRules : CM_EDIPartyCoparnRules;
	x12301Rules : CM_EDIPartyX12301Rules;
	emailOnUpdate : Boolean;
	emailOnDelete : Boolean;
	resetCompleted : Boolean;
	isCoparn : Boolean;
	isX12301 : Boolean;
	defaultVoyage : CM_Voyage;
	garbageColl	: ObjectSet;
	allEDITiRequestDetails : ObjectSet;
	allEDITiRequestCriterias : ObjectSet;
	allEDITiTaskRemarks : ObjectSet;
	ediTaskRemarkTI : CM_EDITaskRemarkRelBookTI;
	ediData : CM_EDIData;
	tempEDIReleaseRequestTI : CM_EDIReleaseRequestTI;
	allEDIReleaseRequestTIs : ObjectArray;
	passport : CM_Passport;						// TFS 58923
	workOrder : CM_WorkOrder;					// TFS 58923
	releaseForCallOff : CMIF_EDIReleaseRequest;	// TFS 58923
	releaseDetails : CM_ObjectArray;			// TFS 58923
	iter : Iterator;							// TFS 58923
	callOffReleaseCode : String;				// TFS 58923
	timeSlot : CM_VehicleBookingTimeSlot;		// TFS 58923
	existingCallOff : CM_EDIFile;					// TFS 58929
	pxyTimeSlot : CM_VehicleBookingTimeSlot;
begin
	// Arm our base exception handlers.
//	on Exception do self.validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);	// This needs to be set so that EDI exceptions get stored against the EDIData
	
	terminal :=	self.getMyTerminal();
	passport := _passport;					// TFS 58923
	doPartial := terminal.getConfig(EdiReleaseAllowPartial).Boolean;
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
	if self.allEDITrackedItems.isEmpty then
		return;
	endif;
	ediData := self.allEDITrackedItems.first.myEDIData;
	isCoparn := self.isCoparnFile(ediData);
	isX12301 := self.isX12301File(ediData);
	emailTo	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
	emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;
//	------------------
//	progress bar stuff
//	------------------	
	partsInJob := self.allEDITrackedItems.size();
	partsDone := null;
	progressStr := app.getString(Setting_ReleaseRequest_Details, partsInJob.display());
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	// do verify first then do dbload if that is ok
//	str := self.class.name &amp; " " &amp; method.qualifiedName;
//	self.cnStartTransaction(str[1:50]);
	
	create releasesBeingProcessed transient;
	create releasesToAdd transient;
	create releasesToUpdate transient;
	create releasesToDelete transient;
	create reservesToDelete transient;
	create reservesToKeep transient;
	create errorSet transient;
	create garbageColl transient;
	create allEDITiRequestDetails transient;
	create allEDITiRequestCriterias transient;
	create allEDITiTaskRemarks transient;
	create allEDIReleaseRequestTIs transient;
	
	self.verifyFileOperator(errorSet, app.myPassport);		// TFS 56795
	
	foreach object in self.allEDITrackedItems do
		if not object.isKindOf(CM_EDIRequestHeaderTI) then
			continue;
		endif;
		ediRequestHeaderTI := object.CM_EDIRequestHeaderTI;

		if ediRequestHeaderTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED or
		   ediRequestHeaderTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
		   ediRequestHeaderTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			// maybe it is a delete that could not be done or it might be a 
			// release that is blocked or can no longer be delete/updated via EDI
			continue;
		endif;
		
		if _verifyOnly then
			app.myTrxUA.trxUpdateEDITIStatus(ediRequestHeaderTI, CM_EDITrackedItem.EDI_STATUS_UNPROCESSED, _passport);
		endif;
//		if ediRequestHeaderTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then				// par 29480 April 2012
			// probably got errors during verify
			// par 29575 - don't ignore these yet.. We will re-verify so that we know
			// that we have errors in the file when we set the EDI Data status at the end of the method
//		endif;
		
		if isCoparn and senderCode = null then											// par 29402 May 2012
			// first time only
			senderCode 	:= ediRequestHeaderTI.CM_EDIRequestHeaderTI.senderCode;
			coparnRules := ediData.getEDIPartyCoparnRules(senderCode);
			
			if coparnRules &lt;&gt; null then
				emailOnUpdate := coparnRules.sendEmailForUpdates;
				emailOnDelete := coparnRules.sendEmailForDeletes;
				defaultVoyage := coparnRules.getDefaultVoyage;
				resetCompleted := coparnRules.resetCompletedOnQtyIncrease;
			endif;	
		endif;
		if isX12301 and
		   senderCode = null then
			// first time only
			senderCode 	:= ediRequestHeaderTI.CM_EDIRequestHeaderTI.senderCode;
			x12301Rules := ediData.getEDIPartyX12301Rules(senderCode);
			if x12301Rules &lt;&gt; null then
				defaultVoyage := x12301Rules.getDefaultVoyage;
			endif;
		endif;
		
		partsDone :=	partsDone + 1;
		ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
 	
		// check to see if this release can be updated.  It may be actioned, completed
		// archived or blocked.  If it is we will mark the EDI TI as Skip Processing and never attempt to update it again.		
		realBulkRelease	:= terminal.getBulkReleaseFromCode(ediRequestHeaderTI.releaseRequestNumber);
		
		if realBulkRelease &lt;&gt; null then 
			// it is not an ADD
			if not self.canDoEDIUpdateDelete(realBulkRelease, ediRequestHeaderTI, coparnRules, _verifyOnly, _passport) then
				// will send email if necessary and mark edi tracked item as DBLoaded
				_passport.moveErrorsToSet(errorSet);
				// we don't want to process this edi tracked item again
				app.myTrxUA.trxUpdateEDITIStatus(ediRequestHeaderTI, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, _passport); 	
				app.setContinueCMExceptions(true);
				continue;
			endif;
		endif;

		if realBulkRelease = null and 
		ediRequestHeaderTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			// TFS 58929 if this is a CallOff, and the previous file that we're cancelling isn't DB Loaded, don't raise an error
			if self.myCallOffEDIData &lt;&gt; null then
				self.myCallOffEDIData.myEDIFile.myEDIFileType.findExistingEDIFile(self.myCallOffEDIData.myEDIFile.ediClientRef, self.myCallOffEDIData.myEDIFile, existingCallOff);
			endif;
			if existingCallOff = null or existingCallOff.ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
				app.raiseCMException1(ReleaseRequest_DoesNotExist, ediRequestHeaderTI.releaseRequestNumber, ETRow_ReleaseRequestNumber, ediRequestHeaderTI);
			endif;
			// TFS 58929 end
		endif;

		// move voyage cutoffs check to doUpdateProxyBR
		pxyBulkRelease := self.findBulkReleaseToUpdate(ediRequestHeaderTI, releasesBeingProcessed, releasesToAdd, releasesToUpdate, releasesToDelete);
		if pxyBulkRelease = null then
			if _passport.hasErrors then
//				if _passport.allErrors.includesErrorCode(ReleaseRequestAlreadyHasItems) then
//					newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;
//				else
					if _verifyOnly then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
					endif;
//				endif;
				app.myTrxUA.trxUpdateEDITIStatus(ediRequestHeaderTI, newStatus, _passport);
			else
				// TFS 58929 If this is a CallOff Cancel, this is fine - update EDI TI status to DB Loaded
				if not _verifyOnly and existingCallOff &lt;&gt; null and existingCallOff.ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED then
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
					app.myTrxUA.trxUpdateEDITIStatus(ediRequestHeaderTI, newStatus, _passport);
					self.getAllEDIRequestDetails(ediRequestHeaderTI, allEDITiRequestDetails);
					foreach object in allEDITiRequestDetails do
						ediRequestDetailTI := object.CM_EDIRequestDetailTI;
						app.myTrxUA.trxUpdateEDITIStatus(ediRequestDetailTI, newStatus, _passport);
						self.getAllEDIRequestCriteria(ediRequestDetailTI, allEDITiRequestCriterias);
						self.getAllEDITaskRemarks(ediRequestDetailTI, allEDITiTaskRemarks);
						foreach obj in allEDITiRequestCriterias do
							ediRequestCriteriaTI := obj.CM_EDIRequestCriteriaTI;
							app.myTrxUA.trxUpdateEDITIStatus(ediRequestCriteriaTI, newStatus, _passport);
						endforeach;
						foreach obj in allEDITiTaskRemarks do
							ediTaskRemarkTI := obj.CM_EDITaskRemarkRelBookTI;
							app.myTrxUA.trxUpdateEDITIStatus(ediTaskRemarkTI, newStatus, _passport);
						endforeach;
					endforeach;
				endif;
				// TFS 58929  end of this bit
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.clearErrorsWarnings;
			continue;
		endif;
		if pxyBulkRelease &lt;&gt; null then
			self.doUpdateProxyBulkRelease(pxyBulkRelease, ediRequestHeaderTI, defaultVoyage, garbageColl);
			self.getAllEDIRequestDetails(ediRequestHeaderTI, allEDITiRequestDetails);
			foreach object in allEDITiRequestDetails do
				ediRequestDetailTI := object.CM_EDIRequestDetailTI;
				matchedReserve := null;
				if not ediRequestHeaderTI.releaseByType then
					//ti := terminal.lookupTrackedItem(ediRequestDetailTI.id, ediRequestHeaderTI.cargoType, TI_STATE_UNDEFINED, null, false);   // 28/01/2015 cnwma1 PAR #37438
					ti := terminal.lookupTrackedItem(ediRequestDetailTI.id, ediRequestDetailTI.cargoType, TI_STATE_UNDEFINED, null, false);     // 28/01/2015 cnwma1 PAR #37438
					
					// par 31185 - if we didn't find it maybe it has already been released
					if ti = null then
						ti := self.findReleasedTrackedItem(ediRequestHeaderTI, ediRequestDetailTI, realBulkRelease);
					endif;
				endif;
	
				if ediRequestHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
					if self.myCallOffEDIData &lt;&gt; null and ediRequestDetailTI.quantity &lt;&gt; null and (ediRequestDetailTI.weightRequested &lt;&gt; null or ediRequestDetailTI.volume &lt;&gt; null) then  //MTN-34689
						app.raiseCMException(Relea_reque_canno_conta_quant_, null , null);
					endif;
					// TFS 58923 instructions
					if ediRequestDetailTI.instructionType &lt;&gt; null then
						if terminal.allInstructionTypes[ediRequestDetailTI.instructionType] = null then
							app.raiseCMException2(Instruction_type_invalid, ediRequestDetailTI.instructionType, terminal.code, null, null);
						endif;
					endif;
					// TFS 58923 end of this bit
					
					foreach pxyReserve in pxyBulkRelease.allReserveDetails do
						if ediRequestDetailTI.sequence = pxyReserve.sequence then
							if not reservesToDelete.includes(pxyReserve) then
								reservesToDelete.add(pxyReserve);
							endif;
						endif;
					endforeach;
					
					foreach pxyReserve in pxyBulkRelease.allReserveDetails do
						if pxyReserve.isAllocationById() then
							if ti &lt;&gt; null then
								//if pxyReserve.allTrackedItems.includes(ti) or
								if pxyReserve.includeTrackedItem(ti, false) or //23/06/2023	navkc1	CR 58406 Task 58408
									pxyReserve.allTrackedItemsReleased.includes(ti) then
									matchedReserve := pxyReserve;
									break;
								endif;
							endif;
						else
							create tempEDIReleaseRequestTI transient;
							allEDIReleaseRequestTIs.add(tempEDIReleaseRequestTI);
							tempEDIReleaseRequestTI.setupFromRelReqMultiLine(ediRequestHeaderTI, ediRequestDetailTI);
							if pxyReserve.isEDIMatch(tempEDIReleaseRequestTI, true) then
								matchedReserve := pxyReserve;
								break;
							elseif pxyReserve.isEDIMatch(tempEDIReleaseRequestTI, false) and matchedReserve &lt;&gt; null then
								matchedReserve := pxyReserve;
								// Don't break here, as there may be a better matching Reserve later in the collection.
							endif;
						endif;
					endforeach;
					// if we have matched against a resevse selection we have just processed then cancel the match
					if matchedReserve &lt;&gt; null and reservesToKeep.includes(matchedReserve) then
						matchedReserve := null;
					endif;
					// If the matchedReserve parameter is null, then a new Reserve Detail will be created.
					matchedReserve := self.doUpdateProxyReserve(pxyBulkRelease, matchedReserve, ediRequestHeaderTI, ediRequestDetailTI, garbageColl, _verifyOnly);	// TFS 58923
					
					if matchedReserve &lt;&gt; null then
						if not reservesToKeep.includes(matchedReserve) then
							reservesToKeep.add(matchedReserve);
						endif;
					endif;
				endif;
			endforeach;
		endif;
		
		if _passport.hasErrors() then
			newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS; 
		elseif _passport.hasWarnings() then
			newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS; 
		else
			if _verifyOnly then
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED; 
			else
				newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
			endif;
		endif;
		
		// save off passport errors so we can tell if next ediTI has errors
		_passport.moveErrorsToSet(errorSet);
		
		if newStatus &lt;&gt; ediRequestHeaderTI.status then
			app.myTrxUA.trxUpdateEDITIStatus(ediRequestHeaderTI, newStatus, _passport);
			self.getAllEDIRequestDetails(ediRequestHeaderTI, allEDITiRequestDetails);
			foreach object in allEDITiRequestDetails do
				ediRequestDetailTI := object.CM_EDIRequestDetailTI;
				app.myTrxUA.trxUpdateEDITIStatus(ediRequestDetailTI, newStatus, _passport);
				self.getAllEDIRequestCriteria(ediRequestDetailTI, allEDITiRequestCriterias);
				self.getAllEDITaskRemarks(ediRequestDetailTI, allEDITiTaskRemarks);	//06 Oct 2016	NDL	TFS 2001 / 2792
				foreach obj in allEDITiRequestCriterias do
					ediRequestCriteriaTI := obj.CM_EDIRequestCriteriaTI;
					app.myTrxUA.trxUpdateEDITIStatus(ediRequestCriteriaTI, newStatus, _passport);
				endforeach;
				foreach obj in allEDITiTaskRemarks do		//06 Oct 2016	NDL	TFS 2001 / 2792
					ediTaskRemarkTI := obj.CM_EDITaskRemarkRelBookTI;
					app.myTrxUA.trxUpdateEDITIStatus(ediTaskRemarkTI, newStatus, _passport);
				endforeach;
			endforeach;
			app.setContinueCMExceptions(true);
		endif;
	endforeach;
	
	// Remove any remaining Reserve Details that have not been updated.
	// This will result in the persistent ones being deleted when the Bulk Release(s) is/are updated.
	// Note that a Reserve Detail should not be deleted if it already has at least one released item.
	
	foreach pxyReserve in reservesToDelete do
		if not reservesToKeep.includes(pxyReserve) then
			pxyBulkRelease := pxyReserve.myReserveHeader;
			
			if pxyReserve.allTrackedItemsReleased.isEmpty() then
				pxyBulkRelease.allReserveDetails.remove(pxyReserve); 
				delete pxyReserve;
			endif;
		endif;
	endforeach;
	
	// TFS 58928 For CallOffStockMove messages, check enough cargo is on site to satisfy each reserve detail
	if self.myCallOffEDIData &lt;&gt; null 
	and self.myCallOffEDIData.statusString &lt;&gt; CMIF_JsonHeaderEUP.Status_Cancel 
	and self.myCallOffEDIData.type = CM_EDIDataCallOff.CallOffStockMovement then
		foreach pxyReserve in reservesToKeep do
			if pxyReserve.isKindOf(CM_ReserveSelection) then
				pxyReserve.CM_ReserveSelection.checkAvailQuantityAndWeight(pxyReserve.totalRequested, pxyReserve.weightRequested);
			endif;
		endforeach;
	endif;
	// TFS 58928 end
	
	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	_passport.moveErrorsToSet(errorSet);		// par 29480 make sure we have all the errors
	_passport.addErrorsFromSet(errorSet);		// par 29480 restore all current errors back to check new status for edi data
	
	newStatus := self.getStatFrEDITIsVerifyOrDBL(_verifyOnly);
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, newStatus);
	app.setContinueCMExceptions(true);
	
	if not doPartial and _passport.hasErrors() then
		return;
	endif;
	
	errorSet.clear;
	
	_passport.moveErrorsToSet(errorSet);
	
	// TFS 58923 if I'm part of a CallOff message, do CallOff specific validation and updates prior to DB Load
	if self.myCallOffEDIData &lt;&gt; null then
		self.doCallOffValidationTidyUp(_verifyOnly, passport);
		
		releaseForCallOff := releasesToAdd.first.CMIF_EDIReleaseRequest;
		if releaseForCallOff = null then
			releaseForCallOff := releasesToUpdate.first.CMIF_EDIReleaseRequest;
		endif;
		if releaseForCallOff = null then
			releaseForCallOff := releasesToDelete.first.CMIF_EDIReleaseRequest;
		endif;
		// TFS 60850 If this is a cancel of a Create that hasn't been DB Loaded yet, there won't be a release request
		if releaseForCallOff &lt;&gt; null then
			timeSlot := releaseForCallOff.myBulkRelease.allVBTimeslotsById.first;
		endif;
		callOffReleaseCode := self.myCallOffEDIData.manifestNumber;
	endif;
	// TFS 58923 end of this bit
	
	// Now create/update/delete for each of the proxy Bulk Releases.
	self.loadDB_Adds(releasesToAdd, _verifyOnly, terminal, doPartial, _passport);
	
	if doPartial or not _passport.hasErrors then
		_passport.moveErrorsToSet(errorSet);
		
		self.loadDB_Updates(releasesToUpdate, _verifyOnly, terminal, doPartial, resetCompleted, emailOnUpdate, emailTo, emailFrom, _passport);
	endif;
	
	if doPartial or not _passport.hasErrors then
		_passport.moveErrorsToSet(errorSet);
		self.loadDB_Deletes(releasesToDelete, _verifyOnly, terminal, doPartial, emailOnDelete, emailTo, emailFrom, _passport);
	endif;
	
	// add back ALL previous errors
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	
	// need to update status now ... use EDi Tracked items for this
	app.setContinueCMExceptions(true);
	// add back ALL previous errors
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	
	// TFS 58923 if we got this far with no errors, create a Cargo Release work order for the CallOff message
	if not _verifyOnly and _passport.noErrors then
		create releaseDetails transient;
		if self.myCallOffEDIData &lt;&gt; null and _passport.isVASEnabled then
			if callOffReleaseCode &lt;&gt; null then
				workOrder := terminal.allWorkOrders[callOffReleaseCode];
				if workOrder = null and self.myCallOffEDIData.statusString &lt;&gt; CMIF_JsonHeaderEUP.Status_Cancel then
					// find the real bulk release (releaseToAdd.myBulkRelease is transient)
					iter := terminal.allBulkReleasesByCodeDate.createIterator;
					terminal.allBulkReleasesByCodeDate.startKeyGeq(callOffReleaseCode.toUpper, "31/12/3100 23:59".TimeStamp, iter);
					while iter.next(realBulkRelease) do
						if realBulkRelease.code &lt;&gt; callOffReleaseCode.toUpper then
							realBulkRelease := null;
							break;
						endif;
						
						break;
					endwhile;
					if realBulkRelease &lt;&gt; null then
						realBulkRelease.allReserveDetails.copy(releaseDetails);
					endif;
					
					//app.myTrxCA.trxCreateWOForManifest(self.myCallOffEDIData.manifestNumber, WO_TASK_RELEASE, releaseDetails, null);		// TFS 59844
					app.myTrxCA.trxCreateWOForManifest(self.myCallOffEDIData.manifestNumber, WO_TASK_RELEASE, releaseDetails, null, null);	// TFS 59844
				else
					if self.myCallOffEDIData.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
						// release request has already been deleted above, now just need to delete the work order
						// TFS 58929 If we're cancelling a CallOff that wasn't yet DB Loaded, we don't have a work order
						if workOrder &lt;&gt; null then
							app.myTrxDA.trxDeleteWorkOrder(workOrder, _passport);
							
							// deleting the vehicle booking time slot
							if timeSlot &lt;&gt; null then
							//MTN-34693  -- uncommented the below lines of code for dissociating the vehicle booking from release request (instead of deleting the vbs), when calloff cancel file is sent
								/*pxyTimeSlot := app.createUpdateProxy(timeSlot).CM_VehicleBookingTimeSlot;		
								pxyTimeSlot.setRefsToNullForCallOffCancel();
								app.myTrxUA.trxUpdateVehicleBookingAdv(pxyTimeSlot, _passport);*/
								app.myTrxDA.trxDeleteVehicleBooking(timeSlot, _passport);				// 23.11.23		navhn30		#TFS 61041
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	// TFS 58923 end of this bit
	
	self.setEDITIStatusFromErrors(_verifyOnly, _passport);
epilog
	_passport.setWarningsIgnored(false);	// In case delete transaction failed!
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
	if allEDIReleaseRequestTIs &lt;&gt; null then
		allEDIReleaseRequestTIs.purge;
		delete allEDIReleaseRequestTIs;
	endif;
	delete releasesToAdd;
	delete releasesToUpdate;
	delete releasesToDelete;
	delete reservesToDelete;
	delete reservesToKeep;
	delete errorSet;
	delete allEDITiRequestDetails;
	delete allEDITiRequestCriterias;
	delete allEDITiTaskRemarks;
	
	if releasesBeingProcessed &lt;&gt; null then
		releasesBeingProcessed.purge();
		
		delete releasesBeingProcessed;
	endif;
	
	if garbageColl &lt;&gt; null then
		garbageColl.purge;
		delete garbageColl;
	endif;
	
	delete releaseDetails;		// TFS 58923
	delete iter;
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEDITIStatusFromErrors" id="8f51cb8d-cc9e-4a28-aba5-0a83e869a4b7">
        <source>setEDITIStatusFromErrors(_verifyOnly : Boolean; _passport : CM_Passport);
//
// 10 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
// 28 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 10 Jul 2018	jlgrs1	TFS 38808 - JMT - Full and Partial loading not working correctly
vars
	error : CM_Error;
	newStatus : Integer;
	oldStatus : Integer;
	passport : CM_Passport;
	ediTI : CM_EDITrackedItem;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ediTI, invalid); //PAR24233 - cnwsh3 skip invalid voyage objects
	passport := _passport;
	foreach error in passport.allErrorWarnings do
		if error.myUserObject = null or
		   not error.myUserObject.isKindOf(CM_EDITrackedItem) then
			continue;
		endif;
		ediTI := error.myUserObject.CM_EDITrackedItem;
		oldStatus := ediTI.status;
		if invalid then
			continue;
		endif;
//		if _passport.allErrors.includesErrorCode(ReleaseRequestAlreadyHasItems) or
		if error.errorCode = Voyage_departed or
		   error.errorCode = ReleaseRequest_DoesNotExist or
		   error.errorCode = ERR_TI_CONSIGNEE_RESTRICTED or
		   error.errorCode = Operat_coparn_party_rule_relea then
			newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;
		else
			if _verifyOnly then
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
				endif;
			else
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			endif;
		endif;
		if oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			newStatus := oldStatus;
		endif;
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, passport);
	endforeach;

epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateProxyTI" id="5f43dca2-90b9-4c89-92e0-4f0876b0956c">
        <source>validateProxyTI(_ti : CM_TrackedItem;  _ediHeaderTI : CM_EDIRequestHeaderTI; _ediDetailTI : CM_EDIRequestDetailTI; _bulkRelease : CM_BulkRelease input; _garbageColl : ObjectSet input; 
                _isInLoadState : Boolean io);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2024	navsaa30	Initial creation

*/

vars
    pxyTI : CM_TrackedItem;

begin
    pxyTI := app.myProxyManager.getProxyObject(_ti).CM_TrackedItem;
    if pxyTI &lt;&gt; null and not _ediHeaderTI.allowCargoMultiReleases then
        app.raiseCMException1(Attempt_Release_Cargo_Twice, _ediDetailTI.id, ETRow_Id, _ediDetailTI);
        return ;
    endif;

    if pxyTI = null then
        app.cmsBeginLoad(_isInLoadState);
        pxyTI := _ti.pxyCreateUpdateProxy().CM_TrackedItem;
        app.cmsEndLoad(_isInLoadState);
    endif;

    //  improve updating of release by ID
    //			 - if the ti has already been released it will already be in the _proxy.allTrackedItemsReleased collection
    //			 - if the ti has already been assigned it will be in the _proxy.allTrackedItemsAssigned collection
    //			 - if this is a new ti for the release we need to add the proxy to the _proxy.allTrackedItemsAssigned collection
    // this next bit seems to be just to stop the same ti being used in &gt;1 release but it only checks releases within this file
    //
    // so wont pick up releases that have already beend loaded - not sure if this is WAI or not (cnwcs5 - feb 2013)
    
    if not _bulkRelease.allTrackedItemsAssigned.includes(_ti) and not _bulkRelease.allTrackedItemsReleased.includes(_ti) then
        // now the proxy release has the proxy TI in its assigned collection - maybe it should be release ****
        pxyTI.allBulkReleasesAssigned.add(_bulkRelease);
    else
        if not _garbageColl.includes(pxyTI) then
            _garbageColl.add(pxyTI);
		endif;
    endif;
end;
	
	
	
	</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_garbageColl" type="ObjectSet" usage="input"/>
        <Parameter name="_isInLoadState" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateTI" id="9e15d178-ac2e-4f10-84df-85f9512075b4">
        <source>validateTI(_id : String; _terminal: CM_Terminal; _ediHeaderTI : CM_EDIRequestHeaderTI; _ediDetailTI : CM_EDIRequestDetailTI; 
           _bulkRelease : CM_BulkRelease) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2024	navsaa30	Initial creation

*/
vars
    ti : CM_TrackedItem;
begin
    ti := _terminal.lookupTrackedItem(_id, _ediDetailTI.cargoType, TI_STATE_UNDEFINED, null, false);
    if ti = null then
        ti := self.findReleasedTrackedItem(_ediHeaderTI, _ediDetailTI, _bulkRelease);
    endif;

    if ti = null then
        app.raiseCMException3(Specfied_Cargo_DoesNotExist, _id, _ediDetailTI.cargoTypeDescr, _terminal.code, ETRow_Id, _ediDetailTI);
    endif;

    return ti;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="verifyFileOperator" id="e9af7eed-08d9-4dbb-9ffe-f16e5fc7838d">
        <source>verifyFileOperator(_errorSet : CM_ErrorSet input; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/03/2023	navdap1		Initial creation TFS 56797 PRP - Suzano EDI - Release Order
//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
vars
	ediFile : CM_EDIFile;
	suzaOperator : CM_Operator;
	data : String;
	count, lines, pos : Integer;
	ediTI : CM_EDITrackedItem;

begin
	ediFile := self.ediFileArray.first;
	if ediFile &lt;&gt; null and
	   ediFile.myEDIFileType.type = EDIFileType_SuzanoReleaseOrder then
		suzaOperator := app.myRoot.allOperators[CM_EDIFileTypeSuzanoManifest.OPERATOR_SUZA];
		if suzaOperator = null or suzaOperator.isNotAvailableForEntry then
			app.raiseCMException1(ERR_INVALID_OPERATOR, CM_EDIFileTypeSuzanoManifest.OPERATOR_SUZA, null, null);
		endif;
		
		_passport.moveErrorsToSet(_errorSet);
	endif;
epilog

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
