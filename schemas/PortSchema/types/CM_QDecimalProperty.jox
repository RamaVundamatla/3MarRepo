    <JadeMethod name="setTextValues" id="e5656b03-97bc-4c46-a9b8-a99f356848d2">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 10/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 18/02/2014	cnwdap1		PAR #33329 Correct display of measurements in Selector
vars
	precision	: Integer; 								// PAR #33329
	searchValue	: Decimal [14,4];						// PAR #33329

begin
	if _txt = null or (not  CM_QueryDecimalOperator.hasInstance(_operator)) then
		return;
	endif;
	
	if self.myMeasurementType = null then													// PAR #31155
		_txt.text := _operator.CM_QueryDecimalOperator.searchValue.String;
	else																					// PAR #31155
		//_txt.text := app.convertMeasurementForDisplay(self.myMeasurementType.shortName, _operator.CM_QueryDecimalOperator.searchValue);	// PAR #33329
		precision := self.myMeasurementType.getDecimalPrecision;																			// PAR #33329
		searchValue := _operator.CM_QueryDecimalOperator.searchValue;																		// PAR #33329
		_txt.text := searchValue.asStringJMTWithPrecision(precision, false);																// PAR #33329
	endif;																					// PAR #31155

end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="4172a44f-c29f-4efa-a3fa-f33309e213c4">
        <source>translateToDisplayValue(_value: Any): String;

/*
Date		Who		Reason
08/09/2009	cnwar2	Initial creation
05/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
18/02/2014	cnwdap1	PAR #33329 Correct display of measurements in Selector
*/
vars
	pos		: Integer;
	measure : CM_MeasurementType;				// PAR #31155
	value 	: String;							// PAR #31155

begin
	measure := self.myMeasurementType;													// PAR #31155
	if measure = null then																// PAR #31155
		if self.propertyName.isOneOf(ETRow_OverHeight, ETRow_OverLengthFront, CM_Container::overLengthRear.name, ETRow_OverWidthRight, ETRow_OverWidthLeft) then	// PAR #31155
			return _value.String;														// PAR #31155
		else																			// PAR #31155
			// 33894 don't truncate the value in a summary.  The incoming value has been through the measurement type process for a summary and may have
			//		a type suffix.  If so, just strip the suffix and return the value.
			pos := _value.String.pos(" ", 1);
			if pos &gt; 1 then
				return _value.String[1:pos-1];
			else
				return _value.Decimal.asStringJMTWithPrecision(2, false);				// original code pre-33894
			endif;
		endif;																			// PAR #31155
	else																				// PAR #31155
		//return app.convertMeasurementForDisplay(measure.shortName, _value.Decimal) &amp; Space &amp; measure.shortName;		// PAR #33329
		return _value.Decimal.asStringJMTWithPrecision(measure.getDecimalPrecision, false) &amp; Space &amp; measure.shortName;	// PAR #33329
	endif;																				// PAR #31155

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="8b9b1b29-15f7-4b28-8428-055739665520">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	if _value.isKindOf(Decimal) and self.myMeasurementType &lt;&gt; null then
		return app.convertMeasurementForStorage(self.myMeasurementType.shortName, _value.Decimal).Decimal;
	endif;
	
	return inheritMethod(_value);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
