    <JadeMethod name="setNumTerminals" id="0cba8b63-262f-49a9-9d37-686982416e90">
        <source>setNumTerminals(_numTerminals : Integer; _array : BooleanArray io) protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	binStr	: String;
	idx,
	len,
	pos		: Integer;
	value	: Boolean;
	
begin

	binStr := _numTerminals.asBinaryNumber.reverse;

	len := binStr.length;
	if len = 0 then
		return;
	endif;

	foreach idx in 1 to len do
		if binStr[idx] = '1' then
			value := true;
		else
			value := false;
		endif;
		if idx = 1 then
			pos := PmNum01;
		elseif idx = 2 then
			pos := PmNum02;
		elseif idx = 3 then
			pos := PmNum03;
		elseif idx = 4 then
			pos := PmNum04;
		elseif idx = 5 then
			pos := PmNum05;
		elseif idx = 6 then
			pos := PmNum06;
		elseif idx = 7 then
			pos := PmNum07;
		elseif idx = 8 then
			pos := PmNum08;
		elseif idx = 9 then
			pos := PmNum09;
		elseif idx = 10 then
			pos := PmNum10;
		else
			app.msgBox('Exceeded number of terminal limit', 'Error', 0);
			break;
		endif;
		_array.atPut(pos - Mod_BaseView, value);
	endforeach;	
end;</source>
        <access>protected</access>
        <Parameter name="_numTerminals" type="Integer"/>
        <Parameter name="_array" type="BooleanArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblLicense_change" id="0d601386-eaaa-4d57-83e4-9b352e4451f1">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLicense_change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setHasLicenseDtlsChanged(true);
	//23/12/2024	navkc1 JIRA Story MTN-33491
	if self.currentLicenseType = DEV_LicenseEntity.LicenseType_EDI then
		self.doSelectEDILicense();
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
