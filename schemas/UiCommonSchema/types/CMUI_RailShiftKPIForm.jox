    <JadeMethod name="doLoad" id="ae2b82a1-764e-4a3c-9946-a2f673d19af7">
        <updating/>
        <source>doLoad() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	cmif : CMIF_TrainShiftHeaderMSL;
	includeNonWorked : Boolean;
	
begin

	self.setupHeaderFrame();
	
	
	create cmif transient;
	cmif.initialise(self.processDate, self.allTerminals);
	cmif.populateInOutTables( self.tblReport, self.tblReport2, includeNonWorked );
	cmif.populateCombinedTotalsTable( self.tblReport3 );
	
	self.setTableHeights();
	
epilog

	delete cmif;

end;</source>
    </JadeMethod>
    <JadeMethod name="run" id="c7af4f8e-b020-4882-bb01-8c1ab5c84e0d">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation

*/

vars
	jrwTrans : CM_JRWTrain;
	obj : Object;
begin

	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	
	if self.processDate = null then
		jrwTrans := app.myQAFilter.allJRWTransients.first.CM_JRWTrain;
		if jrwTrans &lt;&gt; null then
			self.processDate := jrwTrans.processDate;
			
			if not jrwTrans.allTerminals.isEmpty then
				jrwTrans.allTerminals.copy(self.allTerminals);
			endif;
		endif;
	endif;
	
	self.doLoad();
	
	app.printer.print(frmHeader);
	app.printer.print(frmTable);
	
	if not app.printer.frameFits(frmTable2) then
		app.printer.print(frmFooter);
		app.printer.newPage();
		app.printer.print(frmHeader);
	endif;
	
	app.printer.print(frmTable2);
	
	if not app.printer.frameFits(frmTable3) then
		app.printer.print(frmFooter);
		app.printer.newPage();
		app.printer.print(frmHeader);
	endif;
	
	app.printer.print(frmTable3);
	
	app.printer.print(frmFooter);
	
	return null;

epilog

	app.printer.close;
	
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setTableHeights" id="a230263f-72c4-4b10-924d-2fed12a3de59">
        <source>setTableHeights();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation	Par 21519

*/

constants
	
vars

begin

	// inwards cargo
	self.tblReport.height := self.tblReport.rows * self.tblReport.rowHeight[1];
	self.frmTable.height := self.tblReport.height + self.tblReport.top;
	
	//outwards cargo
//	self.frmTable2.top := self.frmTable.height + self.frmTable.top + 25;
	self.tblReport2.height := self.tblReport2.rows * self.tblReport2.rowHeight[1];
	self.frmTable2.height := self.tblReport2.height + self.tblReport2.top;
	
	//cargo shift totals
//	self.frmTable3.top := self.frmTable.height + self.frmTable.top + 25;
	self.tblReport3.height := self.tblReport3.rows * self.tblReport3.rowHeight[1];
	self.frmTable3.height := self.tblReport3.height + self.tblReport3.top;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupHeaderFrame" id="7e31c244-9a4f-4031-b4a2-631848c3a3da">
        <source>setupHeaderFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation

*/

constants

	Gap = 5;
	
vars

	lblUserLabel : Label;
	lblPageNumber : Label;
	terminal : CM_Terminal;
	
begin

	// unused controls
	self.lblReportExtra.visible := false;
	self.lblTerminalName.visible := false;
	self.lblCriteria.visible := false;
	self.lblCriteriaValue.visible := false;
	
	if self.allTerminals.isEmpty then
		terminal :=  app.myPassport.myTerminal;
	else
		terminal := self.allTerminals.first;
	endif;
	
	//terminal name
	self.lblHeading1.caption := terminal.name;
	self.lblHeading1.alignment := self.lblHeading1.Alignment_Center_Middle;
	self.lblHeading1.width := 280;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	self.lblHeading1.fontUnderline := false;
	
	//report name
	self.lblHeading2.caption := processDate.Date.asStringJMT &amp; " " &amp; app.getErrorString(Train_shift_kpi_report);
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.width := 280;
	self.lblHeading2.top := 35;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	self.lblHeading2.fontUnderline := false;
	
	//user label
	lblUserLabel := self.lblReportId;
	lblUserLabel.visible := true;
	lblUserLabel.fontSize := 8;
	lblUserLabel.caption := "User:   " &amp; app.myPassport.myUser.code;
	lblUserLabel.top := self.lblTerminalName.top + self.lblTerminalName.height + Gap;
	lblUserLabel.height := 15;
	
	//page numbering label
	self.lblPage.visible := true;
	self.lblPage.caption := app.getErrorString(Page);
	self.lblPage.fontSize := lblUserLabel.fontSize;
	self.lblPage.top := self.lblHeading1.top + 5;
	self.lblPage.height := 15;
	self.lblPage.width := 30;
	self.lblPage.left := self.lblHeading3_1.left - self.lblPage.width;
	
	//page number
	lblPageNumber := self.lblHeading3_1;
	lblPageNumber.visible := true;
	lblPageNumber := self.lblHeading3_1;
	lblPageNumber.visible := true;
	lblPageNumber.fontSize := lblUserLabel.fontSize;
	lblPageNumber.top := self.lblPage.top;
	lblPageNumber.height := 15;
	lblPageNumber.width := 30;
	
	//print date label
	self.lblPrinted.visible := true;
	self.lblPrinted.fontSize := 8;
	self.lblPrinted.width := 60;
	self.lblPrinted.caption := app.getErrorString(Printed);
	self.lblPrinted.top := lblUserLabel.top;
	self.lblPrinted.height := 15;
	self.lblPrinted.left := self.lblPage.left;

	// print date
	self.lblPrintedDtl.visible := true;
	self.lblPrintedDtl.fontSize := self.lblPrinted.fontSize;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrinted.left + self.lblPrinted.width;
	self.lblPrintedDtl.height := self.lblPrinted.height;
	self.lblPrintedDtl.width := 58;
	
	// print time
	self.lblPrintTime.visible := true;
	self.lblPrintTime.fontSize := self.lblPrinted.fontSize;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintedDtl.left + self.lblPrintedDtl.width;
	self.lblPrintTime.height := self.lblPrinted.height;
	self.lblPrintTime.width := 50;
	
	self.frmHeader.height := self.lblHeading2.top + self.lblHeading2.height + Gap + Gap;
	
	//set Table ( &amp; parent frame &amp;  associated label) width and visibility
	// inwards cargo
	self.frmTable.visible := true;
	self.frmTable.left := self.frmHeader.left;
	self.frmTable.width := self.frmHeader.width;
	
	self.lblTable1Head.parent :=  self.frmTable;
	self.lblTable1Head.visible := true;
	self.lblTable1Head.top := Gap + Gap;
	self.lblTable1Head.left := 1;
	self.lblTable1Head.width := self.frmTable.width - 2;
	self.lblTable1Head.caption := app.getErrorString(Inward_trains);
	self.lblTable1Head.fontBold := true;

	self.tblReport.visible := true;
	self.tblReport.top := lblTable1Head.top + lblTable1Head.height + 2;
	self.tblReport.left := 1;
	self.tblReport.width := self.frmTable.width - 2;
	
	//outwards cargo
	self.frmTable2.visible := true;
	self.frmTable2.left := self.frmHeader.left;
	self.frmTable2.width := self.frmHeader.width;
	
	self.lblTable2Head.parent :=  self.frmTable2;
	self.lblTable2Head.visible := true;
	self.lblTable2Head.top := Gap + Gap;
	self.lblTable2Head.left := 1;
	self.lblTable2Head.width := self.frmTable2.width - 2;
	self.lblTable2Head.caption := app.getErrorString(Departed_trains);
	self.lblTable2Head.fontBold := true;

	self.tblReport2.visible := true;
	self.tblReport2.top  := lblTable2Head.top + lblTable2Head.height + 2;
	self.tblReport2.left := 1;
	self.tblReport2.width := self.frmTable2.width - 2;
	
	//cargo totals
	self.frmTable3.visible := true;
	self.frmTable3.left := self.frmHeader.left;
	self.frmTable3.width := self.frmHeader.width;
	
	self.lblTable3Head.parent :=  self.frmTable3;
	self.lblTable3Head.visible := true;
	self.lblTable3Head.top := Gap + Gap;
	self.lblTable3Head.left := 1;
	self.lblTable3Head.width := self.frmTable3.width - 2;
	self.lblTable3Head.caption := app.getErrorString(Containers_processed);
	self.lblTable3Head.fontBold := true;

	self.tblReport3.visible := true;
	self.tblReport3.top :=  lblTable3Head.top + lblTable3Head.height + 2;
	self.tblReport3.left := 1;
	self.tblReport3.width := self.frmTable2.width - 2;
	
end;</source>
    </JadeMethod>
</GUIClass>
