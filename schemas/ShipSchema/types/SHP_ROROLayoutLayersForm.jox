    <JadeMethod name="doBtnAddDimensionClick" id="d6367211-0224-4520-9e65-a589bd067c23">
        <source>doBtnAddDimensionClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		PAR 27773 - add the NEW point functionality
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	thePoint : Point;
	theFrame : CMUI_PointDrawingFrame;
	newPoints : PointArray;
begin
	idx := self.tblDimensions.row - self.tblDimensions.fixedRows;	// 28764 fix 1300 exception
	// 28764 if row not set, use the second-last, to keep the start and end points the same
	if idx &lt;= self.tblDimensions.fixedRows then
		idx := self.tblDimensions.rows - self.tblDimensions.fixedRows - 1;
	endif;
	create newPoints transient;

	if idx &gt;  self.tblDimensions.fixedRows then
		thePoint := self.myCurrentProxyItemLayout.pointsPolygon[idx];
		theFrame := self.myParentForm.SHP_RORODeckDefinitionForm.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;
		theFrame.doInsertNewPoint(thePoint,false,self.myCurrentProxyItemLayout);
		
		self.myCurrentProxyItemLayout.pointsPolygon.copy(newPoints);
		self.myCurrentProxyItemLayout.setPointsPolygon(newPoints);
		theFrame.doBtnRefreshClick();
		self.doListItemDimensions();
	endif;
epilog
	delete newPoints;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDelDimensionClick" id="9035454e-7921-4e83-b8d7-bb587529114c">
        <source>doBtnDelDimensionClick();
// ---------------------------------------------------------------------------
// Created:		Dec 2011 cnwjre1
//
// Purpose:		28764 after PAR 27773 - add delete point functionality
//
// ---------------------------------------------------------------------------

vars
	row,
	idx : Integer;
	thePoint : Point;
	theFrame : CMUI_PointDrawingFrame;
	newPoints : PointArray;
begin
	row := self.tblDimensions.row;
	// can't delete the first or last entry as these should always be the same
	if row &gt; self.tblDimensions.fixedRows+1 and
	   row &lt; self.tblDimensions.rows then
		idx := self.tblDimensions.row - self.tblDimensions.fixedRows;
		create newPoints transient;

		thePoint := self.myCurrentProxyItemLayout.pointsPolygon[idx];
		theFrame := self.myParentForm.SHP_RORODeckDefinitionForm.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;
		theFrame.doRemovePoint(thePoint);		
		self.myCurrentProxyItemLayout.pointsPolygon.copy(newPoints);
		self.myCurrentProxyItemLayout.setPointsPolygon(newPoints);
		theFrame.doBtnRefreshClick();
		self.doListItemDimensions();
	endif;
epilog
	delete newPoints;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildRealItems" id="b1583d33-4c1b-4f3e-9615-a2b7fe399980">
        <source>doBuildRealItems();
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars

	aDeck 			: CM_Deck;
	aLift 			: CM_ROROLift;
	aRamp 			: CM_RORORamp;
	aMachine 		: CM_ROROEquipment;
	aGeneralItem	: CM_ROROGeneralArea;
	pxyLayout : CM_DeckItemLayout;
	realItems : ObjectSet;
begin

	self.cmbLayerRealItem.clear();
	self.cmbLayerRealItem.addItemObject(null,null);

	aDeck := self.myCurrentProxyDeck.pxyGetRealObject();
	
	// ### 28153 - If our proxy graphics have been linked to a real deck item then add them to the 
	//					collection so that they can be removed from the combo box for other proxy items.
	create realItems transient;
	foreach pxyLayout in self.myCurrentProxyLayer.allDeckItemLayouts  discreteLock do
		if pxyLayout.myDeckItem &lt;&gt; null and not pxyLayout.myDeckItem.isTransient then
			realItems.add(pxyLayout.myDeckItem);
		endif;
	endforeach;
	

	foreach aLift in aDeck.allLifts  discreteLock do
		self.doBuildRealItemsCheck(realItems, aLift);
	endforeach;

	foreach aMachine in aDeck.allMachinery  discreteLock do
		self.doBuildRealItemsCheck(realItems, aMachine);
	endforeach;
	
	foreach aGeneralItem in aDeck.allGeneralItems  discreteLock do
		self.doBuildRealItemsCheck(realItems, aGeneralItem);
	endforeach;
	
	foreach aRamp in aDeck.allRamps  discreteLock do
		self.doBuildRealItemsCheck(realItems, aRamp);
	endforeach;

epilog
	delete realItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildRealItemsCheck" id="a6ab1566-4ad9-40b8-9859-76273bbb69c1">
        <source>doBuildRealItemsCheck(_realItems : ObjectSet; _item : CM_DeckItem);
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
begin

		if _item.myLayout = null 
		or _item.myLayout = self.myCurrentProxyItemLayout 
		or _item.myLayout = self.myCurrentProxyItemLayout.pxyGetRealObject() then
			// PAR 28153 check if the proxy is linked to a real item
			if _realItems.includes(_item)  then
				if self.myCurrentProxyItemLayout.myDeckItem = _item then
					self.cmbLayerRealItem.addItemObject(_item.niceName,_item);
				endif;
			else
				self.cmbLayerRealItem.addItemObject(_item.niceName,_item);
			endif;
		endif;

epilog

end;</source>
        <Parameter name="_realItems" type="ObjectSet"/>
        <Parameter name="_item" type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="doCmbLayerTypeBuild" id="cac0ea8f-33c2-4995-a001-a1de4bb367d5">
        <source>doCmbLayerTypeBuild();
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	combo : CMUI_ComboBox;
begin
	combo := self.cmbLayerType;
	combo.clear;
	combo.sorted := true;
	combo.addItemWithData(app.getROROLayerTypeString(ROROLayerType_Structure), ROROLayerType_Structure);
	combo.addItemWithData(app.getROROLayerTypeString(ROROLayerType_Cargo), ROROLayerType_Cargo);
	combo.addItemWithData(app.getROROLayerTypeString(ROROLayerType_Lanes), ROROLayerType_Lanes);
	combo.listIndex := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayLayerLine" id="cfdea3e5-8955-45f0-8b7f-899368a5c2f0">
        <source>doDisplayLayerLine(_deckLayer : CM_DeckLayerLayout);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpBoo : Boolean;
	idx : Integer;
begin
	theTable := self.tblLayers;
	
	tmpBoo := _deckLayer.isVisible;
	idx := theTable.addItem(Tab &amp; _deckLayer.code);
	theTable.accessRow(idx).itemObject := _deckLayer;
	
	theTable.accessCell(idx, TblCol_Tick).inputType := Table.InputType_CheckBox;
	theTable.accessCell(idx, TblCol_Tick).text := tmpBoo.Integer.String;

	theTable.accessCell(idx, TblCol_Type).text := _deckLayer.String;

	theTable.accessCell(idx, TblCol_Up).text := 225.Character; 
	theTable.accessCell(idx, TblCol_Up).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Up).fontSize := 8;
	theTable.accessCell(idx, TblCol_Up).fontBold := false;

	theTable.accessCell(idx, TblCol_Down).text := 226.Character; 
	theTable.accessCell(idx, TblCol_Down).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Down).fontSize := 8;
	theTable.accessCell(idx, TblCol_Down).fontBold := false;
	


end;</source>
        <Parameter name="_deckLayer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="doDisplayLayers" id="73f44e8c-2ba1-4190-9802-574d47a8ea29">
        <updating/>
        <source>doDisplayLayers() updating;
/*

Date		    Who			Reason
25 March 2011	cnwas3	  Initial creation

*/

vars
	theTable : Table;
	tmpBoo : Boolean;
	idx, option : Integer;
	value : Boolean;
	tmpObj : Object;
	deckLayout : CM_DeckLayout;
	deckLayer, firstLayer : CM_DeckLayerLayout;
begin
	
	theTable := self.tblLayers;
	theTable.rows := 0;
	theTable.columns := 5;
	
	deckLayout := self.myCurrentProxyDeck.myDeckLayout;
	
	if deckLayout = null then
		app.msgBox(app.getErrorString(Please_select_deck), app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Layers), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach deckLayer in deckLayout.allDeckLayerLayouts discreteLock do
		//if deckLayer.type &lt;&gt; ROROLayerType_Cargo and deckLayer.type &lt;&gt; ROROLayerType_Lanes and deckLayer.type &lt;&gt; ROROLayerType_Structure then
		if not deckLayer.isDefinable() then
			continue;
		endif;
		self.doDisplayLayerLine(deckLayer);
		if firstLayer = null then
			firstLayer := deckLayer;
		endif;
	endforeach;
	deckLayer := firstLayer;
	
	if deckLayer &lt;&gt; null then
		self.myCurrentProxyLayer := deckLayer;
		
		self.beginNotification(self.myCurrentProxyLayer, EVENT_RORO_LAYER_UPDATE, Response_Continuous, null);

		self.doListItems(deckLayer);
		
		self.txtLayerCode.text := deckLayer.code;
		self.txtLayerDesc.text := deckLayer.description;
		self.txtLayerRemarks.text := deckLayer.remarks;
		self.cmbLayerType.text := app.getROROLayerTypeString(deckLayer.type);
		self.tblDimensions.rows := self.tblDimensions.fixedRows;
	endif;
	
	theTable.accessColumn(TblCol_Tick).width := 20;
	theTable.accessColumn(TblCol_Up).width := 15;
	theTable.accessColumn(TblCol_Down).width := 15;
	theTable.accessColumn(TblCol_Type).visible := false;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doInitDimensions" id="8c96e60a-2edf-45ea-bd3d-e4a8d67e480f">
        <source>doInitDimensions();
/*

Date		    Who			Reason
25 March 2011	cnwas3	  Initial creation

*/

vars
	theTable : CM_DataTable;
begin
	theTable := self.tblDimensions;
	theTable.rows := 0;
	theTable.columns:= 0;
	theTable.columns:= 3;
	theTable.addItem("" &amp; Tab &amp; app.getErrorString(X_in_metres) &amp; Tab &amp; app.getErrorString(Y_in_metres));
	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;		
	theTable.userInputEnabled := true;
	theTable.inputType := Table.InputType_SignedNumeric;
	theTable.accessColumn(2).inputType := Table.InputType_SignedNumeric;
	theTable.accessColumn(3).inputType := Table.InputType_SignedNumeric;
	// 28785 Dec 2011 limit decimals to 1 (polygons drawn to nearest 10cm so one decimal place of metres)
	theTable.accessColumn(2).decimals := 1;
	theTable.accessColumn(3).decimals := 1;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doItemCopy" id="204c4149-8516-4748-af4c-86de7e03572d">
        <updating/>
        <source>doItemCopy() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	pxyDeckItem : CM_DeckItemLayout;
begin
//	pxyDeckItem := self.tblLayerItems.accessRow(self.tblLayerItems.row).itemObject.CM_DeckItemLayout;
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		self.myCurrentProxyItemLayout.doCopyPxyItem(self.myCurrentProxyLayer, 50);
		self.doListItems(self.myCurrentProxyLayer);
		//self.doSelectFirstItem(self.tblLayerItems);
		self.doSelectLastItem(self.tblLayerItems);				// 19/10/2011 cnwmh5 #28154
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doItemDelete" id="800d806c-5a39-41e8-8829-dc9c908fb8f8">
        <updating/>
        <source>doItemDelete() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyGraphic : CM_DeckItemLayout;
	theReturn, idx, rows  : Integer;
	delObjs : ObjectArray;
	obj : Object;
	invalid : Boolean;
begin
	create delObjs transient;
	
	rows := self.tblLayerItems.rows;
	foreach idx in 1 to rows  do
		if self.tblLayerItems.accessCell(idx,TblCol_Name).selected then
			pxyGraphic := self.tblLayerItems.accessRow(idx).itemObject.CM_DeckItemLayout;
			delObjs.add(pxyGraphic);
		endif;
	
	endforeach;
	
	if delObjs.size = 0 then
		return;
	endif;
	
	theReturn := app.msgBox(app.getErrorString(Sure_that_want_delete) &amp; delObjs.size.String &amp; app.getErrorString(Selected_graphics) &amp; " ?",app.getErrorString(Confirm_delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_Yes then
	
		self.myCurrentProxyItemLayout := null;
		// PAR 27643
		self.txtItemCode.text := null;
		self.txtItemDesc.text := null;
		self.txtItemRemarks.text := null;

		
		on Exception do app.handleDeletedObject(exception, pxyGraphic, invalid);
		foreach obj in delObjs  discreteLock do
			pxyGraphic := obj.CM_DeckItemLayout;
			pxyGraphic.cleanupPxyReferences();
			delete pxyGraphic;
		endforeach;
 		self.doListItems(self.myCurrentProxyLayer);
		self.myCurrentProxyLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
		
	endif;
epilog
	delete delObjs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doItemNew" id="9277d65e-38ce-433e-8350-5b8b6fe1b638">
        <updating/>
        <source>doItemNew() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myCurrentProxyLayer.setProxyNewItem(); // PAR 27509
	self.doListItems(self.myCurrentProxyLayer);
	self.setCurrentItem(self.myCurrentProxyItemLayout);
	self.doSelectLastItem(self.tblLayerItems);			// 19/10/2011 cnwmh5 #28154
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLayerCopy" id="24f5064f-f801-4d8c-84d6-6b664bd4ec2b">
        <updating/>
        <source>doLayerCopy() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myCurrentProxyLayer &lt;&gt; null then
		self.myCurrentProxyLayer.doCopyPxyLayer(self.myCurrentProxyDeck.myDeckLayout);
		self.doDisplayLayers();
		//self.doSelectFirstItem(self.tblLayers);
		self.doSelectLastItem(self.tblLayers);						// 19/10/2011 cnwmh5 #28154
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLayerDelete" id="221334ef-5729-428c-bb99-1458c3d022e8">
        <updating/>
        <source>doLayerDelete() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	realDeck : CM_Deck;
begin

	if self.myCurrentProxyLayer &lt;&gt; null then
		 // PAR 27643 send a delete event
		realDeck := self.myCurrentProxyDeck.pxyGetRealObject();
		if realDeck &lt;&gt; null then
			realDeck.causeEvent(EVENT_RORO_LAYER_DELETE,true,self.myCurrentProxyLayer);
		endif;

		delete self.myCurrentProxyLayer;
		
		// PAR 27643
		self.myCurrentProxyLayer:= null;
		self.myCurrentProxyItemLayout:= null;
		self.tblLayerItems.rows := self.tblLayerItems.fixedRows;
		self.txtItemCode.text := null;
		self.txtItemDesc.text := null;
		self.txtItemRemarks.text := null;
		self.txtLayerCode.text := null;
		self.txtLayerDesc.text := null;
		self.txtLayerRemarks.text := null;
		
		self.doDisplayLayers();

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLayerNew" id="aa01f31b-e7c9-4e62-b581-02f5ff2b2fca">
        <updating/>
        <source>doLayerNew() updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyLayer : CM_DeckLayerLayout;
	realDeck : CM_Deck;
	pxyItem : CM_DeckItemLayout;
begin
	create pxyLayer transient;
	pxyLayer.setProxy(app.getErrorString(Layer) &amp; " 1", app.getErrorString(Layer) &amp; " " &amp; app.getErrorString(One), null, self.myCurrentProxyDeck.myDeckLayout, true,ROROLayerType_Structure);
		
	// ### BASIC GRAPHIC
	pxyItem := pxyLayer.setProxyNewItem(); 
	self.setCurrentItem(pxyItem);// PAR 27509

	realDeck := self.myCurrentProxyDeck.pxyGetRealObject();
	if realDeck &lt;&gt; null then
		realDeck.causeEvent(EVENT_RORO_LAYER_CREATE,true,pxyLayer); // PAR 27515
	endif;
	
	self.doDisplayLayers();
	
	self.doSelectLastItem(self.tblLayers);			// 19/10/2011 cnmwh5 #28154
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doListItemDimensions" id="21fc3545-460b-4421-b615-6f0f3a253c82">
        <source>doListItemDimensions();
// ---------------------------------------------------------------------------
// Created:     11 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 01/08/2011		cnwmh5			#27924 - Change to use asStringJMT to handle Locales
// ---------------------------------------------------------------------------

vars
	theX, theY, b, c, idx : Integer;
	roroGraphic : CM_DeckItemLayout;
	point, cmX, cmY : Decimal[12,1];	// 28785 Dec 2011 limit decimals to 1 (polygons drawn to nearest 10cm so one decimal place of metres)
begin

	roroGraphic := self.myCurrentProxyItemLayout;
	
	self.tblDimensions.rows := self.tblDimensions.fixedRows;

	foreach point in roroGraphic.myPolygonCMs do
		c := c + 1;
		if c mod 2 = 0 then // Y
			cmY := point;
			b := b + 1;
			
			idx := self.tblDimensions.addItem(b.asStringJMT &amp; Tab &amp; cmX.asStringJMT &amp; Tab &amp; cmY.asStringJMT);	// 01/08/2011 cnwmh5 #27924
			self.tblDimensions.accessCell(idx,2).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			self.tblDimensions.accessedCell.maxLength := ((c-1) * 100); // Bodge to store decimal index
			self.tblDimensions.accessCell(idx,3).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			self.tblDimensions.accessedCell.maxLength := (c * 100); // Bodge to store decimal index
		
		else // X
			cmX := point;
		endif;
	

	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListItemLine" id="71918a33-7d97-4477-b6af-96111aa87f11">
        <source>doListItemLine(_graphic : CM_DeckItemLayout);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpBoo : Boolean;
	idx : Integer;
begin
	theTable := self.tblLayerItems;
	
	tmpBoo := _graphic.isVisible;
	idx := theTable.addItem(Tab &amp; _graphic.code);
	theTable.accessRow(idx).itemObject := _graphic;
	
	theTable.accessCell(idx, TblCol_Tick).inputType := Table.InputType_CheckBox;
	theTable.accessCell(idx, TblCol_Tick).text := tmpBoo.Integer.String;

	theTable.accessCell(idx, TblCol_Type).text := _graphic.String;

	theTable.accessCell(idx, TblCol_Up).text := 225.Character; 
	theTable.accessCell(idx, TblCol_Up).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Up).fontSize := 8;
	theTable.accessCell(idx, TblCol_Up).fontBold := false;

	theTable.accessCell(idx, TblCol_Down).text := 226.Character; 
	theTable.accessCell(idx, TblCol_Down).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Down).fontSize := 8;
	theTable.accessCell(idx, TblCol_Down).fontBold := false;
	
	self.doSetGraphicTableColour(_graphic);

end;</source>
        <Parameter name="_graphic" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doListItems" id="171689dd-2019-4d41-9e4c-988ac2a1cdb3">
        <source>doListItems(_layer : CM_DeckLayerLayout);
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTable : Table;
	tmpBoo : Boolean;
	idx, option : Integer;
	value : Boolean;
	tmpGraphic : CM_Graphic;
begin
	
	theTable := self.tblLayerItems;
	theTable.rows := 0;
	theTable.columns := 5;
	self.txtItemCode.text := null;
	self.txtItemDesc.text := null;
	self.txtItemRemarks.text := null;
	
	foreach tmpGraphic in _layer.allDeckItemLayouts discreteLock do
		self.doListItemLine(tmpGraphic.CM_DeckItemLayout);

	endforeach;
	
	theTable.accessColumn(TblCol_Tick).width := 20;
	theTable.accessColumn(TblCol_Up).width := 15;
	theTable.accessColumn(TblCol_Down).width := 15;
	theTable.accessColumn(TblCol_Type).visible := false;
	

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="doReOrderGraphicsInLayer" id="f9b2ef37-53c7-477e-bef7-74923ed35ca2">
        <source>doReOrderGraphicsInLayer();
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars
	objs : CM_RORODeckItemLayoutArray;
	obj : Object;
	idx, st, en : Integer;
begin
	st := self.tblLayerItems.fixedRows + 1;
	en := self.tblLayerItems.rows;
	
	create objs transient;
	foreach idx in st to en  do
		obj := self.tblLayerItems.accessRow(idx).itemObject;
		
		objs.add(obj.CM_DeckItemLayout);
	endforeach;
	
	self.myCurrentProxyLayer.matchOrderOfItemLayouts(objs);
	
epilog
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectFirstItem" id="22729bf2-f233-4913-997c-456e6ee87dae">
        <source>doSelectFirstItem(_table : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _table.rows &lt;= _table.fixedRows then
		return;
	endif;
	
	_table.row := _table.fixedRows + 1;
	
	_table.click(_table);
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSelectLastItem" id="d482ea6d-b84c-41dd-b766-093ba191dfb4">
        <source>doSelectLastItem(_table : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _table.rows &lt;= _table.fixedRows then
		return;
	endif;
	
	_table.row := _table.rows;
	_table.column := 2;
	
	_table.click(_table);
	
	_table.deselectAll();
	_table.selectRow(_table.row, false);
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetGraphicTableColour" id="6104bd6b-4c83-47f2-be2d-0744501c505b">
        <source>doSetGraphicTableColour(_graphic : CM_DeckItemLayout);
// ---------------------------------------------------------------------------
// Created:     06 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	table : CM_DataTable;
begin
	table := self.tblLayerItems;
	
	if table.findObjectInRow(_graphic, idx) then
		table.accessCell(idx,2).backColor := _graphic.drawFillColour;
		table.accessedCell.foreColor := _graphic.drawFillColour.getInverseColour();
	endif;
	
epilog

end;</source>
        <Parameter name="_graphic" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doShowItemDimensions" id="063228a6-abfb-42ed-b418-e06e63605762">
        <updating/>
        <source>doShowItemDimensions() updating;
/*

Date		    Who			Reason
25 March 2011	cnwas3	  Initial creation

*/

vars

begin
	if not self.grpItemDimension.visible then
		self.width := self.ITEM_DIMENSION_WIDTH;
		self.grpItemDimension.visible := true;
		self.btnItemDimension.caption := self.CONTRACT_STRING;
		self.btnLayerItems.caption := self.CONTRACT_STRING;
		self.btnLayerItems.enabled := false;
	else
		self.width := self.LAYER_ITEM_WIDTH;
		self.grpItemDimension.visible := false;
		self.btnItemDimension.caption := self.EXPAND_STRING;
		self.btnLayerItems.caption := self.CONTRACT_STRING;
		self.btnLayerItems.enabled := true;		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowLayerItems" id="14605e00-937b-417c-a172-2916e403c9d2">
        <updating/>
        <source>doShowLayerItems() updating;
/*

Date		    Who			Reason
25 March 2011	cnwas3	  Initial creation

*/

vars
	deckLayer : CM_DeckLayerLayout;

begin
	if not self.grpLayerItems.visible then
		self.doTblLayerClick();
		
		self.width := self.LAYER_ITEM_WIDTH;
		self.grpLayerItems.visible := true;
		self.btnLayerItems.caption := self.CONTRACT_STRING;
		self.btnItemDimension.caption := self.EXPAND_STRING;
	else
		self.width := self.DECK_LAYER_WIDTH;
		self.grpLayerItems.visible := false;
		self.btnLayerItems.caption := self.EXPAND_STRING;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblGraphicClick" id="9d1d8003-b5f3-4420-9f6c-71b77abbab4d">
        <updating/>
        <source>doTblGraphicClick() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theCol, theRow : Integer;
	deckItem : CM_DeckItemLayout;
		theArea : CM_TerminalArea;
	aPoint : Point;
	idx,b : Integer;
	aGraphic : CM_Graphic;
	theX, theY : Integer;
	tickValue : Boolean;
begin
	theRow := self.tblLayerItems.row;
	if theRow &lt;= self.tblLayerItems.fixedRows then
		return;
	endif;
	
	theCol := self.tblLayerItems.column;
	deckItem := self.tblLayerItems.accessRow(theRow).itemObject.CM_DeckItemLayout;
	
	if theCol = self.TblCol_Up then
		if theRow &gt; 1 then
			self.tblLayerItems.moveRow(theRow,theRow - 1);
			self.doReOrderGraphicsInLayer();
			self.myCurrentProxyLayer.causeEvent(EVENT_RORO_LAYER_SELECT,true,null);
		endif;
	elseif theCol = self.TblCol_Down then
		if theRow &lt; self.tblLayerItems.rows then	
			self.tblLayerItems.moveRow(theRow,theRow + 1);
			self.doReOrderGraphicsInLayer();
			self.myCurrentProxyLayer.causeEvent(EVENT_RORO_LAYER_SELECT,true,null);
		endif;
	// VISIBLE
	elseif theCol = self.TblCol_Tick then
		tickValue := self.tblLayerItems.accessCell(theRow, self.TblCol_Tick).text.Integer.Boolean;
		deckItem.setProxyVisible(tickValue);
		deckItem.causeEvent(EVENT_RORO_ITEM_VISIBLE,true,null);
	
	elseif theCol = TblCol_Name then
		self.setCurrentItem(deckItem);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblLayerClick" id="59e01cf1-2172-42f1-9de8-32b8eae55132">
        <updating/>
        <source>doTblLayerClick() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theCol, theRow : Integer;
	shipLayer : CM_DeckLayerLayout;
	tickValue : Boolean;
	realDeck : CM_Deck;
begin
	theRow := self.tblLayers.row;
	if theRow &lt;= self.tblLayers.fixedRows then
		return;
	endif;
	theCol := self.tblLayers.column;

	shipLayer := self.tblLayers.accessRow(theRow).itemObject.CM_DeckLayerLayout;

	
	// MOVE UP
	if theCol = self.TblCol_Up and theRow &gt; 1 then
		self.tblLayers.moveRow(theRow,theRow - 1);
		shipLayer.moveLayer(true);

	endif;
	
	// MOVE DOWN
	if theCol = self.TblCol_Down and theRow &lt; self.tblLayers.rows then	
		self.tblLayers.moveRow(theRow,theRow + 1);
		shipLayer.moveLayer(false);

	endif;
	
	// MAKE VISIBLE
	if theCol = self.TblCol_Tick  then
		tickValue := self.tblLayers.accessCell(theRow, self.TblCol_Tick).text.Integer.Boolean;
		shipLayer.setProxyIsVisible(tickValue);
		
		// ### tell parent form that we have selected a layer
		shipLayer.causeEvent(EVENT_RORO_LAYER_VISIBLE,true,null);
	endif;
	
	// Select Layer
	if theCol = TblCol_Name then
		if self.myCurrentProxyLayer &lt;&gt; null then
			self.endNotification(self.myCurrentProxyLayer,EVENT_RORO_LAYER_UPDATE);
		endif;
		self.myCurrentProxyLayer := shipLayer;
		self.beginNotification(self.myCurrentProxyLayer, EVENT_RORO_LAYER_UPDATE, Response_Continuous, null);
		self.doListItems(shipLayer);
		
		self.txtLayerCode.text := shipLayer.code;
		self.txtLayerDesc.text := shipLayer.description;
		self.txtLayerRemarks.text := shipLayer.remarks;
		self.cmbLayerType.text := app.getROROLayerTypeString(shipLayer.type);
		
		realDeck := self.myCurrentProxyDeck.pxyGetRealObject();
		
		// ### tell parent form that we have selected a layer
		self.myCurrentProxyLayer.causeEvent(EVENT_RORO_LAYER_SELECT,true,null);
		
		self.tblDimensions.rows := self.tblDimensions.fixedRows;
		self.txtLayerCode.setFocus();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNotifyLayers" id="d84028df-e969-45bd-8f8f-32d32b36cefe">
        <updating/>
        <source>doUserNotifyLayers(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*
Purpose:	the layers are maintained on a seperate form		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/


vars
	layerFrame : CMUI_PointDrawingFrame;
	deckItem : CM_DeckItemLayout;
begin

	if eventType = EVENT_RORO_ITEM_UPDATE then
		// we only register for the current deck item layout
		// so it must be for that
		// PAR 27526 this is overriding the arrowing through  the dimensions table, so the cursor moving around does not work	self.doListItemDimensions();
		
		// PAR 27773 made a change here. EVENT_RORO_ITEM_UPDATE is used by lots of updates, 
		//				for the one via the dimensions table we include the layout in the UserInfo so we 
		//				know it is from the dimensions table, normally this is null. If not null then ignore 
		//				as a refresh of the table stops the arrow key between cells working
		if userInfo = null then
			self.doListItemDimensions();
		endif;
	elseif eventType = EVENT_RORO_LAYER_UPDATE then
		// we only register for the current deck layer
		// so it must be for that
		self.doListItems(self.myCurrentProxyLayer);
	elseif eventType = EVENT_RORO_ITEM_SELECT then
		if userInfo.isKindOf(CM_DeckItemLayout) then
			deckItem := userInfo.CM_DeckItemLayout;
			self.setCurrentItem(deckItem);
		endif;
		
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="enableControlsMultiSelect" id="89999931-2a82-402f-9555-43ed4450024f">
        <source>enableControlsMultiSelect(_frameMode : Integer);
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	enabled : Boolean;
begin

	enabled := (_frameMode &lt;&gt; CMUI_PointDrawingFrame.Mode_MultiSelect);
	
	self.btnCopyDeckLayer.enabled := enabled;
	self.btnCopyItemDim.enabled := enabled;
	self.btnCopyLayerItem.enabled := enabled;
	self.btnDltDeckLayer.enabled := enabled;
	self.btnDltItemDim.enabled := enabled;
	self.btnNewDeckLayer.enabled := enabled;
	self.btnNewItemDim.enabled := enabled;
	self.btnNewLayerItem.enabled := enabled;
	

epilog

end;</source>
        <Parameter name="_frameMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="5349f8b6-a13e-4dd4-a2b9-afbf7fcdf7e5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
Date		    Who			Reason
16 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin

	if keyCode = 9 then	// Tab key
		
		if app.activeControl.parent = self.tblDimensions then	
			
			if self.tblDimensions.column = self.tblDimensions.columns then
				if self.tblDimensions.row = self.tblDimensions.rows then
					self.tblDimensions.deselectAll();
					inheritMethod(keyCode, shift);
					return;
				endif;				
				// 29506 May 2012 table changes not being saved from tabbing between entries
				self.tblDimensions_queryRowColChg(self.tblDimensions, self.tblDimensions.sheet, self.tblDimensions.row, self.tblDimensions.column);
				self.tblDimensions.row := self.tblDimensions.row + 1;
				self.tblDimensions.column := 2;
				self.tblDimensions.deselectAll();
				self.tblDimensions.click(self.tblDimensions);
				self.tblDimensions.setFocus();
				keyCode := null;
				return;	
			else				
				// 29506 May 2012 table changes not being saved from tabbing between entries
				self.tblDimensions_queryRowColChg(self.tblDimensions, self.tblDimensions.sheet, self.tblDimensions.row, self.tblDimensions.column);
				self.tblDimensions.column := self.tblDimensions.column + 1;				
				self.tblDimensions.deselectAll();
				self.tblDimensions.click(self.tblDimensions);
				self.tblDimensions.setFocus();
				keyCode := null;
				return;	
			endif;
			
		endif;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuInspectDeck_click" id="b691b8c1-6951-45f9-8cf2-cd1bb30523fd">
