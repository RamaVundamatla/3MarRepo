/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2025	navpw1	Initial creation JIRA: MTN-30307

*/

vars

begin
	//If loggign level is higher than the current logging level then just save to Unit test result otherwise call app.writeLog
	if _messageLevel &gt; app.logLevel and _message &lt;&gt; null then
		app.log(_message);
	endif;
	
	app.writeLog(_message, _messageLevel);
	
epilog

