    <JadeMethod name="trxUpdateToDoTaskTs" id="5ddf7af4-6c17-4ab3-9fdc-e2d2fd4a4787">
        <updating/>
        <source>trxUpdateToDoTaskTs(_toDoTaskCode : Integer; _ts : TimeStamp; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 31 January 2006 by cnwdvb1
// -------------------------------------------
vars

	ti : CM_TrackedItem;

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	ti := app.myValRT.valMediatorTI(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
		
	beginTransaction;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	app.myUtlRT.utlUpdateToDoTaskTs(ti, _toDoTaskCode, _ts, _passport);
	
	return;
	
epilog

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateToDoTasksForTI" id="311bdeca-f217-459e-a9e9-784c03575c0f">
        <updating/>
        <source>trxUpdateToDoTasksForTI(_dto : DTO_EnquiryGradingTasks; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	allTasksToAdd,
	allTasksToComplete,
	allTasksToRemove		: IntegerArray;
	ti						: CM_TrackedItem;

begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	ti := app.myValRT.valMediatorTI(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	create allTasksToAdd transient;
	create allTasksToComplete transient;
	create allTasksToRemove transient;
	
	_dto.extrapolateToDoTaskStates(allTasksToAdd, allTasksToComplete, allTasksToRemove);
	
	beginTransaction;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
		
	app.myUtilityUA.utlUpdateTIToDoTasks(allTasksToAdd, allTasksToComplete, allTasksToRemove, ti, _passport);
	
	_passport.doDeferredUpdates();
	
	return;
	
epilog

	self.finaliseActivityWithPassport(_passport);
	delete allTasksToAdd;
	delete allTasksToComplete;
	delete allTasksToRemove;

end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
