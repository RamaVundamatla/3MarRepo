    <JadeMethod name="hideSelectedControls" id="d389fa38-4c60-46ff-bd38-1285ba14d960">
        <updating/>
        <source>hideSelectedControls() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2012	cnwndl1	Initial creation
12/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	index : Integer;
	control : Control;

begin
	
	// initially hide all.
	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_FieldFrame ) then
			control.CMUI_FieldFrame.isHidden := true;
		endif;
	endforeach;
	
	//and
	self.btnCargoId.visible := false;
	
	//Now show the ones we want.
	self.cmbType.isHidden := false;
	self.txtCargoID.isHidden := false;
	self.cmbImexStatus.isHidden := false;
	self.cmbOperator.isHidden := false;
	//self.txtTotalWeight.isHidden := false;					// PAR #31155
	self.tblTotalWeight.isHidden := false;						// PAR #31155
	self.cmbISOType.isHidden := false;
	self.cmbCommodity.isHidden := false;
	self.cmbVoyage.isHidden := false;
	self.cmbDischarge.isHidden := false;
	self.cmbConsignor.isHidden := false;
	
	
	self.doShowPicture;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
