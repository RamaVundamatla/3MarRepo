<Class name="CMUI_FormConfigAgent" id="aa5c1fe6-6191-41fc-9fbd-1e9d1daea04f">
    <superclass name="CMUI_Transient"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="uicommon"/>
    <ImplicitInverseRef name="myFormConfiguration" id="c25200f3-18da-4f03-8ccf-a9c2baa71c5b">
        <embedded/>
        <type name="CM_FormConfigForm"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="customiseForm" id="77b0a7fe-3894-4561-b6ef-23abadabd5d9">
        <source>customiseForm(_form :CM_BaseForm input);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item	:CM_FormConfigItem;
	control	:Control;
begin
	foreach item in self.getFormConfiguration.allConfigItems do
		if not item.isKindOf (CM_FormConfigControl) then
			continue;
		endif;
		
		control := _form.getControl (item.CM_FormConfigControl.controlName);
		
		if control = null then
			continue;	// oops
		endif;
		
		self.setControlProperties (control, item);
	endforeach;

epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFormConfiguration" id="84061f34-9c61-4033-9d64-259fb30d576e">
        <source>getFormConfiguration():CM_FormConfigForm abstract, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
</source>
        <abstract/>
        <access>protected</access>
        <ReturnType type="CM_FormConfigForm"/>
    </JadeMethod>
    <JadeMethod name="setControlProperties" id="4dd1b88c-fc51-4b52-98fb-e4c8b3026538">
        <source>setControlProperties(_control :Control input; _item :CM_FormConfigItem)protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _item.isKindOf (CM_FormConfigLabel) then
		_control.Label.caption	:= _item.CM_FormConfigLabel.caption;
	elseif _item.isKindOf (CM_FormConfigButton) then
		_control.Button.caption	:= _item.CM_FormConfigButton.caption;
	endif;
	
	_control.visible	:= _item.CM_FormConfigControl.visible;
	_control.left		:= _item.left;
	_control.top		:= _item.top;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_item" type="CM_FormConfigItem"/>
    </JadeMethod>
    <JadeMethod name="setMyFormConfiguration" id="54ef1f36-6e26-4769-9793-5dd242404d18">
        <updating/>
        <source>setMyFormConfiguration(_config :CM_FormConfigForm)updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myFormConfiguration	:= _config;
epilog

end;</source>
        <Parameter name="_config" type="CM_FormConfigForm"/>
    </JadeMethod>
</Class>
