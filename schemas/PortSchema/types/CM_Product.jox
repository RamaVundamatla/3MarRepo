    <JadeMethod name="setProductDefaults" id="90920640-8b2a-41ae-84d6-6742d47c11d8">
        <source>setProductDefaults(_cargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     29 October 2002		cnwth2	
//
// Purpose:     Sets the product attributes values from the cargoTypes default values
//			 
// Chaned On	By			Reason
// ----------   ----------  --------------------------------------------------
// 16/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	height, width, length, weight, volume, density	: CM_MeasurementType;				// PAR #31155
	

begin
	if _cargoType = null then
		return;
	endif;
	
	length := app.getDefaultMeasurementForType(Type_Length);	//10 Sep 2013	NDL	Par 32172
	width := app.getDefaultMeasurementForType(Type_Width);		//10 Sep 2013	NDL	Par 32172
	height := app.getDefaultMeasurementForType(Type_Height);	//10 Sep 2013	NDL	Par 32172
	weight := app.getDefaultMeasurementForType(Type_Weight);			// PAR #31155
	volume := app.getDefaultMeasurementForType(Type_Volume);			// PAR #31155
	density := app.getDefaultMeasurementForType(Type_Density);			// PAR #31155
	
	self.myWidthString.setValue(_cargoType.defaultWidthString);
	self.myHeightString.setValue(_cargoType.defaultHeightString);
	self.myLengthString.setValue(_cargoType.defaultLengthString);
	
	self.myWidth.setValue(_cargoType.defaultWidth);
	self.myHeight.setValue(_cargoType.defaultHeight);
	self.myLength.setValue(_cargoType.defaultLength);
	self.myWidth.setMyMeasurementType(width);							// PAR #31155
	self.myHeight.setMyMeasurementType(height);							// PAR #31155
	self.myLength.setMyMeasurementType(length);							// PAR #31155
	
	self.myQuantity.setValue(_cargoType.defaultQuantity);
	self.myVolume.setValue(_cargoType.defaultVolume);
	self.myDensityDec.setValue(_cargoType.defaultDensity);				// ### TFS 52193 22Nov2021 NAVPW1
	self.myWeight.setValue(_cargoType.defaultWeight);
	self.myDensityDec.setMyMeasurementType(density);					// PAR #31155	// ### TFS 52193 22Nov2021 NAVPW1
	self.myWeight.setMyMeasurementType(weight);							// PAR #31155
	self.myVolume.setMyMeasurementType(volume);							// PAR #31155
	
	self.myType.setValue(_cargoType.defaultType);
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="98db3f0d-ac1f-4219-ade9-8f8673f5223d">
        <updating/>
        <source>setProxy(_cargoType		: CM_CargoType; 
		_operator 		: CM_Operator;
		_defaultCommodityCode	: String;
		_productGroup	: CM_ProductGroup;
		_handlingType 	: CM_HandlingType;
		_handlingSubType : CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414
		_storageCharge	: Decimal;
		_code, _description : String;
		_colour			: Integer;
		_reefer			: Boolean;
		_powered		: Boolean;
		_integral		: Boolean;
		_fan			: Boolean;
		_isNotAvail : 	Boolean;
		_autoVolumeCalculate : Boolean;	//10 June 2016	NDL	TFS 2141
		_allowAutoWeightCalc : Boolean	//18 Jan 2018	NDL	TFS 36697
		) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - new parameters reefer, powered, integral and fan
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code						:=	_code;
	self.description				:=	_description;

	self.myCargoType				:=	_cargoType;
	if _cargoType &lt;&gt; null then
		self.myCargoTypeExtBreakBulkGen	:=	_cargoType.myCargoExtension.CM_CargoTypeExtBreakBulkGen;
	endif;
	self.myHandlingType 			:=	_handlingType;
	self.myHandlingSubType 			:=	_handlingSubType;	//31 Mar 2017	NDL	TFS 3414
	self.myOperator					:=	_operator;
	self.defaultCommodityCode		:=	_defaultCommodityCode;	// ccms 1080 PAR19704. July 2009
	self.myProductGroup				:=	_productGroup;
	self.storageCharge  			:=	_storageCharge;
	self.colour						:=	_colour;
	
	// CCMS 1007
	self.isReefer					:=	_reefer;
	self.isPowered					:=	_powered;
	self.isIntegral					:=	_integral;
	self.isFan						:=	_fan;
	self.isNotActive 				:= _isNotAvail; //epr TFS 1846 18/4/16
	self.autoVolumeCalculate 		:= _autoVolumeCalculate;	//10 June 2016	NDL	TFS 2141
	self.autoWeightCalculate 		:= _allowAutoWeightCalc;	//18 Jan 2018	NDL	TFS 36697
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_defaultCommodityCode" type="String"/>
        <Parameter name="_productGroup" type="CM_ProductGroup"/>
        <Parameter name="_handlingType" type="CM_HandlingType"/>
        <Parameter name="_handlingSubType" type="CM_HandlingSubType"/>
        <Parameter name="_storageCharge" type="Decimal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_powered" type="Boolean"/>
        <Parameter name="_integral" type="Boolean"/>
        <Parameter name="_fan" type="Boolean"/>
        <Parameter name="_isNotAvail" type="Boolean"/>
        <Parameter name="_autoVolumeCalculate" type="Boolean"/>
        <Parameter name="_allowAutoWeightCalc" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyAsSystemDummyProduct" id="eb974570-eddf-469b-864b-7f0a75875ee1">
        <updating/>
        <source>setProxyAsSystemDummyProduct(_pxyCargoType : CM_CargoType) updating;
/* ---------------------------------------------------------------------------
Created:	23 October 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
------------------------------------------------------------------------------
30/11/2009		cnwdap1	CCMS 1007 - new parameters for CM_Product::setProxy method
10/03/2010		cnwdap1	PAR #22938 set default reefer parameters from self
*/
vars
	handlingType	: CM_HandlingType;
	handlingSubType : CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414

begin

	if _pxyCargoType.myDefaultHandlingType &lt;&gt; null then
		handlingType := _pxyCargoType.myDefaultHandlingType;
	else
		handlingType := app.myRoot.allHandlingTypes.first;
	endif;
	
	//31 Mar 2017	NDL	TFS 3414
	if handlingType &lt;&gt; null then
		handlingSubType := handlingType.getDefaultSubHandlingType;
	endif;

	self.setProxy(	_pxyCargoType,	//CargoType; 
					null, 			//operator
					null,
					null,			//_productGroup
					handlingType,
					handlingSubType,	//31 Mar 2017	NDL	TFS 3414
					null,			//_storageCharge
					self.code, self.description,	//code and Description
					null,			//colour
					self.isReefer,	// PAR #22938	false,	// reefer
					self.isPowered,	// PAR #22938	false,	//powered
					self.isIntegral,// PAR #22938	false,	//integral
					self.isFan,		// PAR #22938	false	//fan
					false,
					false,
					false
					);
						
	self.setMyCargoType(null);	// because it won't be included in cargoType.allProducts collection - should be not inversed.


end;</source>
        <Parameter name="_pxyCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxyEdiTIAttributes" id="ad58a9e4-292b-4860-a798-2ca986178f1e">
        <updating/>
        <source>setProxyEdiTIAttributes(_ediTI : CM_EDIProductTI input;_passport : CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height
//07 Oct 2024	navdap1	MTN-19242 TPT| User Defined Cargo Sub Type Uploads
//09 Oct 2924 	navsaa30 MTN-19242 TPT| User Defined Cargo Sub Type Uploads
vars
	rangeErrorStr		: String;
	prodAttrsViewable	: StringArray;
	row					: Integer;	
	rangeStr,
	prodAttrStr			: String;
	prodAttr			: CM_ProductAttr;
	cargoTypeObj		: CM_CargoType;
	tmpValue			: Any;
	measureType			: CM_MeasurementType;
begin
	//set prodAttribute references
	cargoTypeObj		:=	self.myCargoType;
	prodAttrsViewable	:=	cargoTypeObj.allAttributesOnProduct;
	foreach prodAttrStr in prodAttrsViewable do
		if prodAttrStr = ETRow_MyWidth then
			prodAttr := self.myWidth;
			//its OK if these are null - at the gate in stage they can over-ride any value set anyway
			tmpValue := _ediTI.width;
			prodAttr.setValue(tmpValue);
			prodAttr.clearRange();
			// MTN-19242 start
			measureType := self.getEDIAttrMeasure(_ediTI, prodAttrStr);
			if measureType &lt;&gt; null then
				prodAttr.setMyMeasurementType(measureType);
				prodAttr.setDisplayName("Width (" &amp; measureType.shortName &amp; ")");
			endif;
			// MTN-19242 end
		elseif prodAttrStr = ETRow_MyLength then
			prodAttr := self.myLength;
			//its OK if these are null - at the gate in stage they can over-ride any value set anyway
			tmpValue := _ediTI.length;
			prodAttr.setValue(tmpValue);
			prodAttr.clearRange();
			measureType := self.getEDIAttrMeasure(_ediTI, prodAttrStr);   	//9/10/2024  navsaa30 #19242
			if measureType &lt;&gt; null then
				prodAttr.setMyMeasurementType(measureType);
				prodAttr.setDisplayName("Length (" &amp; measureType.shortName &amp; ")");
			endif;
		elseif prodAttrStr = ETRow_MyHeight then		//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height
			prodAttr := self.myHeight;
			//its OK if these are null - at the gate in stage they can over-ride any value set anyway
			tmpValue := _ediTI.height;
			prodAttr.setValue(tmpValue);
			prodAttr.clearRange();
			measureType := self.getEDIAttrMeasure(_ediTI, prodAttrStr);		//9/10/2024  navsaa30 #19242
			if measureType &lt;&gt; null then
				prodAttr.setMyMeasurementType(measureType);
				prodAttr.setDisplayName("Height (" &amp; measureType.shortName &amp; ")");
			endif;
		elseif prodAttrStr = ETRow_MyWeight then
			prodAttr := self.myWeight;
			//its OK if these are null - at the gate in stage they can over-ride any value set anyway
			tmpValue := _ediTI.weight;
			prodAttr.setValue(tmpValue);
			prodAttr.clearRange();
			measureType := self.getEDIAttrMeasure(_ediTI, prodAttrStr);		//9/10/2024  navsaa30 #19242
			if measureType &lt;&gt; null then
				prodAttr.setMyMeasurementType(measureType);
				prodAttr.setDisplayName("Weight (" &amp; measureType.shortName &amp; ")");
			endif;																	
		elseif prodAttrStr = ETRow_MyVolume then
			prodAttr := self.myVolume;
			//its OK if these are null - at the gate in stage they can over-ride any value set anyway
			tmpValue := _ediTI.volume;
			prodAttr.setValue(tmpValue);
			prodAttr.clearRange();
			measureType := self.getEDIAttrMeasure(_ediTI, prodAttrStr);		//9/10/2024  navsaa30 #19242
			if measureType &lt;&gt; null then
				prodAttr.setMyMeasurementType(measureType);
				prodAttr.setDisplayName("Volume (" &amp; measureType.shortName &amp; ")");
			endif;																	
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_ediTI" type="CM_EDIProductTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyEdiTIData" id="28532d1e-1435-4773-80fe-e814f5db48ca">
        <updating/>
        <source>setProxyEdiTIData(_ediTI: CM_EDIProductTI input;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17 Jun 2008	cnwkpd1	PAR #17014 - Allow null operator products

*/

vars
	cargoType 		: CM_CargoType;
	handlingType	: CM_HandlingType;
	productGroup 	: CM_ProductGroup;
	operator 		: CM_Operator;
	cargoTypeID		: Integer;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code			:=	_ediTI.code;
//	self.description	:=	_ediTI.description;	// cnwrl1 14/07/2009 PAR 20247 - what it was
	self.description	:=	_ediTI.description[ 1 : self.description.maxLength ];
	
	if _ediTI.handlingType = 0 then
		handlingType	:=	app.myRoot.allHandlingTypes[2];	
	else 
		handlingType	:=	app.myRoot.allHandlingTypes[_ediTI.handlingType];	
	endif; 
	self.myHandlingType :=	 handlingType;
	
	cargoTypeID := app.myRoot.getCargoTypeIDFromDescription(_ediTI.cargoTypeDescr);
	if cargoTypeID = null then
		cargoTypeID := app.myRoot.getCargoTypeIDFromAbbrev(_ediTI.cargoTypeDescr);
	endif;
	cargoType := app.myRoot.allCargoTypesById[cargoTypeID];
	
	if cargoType &lt;&gt; null then
		self.myCargoType				:=   cargoType;
		self.myCargoTypeExtBreakBulkGen	:=	 cargoType.myCargoExtension.CM_CargoTypeExtBreakBulkGen;
	endif;
	
	if _ediTI.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[_ediTI.operatorCode];
	else 
		operator := null;		// PAR #17014 - was app.myRoot.allOperators["MSC"];
	endif; 
	
	self.myOperator 	:= operator;
	
	if _ediTI.productGroup &lt;&gt; null then
		productGroup := cargoType.allProductGroups[_ediTI.productGroup];
	endif;
	self.myProductGroup	:=	 productGroup;
	
	//26 Jan 2018	NDL	TFS 36697
	self.autoWeightCalculate := _ediTI.autoWeightCalculate;
	
end;</source>
        <Parameter name="_ediTI" type="CM_EDIProductTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyProdAttributes" id="30b9a3d2-f2cc-46d0-8d80-69c7b78237cf">
        <source>setProxyProdAttributes(_realPro : CM_Product);
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     sets all of the product attribute references from a real product
//				The set proxy method of the product attributes also creates pxyCodes for the
//				CM_ProductAttr.allCodes dict
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myWidthString.setProxy(_realPro.myWidthString);
	self.myHeightString.setProxy(_realPro.myHeightString);
	self.myLengthString.setProxy(_realPro.myLengthString);
	
	self.myWidth.setProxy(_realPro.myWidth);
	self.myHeight.setProxy(_realPro.myHeight);
	self.myLength.setProxy(_realPro.myLength);
	
	self.myQuantity.setProxy(_realPro.myQuantity);
	self.myVolume.setProxy(_realPro.myVolume);
	self.myDensityDec.setProxy(_realPro.myDensityDec);		// ### TFS 52193 22Nov2021 NAVPW1
	self.myWeight.setProxy(_realPro.myWeight);
	
	self.myType.setProxy(_realPro.myType);
end;</source>
        <Parameter name="_realPro" type="CM_Product"/>
    </JadeMethod>
