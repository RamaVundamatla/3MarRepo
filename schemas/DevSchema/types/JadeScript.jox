    <JadeMethod name="specialStow" id="cb080082-383a-44a7-a078-2ff11d9d612e">
        <source>specialStow();
//
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
//
vars
	specialStow : CM_SpecialStow;
	pxySpecialStow : CM_SpecialStow;
	strArray : HugeStringArray;
	text : String;
	str : String;
begin
	app.initialize;
	create strArray transient;
	text := "100 Prepare/prepared with plastic lining     
101 Prepare/prepared with varnished floor    
102 Clip-on unit required/attached   
103 Generator required/attached     
104 Vent to be open   
105 Vent to be closed   
106 Off-hire on arrival   
107 Do not accept  
109 Cargo Claim Pending    
112 Redirect elsewhere  
115 To be fumigated    
116 Keep from freezing  
120 Timber control treatment required    
121 Prepare/prepared with stencils   
122 US East Coast axle settings    
123 US West Coast axle settings    
