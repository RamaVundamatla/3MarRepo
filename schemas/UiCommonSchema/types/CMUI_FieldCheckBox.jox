    <JadeMethod name="buildSelf" id="b28fc290-e0d4-484a-9771-8bee2fdc5d4d">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	checkboxObj		: CMUI_FieldCheckBoxControl;
	leftPos			: Integer;
	
begin
	inheritMethod();
	
	create checkboxObj transient;
	checkboxObj.alignment	:=	CheckBox.Alignment_Left;
	checkboxObj.transparent	:=	true;
	checkboxObj.caption		:=	" ";
	self.myCheckBox			:=	checkboxObj;
	checkboxObj.parent		:=	self;
	self.form.addControl(checkboxObj);
	
	if self.labelWidth = 0 then
		leftPos	:=	0;
	else
		leftPos	:=	self.labelWidth + CMUI_FieldFrame.HORIZONTAL_SPACING;
	endif;
	
	checkboxObj.move(leftPos, 2, self.width, checkboxObj.height);
	self.height	:=	checkboxObj.height;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBoolean" id="3b68930b-b7a6-4ed4-8144-dcc3a34214dd">
        <source>getBoolean(): Boolean;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCheckBox.value;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEmbeddedControl" id="081aa50c-ea67-4b73-9e5d-13af281a3543">
        <source>getEmbeddedControl(): Control;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwdap1	Initial creation

*/

vars

begin
	return self.myCheckBox;
epilog

end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="setIsEnabled" id="4206b21e-c9d0-4728-9478-1d12a45615de">
        <updating/>
        <source>setIsEnabled(_isEnabled: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCheckBox.enabled	:=	_isEnabled;
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="0182cf92-7c83-412d-9f97-5292ae42524e">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	self.myCheckBox.tabIndex	:=	tabOrder;
	
	return tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="5c3f6dcf-2494-4fb1-a073-c01bb9b21449">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCheckBox.value	:=	_value.Boolean;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="a7f62bdc-bb4c-4791-b3f1-9f3131252159">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(_controlWidth, _labelWidth);
	self.myCheckBox.width	:= _controlWidth;
	self.myCheckBox.left	:= self.width - _controlWidth;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
