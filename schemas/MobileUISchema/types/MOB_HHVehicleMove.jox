    <JadeMethod name="cmbYardLocation_displayEntry" id="c0c8194e-5073-4da6-88dd-6d485bb2cd36">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbYardLocation_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Display the location controller (Called from Jadeinfrastructure)
//			Note the format of locations depends on the kind of place it is in
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
begin
	//Only display places where we can put things
	if obj.isKindOf(CM_RTGLaneController) or obj.isKindOf(CM_GapController) then
		return null;
	endif;
	
	return self.getSessionAgent().displayEntryLC(obj.CM_LocationsController);
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="92250a46-57b3-46d5-9975-43a5922887af">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

begin

	if not self.wasCalledViaContext(false) then
		return false;
	endif;

	// we only want to show these contexts if we started at the enquiry form.

	return buildContextMenu(null, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayCurrentLocation" id="0267ad8d-e659-4e4e-b202-25f35517fe00">
        <source>displayCurrentLocation() protected;
// ---------------------------------------------------------------------------
// Created:	14 January 2009 By Graeme Black cnwgb1
// Purpose:	Show the current location on the form (Blue Text)
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin

	self.lblCurLocValue.caption := null;
	self.lblDamage.caption := null; 
	if self.myTrackedItem &lt;&gt; null then
		self.lblCurLocValue.caption := self.myTrackedItem.locationId;
		if self.myTrackedItem.allDamageInstances.isEmpty then
			self.lblDamage.translateCaption(Xlat_0021186, self.myLocale);
		else
			self.lblDamage.caption := self.myTrackedItem.getDamageAuditText();
		endif;
	endif;
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDamageBtnClick" id="db62746e-2453-458d-81b3-f81a07e6b5f6">
        <updating/>
        <source>doDamageBtnClick()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	obj : Object;
	lc : CM_LocationsController;
	target : String;
	foundHeight : Integer;

begin

	self.myMobileGenericAgent.setMyLocationsController( null );
	
	obj := self.cmbYardLocation.listObject;
	if obj &lt;&gt; null then
		lc := obj.CM_LocationsController;
	endif;
	if lc = null then
		target := self.txtTargLocn.text;
		if target &lt;&gt; null then
			app.myPassport.myTerminal.findLocationFromString(target, false, lc, foundHeight);
			if lc &lt;&gt; null and not lc.isKindOf (CM_YardController) then
				lc := null;
			endif;
		endif;
	endif;

	self.myMobileGenericAgent.setMyLocationsController( lc );

	self.gotoForm(MOB_HHDamageForm,false);

epilog

end;</source>
    </JadeMethod>
