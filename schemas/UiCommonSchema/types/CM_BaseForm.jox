    </JadeMethod>
    <JadeMethod name="doMaxTableSizeCheck" id="e2e087ef-8875-4ef2-91b6-6556ef1967ba">
        <source>doMaxTableSizeCheck(_numItemsToDisplay: Integer; _msg: String): Boolean;

//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	result		: Integer;
	ok2Continue	: Boolean;
	msg			: String;
begin
	ok2Continue := true;
	
	if _numItemsToDisplay &gt; JadeTableRowLimit then
		if _msg = null then
			//default msg
			//msg :=	"The number items to display is greater than the maximum allowed (" &amp;  JadeTableRowLimit.String &amp; ")." &amp; CrLf &amp;
			//		"Do you want to display the first " &amp; JadeTableRowLimit.String &amp; "?" &amp; CrLf &amp; CrLf &amp;
			//		"Click 'No' to refine your selection.";
			msg :=		app.getErrorString1(MaxTablesRowsContinue, JadeTableRowLimit.String);	//Bug 38662
		else
			msg := _msg;
		endif;
		
		result := app.msgBox(msg, self.caption, MsgBox_Yes_No + MsgBox_Information_Icon);
		if result &lt;&gt; MsgBox_Return_Yes then
			ok2Continue := false;
		endif;
	endif;
epilog
	return ok2Continue;
end;</source>
        <Parameter name="_numItemsToDisplay" type="Integer"/>
        <Parameter name="_msg" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
