    <JadeMethod name="getAllVoyageRequests" id="f1deb7c7-9390-4292-8bf4-a2c672c01b38">
        <source>getAllVoyageRequests(_allRequests: CM_VoyageRequestArray io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033
13 Sep 2012	cnwrs1	Par 29388 don't add null requests
*/
vars
	req : CM_RORORequest;
begin
	if self.myLaneController = null then
		return;
	endif;
	
	req := self.myLaneController.myRORORequestLoad;
	if req = null then
		req := self.myLaneController.myRORORequestDischarge;
	endif;
	if req &lt;&gt; null then
		_allRequests.add(req);
	endif;
epilog

end;</source>
        <Parameter name="_allRequests" type="CM_VoyageRequestArray" usage="io"/>
    </JadeMethod>
