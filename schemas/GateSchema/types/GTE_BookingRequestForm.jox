    <JadeMethod name="btnEditDetail_click" id="6817289b-37e9-4560-81fe-9b92797c797a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditDetail_click(btn: Button input) updating;
//-----------------------------------------
//
// Created : by cnwaer1 27 August 2008
//-----------------------------------------
vars

	row : Integer;
	//brItem : CM_BRefItemContainer; //cnwjo3 19840
	brItem : CM_BookingRefItem;
begin	
	row := self.tblBookingItems.row;
	
	if row &gt; 1 then
		//brItem := self.tblBookingItems.accessRow(row).itemObject.CM_BRefItemContainer; //cnwjo3 19840
		brItem := self.tblBookingItems.accessRow(row).itemObject.CM_BookingRefItem;
		self.doEditBookingRefItem(brItem,false);
	endif;
end;</source>
