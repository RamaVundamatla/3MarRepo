    <JadeMethod name="populateTrackedItem" id="f4da4352-7328-44d9-8d07-d952a7e72a22">
        <updating/>
        <source>populateTrackedItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506
02 Apr 2014	NDL	Par 1366

*/

vars

	weightStr : String;
	volumeStr : String;
	measureType : CM_MeasurementType;

begin

	self.lblQuantity.visible := false;
	self.txtQuantity.visible := false;
	self.txtQuantity.text := "0";
	self.tblWeightVolume.visible := false;

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		
		if self.myTrackedItem.isBulkByQuantity then
			self.lblQuantity.visible := true;
			self.txtQuantity.visible := true;
			self.txtQuantity.text := self.myTrackedItem.totalQuantity.String;
			
		elseif self.myTrackedItem.isBulkByWeight then
			self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, self.myTrackedItem.totalWeight );
		
		elseif self.myTrackedItem.isBulkByVolume then
			self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, self.myTrackedItem.totalVolume );
		
		endif;
		
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;

	endif;
	
	self.displayCurrentLocation();
	self.setMoveEnabledDisabled();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="2840097d-5d09-4863-9a2c-afb9658de89e">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setPreventSiteChange(true);
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveEnabledDisabled" id="f664fe2f-245c-4e52-b092-85315c061370">
        <updating/>
        <source>setMoveEnabledDisabled() updating, protected;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Enables the Move button if there is enough information to do
//			a move (There is a tracked item and a target location )
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
begin
	if self.myTrackedItem &lt;&gt; null and self.txtTargLocn.text &lt;&gt; null then
		if self.myTrackedItem.isBulkByQuantity and self.txtQuantity.text.Integer &lt;= 0 then
			self.btnOne.enabled := false;
		elseif self.myTrackedItem.isBulkByWeight and self.tblWeightVolume.getConvertedValue() &lt;= 0 then
			self.btnOne.enabled := false;
		elseif self.myTrackedItem.isBulkByVolume and self.tblWeightVolume.getConvertedValue() &lt;= 0 then
			self.btnOne.enabled := false;
		else
			self.btnOne.enabled := true;
		endif;
	else
		self.btnOne.enabled := false;
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="75f6b8f4-1534-4af9-a6d3-4cab89bac83d">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	self.displayCurrentLocation();
	self.setMoveEnabledDisabled();
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="7da30a6a-7732-4544-a0de-eb852b97499e">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation

*/

vars

	doImmediateMove : Boolean;	//02 Mar 2017	NDL	TFS 3298

begin
						
	self.doResizeControls(true);

	self.handleAreaTypeSelect();
	self.handleAreaSelect();
	
	if self.wasCalledViaContext(true) then
		self.btnTwo.caption := app.getErrorString(Enquiry);
	endif;
	
	if app.myMobileCargoFindAgent.myYardLoc &lt;&gt; null then
		self.txtTargLocn.text := app.myMobileCargoFindAgent.myYardLoc.getFullId;
		self.txtTargLocn.userObject := app.myMobileCargoFindAgent.myYardLoc;
		//02 Mar 2017	NDL	TFS 3298
		if self.myTerminal.getConfig(HhMoveHideNonSplit).Boolean then
			doImmediateMove := true;	
		endif;
	endif;
	
	self.setMoveEnabledDisabled();
	self.populateTrackedItem();	
	self.txtCargoId.setFocus;
	
	//02 Mar 2017	NDL	TFS 3298 - If the cargo and location is chosen, and there is no 'amount to move' to capture, just do it.
	if self.myTrackedItem &lt;&gt; null and doImmediateMove then
		if ( self.myTrackedItem.isBulkByQuantity and self.txtQuantity.text.Integer = 1 ) // break bulk by quantity, only one selected
		or ( not self.myTrackedItem.isBulkByQuantity and not self.myTrackedItem.isBulkByWeight and not self.myTrackedItem.isBulkByVolume ) // ordinary cargo
		then
			if self.btnOne.enabled then
				if self.doMove then
					self.btnTwo.click( self.btnTwo );
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c5f3b860-ab8c-4af5-94f2-3b9f6dea796f">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Purpose:	Basic form setup 
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Move), BACK_BUTTON, null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="91171698-f3fd-4bb8-9c1a-7284a82d54e7">
        <updating/>
        <source>setupMenu() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	passport : CM_Passport;
	term : CM_Terminal;
	
begin

	passport := app.myPassport;
	term := passport.myTerminal;
	
	if not app.myCurrentUserCan(term, PmHHGrading) then
		self.mnuGrades.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainStops) then
		self.mnuStops.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainTasks) then
		self.mnuTasks.visible := false;
	endif;
	
	self.isMenuItemsVisible := self.mnuStops.visible or
								self.mnuTasks.visible or
								self.mnuGrades.visible;
							
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2f8471b0-5790-4174-a77a-59613e6136e9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019053, locale);
	lblCargoId.translateCaption(Xlat_0019054, locale);
	lblCurLocation.translateCaption(Xlat_0019055, locale);
	lblQuantity.translateCaption(Xlat_0019056, locale);
	lblSelectTarget.translateCaption(Xlat_0019057, locale);
	lblTargLocn.translateCaption(Xlat_0019058, locale);
	lblTerminalArea.translateCaption(Xlat_0019059, locale);
	lblYardLocation.translateCaption(Xlat_0019060, locale);
	mnuContext.translateCaption(Xlat_0019061, locale);
	mnuGrades.translateCaption(Xlat_0019062, locale);
	mnuStops.translateCaption(Xlat_0019063, locale);
	mnuTasks.translateCaption(Xlat_0019064, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
