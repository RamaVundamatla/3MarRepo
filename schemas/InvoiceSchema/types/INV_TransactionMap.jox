    <JadeMethod name="displaySnapShotInvoiceMap" id="d8603942-b553-4e1e-ac66-dd6a9dbfde9d">
        <source>displaySnapShotInvoiceMap();
//04 Feb 2019	NDL	TFS 43153
vars
//	form : INV_SnapShotInvoiceMap;
	formNew : INV_SnapShotAllocMaintForm;
begin
	if self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker.allInvoiceAllocations.isEmpty then
		self.myAssistant.showYAMaintInvoiceForm(true, self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker, null, null);
	else
	//	create form;
	//	form.setMyTerminal(self.myTerminal);	
	//	form.myCurrentTranMapSS := self.myCurrentMapTMSS;
	//	form.mySnapShotBroker := self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker;
	//	form.show();
		create formNew;
		formNew.setMyTerminal( self.myTerminal );	
		formNew.myCurrentTranMapSS := self.myCurrentMapTMSS;
		formNew.mySnapShotBroker := self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker;
		formNew.show();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="displaySnapShotMap" id="a7fbed57-aa3e-4a77-a1bc-ff030c034237">
        <source>displaySnapShotMap();

vars
	form : INV_SnapShotSummMap;
begin

	//31 Jan 2019	NDL	TFS 43153
	if self.myCurrentMapServiceBroker &lt;&gt; null and self.myCurrentMapServiceBroker.isKindOf(CM_SnapShotServiceBroker) then
		self.myAssistant.INV_Assistant.showSnapShotInvoiceMap( self.myTerminal, self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker, self.myCurrentMapTMSS, false );	
		return;
	else

	
		create form;
		form.setMyTerminal(self.myTerminal);	
		form.myCurrentTranMapSS := self.myCurrentMapTMSS;
		form.mySnapShotBroker := self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker;
	//	if self.myCurrentMapServiceBroker &lt;&gt; null and
	//	   self.myCurrentMapServiceBroker.isKindOf(CM_SnapShotServiceBroker) then
	//		form.myOutputFormat := self.myCurrentMapServiceBroker.CM_SnapShotServiceBroker.mySnapShotDefinition;
	//		form.mode := INV_SnapShotSummMap.Mode_Update;
	//	else
			form.mode := INV_SnapShotSummMap.Mode_Add;
	//	endif;
	
		form.show();
	
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="displaySubQuantity" id="af67daab-5744-4d70-a5c2-fd8d9fcd8b0a">
        <updating/>
        <source>displaySubQuantity()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2017	cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time


*/

vars
	calcType	: CM_CalculationType;
begin

	if self.myCurrentMapQuantity = null then
		return;
	endif;

	if self.myCurrentMapTM &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_Cargo);
	elseif self.myCurrentMapTMVoyage &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_HMS);
	elseif self.myCurrentMapTMEvent &lt;&gt; null then
		self.doCmbCalcTypeBuild(self.CalcType_Event);
	elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
		self.doCmbCalcTypeBuild(self.CalcType_WorkOrder); // TFS 39236
	elseif self.myCurrentMapTMBOL &lt;&gt; null then	//01 Nov 2019	NDL	TFS 47100
		self.doCmbCalcTypeBuild(self.CalcType_BOL);
	else
		return;
	endif;
	
	if self.updateMode = UpdateMode_Update then
		calcType := self.myCurrentMapQuantity.myCalculationType;
		self.cmbCalcType.listObject := calcType;
		self.chkBoxQtyZero.value := self.myCurrentMapQuantity.chargeZero;
		self.optMapTypeSingle.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_Single);
		self.optMapTypeEscalt.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_Escalate);
		self.optMapTypeEscPlu.value := (self.myCurrentMapQuantity.mappingType = CM_QuantityMap.MapType_EscalateFull);
	endif;
	if calcType &lt;&gt; null and
	   calcType.allQuantityRanges.size &gt; 0 then
		self.optMapTypeEscPlu.visible := true;
	else
		self.optMapTypeEscPlu.visible := false;
	endif;
	self.chkBoxQtyZero.enabled := self.optMapTypeSingle.value;
	
	self.showQuantityFrame();
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySubQuantityRange" id="04878717-7465-4b54-93bf-b4015d8910a4">
        <updating/>
        <source>displaySubQuantityRange()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

*/

vars
begin
	self.chkMax.value := false;
	if self.updateMode = self.UpdateMode_Update then
		if self.myCurrentMapQuantityRange = null then
			return;
		endif;
			
		self.txtQtyStart.text := self.myCurrentMapQuantityRange.rangeStart.asStringJMT;
		self.txtQtyEnd.text := self.myCurrentMapQuantityRange.rangeEnd.asStringJMT;
		
	endif;
	
	self.showQuantityRangeFrame();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTransMap" id="f780faaa-9b20-4514-879d-ca2cc2cb6ae7">
        <updating/>
        <source>displayTransMap() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entTableDef		: EntTableDef;
	tranMap : CM_TranMap;
	theTable : CM_EntryTable;
	theNarrRow : Integer;
	anObject : Object;
begin
	theTable := self.tblProperties;
	entTableDef := app.myController.getEntTableDef(	ETDef_InvMaintTranMapEnt);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	if self.updateMode = self.UpdateMode_Update then
		if self.myCurrentMapTM = null 
		and self.myCurrentMapTMVoyage = null 
		and self.myCurrentMapTMEvent = null 
		and self.myCurrentMapTMWorkOrder = null
		and self.myCurrentMapTMBOL = null //01 Nov 2019	NDL	TFS 47100
		and self.myCurrentMapTMSS = null 
		and self.myCurrentMapTMInventory = null  // ### TFS 51219 25MAY2021 NAVAB1
		and myCurrentMapTMCargoAllocation = null then // PAR 35833
			app.msgBox(app.getErrorString(Please_select_transactio),app.getErrorString(Properties_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
		if myCurrentMapTMVoyage &lt;&gt; null then
			//theTable.setValueByName(ETRow_Name,myCurrentMapTMVoyage.name);
			//theTable.setValueByName(ETRow_Description,myCurrentMapTMVoyage.description);
			theTable.setValueByName(ETRow_Code30,myCurrentMapTMVoyage.name); //03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,myCurrentMapTMVoyage.description); //03/04/2025	navkc1 JIRA Bug MTN-34244
			
		elseif self.myCurrentMapTM &lt;&gt; null then
			tranMap := self.myCurrentMapTM;
			//theTable.setValueByName(ETRow_Name,tranMap.name);
			//theTable.setValueByName(ETRow_Description,tranMap.description);
			theTable.setValueByName(ETRow_Code30,tranMap.name);	//03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,tranMap.description);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		elseif self.myCurrentMapTMEvent &lt;&gt; null then
			//theTable.setValueByName(ETRow_Name,self.myCurrentMapTMEvent.name);
			//theTable.setValueByName(ETRow_Description,self.myCurrentMapTMEvent.description);
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMEvent.name);	//03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMEvent.description);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
			//theTable.setValueByName(ETRow_Name,self.myCurrentMapTMWorkOrder.name);
			//theTable.setValueByName(ETRow_Description,self.myCurrentMapTMWorkOrder.description);
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMWorkOrder.name);	//03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMWorkOrder.description);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		elseif self.myCurrentMapTMBOL &lt;&gt; null then // 01 Nov 2019	NDL	TFS 47100
			//theTable.setValueByName(ETRow_Name,self.myCurrentMapTMBOL.name);
			//theTable.setValueByName(ETRow_Description,self.myCurrentMapTMBOL.description);
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMBOL.name);	//03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMBOL.description);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		elseif self.myCurrentMapTMSS &lt;&gt; null then
			//theTable.setValueByName(ETRow_Name,self.myCurrentMapTMSS.name);
			//theTable.setValueByName(ETRow_Description,self.myCurrentMapTMSS.description);
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMSS.name);	//03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMSS.description);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then //03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMCargoAllocation.name);
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMCargoAllocation.description);
		elseif self.myCurrentMapTMInventory &lt;&gt; null then //03/04/2025	navkc1 JIRA Bug MTN-34244
			theTable.setValueByName(ETRow_Code30,self.myCurrentMapTMInventory.name);
			theTable.setValueByName(ETRow_Description60,self.myCurrentMapTMInventory.description);
		endif;
	else
		self.myCurrentMapTM := null;
		self.myCurrentMapTMVoyage := null;
		self.myCurrentMapTMEvent := null;
		self.myCurrentMapTMWorkOrder := null;
		self.myCurrentMapTMSS := null;
		self.myCurrentMapTMBOL := null;
		self.myCurrentMapTMCargoAllocation := null; //03/04/2025	navkc1 JIRA Bug MTN-34244
		self.myCurrentMapTMInventory := null; //03/04/2025	navkc1 JIRA Bug MTN-34244
		
		//theTable.setValueByName(ETRow_Name,null);
		//theTable.setValueByName(ETRow_Description,null);
		theTable.setValueByName(ETRow_Code30,null);	//03/04/2025	navkc1 JIRA Bug MTN-34244
		theTable.setValueByName(ETRow_Description60,null);	//03/04/2025	navkc1 JIRA Bug MTN-34244
	endif;
	theTable.moveFirst();
	theTable.setFocus;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayTransactionTypes" id="fe065cd0-b60b-432c-968c-6b336261c8d9">
        <updating/>
        <source>displayTransactionTypes() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//08 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions

vars
	mapObject : CM_FinancialObject; // TFS 38711
begin

	self.doBuildListboxTransactions(self.myCurrentMapCommodity);

	if self.updateMode = self.UpdateMode_Copy then
		if self.modePropertyUpdate = self.ModeProperty_Move then // TFS 38711
			mapObject := self.myCurrentMapCommodity.allTransServiceBrokersByType.first; // TFS 38711
		else // TFS 38711 - note above, there'll always be at least Default...
			mapObject := self.myCurrentMapServiceBroker; // TFS 38711
		endif; // TFS 38711
		self.populateCopyPath(self.myCurrentMapCommodity, mapObject); // TFS 38711
	
		self.lblCopy2.caption := app.getErrorString(Copy_transactio_type);
		self.lblCopy.width := self.lstCopyPath.width - 100;
		if self.modePropertyUpdate = self.ModeProperty_Move then // TFS 38711
			self.lblCopy.caption := app.getErrorString1(Copy_transa_type_after_commod, mapObject.getName); // TFS 38711
		else // TFS 38711
			self.lblCopy.caption := app.getErrorString1(Copy_transa_type_after_commod, mapObject.CM_ServiceBroker.getDescription()); // self.myCurrentMapServiceBroker.getDescription() ); // TFS 38711
		endif; // TFS 38711
		self.showCopyFrame();
	else
		self.lblList.caption := app.getErrorString(Transaction_types);
		self.showListFrame();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayWorkOrder" id="4976f5d2-269a-4692-b982-278e6fe9ad4f">
        <updating/>
        <source>displayWorkOrder() updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
begin
	self.doBuildListBoxWorkOrders();
	self.lblList.caption := app.getErrorString(WorkOrder);
	self.showListFrame();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="d4871b1b-2cd3-464e-b8e6-d47fc547a295">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_TRACKEDITEM then
		self.doSaveTMTrackedItem();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_VOYAGE then
		self.doSaveTMVoyage();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_EVENT then
		self.doSaveTMEvent();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_WO then // TFS 39236
		self.doSaveTMWorkOrder(); // TFS 39236
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_BOL then // 01 Nov 2019	NDL	TFS 47100
		self.doSaveTMBOL(); // 01 Nov 2019	NDL	TFS 47100
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_SSSUMMARY then
		self.doSaveTMSS();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_CARGOALLOC then // PAR 35833
		self.doSaveTMCargoAlloc(); // PAR 35833
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_INVENTORY then // TFS 51219 
		self.doSaveTMInventory(); // TFS 51219 
	else
		app.msgBox(app.getErrorString(Invalid_transactio_type),app.getErrorString(Transaction_error),MsgBox_OK_Only);
		return;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnListSaveClick" id="33ea2107-6031-4fce-9fda-8d469a3e0b78">
        <updating/>
        <source>doBtnListSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		Save changed or new entry
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars

	pxyTISM,realTISM : CM_TIServiceMap;
	pxyImex,realImex : CM_ImexServiceMap;
	pxyContent,realContent : CM_ContentsMap;
	pxyCom,realCom : CM_CommodityMap;
	pxyDM,realDM : CM_DebtorMap;
	pxySB, realSB : CM_ServiceBroker;
	pxyPG, realPG : CM_ProductGroupMap;
	pxyProd, realProd : CM_ProductMap;
	pxyQM, realQM : CM_QuantityMap;
	pxyQRM, realQRM : CM_QuantityRangeMap;
	
	prodGroup : CM_ProductGroup;
	product : CM_Product;
	label : String;
	endRange, mapType, theReturn : Integer;
	cargoType : CM_CargoType;
	status : CM_CargoStatus;
	resource : HMS_Resource;
	event : CM_EventType;
	cStatus : 	CM_ContentsStatus;
	com : CM_Commodity;
	debtor : CM_Debtor;
	debtorType	: CM_DebtorType;
	tranType : CM_TransactionType;
	anObject : Object;
	rangeType :Integer;
	edition			: Integer;
	invalidObject	: Boolean;
	tempMap : CM_CommodityMap;
	woType : CM_TransactionType;
	bolType : CM_TransactionType;
begin
	// 32311	CCMS 1297
	if self.updateMode = self.UpdateMode_Copy then	
		self.doCopyEntry();
		return;
	endif;
	
	// 33535 check for parent entry being deleted under us - the On Exception and edition checks
	if self.modePropertyNew = self.ModeProperty_CargoType then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTM, invalidObject );
		edition := self.myCurrentMapTM.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyTISM transient;
		cargoType := self.lstList.listObject.CM_CargoType;
		label := cargoType.classNameToCreate;
		pxyTISM.setProxy(label, self.myCurrentMapTM, cargoType);
		label := app.getErrorString(Cargo_typeNEW);
	elseif self.modePropertyNew = self.ModeProperty_IMEX then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapProduct, invalidObject );
		edition := self.myCurrentMapProduct.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyImex transient;
		status := self.lstList.listObject.CM_CargoStatus;
		pxyImex.setProxy(self.myCurrentMapProduct, status);
		label := app.getErrorString(Imex_statusNEW);
	elseif self.modePropertyNew = self.ModeProperty_Contents then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapIMEX, invalidObject );
		edition := self.myCurrentMapIMEX.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyContent transient;
		cStatus := self.lstList.listObject.CM_ContentsStatus;
		pxyContent.setProxy(cStatus, self.myCurrentMapIMEX);
		label := app.getErrorString(Contents_statusNEW);

	elseif self.modePropertyNew = self.ModeProperty_ProductGroup then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTIService, invalidObject );
		edition := self.myCurrentMapTIService.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyPG transient;
		prodGroup := self.lstList.listObject.CM_ProductGroup;
		pxyPG.setProxy(prodGroup, self.myCurrentMapTIService);
		label := app.getErrorString(Cargo_subtype_groupNEW);
	elseif self.modePropertyNew = self.ModeProperty_Product then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapProdGrp, invalidObject );
		edition := self.myCurrentMapProdGrp.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyProd transient;
		product := self.lstList.listObject.CM_Product;
		pxyProd.setProxy(product, self.myCurrentMapProdGrp);
		label := app.getErrorString(Cargo_subtypeNEW);
	elseif self.modePropertyNew = self.ModeProperty_Commodity then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapContents, invalidObject );
		edition := self.myCurrentMapContents.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyCom transient;
		com := self.lstList.listObject.CM_Commodity;
		pxyCom.setProxy(com, self.myCurrentMapContents);
		label :=app.getErrorString(CommodityNEW);
	elseif self.modePropertyUpdate = self.ModeProperty_Quantity and self.updateMode =  self.UpdateMode_Update then
		if not global.isValidObject(self.myCurrentMapQuantity) or
		   not global.isValidObject(self.myCurrentMapServiceBroker) then
			self.resetEdit();
			return;
		endif;

		realQM := self.myCurrentMapQuantity;
		pxyQM := app.createUpdateProxy(realQM).CM_QuantityMap;
		if self.optMapTypeSingle.value then
			mapType := CM_QuantityMap.MapType_Single;
		elseif self.optMapTypeEscalt.value then
			mapType := CM_QuantityMap.MapType_Escalate;
		else
			mapType := CM_QuantityMap.MapType_EscalateFull;
		endif;
		pxyQM.setProxy(self.myCurrentMapServiceBroker, self.chkBoxQtyZero.value, mapType, self.cmbCalcType.listObject.CM_CalculationType, null);
		label := app.getErrorString(Quantity_updateNEW);
		
	elseif self.modePropertyUpdate = self.ModeProperty_QuantityRange  and self.updateMode =  self.UpdateMode_Update then
		if not global.isValidObject(self.myCurrentMapQuantity) or
		   not global.isValidObject(self.myCurrentMapQuantityRange) then
			self.resetEdit();
			return;
		endif;

		realQM := self.myCurrentMapQuantity;
		realQRM := self.myCurrentMapQuantityRange;
		pxyQRM := app.createUpdateProxy(realQRM).CM_QuantityRangeMap;
		endRange := self.txtQtyEnd.text.Integer;
		if self.chkMax.value then
			endRange := CM_QuantityRangeMap.MAX_RANGE.Integer;
		endif;
		// 
		rangeType := RANGETYPE_DEFAULT;
		pxyQRM.setProxy(realQM, self.txtQtyStart.text.Integer, endRange, rangeType);
		label := app.getErrorString(Quantity_range_updateNEW);
	elseif self.modePropertyNew = self.ModeProperty_QuantityRange  and self.updateMode =  self.UpdateMode_New then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapQuantity, invalidObject );
		edition := self.myCurrentMapQuantity.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		realQM := self.myCurrentMapQuantity;
		endRange := self.txtQtyEnd.text.Integer;
		if self.chkMax.value then
			endRange := CM_QuantityRangeMap.MAX_RANGE.Integer;
		endif;
		// relative range type not implemented after all
		rangeType:=RANGETYPE_DEFAULT;
		create pxyQRM transient;
		pxyQRM.setProxy(realQM, self.txtQtyStart.text.Integer, endRange, rangeType);
		label := app.getErrorString(Quantity_rangeNEW);
	
	//09/02/2017 cnwma1 TFS #2901
	elseif self.modePropertyNew = self.ModeProperty_SubQuantity  and self.updateMode =  self.UpdateMode_Update then
		if not global.isValidObject(self.myCurrentMapQuantity) or
		   not global.isValidObject(self.myCurrentMapServiceBroker) then
			self.resetEdit();
			return;
		endif;
		realQM := self.myCurrentMapQuantity;
		pxyQM := app.createUpdateProxy(realQM).CM_QuantityMap;
		if self.optMapTypeSingle.value then
			mapType := CM_QuantityMap.MapType_Single;
		elseif self.optMapTypeEscalt.value then
			mapType := CM_QuantityMap.MapType_Escalate;
		else
			mapType := CM_QuantityMap.MapType_EscalateFull;
		endif;
		pxyQM.setProxy(self.myCurrentMapQuantityRange, self.chkBoxQtyZero.value, mapType, self.cmbCalcType.listObject.CM_CalculationType, null);
		label := app.getErrorString(Quantity_updateNEW);
	elseif self.modePropertyNew = self.ModeProperty_SubQuantity and   self.updateMode =  self.UpdateMode_New  then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapQuantity, invalidObject );
		if not global.isValidObject(self.myCurrentMapQuantity) or
		   not global.isValidObject(self.myCurrentMapServiceBroker) then
			self.resetEdit();
			return;
		endif;
		realQM := self.myCurrentMapQuantity;
		create pxyQM transient;
		if self.optMapTypeSingle.value then
			mapType := CM_QuantityMap.MapType_Single;
		elseif self.optMapTypeEscalt.value then
			mapType := CM_QuantityMap.MapType_Escalate;
		else
			mapType := CM_QuantityMap.MapType_EscalateFull;
		endif;
		create pxyQM as CM_QuantityMap transient;
		pxyQM.CM_QuantityMap.setProxy(self.myCurrentMapQuantityRange, self.chkBoxQtyZero.value, mapType, self.cmbCalcType.listObject.CM_CalculationType, null);
	//09/02/2017 cnwma1 TFS #2901
	
	elseif self.modePropertyNew = self.ModeProperty_Debtor then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapServiceBroker, invalidObject );
		edition := self.myCurrentMapServiceBroker.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxyDM transient;
		// 24051 new controls for debtor and type
		debtor := self.lstDebtorsList.listObject.CM_Debtor;
		debtorType := cmbDebtorTypes.listObject.CM_DebtorType;
		pxyDM.setProxy(debtor, self.myCurrentMapServiceBroker, debtorType);
		label := app.getErrorString(DebtorNEW);
		// 24051 maintain debtor type
	elseif self.modePropertyUpdate = self.ModeProperty_Debtor  and self.updateMode =  self.UpdateMode_Update then
		if not global.isValidObject(self.myCurrentMapServiceBroker) or
		   not global.isValidObject(self.myCurrentMapDebtor) then
			self.resetEdit();
			return;
		endif;

		realDM := self.myCurrentMapDebtor;
		pxyDM := app.createUpdateProxy(realDM).CM_DebtorMap;
		debtor := self.lstDebtorsList.listObject.CM_Debtor;
		debtorType := cmbDebtorTypes.listObject.CM_DebtorType;
		pxyDM.setProxy(debtor, self.myCurrentMapServiceBroker, debtorType);
		label := app.getErrorString(Debtor_type_updateNEW);

	elseif self.modePropertyNew = self.ModeProperty_Resource then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTMVoyage, invalidObject );
		edition := self.myCurrentMapTMVoyage.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		resource := self.lstList.listObject.HMS_Resource;
		create pxySB as CM_ResourceServiceBroker transient;
		pxySB.CM_ResourceServiceBroker.setProxyRSB(resource, self.myCurrentMapTMVoyage);
		label := app.getErrorString(ResourceNEW);
	elseif self.modePropertyNew = self.ModeProperty_Event then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTMEvent, invalidObject );
		edition := self.myCurrentMapTMEvent.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		event := self.lstList.listObject.CM_EventType;
		create pxySB as CM_EventServiceBroker transient;
		pxySB.CM_EventServiceBroker.setProxyRSB(event, self.myCurrentMapTMEvent);
		label := app.getErrorString(EventNEW);
	elseif self.modePropertyNew = self.ModeProperty_WorkOrder then // TFS 39236
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTMWorkOrder, invalidObject );
		edition := self.myCurrentMapTMWorkOrder.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		woType := self.lstList.listObject.CM_TransactionType;
		create pxySB as CM_WorkOrderServiceBroker transient;
		pxySB.CM_WorkOrderServiceBroker.setProxyRSB(woType.trxType, self.myCurrentMapTMWorkOrder);
		label := "NEW WORK ORDER"; 
		
	//01 Nov 2019	NDL	TFS 47100
	elseif self.modePropertyNew = self.ModeProperty_BOL then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapTMBOL, invalidObject );
		edition := self.myCurrentMapTMBOL.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		bolType := self.lstList.listObject.CM_TransactionType;
		create pxySB as CM_BOLServiceBroker transient;
		pxySB.CM_BOLServiceBroker.setProxyRSB(bolType.trxType, self.myCurrentMapTMBOL);
		label := "NEW BOL"; 
		
	elseif self.modePropertyNew = self.ModeProperty_TransType then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapCommodity, invalidObject );
		edition := self.myCurrentMapCommodity.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		anObject := self.lstList.listObject;
		if anObject.CM_TransactionType.classNameToCreate = CM_Move.name then
			self.showMoveFrame();
			return;
		endif;
	
		create pxySB as CM_TransServiceBroker transient;
		pxySB.CM_TransServiceBroker.setProxyTSB(anObject.CM_TransactionType.classNameToCreate, self.myCurrentMapCommodity, anObject.CM_TransactionType);
		label := app.getErrorString(TransactionNEW);
	elseif self.modePropertyNew = self.ModeProperty_Move then
		on Exception do app.handleDeletedObject( exception, self.myCurrentMapCommodity, invalidObject );
		edition := self.myCurrentMapCommodity.edition;
		if invalidObject then
			self.resetEdit();
			return;
		endif;

		create pxySB as CM_MoveServiceBroker transient;
		anObject := self.lstList.listObject;
		pxySB.CM_MoveServiceBroker.setProxyMSB(self.lstListMVFrom.text, self.lstListMVTo.text, self.myCurrentMapCommodity);
		label := app.getErrorString(MoveNEW);
	elseif self.modePropertyNew = self.ModeProperty_ResourceType then	// 06 Jan 2010 NDL	CCMS MES 1006
		if not global.isValidObject(self.myCurrentMapCommodity) or
		   not global.isValidObject(myTMCSB) then
			self.resetEdit();
			return;
		endif;

		anObject := self.lstList.listObject;
		create pxySB as CM_TransResourceServiceBroker transient;
		tranType := myTMCSB.myServiceBroker.CM_TransServiceBroker.myTransactionType;
		pxySB.CM_TransResourceServiceBroker.setProxyTSB(tranType.classNameToCreate, self.myCurrentMapCommodity, tranType);
		pxySB.CM_TransResourceServiceBroker.setResourceTypeAndBroker(anObject.CM_ResourceType, myTMCSB.myServiceBroker.CM_TransServiceBroker);
		label := app.getErrorString(Resource_typeNEW);
	
	elseif self.modePropertyNew = self.ModeProperty_EventResourceType then // 15/05/2023	navkc1	CR 57927 Task 54268
		
		anObject := self.lstList.listObject;
		create pxySB as CM_ToDoResourceServiceBroker transient;
		pxySB.CM_ToDoResourceServiceBroker.setResourceTypeAndBroker(anObject.CM_ResourceType, myTMCEG.myEventBroker);
		label := app.getErrorString(Resource_typeNEW);
		
	elseif self.modePropertyNew = self.ModeProperty_WOResourceType then // 15/05/2023	navkc1	CR 57927 Task 54268
		
		anObject := self.lstList.listObject;
		create pxySB as CM_ToDoResourceServiceBroker transient;
		pxySB.CM_ToDoResourceServiceBroker.setResourceTypeAndBroker(anObject.CM_ResourceType, myTMCWO.myWOBroker);
		label := app.getErrorString(Resource_typeNEW);
		
	else
		return;
	endif;	

		
	while true do
		if self.modePropertyNew = self.ModeProperty_CargoType then
			app.myTrxCA.trxCreateInvoiceTMCargoType(pxyTISM,realTISM,app.myPassport);
		elseif self.modePropertyUpdate = self.ModeProperty_Quantity  and self.updateMode =  self.UpdateMode_Update then
			app.myTrxUA.trxUpdateInvoiceTMQty(pxyQM,app.myPassport);
		elseif self.modePropertyUpdate = self.ModeProperty_QuantityRange  and self.updateMode =  self.UpdateMode_Update then
			app.myTrxUA.trxUpdateInvoiceTMQtyRange(pxyQRM, app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_QuantityRange then
			app.myTrxCA.trxCreateInvoiceTMQtyRange(pxyQRM,realQRM, app.myPassport);
		//09/02/2017 cnwma1 TFS #2901
		elseif self.modePropertyNew = self.ModeProperty_SubQuantity  and self.updateMode =  self.UpdateMode_New then
			app.myTrxCA.trxCreateInvoiceTMQtySub(pxyQM,realQM,app.myPassport);
		elseif self.modePropertyUpdate = self.ModeProperty_SubQuantity and self.updateMode =  self.UpdateMode_Update then
			app.myTrxUA.trxUpdateInvoiceTMQty(pxyQM,app.myPassport);
		//09/02/2017 cnwma1 TFS #2901
		elseif self.modePropertyNew = self.ModeProperty_IMEX then
			app.myTrxCA.trxCreateInvoiceTMImex(pxyImex,realImex,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_Contents then
			app.myTrxCA.trxCreateInvoiceTMContents(pxyContent,realContent,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_ProductGroup then
			app.myTrxCA.trxCreateInvoiceTMProductGroup(pxyPG,realPG,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_Product then
			app.myTrxCA.trxCreateInvoiceTMProduct(pxyProd,realProd,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_Commodity then
			app.myTrxCA.trxCreateInvoiceTMCommodity(pxyCom,realCom,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_Debtor then
			app.myTrxCA.trxCreateInvoiceTMDebtor(pxyDM,realDM,app.myPassport);
			// 24051
		elseif self.modePropertyUpdate = self.ModeProperty_Debtor  and self.updateMode =  self.UpdateMode_Update then
			app.myTrxUA.trxUpdateInvoiceTMDebtor(pxyDM,app.myPassport);
		elseif self.modePropertyNew = self.ModeProperty_TransType 
		or self.modePropertyNew = self.ModeProperty_Event
		or self.modePropertyNew = self.ModeProperty_WorkOrder // TFS 39236
		or self.modePropertyNew = self.ModeProperty_BOL	//04 Nov 2019	NDL	TFS 47100
		or self.modePropertyNew = self.ModeProperty_Resource
		or self.modePropertyNew = self.ModeProperty_ResourceType
		or self.modePropertyNew = self.ModeProperty_Move 
		or self.modePropertyNew = self.ModeProperty_EventResourceType	// 15/05/2023	navkc1	CR 57927 Task 54268
		or self.modePropertyNew = self.ModeProperty_WOResourceType  	// 15/05/2023	navkc1	CR 57927 Task 54268
		then
			app.myTrxCA.trxCreateInvoiceTMTransaction(pxySB,realSB,app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(label, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	tempMap := self.myCurrentMapCommodity;
	
	self.frmList.visible := false;
	self.frmListMoves.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	self.frmPropQty.visible := false;
	self.frmPropQtyRange.visible := false;
	self.frmDebtors.visible := false;

epilog
	delete pxyTISM;
	delete pxyImex;
	delete pxyPG;
	delete pxyProd;
	delete pxyContent;
	delete pxyCom;
	delete pxyDM;
	delete pxySB;
	delete pxyQM;
	delete pxyQRM;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="2a6c3a20-1aa3-46ba-b3aa-2b2b1016e0ca">
        <updating/>
        <source>doBtnPropSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	// creates
	if self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_TRACKEDITEM then
		self.doSaveTMTrackedItem();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_VOYAGE then
		self.doSaveTMVoyage();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_EVENT then
		self.doSaveTMEvent();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_WO then // TFS 39236
		self.doSaveTMWorkOrder();
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_BOL then //01 Nov 2019	NDL	TFS 47100
		self.doSaveTMBOL(); //01 Nov 2019	NDL	TFS 47100
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_CARGOALLOC then	 // PAR 35833
		self.doSaveTMCargoAlloc(); // PAR 35833
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_INVENTORY then // TFS 51219 
		self.doSaveTMInventory(); // TFS 51219 
	elseif self.lstData.itemData[self.lstData.listIndex] = CMIF_TMCType.TYPE_SSSUMMARY then	
		self.doSaveTMSS();
	// updates
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then	 // PAR 35833
		self.doSaveTMCargoAlloc();	 // PAR 35833
	elseif self.myCurrentMapTMInventory &lt;&gt; null then	 // TFS 51219
		self.doSaveTMInventory();	 // TFS 51219
	elseif self.myCurrentMapTM &lt;&gt; null then
		self.doSaveTMTrackedItem();
	elseif self.myCurrentMapTMVoyage &lt;&gt; null then
		self.doSaveTMVoyage();
	elseif self.myCurrentMapTMEvent &lt;&gt; null then
		self.doSaveTMEvent();
	elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
		self.doSaveTMWorkOrder(); // TFS 39236
	elseif self.myCurrentMapTMBOL &lt;&gt; null then //01 Nov 2019	NDL	TFS 47100
		self.doSaveTMBOL(); //01 Nov 2019	NDL	TFS 47100
	elseif self.myCurrentMapTMSS &lt;&gt; null then
		self.doSaveTMSS();
	else
//		app.msgBox("Invalid Transaction Map Type.","Transaction Map Error",MsgBox_OK_Only);
		app.msgBox(app.getErrorString(Invalid_transactio_type),app.getErrorString(Transaction_error),MsgBox_OK_Only);
		return;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSearchClick" id="58439beb-c422-488e-890c-f01eb5372447">
