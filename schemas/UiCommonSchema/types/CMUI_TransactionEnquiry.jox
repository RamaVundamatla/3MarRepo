    <JadeMethod name="doBtnRPSaveClick" id="9cf69c99-fb55-43da-a17a-0565a434cddc">
        <updating/>
        <source>doBtnRPSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		18 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//5/06/2018 	JLGNS1	Bug 38935: PNL - Transaction Resync doesn't include Freight Forwarder
vars
	txn : CM_Transaction;
	controller : CMIF_TiTransactionResync;
	logger	: CMIF_Logger;
	theReturn : Integer;
begin
	// par 16549 remove code to require some change - resync regardless - change may be to transaction map etc
	create controller transient;
	
	controller.myTrackedItem := self.myTrackedItem;
	controller.updateBusinessUnit := self.chkRPbusUnit.value;
	controller.updateCommodity := self.chkRPcomm.value;
	controller.updateConsignee := self.chkRPcon.value;
	controller.updateConsignor := self.chkRPconor.value;
	controller.updateContents := self.chkRPcontents.value;
	controller.updateCustomsAgent := self.chkRPcustAg.value;
	controller.updateDestinationPort := self.chkRPdestPort.value;
	controller.updateDischargePort := self.chkRPdischPort.value;
	controller.updateImexStatus := self.chkRPimex.value;
	controller.updateOperator := self.chkRPoperator.value;
	controller.updateQuantity := self.chkRPquantity.value;
	controller.updateVolume := self.chkRPvolume.value;
	controller.updateLength := self.chkRPLength.value; // PAR 31615
	controller.updateWeight := self.chkRPweight.value;
	controller.updateFreightForwarder := self.chkRPfreightForwarder.value;	//Bug 38935
	controller.readonly := self.chkReadOnly.value;  // ### TFS 2682
	controller.logging := self.chkRPLog.value;
	if controller.logging then
		create logger transient;
		app.setLogger(logger);
	endif;
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.tblTrans.allSelectedObjects.copy(controller.allTransactions);
	else
		self.tblTransactions.allSelectedObjects.copy(controller.allTransactions);
	endif;
	self.setupNotesForTransactions(controller);
	
	while true do
		app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			
			break;
		else
			theReturn := app.showErrorWarningDialog("Transaction Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	// PAR 16550
	if app.myPassport.trxCompletedOK then
		txn := controller.allTransactions.last;
		if txn &lt;&gt; null then
			self.endNotification(txn, self.myTerminal.getTerminalEvent(EVENT_TRAN_RESYNC));
		endif;
	endif;
	if logger &lt;&gt; null then
		self.doShowInvoiceLogging(logger);
	endif;
epilog
	self.frmResync.visible := false;
	delete controller;
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
end;</source>
    </JadeMethod>
