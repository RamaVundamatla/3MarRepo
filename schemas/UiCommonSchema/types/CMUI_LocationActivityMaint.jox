    <JadeMethod name="translateForm" id="f0d052a3-6919-440c-a1fb-adca0ba3b76c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 June 2021 10:38:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024309, locale);
	chkSourceMore.translateCaption(Xlat_0024310, locale);
	chkTargetMore.translateCaption(Xlat_0024311, locale);
	lblActivityType.translateCaption(Xlat_0024312, locale);
	lblAmount.translateCaption(Xlat_0024313, locale);
	lblCargoType.translateCaption(Xlat_0024314, locale);
	lblDateTime.translateCaption(Xlat_0024315, locale);
	lblHasBeenEdited.translateCaption(Xlat_0024316, locale);
	lblNeedsRecalc.translateCaption(Xlat_0024317, locale);
	lblNewSourceItem.translateCaption(Xlat_0024318, locale);
	lblNewTargetItem.translateCaption(Xlat_0024319, locale);
	lblOperator.translateCaption(Xlat_0024320, locale);
	lblRemarks.translateCaption(Xlat_0024321, locale);
	lblSource.translateCaption(Xlat_0024322, locale);
	lblSourceArea.translateCaption(Xlat_0024323, locale);
	lblSourceItem.translateCaption(Xlat_0024324, locale);
	lblSourceType.translateCaption(Xlat_0024325, locale);
	lblTarget.translateCaption(Xlat_0024326, locale);
	lblTargetArea.translateCaption(Xlat_0024327, locale);
	lblTargetItem.translateCaption(Xlat_0024328, locale);
	lblTargetType.translateCaption(Xlat_0024329, locale);
end;</source>
    </JadeMethod>
</GUIClass>
