    <JadeMethod name="setTblDataEntRows" id="9265522b-16c2-4229-b765-3f0cbd746bba">
        <updating/>
        <source>setTblDataEntRows(_defName: String) updating;
//10 March 2010	cnwml2


vars
	entTableDef	: EntTableDef;
	entTableView : String;
	entRow		: EntTableRow;
	headingStr,
	tmpStr		: String;
	tmpFactor,
	widthFactorTotal,
	idx,
	numRows,inputType,	index : Integer;
	col	: JadeTableColumn;		
	rowFound	: Boolean;
		
begin

	entTableDef := app.myController.getEntTableDef(_defName);
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; _defName &amp; ') not found');
		return;
	endif;

	if self.myBOLType.id = BOLType_Log then
		entTableView := "Logs";
	elseif self.myBOLType.id = BOLType_GeneralBillOfLading then
		entTableView := "BOLs";
	endif;
	self.tblData.setTblDataEntRowsFromView(entTableDef, entTableView);
	//self.tblData.setTblDataEntRowsArray(entTableDef, self.allTblDataTransientRows, self.xmlStrTblData);

epilog

end;</source>
        <Parameter name="_defName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="60fdcfac-5e55-4eb0-9df3-1293a51e744f">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//13 January 2010	cnwml2


vars
	tmpMenu : MenuItem;
begin
	inheritMethod(conwin);
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_BOLDtl) then
		if self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_Log then
			self.mnuAdd.visible := false;
			self.mnuEdit.visible := self.allowUpdate;				//+cnwml2 PAR23230
			self.mnuDelete.visible := false;
			if self.allowUpdate then					//+cnwml2 PAR23230
				self.mnuSeparator.visible := true;
			else
				self.mnuSeparator.visible := false;
			endif;
			self.mnuSeparator.visible := false;
			self.mnuReconcileBOL.visible := false;
			self.mnuPrintLabels.visible  := false;
			self.mnuSeperator1.visible := false;
			self.btnDeleteTV.enabled := false;
			self.mnuReceived.visible := false;
			self.mnuSeperator2.visible := false;
		else
			self.mnuAdd.visible := self.allowAdd;				//+cnwml2 PAR23230
			self.mnuEdit.visible := self.allowUpdate;			//+cnwml2 PAR23230
			self.mnuDelete.visible := false;
			if self.allowAdd or self.allowUpdate then 			//+cnwml2 PAR23230
				self.mnuSeparator.visible := true;
			else
				self.mnuSeparator.visible := false;
			endif;
			self.mnuReconcileBOL.visible := true;
			self.mnuSeperator1.visible := true;
			self.btnDeleteTV.enabled := false;
			if self.myCurrentObject.CM_BOLDtl.myBOL.allTrackedItems.size &gt; 0 then
				self.mnuReceived.visible := true;
				self.mnuSeperator2.visible := true;
			else
				self.mnuReceived.visible := false;
				self.mnuSeperator2.visible := false;
			endif;
		endif;
	else
		if self.myCurrentObject.CM_BOL.bolType = BOLType_Log then
			self.mnuAdd.visible := false;
			self.mnuEdit.visible := self.allowUpdate;			//+cnwml2 PAR23230
			self.mnuDelete.visible := false;
			if self.allowUpdate then 							//+cnwml2 PAR23230
				self.mnuSeparator.visible := true;
			else
				self.mnuSeparator.visible := false;
			endif;
			self.mnuReconcileBOL.visible := false;
			self.mnuSeperator1.visible := false;
			self.btnDeleteTV.enabled := false;
			self.mnuReceived.visible := false;
			self.mnuSeperator2.visible := false;
		else
			self.mnuAdd.visible := self.allowAdd;				//+cnwml2 PAR23230
			self.mnuEdit.visible := self.allowUpdate;			//+cnwml2 PAR23230
			self.mnuDelete.visible := self.allowDelete;			//+cnwml2 PAR23230
			self.mnuPrintLabels.visible  := true;
			if self.allowAdd or self.allowUpdate or self.allowDelete then 			//+cnwml2 PAR23230
				self.mnuSeparator.visible := true;
			else
				self.mnuSeparator.visible := false;
			endif;
			self.mnuReconcileBOL.visible := true;
			self.mnuSeperator1.visible := true;
			self.btnDeleteTV.enabled := true;
			if self.myCurrentObject.CM_BOL.allTrackedItems.size &gt; 0 then
				self.mnuReceived.visible := true;
				self.mnuSeperator2.visible := true;
			else
				self.mnuReceived.visible := false;
				self.mnuSeperator2.visible := false;
			endif;
		endif;
	endif;
	
	// TFS 2198 CNWAB1
	self.zHideForViewOnly();
	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeperator2, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReceived, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeperator1, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuPrintLabels, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReconcileBOL, false);					
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeparator, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDelete, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuEdit, false);					
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuAdd, false);	



epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="62f35114-f7bc-4f6c-9d9b-e4b9c05e39bc">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		14 June 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	
//	if self.myMasterMenuAction.myMenuDtl.heading = app.getString(Docket_maintenance) then
	if self.myMasterMenuAction.myMenuDtl.constantValue = 494 then	//07 Feb 2011	NDL	Par 26738
		self.myBOLType := app.myRoot.allBOLTypes[BOLType_Log];
//	elseif self.myMasterMenuAction.myMenuDtl.heading = app.getString(Bol_maintenance) then
	elseif self.myMasterMenuAction.myMenuDtl.constantValue = 1152 then	//07 Feb 2011	NDL	Par 26738
		self.myBOLType := app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading];
	endif;
	
	inheritMethod();
	
	if self.myBOLType.id = BOLType_Log then
		self.allowDelete := false;
		self.btnShowBOLItems.visible := false;
		self.btnReconciled.visible := false;
		if self.filterDocketType &lt;&gt; null then
			if self.filterDocketType &lt;&gt; BOLType_Log then
				self.btnShowBOLItems.enabled := true;
				self.btnReconciled.enabled := true;
			else
				self.btnShowBOLItems.enabled := false;
				self.btnReconciled.enabled := false;
			endif;
	
		else		
			self.btnShowBOLItems.enabled := false;
			self.btnReconciled.enabled := false;
			self.btnDeleteTV.enabled := false;
		endif;
		
		self.setupTextTable();
		self.setCaption(app.getString(Docket_maintenance));
		self.setNavigatorHeading('Dockets');
	elseif self.myBOLType.id = BOLType_GeneralBillOfLading then
		//self.allowDelete := true;		//-cnwml2 PAR23230
		self.btnShowBOLItems.visible := true;
		self.btnReconciled.visible := true;
		if self.filterDocketType &lt;&gt; null then
			self.btnShowBOLItems.enabled := true;
			self.btnReconciled.enabled := true;
			if self.allowDelete then		//+cnwml2 PAR23230
				self.btnDeleteTV.enabled := true;
			endif;
		else		
			self.btnShowBOLItems.enabled := false;
			self.btnReconciled.enabled := false;
			self.btnDeleteTV.enabled := false;
		endif;
		
		self.setupTextTable();
		self.setCaption(app.getString(Bol_maintenance));
		self.setNavigatorHeading("BOLs");
	endif;
	

	
	// TFS 2198 CNWAB1
	self.zHideForViewOnly();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTextTable" id="4b16d717-e0e2-425e-a7ed-50dac87aba37">
        <source>setupTextTable();
/*
	Created on 04 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	entTableDef : EntTableDef;
begin
	self.tblBOLItems.columns := 1;
	self.tblBOLItems.fixedColumns := 0;
	self.tblBOLItems.fixedRows := 0;
	self.tblBOLItems.allSelectedObjects.clear;
	self.tblBOLItems.selectionType := self.tblBOLItems.SelectionType_Row;
	entTableDef := app.myController.getEntTableDef(ETDef_BOLItemText);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_BOLItemText &amp; ') not found');
		return;
	endif;
	self.tblBOLItems.setTableTextDisplayFields(entTableDef, null);
	
end;</source>
    </JadeMethod>
