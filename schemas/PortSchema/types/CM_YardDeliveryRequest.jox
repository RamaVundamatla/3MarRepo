    <JadeMethod name="copy" id="7d0033f3-bf9b-4a1b-aa1a-4f2402ee4652">
        <updating/>
        <source>copy(transRequest : CM_YardDeliveryRequest) updating;

/****Changes

Date		Name	TFS#	Description
==========================================================================
03/10/2018	jlgka1	40698	Add "heavyRated".
*/

begin
	self.clean 		:= transRequest.clean;
	self.isoType 	:= transRequest.isoType;
	self.heavyRated := transRequest.heavyRated; //jlgka1 TFS# 40698 
	self.isoGroup 	:= transRequest.isoGroup; //cnwrd1 22.12.09
	//self.mtGrade := transRequest.mtGrade;
	//self.doISOGroupCheck := transRequest.doISOGroupCheck;
	
	transRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades); //cnwrd1 par 26633 17.12.2010
	
	self.operatorCode 	:= transRequest.operatorCode;
	self.targetLocation := transRequest.targetLocation;
	self.totalRequested := transRequest.totalRequested;
	
	self.requiredByDT 			:= transRequest.requiredByDT;	 //cnwrd1 ccms 1075/1735 23.7.09
	self.myTargetSubTerminal 	:= transRequest.myTargetSubTerminal;
	self.myRelease				:= transRequest.myRelease;
	self.myReleaseItem 			:= transRequest.myReleaseItem;
	self.mySelectedRTQueue 		:= transRequest.mySelectedRTQueue;

end;</source>
        <Parameter name="transRequest" type="CM_YardDeliveryRequest"/>
    </JadeMethod>
