    <JadeMethod name="locksChangeDateRange" id="6b20d959-6f20-46ef-b34d-35954c8ad0d6">
        <updating/>
        <source>locksChangeDateRange() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin

	if self.viewLocksMode = self.ViewLocksBy_Table then
		self.tblLocks.clearAllData();
		idx := self.tblLocks.addItem(app.getErrorString(CMUI_UserNodes_DateRangeChange));
		self.tblLocks.accessCell(idx, 1).mergeCells := Table.MergeCells_Merge;
	else
		self.grfLocks.clearGraph();
		self.grfLocks.setAndShowGraphTitle(app.getErrorString(CMUI_UserNodes_DateRangeChange));
	endif;
	
