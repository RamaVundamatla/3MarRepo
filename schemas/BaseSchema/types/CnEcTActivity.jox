    <JadeMethod name="initializeMe" id="901a51f7-14e5-4cc0-a96e-b6ff899a35a9">
        <updating/>
        <source>initializeMe(	pAction				: String;
				pAfterControlName 	: String;
				pAfterText			: String;
				pControlName		: String;
				pErrorText			: String;
				pTheLesson			: CnEcTLesson;
				pName				: String;
				pOnErrorDoAction	: Boolean;
				pOnErrorStop		: Boolean;
				pText				: String) updating;

begin
	if app.myBaseRoot = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12000, "BaseRoot is null or missing.");
	elseif pTheLesson = null or pName = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12001, "The activity must have a name and Lesson.");
	endif;

	// Set the property values...

	self.action				:= pAction;
	self.afterControlName	:= pAfterControlName;
	self.afterText			:= pAfterText;
	self.controlName		:= pControlName;
	self.errorText			:= pErrorText;
	self.name				:= pName;
	self.onErrorDoAction	:= pOnErrorDoAction;
	self.onErrorStop		:= pOnErrorStop;
	self.text				:= pText;

	// Now set any key property values...


	// Last, set any references...

	self.myLesson				:= pTheLesson;
	self.myLesson.addActivity(self);
end;</source>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pAfterText" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pErrorText" type="String"/>
        <Parameter name="pTheLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
    <JadeMethod name="readFromFile" id="07075992-df20-411e-96c7-cdba57a5d484">
        <updating/>
        <source>readFromFile(pTheFile : File io; pTheLesson : CnEcTLesson; pInStr : String) : String updating;

vars
	fileRecord	: String;
	chunk		: String;
	error		: String;
	
begin
	fileRecord	:=	pInStr;

	chunk := self.getNextChunk(fileRecord);	

	if chunk &lt;&gt; self.ACTIVITY_FLAG then
		return "Invalid activity record (" &amp; chunk &amp; ")";
	endif;

	error	:=	update(	pTheLesson,
						self.getNextChunk(fileRecord),
						self.getNextChunk(fileRecord),
						self.getNextChunk(fileRecord),
						self.getNextChunk(fileRecord),
						self.isNextChunk(fileRecord, "Stop on error"),
						self.isNextChunk(fileRecord, "Do action on error"),
						self.isNextChunk(fileRecord, "Use existing value"));
	
	self.text		:=	self.doReplaceCrLf(pTheFile.readLine);
	self.afterText	:=	self.doReplaceCrLf(pTheFile.readLine);	
	self.errorText	:=	self.doReplaceCrLf(pTheFile.readLine);	

	return error;
end;</source>
        <Parameter name="pTheFile" type="File" usage="io"/>
        <Parameter name="pTheLesson" type="CnEcTLesson"/>
        <Parameter name="pInStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setUseExistingValue" id="e8a117fe-9d1a-4a45-9c53-efb0573d7a2a">
        <updating/>
        <source>setUseExistingValue() updating;

begin
	self.useExistingValue := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="9b4bdb8f-4eda-4991-bd3f-31274a70496e">
        <updating/>
        <source>update(	pTheLesson:CnEcTLesson;
		pName:String;
		pControlName:String;
		pAction:String;
		pAfterControlName:String;
		pOnErrorStop:Boolean;
		pOnErrorDoAction:Boolean;
		pUseExistingValue:Boolean) : String updating;

begin
	if pTheLesson = null then
		self.myLesson	:=	CnEcTLesson.firstInstance();
		return "Update Activity: lesson not defined";
	endif;

	self.controlName		:=	pControlName.trimBlanks();
	self.afterControlName	:=	pAfterControlName.trimBlanks();
	self.name				:=	pName.trimBlanks();
	self.action				:=	pAction.trimBlanks();
	self.onErrorStop		:=	pOnErrorStop;
	self.onErrorDoAction	:=	pOnErrorDoAction;
	self.useExistingValue	:=	pUseExistingValue;

	if self.name.length() = 0 then
		self.myLesson := CnEcTLesson.firstInstance();
		return "Update Activity: no name supplied";
	endif;

	if self.myLesson &lt;&gt; pTheLesson then
		self.myLesson	:=	pTheLesson;
		self.myLesson.addActivity(self);
	endif;
end;</source>
        <Parameter name="pTheLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pUseExistingValue" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateAfterText" id="0c2de8e8-804f-4826-8544-69c37ae36770">
        <updating/>
        <source>updateAfterText(pAfterText : String) : String updating;

vars
	error	: String;

begin
	self.afterText	:=	pAfterText.trimBlanks();

	if self.afterText.length &gt; 0 then
		// do nothing - it is valid to have a null control... this displays the entire form
	else
		if self.afterControlName.length &gt; 0 then
			error	:=	"Activity error: no text supplied with after control: " &amp; self.afterControlName;
		endif;
	endif;

	return error;
end;</source>
        <Parameter name="pAfterText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateErrorText" id="0b0c8309-09de-4b24-b53b-65b9606bb921">
        <updating/>
        <source>updateErrorText(pErrorText : String) : String updating;

vars

begin
	self.errorText	:=	pErrorText;
	return "";
end;</source>
        <Parameter name="pErrorText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="1da27895-11aa-4717-98f1-cc59a70e571b">
        <updating/>
        <source>updateMe(	pAction				: String;
			pAfterControlName	: String;
			pAfterText			: String;
			pControlName		: String;
			pErrorText			: String;
			pTheLesson		 	: CnEcTLesson;
			pName				: String;
			pOnErrorDoAction 	: Boolean;
			pOnErrorStop		: Boolean;
			pUseExistingValue	: Boolean;
			pText			 	: String) updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.action				:= pAction;
	self.afterControlName	:= pAfterControlName;
	self.afterText			:= pAfterText;
	self.controlName		:= pControlName;
	self.errorText			:= pErrorText;
	self.name				:= pName;
	self.onErrorDoAction	:= pOnErrorDoAction;
	self.onErrorStop		:= pOnErrorStop;
	self.useExistingValue	:= pUseExistingValue;
	self.text				:= pText;

	// Now set any key property values...

	// Last, set any references...

	self.myLesson				:= pTheLesson;
	self.myLesson.addActivity( self );
end;</source>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pAfterText" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pErrorText" type="String"/>
        <Parameter name="pTheLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pUseExistingValue" type="Boolean"/>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateText" id="c60f1837-a60a-4fe0-bd54-01d656d4065e">
        <updating/>
        <source>updateText(pText : String) : String updating;

vars
	error	: String;

begin
	self.text := pText.trimBlanks();

	if self.text.length() &gt; 0 then
		if self.controlName.length() = 0 then
			error := "Activity error: No control supplied with activity text.";
		endif;
	else
		if self.controlName.length &gt; 0 then
			error	:=	"Activity error: control " &amp; self.controlName &amp; " supplied with no activity text.";
		endif;
	endif;

	return error;
end;</source>
        <Parameter name="pText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeToFile" id="b8ef0a00-e615-476a-aac2-501b443573c2">
        <updating/>
        <source>writeToFile(pTheFile:File io) updating;

vars
	outputStr	: String;

begin
	outputStr := self.ACTIVITY_FLAG &amp; Tab &amp; name &amp; Tab &amp; controlName &amp; Tab &amp; action &amp; Tab &amp; afterControlName &amp; Tab;

	if self.onErrorStop then
		outputStr := outputStr &amp; "Stop on error" &amp; Tab;
	else
		outputStr := outputStr &amp; "continue on error" &amp; Tab;
	endif;

	if self.onErrorDoAction then
		outputStr := outputStr &amp; "Do Action on error" &amp; Tab;
	else
		outputStr := outputStr &amp; "on error no action" &amp; Tab;
	endif;

	if self.useExistingValue then
		outputStr := outputStr &amp; "Use existing value" &amp; Tab;
	else
		outputStr := outputStr &amp; "insert action" &amp; Tab;
	endif;

	pTheFile.writeLine(outputStr);
	
	self.text.cnEcRemoveCrLf();
	pTheFile.writeLine(self.text);
	
	self.afterText.cnEcRemoveCrLf();
	pTheFile.writeLine(afterText);
	
	self.errorText.cnEcRemoveCrLf();
	pTheFile.writeLine(self.errorText);
end;</source>
        <Parameter name="pTheFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
