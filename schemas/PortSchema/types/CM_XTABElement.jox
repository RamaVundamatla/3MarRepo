<Class name="CM_XTABElement" id="43817473-7fb7-4b4f-a12e-4e66bafbfc85">
    <superclass name="CM_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <ExplicitInverseRef name="myOutputFormat" id="134da5a1-5112-441c-af3a-0590141ae34a">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_OutputFormat"/>
        <access>readonly</access>
        <Inverse name="CM_OutputFormat_XTAB::allColumns"/>
        <Inverse name="CM_OutputFormat_XTAB::allRows"/>
        <Inverse name="CM_OutputFormat_XTAB::allFields"/>
        <Inverse name="CM_OutputFormat_XTAB::allTabs"/>
        <Inverse name="CM_OutputFormat_SS::allGroupings"/>
        <Inverse name="CM_OutputFormat_SS::allFields"/>
    </ExplicitInverseRef>
    <PrimAttribute name="propertyName" id="f161cb6f-7312-4503-8764-837a51466a43">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getKeyLength" id="3dbe4bcb-8803-4023-9ddd-37554eded673">
        <source>getKeyLength():Integer;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	: CM_QueryProperty;
	value		: Integer;
	
begin
	property 	:= self.getQueryProperty;
	value		:= 30;	// default;
	
	if property &lt;&gt; null then
		value := property.getKeyLengthForXTABDictionary;
	endif;
	
	return value;
	
epilog
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="04b3434d-689c-4c22-8df8-b1b3bdc58392">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= inheritMethod();
	
	if myOutputFormat &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; myOutputFormat.name.padBlanks( 30 );
	endif;
	
	returnStr	:= returnStr &amp; Tab &amp; propertyName.padBlanks( 30 ) &amp; Tab &amp; creationTime.shortCurrentLocaleFormat;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueryProperty" id="e661c195-bc52-4cc2-88aa-6b2fee402f9e">
        <source>getQueryProperty():CM_QueryProperty;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myOutputFormat.getQueryProperty (self.propertyName);
epilog

end;</source>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="getQueryPropertyTerminology" id="458985a8-2be2-4cc6-910e-06969c585328">
        <source>getQueryPropertyTerminology():String;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/12/2009	cnwcs5		ccms1023 - snapshot summaries
// ---------------------------------------------------------------------------
vars
	bolType 	:CM_CargoBOLType;
	property	:CM_QueryProperty;
begin
	bolType 	:= self.myOutputFormat.getQueryBOLType;
	property	:= self.getQueryProperty ();
	
	if property = null then
		return self.propertyName;
	endif;
	
	return app.getTerminologyAlternate(bolType, null, property.niceName , CM_TermExpressionSingular, property.niceName);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPropertyName" id="0d04c4c0-df09-46b6-ad1b-24d5f9d2f524">
        <updating/>
        <source>setPropertyName(_value :String)updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
	if self.propertyName = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	self.propertyName := _value;
epilog
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c8cd4014-8197-4fef-bc55-9bc34d305f35">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.getQueryProperty = null then
		app.raiseCMException1 (XTAB_InvalidPropertyName, self.propertyName, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b497e346-80f8-4518-ac91-4a99de272564">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateForCreate;
epilog

end;</source>
    </JadeMethod>
</Class>
