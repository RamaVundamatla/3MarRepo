    <JadeMethod name="doUpdateVoyageKPI" id="588e865e-dd60-4aac-aa56-85d66de7875c">
        <source>doUpdateVoyageKPI();
// ---------------------------------------------------------------------------
// Created:		03 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
// ---------------------------------------------------------------------------
vars
	tsStrFrom,tsStrTo : TimeStamp;
	delayHours 	: Real;
	delayCol 	: CM_DelayByStartDTDict;
	kpi 		: CM_KPI;
	vkpi		: CM_KPIVoyageJobSheetShift;	
	voy 		: CM_Voyage;
begin
	create delayCol transient;

	foreach kpi in self.allVoyageKPICraneShifts discreteLock do
		vkpi := kpi.CM_KPIVoyageJobSheetShift;

		if vkpi.myShift.isKindOf(CM_Shift) then
			tsStrFrom := vkpi.myShift.CM_Shift.startDateTime;
			tsStrTo := vkpi.myShift.CM_Shift.endDateTime;
			//04 Apr 2012	NDL	Par 29369 - was taking into account delays that occurred ouside of the displayed timeframe
			// resulting negative net hours on the Moves tab of side profile form.
			if vkpi.shiftStartTS.Date.isValid and vkpi.shiftStartTS &gt; tsStrFrom and vkpi.shiftStartTS &lt; tsStrTo then
				tsStrFrom := vkpi.shiftStartTS;
			endif;
			if vkpi.shiftEndTS.Date.isValid and vkpi.shiftEndTS &gt; tsStrFrom and vkpi.shiftEndTS &lt; tsStrTo then
				tsStrTo := vkpi.shiftEndTS;
			endif;
		else
			tsStrFrom := vkpi.shiftStartTS;
			tsStrTo := vkpi.shiftEndTS;
		endif;

		delayCol.clear;
		
		// ### get delays per shift
		//delayHours := self.getShiftDelayHours(tsStrFrom,tsStrTo,delayCol);  //11/04/2017 cnwma1 TFS# 4027
		if self.isVoyageLOLOJobSheet then //11/04/2017 cnwma1 TFS# 4027
			delayHours := self.getShiftDelayHoursLoLo(tsStrFrom,tsStrTo,delayCol);
		else
			delayHours :=self.getShiftDelayHoursRoRoHold(tsStrFrom,tsStrTo,delayCol);
		endif;
		// update whether delays or not incase the delay has been updates or deleted.
		vkpi.setKPIForDelays(delayHours, delayCol);
	endforeach;

	voy := self.myVoyage;

	if voy &lt;&gt; null then
		voy.causeEvent(voy.myTerminal.getTerminalEvent(EVENT_KPISHIPMOVEUPDATE), false,null);
	endif;

epilog
	delete delayCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="4d3115d0-e58b-4aab-b135-62a176c807e2">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;


vars
	job 	:	CM_VoyageJob;
begin

	exclusiveLock(self);

/*
No longer required as now have an inverse with parent/child
	while self.jobsByLabel.size &gt; 0 do
		job := jobsByLabel.last();
		if not global.isValidObject(job) then
			jobsByLabel.remove(job);
			continue;
		endif;			
		job.erase(eraseLevel);
	endwhile;

*/
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAllJobs" id="11dcf4d5-2309-494b-b16f-db60127d9b2c">
        <source>eraseAllJobs();
// ---------------------------------------------------------------------------
// Created:		17 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	iter : Iterator;
begin

	iter := self.allJobsByJobNum.createIterator();
	while iter.next(aJob) do
		aJob.erase(0);
	endwhile;
epilog
	delete iter;

end;</source>
