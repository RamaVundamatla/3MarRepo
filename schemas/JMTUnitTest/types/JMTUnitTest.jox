    <JadeMethod name="createOverlapFile" id="6c5b1e7f-7265-4af3-b3f6-06504e51861e">
        <source>createOverlapFile( _overlapFile : File io; _inputFileName : String);

/*

Purpose:		Add the overlap details to the Dumped Test Runs	

Date			Who		Reason
08/11/2013		cnwmh5	Initial creation

				lineArray[1] - system
				lineArray[2] - server
				lineArray[3] - startDate
				lineArray[4] - startTime
				lineArray[5] - finishDate
				lineArray[6] - finishTime
				lineArray[7] - runnable
				lineArray[8] - testRun
				lineArray[9] - elapsed
				lineArray[10] - schedule
				lineArray[11] - logResult
				lineArray[12] - numFailed

*/

constants

	DELIM					: String = ",";	

vars

	inputFile				: File;
	obj						: Object;
	
	lineArray				: StringArray512;
	serverNameArray			: StringArray;
	serverNameLastTSArray	: TimeStampArray;

	dict					: DynaDictionary;
	
	iter					: Iterator;
	
	line					: String;
	tempTS					: TimeStamp;	
	indexOf					: Integer;
	overlapStr				: String;
	nonOlapTime				: Time;
	overlapAmount			: Time;
	nonOlapTimeStr			: String;
	overlapAmountStr		: String;
	posNeg					: Integer;
	days					: Integer;
	schedule				: String;
	elapsed					: String;
	elapsedHours			: Decimal[5,2];
	tempTS2					: TimeStamp;

begin

	// create the dict to save stuff in
	create dict transient;
	dict.setMembership(StringArray512);
	dict.addExternalKey(Date, 8, true, false);			// Start Date 
	dict.addExternalKey(Time, 8, true, false);			// Start Time 
	///dict.addExternalKey(Integer, 8, false, false);			// count 
	dict.endKeys(true);
	
	create serverNameArray transient;
	create serverNameLastTSArray transient;
	
	create inputFile transient;
	inputFile.fileName := _inputFileName;
	inputFile.kind := File.Kind_Unknown_Text;
	
	// load the file details up
	while not inputFile.endOfFile do
	
		create lineArray transient;
		
		// get rid of the header
		if line = null then
			line := inputFile.readLine();
		endif;
	
		// read the line and get the individual details
		line := inputFile.readLine();
		if line = null then
			continue;
		endif;
		line.getTokensForDelimiter(",", lineArray);		
		
		if not serverNameArray.includes(lineArray[2]) then
			serverNameArray.add(lineArray[2]);
			serverNameLastTSArray.add(null);
		endif;
		
		dict.putAtKey(lineArray[3].Date, lineArray[4].Time, lineArray);

	endwhile;
	
	create lineArray transient;
	
	iter := dict.createIterator;
	while iter.next(obj) do
	
		lineArray := obj.StringArray512;
		
		// check if 1st time through for server and set initial TS
		indexOf := serverNameArray.indexOf(lineArray[2]);
		if serverNameLastTSArray[indexOf] = null then
			tempTS.setDate(lineArray[5].Date);					// finish
			tempTS.setTime(lineArray[6].Time);
			serverNameLastTSArray[indexOf] := tempTS;
		endif;
		
		// check to current startTime is &lt; serverNameTSArray TS
		tempTS.setDate(lineArray[5].Date);						// finish 
		tempTS.setTime(lineArray[6].Time);
		
		overlapStr := null;
		nonOlapTimeStr := null;
		overlapAmountStr := null;
		nonOlapTime := null;
		
		if tempTS &gt; serverNameLastTSArray[indexOf] then
			overlapAmount := tempTS.differenceAsTime(serverNameLastTSArray[indexOf], posNeg, days);
			if overlapAmount &lt;&gt; "00:00:00".Time then
				overlapAmountStr := overlapAmount.String;
				overlapStr := "Overlap";
				
				tempTS2.setDate(lineArray[3].Date);					// start
				tempTS2.setTime(lineArray[4].Time);
				
				nonOlapTime := serverNameLastTSArray[indexOf].differenceAsTime(tempTS2, posNeg, days);
				nonOlapTimeStr := nonOlapTime.String;
				
			endif;
		endif;
		
		///write lineArray[1] &amp; Tab &amp; lineArray[2] &amp; Tab &amp; lineArray[3] &amp; Tab &amp; lineArray[4] &amp; Tab &amp; 
		///	tempTS.String &amp; Tab &amp; serverNameLastTSArray[indexOf].String &amp; Tab &amp; overlapAmountStr &amp; Tab &amp; 
		///	nonOlapTimeStr;
		
		schedule := lineArray[10].String;
		schedule := schedule.replaceString("^^", "");
		elapsed := lineArray[9].String;
		elapsed := elapsed.replaceString("^^", "");
		elapsedHours := (elapsed.Real / 60).Decimal;
		
		_overlapFile.writeLine(lineArray[1].String  &amp; DELIM &amp; lineArray[2].String &amp; DELIM &amp;
			lineArray[3].Date.String  &amp; DELIM &amp; lineArray[4].Time.String &amp; DELIM &amp; 
			lineArray[5].Date.String &amp; DELIM &amp; lineArray[6].Time.String &amp; DELIM &amp; lineArray[7].String &amp; DELIM &amp; 
			lineArray[8].String &amp; DELIM &amp; lineArray[12].String &amp; DELIM &amp; elapsed &amp; DELIM &amp; elapsedHours.String &amp; DELIM &amp; 
			schedule &amp; DELIM &amp; lineArray[11].String &amp; DELIM &amp; overlapStr &amp; DELIM &amp; nonOlapTimeStr &amp; DELIM &amp; overlapAmountStr);
			
		tempTS.setDate(lineArray[3].Date);					// start
		tempTS.setTime(lineArray[4].Time);
		serverNameLastTSArray[indexOf] := tempTS;
	
	endwhile;

epilog

	delete serverNameArray;
	delete serverNameLastTSArray;
	if dict &lt;&gt; null then
		foreach obj in dict do	
			delete obj;
		endforeach;
	endif;
	delete dict;
	//delete lineArray;
	
	process.dumpTranisentsMDH("A100");

end;
</source>
        <Parameter name="_overlapFile" type="File" usage="io"/>
        <Parameter name="_inputFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createOverlapFile_OLD" id="a0aa7bcc-0075-4595-b0de-94f871847a3f">
        <source>createOverlapFile_OLD( _overlapFile : File io; _inputFileName : String);

/*

Purpose:		Add the overlap details to the Dumped Test Runs	

Date			Who		Reason
08/11/2013		cnwmh5	Initial creation

*/

constants

	DELIM					: String = ",";
	
vars

	dict					: DynaDictionary;
	jdo						: JadeDynamicObject;
	obj						: Object;
	inputFile				: File;
	
	lineArray				: StringArray;
	
	line 					: String;
	currStartTS				: TimeStamp;
	currFinishTS			: TimeStamp;
	prevStartTS				: TimeStamp;
	prevFinishTS			: TimeStamp;
	prevSet					: Boolean;
	overlapStr				: String;
	nonOlapTime				: Time;
	overlapAmount			: Time;
	nonOlapTimeStr			: String;
	overlapAmountStr		: String;
	count					: Integer;
	posNeg					: Integer;
	days					: Integer;
	schedule				: String;
	elapsed					: String;
	elapsedHours			: Decimal[5,2];

begin

	// initialisations
	create lineArray transient;

	// create the dict to save stuff in
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(Date, 8, true, false);			// Start Date 
	dict.addExternalKey(Time, 8, true, false);			// Start Time 
	dict.addExternalKey(Integer, 8, false, false);			// count 
	dict.endKeys(false);

	create inputFile transient;
	inputFile.fileName := _inputFileName;
	inputFile.kind := File.Kind_Unknown_Text;
	
	// load the file details up
	while not inputFile.endOfFile do
	
		lineArray.clear();
	
		// get rid of the header
		if line = null then
			line := inputFile.readLine();
		endif;
	
		// read the line and get the individual details
		line := inputFile.readLine();
		if line = null then
			continue;
		endif;
		line.getTokensForDelimiter(",", lineArray);							// 07/10/2013 cnwmh5 
		
		create jdo transient;
		jdo.addProperty("system", String);
		jdo.setPropertyValue("system", lineArray[1]);
		jdo.addProperty("startDate", Date);
		jdo.setPropertyValue("startDate", lineArray[2].Date);
		jdo.addProperty("startTime", Time);
		jdo.setPropertyValue("startTime", lineArray[3].Time);
		jdo.addProperty("finishDate", Date);
		jdo.setPropertyValue("finishDate", lineArray[4].Date);
		jdo.addProperty("finishTime", Time);
		jdo.setPropertyValue("finishTime", lineArray[5].Time);
		jdo.addProperty("runnable", Integer);
		jdo.setPropertyValue("runnable", lineArray[6].Integer);
		jdo.addProperty("testsRun", Integer);
		jdo.setPropertyValue("testsRun", lineArray[7].Integer);
		jdo.addProperty("elapsed", Real);
		jdo.setPropertyValue("elapsed", lineArray[8].Real);
		jdo.addProperty("schedule", String);
		jdo.setPropertyValue("schedule", lineArray[9]);
		jdo.addProperty("logResult", Boolean);
		jdo.setPropertyValue("logResult", lineArray[10].Boolean);
		
		count := count + 1;
		
		dict.putAtKey(lineArray[2].Date, lineArray[3].Time, count, jdo);
		
	endwhile;
	inputFile.close();	
	
	// now loop through the details and work out any overlaps
	prevSet := false;
	foreach obj in dict do
		
		currStartTS.setDate(obj.JadeDynamicObject.getPropertyValue('startDate').Date);
		currStartTS.setTime(obj.JadeDynamicObject.getPropertyValue('startTime').Time);
		currFinishTS.setDate(obj.JadeDynamicObject.getPropertyValue('finishDate').Date);
		currFinishTS.setTime(obj.JadeDynamicObject.getPropertyValue('finishTime').Time);
		schedule := obj.JadeDynamicObject.getPropertyValue('schedule').String;
		schedule := schedule.replaceString("^^", "");
		elapsed := obj.JadeDynamicObject.getPropertyValue('elapsed').String;
		elapsed := elapsed.replaceString("^^", "");
		elapsedHours := (elapsed.Real / 60).Decimal;
		
		overlapStr := null;
		nonOlapTimeStr := null;
		overlapAmountStr := null;

		// work out that is overlapped and what isn't
		if prevSet then
		
			if currFinishTS &gt; prevStartTS then
				overlapAmount := currFinishTS.differenceAsTime(prevStartTS, posNeg, days);
				if overlapAmount &lt;&gt; "00:00:00".Time then
					overlapAmountStr := overlapAmount.String;
					overlapStr := "Overlap";
					
					nonOlapTime := currStartTS.differenceAsTime(prevStartTS, posNeg, days);
					nonOlapTimeStr := nonOlapTime.String;
					
				endif;
			endif;
			
		endif;
		
		// set the previous details
		prevStartTS := currStartTS;
		prevFinishTS := currFinishTS;
		prevSet := true;
				
		_overlapFile.writeLine(obj.JadeDynamicObject.getPropertyValue('system').String  &amp; DELIM &amp; currStartTS.date.String &amp; DELIM &amp; currStartTS.time.String &amp; DELIM &amp; 
			currFinishTS.date.String &amp; DELIM &amp; currFinishTS.time.String &amp; DELIM &amp; obj.JadeDynamicObject.getPropertyValue('runnable').String &amp; DELIM &amp; 
			obj.JadeDynamicObject.getPropertyValue('testsRun').String &amp; DELIM &amp;	elapsed &amp; DELIM &amp; elapsedHours.String &amp; DELIM &amp; schedule &amp; 
			DELIM &amp; obj.JadeDynamicObject.getPropertyValue('logResult').String &amp; DELIM &amp; overlapStr &amp; DELIM &amp; nonOlapTimeStr &amp; DELIM &amp; overlapAmountStr);
	
	endforeach;
	_overlapFile.close();
	
epilog

	foreach obj in dict do
		delete obj;
	endforeach;
	delete dict;
	
	delete inputFile;
	delete lineArray;
	
end;</source>
        <Parameter name="_overlapFile" type="File" usage="io"/>
        <Parameter name="_inputFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createPassport" id="292bfe08-1969-4ff9-8625-0fb189637887">
