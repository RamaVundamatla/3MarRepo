<CollClass name="WS_WorkOrderTrackedItemArray" id="bd8c6489-aaea-4dec-ae0d-490f22764932">
    <memberType name="WS_WorkOrderTrackedItem"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="asDelimitedString" id="b1e218c5-e34e-4814-8e64-700b810a75e6">
        <source>asDelimitedString(_delimiter :Character):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/


vars
	woTI	: WS_WorkOrderTrackedItem;
	output	: String;
begin

	foreach woTI in self do
		if output = null then
			output := woTI.id ;
		else
			output := output &amp; _delimiter &amp;  woTI.id ;
		endif;
		
	endforeach;	
	
	return output;
epilog

end;</source>
        <Parameter name="_delimiter" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="598b6316-a948-4a09-9dae-85b5a1c2d52b">
        <source>getTIs(_tiSet : CM_TISet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	ti 		: CM_TrackedItem;
	woTI	: WS_WorkOrderTrackedItem;
begin
	
	foreach	   woTI in   self do 
		ti 	:= app.myPassport.getObjectOfTypeFromOid(woTI.cmObjectId,CM_TrackedItem).CM_TrackedItem;
		
		if ti &lt;&gt; null then
			_tiSet.addNoDuplicates(ti,false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
</CollClass>
