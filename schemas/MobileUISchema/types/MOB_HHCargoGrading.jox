    <JadeMethod name="doResizeControls" id="6044e528-e2cc-496a-a143-1ebbe6abae68">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cHeight := self.clientHeight - cTop - ( 3 * self.resizedMargin ) - self.getCMDButtonsHeight();
	if _initialSetup then
		self.setupTable();
		self.tblGrades.setAndIncrementTabIndex( tabIndex );
		self.tblGrades.visible := true;
	endif;
		
	self.tblGrades.move( self.resizedMargin, 
						cTop, 
						stdWidth, 
						cHeight );
	

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="1642d072-0239-4456-84a3-150ad37c7128">
        <updating/>
        <source>doSave() : Boolean protected, updating;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
19 Aug 2013 cnwer1	PAR 32261
*/

vars
	grade	: CM_MTGrade;
	msg : String;
begin
	grade := tblGrades.accessRow(selectedRow).itemObject.CM_MTGrade;
	
	if self.myTrackedItem = null or not self.myTrackedItem.canSetAvailabilityGrade then	// 35244 change from isContainer to allow chassis as well
		msg := app.getErrorString(NO_Container_selected);
		self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
		return false;
	endif;
	
	if grade = null then
		msg := app.getErrorString(No_Grade_selected);
		self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
		return false;
	endif;
	
	if grade.code = self.myTrackedItem.getAvailabilityGrade then
		// already set.
		msg := app.getErrorString(Grade_already_selected) &amp; CrLf &amp; app.getErrorString(Aborting_update);
		self.msgBox(msg,app.getErrorString(Warning), MsgBox_OK_Only, false);
		return true; // return true anyway as this wil refresh the form 
	endif;
	
	return self.getSessionAgent.updateGrade(self.myTrackedItem,grade);
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
