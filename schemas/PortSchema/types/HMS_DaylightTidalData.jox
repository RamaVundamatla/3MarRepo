<Class name="HMS_DaylightTidalData" id="55060807-b3db-4736-a79f-b28481a828d2">
    <superclass name="HMS_TidalData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hms"/>
    <PrimAttribute name="daylight" id="c6707079-e1d1-48d6-a19b-04d83f188459">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDataType" id="a7929101-13dc-4147-a54a-fe5e14e3dd8f">
        <source>getDataType(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	18 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return HMS_TidalDataType_TimeGap;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="94ab6bb4-7f4d-4981-93e3-4e196a1fe63b">
        <source>getValue(): Decimal;

/*
----------   ----------  --------------------------------------------------
Created:	18 October 2006 By cnwth2

Purpose:	

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars

begin
	return self.daylight.Decimal;


end;


</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fb63b9c4-eb3e-4099-bb8c-eb19b7be8396">
        <updating/>
        <source>setForUpdate(_pxyTidalData: HMS_DaylightTidalData; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyTidalData, _passport);

	self.daylight := _pxyTidalData.daylight;
end;


</source>
        <Parameter name="_pxyTidalData" type="HMS_DaylightTidalData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="af80fc5e-1c2a-41e6-94eb-c7a57d83a29d">
        <updating/>
        <source>setProxy(_ts : TimeStamp;
		_tidalModelDef : HMS_TidalModelDefinition;
		_daylight : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.ts 		:= _ts;
	self.myTidalModelDefinition := _tidalModelDef;
	self.daylight 	:= _daylight;
	
end;


</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_tidalModelDef" type="HMS_TidalModelDefinition"/>
        <Parameter name="_daylight" type="Boolean"/>
    </JadeMethod>
</Class>
