    <JadeMethod name="resolveTerminalArea" id="66cdbf91-0d2f-4352-afb6-81c7cb916ef5">
        <source>resolveTerminalArea(_propertyName : String; _key : String) : Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36811 - Use Case - Terminal Screen - Satellite View Definition Export/Import

*/

vars
	terminal : CM_Terminal;
begin
	if _propertyName = CM_TerminalArea::myTerminal.name then
		return app.myRoot.allTerminals[_key];
	elseif _propertyName = CM_TerminalArea::id.name then
		terminal := self.getMyTerminal();
		return terminal.allTerminalAreas[_key];
	endif;
	return null;
epilog

