        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLocationActivity" id="cd133fd7-1f53-493c-85ab-bfde05281c14">
        <updating/>
        <source>utlUpdateLocationActivity(	_pxyLA : CMEVT_LocationActivity; 
							_cmifSet : CMIF_TITxnControllerSet; 
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars
	realObject : CMEVT_LocationActivity;
	expectedEdition	: Integer;
	sourceObject : CM_Object;
	sourceChildObj : CM_LocationsController;
	targetObject : CM_Object;
	targetChildObj : CM_LocationsController;
	
	cmif : CMIF_TITransactionController;
	cmifDiscrep : CMIF_BBDiscrepancyController;
	tiTrans : CM_TITransaction;
	agent : CM_LocationActivityUpdateAgent; // ### TFS 51515 13JUL2021 NAVAB1
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyLA, 'Test Object');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valLocationActivity( _pxyLA );

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyLA, 'Location Activity Object', _passport).CMEVT_LocationActivity;

	
	create agent transient; // ### TFS 51515 13JUL2021 NAVAB1
	// set the earliest date and other details on this agent that will later mark balances for recalculation 
	agent.initialiseFromProxy(_pxyLA, realObject); // ### TFS 51515 13JUL2021 NAVAB1
	
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		sourceObject := _pxyLA.getSourceParentLocation( sourceChildObj );
		targetObject := _pxyLA.getTargetParentLocation( targetChildObj );
		if sourceChildObj &lt;&gt; null then
			sourceObject := sourceChildObj;
		endif;
		if targetChildObj &lt;&gt; null then
			targetObject := targetChildObj;
		endif;
		realObject.setUpdateCapableAttributes(	_pxyLA.dateTime,	//_dateTime : TimeStamp;
												_pxyLA.weight,	//_weight : Decimal;
												_pxyLA.quantity,	//_quantity : Integer;
												_pxyLA.volume,	//_volume : Decimal;
												sourceObject,	//_mySourceObject : CM_Object;
												targetObject,	//_myTargetObject : CM_Object
												_pxyLA.remarks	//_remarks : String
												);
	endif;
	
	
	if _passport.noErrors then // ### TFS 51515 13JUL2021 NAVAB1
		// mark all the balances for this terminal area/cargo type/operator from the earliest date
		agent.doProcess(); // ### TFS 51515 13JUL2021 NAVAB1
	endif;
	
	if _passport.noErrors and not _cmifSet.isEmpty then
		foreach cmif in _cmifSet do
			cmifDiscrep := cmif.CMIF_BBDiscrepancyController;
			//update the discrep values directly onto the TI and create the special tiTrx
			if cmifDiscrep.updateTI() then
				tiTrans := cmifDiscrep.myTrackedItem.createTransaction( cmifDiscrep, _passport );
			endif;
			if _passport.hasErrors then
				break;
			endif;
		endforeach;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
epilog
	delete agent;  // ### TFS 51515 13JUL2021 NAVAB1
end;</source>
        <Parameter name="_pxyLA" type="CMEVT_LocationActivity"/>
        <Parameter name="_cmifSet" type="CMIF_TITxnControllerSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLocationStatistics" id="e35d350d-cdb8-4d42-a1fd-447f106c4a8a">
        <source>utlUpdateLocationStatistics(pProxyLocationStatistics : CM_LocationStatistics ; _passport : CM_Passport input);

/*

Purpose:		Update a persistent CM_LocationStatistics object		

Parameters:		proxy	

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/
vars
	cancelSave		      : Boolean;
	realLocationStatistic : CM_LocationStatistics;
	expectedEdition	      : Integer;
	
begin

	self.initialiseActivity();

	pProxyLocationStatistics.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyLocationStatistics.pxyGetRealObjectAndEdition(realLocationStatistic, expectedEdition);
	
	if realLocationStatistic = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LocationStatistics.name, null, null);
		return;
	endif;

	app.myValUA.valLocationStatistics(realLocationStatistic, pProxyLocationStatistics);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realLocationStatistic);

	if _passport.noErrors and realLocationStatistic.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'LocationStatistics', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLocationStatistic, true);
	endif;
	
	if _passport.noErrors then
		realLocationStatistic.update(pProxyLocationStatistics);
	endif;


	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLocationStatistic, false);
	endif;

end;</source>
        <Parameter name="pProxyLocationStatistics" type="CM_LocationStatistics"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLocationStatisticsRC" id="3817ccc4-55a2-40dc-bdc2-f8a67b5d8172">
        <source>utlUpdateLocationStatisticsRC(pProxyLocationStatistics : CM_LocationStatistics ; _passport : CM_Passport input);

/*

Purpose:		Recalculate CM_LocationStatistics objects for a Terminal
				Normally only called when a Terminal is created or terminal areas added.

Parameters:		proxy - just needs to be empty	

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/
vars
	cancelSave		: Boolean;
	realLocationStatistic : CM_LocationStatistics;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyLocationStatistics.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyLocationStatistics.pxyGetRealObjectAndEdition(realLocationStatistic, expectedEdition);
	
	if realLocationStatistic = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LocationStatistics.name, null, null);
		return;
	endif;

	app.myValUA.valLocationStatistics(realLocationStatistic, pProxyLocationStatistics);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realLocationStatistic);

	if _passport.noErrors and realLocationStatistic.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'LocationStatistics', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLocationStatistic, true);
	endif;
	
	if _passport.noErrors then
		realLocationStatistic.recalculateValues(pProxyLocationStatistics);
	endif;


	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLocationStatistic, false);
	endif;

end;</source>
        <Parameter name="pProxyLocationStatistics" type="CM_LocationStatistics"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
