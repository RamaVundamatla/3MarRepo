    <JadeMethod name="kaGetNextTask" id="2ed7d2d0-bf44-4030-ae83-a15530eef6bc">
        <source>kaGetNextTask();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	machine 	: CM_Machine;
	allTasks 	: CM_RTQueueTaskArray; 
	response	: String;
	task		: CM_RTQueueTask;
begin
	app.initialize;
	
	machine:="2296.1375".asOid.CM_Machine; //KIMV
	if machine.rejectedRTQueueTasks.size &gt; 0 then
		task := machine.rejectedRTQueueTasks.first;	
		beginTransaction;
		machine.rejectedRTQueueTasks.remove(task);
		commitTransaction;
	endif;
	app.myPassport.setMyUser(machine.user);
	app.myPassport.setMyTerminal(machine.getMyTerminal);
	app.myPassport.setWarningsIgnored(true); 
	app.myPassport.warningsAcknowledged := true;
	
	create allTasks transient;	
	machine.getTasksAsJSON(allTasks);
	//app.myTrxUA.trxMachineGetNext(machine, app.myPassport);	

epilog
	delete allTasks;
end;</source>
    </JadeMethod>
    <JadeMethod name="kaGetTask" id="c200a3f4-1387-4442-88d4-8cf16dd4f19e">
        <source>kaGetTask();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	machine 	: CM_Machine;
	allTasks 	: CM_RTQueueTaskArray; 
	response	: String;
	task		: CM_RTQueueTask;
	response1	: WS_MachineTaskListResponse;
begin
	app.initialize;
	
	machine:="2296.386708".asOid.CM_Machine; //ZM4
	if machine.rejectedRTQueueTasks.size &gt; 0 then
		task := machine.rejectedRTQueueTasks.first;	
		beginTransaction;
		machine.rejectedRTQueueTasks.remove(task);
		commitTransaction;
	endif;
	app.myPassport.setMyUser(machine.user);
	app.myPassport.setMyTerminal(machine.getMyTerminal);
	app.myPassport.setWarningsIgnored(true); 
	app.myPassport.warningsAcknowledged := true;
		
	//create response1 transient;
	//response1.getAllAvailableTasks();
	
	create allTasks transient;	
	machine.getTasksAsJSON(allTasks);
	//app.myTrxUA.trxMachineGetNext(machine, app.myPassport);	

epilog
	delete allTasks;
end;</source>
    </JadeMethod>
    <JadeMethod name="kaLanderMove" id="55f270ee-eb50-4bf4-9f2c-95e44d2b0a4b">
        <source>kaLanderMove() : WS_Response;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 July 2024
TFS#		: 65359
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


vars
	response : WS_Response;
	request : WS_LanderCompleteRequest;	
	webServiceService : JMTUserInterfaceService;
	barrierDateTime :TimeStampOffset;
	completedOK : Boolean;
begin

	app.initialize();
	
	create webServiceService transient;
	
	app.myPassport.setMyUserFromCode("jlika1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["GTY"]);	

	create request transient;
	create response transient;
			
	request.setPropertyValue("cargoOid","2367.60703284");
	request.setPropertyValue("targetLocation","FK13");
	request.setPropertyValue("doLoad",false);
	request.setPropertyValue("doSOB",false);
	request.setPropertyValue("doDischargeToGround",false);
	request.setPropertyValue("doDischargeToGroundInTransit",false);
	request.setPropertyValue("doDischargeToMachine",true);
	request.setPropertyValue("voyageOid","4480.2946213");
	
	response := webServiceService.doLanderComplete(request);
	
	if response.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
epilog

	delete response;
	delete request;
	delete webServiceService;

end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
