    <JadeMethod name="canBeIncludedOnWOO" id="7c7a9a34-5bed-4ac3-98da-001d067c1a9c">
        <source>canBeIncludedOnWOO(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
*/

vars

begin
	if self.status &lt;&gt; JOB_COMPLETE and not self.isPackParentJob then	//25.03.2024 navhl20 #62300
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSplitPackJob" id="85e6c8dc-3076-4ec0-8e6c-dce9c80f3aae">
        <source>canSplitPackJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
07 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	relReq 	: CM_BulkRelease;
	resDtl	: CM_ReserveDetail;
	wod		: CM_WodPack;
	pJob	: CM_Job;
	totQty  : Integer;
begin
	wod    := self.myWODtl.CM_WodPack;
	
	if wod &lt;&gt; null then						//04.04.2025 navhl20 #34493
		return false;
	endif;
	
	relReq := wod.myReleaseRequest;
	resDtl := relReq.allReserveDetails.first;
	
	foreach pJob in self.myWODtl.allJobs discreteLock do
		if pJob.id = self.id then
			break;
		endif;
	endforeach;
	
	totQty := pJob.getTotalQuantity();
	
	if totQty &gt; 1 and self.status = JOB_UNACTIONED and wod.allPackingTIs.isEmpty() then
		return true;
	endif;
	
	if totQty &gt; 1 and self.status = JOB_PART_COMPLETE and pJob.allCompletedWLEsByDate.isNotEmpty then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createStopStartTransaction" id="237f72df-9480-47c6-b33a-bb93cb67f431">
        <source>createStopStartTransaction(_action: Integer; _ts: TimeStamp; _obj : CM_Object); 		//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars
	txnParams		: CMIF_TITransactionController;
	woTrans			: CM_WOTransaction;
	tiTrans			: CM_TITransaction;
	tiJobTrans		: CM_TIJobDetail;
	woJobTrans		: CM_WOJobDetail;
	woDtl			: CM_WorkOrderDtl;
	parentTI,
	ti				: CM_TrackedItem;
	eventType,
	woTransType,
	cargoTransType,
	vvrType 		: Integer;
	isStart 		: Boolean;
begin
	// Get the type based on the action
	self.getTypesToCreate(_action, eventType, vvrType, woTransType, cargoTransType);
	
	/*isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
	
	// Create WO Transaction
	woDtl := self.getMyWorkOrderDtl();
	if woDtl &lt;&gt; null then
		woTrans := woDtl.getLastTransOfType(woTransType);							//08.10.2024 navhl20 #12389
		if woTrans = null then														//08.10.2024 navhl20 #12389
			woTrans := woDtl.createWOTransaction(woTransType, null, null);
			if woTrans &lt;&gt; null then
				woJobTrans := woTrans.CM_WOJobDetail;
				woJobTrans.setJobActionDetails(self, isStart, _ts);
			endif;
		endif;
	endif;
	
	// Create TI transaction
	parentTI := _ti;																//08.10.2024 navhl20 #12389
	if parentTI &lt;&gt; null then														//08.10.2024 navhl20 #12389
		create txnParams transient;
		txnParams.type := cargoTransType;
		tiTrans := parentTI.createTransaction(txnParams, app.myPassport);			//08.10.2024 navhl20 #12389
		if tiTrans &lt;&gt; null then
			tiJobTrans := tiTrans.CM_TIJobDetail;
			tiJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;*/
	ti := _obj.CM_TrackedItem;														//30.10.2024 navhl20 #33232
	if ti &lt;&gt; null then																//17.10.2024 navhl20 #12389		//30.10.2024 navhl20 #33232
		parentTI := ti;																								//30.10.2024 navhl20 #33232
		parentTI.createStartStopTransUnpack(self, _action, _ts, cargoTransType);
	endif;
	if app.isWebApp and _action = Job_Action_Complete and self.status &lt;&gt; JOB_COMPLETE then
		return;
	else
		self.createWOTransaction(_action,woTransType,_ts);
	endif;
epilog
	//delete txnParams;
end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getFirstParent" id="1e7de8e3-fc43-477a-ad6b-6f197dd05dc3">
        <source>getFirstParent():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	Defect 58748: MTN - Pack Work Order details are not populated correctly on the delivery dispatch screen
*/

vars
	wod 	: CM_WorkOrderTIDtl;
	ti 		: CM_TrackedItem;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	
	wod := self.myWODtl;
	
	if wod &lt;&gt; null and self.isPackParentJob then
		ti :=  wod.allSelectedTIs.first;
		if ti &lt;&gt; null then
			ti.edition;
			if not invalid then
				return ti;
			endif;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItem" id="0dd7971e-6ab1-4710-bd00-3e3797bf1f2d">
        <source>getFirstTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023	navhl20	Defect 58748: MTN - Pack Work Order details are not populated correctly on the delivery dispatch screen

*/

vars
	ti 		: CM_TrackedItem;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	
	if self.myWODtl &lt;&gt; null then
		if self.isPackParentJob then
			ti:= self.myWODtl.CM_WodPack.allSelectedTIs.first;
		else
			ti:= self.myWODtl.CM_WodPack.allPackingTIs.first;
		endif;
		
		if ti &lt;&gt; null then
			ti.edition;
			if not invalid then
				return ti;
			endif;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
