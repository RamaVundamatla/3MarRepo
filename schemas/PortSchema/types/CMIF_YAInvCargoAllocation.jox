    <JadeMethod name="isDirectDelivery_Match" id="df057872-998b-4397-804f-7efa255e94a4">
        <source>isDirectDelivery_Match(_yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2019	jlgndl1	Initial creation	TFS 42882

*/

vars

	isDirectRelease : Boolean;

begin

	if self.myTransaction &lt;&gt; null then
		isDirectRelease := self.myTransaction.isDirectReleaseMove;
		if isDirectRelease then
			return _yaData.doesValueMatch( isDirectRelease );	
		endif;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		return _yaData.doesValueMatch( self.myTrackedItem.directDelivery );
	endif;
	
	return inheritMethod( _yaData );

epilog

end;</source>
