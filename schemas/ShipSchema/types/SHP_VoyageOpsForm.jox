    <JadeMethod name="doBtnSummariseAll" id="82203aa2-b512-450b-a938-32d650ce38f9">
        <source>doBtnSummariseAll();
/*
Purpose:		
Parameters:		
Return Value:	

Date		Who		Reason
16/02/2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
02/02/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation - summarise all tables
*/
vars
	coll				: ObjectSet;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	self.tblOnship.getAllRowObjects( coll );
	self.tblOnsite.getAllRowObjects( coll );
	self.tblOffsite.getAllRowObjects( coll );
	self.tblPreNote.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildChangeMoveMenu" id="ace71c7a-0228-45fd-a6c7-0a26524ad8d1">
        <source>doBuildChangeMoveMenu();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Mar 2021 cnwma1  ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount

*/

vars
	ti       : CM_TrackedItem;
	pFm      : CM_FutureMove;
	idx      : Integer;
	mnuChild : MenuItem;
	menu     : MenuItem;
	wle      : CM_WorkListEntry;
begin

	menu := self.mnuCargoChangeMoveAmount;
	
	menu.visible 	   := false;
	menu.enabled 	   := false;
	menu.userObject    := null;
	
	if self.myCurrentTrackedItem = null then
		return;
	endif;
	
	ti := self.myCurrentTrackedItem;
	
	if not ti.myCargoType.allowDuplicates then
		return;
	endif;

	if ti.allPlannedFutureMoves.size = 0 then
		return;
	endif;
	
	menu.enabled 	   := true;
	menu.visible 	   := true;

	foreach idx in 1 to 10 do
		mnuChild := menu.getMenuItem(idx);
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
	endforeach;
	
	idx  := 0 ;

	
	foreach pFm in ti.allPlannedFutureMoves discreteLock do
		
		if pFm.myWorkListEntry = null then
			continue;
		endif;
		
		wle  := pFm.myWorkListEntry;
		
		if wle.myRequest = null then
			continue;
		endif;
		
		//Ignore Hold Planning Jobs
		if  wle.myRequest.isKindOf(CM_HoldRequest) then
			continue;
		endif;
		
		idx 	 := idx + 1;
		mnuChild := menu.getMenuItem(idx);

		if mnuChild = null then
			mnuChild := menu.loadSubMenu(idx);
		endif;
		
		mnuChild.caption 	   := pFm.myWorkListEntry.getMoveAmountDisplay(true)  &amp;" X "&amp;  ti.id &amp; " to " &amp; pFm.getPrimaryLocationId();
		mnuChild.userObject    := pFm;
		mnuChild.visible       := true;
		mnuChild.enabled       := true;
	
	endforeach;
	
	if idx = 0 then
		menu.visible := false;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTARow" id="049a383e-3b27-4fac-8d3b-893978b6fe6f">
        <source>doBuildComboTARow();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 25 Nov 2014 		cnwma1  		PAR #27002 NPNW -  Discharge to Areas - should include RoRo Lanes
// 25 Jun 2020		jlgdap1			TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
	obj : CM_Object;
	tmpTA : CM_TerminalArea;
	row : CM_GridRow;
	col : CM_GridColumn;
	rc  : CM_RoRoController;
begin
	self.cmbTARow.clear();
	
	//13 Feb 2013	NDL	Par 31102
	obj := self.cmbTerminalArea.listObject.CM_Object;
	
	if obj = null then
		return;
	elseif obj.isKindOf(CM_TerminalArea) then
		tmpTA := obj.CM_TerminalArea;
	
		if not tmpTA.isGridArea then
			if not tmpTA.isIrregularBlockArea() and not tmpTA.type = TA_TYPE_RORO_LANE_AREA	// PAR 26709 //+ cnwma1 25/11/2014 PAR #27002
			and not tmpTA.isGeneralCargoAllocArea then									// TFS 49453
				return;
			endif;
		endif;
		
		// PAR 26709
		if tmpTA.isIrregularBlockArea() then
			foreach lc in tmpTA.CM_IrregularBlockArea.allLocationsControllers discreteLock do
				self.cmbTARow.addItemObject(tmpTA.id &amp; " - " &amp; lc.ident, lc);
			endforeach;
		elseif tmpTA.type = TA_TYPE_FORK_LIFT_STACK then //+ cnwmd1 Par 24382 - Show columns for Forklift Areas
			foreach col in tmpTA.CM_GridArea.allGridColumns discreteLock do
				self.cmbTARow.addItemObject(tmpTA.id &amp; " - " &amp; col.label , col);
			endforeach;
		elseif tmpTA.type = TA_TYPE_RORO_LANE_AREA then  //+ cnwma1 25/11/2014 PAR #27002
			foreach rc in tmpTA.CM_RoRoLaneArea.allLanesById discreteLock do
				self.cmbTARow.addItemObject(tmpTA.id &amp; " - " &amp; rc.ident , rc);
			endforeach;
		elseif tmpTA.isGeneralCargoAllocArea then										// TFS 49453
			foreach lc in tmpTA.CM_GeneralCargoAllocRowArea.allRowControllersById do	// TFS 49453
				self.cmbTARow.addItemObject(tmpTA.id &amp; " - " &amp; lc.ident, lc);			// TFS 49453
			endforeach;																	// TFS 49453
		else
			foreach row in tmpTA.CM_GridArea.allGridRows discreteLock do
				self.cmbTARow.addItemObject(tmpTA.id &amp; " - " &amp; row.label, row);
			endforeach;
		endif;
	
	elseif obj.isKindOf(CM_ShipBlockController) then
		lc := obj.CM_LocationsController;
		self.cmbTARow.addItemObject(lc.getFullId, lc);
	elseif obj.isKindOf(CM_VehicleController) then	//13 Feb 2012	NDL	Par 31102
		lc := obj.CM_LocationsController;
		self.cmbTARow.addItemObject(lc.getFullId, lc);
	elseif obj.isKindOf(CM_Wagon) then	//13 Feb 2012	NDL	Par 31102
		foreach lc in obj.CM_Wagon.allLocationsControllersArray discreteLock where lc.allTrackedItems.isEmpty do
			self.cmbTARow.addItemObject(lc.getFullId, lc);
		endforeach;
	endif;
	
	
	
	
	// PAR 26709
	if self.cmbTARow.listCount() = 1 then
		self.cmbTARow.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyages" id="5f55d93c-9af5-4de7-9662-61ab1d7e2546">
        <source>doBuildComboVoyages();
/*

Date		Who		Reason
03 September 2015	cnwer1	Initial creation PAR 36201

*/

vars
	current : Boolean; // TFS 50012
begin
	current := self.chkCurrentVoyages.value; // TFS 50012

	self.allVoyages.clear;
	self.myTerminal.getAllVoyagesOperational(self.allVoyages, current, app.myPassport);	
	self.cmbVoyage.listCollection(self.allVoyages, false, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuDisplaySub" id="7a1e7790-3b1b-4b1a-aba3-b814778a371a">
        <source>doBuildMenuDisplaySub(_index : Integer; _picture : String; _caption : String; frame: Frame input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

vars
	
	tableDisplayMode : Integer;
	mnuChild	: MenuItem;
	aPicture	: Binary;
	root : CM_Root;

begin

	tableDisplayMode := self.getDisplayModeForFrame(frame);
	
	self.mnuStatusDisplay.visible := true;
	self.mnuStatusDisplay.enabled := true;
	root := app.myRoot;

	mnuChild := self.mnuStatusDisplay.getMenuItem(_index); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := self.mnuStatusDisplay.loadSubMenu(_index); // Clone menu
		mnuChild.caption := _caption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		if root &lt;&gt; null then
			aPicture := root.getConfig(_picture).Binary;
			mnuChild.picture := aPicture;
		endif;
	endif;
	if tableDisplayMode = _index then
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;

epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_picture" type="String"/>
        <Parameter name="_caption" type="String"/>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuForTI" id="35050792-ed96-457b-b65f-4b78656dd7bc">
        <updating/>
        <source>doBuildMnuForTI() updating;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 16/06/2010	cnwcs5	par 24342 - no context menu for stops.  Also save self.myTrackedItem in local variable
// 15/12/2014	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 18/12/2019	jlgdap1	TFS 47144 JMT Refactor OOW Job Split Transfer
// 23/06/2020   cnwma1  Bug 49384: PEN - Problem with splitting jobs
// 10 December 2025	jlier1	JIRA# 36738
vars
	obj					: Object;
	hasCurrentTI		: Boolean;
	tiSet				: CM_TISet;
	ti, currentTI		: CM_TrackedItem;
	allowCreateCargoForVoy : Boolean;
	task 				: CM_RTQueueTask;								// PAR #35397
	request				: CM_Request;									// PAR #35397
	doorsForward		: Boolean;										// PAR #35397
	wle					: CM_WorkListEntry;								// PAR #35397
	actual, plan, queue	: String;										// PAR #35397
	discharge, load		: String;										// PAR #35397
	tmpMenu				: MenuItem;
	useTaskForm			: Boolean;
	job 				: CM_Job;						// TFS 47144
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	
	obj 		:= self.mnuVoyageContext.userObject;
	currentTI	:= self.myCurrentTrackedItem;			// par 24342
	
	self.mnuInspect.visible		:= app.isAllowedToInspect();													// PAR #35397
	self.mnuVoyageSep.visible	:= app.isAllowedToInspect();													// PAR #35397
	self.mnuInspect.userObject	:= currentTI;														// PAR #35397
	
	self.mnuCargoCreateNew.visible 		:= false;
	self.mnuCargoCreateItem.visible 	:= false; //ccms 1093 cnwrs1 mar 2008
	self.mnuCargoCreateItem.userObject 	:= null;	
	self.mnuGCCreateNew.visible 		:= false;
	self.mnuGCBOLEnquiry.visible 		:= false;
	self.mnuGCCargoEdit.visible 		:= false;
	self.mnuCargo.visible 				:= true;	

	self.mnuSetGrade.visible		:= false;
	self.mnuSetStops.visible		:= false;
	self.mnuTasksAdd.visible 		:= false;
	self.mnuTasksComplete.visible	:= false;
	self.mnuTasksRemove.visible 	:= false;
	self.mnuCargoTaskAdd.visible 		:= false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.visible	:= false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.visible 	:= false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemove.visible 	:= false;	//07 Oct 2015	NDL	Par 37011
	self.mnuTranship.visible 		:= false;
	self.mnuNonTranship.visible 	:= false;	//05 Aug 2013	NDL	Par 32162
	self.mnuSplitBB.visible 		:= false;	//14 Jul 2015	NDL	Par 36550
	self.mnuPlanLoadCargo.visible	:=false;  //epr par 36320 9/9/15
	
	self.mnuShowInYard.visible 		:= currentTI &lt;&gt; null and currentTI.isOnSite;					// PAR #35397
	
	self.mnuDeleteSelected.enabled := currentTI &lt;&gt; null and not currentTI.getReceiveDate.isValid;	// PAR #35397
	if self.mnuVoyageContext.userObject = self.tblPreNote then										// PAR #35397
		self.mnuShowInYard.enabled 		:= false;													// PAR #35397
		self.mnuOpsSep1.visible 		:= false;													// PAR #35397
		self.mnuQAmend.visible 			:= false;													// PAR #35397
		self.mnuQTaskStatus.visible 	:= false;													// PAR #35397
		self.mnuOpsSep2.visible			:= false;													// PAR #35397
		//self.mnuAP.visible 				:= false;													// PAR #35397
		self.mnuQueue.visible 			:= false;													// PAR #35397
		self.mnuMoveIt.visible 			:= false;													// PAR #35397
		self.mnuDoorDirections.visible 	:= false;													// PAR #35397
		self.mnuJob.visible 			:= false;													// PAR #35397
	else										 													// PAR #35397
		self.mnuShowInYard.enabled 		:= true;													// PAR #35397
		self.mnuOpsSep1.visible 		:= true;													// PAR #35397
		self.mnuQAmend.visible 			:= true;													// PAR #35397
		self.mnuQTaskStatus.visible 	:= true;													// PAR #35397
		self.mnuOpsSep2.visible			:= true;													// PAR #35397
		self.mnuAP.visible 				:= true;													// PAR #35397
		self.mnuQueue.visible 			:= true;													// PAR #35397
		self.mnuMoveIt.visible 			:= true;													// PAR #35397
		self.mnuDoorDirections.visible 	:= true;													// PAR #35397
		self.mnuJob.visible 			:= true;													// PAR #35397
	endif;																							// PAR #35397
	
	if currentTI &lt;&gt; null then 
		hasCurrentTI := true;
		
		self.myAssistant.buildMnuGridLoadPlan(self.mnuPlanLoadCargo,currentTI,null,tiSet);
		
		self.mnuCargoEnquiry.visible 	:= true;	
		self.mnuCargoEdit.visible 		:= true;
		self.mnuCargoEnquiry.userObject := currentTI;	
		self.mnuCargoEdit.userObject 	:= currentTI;
		
		if self.myCurrentTrackedItem.myReceivalBOL &lt;&gt; null then
			self.mnuGCBOLEnquiry.visible 	:= true;
			self.mnuGCCargoEdit.visible		:= not currentTI.myCargoType.isSystemCargoBOLType;  //Par 18303
		endif;

		//epr par 32261 19/8/13
		self.myAssistant.menuSetGradeBuild(self.mnuSetGrade,self.mnuSetGradeSub,currentTI);
		
		if CM_Container.hasInstance(currentTI) then
			if not currentTI.CM_Container.isEmpty() then //ccms 1093 cnwrs1 mar 2008
				self.mnuCargoCreateItem.userObject 	:= currentTI;	
				self.mnuCargoCreateItem.visible 	:= true;
			endif;
		endif;
		// par 24342 self.buildMnuStops(self.mnuSetStops, self.myCurrentTrackedItem);		
		self.mnuSetStops.userObject	:= currentTI;	// par 24342
		self.mnuSetStops.visible 	:= true;		// par 24342
		self.mnuSetStops.enabled 	:= true;		// par 24342
		
		if useTaskForm then//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskAdd.visible 		:= true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskComplete.visible	:= true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemarks.visible 	:= true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemove.visible 	:= true;	//07 Oct 2015	NDL	Par 37011
		else
			self.myAssistant.buildMnuTasksAdd(self.mnuTasksAdd,self.mnuTasksAddSub,currentTI);
			self.myAssistant.buildMnuTasksComplete(self.mnuTasksComplete,self.mnuTasksCompleteSub,currentTI);
			self.myAssistant.buildMnuTasksRemove(self.mnuTasksRemove,self.mnuTasksRemoveSub,currentTI);
		endif;
	
		self.mnuCargo.userObject := currentTI; //&lt;-- used by sub menus click events														
		self.mnuTranship.visible := true;
		self.mnuNonTranship.visible := true;		//05 Aug 2013	NDL	Par 32162
		
		// TFS 3190
		foreach ti in tiSet do
			self.mnuUnassignRels.visible := (ti.isTBAorIsRRP);
			if ti.isTBAorIsRRP then
				break;
			endif;
			
		endforeach;
		
		foreach ti in tiSet do
			self.mnuTranship.enabled := (not ti.isTranshipItem);
			if ti.isTranshipItem then
				break;
			endif;
		endforeach;
		
		//05 Aug 2013	NDL	Par 32162
		self.mnuNonTranship.enabled := false;
		foreach ti in tiSet do		
			if ti.isTranshipItem then
				self.mnuNonTranship.enabled := true;
				break;
			endif;
		endforeach;
		
		// show / hide queue and job menus as appropriate											// PAR #35397
		task := currentTI.getQueueTask;																// PAR #35397
		if task = null then																			// PAR #35397
			self.mnuQAmend.visible := false;														// PAR #35397
			self.mnuQTaskStatus.visible := false;													// PAR #35397
			self.mnuOpsSep2.visible := false;														// PAR #35397
			self.mnuJob.visible := false;															// PAR #35397
		else																						// PAR #35397
			self.mnuQAmend.visible := true;															// PAR #35397
			self.mnuQTaskStatus.visible := true;													// PAR #35397
			self.mnuOpsSep2.visible := true;														// PAR #35397
			self.mnuJob.visible := true;															// PAR #35397
			self.mnuJob.caption := app.getErrorString(Job) &amp; Space &amp; task.myEntry.myJob.getNiceName &amp; "...";	// PAR #35397
			job := task.myEntry.myJob;							// TFS 47144
			
			/* 23.06.2020 cnwma1 #49384
			if job.status = JOB_UNACTIONED then					// TFS 47144
				self.mnuJobSplit.enabled := false;				// TFS 47144
				self.mnuJobTransfer.enabled := true;			// TFS 47144
			else												// TFS 47144
				self.mnuJobSplit.enabled := true;				// TFS 47144
				foreach ti in tiSet do 							// TFS 47144
					task := ti.getQueueTask;					// TFS 47144
					if task.myEntry.myJob &lt;&gt; job then			// TFS 47144
						self.mnuJobSplit.enabled := true;		// TFS 47144
						break;									// TFS 47144
					endif;										// TFS 47144
				endforeach;										// TFS 47144
				self.mnuJobTransfer.enabled := false;			// TFS 47144
			endif;												// TFS 47144
			*/
			//23.06.2020 cnwma1 #49384
			if job &lt;&gt; null then
				self.mnuJobSplit.enabled := true;
				if job.status = JOB_UNACTIONED then	
					self.mnuJobTransfer.enabled := true;
				else
					self.mnuJobTransfer.enabled := false;
				endif;
			endif;
			//23.06.2020 cnwma1 #49384
		endif;																						// PAR #35397
		if CM_Container.hasInstance(currentTI) then													// PAR #35397
			wle := currentTI.getVoyageWLEUnactioned(true);											// PAR #35397
			if wle &lt;&gt; null and wle.myRequest.isKindOf(CM_SlotRequest) then																		// PAR #35397
				self.mnuDoorDirections.visible := true;												// PAR #35397
				doorsForward := wle.myRequest.CM_SlotRequest.doorsDirection = TI_DOORSDIRN_FWD;		// PAR #35397
				if doorsForward then																// PAR #35397
					self.mnuDoorDirections.caption := app.getErrorString(Set_Door_dir_Aft);			// PAR #35397
				else																				// PAR #35397
					self.mnuDoorDirections.caption := app.getErrorString(Set_door_dir_Forward);		// PAR #35397
				endif;																				// PAR #35397
			else																					// PAR #35397
				self.mnuDoorDirections.visible := false;											// PAR #35397
			endif;																					// PAR #35397
		else																						// PAR #35397
			self.mnuDoorDirections.visible := false;												// PAR #35397
		endif;																						// PAR #35397
		
		if currentTI.canSplitTotalQuantity and (currentTI.isOnSite  or currentTI.isOnShip ) then	//14 Jul 2015	NDL	Par 36550
			self.mnuSplitBB.visible := true;
			self.mnuSplitBB.userObject := currentTI;
		endif;
	else 
		hasCurrentTI := false;
		self.mnuCargoEnquiry.visible 	:= false;	
		self.mnuCargoEdit.visible 		:= false;
		self.mnuCargoEnquiry.userObject	:= null;	
		self.mnuCargoEdit.userObject 	:= null;
		self.mnuCargo.userObject 		:= null;
		
		self.mnuShowInYard.enabled		:= false;													// PAR #35397
		self.mnuOpsSep1.visible			:= false;													// PAR #35397
		self.mnuOpsSep2.visible			:= false;													// PAR #35397
		self.mnuQAmend.visible			:= false;													// PAR #35397
		self.mnuQTaskStatus.visible		:= false;													// PAR #35397
		self.mnuMoveIt.visible			:= false;													// PAR #35397
		self.mnuDoorDirections.visible	:= false;													// PAR #35397
		self.mnuJob.visible				:= false;													// PAR #35397
	endif;
	self.mnuCargoTransit.visible := false;
	
	if obj = self.tblOnship then
		self.mnuCargoTransit.visible 	:= hasCurrentTI;
		self.mnuCargoTransit.userObject := currentTI;
		
		self.mnuDischarge.visible 		:= hasCurrentTI;
		self.mnuLoad.visible 			:= false;
		// always display Create new Cargo menu item
		self.mnuCargoCreateNew.visible 	:= true;
		
		self.mnuMoveIt.userObject 	:= obj;															// PAR #35397
	
	elseif obj = self.tblOnsite then
		self.mnuDischarge.visible 	:= false;
		self.mnuLoad.visible 		:= hasCurrentTI;		
		self.mnuMoveIt.userObject 	:= obj;															// PAR #35397
		self.mnuCargoCreateNew.visible 	:= true; // TFS 3218 allow to create new cargo on site
		self.mnuAP.visible:=currentTI &lt;&gt; null and not currentTI.isRRPforVoyage; //jlier1 14/1/26 JIRA-36877
		
	elseif obj = self.tblOffsite then
		self.mnuDischarge.visible 	:= false;
		self.mnuLoad.visible 		:= false;
		self.mnuAP.visible			:= false;
		self.mnuQueue.visible			:= false;
		self.mnuMoveIt.visible		:= false;
		self.mnuOpsSep1.visible		:= false;
	else
		self.mnuDischarge.visible 	:= false;
		self.mnuLoad.visible 		:= false;		
	endif;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if self.allowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:=	self.myCurrentContextTbl &lt;&gt; null and
												not self.myCurrentContextTbl.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	self.mnuCargo.visible := 	self.mnuCargoCreateNew.visible or
								self.mnuCargoEnquiry.visible or
								self.mnuCargoEdit.visible or
								self.mnuCargoTransit.visible or
								self.mnuSetGrade.visible or
								self.mnuSetStops.visible or
								self.mnuTasksAdd.visible or
								self.mnuTasksComplete.visible or
								self.mnuTasksRemove.visible;								
	
	self.mnuGeneralCargo.visible := self.mnuGCCreateNew.visible or
									self.mnuGCBOLEnquiry.visible or
									self.mnuGCCargoEdit.visible;
	
	self.mnuColumnOrganiser.userObject := obj;
	self.mnuAPAll.userObject := obj;																// PAR #35397
	self.mnuAPSelected.userObject := obj;															// PAR #35397
	self.mnuAPUnplanAll.userObject := obj;															// PAR #35397
	self.mnuAPUnplanSelected.userObject := obj;														// PAR #35397
	self.mnuQueueAll.userObject := obj;																// PAR #35397
	self.mnuQueueSelected.userObject := obj;														// PAR #35397
	self.mnuQueueUnqueueAll.userObject := obj;														// PAR #35397
	self.mnuQueueUnqueueSel.userObject := obj;														// PAR #35397
	self.mnuQShowTask.userObject := obj;															// PAR #35397
	self.mnuCopyColumnToTables.userObject := obj; 													//01/04/2025	navkc1 JIRA Story MTN-33942
	self.mnuDeleteSelected.userObject := obj;	
	
	actual := app.getErrorString(Actual);
	plan := app.getErrorString(Planned);
	queue := app.getErrorString(Queued);
	discharge := app.getErrorString(Discharge);
	load := app.getErrorString(Load);
	if self.moveModeForm = REAL_MODE then
		self.mnuDischarge.caption := actual &amp; Space &amp; discharge;
		self.mnuDischargeAll.caption := actual &amp; Space &amp; discharge &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuDischargeSelected.caption := actual &amp; Space &amp; discharge &amp; Space &amp; app.getErrorString(Selected);
		self.mnuLoad.caption := actual &amp; Space &amp; load;
		self.mnuLoadAll.caption := actual &amp; Space &amp; load &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuLoadSelected.caption := actual &amp; Space &amp; load &amp; Space &amp; app.getErrorString(Selected);
	elseif self.moveModeForm = PLANNING_MODE then
		self.mnuDischarge.caption := plan &amp; Space &amp; discharge;
		self.mnuDischargeAll.caption := plan &amp; Space &amp; discharge &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuDischargeSelected.caption := plan &amp; Space &amp; discharge &amp; Space &amp; app.getErrorString(Selected);
		self.mnuLoad.caption := plan &amp; Space &amp; load;
		self.mnuLoadAll.caption := plan &amp; Space &amp; load &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuLoadSelected.caption := plan &amp; Space &amp; load &amp; Space &amp; app.getErrorString(Selected);
	elseif self.moveModeForm = QUEUE_MODE then
		self.mnuDischarge.caption := queue &amp; Space &amp; discharge;
		self.mnuDischargeAll.caption := queue &amp; Space &amp; discharge &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuDischargeSelected.caption := queue &amp; Space &amp; discharge &amp; Space &amp; app.getErrorString(Selected);
		self.mnuLoad.caption := queue &amp; Space &amp; load;
		self.mnuLoadAll.caption := queue &amp; Space &amp; load &amp; Space &amp; BR_TYPE_ALL_STR;
		self.mnuLoadSelected.caption := queue &amp; Space &amp; load &amp; Space &amp; app.getErrorString(Selected);
	endif;
	
	if currentTI &lt;&gt; null then
		self.doBuildUnplanMenu(self.mnuCargoUnplan, self.mnuCargoUnplanSingle, currentTI);
		self.mnuUnqueueSel.visible := self.hasMultiSelectedQueuedItems(obj.CM_FilterTable);
		tmpMenu := self.zCloneMenu(self.mnuOperations, self.mnuUnqueueSel, true);
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		
		self.mnuDischarge.visible := false;
		self.mnuDischargeAll.visible := false;
		
		
		self.mnuLoad.visible := false;
		self.mnuLoadAll.visible := false;
		self.mnuTranship.visible := false;
		self.mnuNonTranship.visible := false;
		self.mnuGCCargoEdit.visible := false;
		// ### MNUOPERATIONS
		self.mnuDeleteSelected.visible := false;
		self.mnuQAmend.visible:= false;
		self.mnuQTaskStatus.visible:= false;
		self.mnuTranship.visible := false;
		self.mnuNonTranship.visible := false;
		self.mnuAP.visible := false;
		self.mnuMoveIt.visible := false;
		self.mnuQueue.visible := false;
		self.mnuOpsSep1.visible := false;
		self.mnuOpsSep2.visible := false;
		// ### MNU CARGO
		self.mnuCargoCreateNew.visible := false;
		self.mnuCargoEdit.visible := false;
		self.mnuCargoTransit.visible := false;
		self.mnuTasksAdd.visible := false;
		self.mnuTasksComplete.visible := false;
		self.mnuTasksRemove.visible := false;
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemove.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		self.mnuSetStops.visible := false;
		self.mnuSetGrade.visible := false;
		self.mnuCargoCreateItem.visible := false;
		self.mnuCargoTestAPChild.visible := false;
		self.mnuCargoTestAp.visible := false;
		self.mnuSplitBB.visible := false;
	endif;

epilog
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuSeparators" id="c5704fd3-6a88-4632-8391-eaa440305a84">
        <source>doBuildMnuSeparators();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="fa3565db-68f1-496d-8fe3-5cf81b64a8cb">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		self.getCurrentlySelectedTIs(realTiSet);
		ti  := self.myCurrentTrackedItem;
		if ti = null and realTiSet.isEmpty then
			return;
		endif;
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuAssignRelease" id="ed413aac-eb7a-4af7-a789-854f5575226b">
        <updating/>
        <source>doContextMenuAssignRelease( _gcLocation : CM_VoyageController input) updating;
/*

Purpose:		Build a context menu of bulk releases that can be used for current voyage	

Parameters:			parent = self.mnuAssignRels
					children = self.mnuResDetail for individual children

Return Value:		

Date				Who		Reason
16 January 2017		cnwndl1	Initial creation	TFS 3190/2876
14/07/2025			naviv1	35226	MTN - Usage of Iterator.getCurrentKeys
28 October 2025		jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars
	
	assignReleaseSubMenu : MenuItem;
	bulkReleases : CM_BulkReleaseByTypeStCodeDict;
	bulkRelease	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	iter : Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dtKey				: TimeStamp;
	captionStr : String;
	ct : CM_CargoType;
begin

	self.allResDetMenuItems.purge();
	
	if _gcLocation &lt;&gt; null then

		self.mnuAssignRels.visible := true;
		self.mnuAssignRels.enabled := true;
		
		// Find all relevent Bulk Releases
		bulkReleases := self.myTerminal.allBulkReleaseByTypeByStByCd;
		iter := bulkReleases.createIterator();
		bulkReleases.startKeyGeq(BR_TYPE_SHIP, BR_ACTIVE, null, null, iter);
		while iter.next(bulkRelease) do 
			iter.getCurrentKeys(typeKey,statusKey,codeKey,dtKey); //MTN-35226
			if typeKey &lt;&gt; BR_TYPE_SHIP or statusKey &lt;&gt; BR_ACTIVE then
				break;
			endif;
			// Only want bulk release for current voyage
			if bulkRelease.myVoyage &lt;&gt; self.myCurrentVoyage then
				continue;
			endif;
			
			foreach reserveDetail in bulkRelease.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveSelection) then
					
					//captionStr := reserveDetail.getDescription;
					captionStr := bulkRelease.code &amp; " - " &amp; reserveDetail.getDescription;	//17 Mar 2017	NDL	TFS 3777
					assignReleaseSubMenu := self.mnuAssignRels.loadSubMenu(self.allResDetMenuItems.size+1);	
					assignReleaseSubMenu.caption := captionStr &amp; " --&gt; " &amp; _gcLocation.getID();
					assignReleaseSubMenu.visible := true;
					assignReleaseSubMenu.userObject := reserveDetail;
					assignReleaseSubMenu.setEventMapping(MenuItem::click.name,SHP_VoyageOpsForm::mnuResDetail_click.name);
					self.allResDetMenuItems.add(assignReleaseSubMenu);
					
					// ### TFS 3673
					ct := reserveDetail.getMyCargoType();
					if ct &lt;&gt; null then
						if ct.isContainer or ct.isBreakBulk() then 
							assignReleaseSubMenu.enabled := self.doGetReserveDetailQuantity(reserveDetail) &gt; 0;
						elseif ct.isBulk() then 
							assignReleaseSubMenu.enabled := self.doGetReserveDetailWeight(reserveDetail) &gt; 0;
						endif;
					endif;
						
				endif;
			endforeach;
		endwhile;
		
		if self.allResDetMenuItems.isEmpty then
			self.mnuAssignRels.enabled := false;
		endif;
	endif;	
epilog
	
	delete iter;
	
end;</source>
        <Parameter name="_gcLocation" type="CM_VoyageController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCopyColumnToTables" id="9c59dfef-60fa-4e24-8682-0991ddc79ae9">
        <updating/>
        <source>doCopyColumnToTables(_sourceTable : CM_DataTable input) updating;
/*

Purpose:			This method copy the columns and sorting order from the _sourceTable to the other tables.

Parameters:			

Return Value:		

Date		Who		Reason
01/04/2025	navkc1 JIRA Story MTN-33942: MTN | Voyage Ops Column Copy option

*/

vars
	onShip,
	onSite,
	prenote,
	offsite		: CM_DataTable;
begin
	
	onShip := self.tblOnship;
	onSite := self.tblOnsite;
	prenote := self.tblPreNote;
	offsite := self.tblOffsite;
	
	if _sourceTable = onShip then
		_sourceTable.copyColumnsToTable(onSite);
		_sourceTable.copyColumnsToTable(prenote);
		_sourceTable.copyColumnsToTable(offsite);
	elseif _sourceTable = onSite then
		_sourceTable.copyColumnsToTable(onShip);
		_sourceTable.copyColumnsToTable(prenote);
		_sourceTable.copyColumnsToTable(offsite);
	elseif _sourceTable = prenote then
		_sourceTable.copyColumnsToTable(onShip);
		_sourceTable.copyColumnsToTable(onSite);
		_sourceTable.copyColumnsToTable(offsite);
	elseif _sourceTable = offsite then
		_sourceTable.copyColumnsToTable(onShip);
		_sourceTable.copyColumnsToTable(onSite);
		_sourceTable.copyColumnsToTable(prenote);
	endif;
epilog

end;</source>
        <Parameter name="_sourceTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteCargo" id="d4fb5ad9-5ef2-410b-93f3-b7dda164751e">
        <updating/>
        <source>doDeleteCargo() updating;
//----------------------------------------------------------------
//	Created:	03 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	result 			: Integer;
	ti				: CM_TrackedItem;
	tiSet 			: CM_TISet;
	ta				: CM_TerminalArea;
	targetLocn 		: CM_LocationsController;
	tisWithWarnSet 	: CM_TISet;
	retval			: Integer;	
begin
	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		
	
	create tiSet transient;
	self.getAllSelectedTIs("", tiSet, false, self.tblOnship);
		
	if tiSet.isEmpty then
		return;
	endif;

	foreach ti in tiSet do
		if ti.getReceiveDate().isValid then
			app.msgBox("Your selection contains cargo not suitable for deleting.  You can only delete unworked cargo.", 'Invalid Cargo', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
	endforeach;

	retval := app.msgBox("You are about to delete all the selected cargo items.  Continue?", 'Confirm Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if retval = MsgBox_Return_No then
		return;
	endif;
	
	create tisWithWarnSet transient;

	while true do
		app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, false, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Delete Ship Cargo', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete tisWithWarnSet;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDischarge" id="a9501ab4-9ec1-4149-a6af-45e1dd5e6c24">
        <updating/>
        <source>doDischarge(_all : Boolean; _fromDragDrop : Boolean; _table : CM_DataTable; win: Window input) updating;
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
// 27 Aug 2014	cnwma1	PAR#34779  Discharging from a non planned voyage - I am unable to discharge
// 25 Nov 2014	cnwma1	PAR #27002 NPNW -  Discharge to Areas - should include RoRo Lanes
// 25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 02/04/2024	navkc1 Bug 61474: MTN - 1090 when discharged cargo to Offsite using Voyage Ops form in Hybrid mode
// 20/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//--------------------------------------------------
vars
	result 					: Integer;
	firstTI 				: CM_TrackedItem;
	tiSet 					: CM_TISet;
	ta						: CM_TerminalArea;
	primaryActualLocation,
	targetLocn 				: CM_LocationsController;
	moveController 			: CMIF_MoveController;
	listObject				: CM_Object;
	gridObject 				: CM_GridObject;
	wle 					: CM_WorkListEntry;
	ti						: CM_TrackedItem;
	requiresJob,
	isMoveToPlanned			: Boolean;
	tiIDs					: String;
	showMoveConfirmation 	: Boolean;
	isNonCraneVoyageMove 	: Boolean;	//07 Sep 2018	NDL	TFS 39972
begin
	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	isNonCraneVoyageMove := true;		//07 Sep 2018	NDL	TFS 39972 - default value
	
	// 08 Apr 2011	NDL	Par 27045
	if self.cmbTerminalArea.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(PleaseSelectLocation),app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);		
		return;
	elseif self.cmbTerminalArea.text = app.getErrorString(Planned_location) then		// 26/6/17 MAP TFS4719
		isMoveToPlanned := true;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	create tiSet transient;
	// cnwmc5 - 28 August 2014 - PAR 34779 - move this block up here so we can use the moveController in validation
	// We must have been a drag and drop
	if _fromDragDrop and global.isValidObject(app.myMoveController) then
		// Hopefully we have a few tracked items to play with.
		moveController := app.myMoveController;
		
		if isMoveToPlanned then		// 26/7/17 MAP TFS4719	weed out TIs that don't have a planned location
			foreach ti in moveController.allOtherTrackedItems do
				if ti.allPlannedFutureMoves.size = 0 then
					moveController.allOtherTrackedItems.remove(ti);
				endif;
			endforeach;
			if moveController.myTrackedItem.allPlannedFutureMoves.size = 0 then
				if moveController.allOtherTrackedItems.size &gt; 0 then
					moveController.setMyTrackedItem(moveController.allOtherTrackedItems.first());
					moveController.allOtherTrackedItems.remove(moveController.myTrackedItem);
				else
					return;
				endif;
			endif;
		endif;
		
		self.getDragDropTIsForController(moveController);			// TFS 53388
		if moveController.myTrackedItem = null then
			return;
		endif;
		
	elseif not _fromDragDrop then
		if global.isValidObject(app.myMoveController) then
			delete app.myMoveController;
		else
			app.myMoveController := null;
		endif;
	
		create moveController transient;
		app.myMoveController := moveController; // PAR 13067
		
		self.getAllSelectedTIs("", tiSet, _all, self.tblOnship);
		if tiSet.isEmpty then
			return;
		endif;
		
		firstTI := tiSet.first;
		//epr par 36292 25/5/15 
		moveController.setMyTrackedItem(firstTI);	
		moveController.setMyOriginatingLocation(firstTI.myPrimaryActualLocation);
		
		//07 Sep 2018	NDL	TFS 39972
		if tiSet.size &gt; 1 then
			foreach ti in tiSet do
				wle := ti.getVoyageWLEUnactioned( false );
				if wle &lt;&gt; null then
					moveController.allOtherWLEs.add( wle );
				endif;
			endforeach;
			if not moveController.allOtherWLEs.isEmpty then
				// so we re-evaluate isNonCraneVoyageMove for each ti in "CM_UtilityUpdateAgent::utlUpdateMoveTrackedItems"
				// some may already have discharge wles that we want to use
				// others may not
				moveController.myOriginatingForm := self;	
			endif;
		else
			wle := firstTI.getVoyageWLEUnactioned( false );
			if wle &lt;&gt; null then
				isNonCraneVoyageMove := false;  // because there is only one ti and it has a real wle already that we want to use
				moveController.setMyWorkListEntry( wle );
			endif;	
		endif;
		
	endif;

// PAR 33644	if (not self.myCurrentVoyage.isCelluarStructureRORO()) 
// PAR 33644	and self.cmbTerminalArea.listObject = null // 08 Apr 2011	NDL	Par 27045
	// PAR 33644 and self.myCurrentVoyage.isNonWorkedVoyage and (not self.myCurrentVoyage.isNonPlannedVoyage) then
	if (self.cmbTerminalArea.text = "**Off Site**" 
		and self.myCurrentVoyage.isHOLDSorSHIP())
	or (_table = self.tblOffsite and process.isJLGAB1()) then // TFS 45731
		// No target location, tis are released directly off site for non-worked voyages
		targetLocn := null;
	elseif not isMoveToPlanned then //non-planned or mixed voyage - see if they have selected a discharge area
		listObject := self.cmbTerminalArea.listObject.CM_Object;
		if CM_TerminalArea.hasInstance(listObject) then
			ta := listObject.CM_TerminalArea; 
		elseif CM_LocationsController.hasInstance(listObject) then
			targetLocn := listObject.CM_LocationsController;
		//13 Feb 2013	NDL	Par 31102
		elseif CM_Wagon.hasInstance(listObject) then
			targetLocn := self.cmbTARow.listObject.CM_LocationsController;
		endif;
		
		// cnwmc5 - 28 August 2014 - PAR 34779 - move this so can validate before deciding if can just move offsite..
		if _fromDragDrop and global.isValidObject(app.myMoveController) then
			//04 Feb 2011	NDL	Par 26867
			if _table = self.tblOffsite then
				targetLocn := null;
				ta := null;				// cnwmc5 - 28 August 2014 - PAR 34779 
			endif;
		endif;
	
		if targetLocn = null then
		
			if ta = null then
				// cnwmc5 - 28 August 2014 - PAR 34779 - change validation below to check ALL cargo on the move controller..
				requiresJob := false;
				primaryActualLocation := moveController.myTrackedItem.myPrimaryActualLocation; //02/04/2024	navkc1 Bug 61474
				//if (self.myCurrentVoyage.isLOLOorRORO()) then						// 27 Aug 2014 -cnwma1 PAR#34779 
				//if moveController.myTrackedItem.myPrimaryActualLocation.requiresJob then  // 27 Aug 2014 +cnwma1 PAR#34779 
				if primaryActualLocation &lt;&gt; null and primaryActualLocation.requiresJob() then //02/04/2024	navkc1 Bug 61474
					requiresJob := true;
				endif;
				
				if not requiresJob then //02/04/2024	navkc1 Bug 61474
					foreach ti in tiSet do
						primaryActualLocation := ti.myPrimaryActualLocation; //02/04/2024	navkc1 Bug 61474
						//if ti.myPrimaryActualLocation.requiresJob then
						if primaryActualLocation &lt;&gt; null and primaryActualLocation.requiresJob() then //02/04/2024	navkc1 Bug 61474
							requiresJob := true;
							break;
						endif;
					endforeach;
				endif;
				if requiresJob then
					// they must select a discharge area			
					app.msgBox(app.getErrorString1(Requires_job_discharge_offsite,ti.id), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);		
					return;
				endif;
			else
				if ta.isGridArea() then
					//tmpRow := self.cmbTARow.listObject.CM_GridRow; //- cnwmd1, Par 24382
					gridObject := self.cmbTARow.listObject.CM_GridObject;
					//if tmpRow = null then //- cnwmd1, Par 24382
					if gridObject = null then //+ cnwmd1 Par 24382
						app.msgBox(app.getErrorString(PleaseSelectLocation), app.getErrorString(Select_discharge_area_row), MsgBox_Stop_Icon + MsgBox_OK_Only);		
						return;
					endif;
					//targetLocn := tmpRow.getNextAvailableLocation(); //- cnwmd1 Par 24382
					targetLocn := gridObject.getNextAvailableLocation(self.moveModeForm); //+ cnwmd1 Par 24382 // PAR 35397 added move mode
					if targetLocn = null then
						//app.msgBox("There are no empty locations in row " &amp; ta.id &amp; " - " &amp; tmpRow.label &amp; ".", 'Select Discharge Area', MsgBox_Stop_Icon + MsgBox_OK_Only);		 //- cnwmd1, Par 24382
						app.msgBox(app.getErrorString2(There_empty_locations,ta.id, gridObject.label), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);	 //+ cnwmd1 Par 24382
						return;
					endif;
				// PAR 26709
				elseif ta.isIrregularBlockArea()  or ta.type=TA_TYPE_RORO_LANE_AREA     //+ cnwma1 25/11/2014 PAR #27002
				or ta.isGeneralCargoAllocArea then									// TFS 49453
					targetLocn := self.cmbTARow.listObject.CM_LocationsController;
					if targetLocn = null then
						app.msgBox(app.getErrorString1(Please_select_locatio_within, ta.id), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);
						return;
					endif;
				else
					targetLocn := ta.getLocationsController();		
				endif;
			endif;
		endif;
	endif;	
	
	//cnwrd1 par 28343 14.10.2011
	// if we have received a drag drop from another form we want to leave the move controllers move mode as it is!
	if win = null then // no drag drop use our forms mode
		moveController.setMoveMode(self.moveModeForm);	//19 Nov 2009	NDL	CCMS 1031
	else
		if win.isKindOf(Control) then
			if win.Control.form = self then
				moveController.setMoveMode(self.moveModeForm);	
			endif;
		elseif win.isKindOf(Form) then
			if win = self then
				moveController.setMoveMode(self.moveModeForm);	
			endif;
		endif;
	endif;
	
	moveController.setMyToPrimaryLocation(targetLocn);
	//moveController.transferType := VESSEL_TYPE_RORO; // TFS 4435 CNWAB1 MAY17 self.chkRORO.value.Integer; // 0 = LOLO 1 = RORO 
	moveController.transferType := self.getVoyJobTransferType();	//12 Mar 2018	NDL	TFS 37444
	moveController.isNonCraneVoyageMove := isNonCraneVoyageMove; // PAR 23819
	moveController.isMoveToPlanned := isMoveToPlanned;	// 27/6/17 MAP TFS4719

	if self.cbRetrospective.value and self.myTerminal.getConfig(VoyageRetroDefault).Boolean and self.myCurrentVoyage.shipExchangeCompleteDT.isValid then	//17 May 2021	NDL	TFS 51199
		moveController.setEffectiveTimeStampOverride(self.myCurrentVoyage.shipExchangeCompleteDT);
	elseif self.myCurrentVoyage.nonPlannedEffectiveDT.isValid and self.cbRetrospective.value then
		moveController.setEffectiveTimeStampOverride(self.myCurrentVoyage.nonPlannedEffectiveDT);
	endif;
	
	
	//04 Feb 2011	NDL	Par 26867
	if moveController.myToPrimaryLocation = null then //epr par 36325 17/7/15
		if self.moveModeForm &lt;&gt; REAL_MODE then
			if app.msgBox(app.getErrorString(Offsite_move_instant_only), app.getErrorString(Move_error), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
			moveController.setMoveMode(REAL_MODE);
		endif;
	endif;
	
	tiIDs := moveController.myTrackedItem.id;				// 28/6/17 MAP TFS4719
	if moveController.allOtherTrackedItems &lt;&gt; null then
		foreach ti in moveController.allOtherTrackedItems do
			tiIDs := tiIDs &amp; Comma &amp; Space &amp; ti.id;
		endforeach;
	endif;
	if tiSet &lt;&gt; null then
		foreach ti in tiSet where ti &lt;&gt; moveController.myTrackedItem do
			tiIDs := tiIDs &amp; Comma &amp; Space &amp; ti.id;
		endforeach;
	endif;

	if tiSet = null or tiSet.size &lt;= 1 then
	//	if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.canMergeBreakBulk then
		if moveController.myTrackedItem &lt;&gt; null
		and moveController.myTrackedItem.canMergeBreakBulk
		and moveController.allOtherTrackedItems.isEmpty	//19 Sep 2016	NDL TFS 7016
		then
			if not self.getQuantityForMove( moveController ) then
				return;
			endif;
		else
			if chkConfirmAllMoves.value and
				moveController.moveMode = REAL_MODE and
				//((win = null) or (win.isKindOf(Control) and win.Control.form = self)) and
				app.msgBox(app.getErrorString1(Please_confirm_move, tiIDs), app.getErrorString(Warning), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		
				return;
			endif;
		endif;
		
		//epr par 32868 30/10/13
		if targetLocn.isKindOf(CM_VehicleController) and  moveController.myTrackedItem &lt;&gt; null then
			wle:=moveController.myTrackedItem.getIncompleteRoadWleForJob(targetLocn.CM_VehicleController.vehicle,false);
			if wle &lt;&gt; null then
				moveController.setMyWorkListEntry(wle);
			endif;
		endif;
	else		// 30/6/17 MAP TFS4719
		if chkConfirmAllMoves.value and
			moveController.moveMode = REAL_MODE and
			app.msgBox(app.getErrorString1(Please_confirm_move, tiIDs), app.getErrorString(Warning), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
	
			return;
		endif;
	endif;

	showMoveConfirmation := app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean;		// 8/9/17 MAP TFS6818
	if showMoveConfirmation then
		moveController.nonWorkedInstantPreMove();	//01 Aug 2013	NDL	Par 32140
	
		if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;

	while true do	
		//epr par 36214 14/5/15 if we don't call this method the validation for move to locations doesn't work
		if tiSet &lt;&gt; null and tiSet.size &gt; 1 then
			app.myTrxUA.trxMoveTrackedItems(tiSet,moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Discharge Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				moveController.isNonCraneVoyageMove := isNonCraneVoyageMove;  //+ cnwmd1, Par 24382  -&gt; Needs to be reset to true so Jobs and WLE's can be recreated
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	if moveController &lt;&gt; null then
		moveController.isMoveToPlanned := false;
	endif;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_fromDragDrop" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="win" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDockContainerResize" id="e3af5496-07c5-4b53-8ff0-025036920e40">
        <updating/>
        <source>doDockContainerResize(_dock : JadeDockContainer input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	if _dock.isFloating then
		_dock.userObject.SHP_VoyageOpsForm.doResize;
	else
		self.doResize;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dock" type="JadeDockContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEditBOL" id="2ce66a89-f1bd-4964-b6d9-0bb8cfccbb9d">
        <source>doEditBOL(_bol : CM_BOLIn);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2017	cnwdap1		Initial creation TFS 4744 AAT Error when transhipping cargo
//
vars
	form : CMUI_BOLMaintForm;

begin
	form := app.loadForm(	CMUI_BOLMaintForm,
							self.myAssistant.class,
							false,
							false,
							false,
							self.myTerminal, 
							null	).CMUI_BOLMaintForm;
	
	if form = null then
		return;				// may have failed security check
	endif;

	form.setCaption(app.getString(EditShipBOL));
	form.setMode(CM_TableViewForm.Mode_Update);
	form.setMyCurrentBOL(_bol);
	form.setMyBOLType(_bol.getMyBOLType);
	
	form.show();
epilog

end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="doEditCargo" id="ac5b45f5-9f1c-4940-9abd-3d27c782cd30">
        <source>doEditCargo(_ti : CM_TrackedItem; _editCurrentObject : Boolean);
//-----------------------------------------------------------------------
//	Created:	31 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	----------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
//
vars
	objArr : ObjectArray;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
begin
	create objArr transient;
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	tiSet.copy(objArr);
	if (not tiSet.includes(_ti)) then
		tiSet.add(_ti);
	endif;
	
	self.myAssistant.showCargoEnquiryForTIs(tiSet.first, objArr, self.myMasterMenuAction, _editCurrentObject);
epilog
	delete objArr;
	delete tiSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterVisibilityForNote" id="6bfe59f8-32d1-4f15-b0e6-8ded390cc25b">
        <source>doFilterVisibilityForNote( _table : CM_DataTable input; _rowIndex : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2014	cnwndl1	Initial creation	Par 32501

*/

vars

begin

	//14 Jan 2015	NDL
	if _table.isKindOf(CM_FilterTable) then
		_table.CM_FilterTable.applyColumnFilterToRow( _rowIndex, true );
	endif;
											
	self.colourTableRows( _table );


epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFirstRunAfterUpgrade" id="9313d61b-a4d0-456c-8b41-8b20fbab0cb2">
        <updating/>
        <source>doFirstRunAfterUpgrade(_userWindow: CM_UserWindow) updating;
/*

Purpose:			This method populates the Classic, Hybrid, and ECO behavior into the new notification framework
					Will only be run the first time user open the form after this form changed from old to new framework

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2025	navkc1	JIRA MTN 35788

*/

vars
	idx,
	refreshMin: Integer;
	chkTableCount,
	optManRefresh,
	optMinRefresh,
	optCurRefresh,
	optHybrid,
	optEco,
	optClassic : String;
	wasClassic,
	wasEco,
	wasHybrid,
	curRefresh,
	manRefresh,
	minRefresh : Boolean;
begin
	// These were the user settings before the notification change in voyage operation form
	optClassic := _userWindow.xmlInfo.cnEcGetTagValueOfName("optClassicMode");
	optHybrid := _userWindow.xmlInfo.cnEcGetTagValueOfName("optHybridMode");
	optEco := _userWindow.xmlInfo.cnEcGetTagValueOfName("optEcoMode");
	refreshMin := _userWindow.xmlInfo.cnEcGetTagValueOfName("cmbRefreshMins").Integer;
	chkTableCount := _userWindow.xmlInfo.cnEcGetTagValueOfName("chkTableCount");
	
	wasClassic := optClassic &lt;&gt; null and optClassic = "true";
	wasHybrid := optHybrid &lt;&gt; null and optHybrid = "true";
	wasEco := optEco &lt;&gt; null and optEco = "true";
	
	if not wasClassic and not wasHybrid and not wasEco then
		// This user setting is old enough and doesn't have the Classic Hybrid ECO mode. Use "chkTableCount" to check as it's implemented with Classic Hybrid ECO mode and is still being used
		if chkTableCount = null then
			self.chkTableCount.value := true;
			self.chkAllowFilter.value := true;
			self.chkAllowMore20.value := true;
		endif;
		// On getXMLSettingsForSave, we no longer save these tags.
		// If they are null that means user has opened and saved this form after the upgrade
		// Don't need to do anything
		return;
	endif;
	
	// First time opening the form after notification change
	if wasClassic or wasEco or wasHybrid then
		self.frmNotifications.visible := true; //hacky way so it doesn't get displayed when we call doBtnNotiSaveClick() later;
		
		// Was doing Classic
		if wasClassic then
			self.optDoNotes.value := true;
			self.chkTableCount.value := true;
			self.chkAllowFilter.value := true;
			self.chkAllowMore20.value := true;
		// Was doing ECO
		elseif wasEco then
			// ECO was doing refresh current view. 
			//	That is no longer an option in the new framework, so don't do notification
			self.optNoNotes.value := true;
			self.chkTableCount.value := false;
			self.chkAllowFilter.value := false;
			self.chkAllowMore20.value := false;
		elseif wasHybrid then
			/* 	Hybrid mode can do 
					1) Manual Refresh ( = new framework self.NoteLevelNoNotes) or 
					2) Refresh x min ( = new framework self.NoteLevelNoNotesRefresh) or 
					3) Refresh Current View ( = new framework self.NoteLevelNoNotes)
			
			Get the settings before upgrade, and populate them into the new notification framework
			*/
			optMinRefresh := _userWindow.xmlInfo.cnEcGetTagValueOfName("optMinsRefresh"); 	// Refresh every x minute
			optManRefresh := _userWindow.xmlInfo.cnEcGetTagValueOfName("optManualRefresh");	// Manual Refresh (Dont do notification)
			optCurRefresh := _userWindow.xmlInfo.cnEcGetTagValueOfName("optCurrentView");	// Refresh current view (Dont do notification)
			
			minRefresh := optMinRefresh &lt;&gt; null and optMinRefresh = "true";
			manRefresh :=  optManRefresh &lt;&gt; null and optManRefresh = "true" ;
			curRefresh :=  optCurRefresh &lt;&gt; null and optCurRefresh = "true" ;
			
			// Was doing refresh x min, get the minutes to refresh
			if minRefresh then
				
				// Default to 15
				if refreshMin = null then
					refreshMin := 15;
				// We don't have 3 mins now, set to 5
				elseif refreshMin = 3 then
					refreshMin := 5;
				elseif curRefresh then
					refreshMin := 0;
				endif;
			endif;
			
			// Manual Refresh or Refresh current view, set not to do notification
			if manRefresh or curRefresh then
				self.optNoNotes.value := true;
			// Refresh every x minutes
			elseif minRefresh then 
				self.optNoNotesRefresh.value := true;
				self.autoRefreshValue := refreshMin;
				
				// Set the combobox
				idx := self.cmbNotiMinutes.findItemData(self.autoRefreshValue);
				if idx &gt; null then
					self.cmbNotiMinutes.listIndex := idx;
				endif;
			endif;
		endif;
		// Update the notification level setting
		self.doBtnNotiSaveClick();
	endif;
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="doGetAmount" id="08fdfe36-2e72-429f-8fc9-c5cbb5c21920">
        <updating/>
        <source>doGetAmount( _reserveDetail : CM_ReserveDetail; _qtyType : Integer; _req : CM_HoldRequest) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
FEB 2017		CNWAB1		Initial creation
*/


vars
	theAmount, modalResult : Integer;
	theWeight : Real;
	req : CM_VoyageRequest;
	wle : CM_WorkListEntry;
	lForm : CMUI_GetData;
	weight : CM_MeasurementType;
	weightType : String;

begin
	app.mousePointer := MousePointer_Default;



	create lForm;
	lForm.centreWindow;
	lForm.myCaller := self;
	lForm.myTerminal := self.myTerminal;
	lForm.type := _qtyType; 

	if _qtyType = GETVALUE_QUANTITY then
		theAmount := self.doGetReserveDetailQuantity(_reserveDetail);
	
		if theAmount &lt; 1 then
			theAmount := 1;
		endif;
		lForm.lblTextCaption := app.getErrorString(Quantity).cnEcFirstToUpper &amp; ":";
		lForm.txtData.text := theAmount.String;
		lForm.txtData.maxLength := 9;
		lForm.txtData.dataType := TextBox.DataType_Numeric;
		lForm.txtData.decimals := 0;		
		lForm.formCaption := app.getErrorString(CM_Quantity);
	elseif _qtyType = GETVALUE_WEIGHT then  // TFS 3873
		weight := app.getDefaultMeasurementForType(Type_Weight);
		theWeight := self.doGetReserveDetailWeight(_reserveDetail);
	
		if theWeight &lt; 1 then
			theWeight := 1;
		endif;
		lForm.msrWeight.visible := true;
		lForm.msrWeight.setup(Type_Weight, self.backColor);
		lForm.msrWeight.tabKey := J_key_Tab;
		if weight &lt;&gt; null then																					
			weightType := weight.shortName;																		
			lForm.msrWeight.setValues(app.convertMeasurementForDisplay(weightType, theWeight) &amp; Space &amp; weightType);	
		endif;
		lForm.lblTextCaption := app.getErrorString(Weight).cnEcFirstToUpper &amp; ":";
		lForm.txtData.visible := false;
		lForm.formCaption := app.getErrorString(Weight);
	endif;
	
	lForm.doResize;
	modalResult := lForm.showModal;
	
	
	return modalResult = ModalResultOK;
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_qtyType" type="Integer"/>
        <Parameter name="_req" type="CM_HoldRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGetReserveDetailQuantity" id="623987e6-e92f-41aa-a28c-0e11b1ccb83f">
        <updating/>
        <source>doGetReserveDetailQuantity( _reserveDetail : CM_ReserveDetail) : Integer updating;
/*
Purpose:			
Date				Who			Reason
FEB 2017		CNWAB1		Initial creation
*/


vars
	theAmount : Integer;
	req : CM_VoyageRequest;
	wle : CM_WorkListEntry;
begin

	if _reserveDetail &lt;&gt; null then
	
		theAmount := _reserveDetail.getAssignedAmountHolds();
	endif;
	
	return theAmount;
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGetReserveDetailWeight" id="baf81c6a-8581-4f28-ad03-8ffe7ba57f93">
        <updating/>
        <source>doGetReserveDetailWeight( _reserveDetail : CM_ReserveDetail) : Real updating;
/*
Purpose:		 // TFS 3873	
Date				Who			Reason
FEB 2017		CNWAB1		Initial creation
*/


vars
	theAmount : Real;
	req : CM_VoyageRequest;
	wle : CM_WorkListEntry;
	lForm : CMUI_GetData;
begin

	if _reserveDetail &lt;&gt; null then
		theAmount := _reserveDetail.getTotalWeightRequested;
		foreach req in _reserveDetail.allVoyageRequestsAssigned discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				theAmount := theAmount - wle.weight;
			endforeach;
		endforeach;
	endif;

	return theAmount;
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="d7ecaf39-ab21-49da-9557-458adb17b37a">
        <updating/>
        <source>doLoad(_all : Boolean; _table : CM_DataTable input; win: Window input) updating;
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
// 19 July 2019 cnwma1 Bug 45706: MSL - RORO Moves - voyage SHA021
// 05 Nov 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 18 Nov 2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
// 28 Feb 2022	navdap1	TFS 52683 MTN Direct Delivery - Load from Voyage Ops not working
// 24/02/2024 navcs2 MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 28 Oct 2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//--------------------------------------------------
vars
	result 					: Integer;
	ti,
	firstTI 				: CM_TrackedItem;
	tiSet 					: CM_TISet;
	ta						: CM_TerminalArea;
	targetLocn 				: CM_LocationsController;
	moveController 			: CMIF_MoveController;
	wle 					: CM_WorkListEntry;
	isMoveToPlanned			: Boolean;
	tiIDs,
	tiId					: String;
	showMoveConfirmation	: Boolean;
	isLoadJobExist      	: Boolean;
	vwle 					: CM_VoyageWLE;
	directLoad 				: Boolean;				// TFS 51935
	lc 						: CM_LocationsController;		// TFS 52360
	foundHeight 			: Integer;				// TFS 52360		
begin
	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	directLoad := self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;		// TFS 51935
	targetLocn := self.cmbLoadLocation.listObject.CM_LocationsController;
	
	if targetLocn = null then
		if self.cmbLoadLocation.text = app.getErrorString(Planned_location) then		// 26/6/17 MAP TFS4719
			isMoveToPlanned := true;
		else
			app.raiseCMException(Input_required_field_loadTo, null, null); 				// cnwdb2	PAR 35364
			self.cmbLoadLocation.setFocus();
			return;
		endif;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		

	// We must have been a drag and drop
	if _table = self.tblOnship and global.isValidObject(app.myMoveController) then
		// Hopefully we have a few tracked items to play with.
		moveController := app.myMoveController;

		if isMoveToPlanned then		// 26/7/17 MAP TFS4719	weed out TIs that don't have a planned location
			foreach ti in moveController.allOtherTrackedItems do
				if ti.allPlannedFutureMoves.size = 0 then
					moveController.allOtherTrackedItems.remove(ti);
				endif;
			endforeach;
			if moveController.myTrackedItem.allPlannedFutureMoves.size = 0 then
				if moveController.allOtherTrackedItems.size &gt; 0 then
					moveController.setMyTrackedItem(moveController.allOtherTrackedItems.first());
					moveController.allOtherTrackedItems.remove(moveController.myTrackedItem);
				else
					return;
				endif;
			endif;
		endif;
		self.getDragDropTIsForController(moveController);			// TFS 53388
	else
		if global.isValidObject(app.myMoveController) then
			delete app.myMoveController;
		else
			app.myMoveController := null;
		endif;
		
		create moveController transient;
		app.myMoveController := moveController;
		create tiSet transient;
		self.getAllSelectedTIs("", tiSet, _all, _table);
		if tiSet.isEmpty then
			return;
		endif;
		firstTI := tiSet.first;
		tiSet.remove(firstTI);
		moveController.setMyTrackedItem(firstTI);
		moveController.setAllOtherTrackedItems(tiSet);
	endif;
	
	//moveController.transferType := VESSEL_TYPE_RORO; // TFS 4435 CNWAB1 MAY17 self.chkRORO.value.Integer; // 0 = LOLO 1 = RORO 
	moveController.transferType := self.getVoyJobTransferType();	//12 Mar 2018	NDL	TFS 37444
	moveController.setMyToPrimaryLocation(targetLocn);	
	moveController.isMoveToPlanned := isMoveToPlanned;	// 29/6/17 MAP TFS4719

	// if we have received a drag drop from another form we want to leave the move controllers move mode as it is!
	if win = null then // no drag drop use our forms mode
		moveController.setMoveMode(self.moveModeForm);
	else
		if win.isKindOf(Control) then
			if win.Control.form = self then
				moveController.setMoveMode(self.moveModeForm);	
			endif;
		elseif win.isKindOf(Form) then
			if win = self then
				moveController.setMoveMode(self.moveModeForm);	
			endif;
		endif;
	endif;
	
	moveController.isNonCraneVoyageMove := true; // PAR 23819

	if self.cbRetrospective.value and self.myTerminal.getConfig(VoyageRetroDefault).Boolean and self.myCurrentVoyage.shipExchangeCompleteDT.isValid then	//17 May 2021	NDL	TFS 51199
		moveController.setEffectiveTimeStampOverride(self.myCurrentVoyage.shipExchangeCompleteDT);
	elseif self.myCurrentVoyage.nonPlannedEffectiveDT.isValid and self.cbRetrospective.value then
		moveController.setEffectiveTimeStampOverride(self.myCurrentVoyage.nonPlannedEffectiveDT);
	endif;
	
	tiIDs := moveController.myTrackedItem.id;				// 28/6/17 MAP TFS4719
	if moveController.allOtherTrackedItems &lt;&gt; null then
		foreach ti in moveController.allOtherTrackedItems do
			tiIDs := tiIDs &amp; Comma &amp; Space &amp; ti.id;
		endforeach;
	endif;
	
	// navmd1 TFS 55379 TIs in the tiSet have already been copied to the allOtherTrackedItems collection, so this just add duplicates!
	/*if tiSet &lt;&gt; null then
		foreach ti in tiSet where ti &lt;&gt; moveController.myTrackedItem do
			tiIDs := tiIDs &amp; Comma &amp; Space &amp; ti.id;
		endforeach;
	endif;*/

	//23 Sep 2013	NDL	Par 32479
	if tiSet = null or tiSet.size &lt;= 1 then
		if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.canMergeBreakBulk then
			if not self.getQuantityForMove( moveController ) then
				return;
			endif;
		else
			if chkConfirmAllMoves.value and				// 28/6/17 MAP TFS4719
				moveController.moveMode = REAL_MODE and
				//((win = null) or (win.isKindOf(Control) and win.Control.form = self)) and
				app.msgBox(app.getErrorString1(Please_confirm_move, tiIDs), app.getErrorString(Warning), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		
				return;
			endif;
		endif;
		//epr par 32868 30/10/13
		if moveController.myTrackedItem &lt;&gt; null and  moveController.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_VehicleController)  then
			wle:=moveController.myTrackedItem.getIncompleteRoadWleForJob(moveController.myTrackedItem.myPrimaryActualLocation.CM_VehicleController.vehicle,true);
			if wle &lt;&gt; null then
				moveController.setMyWorkListEntry(wle);
			endif;
		endif;
		
	else
		if chkConfirmAllMoves.value and				// 28/6/17 MAP TFS4719
			moveController.moveMode = REAL_MODE and
			//((win = null) or (win.isKindOf(Control) and win.Control.form = self)) and
			app.msgBox(app.getErrorString1(Please_confirm_move, tiIDs), app.getErrorString(Warning), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
	
			return;
		endif;
	endif;
	firstTI:=moveController.myTrackedItem;

	showMoveConfirmation := app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean;		// 8/9/17 MAP TFS6818
	if showMoveConfirmation then
		moveController.nonWorkedInstantPreMove();	//01 Aug 2013	NDL	Par 32140
	
		if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;
	
	//19.07.2019 cnwma1 Bug #45706
	//if tiSet &lt;&gt; null then										// TFS 51935
	if tiSet &lt;&gt; null and tiSet.size &gt; 0 then					// TFS 51935
		foreach ti in tiSet discreteLock do 
			vwle := ti.getVoyageWLEUnactioned(true);
			if vwle &lt;&gt; null and vwle.job &lt;&gt; null  then
				if not vwle.job.isVoyageROROJob() 		// TFS 45983 ignore 'hidden' jobs
				and not vwle.job.isVoyageHoldJob
				//and not directLoad then						// TFS 51935	// TFS 52293
				and not vwle.job.isDirectDeliveryJob then		// TFS 51935	// TFS 52293
					isLoadJobExist := true;
					tiId		   := ti.id;
					break;
				endif;
			endif;
			
			if ti.isRRPforVoyage and moveController.moveMode = REAL_MODE then
				if app.msgBox(app.getErrorString(No_Cargo_Assigned_To_Job), app.getErrorString(Error), MsgBox_OK_Only) = MsgBox_Return_OK then
					return;
				endif;
			endif;
		endforeach;
	else
		if firstTI &lt;&gt; null then
			if firstTI.isRRPforVoyage and moveController.moveMode = REAL_MODE then
				if app.msgBox(app.getErrorString(No_Cargo_Assigned_To_Job), app.getErrorString(Error), MsgBox_OK_Only) = MsgBox_Return_OK then
					return;
				endif;
			endif;
		
			vwle := firstTI.getVoyageWLEUnactioned(true);
			
			if vwle &lt;&gt; null and vwle.job &lt;&gt; null  then
				if not vwle.job.isVoyageROROJob() 		// TFS 45983 ignore 'hidden' jobs
				and not vwle.job.isVoyageHoldJob
				//and not directLoad then						// TFS 51935	// TFS 52293
				and not vwle.job.isDirectDeliveryJob then		// TFS 51935	// TFS 52293
					isLoadJobExist := true;
					tiId		   := firstTI.id;
				endif;
			endif;
		endif;
	endif;
	
	//19.07.2019 cnwma1 Bug #45706
	if isLoadJobExist then
		if app.msgBox(app.getErrorString2(Release_Wle_Exist,tiId,app.getErrorString(Load)), app.getErrorString(Error), MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	// TFS 52360 Direct Loading expects the move controller to have a destination - exception to Planned Location processing
	// TFS 52683 Direct Delivery also expects the move controller to have a DD WLE and job - make sure there is one	// TFS 52683
	//if directLoad and moveController.myToPrimaryLocation = null then												// TFS 52683
	if directLoad and (moveController.myToPrimaryLocation = null or moveController.myDDWorkListEntry = null) then	// TFS 52683
		if firstTI &lt;&gt; null then
			foreach wle in firstTI.allWorklistEntries discreteLock do
				if CM_VoyageWLE.hasInstance(wle) and wle.myRequest.getAttrIsLoad() 
				and wle.status &lt;&gt; WLE_COMPLETED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
					vwle := wle.CM_VoyageWLE;
					break;
				endif;
			endforeach;
			if vwle &lt;&gt; null then
				if moveController.myToPrimaryLocation = null then													// TFS 52683
					self.myTerminal.findLocationFromString(vwle.locationTarget, true, lc, foundHeight);
					moveController.setMyToPrimaryLocation(lc);
				endif;																								// TFS 52683
				moveController.myDDWorkListEntry := vwle;
				moveController.myDDJob := vwle.job;
			endif;
		endif;
	endif;
	// TFS 52360 end of this bit
	
	while true do
		if tiSet = null or tiSet.size &lt;= 1 then
			moveController.setMyTrackedItem(firstTI );
			moveController.setMyWorkListEntry(wle);
			
			if firstTI.isRRPforVoyage then
				foreach wle in firstTI.allWorklistEntries discreteLock do
					if wle.job = null then		// TFS 52293
						continue;													// TFS 52293
					endif;															// TFS 52293
					if CM_VoyageWLE.hasInstance(wle) and wle.status &lt;&gt; WLE_COMPLETED then
						moveController.setMyWorkListEntry(wle);
						break;
					endif;
				endforeach;
			else
			// TFS 52360 For direct loads, the WLE on the move controller is a Yard WLE
			//if directLoad then													// TFS 52293
				foreach wle in firstTI.allWorklistEntries discreteLock do
					if wle.job = null or not wle.job.isDirectDeliveryJob then		// TFS 52293
						continue;													// TFS 52293
					endif;															// TFS 52293
					if CM_YardWLE.hasInstance(wle) and wle.status &lt;&gt; WLE_COMPLETED then
						moveController.setMyWorkListEntry(wle);
						break;
					endif;
				endforeach;
			endif;
			//endif;																// TFS 52293
			// TFS 52360 end of this bit
		endif;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Load Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	if moveController &lt;&gt; null then
		moveController.isMoveToPlanned := false;
	endif;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;
</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoCounterAll" id="15ad8bbe-059f-4f8b-95a5-66924996bf83">
        <source>doMnuCargoCounterAll();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/01/2015	cnwdap1		Initial creation PAR #35397 CCM SFW 1394 Voyage Rationalisation
//
vars
	form 		: SHP_VoyageCargoCounterForm;
	cargoTypes	: CM_CargoTypeSet;
	idx			: Integer;
	ti 			: CM_TrackedItem;
	
begin
	form := self.initCargoCounterForm;
	if form = null then
		return;
	endif;
	
	create cargoTypes transient;
	self.getCargoTypesForCounter(cargoTypes, false);
	
	form.show();
	form.mulCargoTypes.setSelected(cargoTypes);
	form.doQuery;
epilog
	delete cargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoCounterSel" id="6ec49537-5c1a-4633-a87a-03dac07ccd3f">
        <source>doMnuCargoCounterSel();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyge Rationalisation
//
vars
	form 		: SHP_VoyageCargoCounterForm;
	selectedTIs	: CM_TISet;
	cargoTypes	: CM_CargoTypeSet;
	
begin
	if self.myCurrentContextTbl = null then
		return;
	endif;
	
	form := self.initCargoCounterForm;
	if form = null then
		return;
	endif;
	
	create selectedTIs transient;
	create cargoTypes transient;
	self.getCargoTypesForCounter(cargoTypes, true);
	
	self.myCurrentContextTbl.allSelectedObjects.copy(selectedTIs);
	form.show();
	form.mulCargoTypes.setSelected(cargoTypes);
	form.setSelectedTIs(selectedTIs);
	form.doQuery;
	
epilog
	delete selectedTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuChangeAmountClick" id="e384b751-b983-4895-8f11-3b6911401a03">
        <updating/>
        <source>doMnuChangeAmountClick(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Mar 2021 cnwma1  ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount

*/

vars
	form 			: CMUI_MoveAmountForm;
	wle  			: CM_WorkListEntry;
	ti   	    	: CM_TrackedItem;
	pFM 			: CM_FutureMove;
	newQuantity 	: Integer;
	newWeight 		: Decimal[16,4];
	moveController  : CMIF_MoveController;
	req 			: CM_HoldRequest;
	theReturn 		: Integer;
begin

	app.mousePointer := MousePointer_Default;
	
	pFM := menuItem.userObject.CM_FutureMove;
	
	if pFM = null then
		return;
	endif;
	
	if pFM.myWorkListEntry = null then
		return;
	endif;
	
	wle := pFM.myWorkListEntry;
	
	if wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	newWeight   := wle.weight;
	newQuantity := wle.quantity;
	ti 			:= wle.myTrackedItem;
	
	if ti = null then
		return;
	endif;
		
	
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
	
	create moveController transient;
	app.myMoveController := moveController;
	moveController.setMyTrackedItem( ti );
	moveController.setMyToPrimaryLocation( wle.getTargetLocation );
	moveController.setQuantity(wle.quantity);
	moveController.setWeight( wle.weight);
	moveController.setMoveMode( PLANNING_MODE );
	
	create form transient;
	form.myTrackedItem   := ti;
	form.myWorkListEntry := wle;
	form.targetLocation  := wle.locationTarget;
	
	if form.showModal &lt;&gt; IDOK then
		return;
	endif;
	
	if form.byQuantity then
		newQuantity := form.getQuantity;	
	else
		newWeight := form.getWeightMovedKgs;
	endif;
	
	if newQuantity = wle.quantity and  newWeight = wle.weight then
		return;
	endif;
	
	while true do 
		app.myTrxUA.trxUpdateFutureMoveQty( pFM, newWeight, newQuantity, app.myPassport );	
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move_amount), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog

	if moveController &lt;&gt; null then
		if app.myMoveController = moveController then
			app.myMoveController := null;
		endif;
		delete moveController;
	endif;

	mousePointer := MousePointer_Default;
	delete form;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuDeleteSelectedClick" id="b1c106bb-506b-48a8-a6aa-6f9efa28b245">
        <updating/>
        <source>doMnuDeleteSelectedClick(_table : CM_DataTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//  10 December 2025	jlier1	JIRA# 36738
// 14 Jan 2026  jlier1 	JIRA-36877
vars
	result 			: Integer;
	ti				: CM_TrackedItem;
	tiSet 			: CM_TISet;
	ta				: CM_TerminalArea;
	targetLocn 		: CM_LocationsController;
	tisWithWarnSet 	: CM_TISet;
	retval			: Integer;
begin
	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		
	
	create tiSet transient;
	self.getAllSelectedTIs("", tiSet, false, _table);
		
	if tiSet.isEmpty then
		return;
	endif;

	foreach ti in tiSet do
		if ti.getReceiveDate().isValid then
			app.msgBox("Your selection contains cargo not suitable for deleting.  You can only delete unworked cargo.", 'Invalid Cargo', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
	endforeach;

	retval := app.msgBox("You are about to delete all the selected cargo items.  Continue?", 'Confirm Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if retval = MsgBox_Return_No then
		return;
	endif;
	
	create tisWithWarnSet transient;

	while true do
		// 14 Jan 2026  jlier1 	JIRA-36877 - handles RRP cargo differently
		app.myTrxDA.trxDeleteRPPTrackedItems(tiSet,self.myCurrentVoyage, tisWithWarnSet, false, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Delete Ship Cargo', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;		
	
epilog
	delete tisWithWarnSet;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuJobRebuildStatusClick" id="1e6270db-9744-4b1c-97cf-0e240c90fdda">
        <updating/>
        <source>doMnuJobRebuildStatusClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2014	cnwdap1		Initial creation PAR #35397 CCMSS SFW 1394 Voyage Rationalisation
//
vars
	wle 		: CM_WorkListEntry;
	job 		: CM_Job;
	oldStatus	: Integer;
	obj			: Object;
	rtnValue	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	if self.myCurrentTrackedItem = null then
		return;
	endif;
	wle := self.myCurrentTrackedItem.getVoyageWLE;
	if wle = null or wle.isCompleteForJob then
		return;
	endif;
	
	job := wle.job;
	if job = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	oldStatus := job.status;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateJobStatus(job, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Job Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuJobSplitClick" id="cdadc069-1805-40f1-acf5-78d54d636491">
        <updating/>
        <source>doMnuJobSplitClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 18/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars
	allVoyageJobs : CM_JobArray;
	wle : CM_WorkListEntry;
	job : CM_Job;

begin
	create allVoyageJobs transient;
	// TFS 47144 start
	//wle := self.myCurrentTrackedItem.getVoyageWLE();
	//if wle = null then
	//	return;
	//endif;
	//job := wle.job;
	foreach wle in self.myCurrentTrackedItem.allWorklistEntries discreteLock do
		if wle.isKindOf(CM_VoyageWLE) and wle.getMyVoyageObject = self.myCurrentVoyage then
			job := wle.job;
			break;
		endif;
	endforeach;
	if job = null then
		return;
	endif;
	// TFS 47144 end
	allVoyageJobs.add(job);
	self.myAssistant.showSplitWorkCraneForm(job.CM_VoyageJob, null, allVoyageJobs);
	
epilog
	delete allVoyageJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuJobTransferClick" id="fa76ccf1-2d58-48dc-a11a-747376ca61f6">
        <source>doMnuJobTransferClick();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/12/2019	jlgdap1		Initial creation TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars
	allVoyageJobs : CM_JobArray;
	wle : CM_WorkListEntry;
	job : CM_Job;

begin
	create allVoyageJobs transient;
	foreach wle in self.myCurrentTrackedItem.allWorklistEntries discreteLock do
		if wle.isKindOf(CM_VoyageWLE) and wle.getMyVoyageObject = self.myCurrentVoyage then
			job := wle.job;
			break;
		endif;
	endforeach;
	if job = null then
		return;
	endif;
	allVoyageJobs.add(job);
	self.myAssistant.showTransferWorkCraneForm(job.CM_VoyageJob, null, allVoyageJobs);
	
epilog
	delete allVoyageJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuMoveItClick" id="35c578a0-e7dc-4bb3-9d46-d4088fcd7ec2">
        <updating/>
        <source>doMnuMoveItClick(_tiArray : ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	tiArray	: CM_TIArray;
	obj		: Object;
	ti		: CM_TrackedItem;
	
begin
	if _tiArray = null or _tiArray.isEmpty then 
		return;
	endif;
	
	create tiArray transient;
	foreach obj in _tiArray do
		ti := obj.CM_TrackedItem;
		tiArray.add(ti);
	endforeach;
	if tiArray.size &lt; 2 then
		self.myAssistant.showMoveItForm(tiArray, self.getMoveMode);
	else
		self.myAssistant.showMoveItForm(tiArray, AUTO_PLAN_MODE);
	endif;
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doMnuNonTranshipClick" id="c9533f98-605b-4657-98aa-c4a9045ff680">
        <source>doMnuNonTranshipClick(_tiArray : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2013	cnwndl1	Initial creation Par 32162

*/

vars

	obj :Object;
	pxyTIArray : CM_TIArray;
	
begin
	
	create pxyTIArray transient;
	
	// PAR #23645 CCMS 1116 - handle single and multiple TIs the same way
	foreach obj in _tiArray do
		if CM_TrackedItem.hasInstance(obj) and obj.CM_TrackedItem.isTranshipItem then
			pxyTIArray.add(obj.CM_TrackedItem);
		endif;	
	endforeach;
	
	// call tranship form to make TIs non-tranship
	self.myAssistant.showTranshipDetailForm(pxyTIArray);
	
	
epilog

	delete pxyTIArray;
end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doMnuQSetComplete" id="849cf2dd-04cb-40e0-8006-166f087e3d98">
        <source>doMnuQSetComplete(_masterMenuAction : CMUI_MenuAction);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	wle					: CM_WorkListEntry;
	queueEntry			: CM_RTQueueEntry;
	nextEntry			: CM_RTQueueEntry;
	taskMach, 
	imvMach 			: CM_Machine;
	completeTaskForm 	: Form;
	modalResult, 
	taskType, 
	quantity 			: Integer;
	completeAll, 
	completePickupAndSetdown, 
	invalidObj 			: Boolean;
	theTask, currentTask,
	initTask	 		: CM_RTQueueTask;
	weight 				: Decimal [14,4];
	isMoveNoNextEntry	: Boolean;
	initQueueTask		: CM_RTQueueTask;
	pickupTask			: CM_RTQueueTask;
	theClass 			: Class;
	assistClass 		: Class;
	jrw 				: Schema;
	pickSetTask			: Boolean;

begin
	if self.myCurrentTrackedItem = null then
		return;
	endif;
	wle := self.getVoyageWLE();
	if wle = null then
		return;
	endif;
	queueEntry := wle.getFirstUncompleteRTEntry();
	if queueEntry = null then
		return;
	endif;
	foreach initTask in queueEntry.allTasks where initTask.status &lt;&gt; TASK_COMPLETE do
		currentTask := initTask;
		break;
	endforeach;
	if currentTask = null then
		return;
	endif;	

	// do initial validation that happens in the YRD_CompleteTaskForm initDetails method that
	// we can't respond to in a sendMsg
	if queueEntry.status = ENTRY_COMPLETE then
		app.msgBox(app.getErrorString(Not_complete_completed_entry), app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	if currentTask.isSetDown then
		pickupTask := queueEntry.getDirectorOrPickupTask();
	
		if pickupTask.status = TASK_COMPLETE then
			initQueueTask := currentTask;
		else
			initQueueTask := pickupTask;
		endif;
	elseif currentTask.isMove then
		nextEntry := queueEntry.getNextRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
		// 28726 cnwjre1 Nov 2011 voyage load via machine rules ending in IMV
		if nextEntry = null then
			pickupTask := queueEntry.getDirectorOrPickupTask();
			isMoveNoNextEntry := true;
		else
			pickupTask := nextEntry.getDirectorOrPickupTask();
		endif;
		initQueueTask := pickupTask;
	elseif currentTask.taskType = TASK_BREAKBULK then
		initQueueTask := currentTask;
	else
		initQueueTask := currentTask;
	endif;
	if initQueueTask.status = TASK_COMPLETE then
		initQueueTask := queueEntry.getDirectorOrSetDownTask();
	endif;
	if not isMoveNoNextEntry and initQueueTask.taskType = TASK_DIRECTOR then
		app.msgBox(app.getErrorString(Complete_director_no_cargo) ,app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	
	jrw := rootSchema.getSchema("YardSchema");
	theClass := jrw.getClass("YRD_CompleteTaskForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	completeTaskForm := app.loadForm(theClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if completeTaskForm = null then
		return;
	endif;
	completeTaskForm.sendMsgWithParams("initDetails", self.myTerminal, currentTask);
	modalResult := completeTaskForm.showModal;
	if modalResult &lt;&gt; IDOK then
		return;
	endif;
	completeTaskForm.sendMsgWithIOParams("getOptMoveValue", completeAll);
	if not completeAll then
		completeTaskForm.sendMsgWithIOParams("getCmbMachListObject", taskMach);
		completeTaskForm.sendMsgWithIOParams("getCmbIMVListObject", imvMach);
	endif;
	
	//epr par 31092 14/2/12
	on Exception do app.handleDeletedObject(exception, initTask,invalidObj);
	completeTaskForm.sendMsgWithIOParams("getMyInitQueueTask", initTask);
	taskType := initTask.taskType; //dereference
	if invalidObj then
		return;
	endif;
	
	completePickupAndSetdown := false;
	completeTaskForm.sendMsgWithIOParams("getOptPickSetTask", pickSetTask);
	if pickSetTask and initTask.isPickUp then
		theTask := queueEntry.getDirectorOrSetDownTask();
		completePickupAndSetdown := true;
	else
		theTask := initTask;
	endif;
	
	if currentTask.taskType = TASK_BREAKBULK then
		completeTaskForm.sendMsgWithIOParams("getOptPickSetTask", completePickupAndSetdown);
		completeTaskForm.sendMsgWithIOParams("getQuantityBySendMsg", quantity);
		completeTaskForm.sendMsgWithIOParams("getWeightMovedKgsBySendMsg", weight);
	endif;
	
	self.doSingleTaskComplete(theTask, completeAll, completePickupAndSetdown, taskMach, imvMach, quantity, weight);

epilog
	delete completeTaskForm;
end;</source>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="doMnuQShowTaskClick" id="04d388ea-37f8-42e4-80ae-e18e45adb3f3">
        <updating/>
        <source>doMnuQShowTaskClick(_isLoad : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	rtQueueEntry	: CM_RTQueueEntry;
	wle : CM_WorkListEntry;

begin
	if self.myCurrentTrackedItem = null then
		write "self.myCurrentTrackedItem = null ";
		return;
	endif;
	
	wle := self.myCurrentTrackedItem.getVoyageWLEUnactioned(_isLoad);
	if wle = null then
		write "wle = null";
		return;
	endif;
	rtQueueEntry := wle.getMyQueueEntry();
	if rtQueueEntry = null then
		write "rtQueueEntry = null";
		return;
	endif;
	
	self.myAssistant.showRTQueueForm(rtQueueEntry, self.myMasterMenuAction);
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuQueueAmendTarget" id="ce448858-7ff6-4c15-8162-2fd8b1c659c1">
        <updating/>
        <source>doMnuQueueAmendTarget() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	ti				: CM_TrackedItem;
	locationForm	: CMUI_LocationSelector;
	twinTaskId		: String;
	currentTask,
	twinTask,
	task			: CM_RTQueueTask;
	currentEntry	: CM_RTQueueEntry;
	location,
	twinLocation,
	newTwinLocation,
	newLocation		: CM_LocationsController;
	machine 		: CM_Machine;
	twinTI			: CM_TrackedItem;
	wle,twinWLE 	: CM_WorkListEntry;
	newMoveRule 	: CM_RTMoveMethodRule;
	
begin
	if self.myCurrentTrackedItem = null then
		return;
	endif;
	currentEntry := self.myCurrentTrackedItem.getQueueEntry;
	if currentEntry = null then
		return;
	endif;
	
	currentTask := self.myCurrentTrackedItem.getQueueTask;
	wle 		:= currentEntry.myWorkListEntry;
	// Always the task's final location
	location 	:= wle.getFinalTaskTargetLoc;
	
	machine := currentTask.machine;
	if machine &lt;&gt; null and not machine.isMultiLift then
		foreach task in machine.allCurrentQueueTasks do
			if task &lt;&gt; currentTask then
				twinTask := task;
				break;
			endif;
		endforeach;
	endif;
	
	if twinTask &lt;&gt; null then		
		// likewise always the twins final location
		twinWLE 		:= twinTask.myEntry.myWorkListEntry;
		twinLocation 	:= twinWLE.getFinalTaskTargetLoc;
		twinTaskId 		:= twinTask.getTaskId;
		twinTI 			:= twinTask.ti;
	endif;
	
	
	create locationForm;
	locationForm.centreWindow;
	locationForm.myTerminal := self.myTerminal;
	locationForm.initForm(location, twinLocation, currentTask.getTaskId, twinTaskId, currentTask.ti, twinTI, true,
								(currentTask.taskType = TASK_DIRECTOR), null, currentEntry);	
	locationForm.showModal;
	
	if locationForm.modalResult &lt;&gt; IDCANCEL then
		newLocation 	:= locationForm.txtLoc.userObject.CM_LocationsController;
		newTwinLocation := locationForm.txtTwinLoc.userObject.CM_LocationsController;
		newMoveRule 	:= locationForm.getMoveMethodRule();
		if location = newLocation then
			return;
		endif;	
		
		if newLocation = null then
			app.msgBox(app.getErrorString(No_Target_location_found), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		/* Voyage WLE return to yard code
		
		If we are a voyage job heading to a slot/cta and the user selects to amend target location to a yard location we are sending the cargo back to the yard
		
		we should:
		Warn the user we are going to take a ship job container and put it back in th yard, and we are going to unplan it also.
		
		Move the current RTentry onto a new YARD job queued as it would be to whatever yard location from its current location (machine, ICA, CTA etc).
		Tidy up/remove any queue entry against the voyage WLE
		Unplan the container from the ship 
		
		if it is a ship release (i.e. was a director task) then we return it to a director task/unasign the actual cargo item
		*/
		if currentTask.ti &lt;&gt; null and  (location &lt;&gt; null and (location.isVoyageController or location.isCraneLaneController)) 
			or (location = null and currentTask.myEntry.status = ENTRY_COMPLETE and currentTask.myEntry.myJob.isVoyageTypeJob() and currentTask.myEntry.myJob.jobType = JOB_TYPE_LOAD)then // TFS 4859
			//we were going to a ship
			if app.msgBox(app.getErrorString1(This_voyag_load_task_cargo_cha, currentTask.ti.id), null, MsgBox_OK_Cancel) = MsgBox_Return_OK then
				while true do
					app.myTrxUA.trxUpdateVoyageRTReturnToYard(newLocation, currentTask, newTwinLocation, twinTask, newMoveRule, app.myPassport);
					if self.doTransactionLoopCompleted(app.getErrorString(Change_target_location)) then
						break;
					endif;
				endwhile; 				
				return;
			endif;
		endif;

		while true do
			app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, currentTask, newTwinLocation, twinTask, newMoveRule, app.myPassport);
			if self.doTransactionLoopCompleted(app.getErrorString(Change_target_location)) then
				break;
			endif;
		endwhile; 
	endif;
	
epilog
	delete locationForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSetGradeClick" id="a3ab4692-5c8c-4901-9f00-d9aa6a26cd03">
        <updating/>
        <source>doMnuSetGradeClick(menuItem: MenuItem input) updating, protected;
//------------------------------------------------
// Created: 19 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.myAssistant.menuSetGradeClick(self.mnuSetGrade,menuItem);
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuSetStopsClick" id="97b48b81-59f0-4537-980b-a9431a9d5c83">
        <updating/>
        <source>doMnuSetStopsClick(_menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On	Changed By  Reason
28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
16/06/2010	CNWCS5		PAR 24342 - NEW FORM FOR MAINTAINING STOPS
---------------------------------------------------------------------------
*/
	
vars
	lTI			: CM_TrackedItem;
begin
	lTI := _menuItem.userObject.CM_TrackedItem; 
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuShowEDIClick" id="ff3f5fcc-ede8-4a87-aa52-c171e35f90cb">
        <updating/>
        <source>doMnuShowEDIClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15 December 2014	cnwdap1		Initial creation PAR #
//
vars
	form		: CMUI_EDIForm;
	voyage		: CM_Voyage;
	ediType		: CM_EDIFileType;
	idx			: Integer;

begin
	form := app.loadForm(CMUI_EDIForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDIForm;
	if form = null then
		return;
	endif;
	
	form.initForm();
	form.initFilterTable();
	form.initDataTable();
	idx := form.cmbFiltVoyage.findObject(self.myCurrentVoyage);
	if idx = null then
		form.unload();
		return;
	endif;
	form.show();
	form.cmbFiltVoyage.text := self.myCurrentVoyage.code;
	form.cmbFiltVoyage_lostFocus(form.cmbFiltVoyage);
	form.setPropertyValue(CMUI_EDIForm::filterVoyage.name, self.myCurrentVoyage);
	form.myDataClass := CM_EDIDataBayPlan;
	form.tblSearch.setValueByControlName(form.cmbFiltVoyage.name, self.myCurrentVoyage.code);
	idx := null;
	form.addObjectsToTable(idx);
	if form.tblData.rows &gt; form.tblData.fixedRows then
		form.tblData.row := 2;
		form.tblData.accessRow(2).selected := true;
		form.tblData_click(form.tblData);
		form.showThumbnailData(form.tblData.accessedRow.itemObject);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuShowInYardClick" id="dd5915df-4c3e-4390-8077-c3130f0cff4e">
        <updating/>
        <source>doMnuShowInYardClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	idx 	: Integer;
	objs 	: ObjectSet;
	enquiry	: CM_EnquiryController;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	create objs transient;
	
	if self.tblOnsite.findObjectInRow(self.myCurrentTrackedItem, idx) then
		self.tblOnsite.allSelectedObjects.copy(objs);
	elseif self.tblOffsite.findObjectInRow(self.myCurrentTrackedItem, idx) then
		self.tblOffsite.allSelectedObjects.copy(objs);
	elseif self.tblOnship.findObjectInRow(self.myCurrentTrackedItem, idx) then
		self.tblOnship.allSelectedObjects.copy(objs);
	elseif self.tblPreNote.findObjectInRow(self.myCurrentTrackedItem, idx) then
		self.tblPreNote.allSelectedObjects.copy(objs);
	endif;
	
	enquiry := self.myAssistant.SHP_Assistant.doGetSelectorTIsLoadList(objs, self.myCurrentVoyage);
	self.myAssistant.showYardRowEnquiryForm(objs, self.myMasterMenuAction, enquiry, true, VIEW_DISPORT, 1, null);
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
