/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	delete self.myDTOWagonOut;
	create self.myDTOWagonOut transient;
	self.maxCloneButtonsOut := 1;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
