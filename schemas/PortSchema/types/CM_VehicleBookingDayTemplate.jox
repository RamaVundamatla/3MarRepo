    <JadeMethod name="generateSlotsFromTemplate" id="5926c1b0-19f1-448a-82ef-a904b657ae5b">
        <source>generateSlotsFromTemplate( _date : Date):Boolean;
/*

Purpose:			Generates vehicle booking time slots for the date and the user

Parameters:			_date	Date	The date to generate slots for
					_user	CM_User	The user who generated the slots

Return Value:		Boolean	Representing whether it was successful or not

Date			Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393
*/

vars
	timeTemplate	: CM_VehicleBookingTimeTemplate;
	iter			: Iterator;

begin
	iter := self.allTimeTemplates.createIterator;

	while iter.next( timeTemplate ) do
		if not timeTemplate.generateSlots( _date ) then
			return false;
		endif;
	endwhile;
	
	return true;

epilog
	delete iter;

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForError" id="eb7c20ed-d12c-4fef-870d-28cc60ae3bd0">
        <source>getDisplayForError():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	return app.getErrorString(Vehicle_schedule_day_template) &amp; " " &amp; self.name;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ebfc2b5b-6756-4e8d-8f77-04a664e66163">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

begin

	//ETDef_DaySlotTemplate

	if _attrName = ETRow_Name then
		return self.name;
	
	elseif _attrName = ETRow_Calendar then
		if self.myCalendar = null then
			return null;
		else
			return self.myCalendar.description;
		endif;
	
	elseif _attrName = ETRow_Priority then
		return self.priority.String;
	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
