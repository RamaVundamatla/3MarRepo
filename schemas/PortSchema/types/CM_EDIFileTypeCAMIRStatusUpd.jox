    <JadeMethod name="createCustomsMessageTIs" id="f45d0592-ab09-4a7e-a742-57428aedad83">
        <source>createCustomsMessageTIs(_contIDs : StringArray;_customsMessageData : CM_EDIDataUSCustomsMessage;_customsMessageTI	: CM_EDIUSCustomsMessageTI ;_ediFile: CM_EDIFile input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2019	jlgns1	Initial creation
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/

vars
idString : String;
	postedDT : TimeStamp;
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	contCustomsMessageTI	: CM_EDIUSCustomsMessageTI;
begin
	terminal := app.myPassport.myTerminal;	
	postedDT.setDate(_customsMessageTI.postedDate);
	postedDT.setTime(_customsMessageTI.postedTime);
		
	foreach idString in _contIDs do
		create contCustomsMessageTI;
		contCustomsMessageTI.setForCreateNew(_customsMessageData);
				
		contCustomsMessageTI.setMessageDetails(null,						//Should not be setting tle BOL on the ISO
												_customsMessageTI.dispositionCode,
												_customsMessageTI.controlNumber.String,
												_customsMessageTI.entryType,
												_customsMessageTI.entryNumber,
												_customsMessageTI.vesselName,
												_customsMessageTI.ediFileVoyageCode,
												_customsMessageTI.voyageCode,
												_customsMessageTI.portInBond,
												_customsMessageTI.portForeign,
												_customsMessageTI.portInTransit,
												_customsMessageTI.portOfEntry,
												_customsMessageTI.remarks,
												postedDT,
												_customsMessageTI.processedDT);
		
		contCustomsMessageTI.vesselCode := _customsMessageTI.vesselCode;
		contCustomsMessageTI.id := idString;
		contCustomsMessageTI.voyageOperator := _customsMessageTI.voyageOperator;
		
		//find on site
		
		
		if terminal &lt;&gt; null then
			//find on site
			ti := terminal.allOnsiteTIsByIdCargoType[idString, TI_CargoType_Container ];
			if ti = null then
				voyage := terminal.allVoyagesByCode.getAtKeyGeq(_customsMessageTI.voyageCode, null);
				
				if voyage &lt;&gt; null and voyage.code = _customsMessageTI.voyageCode and not voyage.hasDeparted then
					//find on voyage
					ti := voyage.allOnshipTIsByIdCargoType[idString, TI_CargoType_Container];
				endif;
				
				if ti = null then 
					//find pre notified
					ti := terminal.allNotifiedTIsByIdCargoType[idString, TI_CargoType_Container];
				endif;
			endif;
				
			if ti &lt;&gt; null then
				contCustomsMessageTI.setTrackedItem( ti );
			endif;
		endif;
		
		contCustomsMessageTI.setMyEDIFile(_ediFile);		
	endforeach;
epilog

end;</source>
        <Parameter name="_contIDs" type="StringArray"/>
        <Parameter name="_customsMessageData" type="CM_EDIDataUSCustomsMessage"/>
        <Parameter name="_customsMessageTI" type="CM_EDIUSCustomsMessageTI"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="e5651dbf-f482-4b14-8a91-9f9a7b374258">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2014	cnwmc5	Initial creation

*/

vars

begin
	_ediDataClass 	:= CM_EDIDataUSCustomsMessage;
	_dataType		:= EDIDataType_CustomsMessage;

epilog

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIActionFrmCustomsMessage" id="a5634280-d3be-44e6-b8de-98eb2b7b1a3d">
        <source>getEDIActionFrmCustomsMessage(_dispositionCode : String) : CM_EDIAction;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2019	jlgns1	Initial creation
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/
vars
	ediAction : CM_EDIAction;
	dispositionFound : Boolean;
begin
	foreach ediAction in self.allEDIActions where ediAction.keyword = _dispositionCode do
		if ediAction.hasValidActionType() then
			return ediAction;
		endif;
	endforeach;
	return null;
epilog
end;</source>
        <Parameter name="_dispositionCode" type="String"/>
        <ReturnType type="CM_EDIAction"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="62808745-11d7-4cb9-83fd-a64b6c4d7fae">
