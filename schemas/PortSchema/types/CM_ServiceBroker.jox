    <JadeMethod name="getDebtorForTransaction" id="28c23414-fc38-48d8-96fa-97e0a299cd91">
        <source>getDebtorForTransaction(_aSBController : CMIF_ServiceBroker input) : CM_DebtorNode;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//				Modified June 2010	24051 use the new debtor map debtor type
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aDM : CM_DebtorMap;
	trans : CM_TITransaction;
	aDebtor : CM_DebtorNode;
begin

	// ### CHECK SPECIAL MAPPINGS FOR DEBTOR
	if self.allDebtorMapsByDebtor.isEmpty then
		return null;
	endif;

	trans := _aSBController.myTransaction;
	
	foreach aDM in self.allDebtorMapsByDebtor do
		aDebtor := aDM.getDebtorFromTransaction(trans);
		if aDebtor = aDM.myDebtorNode then
			return aDebtor;
		endif;
	endforeach;

	return null;

end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
