    <JadeMethod name="addVoyageWithGCStructDates" id="11422eb0-3aee-47a6-a919-b3d502dfe85e">
        <source>addVoyageWithGCStructDates(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _numberHatches : Integer;
							_arrive : TimeStamp; _depart : TimeStamp) : CM_Voyage;
//----------------------------------------------------------------------
// copy of addVoyageWithGeneralCargoStruc with explicit arrive and departure dates
/****Changes

Date		Name	TFS#			Description
============================================================================
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	pxyGeneralCargoStructure : CM_GeneralCargoVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	trade					 : CM_Trade;
	berth					 : HMS_Berth;
	pxyHMSData				 : HMS_VoyageData;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	term					 : CM_Terminal;
	portRotationArray		 : CM_PortRotationArray;
begin
	self.deleteVoyage(_code);
	term := self.getTerminal();

	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");
	 
	create portRotationArray transient;	
	
	trade := getTrade;
	create pxyVoyage transient;							

	create pxyGeneralCargoStructure transient;
	pxyVoyage.setProxyVoyageGeneralCargo(pxyGeneralCargoStructure);
	pxyGeneralCargoStructure.setProxyGCVoyage(_numberHatches);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate := _arrive;
	departureDate := _depart;

	pxyVoyage.setProxyVoyage(	null,
								"",
								_code,
								"",
								self.createdByUnitTest(null),								// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								"",
								true,
/* PAR 33644								true,
								false,*/
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,		  	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					
								
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	delete pxyGeneralCargoStructure;
	delete pxyHMSData;
	foreach pxyVoyagePortRotation in portRotationArray do	
		delete pxyVoyagePortRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage;
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <Parameter name="_arrive" type="TimeStamp"/>
        <Parameter name="_depart" type="TimeStamp"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithGeneralCargoStruc" id="c95e0c69-d82f-427d-8a3d-07432f6942e9">
        <source>addVoyageWithGeneralCargoStruc(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _numberHatches : Integer) : CM_Voyage;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		29 October 2009
//
// Implemented version: JMT 7.7.3
/****Changes

Date		Name	TFS#			Description
============================================================================
05/08/2011	cnwmh5					Change to use UT_UnitTest's opts
05/03/2015	cbwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	pxyGeneralCargoStructure : CM_GeneralCargoVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	trade					 : CM_Trade;
	berth					 : HMS_Berth;
	pxyHMSData				 : HMS_VoyageData;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	term					 : CM_Terminal;
	portRotationArray		 : CM_PortRotationArray;								// 24/02/2014 cnwmh5 - Transient Leaks
	estArrivalDate			 : TimeStamp;
	estDepartureDate		 : TimeStamp;
begin

	self.deleteVoyage(_code);
	term := self.getTerminal();

	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	 
	create portRotationArray transient;	
	
	trade := getTrade;
	create pxyVoyage transient;							

	create pxyGeneralCargoStructure transient;
	pxyVoyage.setProxyVoyageGeneralCargo(pxyGeneralCargoStructure);
	pxyGeneralCargoStructure.setProxyGCVoyage(_numberHatches);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	if self.opts.includesKey("tsArrival") then // whole time stamp
		arrivalDate := self.opts.timestamp("tsArrival");
	elseif self.opts.includesKey("dateArrival") then // just a date
		arrivalDate.setDate(self.opts.date("dateArrival"));
	endif;
	
	departureDate := arrivalDate.addDays(2);
	if self.opts.includesKey("tsDeparture") then // whole time stamp
		departureDate := self.opts.timestamp("tsDeparture");
	elseif self.opts.includesKey("dateDeparture") then // just a date
		departureDate.setDate(self.opts.date("dateDeparture"));
	endif;
	
	estArrivalDate.setDate(now.date());
	estArrivalDate.setTime(now.time());
	if self.opts.includesKey("tsArrivalEst") then // whole time stamp
		estArrivalDate := self.opts.timestamp("tsArrivalEst");
	endif;
	
	estDepartureDate := estArrivalDate.addDays(2);
	if self.opts.includesKey("tsDepartureEst") then // whole time stamp
		estDepartureDate := self.opts.timestamp("tsDepartureEst");
	endif;

	pxyVoyage.setProxyVoyage(	null,
								"",
								_code,
								"",
								self.createdByUnitTest(null),								// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								"",
								true,
/* PAR 33644								true,
								false,*/
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								estArrivalDate,
								estDepartureDate,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407			
								null,			  // TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,		   //jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode, //03/06/2020 cnwma1 Tfs #49400 
								false	// 31.Aug.2023 navsp1 TFS 57809
								);						
								
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	// 24/02/2014 cnwmh5 - Transient Leaks
	delete pxyGeneralCargoStructure;
	delete pxyHMSData;
	foreach pxyVoyagePortRotation in portRotationArray do	
		delete pxyVoyagePortRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;


	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithInwardCode" id="309b5685-e886-4466-82dc-efeeb1f1a57c">
        <source>addVoyageWithInwardCode( _outwardCode : String; _inwardCode : String; _vesselCode : String; _operatorName : String; _shippingLine : String) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
16/12/2008	cnwdw1	
29/07/2011	cnwmh5					Change to use UT_UnitTest.opts
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	vessel				  : CM_Vessel;
	pxyVoyage    		  : CM_Voyage;
	voyage				  : CM_Voyage;
	pxyCellStructure	  : CM_CellularVoyageStructure;
	now					  : TimeStamp;
	arrivalDate			  : TimeStamp;
	departureDate 		  : TimeStamp;
	pxyGlobalVoyage		  : CM_VoyageGlobal;
	trade				  : CM_Trade;
	pxyVoyagePortRotation : CM_PortRotation;
	portRotation		  : CM_PortRotation;
	portRotationArray	  : CM_PortRotationArray;								// 24/02/2014 cnwmh5 - Transient leaks
	
begin
	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	
	create portRotationArray transient;
	
	trade := getTrade;
	create pxyVoyage transient;							
	
	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay,
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id,
											vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(	_outwardCode,
								_vesselCode,
								null,
								null,
								null,
								null,
								null,
								0,
								null,
								app.myRoot);
	
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);
	
	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_outwardCode,
								_inwardCode,
								self.createdByUnitTest(null),											// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/* PAR 33644								true,
								true, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,			//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return voyage;
epilog
	
	// 24/02/2014 cnwmh5 - Transient Leaks
	delete pxyCellStructure;
	foreach pxyVoyagePortRotation in portRotationArray do
		delete pxyVoyagePortRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;
	
	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_outwardCode" type="String"/>
        <Parameter name="_inwardCode" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWorkPointQueue" id="b3cb9887-fa53-4211-84ae-0baf1f627025">
        <source>addVoyageWorkPointQueue(_voyage: CM_Voyage input; _voyageQueue: CM_VoyageQueue input; _wp: CM_WorkPoint input) : CM_VoyageWorkPointQueue;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2013	cnwrd1	Initial creation

*/

vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyageQueue.id &amp; ' ' &amp; _wp.code.trimBlanks);
	
	beginTransaction;
	//_wp.setPropertyValue(CM_WorkPoint::myPrimaryQueue.name, _voyageQueue);
	_voyageQueue.createWorkPointQueue(_wp, queue);
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageWorkPointQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageQueue" type="CM_VoyageQueue" usage="input"/>
        <Parameter name="_wp" type="CM_WorkPoint" usage="input"/>
        <ReturnType type="CM_VoyageWorkPointQueue"/>
    </JadeMethod>
    <JadeMethod name="addWPOpHrs" id="aafcfd20-302c-4630-96be-531b7773bcd7">
        <source>addWPOpHrs( _voyage: CM_Voyage; _job : CM_VoyageJob; _doWPOpHrs : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	onBoardTS : TimeStamp;
	exchStartTS : TimeStamp;
	exchEndTS : TimeStamp;
	ashoresTS : TimeStamp;
	proxy : CM_WorkPointOperatingHours;
	wpOpHrs : CM_WorkPointOperatingHours;
	crane : CM_Crane;
	wp : CM_WorkPoint;
	user : CM_User;
begin

	onBoardTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	exchStartTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	process.sleep(_doWPOpHrs);
	exchEndTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	ashoresTS := app.actualTimeServer;
	
	crane := _job.myJobSheet.CM_VoyageJobSheet.getMyCrane;
	wp := _job.myJobSheet.CM_VoyageJobSheet.getMyWorkPoint;
	
	create proxy transient;
	proxy.setProxy(	exchStartTS,	//_exchangeStart : TimeStamp;
					exchEndTS,	//_exchangeEnd : TimeStamp;
					onBoardTS,	//_labourStart : TimeStamp;
					ashoresTS,	//_labourEnd : TimeStamp;
					"Unit Test generated data.",	//_remarks : String;
					crane,	//_myCrane : CM_Crane;
					wp,	//_myWorkPoint : CM_WorkPoint;
					_voyage,	//_myVoyage : CM_Voyage
					user
					);
					
	app.myTrxCA.trxCreateWpOperatingHrs( proxy, wpOpHrs, app.myPassport );

epilog

	delete proxy;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_doWPOpHrs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="97430900-2a0f-4ddd-81d5-65eee60e3f22">
        <source>addWagon(_wagonCode, _wagonClassCode : String; _train : CM_Train) : CM_Wagon;
//09 July 2009	cnwmd1	
//02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
vars
	proxyWagon, 
	wagon 	     : CM_Wagon;
	wagonClass   : CM_WagonClass;
	railLine	 : CM_RailLine;
	terminal     : CM_Terminal;
	ta 			 : CM_TerminalArea;
	railArea	 : CM_Rail;
begin
	terminal := app.myPassport.myTerminal;
		foreach ta in terminal.allTerminalAreas do
		if ta.isKindOf(CM_Rail) then
			railArea := ta.CM_Rail;
			break;
		endif;
	endforeach;
	assertTrueMsg(railArea &lt;&gt; null , "No rail area");
	
	wagonClass := app.myRoot.allWagonClasses[_wagonClassCode];
	assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class does not exist");
	
	if self.opts.includesKey("RailLine") then						// 04/04/2014 cnwmh5
		railLine := self.opts.obj("RailLine").CM_RailLine;
	endif;	
	
	//create proxyWagon transient;
	create proxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	proxyWagon.setProxy(app.myPassport.myTerminal,
						_wagonCode,
						wagonClass,
						_train,
						_train,
						null,
						null,
						null,
						null,
						null,
						null,   //02.10.2020 cnwma1 TFS #50112
						null);  //02.10.2020 cnwma1 TFS #50112
						
	app.myTrxCA.trxCreateWagon(proxyWagon, wagon, railLine, null, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return wagon;
epilog
	delete proxyWagon;
end;</source>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_wagonClassCode" type="String"/>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonClass" id="57dc0d06-473a-4cf5-9247-b5c1e16d4002">
        <source>addWagonClass( classId : String ): CM_WagonClass;

/*

Purpose:			
				Creates a wagonclass called "ZZ" for testing.
				Please delete it with "deleteWagonClass" when finished.
Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	existingWagonClass : CM_WagonClass;
	loadState : Boolean;
	notAvailableForEntry : Boolean;
	
	wagonClass : CM_WagonClass;
	proxyWagonClass : CM_WagonClass;
	pLocationIds : StringArray;
	pConsigneeRestrictions	: CM_ConsignCodeArray;
	rule : CM_WagonPositionalRule;
	pxyRule : CM_WagonPositionalRule;
	pxyPosi : CM_WagonPosition;
	
	carrier					: CM_Carrier;
	maxLoadWeight : Decimal [12,2];
	maxPosiWeight : Decimal [12,2];
	maxPosiHeight : Decimal [12,2];
	deckHeight : Decimal [12,2];
	tareWeight : Decimal [12,2];	
	
	acceptsGenerator		: Boolean;
	doorsAccessible			: Boolean;
	wagonType : Integer;
	lenInUnits : Integer;
	intHeight : Decimal [6,2];	
	intLength : Decimal [6,2];
	intWidth : Decimal [6,2];
	extHeight : Decimal [6,2];
	extLength : Decimal [6,2];
	extWidth : Decimal [6,2];
	index : Integer;
	maxNumInStack : Integer;
	tierIds : StringArray;
	
	wellDef : CM_WagonWellDefinition;
	wellDeckHeight : Decimal [16,4];
	wellMaxCargoHeight : Decimal [16,4];
	wellCargoWeight : Decimal [16,4];
	wellTare : Decimal [16,4];
	wellLength : Decimal [16,4];
	wellWidth : Decimal [16,4];
	load : Boolean;
	pxy : CM_WagonWellDefinition;
	wellLocations : StringArray;
	string : String;
	pos : Integer;
	
	sealTypeStr : String;
	sealTypes : CM_SealTypeDict;
	sealType : CM_SealType;
	
	boxcarGraphic : Integer;
		
begin

	//set up some default values.
	maxPosiWeight := 4100.00;
	maxPosiHeight := 300.00;
	deckHeight := 45.00;
	tareWeight := 5000.00;
	maxLoadWeight := 50000;
	notAvailableForEntry := false;
	maxNumInStack := 1;

	self.assertTrueMsg(classId.length &lt; 8, "Class ID value may be up to 7 characters long '" &amp; classId &amp; "' !!");
	
	existingWagonClass := app.myRoot.allWagonClasses.getAtKey(classId);

	self.assertTrueMsg(existingWagonClass = null, "Wagon class '" &amp; classId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	if self.opts.includesKey("AcceptsGenerator") then
		acceptsGenerator := self.opts.bool("AcceptsGenerator");
	endif;
	
	if self.opts.includesKey("DoorsAccessible") then
		doorsAccessible := self.opts.bool("DoorsAccessible");
	endif;
	
	if self.opts.includesKey("NotAvailableForEntry") then
		notAvailableForEntry := self.opts.bool("NotAvailableForEntry");
	endif;
	
	if self.opts.includesKey("LengthInUnits") then
		lenInUnits := self.opts.int("LengthInUnits");
	else
		lenInUnits := 8;
	endif;
	
	if self.opts.includesKey("WagonType") then
		wagonType := self.opts.int("WagonType");
	else
		wagonType := CM_WagonClass.Wagon_Flatcar;
	endif;
	
	if self.opts.includesKey("InternalHeight") then
		intHeight := self.opts.dec("InternalHeight");
	endif;
	if self.opts.includesKey("InternalLength") then
		intLength := self.opts.dec("InternalLength");
	endif;
	if self.opts.includesKey("InternalWidth") then
		intWidth := self.opts.dec("InternalWidth");
	endif;
	if self.opts.includesKey("ExternalHeight") then
		extHeight := self.opts.dec("ExternalHeight");
	endif;
	if self.opts.includesKey("ExternalLength") then
		extLength := self.opts.dec("ExternalLength");
	endif;
	if self.opts.includesKey("ExternalWidth") then
		extWidth := self.opts.dec("ExternalWidth");
	endif;
	
	if self.opts.includesKey("Tare") then
		tareWeight := self.opts.dec("Tare");
	endif;
	if self.opts.includesKey("MaxPosiWeight") then
		maxPosiWeight := self.opts.dec("MaxPosiWeight");
	endif;
	if self.opts.includesKey("MaxPosiHeight") then
		maxPosiHeight := self.opts.dec("MaxPosiHeight");
	endif;
	if self.opts.includesKey("DeckHeight") then
		deckHeight := self.opts.dec("DeckHeight");
	endif;
	if self.opts.includesKey("MaxLoadWeight") then
		maxLoadWeight := self.opts.dec("MaxLoadWeight");
	endif;
	
	if self.opts.includesKey("SealType") then
		sealTypeStr := self.opts.str("SealType");
		if sealTypeStr &lt;&gt; null then
			sealType := app.myRoot.allSealTypes.getAtKey(sealTypeStr);
			if sealType &lt;&gt; null then
				create sealTypes transient;
				sealTypes.add(sealType);
			endif;
		endif;
	endif;
	
	if self.opts.includesKey("Carrier") then
		carrier := self.opts.obj("Carrier").CM_Carrier;
	endif;
	if wagonType = CM_WagonClass.Wagon_Flatcar or wagonType = CM_WagonClass.Wagon_Wellcar then
		if self.opts.includesKey("MaxNumInStack") then
			maxNumInStack := self.opts.int("MaxNumInStack");
		endif;
	endif;
	
	create proxyWagonClass transient;
	create pConsigneeRestrictions transient;
	create pLocationIds transient;

	if wagonType = CM_WagonClass.Wagon_Wellcar then
		pLocationIds.add("A");
		if lenInUnits = 8 then
			pLocationIds.add("B");
		elseif lenInUnits = 12 then
			pLocationIds.add("C");
			pLocationIds.add("B");
		elseif lenInUnits =16 then
			pLocationIds.add("C");
			pLocationIds.add("D");
			pLocationIds.add("B");
		elseif lenInUnits = 20 then
			pLocationIds.add("C");
			pLocationIds.add("D");
			pLocationIds.add("E");
			pLocationIds.add("B");
		endif;
		if maxNumInStack = 2 then
			create tierIds transient;
			if self.opts.includesKey("TierIds") then
				string := self.opts.str("TierIds").String;
				foreach pos in 1 to string.length do
					tierIds.add(string[pos]);
				endforeach;
			else
				tierIds.add("B");
				tierIds.add("A");
			endif;
		endif;

		create wellLocations transient;
		wellLocations.add("1");
		wellLocations.add("2");
		wellLocations.add("3");
		wellLocations.add("4");
	else
		foreach index in 1 to lenInUnits do
			pLocationIds.add(index.String);
		endforeach;
	endif;
	
	if self.opts.includesKey("BoxCarGraphic") then
		boxcarGraphic := self.opts.int("BoxCarGraphic").Integer;
	endif;

	proxyWagonClass.setProxy(	classId,	//pCode : String;
								acceptsGenerator,	//pAcceptsGenerator : Boolean;
								doorsAccessible,	//pDoorsAccessible : Boolean;
								notAvailableForEntry,	//isNotAvailableForEntry : Boolean; 
								maxLoadWeight,	//pMaxLoadWeight : Integer;
								maxNumInStack,	//pMaxNumInStack : Integer;
								lenInUnits,	//pLenInUnits : Integer;
								pLocationIds,	//pLocationIds : StringArray;
								pConsigneeRestrictions,	//pConsigneeRestrictions : CM_ConsignCodeArray;
								deckHeight,	//pDeckHeight : Decimal;
								maxPosiHeight,	//pMaxCargoHeight : Decimal;
								tareWeight,	//pTareWeight : Decimal;
								carrier,	//pMyCarrier : CM_Carrier
								intHeight,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								intLength,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								intWidth,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								extHeight,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								extLength,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								extWidth,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								wagonType,	//pWagonType : Integer;
								tierIds,		//pTierIds : StringArray;
								sealTypes,	//pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
								boxcarGraphic // TFS 49523
								);
								
	app.myTrxCA.trxCreateWagonClass(proxyWagonClass, wagonClass, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	if wagonClass &lt;&gt; null and wagonType = CM_WagonClass.Wagon_Flatcar then
		create pxyRule transient;
		pxyRule.setProxy(	proxyWagonClass,	//_myWagonClass : CM_WagonClass;
							4,	//_numberOfPositions : Integer;
							null	//_allWagonPositions : CM_WagonPositionDict
							);
							
		foreach pxyPosi in pxyRule.allWagonPositions do
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		endforeach;
	
		app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		
	elseif wagonClass &lt;&gt; null and wagonType = CM_WagonClass.Wagon_Wellcar then
	
		if self.opts.includesKey("WellDeckHeight") then
			wellDeckHeight := self.opts.dec("WellDeckHeight");
		else
			wellDeckHeight := deckHeight;
		endif;
		if self.opts.includesKey("WellMaxCargoHeight") then
			wellMaxCargoHeight := self.opts.dec("WellMaxCargoHeight");
		else
			wellMaxCargoHeight := maxPosiHeight;
		endif;
		if self.opts.includesKey("WellCargoWeight") then
			wellCargoWeight := self.opts.dec("WellCargoWeight");
		else
			wellCargoWeight := maxLoadWeight / pLocationIds.size;
		endif;
		if self.opts.includesKey("WellTare") then
			wellTare := self.opts.dec("WellTare");
		else
			wellTare := tareWeight / pLocationIds.size;
		endif;
		if self.opts.includesKey("WellLength") then
			wellLength := self.opts.dec("WellLength");
		endif;
		if self.opts.includesKey("WellWidth") then
			wellWidth := self.opts.dec("WellWidth");
		endif;
		
		foreach wellDef in wagonClass.allWagonWellDefArray do
			app.cmsBeginLoad(load);
			pxy := wellDef.pxyCreateUpdateProxy();
			app.cmsEndLoad(load);
			
			pxy.setProxy(	wellDeckHeight,	//_deckHeight : Decimal;			
							wellLocations.size,	//_lenInUnits : Integer;
							wellMaxCargoHeight,	//maxCargoHeight : Decimal;
							wellCargoWeight,	//_maxLoadWeight : Decimal;
							wellLength,	//_overallLength : Decimal;
							wellWidth,	//_overallWidth : Decimal;
							wellTare,	//_tareWeight : Decimal;
							pxy.wellId,	//_wellId : String;
							wellLocations	//_wellLocations : StringArray
							);
			app.myTrxUA.trxUpdateWagonWellDef(pxy, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			delete pxy;
		endforeach;
		
	endif;
	
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class not created!");
	
	return wagonClass;
						
epilog

	app.cmsEndLoad(loadState);
	delete proxyWagonClass;
	delete pConsigneeRestrictions;
	delete pLocationIds;
	delete tierIds;
	delete pxy;
	delete wellLocations;
	delete sealTypes;
	
end;</source>
        <Parameter name="classId" type="String"/>
        <ReturnType type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="addWagonInRailArea" id="2fafadb9-deda-43fd-8b41-abce5eff4653">
        <source>addWagonInRailArea(_wagonCode, _wagonClassCode : String; _railArea : CM_Rail;  _train : CM_Train) : CM_Wagon;
//02 November 2009	cnwjo3	
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	proxyWagon, wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	//railLine : CM_RailLine;
	terminal : CM_Terminal;
	ta : CM_TerminalArea;
	railArea : CM_Rail;
	
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	ls : Boolean;  //what do i do?
begin
	app.cmsBeginLoad(ls);
	create wagonUpdateCtrl transient;
	
	terminal := app.myPassport.myTerminal;
	railArea := _railArea;
	assertTrueMsg(railArea &lt;&gt; null , "No rail area");
	
	wagonClass := app.myRoot.allWagonClasses[_wagonClassCode];
	assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class does not exist");
	
//	create proxyWagon transient;
	create proxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	proxyWagon.setProxy(app.myPassport.myTerminal,
						_wagonCode,
						wagonClass,
						_train,
						_train,
						null,
						null,
						null,
						null,
						null,
						null,  //02.10.2020 cnwma1 TFS #50112
						null); //02.10.2020 cnwma1 TFS #50112
	
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	if self.opts.includesKey("RailLine") then								// 14/04/2014 cnwmh5
		wagonUpdateCtrl.setPropertyValue("myRailLine", self.opts.obj("RailLine").CM_RailLine);
	endif;
	
	app.cmsEndLoad(ls);

	//i have to set the myProxyWagon at some point too :-(
	
	//we don't use CreateWagon.  we are using CreateWagonCMIF
	//app.myTrxCA.trxCreateWagon(proxyWagon, wagon, railLine, null, null, app.myPassport);
	wagonUpdateCtrl.isTrainMode := true;
	wagonUpdateCtrl.mode := 1; //Mode_Add;  //nice
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return wagon;
epilog
	app.cmsEndLoad(ls);					// 08/04/2011 cnwmh5 #27347
	delete proxyWagon;
	delete wagonUpdateCtrl;
end;</source>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_wagonClassCode" type="String"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonToTrainOption2" id="0d25ae39-cc25-45c4-ae4b-cc8e31323441">
        <source>addWagonToTrainOption2( train : CM_Train;	// mandatory
						wagonMaster : CM_WagonMaster;	// mandatory
						allTrackedItems : CM_TIByIdDups;	//optional (containing as many 20 foot containers as will fit on the wagon)
						makeInTransit : Boolean
						): CM_Wagon;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2009	cnwndl1	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	wagonLength : Integer;
	tiArraySize : Integer;
	ti : CM_TrackedItem;
	pos : Integer;
	wagonPosition : CMIF_TIWagonPosition;
	tiArray : CM_TIArray;
	proxyWagon : CM_Wagon;
	wagon : CM_Wagon;
	railLine : CM_RailLine;
begin
	
	railLine := self.opts.obj("RailLine").CM_RailLine;
	
	// create Wagon on Train from WagonMaster, adds containers to wagon.
	create  wagonUpdateCtrl transient;	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
										railLine,	//_rake : CM_RailLine;
										train,	//_train : CM_Train;
										train.allWagonsByIdInward.size + 1,	//_wagonPosition : Integer
										true//_trainMode : Boolean
										);
	
	if wagonMaster.myWagonClass &lt;&gt; null then
		wagonLength := wagonMaster.myWagonClass.getLenInUnits;
	else
		wagonLength := 8;	// default value
	endif;
	
	if allTrackedItems &lt;&gt; null then
		self.assertTrueMsg(( allTrackedItems.size * 2 ) &lt;= wagonLength, "Too many ti's for wagon");
	endif;
	
	create tiArray transient;
	if allTrackedItems &lt;&gt; null and not allTrackedItems.isEmpty then
		foreach ti in allTrackedItems do
			self.assertTrueMsg(ti.getActualLength = 20, "Container wrong size for this method, must be a 20 footer");
			tiArray.add(ti);
			tiArray.add(ti);
		endforeach;
	endif;
	tiArraySize := tiArray.size;
	
	//09 Feb 2011	NDL	To fix up test after Par 26899 changes
	foreach ti in tiArray do
		beginTransaction;
		ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
		if makeInTransit then
			ti.setImExStatus( TI_IMEX_STATUS_REMAINONBOARD);
		endif;
		commitTransaction;
	endforeach;
	
	foreach pos in 1 to wagonLength do
		create wagonPosition transient;
		wagonUpdateCtrl.allWagonPositions.add(wagonPosition);
		wagonPosition.position := pos;
		wagonPosition.available := true;
		wagonPosition.hasTwistLocks := true;
		wagonPosition.twistLocksAreUp := false;
		if tiArraySize &gt;= pos then
	//		wagonPosition.trackedItemId := tiArray[pos].id;
			if pos.isOdd then
			//	wagonPosition.myTrackedItem := tiArray[pos];
				//14 Oct 2014	NDL	Par 35040
				if tiArray[pos] &lt;&gt; null then
					wagonPosition.allTrackedItems.add(tiArray[pos]);
				endif;
			endif;
		endif;
	endforeach;
	
	if allTrackedItems &lt;&gt; null then
		allTrackedItems.copy(wagonUpdateCtrl.allTrackedItems);
	endif;
	
//	create proxyWagon transient;
	if wagonMaster.myWagonClass = null then	//22 Mar 2013	NDL	Par 31278
		create proxyWagon as app.getWagonVisitClassToCreate( null, train.myTerminal, wagonMaster.id, null )  transient;//22 Mar 2013	NDL	Par 31278
	else
		create proxyWagon as wagonMaster.myWagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	endif;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
//	wagonUpdateCtrl.isTrainMode := true; 
	
	proxyWagon.setProxy(train.myTerminal,	//_term			: CM_Terminal;
						wagonMaster.id,	//_id 			: String;
						wagonMaster.myWagonClass,	//_class 			: CM_WagonClass;
						train,	//_train			: CM_Train;
						train,	//_outTrain		: CM_Train;
						null,	//_remark 		: String;
						wagonMaster.maxCargoHeight,	//_maxCargoHeight	: Decimal; 
						wagonMaster.maxCargoWeight,	//_maxCargoWeight	: Decimal;
						wagonMaster.tareWeight,	//_tareWeight		: Decimal;
						wagonMaster.myCarrier,	//_carrier		: CM_Carrier
						null,                   //02.10.2020 cnwma1 TFS #50112
						null                    //02.10.2020 cnwma1 TFS #50112
						);
	
	if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		wagonUpdateCtrl.unconfirmWagonOutwards := true;
	endif;	
	wagonUpdateCtrl.doAutoPlan := true;
	wagonUpdateCtrl.unconfirmWagonInwards := true;
	
	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
		
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(wagon &lt;&gt; null, "Wagon '" &amp; wagonMaster.id &amp; "' not created.");
	
epilog

	if not wagonUpdateCtrl.allWagonPositions.isEmpty then
		wagonUpdateCtrl.allWagonPositions.purge;
	endif;
	delete wagonUpdateCtrl;
	delete tiArray;
	delete proxyWagon;
	
	return wagon;
	
end;</source>
        <Parameter name="train" type="CM_Train"/>
        <Parameter name="wagonMaster" type="CM_WagonMaster"/>
        <Parameter name="allTrackedItems" type="CM_TIByIdDups"/>
        <Parameter name="makeInTransit" type="Boolean"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonToTrainOption3" id="3f54cd4f-2397-4cc0-9e56-90c8cb004e11">
        <source>addWagonToTrainOption3(	_train : CM_Train;	// mandatory
						_wagonId : String;
						_wagonClass : CM_WagonClass;
						_ti : CM_TrackedItem input;	//optional (One 20 foot container)
						_ignoreWarnings : Boolean;
						_makeIntransit : Boolean
						) : CM_Wagon;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2009	cnwndl1	Initial creation
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars

	wagonUpdateCtrl : CMIF_WagonUpdateController;
	pos : Integer;
	wagonPosition : CMIF_TIWagonPosition;
	proxyWagon : CM_Wagon;
	wagon : CM_Wagon;

begin
	// create Wagon ( WagonMaster s/be created automatically )
	
	create  wagonUpdateCtrl transient;	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
										null,	//_rake : CM_RailLine;
										_train,	//_train : CM_Train;
										_train.allWagonsByIdOutward.size + 1,	//_wagonPosition : Integer
										true//_trainMode : Boolean
										);
	
	self.assertTrueMsg(_wagonClass.getLenInUnits &gt;= 2, "Wagon class length in units too short.");
	
	foreach pos in 1 to _wagonClass.getLenInUnits do
		create wagonPosition transient;
		wagonUpdateCtrl.allWagonPositions.add(wagonPosition);
		wagonPosition.position := pos;
		wagonPosition.available := true;
		wagonPosition.hasTwistLocks := true;
		wagonPosition.twistLocksAreUp := false;
		if _ti &lt;&gt; null then
			if pos = 1 then
			//	wagonPosition.myTrackedItem := _ti;
				wagonPosition.allTrackedItems.add(_ti);	//14 Oct 2014	NDL	Par 35040
				
		//		wagonPosition.trackedItemId := _ti.id;
		//	elseif pos = 2 then
		//		wagonPosition.trackedItemId := _ti.id;
			endif;
		endif;
	endforeach;
	
	if _ti &lt;&gt; null then
		wagonUpdateCtrl.allTrackedItems.add(_ti);
		
		//09 Feb 2011	NDL	To fix up test after Par 26899 changes
		beginTransaction;
		_ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
		if _makeIntransit then
			_ti.setImExStatus( TI_IMEX_STATUS_REMAINONBOARD);
		endif;
		commitTransaction;
	
	endif;
	
	//create proxyWagon transient;	
	
	//wagonUpdateCtrl.isTrainMode := true; 
	create proxyWagon as _wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	proxyWagon.setProxy(_train.myTerminal,	//_term			: CM_Terminal;
						_wagonId,	//_id 			: String;
						_wagonClass,	//_class 			: CM_WagonClass;
						_train,	//_train			: CM_Train;
						_train,	//_outTrain		: CM_Train;
						null,	//_remark 		: String;
						_wagonClass.maxCargoHeight,	//_maxCargoHeight	: Decimal; 
						_wagonClass.maxLoadWeight,	//_maxCargoWeight	: Decimal;
						_wagonClass.tareWeight,	//_tareWeight		: Decimal;
						_wagonClass.myCarrier,	//_carrier		: CM_Carrier
						null,                   //02.10.2020 cnwma1 TFS #50112
						null                    //02.10.2020 cnwma1 TFS #50112
						);
	
	if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		wagonUpdateCtrl.unconfirmWagonOutwards := true;
	endif;	
	wagonUpdateCtrl.doAutoPlan := true;
	wagonUpdateCtrl.unconfirmWagonInwards := true;
	
	self.ignoreTrxWarnings(_ignoreWarnings);
	//app.myPassport.setWarningsIgnored(_ignoreWarnings);
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);	
	if _ignoreWarnings then
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
	
epilog

	if not wagonUpdateCtrl.allWagonPositions.isEmpty then
		wagonUpdateCtrl.allWagonPositions.purge;
	endif;
	delete wagonUpdateCtrl;
	delete proxyWagon;
	
	return wagon;
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
        <Parameter name="_makeIntransit" type="Boolean"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWaypoint" id="615f047c-423d-498a-9486-8bce0e6929e7">
        <source>addWaypoint(_waypointCode, _waypointDesc : String; _harbour : HMS_Harbour; _preferredBerth : HMS_Berth) : HMS_HarbourRegion;

/*

Purpose:		Add a WayPoint

Date			Who		Reason
12/01/2012		cnwmh5	Initial creation
*/

vars

	pxyWaypoint			: HMS_HarbourRegion;
	waypoint			: HMS_Object;
	restriction			: HMS_CheckPoint;
	terminal			: CM_Terminal;
	
	allCheckPoints 		: HMS_CheckPointByTypeDict;

begin

	self.deleteWaypoint(_waypointCode);

	create allCheckPoints transient;

	// Get any checkpoints (restrictions)
	if self.opts.includesKey("Restriction-UserHookCode") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-UserHookCode")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Restriction-Height") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-Height")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Restriction-TideState") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-TideState")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Terminal") then
		terminal := self.opts.obj("Terminal").CM_Terminal;
	endif;
	
	create pxyWaypoint transient;
	pxyWaypoint.setProxy(app.myRoot,  
						 _harbour,  
						 terminal,									// terminal
						 _preferredBerth,
						 allCheckPoints);
						 
	pxyWaypoint.setPropertyValue("code", _waypointCode);
	pxyWaypoint.setPropertyValue("description", _waypointDesc);
	if self.opts.includesKey("CanWaitHere") then
		pxyWaypoint.setPropertyValue("canWaitHere", self.opts.bool("CanWaitHere"));
	endif;
	
	app.myTrxCA.trxCreateHMSObject(pxyWaypoint, waypoint, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
		
	
	return waypoint.HMS_HarbourRegion;

epilog

	delete pxyWaypoint;
	delete allCheckPoints;
	
end;</source>
        <Parameter name="_waypointCode" type="String"/>
        <Parameter name="_waypointDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_preferredBerth" type="HMS_Berth"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="addWharf" id="f968a4d5-dcc9-463b-9e63-6af006e2fe8f">
        <source>addWharf(_wharfId, _wharfDesc : String; _harbour : HMS_Harbour; _length, _width : Integer) : HMS_Wharf;

/*

Purpose:	Add a wharf		

Date			Who		Reason
21/12/2011 		cnwmh5	Initial creation

*/

vars

	pxyWharf			: HMS_Wharf;
	wharf				: HMS_Wharf;
	resource			: HMS_ResourceForWharf;
	
	isLogicalWharf		: Boolean;
	waterOnLeft			: Boolean;
	isVisibleOnView		: Boolean;
	displayLeftToRight	: Boolean;
	overhangStart		: Integer;
	overhangEnd			: Integer;
	timeInHoursAddExtraBlock	: Decimal[12,2];
	
begin

	self.deleteWharf(_wharfId, _harbour);

	create pxyWharf transient;
	
	pxyWharf.setProxy(_harbour,						// Harbour
					  null,							// Jade scode
					  app.myPassport.userCode);		// user code
	
	
	pxyWharf.setPropertyValue("code", _wharfId);
	pxyWharf.setPropertyValue("description", _wharfDesc);
	pxyWharf.setPropertyValue("length", _length);
	pxyWharf.setPropertyValue("width", _width);
	isLogicalWharf := true;
	if self.opts.includesKey("IsLogicalWharf") then
		isLogicalWharf := self.opts.bool("IsLogicalWharf");
	endif;
	pxyWharf.setPropertyValue("isLogicalWharf", isLogicalWharf);
	waterOnLeft := true;
	if self.opts.includesKey("WaterOnLeft") then
		waterOnLeft :=  self.opts.bool("WaterOnLeft");
	endif;
	pxyWharf.setPropertyValue("waterOnLeft", waterOnLeft);
	isVisibleOnView := true;
	if self.opts.includesKey("IsVisibleOnView") then
		isVisibleOnView :=  self.opts.bool("IsVisibleOnView");
	endif;
	pxyWharf.setPropertyValue("isVisibleOnView", isVisibleOnView);
	displayLeftToRight := true;
	if self.opts.includesKey("DisplayLeftToRight") then
		displayLeftToRight :=  self.opts.bool("DisplayLeftToRight");
	endif;
	pxyWharf.setPropertyValue("displayLeftToRight", displayLeftToRight);
		if self.opts.includesKey("OverhangStart") then
		overhangStart := self.opts.int("OverhangStart");
	endif;
	pxyWharf.setPropertyValue("overhangMaxMetreEnd", overhangStart);
	if self.opts.includesKey("OverhangEnd") then
		overhangEnd := self.opts.int("OverhangEnd");
	endif;
	pxyWharf.setPropertyValue("overhangZeroMetreEnd", overhangEnd);
	if self.opts.includesKey("TimeInHoursAddExtraBlock") then
		timeInHoursAddExtraBlock := self.opts.dec("TimeInHoursAddExtraBlock");
	endif;
	pxyWharf.setPropertyValue("timeTill2ndResource", timeInHoursAddExtraBlock);
	
	pxyWharf.allTerminals.add(self.getTerminal());
	
	app.myTrxCA.trxCreateWharf(pxyWharf, wharf, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return wharf;
	
epilog

	delete pxyWharf;

end;</source>
        <Parameter name="_wharfId" type="String"/>
        <Parameter name="_wharfDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <ReturnType type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrder" id="878414c4-dd63-41ad-935d-baed494d87bf">
        <source>addWorkOrder( _id : String; _woStatus : Integer) : CM_WorkOrderTI;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jan 2010	cnwrd1	Initial creation
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	pxyWorkOrder : CM_WorkOrderTI;
	realWorkOrder : CM_WorkOrder;
	pxyRequest : CM_WorkOrderRequestByType;
	pxyWorkOrderSource : CM_WorkOrderTISource;
	availGrades	: IntegerArray;
	pxyWODtl : CM_WorkOrderDtl;
	cargoType: CM_CargoType;
	cargoList : String;
	root: CM_Root;
	totalReq : Integer;
	dtRequired,
	dtStart	: 	TimeStamp;
	remarks : String;
	emails : CM_EmailEntityByTypeNameDict;
	operator: CM_Operator;
begin

	deleteWorkOrder(_id);
	
	root := CM_Root.firstInstance;
	cargoType := root.allCargoTypesById[TI_CargoType_Container];
	
	create emails transient;

	if self.opts.includesKey("CargoList") then
		cargoList := self.opts.str("CargoList");
	endif;
	
	if self.opts.includesKey("TotalReq") then
		totalReq := self.opts.int("TotalReq");
	endif;
	
	//dtRequired := app.actualTimeServer().addDays(2);
	//dtStart :=  app.actualTimeServer().addDays(1);	

	if self.opts.includesKey("DtRequired") then
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("DtStart") then
		dtStart := self.opts.str("DtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	
	create pxyWorkOrder transient;
		
	pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 							//_customerReference
			false, 							//_emailNotification
			app.actualTimeServer, 			//_enteredByDT
			app.getMyUser(), 				//_enteredByUser 
			'',								//_approvedBy
			app.getMyUser().myOrganisation, // _myOrganisation
			app.myPassport.myTerminal, 		//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 						//	WO_STATUS_USERENTRY 			//_taskStatus
			);
			
			
	pxyWorkOrder.setID( _id ); //set the ID so we know what one we are creating to delete later..
	//pxyWorkOrder.setTotalRequired(totalReq);					//08.02.2023 navma1 #56457 Task#56458


	pxyWorkOrderSource := pxyWorkOrder.setProxyWorkOrderSource(
			null,				// real work order, dont have here
			pxyWorkOrder,   	// the source parent, the pxyWorkOrder here (is also used to set source for pack task
			cargoType, 			// cargo type - ISO Container here
			cargoList, 				// CSV string of cargo ID's
			false				// not updating here
			);
			
	
	
	self.addWorkOrderTask(pxyWorkOrder);
	
	operator := self.opts.obj("Operator").CM_Operator;
	if operator &lt;&gt; null then
		create availGrades transient;
		if 	self.opts.includesKey("AvailabilityGrade") then
			availGrades.add(self.opts.int("AvailabilityGrade"));
		endif;
		create pxyRequest transient;
		pxyRequest.setProxy(
				null, 						//_myCargoType		: CM_CargoType;
				self.opts.str("ISOType"), 	//_isoType			: String;
				self.opts.obj("Operator").CM_Operator,	//_operator			: CM_Operator;
				null, 						//_operatorGroup		: CM_OperatorGroup;
				0,							//_totalRequested		: Integer;
				null,						//_isoGroup			: String;
				availGrades, 				//_availabilityGrades	: IntegerArray;
				false,						//_clean 				: Boolean;
				false,						// _heavyRated			: Boolean;
				null,						//		: CM_LocationsController;
				null						//_product			: CM_Product	
				);
		pxyWorkOrderSource.proxyAddWoRequest(pxyRequest);
	endif;
	
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	

	return realWorkOrder.CM_WorkOrderTI;		
	
epilog
	delete pxyWorkOrder;
	delete emails;
	delete availGrades;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <ReturnType type="CM_WorkOrderTI"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderApproved" id="7b1665f7-88c0-4f77-8c68-68e1b9f008ff">
        <source>addWorkOrderApproved( _id : String;  _totalCount : Integer; _dtRequired: TimeStamp; _dtStart : TimeStamp; _toDoTask : CM_ToDoTaskDesc) : CM_WorkOrderTI;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jan 2010	cnwrd1	Initial creation
05/08/2011	cnwmh5	Change to use UT_UnitTest's opts
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	pxyWorkOrder  : CM_WorkOrderTI;
	realWorkOrder : CM_WorkOrder;
	pxyWODtl 	  : CM_WorkOrderDtl;
	cargoType	  : CM_CargoType;
	root		  : CM_Root;
begin
	


	root := CM_Root.firstInstance;
	
	if self.opts.includesKey("cargoType") then
		cargoType := root.allCargoTypesById[self.opts.int("cargoType")];
	endif;
	
	create pxyWorkOrder transient;
		
	pxyWorkOrder.setProxy(		
			null, 							//_allEmailAddresses
			null, 							//_customerReference
			false, 							//_emailNotification
			app.actualTimeServer, 			//_enteredByDT
			app.getMyUser(), 				//_enteredByUser 
			'',								//_approvedBy
			app.getMyUser().myOrganisation, // _myOrganisation
			app.myPassport.myTerminal, 		//_myTerminal
			'',  							//_remarks
			_dtRequired,							//_requiredByDT
			_dtStart, 							//_startAtDT
			WO_STATUS_APPROVED 				//_taskStatus
			);
			
			
	pxyWorkOrder.setID( _id ); //set the ID so we know what one we are creating to delete later..
	//pxyWorkOrder.setTotalRequired(_totalCount);					//08.02.2023 navma1 #56457 Task#56458

	pxyWorkOrder.setProxyWorkOrderSource(
			null,				// real work order, dont have here
			pxyWorkOrder,   	// the source parent, the pxyWorkOrder here (is also used to set source for pack task
			cargoType, 			// cargo type - ISO Container here
			'', 				// CSV string of cargo ID's
			false				// not updating here
			);
			
	if opts.includesKey("tiTextList") then
		pxyWorkOrder.setPropertyValue(CM_WorkOrderTISource::tiTextList.name, opts.str("tiTextList"));		
	endif;
			
	self.addWorkOrderTask(pxyWorkOrder);
			
	
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	

	return realWorkOrder.CM_WorkOrderTI;		
	
epilog
	delete pxyWorkOrder;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_totalCount" type="Integer"/>
        <Parameter name="_dtRequired" type="TimeStamp"/>
        <Parameter name="_dtStart" type="TimeStamp"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
        <ReturnType type="CM_WorkOrderTI"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderSchedule" id="ba010a20-5025-4a93-bef7-41aa410ddcfe">
        <source>addWorkOrderSchedule( _workOrderDtl: CM_WorkOrderTIDtl; _schedDate : TimeStamp; _count: Integer) : CM_WorkOrderSchedule;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwrd1	Initial creation

*/

vars
	pxySchedule,
	realSchedule : CM_WorkOrderSchedule;
begin

	create pxySchedule transient;
	pxySchedule.setProxy( _count, _schedDate);
	
	app.myTrxCA.trxCreateWorkOrderSchedule(pxySchedule, realSchedule,_workOrderDtl, app.myPassport);
	
	return realSchedule; 

epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderTIDtl"/>
        <Parameter name="_schedDate" type="TimeStamp"/>
