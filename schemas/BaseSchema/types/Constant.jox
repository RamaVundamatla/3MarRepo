<Class name="Constant">
    <JadeMethod name="cnEcIsGlobal" id="87dc96ef-9049-4cae-80b4-a5d46a5ec76c">
        <source>cnEcIsGlobal():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 April 2009 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receival is Global.
//
// Parameters:	None
//
// Returns:		True if the receiver is Global, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsUsed" id="92a58fdb-68ba-4bbd-9183-75a8121f854f">
        <source>cnEcIsUsed():Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is used.
//
// Parameters:	None
//
// Returns:		True if the receiver is used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allReferencesObj	: MethodSet;

begin
	if (not self.constantRefs.isEmpty()) then
		return true;
	endif;
	
	if (not self.constantUsages.isEmpty()) then
		return true;
	endif;
	
	create allReferencesObj transient;
	self.getMethodRefs(allReferencesObj);
	
	if (not allReferencesObj.isEmpty()) then
		return true;
	endif;
	
	return false;
epilog
	delete allReferencesObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
