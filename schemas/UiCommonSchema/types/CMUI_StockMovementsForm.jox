    <JadeMethod name="outputBucketsByLocation" id="82594094-08ab-44bc-a1a2-9939003524f4">
        <source>outputBucketsByLocation(_iter : Iterator input);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bucket				: CM_StockMoveLocation;
	stockMovement		: CM_StockMovement;
	firstTime			: Boolean;
	tmpDate,
	firstDate			: Date;
	rowIdx,
	moveType			: Integer;
	rowMoveHelper,
	totalMoveHelper		: CMIF_StockMoveHelper;	
	passport			: CM_Passport;
	locn				: CM_SOHLocation;
	failedDAC  :CM_DataAccessController;
begin
	
	create totalMoveHelper transient;
	create rowMoveHelper transient;
	self.allStockMoveHelpers.add(rowMoveHelper);
	self.outputOpeningLevelsForDate(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	
	firstTime := true;
	
	passport := app.myPassport;
	
	while _iter.next(bucket) do
		if bucket.date &gt; self.filtCloseDate then
			break;
		endif;

		locn := bucket.mySOHLocation;
		if locn &lt;&gt; null then
			if not locn.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
		endif;

		if firstTime then
			firstTime 	:= false;
			firstDate 	:= bucket.date;
			tmpDate 	:= firstDate;
		endif;
		if self.filtShowDetail then
			if tmpDate &lt;&gt; bucket.date then
				rowIdx := self.tblData.addItem(tmpDate.String);
				self.tblData.accessRow(rowIdx).backColor := self.colorRow2;
				self.outputRow('Receivals/Releases', rowMoveHelper, 1);
				self.outputRow('Reject', rowMoveHelper, 2);
				self.outputRow('Operator Change', rowMoveHelper, 3);
				self.outputRow(app.getErrorString(Product) &amp; ' Change', rowMoveHelper, 4);
				self.outputRow('Update Change', rowMoveHelper, 5);
				self.outputRow('Reassembly', rowMoveHelper, 6);
				self.outputRow('Fixup', rowMoveHelper, 7);				

				tblData.accessRow(rowIdx).itemObject := rowMoveHelper;
				create rowMoveHelper transient;
				self.allStockMoveHelpers.add(rowMoveHelper);
			endif;
		endif;
		rowMoveHelper.totalQuantities(bucket);

		totalMoveHelper.totQty := totalMoveHelper.totQty + bucket.adjustQuantity.Integer;
		totalMoveHelper.totVol := totalMoveHelper.totVol + bucket.adjustVolume.Decimal;
		totalMoveHelper.totWeight := totalMoveHelper.totWeight + bucket.adjustWeightKgs.Integer;

		tmpDate := bucket.date;
	endwhile;

	if self.filtShowDetail then
		rowIdx := self.tblData.addItem(tmpDate.String);
		self.tblData.accessRow(rowIdx).backColor := self.colorRow2;
		tblData.accessRow(rowIdx).itemObject := rowMoveHelper;
	endif;
	self.outputRow('Receivals/Releases', rowMoveHelper, 1);
	self.outputRow('Reject', rowMoveHelper, 2);
	self.outputRow('Operator Change', rowMoveHelper, 3);
	self.outputRow(app.getErrorString(Product) &amp; ' Change', rowMoveHelper, 4);
	self.outputRow('Update Change', rowMoveHelper, 5);
	self.outputRow('Reassembly', rowMoveHelper, 6);
	self.outputRow('Fixup', rowMoveHelper, 7);					
	
	self.outputCloseLevelsForDate(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);

epilog
	delete totalMoveHelper;
		
end;</source>
        <Parameter name="_iter" type="Iterator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputBucketsByProduct" id="7886920a-4602-4aa6-b85e-c5f28836925f">
        <source>outputBucketsByProduct(_iter : Iterator input);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bucket				: CM_StockMoveLocation;
	//stockMovement		: CM_StockMovement;
	firstTime			: Boolean;
	tmpDate,
	firstDate			: Date;
	rowIdx				: Integer;
	//moveType			: Integer;
	rowMoveHelper,
	totalMoveHelper		: CMIF_StockMoveHelper;	
	passport			: CM_Passport;
	//locn				: CM_SOHLocation;
	failedDAC  			: CM_DataAccessController;
	product				: CM_Product;
	sohLoc 				: CM_SOHLocation;
begin

	create totalMoveHelper transient;
	create rowMoveHelper transient;
	self.allStockMoveHelpers.add(rowMoveHelper);
	
	totalMoveHelper.clearSelf();
	self.outputOpeningLevelsForProduct(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);

	passport := app.myPassport;

	firstTime := true;
	
	while _iter.next(bucket) do
		if bucket.productType &lt;&gt; self.myFiltCargoType.id then
			continue;
		endif;
		
		sohLoc := bucket.mySOHLocation;
		
		if self.myFiltProduct &lt;&gt; null then
			//PAR15591/18081 - cnwsh3 Check product and operator as the same product code can be used on different operators.
			if self.myFiltOperator &lt;&gt; null and 
			   sohLoc &lt;&gt; null then
				product:= sohLoc.myProduct;
					
				if product &lt;&gt; null then
					//First check if I'm the correct product code by checking if the product and operator match based on their code.
					if	(product.code &lt;&gt; self.myFiltProduct.code) or
						(product.myOperator.code &lt;&gt; self.myFiltOperator.code) then 
						continue;
					endif;
							
					//If I have the same product code but the product objects are different then we don't need to report it. Object 4076.4291 is one such case of this.
					if (product &lt;&gt; self.myFiltProduct) then
						continue;
					endif;
										
				endif;
				
			else 
				//Don't have an operator so just check the product code.
				if bucket.product &lt;&gt; self.myFiltProduct.code then
					continue;
				endif;
			endif;
		endif;
		
		//Was just this before PAR15591/18081.
		/*if self.myFiltProduct &lt;&gt; null then
			if bucket.product &lt;&gt; self.myFiltProduct.code then
				continue;
			endif;
		endif;
		*/
		
		if (self.filtOpenDate.isValid and bucket.date &lt; self.filtOpenDate) 
		or bucket.date &gt; self.filtCloseDate then
		//if bucket.date &gt; self.filtCloseDate then
			break;
		endif;
		
		//locn := bucket.mySOHLocation;
		if sohLoc &lt;&gt; null then
			if not sohLoc.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
		endif;
		
		if firstTime then
			firstTime 	:= false;
			firstDate := bucket.date;
			tmpDate 	:= firstDate;
		endif;
		
		if self.filtShowDetail then
			if tmpDate &lt;&gt; bucket.date then
				rowIdx := self.tblData.addItem(tmpDate.String);
				self.tblData.accessRow(rowIdx).backColor := self.colorRow2;
				self.outputRow('Receivals/Releases', rowMoveHelper, 1);
				self.outputRow('Reject', rowMoveHelper, 2);
				self.outputRow('Operator Change', rowMoveHelper, 3);
				self.outputRow(app.getErrorString(Product) &amp; ' Change', rowMoveHelper, 4);
				self.outputRow('Update Change', rowMoveHelper, 5);
				self.outputRow('Reassembly', rowMoveHelper, 6);
				self.outputRow('Fixup', rowMoveHelper, 7);								
				
				self.tblData.accessRow(rowIdx).itemObject := rowMoveHelper;
				create rowMoveHelper transient;
				self.allStockMoveHelpers.add(rowMoveHelper);
			endif;
		endif;
		rowMoveHelper.totalQuantities(bucket);

		totalMoveHelper.totQty 		:= totalMoveHelper.totQty + bucket.adjustQuantity.Integer;
		totalMoveHelper.totVol 		:= totalMoveHelper.totVol + bucket.adjustVolume.Decimal;
		totalMoveHelper.totWeight 	:= totalMoveHelper.totWeight + bucket.adjustWeightKgs.Integer;
		
		tmpDate := bucket.date;	
	endwhile;
	
	if self.filtShowDetail then
		rowIdx := self.tblData.addItem(tmpDate.String);
		self.tblData.accessRow(rowIdx).backColor := self.colorRow2;
		self.tblData.accessRow(rowIdx).itemObject := rowMoveHelper;
	endif;
	self.outputRow('Receivals/Releases', rowMoveHelper, 1);
	self.outputRow('Reject', rowMoveHelper, 2);
	self.outputRow('Operator Change', rowMoveHelper, 3);
	self.outputRow(app.getErrorString(Product) &amp; ' Change', rowMoveHelper, 4);
	self.outputRow('Update Change', rowMoveHelper, 5);
	self.outputRow('Reassembly', rowMoveHelper, 6);
	self.outputRow('Fixup', rowMoveHelper, 7);					

	if self.myFiltProduct &lt;&gt; null then //we're querying on product type so
		self.outputCloseLevelsForProduct(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	else
		self.outputCloseLevelsForDate(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	endif;

epilog
	delete totalMoveHelper;
end;</source>
        <Parameter name="_iter" type="Iterator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputCloseLevelsForDate" id="dbaa92a9-613a-4510-b9f4-857a7bd82a63">
        <source>outputCloseLevelsForDate(_totQty, _totVol : Real ; _totWeight : Decimal);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	closeStr		: String;
	today,
	closeDate		: Date;
	closeQty		: Integer;
	closeVol		: Real;
	closeWeight		: Decimal[14,4];	
	sohLocn			: CM_SOHLocation;
	idx				: Integer;
	noProdQty		: Integer;
	noProdVol		: Real;
	noProdWeight	: Decimal[14,4];	
begin
	closeDate := self.filtCloseDate;
	
	if self.filtLocationType = LocationType_LC then
		self.myFiltLC.getSOHLevelsForDate(closeDate, true, closeQty, closeVol, closeWeight);
		self.myFiltLC.getSOHLevelsNoProduct(true, noProdQty, noProdVol, noProdWeight);

	elseif self.filtLocationType = LocationType_TA then
		self.myFiltTA.getSOHLevelsForDate(closeDate, true, closeQty, closeVol, closeWeight);
		self.myFiltTA.getSOHLevelsNoProduct(true, noProdQty, noProdVol, noProdWeight);

	elseif self.filtLocationType = LocationType_Terminal then
		self.myFiltTerminal.getSOHLevelsForDate(closeDate, true, closeQty, closeVol, closeWeight);
		self.myFiltTerminal.getSOHLevelsNoProduct(true, noProdQty, noProdVol, noProdWeight);

	elseif self.filtLocationType = LocationType_Voyage then
		self.myFiltVoyage.getSOHLevelsForDate(closeDate, true, closeQty, closeVol, closeWeight);		
		noProdQty := 0;
		noProdVol := 0;
		noProdWeight := 0;		
	endif;
	
	closeStr := 'Calculated Closing Level' &amp; Tab &amp; Tab &amp; Tab &amp;
				_totQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				_totVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				_totWeight.asStringWeightJMT();
	
	idx := tblData.addItem(closeStr);
	if closeQty &lt;&gt; _totQty then
		tblData.accessRow(idx).backColor := self.ColorRedWarning;
	else
		tblData.accessRow(idx).backColor := self.colorRow1;
	endif;

	closeStr := 'Actual Closing Level' &amp; Tab &amp; Tab &amp; Tab &amp;
				closeQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				closeVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				closeWeight.asStringWeightJMT(); // cnwrd1 par 20165 ++ 1.7.09
				//closeWeight.String;	
	
	idx := tblData.addItem(closeStr);
	if closeQty &lt;&gt; _totQty or
	   closeVol &lt;&gt; _totVol or
	   closeWeight &lt;&gt; _totWeight then
		tblData.accessRow(idx).backColor := self.ColorRedWarning;
	else
		tblData.accessRow(idx).backColor := self.ColourYellowLight;
	endif;

	//this might help to show why the balance is out (if at all)
	if closeDate &gt;= app.actualTimeServer.date
	and noProdQty &gt; 0 then
		//this is the only time non-product stuff gets picked up
		closeStr := 'Non-Product items in this location' &amp; Tab &amp; Tab &amp; Tab &amp;
				noProdQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				noProdVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				noProdWeight.asStringWeightJMT();	// cnwrd1 par 20165 ++ 1.7.09
	
		idx := tblData.addItem(closeStr);
		if noProdQty &gt; 0 then
			tblData.accessRow(idx).backColor := self.ColorRedWarning;
		else
			tblData.accessRow(idx).backColor := self.ColourYellowLight;
		endif;
	endif;

			
end;</source>
        <Parameter name="_totQty" type="Real"/>
        <Parameter name="_totVol" type="Real"/>
        <Parameter name="_totWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="outputCloseLevelsForProduct" id="de4e2f84-3b98-4b7a-8eb9-b7a6c3920e85">
        <source>outputCloseLevelsForProduct(_totQty : Integer;
							_totVol : Decimal;
							_totWeight : Decimal);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	closeStr		: String;
	today,
	closeDate		: Date;
	closeQty		: Real;
	closeVol,
	closeWeight		: Decimal[16,4];
	sohLocn			: CM_SOHLocation;
	idx				: Integer;
begin
	
	closeDate := self.filtCloseDate;
	if self.filtLocationType = self.LocationType_LC then
		self.myFiltProduct.getSOHLevelsForDateLocation(self.myFiltLC,
										closeDate, 
										true, 
										closeQty, 
										closeVol, 
										closeWeight);
	
	elseif self.filtLocationType = self.LocationType_TA then
		self.myFiltProduct.getSOHLevelsForDateTA(self.myFiltTA,
										closeDate, 
										true, 
										closeQty, 
										closeVol, 
										closeWeight);
	
	
	elseif self.filtLocationType = self.LocationType_Terminal then
		self.myFiltProduct.getSOHLevelsForDateTerminal(self.myFiltTerminal,
										closeDate, 
										true, 
										closeQty, 
										closeVol, 
										closeWeight);
										
	elseif self.filtLocationType = self.LocationType_Voyage then
		self.myFiltProduct.getSOHLevelsForDateVoyage(self.myFiltVoyage,
										closeDate, 
										true, 
										closeQty, 
										closeVol, 
										closeWeight);										
	
	endif;
	closeStr := 'Calculated Closing Level' &amp; Tab &amp; Tab &amp; Tab &amp;
				_totQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				_totVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				_totWeight.asStringWeightJMT();
	
	idx := tblData.addItem(closeStr);
	
	if closeQty &lt;&gt; _totQty or
	   closeVol &lt;&gt; _totVol or
	   closeWeight &lt;&gt; _totWeight then
		tblData.accessRow(idx).backColor := self.ColorRedWarning;
	else
		tblData.accessRow(idx).backColor := self.colorRow1;
	endif;

	closeStr := 'Actual Closing Level' &amp; Tab &amp; Tab &amp; Tab &amp;
				closeQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				closeVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				closeWeight.asStringWeightJMT(); // cnwrd1 par 20165 ++ 1.7.09
				//closeWeight.String;	
	
	idx := tblData.addItem(closeStr);

	if closeQty &lt;&gt; _totQty or
	   closeVol &lt;&gt; _totVol or
	   closeWeight &lt;&gt; _totWeight then
		tblData.accessRow(idx).backColor := self.ColorRedWarning;
	else
		tblData.accessRow(idx).backColor := self.ColourYellowLight;
	endif;
end;</source>
        <Parameter name="_totQty" type="Integer"/>
        <Parameter name="_totVol" type="Decimal"/>
        <Parameter name="_totWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="outputOpeningLevelsForDate" id="5b669b3f-ce97-4b15-962e-5c689acdb06b">
        <source>outputOpeningLevelsForDate(_totQty : Integer output;
							_totVol : Decimal output;
							_totWeight : Decimal output);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	openDate			: Date;
	openQty				: Integer;
	openWeight			: Decimal[14,4];
	openVol				: Decimal[16,4];
	openStr				: String;
	idx					: Integer;
begin	
	openDate := self.filtOpenDate;

	if self.filtLocationType = LocationType_LC then
		self.myFiltLC.getSOHLevelsForDate(openDate, false, openQty, openVol, openWeight);
	elseif self.filtLocationType = LocationType_TA then
		self.myFiltTA.getSOHLevelsForDate(openDate, false, openQty, openVol, openWeight);
	elseif self.filtLocationType = LocationType_Terminal then
		self.myFiltTerminal.getSOHLevelsForDate(openDate, false, openQty, openVol, openWeight);
	elseif self.filtLocationType = LocationType_Voyage then
		self.myFiltVoyage.getSOHLevelsForDate(openDate, false, openQty, openVol, openWeight);		
	endif;

	//init totals to the opening levels
	_totQty := openQty;
	_totVol := openVol;
	_totWeight := openWeight;
	
	openStr := 'Opening Stock' &amp; Tab &amp; Tab &amp; Tab &amp;
			openQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
			openVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
			openWeight.asStringWeightJMT(); // cnwrd1 par 20165 ++ 1.7.09
			//openWeight.String; // cnwrd1 par 20165 -- 1.7.09

	idx := tblData.addItem(openStr);
	tblData.accessRow(idx).backColor := self.colorRow1;
end;</source>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="outputOpeningLevelsForProduct" id="84bba40a-4bbb-4c92-a4b9-22d13430af26">
        <source>outputOpeningLevelsForProduct(_totQty   :Integer output;
							_totVol		: Decimal output;
							_totWeight  : Decimal output);
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	openStr		: String;
	today,
	openDate		: Date;
	openQty			: Integer;
	openVol			: Decimal[16,4];
	openWeight		: Decimal[14,4];	
	sohLocn			: CM_SOHLocation;
	idx				: Integer;
begin

	if self.myFiltProduct = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), ETRow_Product, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), ETRow_Product, null); // cnwdb2	PAR 35364
		return;
	endif;

	openDate := self.filtOpenDate;
	if self.filtLocationType = self.LocationType_LC then
		self.myFiltProduct.getSOHLevelsForDateLocation(self.myFiltLC,
										openDate, 
										false, 
										openQty, 
										openVol, 
										openWeight);
	
	elseif self.filtLocationType = self.LocationType_TA then
		self.myFiltProduct.getSOHLevelsForDateTA(self.myFiltTA,
										openDate, 
										false, 
										openQty, 
										openVol, 
										openWeight);
	
	elseif self.filtLocationType = self.LocationType_Terminal then
		self.myFiltProduct.getSOHLevelsForDateTerminal(self.myFiltTerminal,
										openDate, 
										false, 
										openQty, 
										openVol, 
										openWeight);
										
	elseif self.filtLocationType = self.LocationType_Voyage then
		self.myFiltProduct.getSOHLevelsForDateVoyage(self.myFiltVoyage,
										openDate, 
										false, 
										openQty, 
										openVol, 
										openWeight);

	endif;
	
	//init totals to the opening levels
	_totQty := openQty;
	_totVol := openVol;
	_totWeight := openWeight;

	openStr := 'Opening Stock' &amp; Tab &amp; Tab &amp; Tab &amp;
				openQty.String &amp; Tab &amp; Tab &amp; Tab &amp;
				openVol.jasVolumeString &amp; Tab &amp; Tab &amp; Tab &amp;
				//openWeight.String;//par 15590 // cnwrd1 par 20165 ++ 1.7.09
				openWeight.asStringWeightJMT(); // cnwrd1 par 20165 ++ 1.7.09
				
	tblData.addItem(openStr);
	
end;</source>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="outputRow" id="703f36ba-83a8-499d-bcd6-5b00aaedbfde">
        <source>outputRow(_type : String; _moveHelper : CMIF_StockMoveHelper; _idx : Integer);
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	moveDtl	: CMIF_StockMoveDtl;
	rowIdx	: Integer;

begin

	moveDtl := _moveHelper.allStockMoveDtls[_idx];
	if moveDtl = null then
		return;
	endif;

	rowIdx := self.tblData.addItem(_type &amp; Tab &amp; moveDtl.getDisplayStr());
	self.tblData.accessRow(rowIdx).itemObject := moveDtl;

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_moveHelper" type="CMIF_StockMoveHelper"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="outputSOHLocations" id="6392bd51-aec9-480e-ae55-e12db709e128">
        <source>outputSOHLocations(_sohLocnSet : CM_SOHLocationSet);
//--------------------------------------------------------------
//Created: 08 October 2002 By: cnwgd1
//--------------------------------------------------------------
/*
	Date    Who		Reason
8 sep 20088	cnwdz2	Par17850 - Stock movements by voyage should be sorted before shown on screen.
*/
vars
	firstTime			: Boolean;
	sohLocn				: CM_SOHLocation;
	stockMoveDict		: CM_StockMoveBucketsByDate;
	bucket				: CM_StockMoveBucket;
	iter				: Iterator;
	rowIdx				: Integer;
	rowMoveHelper,
	totalMoveHelper		: CMIF_StockMoveHelper;		
	passport			: CM_Passport;
	failedDAC  			: CM_DataAccessController;
	dict				: DynaDictionary; // 8 sep 20088 cnwdz2	Par17850
	
begin
	
	if _sohLocnSet = null or _sohLocnSet.size &lt; 1 then
		return;
	endif;
	
	create totalMoveHelper transient;
	
	if self.queryType = QueryType_StkMoveByProduct then
		self.outputOpeningLevelsForProduct(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);	
	elseif self.queryType = QueryType_StkMoveByLocation then
		self.outputOpeningLevelsForDate(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	else
		return;
	endif;

	self.allStockMoveHelpers.purge();
	create rowMoveHelper transient;
	self.allStockMoveHelpers.add(rowMoveHelper);	
	
	passport := app.myPassport;	

	firstTime := true;
	
	foreach sohLocn in _sohLocnSet do
		if self.queryType = self.QueryType_StkMoveByProduct then
			if sohLocn.myProduct.myCargoType &lt;&gt; self.myFiltCargoType then
				continue;
			endif;
		   if self.myFiltProduct &lt;&gt; null then
				if sohLocn.myProduct &lt;&gt; self.myFiltProduct then
					continue;
				endif;
			endif;
		endif;
		
		if not sohLocn.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		stockMoveDict := sohLocn.allStockMovementsByDate;
		iter := stockMoveDict.createIterator;		
		stockMoveDict.startKeyGeq(self.filtOpenDate, iter);
		while iter.next(bucket) do
			if bucket.date &gt; self.filtCloseDate then
				break;
			endif;
			if firstTime then
				rowMoveHelper.date := bucket.date;
				firstTime := false;
			endif;
			if self.filtShowDetail then
				rowMoveHelper := self.getRowMoveHelperForDate(bucket.date);
				if rowMoveHelper = null then
					create rowMoveHelper transient;
					rowMoveHelper.date := bucket.date;
					self.allStockMoveHelpers.add(rowMoveHelper);			
				endif;
			endif;
			rowMoveHelper.totalQuantities(bucket);
			totalMoveHelper.totQty 		:= totalMoveHelper.totQty + bucket.adjustQuantity.Integer;
			totalMoveHelper.totVol 		:= totalMoveHelper.totVol + bucket.adjustVolume.Decimal;
			totalMoveHelper.totWeight 	:= totalMoveHelper.totWeight + bucket.adjustWeightKgs.Integer;
		endwhile;		
		delete iter;
	endforeach;	
	
	
	create dict transient; // 8 sep 20088 cnwdz2	Par17850
	dict.setMembership(CMIF_StockMoveHelper);// 8 sep 20088 cnwdz2	Par17850
	dict.addMemberKey(CMIF_StockMoveHelper::date.name, false, true);// 8 sep 20088 cnwdz2	Par17850
	dict.endKeys(false);// 8 sep 20088 cnwdz2	Par17850
	
	self.allStockMoveHelpers.copy(dict);// 8 sep 20088 cnwdz2	Par17850
	
//	foreach rowMoveHelper in self.allStockMoveHelpers do // 8 sep 20088 cnwdz2	Par17850
	delete iter;// 8 sep 20088 cnwdz2	Par17850
	iter := dict.createIterator; // 8 sep 20088 cnwdz2	Par17850
	while iter.next(rowMoveHelper) do // 8 sep 20088 cnwdz2	Par17850
		if self.filtShowDetail then
			rowIdx := self.tblData.addItem(rowMoveHelper.date.String);
			self.tblData.accessRow(rowIdx).backColor := self.colorRow2;
			tblData.accessRow(rowIdx).itemObject := rowMoveHelper;
		endif;
		self.outputRow('Receivals/Releases', rowMoveHelper, 1);
		self.outputRow('Reject', rowMoveHelper, 2);
		self.outputRow('Operator Change', rowMoveHelper, 3);
		self.outputRow(app.getErrorString(Product) &amp; ' Change', rowMoveHelper, 4);
		self.outputRow('Update Change', rowMoveHelper, 5);
		self.outputRow('Reassembly', rowMoveHelper, 6);
		self.outputRow('Fixup', rowMoveHelper, 7);						
	endwhile;

	if self.queryType = QueryType_StkMoveByProduct then	
		self.outputCloseLevelsForProduct(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	else
		self.outputCloseLevelsForDate(totalMoveHelper.totQty, totalMoveHelper.totVol, totalMoveHelper.totWeight);
	endif;
	
epilog
	delete iter;
	delete totalMoveHelper;
	delete dict; // 8 sep 20088 cnwdz2	Par17850
	
end;</source>
        <Parameter name="_sohLocnSet" type="CM_SOHLocationSet"/>
    </JadeMethod>
    <JadeMethod name="queryContainer" id="9ace6fcf-89b8-48b7-b565-16fcde000cfa">
        <source>queryContainer();
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	today,
	openDate,
	closeDate		: Date;
	opDict 			: CM_OperatorByCodeDict;
	bolDict			: CM_BOLByTypeNumberDTDict;
	op				: CM_Operator;
	opTerm			: CM_OperatorTerminal;
	iter			: Iterator;
	bol				: CM_BOL;
	bolOut			: CM_BOLOut;
	firstBOL		: Boolean;
	contsInDate,
	conts,
	teus,
	tot20ftInDate,
	tot40ftInDate,
	tot20ft,
	tot40ft			: Real;
	isoStr			: String;
	isoType			: CM_ISOType;
	
begin
	openDate := self.filtOpenDate;
	closeDate := self.filtCloseDate;
	
	opDict := app.myRoot.allOperators;
	foreach op in opDict do
		opTerm := op.getOperatorTerminal(self.myTerminal, false);
		if opTerm = null then
			continue;
		endif;
		//reset counters
		contsInDate := 0;
		conts := 0;
		teus := 0;
		tot20ftInDate := 0;
		tot40ftInDate := 0;
		tot20ft := 0;
		tot40ft := 0;
		//delete previous iterator
		if iter &lt;&gt; null then
			delete iter;
		endif;
		
		bolDict := opTerm.allBOLByTypeNumber;
		iter := bolDict.createIterator;
		bolDict.startKeyGeq(BOLType_GeneralDocket, null, null, iter);
		
		while iter.next(bol) do
			if bol.isKindOf(CM_BOLOut) then
				bolOut := bol.CM_BOLOut;
				isoStr := bolOut.myExtension.CM_BOLExtWarehouse.isoType;
				isoType := app.myRoot.allISOTypes[isoStr];
				if bolOut.dateTime.date.year = today.year then
					
					if isoType &lt;&gt; null then
						conts := conts +1;
						if isoType.is20ftLong then
							tot20ft := tot20ft + 1;					
						elseif isoType.is40ftLong or isoType.is45ftLong then
							tot40ft := tot40ft + 1;
						endif;
						
						if (bolOut.dateTime.date &gt;= openDate) and
							(bolOut.dateTime.date &lt;= closeDate) then
							contsInDate := contsInDate + 1;
							if isoType.is20ftLong then
								tot20ftInDate := tot20ftInDate + 1;					
							elseif isoType.is40ftLong or isoType.is45ftLong then
								tot40ftInDate := tot40ftInDate + 1;
							endif;						
						endif;
						
					endif;														
				endif;
			endif;
		endwhile;
		//output the info for this operator
		tblData.addItem(op.code &amp; '  ' &amp; op.description &amp; Tab &amp;
						'20ft' &amp; Tab &amp;
						tot20ftInDate.String &amp; Tab &amp;
						tot20ft.String);
		tblData.addItem(null.String &amp; Tab &amp;
						'40ft' &amp; Tab &amp;
						tot40ftInDate.String &amp; Tab &amp;
						tot40ft.String);
		tblData.addItem(null.String &amp; Tab &amp;
						'CONT' &amp; Tab &amp;
						contsInDate.String &amp; Tab &amp;
						conts.String);
			
		tblData.addItem(null.String &amp; Tab &amp;
						'TEUS' &amp; Tab &amp;
						(tot20ftInDate + (tot40ftInDate * 2)).String &amp; Tab &amp;
						(tot20ft + (tot40ft * 2)).String);
	endforeach;	

epilog
	delete iter;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="queryLCByDate" id="72c4e500-a968-4da4-acc0-ce1a6d293fd3">
        <updating/>
        <source>queryLCByDate() updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2002 by cnwth2
//
// Purpose:     
//
