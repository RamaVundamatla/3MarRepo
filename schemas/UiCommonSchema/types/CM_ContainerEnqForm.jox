    <JadeMethod name="mnuDABooking_click" id="8159826f-af71-4e6b-b647-dc717552b719">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDABooking_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2016	cnwndl1	Initial creation	TFS 2419

*/

vars

	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	ti : CM_TrackedItem;
	docAction : CM_DocumentActions;
	maintForm : CMUI_DocumentActionMaint;

begin

	create resDetailSet transient;
	create bookingItemSet transient;
	
	ti := menuItem.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	ti.hasDocumentActions( resDetailSet, bookingItemSet );
	
	if not bookingItemSet.isEmpty then
		docAction := bookingItemSet.first.myBookingRefItemActions;
	endif;
	
	if docAction &lt;&gt; null then
		maintForm := app.loadForm(CMUI_DocumentActionMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DocumentActionMaint;
		if maintForm &lt;&gt; null then
			maintForm.setMyDocumentAction( docAction );
			maintForm.showModal();
		endif;
	endif;
	
epilog

	delete resDetailSet;
	delete bookingItemSet;
	delete maintForm;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuDAReserve_click" id="5c2d83ac-258b-47c2-817d-eb21709f8c7f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDAReserve_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2016	cnwndl1	Initial creation	TFS 2419

*/

vars

	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	ti : CM_TrackedItem;
	docAction : CM_DocumentActions;
	maintForm : CMUI_DocumentActionMaint;

begin

	create resDetailSet transient;
	create bookingItemSet transient;
	
	ti := menuItem.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	ti.hasDocumentActions( resDetailSet, bookingItemSet );
	
	if not resDetailSet.isEmpty then
		docAction := resDetailSet.first.myReserveDetailActions;
	endif;
	
	if docAction &lt;&gt; null then
		maintForm := app.loadForm(CMUI_DocumentActionMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DocumentActionMaint;
		if maintForm &lt;&gt; null then
			maintForm.setMyDocumentAction( docAction );
			maintForm.showModal();
		endif;
	endif;
	
epilog

	delete resDetailSet;
	delete bookingItemSet;
	delete maintForm;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuDeleteCargoGroup_click" id="b4bc0350-c442-495c-af5c-aa745aef9208">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDeleteCargoGroup_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2018	jlgndl1	Initial creation	TFS 40120
13/11/2025	navcs2 MTN-36470 TPT - Delete Cargo Group
*/

vars

	cg : CM_CargoGroup;
	theReturn : Integer;
	cm_Object : CM_Object;

begin

	if menuItem.userObject = null or not menuItem.userObject.isKindOf(CM_CargoGroup) then
		return;
	endif;
	
	cg := menuItem.userObject.CM_CargoGroup;
	
	if app.msgBox(app.getErrorString(Sure_that_want_delete) &amp; app.getErrorString(CargoGroup) &amp;  Colon &amp; Space &amp; cg.id, 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then		// 13/11/2025	navcs2 MTN-36470
		return;																																										// 13/11/2025	navcs2 MTN-36470
	endif;																																											// 13/11/2025	navcs2 MTN-36470
	
	while true do
	
		cm_Object := cg;	
		
		app.myTrxDA.trxDeleteCMObject( cm_Object, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
			
		endif;
		
		break;
	
	endwhile;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
