	// 05/10/2016 cnwma1 TFS #2712
	//13/12/2016 cnwma1	 TFS #2801
	self.setPicSettingsScrollRange(theForm.chkUseCodecoNonStruc, self.chkVERMASNAD);  // jlgka1 TFS 41641 // jlgka1 TFS 43785
	
																								//+TFS7781 Starts				
