    <JadeMethod name="addItemObject" id="0a8484bf-a7dc-417c-80cd-d27b70d00f0b">
        <updating/>
        <source>addItemObject(_str : String; _obj : Object) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;

begin

	idx := self.addItem(Tab &amp; _str);
	if _obj &lt;&gt; null then
		self.accessRow(idx).itemObject := _obj;
	endif;
	
	return idx;

end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSelectedObject" id="4d12ddcc-488c-4caf-a7ac-0c8ccb466431">
        <updating/>
        <source>addSelectedObject(_obj : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin
	if _obj = null then
		return;
	endif;
	if (not self.allSelectedObjects.includes(_obj)) then
		self.allSelectedObjects.add(_obj);
		if self.findObjectInRow(_obj, idx) then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="adjustColumns" id="974ef51f-af64-4327-8e89-78f9dcfee536">
        <updating/>
        <source>adjustColumns() updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling - add Packing Group column
vars
	colWidth	: Integer;
begin

	self.accessColumn(1).width	:= 25;
	self.accessColumn(2).width	:= 35;
	//self.accessColumn(5).width := 45;		// PAR #36421
	self.accessColumn(5).width	:= 25;		// PAR #36421
	self.accessColumn(6).width	:= 35;		// PAR #36421
	
	//colWidth	:= (((self.width - (self.accessColumn(1).width + self.accessColumn(2).width + self.accessColumn(5).width) ))/2).Integer-8; 									// PAR #36421
	colWidth	:= (((self.width - (self.accessColumn(1).width + self.accessColumn(2).width + self.accessColumn(5).width + self.accessColumn(6).width) ))/2).Integer-8; 	// PAR #36421
	
	self.accessColumn(3).width	:= colWidth +(colWidth/3).Integer;
	self.accessColumn(4).width	:= colWidth -(colWidth/3).Integer;

end;</source>
    </JadeMethod>
    <JadeMethod name="change" id="d0e5df1c-c31b-4b1c-88ca-4a9f8cb47bad">
        <updating/>
        <source>change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	theForm : Form;
begin

	inheritMethod(table);
	
	if table.row &gt; 0 and table.row &lt;= table.rows then
		obj := table.accessRow(table.row).itemObject;
		if self.rowChecked(table.row) then
			if (not self.allSelectedObjects.includes(obj)) then
				self.allSelectedObjects.add(obj);
				if self.form.respondsTo(IF_TIHazardListTableControl) then
					self.form.IF_TIHazardListTableControl.addSelectedTIHazard(obj.CM_TIHazard);
				endif;
			endif;
		else
			if self.allSelectedObjects.includes(obj) then
				self.allSelectedObjects.remove(obj);
				if self.form.respondsTo(IF_TIHazardListTableControl) then
					self.form.IF_TIHazardListTableControl.removeSelectedTIHazard(obj.CM_TIHazard);
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkBoxFirst" id="a4e07fdb-9828-4049-bb38-00aa32e436d3">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>chkBoxFirst(set: Boolean; _value: Boolean io) updating, mapping, protected;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value then
			self.chkBoxColumn 	:= 1;
		else
			self.chkBoxColumn 	:= self.columns;
		endif;
	else
		_value := (self.chkBoxColumn = 1);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="482aa5d2-60ba-4f5f-b9a0-2729b2f7758d">
        <updating/>
        <source>clearSelected() updating;

vars
	maxRows,
	theFirstRow,
	idx,
	chkCol, txtCol,limitedQuantCol	: Integer;
	tblHaz	: CM_TIHazard;
begin

	self.allSelectedObjects.clear;
	chkCol := self.chkBoxColumn;
	txtCol := self.textInputColumn;
	limitedQuantCol := 5;
	maxRows := self.rows;
	theFirstRow := self.fixedRows + 1;
	foreach idx in theFirstRow to maxRows do
		tblHaz := self.accessRow(idx).itemObject.CM_TIHazard;
		if tblHaz &lt;&gt; null then
			tblHaz.setUNDGCodes(null);
			tblHaz.setLimitedQuantity(false);
		endif;
		self.accessCell(idx, chkCol).text := TableCheckBox_NotSelected;
		self.accessCell(idx, txtCol).text := "";
		self.accessCell(idx, limitedQuantCol).text := TableCheckBox_NotSelected;
	endforeach;
	
	if maxRows &gt;= theFirstRow then
		self.row := theFirstRow;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="d93d0d05-78d8-48f8-a244-b07819514726">
        <updating/>
        <source>click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cell	: JadeTableCell;
	unSelect, select :Boolean;
begin

	if table.userInputEnabled and (table.row &gt; table.fixedRows and table.row &lt;= table.rows) then
		self.highlightRow(self.row);
		unSelect := false;
		if self.doManually then
			// the click occured in column 2 so we will need to
			// change the value of the checkbox manually
			cell := table.accessCell(table.row, self.chkBoxColumn);
			if cell.text = TableCheckBox_NotSelected then
				cell.text := TableCheckBox_Selected;
			else
				cell.text := TableCheckBox_NotSelected;
				unSelect := true;
			endif;
			
			//check for the other checkBox and deselect it if selected.
			cell := table.accessCell(table.row, 5);
			if unSelect and cell.text = TableCheckBox_Selected then
				cell.text := TableCheckBox_NotSelected;
			endif;
		elseif table.column = self.chkBoxColumn then
			cell := table.accessCell(table.row, self.chkBoxColumn);
			if cell.text = TableCheckBox_NotSelected then
				unSelect := true;
			endif;
			cell := table.accessCell(table.row, 5);
			if unSelect and cell.text = TableCheckBox_Selected then
				cell.text := TableCheckBox_NotSelected;
			endif;
		elseif table.column = 5 then
			cell := table.accessCell(table.row, 5);
			if cell.text = TableCheckBox_Selected then
				select := true;
			endif;
			cell := table.accessCell(table.row, self.chkBoxColumn);
			if select and cell.text = TableCheckBox_NotSelected then
				cell.text := TableCheckBox_Selected;
			endif;
		endif;
		self.doManually := false;
		table.change(table);
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneAllSelectedObjects" id="37ac8263-7ca6-406d-95e1-6cc9c6bc2e34">
        <source>cloneAllSelectedObjects(_coll :CM_HazardByCodeDict input);
// adm 290610 Par 24552
vars
	obj	: Object;
begin
	foreach obj in allSelectedObjects do
		_coll.add(obj.copySelf(true).CM_Hazard);
	endforeach;
end;
</source>
        <Parameter name="_coll" type="CM_HazardByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="eda53d99-3111-4f1c-bc05-262510869a2e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling - add Packing Group column
// ---------------------------------------------------------------------------
vars

begin

	
	self.rows 		:= 1;
	self.fixedRows 	:= 1;
	
	//self.columns 	:= 5;						// PAR #36421
	self.columns 	:= 6;						// PAR #36421
	self.fixedColumns := 0;

	self.chkBoxFirst := true;
	//self.textInputColumn := self.columns-1;	// PAR #36421
	self.textInputColumn := self.columns-2;		// PAR #36421
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="0d11e3e2-233d-4e82-8e49-cb75c111d951">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	02 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	self.allRowTransients.purge();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="findObject" id="9463460e-454a-4d55-b458-e71cd30639f9">
        <updating/>
        <source>findObject(_obj : Object; _rowIdx : Integer io) : Boolean updating;
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin

	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="eeddd959-4724-466d-a7ac-80f25fa71b15">
        <updating/>
        <source>findObjectInRow(_obj : Object; _rowIdx : Integer io) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedString" id="21a61597-1c3c-4d42-ac96-179f8c74e6d0">
        <source>getSelectedString() : String;
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	str	: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		if self.useAnyStringWhenNonSelected then
			str := "";
			//cnwjo3 par 20644, why Any?  Commented out
			//str := Any_String;
		endif;
	else
		foreach obj in self.allSelectedObjects do
			if str &lt;&gt; null then
				str := str &amp; '; ';
			endif;
			
			str := str &amp; obj.CM_TIHazard.getTableDisplay(false, true);
		endforeach;
	endif;

	return str;
			
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStringArray" id="d9f9234e-d7d1-4695-b243-ffbdb0e9025a">
        <updating/>
        <source>getSelectedStringArray(_allHazards : StringArray input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
30/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	obj	: Object;
	str	: String;
begin
	if self.allSelectedObjects.size = 0 then
		return;
	else
		foreach obj in self.allSelectedObjects do			
			str := obj.CM_TIHazard.getTableDisplay(false, true);
			_allHazards.add(str);
		endforeach;
	endif;
end;</source>
        <Parameter name="_allHazards" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStringXML" id="9d5e1371-4664-41ff-b9b0-5a3cf6b759de">
        <source>getSelectedStringXML(_attrName, _tag : String) : String protected;

// cnwdvb1 20 March 2003 

vars
	obj	: Object;
	tmp,
	str	: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		str := Any_String;
	else
		foreach obj in self.allSelectedObjects do
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			tmp := obj.getPropertyValue(_attrName).String;
			str := str &amp; tmp.cnEcGetTagValueOfName(_tag);
		endforeach;
	endif;
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextInput" id="2068665a-4b31-48a5-9a41-4faa8116fb16">
        <updating/>
        <source>getTextInput(_obj: Object): String updating, protected;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx	: Integer;
	str	: String;
begin
	idx := self.fixedRows;
	
	if self.findObject(_obj, idx) then
		str := self.accessCell(idx, self.textInputColumn).text;
	endif;
	
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="18ec7213-398f-48dd-97ba-e047ead06f23">
        <source>getXMLStringForSelected(_attrNames : StringArray) : String protected;
// -------------------------------------------
// Created 18 February 2004 by cnwdvb1
// -------------------------------------------
vars

	obj	: Object;
	str,
	tmp,
	attrName	: String;

begin

	if not self.allSelectedObjects.isEmpty then
		str := self.formatAsXMLPrefix(XMLTag_ListTable &amp; self.name);
		foreach obj in self.allSelectedObjects do
			tmp := null;
			foreach attrName in _attrNames do
				if tmp &lt;&gt; null then
					tmp := tmp &amp; ',';
				endif;
				tmp := tmp &amp; obj.getPropertyValue(attrName).String;
			endforeach;
			str := str &amp;  global.formatAsXML(XMLTag_SelectedValue, tmp);
		endforeach;
		str := str &amp; self.formatAsXMLSuffix(XMLTag_ListTable &amp; self.name);
	endif;
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_attrNames" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="highlightRow" id="4d280e8c-f14f-4f34-ab23-9acd2d60fe09">
        <updating/>
        <source>highlightRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		self.accessRow(pRow).selected := true;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertRow" id="728015ac-e02e-43da-939d-12511d45c9f6">
        <updating/>
        <source>insertRow(hazClass : CM_HazardClass; idx : Integer io) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 23 May 2019
TFS#		: 43346
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	tmpTIHazard	: CM_TIHazard;	
begin
	create tmpTIHazard transient;
	tmpTIHazard.setFromHazardClass(hazClass);
	idx := self.addItem(tmpTIHazard.getDisplayStringForListTable());
	
	self.accessRow(idx).itemObject := tmpTIHazard;
	
	if hazClass.isNotAvailableForEntry then 
		self.accessRow(idx).visible := false;		
	endif; 		
	
	self.allRowTransients.add(tmpTIHazard);
end;</source>
        <Parameter name="hazClass" type="CM_HazardClass"/>
        <Parameter name="idx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="5ac22d9e-2fb4-40a5-b78c-9754f2ca7e5f">
        <updating/>
        <source>keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	col : Integer;
	cell : JadeTableCell;
begin
	
	if table.column = 5 and keyCode = 32 then					//+cnwml2 PAR19884 SFW CCMS 1079
		self.click(table);										//+cnwml2 PAR19884 SFW CCMS 1079
	elseif table.column &lt;&gt; self.textInputColumn 				//+cnwml2 PAR19884 SFW CCMS 1079
	//if table.column &lt;&gt; self.textInputColumn					//-cnwml2 PAR19884 SFW CCMS 1079
	//or (keyCode &gt;= 37 and keyCode &lt;= 47) then
	or (keyCode &lt;= 47) then
		//arrow keys and space bar
		return;
	
	endif;	
	//if 
	//we are
	col	:= self.chkBoxColumn;
	table.accessCell(table.row, col).text := TableCheckBox_Selected;

epilog
	inheritMethod(table, keyCode, shift);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadHazardObjects" id="3a391dfb-5cf4-464a-9f81-a08d2509ac51">
        <updating/>
        <source>loadHazardObjects() updating;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling - add Packing Group column
vars
	tmpTIHazard	: CM_TIHazard;
	hazClass	: CM_HazardClass;
	idx			: Integer;
begin
	
	self.rows := 1;
	self.fixedRows := 1;
	self.accessCell(1,1).inputType := InputType_None;
	//self.accessedCell.text := "Incl." &amp; Tab &amp; "Code" &amp; Tab &amp; "Description" &amp; Tab &amp; "UNDG Numbers" &amp; Tab &amp;"Ltd Qty";				// PAR #36421
	self.accessedCell.text := "Incl." &amp; Tab &amp; "Code" &amp; Tab &amp; "Description" &amp; Tab &amp; "UNDG Numbers" &amp; Tab &amp; "Ltd" &amp; Tab &amp; "Packing";	// PAR #36421
	foreach hazClass in app.myRoot.allHazardClasses do
		create tmpTIHazard transient;
		tmpTIHazard.setFromHazardClass(hazClass);
		idx := self.addItem(tmpTIHazard.getDisplayStringForListTable());
		
		self.accessRow(idx).itemObject := tmpTIHazard;
		
		if hazClass.isNotAvailableForEntry then 
			self.accessRow(idx).visible := false;		
		endif; 		
		
		self.allRowTransients.add(tmpTIHazard);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="8cdde120-18e9-4b2a-98df-9796d0091156">
        <updating/>
        <source>lostFocus(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.queryRowColChg(self, self.sheet, self.row, self.column);

	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="aa9e957e-f91c-476f-8055-e746b7d5fc0d">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(table, button, shift, x, y);

	self.highlightRow(self.row);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="9993540f-774a-43ff-9917-0a5f140c3071">
        <updating/>
        <source>queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer): Boolean updating;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
vars
	rowSelected	: Boolean;
	undgs		: String;
	hazObj		: CM_TIHazard;
begin

	if table.row &gt; table.fixedRows then
		hazObj	:= table.accessRow(table.row).itemObject.CM_TIHazard;
		
		undgs := table.accessCell(table.row, self.textInputColumn).text;
	
		hazObj.setUNDGCodes(undgs);
		if table.accessCell(table.row, 5).text = '1' then
			hazObj.setLimitedQuantity(true);
		else
			hazObj.setLimitedQuantity(false);
		endif;
		hazObj.setPackingGroup(table.accessCell(table.row, 6).text);		// PAR #36421
	endif;
	
	return inheritMethod(table, newSheet, newRow, newCol);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowChecked" id="80067314-51b4-47aa-b0dc-efa92d34afe5">
        <updating/>
        <source>rowChecked(pRow : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_Selected then
			return true;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="e03b9ed6-bf46-4be3-803f-42c22a207fec">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(table);
	
	//+cnwml2 PAR19884 SFW CCMS 1079 start
	if table.column = self.textInputColumn then
		self.doManually := false;
	elseif table.column = 2 then
		table.column := self.textInputColumn;
		self.doManually := true;
	elseif table.column = 3 then
		table.column := self.chkBoxColumn;
		self.doManually := true;
	else
		self.doManually := false;
	endif;
	//+cnwml2 PAR19884 SFW CCMS 1079 end
	
	//-cnwml2 PAR19884 SFW CCMS 1079 start
	/*if table.column = self.textInputColumn then
		self.doManually := false;
	elseif table.column &lt;&gt; self.chkBoxColumn and table.column &lt;&gt; 5 then
		// always set the column to the checkBox column so that the
		// spacebar can be used to set/unset the checkbox.
		table.column := self.chkBoxColumn;
		self.doManually := true;
	else
		self.doManually := false;
	endif;*/
	//-cnwml2 PAR19884 SFW CCMS 1079 end
	
	self.highlightRow(self.row);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAllToFalse" id="59489fe0-97bb-49dc-af07-c11769ae2021">
        <updating/>
        <source>setAllToFalse()updating ;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 2 then
		return;
	endif;
	
	objArray := self.allSelectedObjects;
	foreach idx in 2 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		obj := self.accessRow(idx).itemObject;
		if (objArray.includes(obj)) then
			objArray.remove(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToTrue" id="85cf1129-bd7a-4564-a69d-2b9066e82077">
        <updating/>
        <source>setAllToTrue()updating ;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 2 then
		return;
	endif;
	
	objArray := self.allSelectedObjects;
	foreach idx in 2 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		obj := self.accessRow(idx).itemObject;
		if (not objArray.includes(obj)) then
			objArray.add(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSelected" id="237a8419-b384-497e-8f20-be111cf3cc4c">
        <updating/>
        <source>setSelected(_objs : Collection) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     Copies the collection passed in into the allSelectedObjects and
//				sets the "checked" flag on the table.
//
// Parameters:  None
//
// Returns:     The selected string.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	max		: Integer;

begin
 
	self.allSelectedObjects.clear;
	
	if _objs &lt;&gt; null then
		_objs.copy(self.allSelectedObjects);
	endif;
	
	max := self.rows;
	
	foreach idx in 1 to max do
		if self.allSelectedObjects.includes(self.accessRow(idx).itemObject) then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		else
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		endif;
	endforeach;

end;</source>
        <Parameter name="_objs" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setSelectedFromObject" id="75cbcbff-8ba6-4d7b-aa72-50659527e302">
        <updating/>
        <source>setSelectedFromObject(_obj: Object) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
08/07/2015	cnwdap1	PAR #36421 	Hazardous Materials Handling
30/11/2016	cnwdap1	TFS 3058 	Extra hazard attributes
23/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
============================================================================*/
vars
	tblHaz		 : CM_TIHazard;
	tiHaz		 : CM_TIHazard;
	intRow		 : Integer;
	theDict		 : CM_HazardByCodeDict;
	blnDeleteDict,
	limitQ		 : Boolean;
	select		 : Character;
	packing		 : String;						// PAR #36421
	//jlgka1 TFS 43346 --&gt;
	count		 : Integer;  					
	hazard		 : CM_Hazard; 					
	hazardDict 	 : CM_HazardClassByCodeDict;		
	newRow		 : Integer;
	lstProcessed : StringArray;
	//jlgka1 TFS 43346 &lt;--
begin 
	
	if CMIF_InOutAttachment.hasInstance(_obj) then
		theDict := _obj.CMIF_InOutAttachment.allTIHazards;
	elseif CM_BookingRef.hasInstance(_obj) then
	//	create theDict transient;
	//	blnDeleteDict := true;
		//_obj.CM_BookingRef.getAllItemTIIHazards(theDict);
		theDict := _obj.CM_BookingRef.allTIHazards;
	elseif CMIF_BookingRef.hasInstance(_obj) then
		create theDict transient;
		blnDeleteDict := true;
		_obj.CMIF_BookingRef.allTIHazards.copy(theDict);
	elseif CMIF_BookingRefItem.hasInstance(_obj) then
		theDict := _obj.CMIF_BookingRefItem.allTIHazards;
	elseif CM_BookingRefItem.hasInstance(_obj) then
		theDict := _obj.CM_BookingRefItem.allTIHazards;
	// cnwjk3 sfw1035
	elseif CMGTE_Receival.hasInstance(_obj) then
		theDict := _obj.CMGTE_Receival.allTIHazards;
	elseif CMIF_PreNote.hasInstance(_obj) then
		theDict := _obj.CMIF_PreNote.allTIHazards;
	elseif _obj &lt;&gt; null then
		theDict := _obj.IF_CargoField.getAllTIHazards;
	endif;

	self.clearSelected();
	
	if theDict = null then
		return;
	endif;
	//jlgka1 TFS 43346 --&gt;
	create lstProcessed transient;
	hazardDict := app.myRoot.allHazardClasses;
	foreach intRow in self.fixedRows+1 to self.rows do
		tblHaz := self.accessRow(intRow).itemObject.CM_TIHazard;
		count  := 1;
		if theDict.includesKey(tblHaz.code) then			
			//set undgs
			if not lstProcessed.includes(tblHaz.code) then
				foreach hazard in theDict do				
					if hazard.code = tblHaz.code then
						if count &gt; 1 then								
							self.insertRow(hazardDict[tblHaz.code], newRow);
							tblHaz := self.accessRow(newRow).itemObject.CM_TIHazard;				
						endif;
						tiHaz := hazard.CM_TIHazard;
						self.allSelectedObjects.add(tblHaz);
						tblHaz.setUNDGCodes(tiHaz.allUNDGCodes.asCSV(false));
						select := TableCheckBox_Selected;
						limitQ := tiHaz.limitedQuantity;
						tblHaz.setLimitedQuantity(limitQ);
						packing := tiHaz.packingGroup;										// PAR #36421
						tblHaz.setPackingGroup(packing);									// PAR #36421
						tblHaz.setAcidsBases(tiHaz.acidsBases);								// TFS 3058
						tblHaz.setFlashpointTemperature(tiHaz.flashpointTemperature);		// TFS 3058
						tblHaz.setIsMarinePollutant(tiHaz.isMarinePollutant);				// TFS 3058
						self.accessCell(intRow, self.chkBoxColumn).text := select &amp; Tab &amp; tblHaz.code &amp; Tab &amp; tblHaz.description &amp; Tab &amp; tblHaz.getUndgCodesAsString(true) &amp; Tab &amp; limitQ.cnEcGetTableCheckBoxValue &amp; Tab &amp; packing;	// PAR #36421
						// if not avail for entry will be not visisble. If obj has in collection then should be able to edit. 
						self.accessRow(intRow).visible := true;	
						
						count := count + 1;
					endif;
				endforeach;
				lstProcessed.add(tblHaz.code);
			endif;
		endif;
	endforeach;
	//jlgka1 TFS 43346 &lt;--
epilog
	if blnDeleteDict then
		delete theDict;
	endif;
	delete lstProcessed;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setSelectedFromObjectRORO" id="8904d5f2-276a-44a0-b95b-e6c2e65b020d">
        <updating/>
        <source>setSelectedFromObjectRORO(_obj: Object) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
27/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
============================================================================*/
vars
	tblHaz		: CM_TIHazard;
	intRow		: Integer;
	theDict		: CM_HazardByCodeDict;
	blnDeleteDict,
	limitQ		: Boolean;
	select		: Character;
	//jlgka1 TFS 43346 --&gt;
	count		 : Integer;  					
	hazard		 : CM_Hazard; 					
	hazardDict 	 : CM_HazardClassByCodeDict;		
	newRow		 : Integer;
	lstProcessed : StringArray;
	//jlgka1 TFS 43346 &lt;--
begin
	if CM_ROROLocnDefn.hasInstance(_obj) then
		theDict := _obj.CM_ROROLocnDefn.allHazardsAllowed;
	endif;

	self.clearSelected();
	
	if theDict = null then
		return;
	endif;
	//jlgka1 TFS 43346 --&gt;
	create lstProcessed transient;
	hazardDict := app.myRoot.allHazardClasses;
	foreach intRow in self.fixedRows+1 to self.rows do
		tblHaz := self.accessRow(intRow).itemObject.CM_TIHazard;
		count  := 1;
		if theDict.includesKey(tblHaz.code) then
			//set undgs
			if not lstProcessed.includes(tblHaz.code) then
				foreach hazard in theDict do				
					if hazard.code = tblHaz.code then
						if count &gt; 1 then								
							self.insertRow(hazardDict[tblHaz.code], newRow);
							tblHaz := self.accessRow(newRow).itemObject.CM_TIHazard;				
						endif;
						self.allSelectedObjects.add(tblHaz);
						select := TableCheckBox_Selected;
						self.accessCell(intRow, self.chkBoxColumn).text := select &amp; Tab &amp; tblHaz.code &amp; Tab &amp; tblHaz.description &amp; Tab &amp; tblHaz.getUndgCodesAsString(true) &amp; Tab &amp; limitQ.cnEcGetTableCheckBoxValue;
						// if not avail for entry will be not visisble. If obj has in collection then should be able to edit. 
						self.accessRow(intRow).visible := true;	
						count := count + 1;
					endif;
				endforeach;
				lstProcessed.add(tblHaz.code);
			endif;			
		endif;
	endforeach;
	//jlgka1 TFS 43346 &lt;--
epilog
	if blnDeleteDict then
		delete theDict;
	endif;
	delete lstProcessed;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showOnlySelectedFromObjectRORO" id="8c2f33a7-03f5-47da-9d3a-ea62ea994eea">
        <updating/>
        <source>showOnlySelectedFromObjectRORO(_obj: Object) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
28/07/2011	cnwas3	CCMS 1035 	CargoSideView form. Initial creation
27/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
============================================================================*/


vars
	tblHaz		: CM_TIHazard;
	intRow		: Integer;
	theDict		: CM_HazardByCodeDict;
	blnDeleteDict,
	limitQ		: Boolean;
	select		: Character;
	//jlgka1 TFS 43346 --&gt;
	count		 : Integer;  					
	hazard		 : CM_Hazard; 					
	hazardDict 	 : CM_HazardClassByCodeDict;		
	newRow		 : Integer;
	lstProcessed : StringArray;
	//jlgka1 TFS 43346 &lt;--
begin
	if _obj.isKindOf(CM_ROROLocnDefn) then
		theDict := _obj.CM_ROROLocnDefn.allHazardsAllowed;
	endif;

	self.clearSelected();
	
	if theDict = null then
		foreach intRow in self.fixedRows+1 to self.rows do
			self.accessRow(intRow).visible := false;	
		endforeach;
		return;
	endif;
	//jlgka1 TFS 43346 --&gt;
	create lstProcessed transient;
	hazardDict := app.myRoot.allHazardClasses;	
	foreach intRow in self.fixedRows+1 to self.rows do
		tblHaz := self.accessRow(intRow).itemObject.CM_TIHazard;
		count  := 1;
		if theDict.includesKey(tblHaz.code) then
			//set undgs
			if not lstProcessed.includes(tblHaz.code) then
				foreach hazard in theDict do				
					if hazard.code = tblHaz.code then
						if count &gt; 1 then								
							self.insertRow(hazardDict[tblHaz.code], newRow);
							tblHaz := self.accessRow(newRow).itemObject.CM_TIHazard;				
						endif;
						self.allSelectedObjects.add(tblHaz);
						select := TableCheckBox_Selected;
						self.accessCell(intRow, self.chkBoxColumn).text := select &amp; Tab &amp; tblHaz.code &amp; Tab &amp; tblHaz.description &amp; Tab &amp; tblHaz.getUndgCodesAsString(true) &amp; Tab &amp; limitQ.cnEcGetTableCheckBoxValue;
						// if not avail for entry will be not visisble. If obj has in collection then should be able to edit. 
						self.accessRow(intRow).visible := true;	
						count := count + 1;
					endif;
				endforeach;
				lstProcessed.add(tblHaz.code);
			endif;			
		else
			self.accessRow(intRow).visible := false;	
		endif;
	endforeach;
	//jlgka1 TFS 43346 &lt;--
epilog
	if blnDeleteDict then
		delete theDict;
	endif;
	delete lstProcessed;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="486b9278-008e-41a8-83bc-3ad3e3ce2e50">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling - add Packing Group column
// ---------------------------------------------------------------------------
vars
	col	: JadeTableColumn;
	idx	: Integer;

begin

	inheritMethod(cntrl, persistCntrl);
	self.selectMode := SelectMode_Row;
	self.gridLines	:= true;
	self.gridColor	:= CM_BaseForm.Color_GrayText;
	//self.scrollBars	:= ScrollBars_Vertical;				//-cnwml2 PAR19884 SFW CCMS 1079
	self.scrollBars := ScrollBars_Both;						//+cnwml2 PAR19884 SFW CCMS 1079
//	self.autoSize	:= self.AutoSize_Column;
	self.fixed3D	:= false;
	//self.columns := 5;							// PAR #36421
	self.columns := 6;								// PAR #36421
	self.textInputColumn  :=4;
//	if self.columns &lt;= 1 then
//		self.columns := 5;
//	endif;
 
	foreach idx in 1 to self.columns do
		col := self.accessColumn(idx);
		if idx = self.chkBoxColumn or idx = 5 then
			// setup the checkbox column
			col.inputType := InputType_CheckBox;
		elseif idx = self.textInputColumn then
			// setup the UNDG column and the packing group column
			col.inputType := Table.InputType_TextBox;		
			col.backColor := CM_BaseForm.ColourYellowLight;
		elseif idx = self.columns then									// PAR #36421
			col.inputType := Table.InputType_ComboBox;					// PAR #36421
			col.comboList := "" &amp; Tab &amp; "I" &amp; Tab &amp; "II" &amp; Tab &amp; "III";	// PAR #36421
		else
			// setup the text column
			col.inputType := InputType_None;
			col.partialTextIndication := true;
		endif;
	endforeach;

	if self.isInPainter then
		return;
	endif;
	
	self.loadHazardObjects();
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
