    <JadeMethod name="doesRequireSnapShot" id="0701c947-6c06-49e0-a283-72d3b6a877e7">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := true;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="42ebadcb-f540-4954-8fb7-7126e3e414bd">
        <source>getDisplayString(): String;
// created by cnwvu1	27/02/2007

vars

	drstr, amountDisplay, lDetail : String;
begin

	if self.pinNo &lt;&gt; null then
		return 'PIN = ' &amp; self.pinNo;
	else // TFS 42882
		if self.isDirectReleaseMove then
			drstr := " DR ";
		endif;
		amountDisplay := '(' &amp; self.getAmountDisplay() &amp; ') ';
		if amountDisplay &lt;&gt; "() " then
			lDetail:= app.getErrorString(Release) &amp; drstr &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
		else
			lDetail:= app.getErrorString(Release) &amp; drstr &amp;  " " &amp; lDetail;
		endif;
		return lDetail;
	endif;


	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f6dbf8d2-2a36-4572-8b7f-8d80ebff87de">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.getDisplayString();
			
		endif;
							
	elseif _attrName = ETRow_ReleasePinNo then
		return self.pinNo;
	
	elseif _attrName = ETRow_ReleaseRoadFrom then	//14 May 2020	NDL	TFS 49202
		return self.locationRoad;
	elseif _attrName = ETRow_ReleaseRoadTo then	//14 May 2020	NDL	TFS 49202
		return self.locationYard;
		
	elseif _attrName = ETRow_TrailerType then	//21 Oct 2020	NDL	TFS 50113
		return self.getTrailerType();	
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="cb9c7ebc-7f8e-4f11-b92e-ea00ce3422df">
        <source>getEnquiryRow(): String;
// created by cnwvu1	27/02/2007

vars
	str : String;

begin
	
	str := inheritMethod();
	str := str &amp; self.getDisplayString();
	return str;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
