        &lt;/BOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;16960.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
