    <JadeMethod name="rel812_par29499" id="bcae2a41-39ec-413a-8f91-20a634e80a2d">
        <source>rel812_par29499();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2012	cnwjre1	CCMS QNS 2177 create CM_TranMapInvoiceLineGroupType and convert existing quantity range maps

*/

vars
	root	: CM_Root;
	mapType	: CM_TranMapInvoiceLineGroupType;
	mapMapping	: CM_TranMapInvoiceLineMapping;
	qrm		: CM_QuantityRangeMap;
	ild		: CM_InvoiceLineDesc;
	iter	: Iterator;
	key		: Integer;
begin
	app.initialize();
	
	root := app.myRoot;
	if CM_TranMapInvoiceLineGroupType.instances.isEmpty() then
		beginTransaction;
		create mapType;
		mapType.update("All", TranMapInvLineGroupTypeAll, root);
		create mapType;
		mapType.update("Lowest", TranMapInvLineGroupTypeLow, root);
		create mapType;
		mapType.update("Lowest Default", TranMapInvLineGroupTypeLowDef, root);
		create mapType;
		mapType.update("Highest", TranMapInvLineGroupTypeHigh, root);
		create mapType;
		mapType.update("Highest Default", TranMapInvLineGroupTypeHighDef, root);
		commitTransaction;
	endif;
	
	foreach mapType in CM_TranMapInvoiceLineGroupType.instances do
		if mapType.type = TranMapInvLineGroupTypeAll then
			break;
		endif;
	endforeach;
	/* TFS 40620 removing all references to qrm.allInvoiceLineMaps
	beginTransaction;
	foreach qrm in CM_QuantityRangeMap.instances do
		if qrm.allTMInvoiceLineMappings.isEmpty() then
			iter := qrm.allInvoiceLineMaps.createIterator();
			while iter.next(ild) do
				qrm.allInvoiceLineMaps.getIteratorKeys(key, iter);
				create mapMapping;
				mapMapping.update(key, ild, qrm, mapType, null, null);
			endwhile;
			delete iter;
		endif;
	endforeach;
	commitTransaction;
	*/
epilog
	delete iter;
end;</source>
    </JadeMethod>
