    <JadeMethod name="displayDebtor" id="d2ff7c2a-5fda-4018-8f71-0747339702f0">
        <source>displayDebtor(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.CM_Debtor.name;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmbDefDebtorBuild" id="e61a848d-93ba-4279-8cce-fc1985acd984">
        <source>doCmbDefDebtorBuild();
// ---------------------------------------------------------------------------
// Created:	7 April 2008 By Graeme Black cnwgb1
// Fill the default debtor combo box
// ---------------------------------------------------------------------------
vars
	aDebtor : CM_Debtor;
	availableDebtors : CM_DebtorByNameDict;
begin
	create availableDebtors transient;
	self.loadAvailableDebtors( availableDebtors );

	foreach aDebtor in availableDebtors do
		self.cmbDebtor.addItem(aDebtor.name);
		self.cmbDebtor.itemObject[self.cmbDebtor.newIndex] := aDebtor;
	endforeach;
	
	//Allow the user to null out default debtor
	self.cmbDebtor.addItem("");
	
	delete availableDebtors;

end;
</source>
    </JadeMethod>
