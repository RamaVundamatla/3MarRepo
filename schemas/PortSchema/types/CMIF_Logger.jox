<Class name="CMIF_Logger" id="c64d1ece-f032-4eff-8dc4-3bf31e380df7">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="temp"/>
    <ImplicitInverseRef name="allLogs" id="f8a84e57-0bbb-49a5-935b-d1e9cecce66b">
        <embedded/>
        <type name="HugeStringArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="e45cb4d6-44c0-4b93-a13b-2782e43405d6">
        <updating/>
        <source>create() updating;
//21 September 2010	cnwdw1	
//
vars

begin
	create self.allLogs transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="08fb17b6-c700-4db7-9294-0b5e462a2eee">
        <updating/>
        <source>delete() updating;
//21 September 2010	cnwdw1	
//
vars

begin
	delete self.allLogs;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLogs" id="6393b895-cef9-428f-b6d4-61fa96d3c052">
        <source>getLogs(): String;
//21 September 2010	cnwdw1	
//
vars
	logs, log: String;
begin
	foreach log in self.allLogs do
		logs := logs &amp; log &amp; CrLf;
	endforeach;
	logs.replaceChar(Tab, ' ');
	return logs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogsAsBlocks" id="f0ba4426-03ed-4fec-bf79-89e71ac16765">
        <source>getLogsAsBlocks(_dataContainer: CM_DataContainer);

vars
	block : CM_DataContainerBlock;
	str	: String;
	idx	: Integer;
begin

	block := _dataContainer.addNewBlock;	
	foreach str in self.allLogs do
		idx:= idx + 1;
		block.addNewItem(idx.String &amp; ' ', DC_Label, 1, null);
		block.addNewItem(str, DC_Data, 1, null);
	endforeach;
	
end;

</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="log" id="15a2387b-b20e-4589-9a32-c4d0ddb4bf2b">
        <source>log(_message: String);
//21 September 2010	cnwdw1	
//
constants
    MAXSIZE = 2040;
vars
	l, s: Integer;
begin
	if _message.cnContains("olatility") then	// ignore all the volatility debugging
		return;
	endif;
	
	l := _message.length;
	s := 1; 
	while s &lt;= l do
		allLogs.add(_message[s:MAXSIZE]);
		s := s+MAXSIZE;
	endwhile;
end;
</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
</Class>
