    <JadeMethod name="tblGroupAddRow" id="b1e86f6b-d49b-404d-9428-999c2bf311b9">
        <source>tblGroupAddRow(pRow : EntTableRow) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin

	idx := tblGroup.addItem('');
	tblGroup.accessCell(idx, Col_InputType).comboList := self.getInTypeComboValues();
	tblGroup.accessCell(idx, Col_InputTypeWeb).comboList := self.getInputTypeWebComboValues();
	tblGroup.accessCell(idx, Col_TerminologyType).comboList := self.getTerminologyTypeNames();
	tblGroup.accessCell(idx, Col_MeasurementType).comboList := self.getMeasurementTypeNames();		// PAR #31155

	tblGroup.accessCell(idx, 1).text := self.displayEntTableRow(pRow, true);
	tblGroup.accessRow(idx).itemObject := pRow;
	
	return idx;

end;</source>
        <Parameter name="pRow" type="EntTableRow"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
