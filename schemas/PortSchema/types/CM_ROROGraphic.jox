begin
	return self.drawFillStyle;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="833a966c-62db-4b68-b65b-5bfa185075a1">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	likeMe : SelfType;
	completedOK		: Boolean;
begin
	likeMe :=  inheritMethod();

	likeMe.myRepresentativeObject := self.myRepresentativeObject;
	likeMe.myShipLayer := self.myShipLayer.pxyGetProxyObject();
	if likeMe.myShipLayer = null then
		likeMe.myShipLayer := self.myShipLayer;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return likeMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete likeMe;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateRORO" id="fc2ace9a-0b88-4228-b3b2-f4cb6e99eddf">
        <updating/>
        <source>setForCreateRORO(pProxyROROGraphic: CM_ROROGraphic; _realLayer : CM_ShipDeckLayer) updating;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realROROVessel : CM_ROROStructure;
begin
	self.setForCreate(pProxyROROGraphic);
	
	self.setLabel(pProxyROROGraphic.label);
	self.drawFillColor := pProxyROROGraphic.drawFillColor;
	self.drawFillStyle := pProxyROROGraphic.drawFillStyle;
	self.drawWidth := pProxyROROGraphic.drawWidth;
	self.remarks := pProxyROROGraphic.remarks;
	
	self.myShipLayer := _realLayer; // pProxyROROGraphic.myShipLayer.pxyGetRealObject(); // real object
	
epilog

end;</source>
        <Parameter name="pProxyROROGraphic" type="CM_ROROGraphic"/>
        <Parameter name="_realLayer" type="CM_ShipDeckLayer"/>
    </JadeMethod>
