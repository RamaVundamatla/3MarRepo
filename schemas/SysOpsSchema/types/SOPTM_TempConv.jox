    <JadeMethod name="doSave" id="8242cc19-e448-4785-bcdc-167199590182">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	---------	------------------------------------------------------------
// 09/10/2017	jlgdap1		TFS 7204 Correct STWR Correct real  handling for non-standard locales
vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	proxyTemperatureConversion:CM_TemperatureConversion;
	lCelsius,lFahrenheit:Real;
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm; 

	//lCelsius := theForm.tblInput1.getValueByName(ETRow_Celsius).Real;						// TFS 7204
	//lFahrenheit := theForm.tblInput1.getValueByName(ETRow_Fahrenheit).Real;				// TFS 7204
	lCelsius := theForm.tblInput1.getValueByName(ETRow_Celsius).String.asRealJMT;			// TFS 7204
	lFahrenheit := theForm.tblInput1.getValueByName(ETRow_Fahrenheit).String.asRealJMT;		// TFS 7204

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_TemperatureConversion transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyTemperatureConversion := theForm.myProxyObject.CM_TemperatureConversion;
	proxyTemperatureConversion.setProxy(lCelsius, lFahrenheit);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateTemperatureConversion(proxyTemperatureConversion, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateTemperatureConversion(proxyTemperatureConversion, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
