    <JadeMethod name="tCashReleaseSplit04" id="97737d54-679e-448d-a5ca-523ffa486144">
        <updating/>
        <source>tCashReleaseSplit04() updating;
/*
Purpose - 	Nothing to do with splitting. This is about non invoiced cash payments iei those cash payment that are for transactions in the future and so they have no invoice lines.
				Configure cash to create road release , this will auto create a storage transaction as well. Discharge some cargo from a voyage, send draft request to cash API
				Check that it has cash payments for release road and storage
				Cancel the cash receipt. 
				Resent the send draft request to cash API
				Set status to FINAL
				create a road release job.
				On road exit shoudl not get error Cash_cargo_not_paid
Date - 24JUN2025
ADO - JIRA 35178
*/

constants
	CEN = "UTCEN";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CASHAPITI";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	EXTFINANCIALID = "EXTERNAL FINANCIAL ID";
	EXTRECEIPTNUMBER = "EXTERNAL RECEIPT NUMBER";
	EXTREF1 = "EXTREF1";
	EXTTRANSACTION = "EXTERNAL TRANSACTION";
	
vars
	cargoId,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	draftReceiptNumber,
	finalReceiptNumber, idx	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt : CM_CashReceipt;
	cashPay : CM_CashPayment;
	type : CM_TerminalAreaType;
	blockStack1 : CM_BlockStack;
	effectTS : TimeStamp;
		vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

begin
	//return;
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	
	
	terminal := self.getMyTerminal();
	
	
	
		type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");

	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	self.setTerminalConfig(CashRoadExitChkServices, true);
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	
	 // 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,UT33930-2
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),(Default) ?,(Default),,,**Any**,All,UT33930-1';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Release Road (plus Storage)
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	effectTS := effectTS.addDays(-10);
	self.opts.purge();
	self.opts.addAssoc("EffectiveTimeStamp", effectTS);
	self.move(ti, blockStack1);
	
	self.assertTrueMsg(ti.locationId = "UT_BS1", " TI should be in block stack");
	self.assertTrueMsg(ti.isOnSite(), " TI should be in onsite");
	
	voyCode := voyage.code;
	today := app.actualTimeServer().date();
	effectiveDate := today.addDays(5);
	agentId := customagent.code;
		
	/*
	First, create a  draft receipt
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[draftReceiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.allCashPayments.size = 2, "Cash receipt shouldhave 2 payments");
	
	//self.assertTrueMsg(cashReceipt.cashValue = 2314.95, "1. Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt.cashValue = 2319.95, "1. Total amount is not correct is " &amp; cashReceipt.cashValue.String); // 25/07/2025	navkc1	JIRA MTN-35344 - include all charges
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	// Get the BGP - we need to make sure we have 1 now
	

	/*
	CANCEL IT
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 23
				}
					';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 4 - Good scenario, update status and external fields
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED, "Payment status should gets updated to be CANCELLED");
	self.assertTrueMsg(finalReceiptNumber = null, "1 Should not have a final receipt number here");
	self.assertTrueMsg(draftReceiptNumber = cashReceipt.sequenceNum, "1 Draft receipt sequence number should match the cash receipt sequence number");
	self.assertTrueMsg(draftReceiptNumber &gt;= DRAFTCASHRECEIPT_StartNumber, "1 Draft receipt number should start from this number in the global constant");
	
	
	// RECREATE DRAFT
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[draftReceiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	//self.assertTrueMsg(cashReceipt.cashValue = 2314.95, "2. Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt.cashValue = 2319.95, "2. Total amount is not correct is " &amp; cashReceipt.cashValue.String); // 25/07/2025	navkc1	JIRA MTN-35344 - include all charges
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
		
		
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
	
	/*
	set to PAID (24)
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "Payment status should gets updated to be FINAL");
	
	self.assertTrueMsg(ti.allCashPayments.size = 4, "should be 4 cash payments");
	idx := 1;
	foreach cashPay in ti.allCashPayments do
		if idx =  1 or idx = 2 then
			self.assertTrueMsg(cashPay.myCashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED, idx.String &amp; " cash payment should be cancelled, not " &amp; cashPay.myCashReceipt.paymentStatus.String);
			if idx = 2 then
				self.assertTrueMsg(cashPay.myInvoiceLine = null, idx.String &amp; " payment should not have an invoice line");
			endif;
		elseif idx = 3 or idx = 4 then
			self.assertTrueMsg(cashPay.myCashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, idx.String &amp; " cash payment should be final, not " &amp; cashPay.myCashReceipt.paymentStatus.String);
			if idx = 4 then
				self.assertTrueMsg(cashPay.myInvoiceLine = null, idx.String &amp; " payment should not have an invoice line");
			endif;
		
		endif;
		idx += 1;
	endforeach;
	
	
// gate first container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(ti);

	vvrOut := self.createVVRBBlk( truckOut, ti, ti.myCargoType );
	self.assertTrueMsg(vvrOut &lt;&gt; null, " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	self.deleteVVR(vvrOut);
	
	self.assertTrueMsg(ti.isOffSite, "onsiteTi1 should be Offsite");
	
epilog
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);  // 25/07/2025	navkc1	JIRA MTN-35344
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	delete pxyTransService;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit05" id="ddfbfe86-fd61-4b50-b527-9d75c55288f0">
        <updating/>
        <source>tCashReleaseSplit05() updating;
/*
Purpose - 	Test pay whilst on ship, invoice quantity of 1. Discharge in 2 parts 50/50, so merges. On site move part to 2nd location, move more to 2nd location 50/50, but no all.
				The invoice lines shoudl add up to 0.5 on each and the cash payment shoudl be 0.5 on each.
				

				Who - NAVAB1
Date - 24JUN2025
ADO - JIRA 35068
*/

constants
	ServName = "UT_SrvSplitCsh";
	LineName =  "UT_LneSplitCsh";
	CGTYPE = "UTCGTYPE";
vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	taxCode : CM_TaxCode;
	bank : CM_Bank;
	terminal : CM_Terminal;
	ct : CM_CargoType;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.addCargoType(CGTYPE, false);
	self.assertNotNullMsg(ct, "Failed to create cargo type " &amp; CGTYPE);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	create cargoIds transient;
	// ids with valid check digits
	cargoIds.add("CATTLE250502-100");
	foreach cargoId1 in cargoIds do
		self.deleteCargo(cargoId1, ct.id);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.setBankProFormaAllocBBlk();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := debtor; // app.myRoot.myRootCompany.debtors[DrNameOne];
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT03", LineName, null, invType); // CARGO VOLUME

	invLineType1 := self.myBank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

//	debtor := operator.debtor;
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	
	
	
	self.tranMapLoadBBlkSplit();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.cashTestMultipleReceipts8(cargoId1, null, drTerm1, 1);
	
epilog
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.opts.purge();
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
	self.deleteTranMapTI("UT_BBlkSplit");	  // ### JIRA 35068 16JUN2025 NAVAB1
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit06" id="e183fe84-d5de-4a12-b431-338ccc557e8a">
        <updating/>
        <source>tCashReleaseSplit06() updating;
/*
Purpose - 	Test split of invoice lines for a cash debtor and then merge of those invoice lines. Test split and merge of invoice lines with cash payments. test split and merge of cash payments. 
				NOTE this alsi tests JIRA 35283

				Who - NAVAB1
Date - 30JUN2025
ADO - JIRA 35213
*/

constants
	ServName = "UT_SrvSplitCsh";
	LineName =  "UT_LneSplitCsh";
	CGTYPE = "UTCGTYPE";
vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	taxCode : CM_TaxCode;
	bank : CM_Bank;
	terminal : CM_Terminal;
	ct : CM_CargoType;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.addCargoType(CGTYPE, false);
	self.assertNotNullMsg(ct, "Failed to create cargo type " &amp; CGTYPE);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	create cargoIds transient;
	// ids with valid check digits
	cargoIds.add("CATTLE250502-101");
	cargoIds.add("CATTLE250502-102");
	cargoIds.add("CATTLE250502-103");
	cargoIds.add("CATTLE250502-104");
	foreach cargoId1 in cargoIds do
		self.deleteCargo(cargoId1, ct.id);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.setBankProFormaAllocBBlk();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := debtor; // app.myRoot.myRootCompany.debtors[DrNameOne];
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT03", LineName, null, invType); // CARGO VOLUME

	invLineType1 := self.myBank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

//	debtor := operator.debtor;
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	
	
	
	self.tranMapLoadBBlkSplit();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.cashTestMultipleReceipts9a(cargoId1, cargoId2, drTerm1, 1);

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	cargoId1 := cargoIds[3];
	cargoId2 := cargoIds[4];
	self.cashTestMultipleReceipts9b(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.deleteCashReceipts(drTerm1);
	self.opts.purge();
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
	self.deleteTranMapTI("UT_BBlkSplit");	  // ### JIRA 35068 16JUN2025 NAVAB1
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit07" id="6765b838-e22e-4a14-9d64-6f0a7ebd6c73">
        <updating/>
        <source>tCashReleaseSplit07() updating;
/*
Purpose - 	This is about invoiced cash payments ie real invoice lines with cash payment
				Configure cash to create road release , this will auto create a storage transaction as well. Discharge some cargo from a voyage
				
				SPLIT cargo using SPLIT TRX
				Send draft request to cash API
				Check that it has cash payments for release road and storage
				
				MERGE Cargo using MERGE TRX
				Check that it has cash payments for release road and storage
				
				Cancel the cash receipt. 
				
				Resent the send draft request to cash API
				Set status to FINAL
				
				SPLIT cargo using SPLIT TRX
				
				Check all TIs have payments 
				CHECK all payments for all TI  are on same receipt
				
				
				create a road release job.
				On road exit shoudl not get error Cash_cargo_not_paid
				
				
				the issue was
					## discharge cargo
					## split cargo
					## create draft CR
					## merge TIs into one
					## CR cancelled - status 22 &gt;&gt; 23
					## create new draft CR
					## split cargo

					cash payments on wrong receipts!!!!


Date - 29JUL2025
ADO - JIRA 35593
*/

constants
	CEN = "UTCEN";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CAPITI";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	EXTFINANCIALID = "EXTERNAL FINANCIAL ID";
	EXTRECEIPTNUMBER = "EXTERNAL RECEIPT NUMBER";
	EXTREF1 = "EXTREF1";
	EXTTRANSACTION = "EXTERNAL TRANSACTION";
	ServName = "UTRShip";
	LineName =  "UTRShip";
	ServName2 = "UTRRoad";
	LineName2 =  "UTRRoad";
vars
	cargoId,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount, invLine1Amt, invLine2Amt, rate1, rate2		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti, cashTI1, onsiteTi1, origTI				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	draftReceiptNumber,
	finalReceiptNumber, idx	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt, cashReceipt1, cashReceipt2 : CM_CashReceipt;
	cashPay : CM_CashPayment;
	type : CM_TerminalAreaType;
	blockStack1 : CM_BlockStack;
	effectTS : TimeStamp;
		vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;
	newTiIds: StringArray;
	allTisToMerge : CM_TISet;
	qty : Integer;
	wgt, vol : Decimal[23,6];
	tempID : String;
	invLine : CM_InvoiceLine;
	ctype : CM_CargoType;
	invType : CM_InvoiceDesc;
	taxCode : CM_TaxCode;
	invLineType1,invLineType2 : CM_InvoiceLineDesc;
	service : CM_Service;
begin
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	
	
	terminal := self.getMyTerminal();
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId",true);
	
	
	ctype := self.addCargoType("UTINV",false);
	
	
		type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");

	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	
	// create Services and invoiceLineReevaluate line types
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	self.deleteService(ServName2);
	self.deleteInvoiceLineType(LineName2,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT03", LineName, null, invType); // CARGO VOLUME
	self.addIfNewServiceILD(ServName2, "CCT03", LineName2, null, invType); // CARGO VOLUME
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	invLineType1 := bank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	invLineType2 := bank.invoiceLineDescriptors[LineName2];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName2];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	self.setTerminalConfig(CashRoadExitChkServices, true);
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	
	 // 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,' &amp; LineName &amp; CrLf &amp;
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) ?,(Default),,,**Any**,All,"  &amp; LineName2;

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Release Road (plus Storage)
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	qty := 4;
	wgt := 16;
	vol := 8;
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",qty);
	self.opts.addAssoc("TotalWeight",wgt);
	self.opts.addAssoc("TotalVolume",vol);
	self.opts.addAssoc("CargoType",ctype.id);
	
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	effectTS := effectTS.addDays(-10);
	self.opts.purge();
	self.opts.addAssoc("EffectiveTimeStamp", effectTS);
	self.move(ti, blockStack1);
	
	self.assertTrueMsg(ti.locationId = "UT_BS1", " TI should be in block stack");
	self.assertTrueMsg(ti.isOnSite(), " TI should be in onsite");
	
	
	// ###### SPLIT
	cashTI1 := ti;
	origTI := cashTI1;
	create newTiIds transient;
	newTiIds.add(cargoId &amp; "-01");
	newTiIds.add(cargoId &amp; "-02");
	newTiIds.add(cargoId &amp; "-03");
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 1 ");	
	

	create allTisToMerge transient;
	
	tempID := cargoId;
	cashTI1 := blockStack1.getTiById(tempID);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI0 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");

	invLine1Amt := 57.60;
	invLine2Amt := 3.9;
	rate1 := 28.8;
	rate2 := 8;
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, " cashTI0 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Split cashTI0 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt, "Merged cashTI0 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);

	
	
	tempID := cargoId &amp; "-01";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI1 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-02";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI2 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI2 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI2 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI2 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI2 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI2 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI2 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI2 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI2 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-03";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI3 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI3 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI3 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI3 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI3 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI3 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI3 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI3 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal =invLine1Amt,  tempID &amp; "  cashTI3 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	// create draft	
	voyCode := voyage.code;
	effectiveDate := effectiveDate.addDays(20);
	agentId := customagent.code;
		
	/*
	First, create a  draft receipt
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[draftReceiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.allCashPayments.size = 8, "Cash receipt should have 8 payments");
	
	self.assertTrueMsg(cashReceipt.cashValue = 460.8, "1. Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt.allTrackedItems.size = 4, "1. Cash Receipt should have 4 TIs, has " &amp; cashReceipt.allTrackedItems.size.String);
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	cashReceipt1 := cashReceipt;
	
	
	// #### MERGE
	app.myTrxUA.trxMergeBreakBulk(origTI.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 1 ");
	
	onsiteTi1 := blockStack1.getTiById(cargoId);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "Merged OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "Merged OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "Merged OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 230.4, "Merged OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);

	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "Merged OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, "Merged OnsiteTi1 should have 2 cash payments");
	cashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(cashPay &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(cashPay.cashValue = 230.4, "Merged OnsiteTi1 has wrong cash value - 2.2SA is " &amp; cashPay.cashValue.String);
	self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line - 2.2SA" );
	cashPay := onsiteTi1.allCashPayments.last;
	self.assertTrueMsg(cashPay &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(cashPay.cashValue = 230.4, "Merged OnsiteTi1 has wrong cash value - 2.2SA is " &amp; cashPay.cashValue.String);
	self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, "Merged OnsiteTi1 has no myProformaDetail - 2.2SA" );

	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 8, "2.4 Cash receipt should have 8 payments is " &amp; cashReceipt1.allCashPayments.size.String);
	self.assertTrueMsg(cashReceipt1.cashValue = 460.8, "2.4 Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "2.4 Cash Receipt should have 1 TIs, has " &amp; cashReceipt.allTrackedItems.size.String);
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments do
		if idx &lt;= 2 then
			assertTrueMsg(cashPay.voided = false, idx.String &amp; " Cash Payment should not be voided");
		else
			assertTrueMsg(cashPay.voided = true, idx.String &amp; " Cash Payment should  be voided");
		endif;
		idx += 1;
	
	
	endforeach;
	
	
	
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
		
	
	/*
	CANCEL IT
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 23
				}
					';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 4 - Good scenario, update status and external fields
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED, "Payment status should gets updated to be CANCELLED");
	self.assertTrueMsg(finalReceiptNumber = null, "1 Should not have a final receipt number here");
	self.assertTrueMsg(draftReceiptNumber = cashReceipt.sequenceNum, "1 Draft receipt sequence number should match the cash receipt sequence number");
	self.assertTrueMsg(draftReceiptNumber &gt;= DRAFTCASHRECEIPT_StartNumber, "1 Draft receipt number should start from this number in the global constant");
	
	
	// RECREATE DRAFT
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[draftReceiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "2 Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 460.800000, "2. Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(isPaymentAllowed, "2 Is Payment Allowed should be true");
	self.assertTrueMsg(cashReceipt.allCashPayments.size = 2, "2 Cash receipt should have 8 payments");
	self.assertTrueMsg(cashReceipt.cashValue = 460.8, "2. Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt.allTrackedItems.size = 1, "2. Cash Receipt should have 1 TIs, has " &amp; cashReceipt.allTrackedItems.size.String);
		
	cashReceipt2 := cashReceipt;
	
	// ### SPLIT AGAIN
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 2 ");	
		
	// in this scenario the issue was at this point. having cancelled the first CR then created a new CR then split, this issue was that the payments for the split off TI was on the original cash receipt, where as they should  be on this new 1.
	// New Cash Receipt
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "3.1 Cash receipt should not be null");
	self.assertTrueMsg(isPaymentAllowed, "3.1 Is Payment Allowed should be true");
	self.assertTrueMsg(cashReceipt2.allCashPayments.size = 8, "3.1 Cash receipt should have 8 payments");
	self.assertTrueMsg(cashReceipt2.cashValue = 460.8, "3.1. cash value is not correct is " &amp; cashReceipt2.cashValue.String);
	self.assertTrueMsg(cashReceipt2.allTrackedItems.size = 4, "3.1. Cash Receipt should have 4 TIs, has " &amp; cashReceipt2.allTrackedItems.size.String);
	
	// FIRST CASH RECEIPT
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 8, "2.5 Cash receipt should have 8 payments is " &amp; cashReceipt1.allCashPayments.size.String);
	self.assertTrueMsg(cashReceipt1.cashValue = 460.8, "2.5 Total amount is not correct is " &amp; cashReceipt.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "2.5 Cash Receipt should have 1 TIs, has " &amp; cashReceipt.allTrackedItems.size.String);
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments do
		if idx &lt;= 2 then
			assertTrueMsg(cashPay.voided = false, idx.String &amp; " Cash Payment should not be voided 2.5");
		else
			assertTrueMsg(cashPay.voided = true, idx.String &amp; " Cash Payment should  be voided 2.5");
		endif;
		idx += 1;
	
	
	endforeach;
		
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
	
	/*
	set to PAID (24)
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "Payment status should gets updated to be FINAL");
	

	
epilog
	delete newTiIds;
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport); 
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete allTisToMerge;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	delete pxyTransService;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit08" id="39d570af-7579-4c01-9ee1-848721c7d391">
        <updating/>
        <source>tCashReleaseSplit08() updating;
/*
Purpose - 	Test split and then merge of invoice lines for cash debtor that have a calc type of to do resource quantiity

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 1 part will be 1 invoice line
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 1 proportional invoice line on each TI
				
				Add a to do on all TIs
				Complete to do on all and enter resource quantity
				
				check that each has the appropriate invoice line.
				
				Then Merge into 1 part, using MERGE TRX
				Should be 4 invoice lines because there are 4 seperate transactions.

				Then Split TI into 4 parts, different IDs using SPLIT TRX
				
				Should be 5 invoice lines  TI, 1 for each to do and the discharge line
				
				Then Merge into 1 part, using MERGE TRX
				Should be 4 invoice lines because there are 4 seperate transactions.
	
				Who - NAVAB1
Date - 07AUG2025
ADO - JIRA 35638
*/



constants
	ServName = "UT_SrvSplitRes";
	LineName =  "UT_LneSplitRes";
	ServName2 = "UT_SrvSplitDis";
	LineName2 =  "UT_LneSplitDis";
	CGTYPE = "UTCGTYPE";
	TODOTASKDESC = "Palletised";
vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	taxCode : CM_TaxCode;
	bank : CM_Bank;
	terminal : CM_Terminal;
	ct : CM_CargoType;
	transType : CM_TransactionType;
	toDoTaskDesc : CM_ToDoTaskDesc;
	resourceType : CM_ResourceType;
	toDoTaskList : CM_ToDoTaskDescBySortKey;
	trxtTypeType : Integer;
begin


	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.addCargoType(CGTYPE, false);
	self.assertNotNullMsg(ct, "Failed to create cargo type " &amp; CGTYPE);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	self.deleteTranMapTI("UT_BBlkResQty");	 
	
	transType := app.myRoot.allTransactionTypesByDesc["UTResTrans"];
	if transType &lt;&gt; null then
		trxtTypeType := transType.trxType;
	else
		trxtTypeType := app.myRoot.allTransactionTypes.last.trxType + 1;
	endif;
	
	transType := self.addTransactionType("UTResTrans", "CM_TaskComplete", trxtTypeType, TRANS_TYPE_GROUP_TI,true);
	self.assertTrueMsg(transType &lt;&gt; null, "Trans Type Is Null!");
	
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.opts.addAssoc("TrxTypeOnCompletion", transType);
	
	
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	
	create toDoTaskList transient;
	toDoTaskList.add(toDoTaskDesc);
	
	resourceType := app.myRoot.allTaskResourceTypes["UTPall"];
	if resourceType &lt;&gt; null then
		beginTransaction;
		resourceType.setPropertyValue("hasBeenUsed",false);
		commitTransaction;
		self.deleteResourceType("UTPall");
	endif;
		resourceType := self.addToDoTaskResource("UTPall",
											 "UT Pallet",
											 "PALL",
											 0,
											 false,
											 true,
											 toDoTaskList);
	self.assertNotNull(resourceType);
	
	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	create cargoIds transient;
	// ids with valid check digits
	cargoIds.add("CATTLE250502-101");
	cargoIds.add("CATTLE250502-102");
	cargoIds.add("CATTLE250502-103");
	cargoIds.add("CATTLE250502-104");
	foreach cargoId1 in cargoIds do
		self.deleteCargo(cargoId1, ct.id);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.setBankProFormaAllocBBlk();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := debtor; // app.myRoot.myRootCompany.debtors[DrNameOne];
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	self.deleteService(ServName2);
	self.deleteInvoiceLineType(LineName2,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT02", LineName, null, invType); // CARGO TO DO RES QTY
	self.addIfNewServiceILD(ServName2, "CCT03", LineName2, null, invType); // CARGO VOLUME

	invLineType1 := self.myBank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);
	service := self.myBank.services[ServName2];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

//	debtor := operator.debtor;
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	
	
	
	self.tranMapLoadSplitToDoResQty();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.cashTestMultipleReceipts10(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	self.deleteService(ServName2);
	self.deleteInvoiceLineType(LineName2,0);
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.deleteCashReceipts(drTerm1);
	self.opts.purge();
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
	self.deleteTranMapTI("UT_BBlkResQty");	 
	self.deleteTransactionType(trxtTypeType);
	delete toDoTaskList;
	
	// delete down here as it has been mapped on tran map so need to delete that first
	resourceType := app.myRoot.allTaskResourceTypes["UTPall"];
	if resourceType &lt;&gt; null then
		beginTransaction;
		resourceType.setPropertyValue("hasBeenUsed", false);
		commitTransaction;
		self.deleteResourceType("UTPall");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit09" id="8df608d3-3a5a-4158-8e2f-fd283a3c5c73">
        <updating/>
        <source>tCashReleaseSplit09() updating;
/*
Purpose - 	This is about invoiced cash payments ie real invoice lines with cash payment
				Configure cash to create road release , this will auto create a storage transaction as well. Discharge some cargo from a voyage

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 1 part will be 1 invoice line
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 1 proportional invoice line on each TI
				
				Add a to do on all TIs
				Complete to do on all and enter resource quantity
				
				check that each has the appropriate invoice line.
				Check that each to do transaction has resource

				CASH RECEIPT. Send draft request to cash API
				Check that it has cash payments for release road and storage
				
				Check all the cash payments have the correct value
				
				
				MERGE Cargo using MERGE TRX
				check correct number of cash payments on cash receipt
				check correct number of cash payments on cargo item
				
				Cash Receipt set to HOLD
				Cash Receipt set to CANCEL
				
				Resent the send draft request to cash API
				check all the cash payments on singleton cargo item, correct number , correct cash values
				check all the cash payments on cash receipt 1, correct number , correct cash values
				check all the cash payments on cash receipt 2, correct number , correct cash values
				
				SPLIT cargo using SPLIT TRX
				
				check all the cash payments on cash receipt 1, correct number , correct cash values
				check all the cash payments on cash receipt 2, correct number , correct cash values
				check all the cash payments on cash receipt 1, correctly voided or not voiced (MERGED)

				
				Cash Receipt set to HOLD
				Cash Receipt set to FINAL



Date - 22AUG2025
ADO - JIRA 35803
*/

constants
	CEN = "UTCEN";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CAPITI";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	EXTFINANCIALID = "EXTERNAL FINANCIAL ID";
	EXTRECEIPTNUMBER = "EXTERNAL RECEIPT NUMBER";
	EXTREF1 = "EXTREF1";
	EXTTRANSACTION = "EXTERNAL TRANSACTION";
	ServName = "UTRShip";
	LineName =  "UTRShip";
	ServName2 = "UTRRoad";
	LineName2 =  "UTRRoad";
	ServName3 = "UTTODO";
	LineName3 =  "UTTODO";
	TODOTASKDESC = "Palletised";
vars
	cargoId,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount, invLine1Amt, invLine2Amt, rate1, rate2		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti, cashTI1, onsiteTi1,onsiteTi2, origTI				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	draftReceiptNumber,
	finalReceiptNumber, idx	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt1, cashReceipt2 : CM_CashReceipt;
	cashPay : CM_CashPayment;
	type : CM_TerminalAreaType;
	blockStack1 : CM_BlockStack;
	effectTS : TimeStamp;
	newTiIds: StringArray;
	allTisToMerge, allTIsForTODO : CM_TISet;
	qty : Integer;
	wgt, vol : Decimal[23,6];
	tempID : String;
	invLine : CM_InvoiceLine;
	ctype : CM_CargoType;
	invType : CM_InvoiceDesc;
	taxCode : CM_TaxCode;
	invLineType1,invLineType2, invLineType3 : CM_InvoiceLineDesc;
	service : CM_Service;
	transType : CM_TransactionType;
	toDoTaskDesc : CM_ToDoTaskDesc;
	resourceType : CM_ResourceType;
	toDoTaskList : CM_ToDoTaskDescBySortKey;
	trxtTypeType : Integer;
	todotask : CM_ToDoTask;
	proxyResourceTypeUsage : CM_ResourceTypeUsage;
	tiTrx : CM_TITransaction;
	resourceUsageProxys 	: CM_ResourceTypeUsageSet;

begin
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	
	
	terminal := self.getMyTerminal();
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId",true);
	
	
	ctype := self.addCargoType("UTINV",false);
	
	
		type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");

	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	
	// create Services and invoiceLineReevaluate line types
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	self.deleteService(ServName2);
	self.deleteInvoiceLineType(LineName2,0);
	self.deleteService(ServName3);
	self.deleteInvoiceLineType(LineName3,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT03", LineName, null, invType); // CARGO VOLUME
	self.addIfNewServiceILD(ServName2, "CCT03", LineName2, null, invType); // CARGO VOLUME
	self.addIfNewServiceILD(ServName3, "CCT02", LineName3, null, invType); // RESOURCE QTY
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	invLineType1 := bank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	invLineType2 := bank.invoiceLineDescriptors[LineName2];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName2];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	invLineType3 := bank.invoiceLineDescriptors[LineName3];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType3.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName3];		// RESOURCE QUANTITY
	self.setServiceRate(service, debtor, "01/01/2013".Date,10);

	
	transType := app.myRoot.allTransactionTypesByDesc["UTResTrans"];
	if transType &lt;&gt; null then
		trxtTypeType := transType.trxType;
	else
		trxtTypeType := app.myRoot.allTransactionTypes.last.trxType + 1;
	endif;
	
	transType := self.addTransactionType("UTResTrans", "CM_TaskComplete", trxtTypeType, TRANS_TYPE_GROUP_TI,true);
	self.assertTrueMsg(transType &lt;&gt; null, "Trans Type Is Null!");

	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", ctype);
	self.opts.addAssoc("TrxTypeOnCompletion", transType);
	
	
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");

	create toDoTaskList transient;
	toDoTaskList.add(toDoTaskDesc);	
	
	
	resourceType := app.myRoot.allTaskResourceTypes["UTPall"];
	if resourceType &lt;&gt; null then
		beginTransaction;
		resourceType.setPropertyValue("hasBeenUsed",false);
		commitTransaction;
		self.deleteResourceType("UTPall");
	endif;
		resourceType := self.addToDoTaskResource("UTPall",
											 "UT Pallet",
											 "PALL",
											 0,
											 false,
											 true,
											 toDoTaskList);
	self.assertNotNull(resourceType);
		
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	self.setTerminalConfig(CashRoadExitChkServices, true);
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	
	 // 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID' &amp; CrLf &amp; 
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,," &amp; CrLf &amp; 
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,Resource Mappings:UTPall,(Default),(Default) ›,(Default),,,**Any**,All,"  &amp; LineName3 &amp; CrLf &amp;
'Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,' &amp; LineName &amp; CrLf &amp;
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) ?,(Default),,,**Any**,All,"  &amp; LineName2;

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Release Road (plus Storage)
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	qty := 4;
	wgt := 16;
	vol := 8;
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",qty);
	self.opts.addAssoc("TotalWeight",wgt);
	self.opts.addAssoc("TotalVolume",vol);
	self.opts.addAssoc("CargoType",ctype.id);
	
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	effectTS := effectTS.addDays(-10);
	self.opts.purge();
	self.opts.addAssoc("EffectiveTimeStamp", effectTS);
	self.move(ti, blockStack1);
	
	self.assertTrueMsg(ti.locationId = "UT_BS1", " TI should be in block stack");
	self.assertTrueMsg(ti.isOnSite(), " TI should be in onsite");
	
	
	// ###### SPLIT
	cashTI1 := ti;
	origTI := cashTI1;
	create newTiIds transient;
	newTiIds.add(cargoId &amp; "-01");
	newTiIds.add(cargoId &amp; "-02");
	newTiIds.add(cargoId &amp; "-03");
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 1 ");	
	

	create allTisToMerge transient;
	create allTIsForTODO transient;
	
	tempID := cargoId;
	cashTI1 := blockStack1.getTiById(tempID);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI0 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");

	invLine1Amt := 57.60;
	invLine2Amt := 3.9;
	rate1 := 28.8;
	rate2 := 8;
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, " cashTI0 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Split cashTI0 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt, "Merged cashTI0 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	allTIsForTODO.add(cashTI1);

	
	
	tempID := cargoId &amp; "-01";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI1 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-02";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI2 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI2 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI2 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI2 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI2 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI2 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI2 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI2 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI2 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-03";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI3 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI3 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI3 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI3 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI3 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI3 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI3 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI3 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal =invLine1Amt,  tempID &amp; "  cashTI3 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	
	// ############### Add To DO TASK

	
	// ###### ADD TO DO TASK
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Palletised"];
	self.addToDoTask(toDoTaskDesc,allTIsForTODO);
	todotask := cashTI1.allToDoTasksToDo.first;
	self.assertTrueMsg(todotask &lt;&gt; null, toDoTaskDesc.description &amp; " not created on TI1");
	
	create resourceUsageProxys transient;
	foreach resourceType in toDoTaskDesc.allResourceTypes as CM_ResourceType do 
		create proxyResourceTypeUsage transient;
		proxyResourceTypeUsage.setProxy(	resourceType,					//_resourceType : CM_ResourceType;
											null,							//_transaction 	: CM_TITransaction;
											false,						    //_noCharge 	: Boolean;
											5.0,							//_quantity		: Decimal;
											resourceType.description,		//_remarks 		: String;
											CM_InvoiceLine.STATUS_NORMAL,	//_status 		: Integer;
											null, null,null,null,null);		
		resourceUsageProxys.add(proxyResourceTypeUsage);

	endforeach;
	
	self.completeToDoTask(toDoTaskDesc,allTIsForTODO , resourceUsageProxys);
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	
	// check trans and resources
	foreach onsiteTi2 in allTIsForTODO do
		tiTrx := onsiteTi2.allTransactions.last;
		self.assertTrueMsg(tiTrx &lt;&gt; null, "Transaction not created for " &amp; onsiteTi2.id &amp; " todo issue");
		self.assertTrueMsg( tiTrx.myToDoTask.toDoTaskDesc = toDoTaskDesc, 		"FAIL Completion of To Do Task '" 			  &amp; toDoTaskDesc.description &amp; "' for " &amp; onsiteTi2.id &amp; " to create transaction." );
		self.assertTrueMsg( tiTrx.allResourceUsages.size = toDoTaskDesc.allResourceTypes.size, toDoTaskDesc.description &amp; " Resource Count not correct" );
	
		self.assertTrueMsg(tiTrx.allInvoiceLines.isNotEmpty(),  toDoTaskDesc.description &amp;  " did not charge for " &amp; onsiteTi2.id);
		invLine := tiTrx.allInvoiceLines.first;
		self.assertTrueMsg(invLine &lt;&gt; null,  toDoTaskDesc.description &amp;  " no invoice line " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.invoiceLineDesc.narration = LineName3, toDoTaskDesc.description &amp;  " wrong invoice line type for " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.totalAmount = 50.00, "Merged OnsiteTi1 has wrong invoice total amount sbe 50.00 - 2.4SEA is " &amp; invLine.totalAmount.String);
	
	endforeach;	
	
	

	
	
	
	
	
	
	
	
	
	// ##### CASH create draft	
	voyCode := voyage.code;
	effectiveDate := effectiveDate.addDays(20);
	agentId := customagent.code;
		
	/*
	First, create a  draft receipt
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	cashReceipt1 := debtorTerminal.allCashReceipts[draftReceiptNumber];
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 12, "Cash receipt should have 12 payments");
	
	self.assertTrueMsg(cashReceipt1.cashValue = 660.80, "1. Total amount is not correct is " &amp; cashReceipt1.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "1. Cash Receipt should have 4 TIs, has " &amp; cashReceipt1.allTrackedItems.size.String);
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,4,5,7,8,10,11) then // SHIP RECEIVE and  TO DO TASK
			self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
			self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
			if idx.isOneOf(1,4,7,10) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 , "line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 57.6, "cash payment value &lt;&gt; 57.6 AAA");
			elseif idx.isOneOf(2,5,8,11) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 , "line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0, "cash payment value &lt;&gt; 50.00 BBB");
			endif;
		else // ROAD RELEASE
			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 , "line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 57.60, "cash payment value &lt;&gt; 57.60 CCCC");
		endif;
	
	idx += 1;
	endforeach;
	
	// #### MERGE
	app.myTrxUA.trxMergeBreakBulk(origTI.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 1 ");
	
	onsiteTi1 := blockStack1.getTiById(cargoId);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "Merged OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "Merged OnsiteTi1 sbe 4");
	
	
	
	// ### Check that the invoice lines have merged (by transaction) and that the cash payments are also merged (by invoic eline)
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 5, "Merged OnsiteTi1 should have 5 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no first invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 230.4, "Merged OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no last invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName3, "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 50.0, "Merged OnsiteTi1 has wrong invoice line total - 2.3DDSA is " &amp; invLine.lineTotal.String);
	
	
	

	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "Merged OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 6, "Merged OnsiteTi1 should have 6 cash payments");
	cashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(cashPay &lt;&gt; null, "Merged OnsiteTi1 has nocashPay");
	self.assertTrueMsg(cashPay.cashValue = 230.4, "Merged OnsiteTi1 has wrong cash value - 2.2SABB is " &amp; cashPay.cashValue.String);
	self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line - 2.2SABB" );
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, "Merged OnsiteTi1 has no cashReceipt1");
	self.assertTrueMsg(cashReceipt1.cashValue = 660.800000, "Merged OnsiteTi1 has wrong cash value - 2.2SACC is " &amp; cashReceipt1.cashValue.String);
	
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,4,5,6,7,8,9,10,11, 12) then // SHIP RECEIVE and  TO DO TASK
			if idx.isOneOf(1) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 230.4, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAW");
			elseif idx.isOneOf(2,5,8,11) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 ,  idx.String &amp; " line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0,  idx.String &amp; " cash payment value &lt;&gt; 50.00 BBBW");
			elseif idx.isOneOf(4, 6, 7, 9, 10, 12) then 
				self.assertTrueMsg(cashPay.voided,  idx.String &amp; "cash pay should be voided");
			endif;
		else // ROAD RELEASE
			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCW");
		endif;
	
	idx += 1;
	endforeach;
	
	idx := 1;
	foreach cashPay in onsiteTi1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,4,5,6) then // SHIP RECEIVE and  TO DO TASK
			if idx.isOneOf(1) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 230.4, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAX");
			elseif idx.isOneOf(2,4,5,6) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 ,  idx.String &amp; " line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0,  idx.String &amp; " cash payment value &lt;&gt; 50.00 BBBX");
			endif;
		else // ROAD RELEASE
			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCX");
		endif;
	
	idx += 1;
	endforeach;
	

	
	
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt1.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt1.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt1.externalFinancialId);
	self.assertTrueMsg(cashReceipt1.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt1.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt1.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt1.externalRef1);
	self.assertTrueMsg(cashReceipt1.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt1.externalTransaction);
		
	
	/*
	CANCEL IT
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 23
				}
					';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 4 - Good scenario, update status and external fields
	self.assertTrueMsg(cashReceipt1.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED, "Payment status should gets updated to be CANCELLED");
	self.assertTrueMsg(finalReceiptNumber = null, "1 Should not have a final receipt number here");
	self.assertTrueMsg(draftReceiptNumber = cashReceipt1.sequenceNum, "1 Draft receipt sequence number should match the cash receipt sequence number");
	self.assertTrueMsg(draftReceiptNumber &gt;= DRAFTCASHRECEIPT_StartNumber, "1 Draft receipt number should start from this number in the global constant");
	
	
	// RECREATE DRAFT
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
					
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt2 := debtorTerminal.allCashReceipts[draftReceiptNumber];

	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "2 Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt2.cashValue = 660.800000, "2. Total amount is not correct is " &amp; cashReceipt2.cashValue.String);
	self.assertTrueMsg(isPaymentAllowed, "2 Is Payment Allowed should be true");
	self.assertTrueMsg(cashReceipt2.allCashPayments.size = 6, "2 Cash receipt should have 6 payments");
	self.assertTrueMsg(cashReceipt2.allTrackedItems.size = 1, "2. Cash Receipt should have 1 TIs, has " &amp; cashReceipt2.allTrackedItems.size.String);
		
	
	idx := 1;
	foreach cashPay in cashReceipt2.allCashPayments discreteLock do
		if idx.isOneOf(1,2,3,4,5) then // SHIP RECEIVE and  TO DO TASK
			if idx.isOneOf(1) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 230.4, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAY");
			elseif idx.isOneOf(2,3,4,5) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 ,  idx.String &amp; " line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0,  idx.String &amp; " cash payment value &lt;&gt; 50.00 BBBY");
			endif;
		else // ROAD RELEASE
			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCY");
		endif;
	
	idx += 1;
	endforeach;		
	
	idx := 1;
	// TI now has 12 payment 6 are for the cancelled cash receipt.
	foreach cashPay in onsiteTi1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,3,4,5,6) then // SHIP RECEIVE and  TO DO TASK
			self.assertTrueMsg(cashPay.myCashReceipt = cashReceipt1, idx.String &amp; " TI cash payment should be on cashReceipt1");
			if idx.isOneOf(1) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 230.4, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAZ");
			elseif idx.isOneOf(3) then //  ROAD RELEASE
				self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
				self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
				self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCZ");
			elseif idx.isOneOf(2,4,5,6) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 ,  idx.String &amp; " line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0,  idx.String &amp; " cash payment value &lt;&gt; 50.00 BBBZ");
			endif;
		elseif idx.isOneOf(7,8,9,10,11,12) then // SHIP RECEIVE and  TO DO TASK
			self.assertTrueMsg(cashPay.myCashReceipt = cashReceipt2, idx.String &amp; " TI cash payment should be on cashReceipt2");
			if idx.isOneOf(7) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 230.4, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAZ");
			elseif idx.isOneOf(12) then //  ROAD RELEASE
				self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
				self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
				self.assertTrueMsg(cashPay.cashValue = 230.4,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCZ");
			elseif idx.isOneOf(8,9,10,11) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 ,  idx.String &amp; " line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0,  idx.String &amp; " cash payment value &lt;&gt; 50.00 BBBZ");
			endif;
		endif;
	
	idx += 1;
	endforeach;		
	
	// ### SPLIT AGAIN
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 2 ");	
		
	// in this scenario the issue was at this point. having cancelled the first CR then created a new CR then split, this issue was that the payments for the split off TI was on the original cash receipt, where as they should  be on this new 1.
	// New Cash Receipt
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "3.1 Cash receipt should not be null");
	self.assertTrueMsg(isPaymentAllowed, "3.1 Is Payment Allowed should be true");
	self.assertTrueMsg(cashReceipt2.allCashPayments.size = 24, "3.1 Cash receipt should have 24 payments");
	self.assertTrueMsg(cashReceipt2.cashValue = 660.800000, "3.1. cash value is not correct is " &amp; cashReceipt2.cashValue.String);
	self.assertTrueMsg(cashReceipt2.allTrackedItems.size = 4, "3.1. Cash Receipt should have 4 TIs, has " &amp; cashReceipt2.allTrackedItems.size.String);
	
	// FIRST CASH RECEIPT
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 12, "2.5 Cash receipt should have 12 payments is " &amp; cashReceipt1.allCashPayments.size.String);
	self.assertTrueMsg(cashReceipt1.cashValue = 660.80, "2.5 Total amount is not correct is " &amp; cashReceipt1.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "2.5 Cash Receipt should have 1 TIs, has " &amp; cashReceipt1.allTrackedItems.size.String);
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments do
		if idx.isOneOf(1,2,3,5,8,11) then
			assertTrueMsg(cashPay.voided = false, idx.String &amp; " Cash Payment should not be voided 2.5");
		else
			assertTrueMsg(cashPay.voided = true, idx.String &amp; " Cash Payment should  be voided 2.5");
		endif;
		idx += 1;
	
	
	endforeach;
		
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt2.externalFinancialId = EXTFINANCIALID, "2 externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt2.externalFinancialId);
	self.assertTrueMsg(cashReceipt2.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt2.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt2.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt2.externalRef1);
	self.assertTrueMsg(cashReceipt2.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt2.externalTransaction);
	
	/*
	set to PAID (24)
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt2.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "Payment status should gets updated to be FINAL");
	
epilog
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	delete pxyTransService;
	delete proxyCriteria;
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	delete toDoTaskList;
	delete newTiIds;
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport); 
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete allTisToMerge;
	delete allTIsForTODO;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt1 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt1);
	endif;
	if cashReceipt2 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt2);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit10" id="9e181e63-663a-4f0e-ba01-9077019c5fdc">
        <updating/>
        <source>tCashReleaseSplit10() updating;
/*
Purpose - 	This is about invoiced cash payments ie real invoice lines with cash payment
				Configure cash to create road release , this will auto create a storage transaction as well. Discharge some cargo from a voyage

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 1 part will be 1 invoice line
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 1 proportional invoice line on each TI
				
				Add a to do on all TIs
				Complete to do on all and enter resource quantity
				
				check that each has the appropriate invoice line.
				Check that each to do transaction has resource

				CASH RECEIPT. Send draft request to cash API
				Check that it has cash payments for release road and storage
				
				Check all the cash payments have the correct value
				
				Cash Receipt set to HOLD
				Cash Receipt set to CANCEL

				Resent the send draft request to cash API
				check all the cash payments on each of the 4 cargo item, correct number , correct cash values
				check all the cash payments on cash receipt 1, correct number , correct cash values
				check all the cash payments on cash receipt 2, correct number , correct cash values
				
				
				
				MERGE Cargo using MERGE TRX
				check correct number of cash payments on cash receipt
				check correct number of cash payments on cargo item
				
				
				
				SPLIT cargo using SPLIT TRX
				
				check all the cash payments on cash receipt 1, correct number , correct cash values
				check all the cash payments on cash receipt 2, correct number , correct cash values
				check all the cash payments on cash receipt 1, correctly voided or not voiced (MERGED)

				
				Cash Receipt set to HOLD
				Cash Receipt set to FINAL



Date - 17OCT2025
ADO - JIRA 36345
*/

constants
	CEN = "UTCEN";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CAPITI";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	EXTFINANCIALID = "EXTERNAL FINANCIAL ID";
	EXTRECEIPTNUMBER = "EXTERNAL RECEIPT NUMBER";
	EXTREF1 = "EXTREF1";
	EXTTRANSACTION = "EXTERNAL TRANSACTION";
	ServName = "UTRShip";
	LineName =  "UTRShip";
	ServName2 = "UTRRoad";
	LineName2 =  "UTRRoad";
	ServName3 = "UTTODO";
	LineName3 =  "UTTODO";
	TODOTASKDESC = "Palletised";
vars
	cargoId,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount, invLine1Amt, invLine2Amt, rate1, rate2		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti, cashTI1, onsiteTi1,onsiteTi2, origTI				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	draftReceiptNumber,
	finalReceiptNumber, idx	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt1, cashReceipt2 : CM_CashReceipt;
	cashPay : CM_CashPayment;
	type : CM_TerminalAreaType;
	blockStack1 : CM_BlockStack;
	effectTS : TimeStamp;
	newTiIds: StringArray;
	allTisToMerge, allTIsForTODO : CM_TISet;
	qty : Integer;
	wgt, vol : Decimal[23,6];
	tempID : String;
	invLine : CM_InvoiceLine;
	ctype : CM_CargoType;
	invType : CM_InvoiceDesc;
	taxCode : CM_TaxCode;
	invLineType1,invLineType2, invLineType3 : CM_InvoiceLineDesc;
	service : CM_Service;
	transType : CM_TransactionType;
	toDoTaskDesc : CM_ToDoTaskDesc;
	resourceType : CM_ResourceType;
	toDoTaskList : CM_ToDoTaskDescBySortKey;
	trxtTypeType : Integer;
	todotask : CM_ToDoTask;
	proxyResourceTypeUsage : CM_ResourceTypeUsage;
	tiTrx : CM_TITransaction;
	resourceUsageProxys 	: CM_ResourceTypeUsageSet;

begin
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	
	
	terminal := self.getMyTerminal();
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId",true);
	
	
	ctype := self.addCargoType("UTINV",false);
	
	
		type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");

	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	
	// create Services and invoiceLineReevaluate line types
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	self.deleteService(ServName2);
	self.deleteInvoiceLineType(LineName2,0);
	self.deleteService(ServName3);
	self.deleteInvoiceLineType(LineName3,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT03", LineName, null, invType); // CARGO VOLUME
	self.addIfNewServiceILD(ServName2, "CCT03", LineName2, null, invType); // CARGO VOLUME
	self.addIfNewServiceILD(ServName3, "CCT02", LineName3, null, invType); // RESOURCE QTY
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	invLineType1 := bank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	invLineType2 := bank.invoiceLineDescriptors[LineName2];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName2];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

	invLineType3 := bank.invoiceLineDescriptors[LineName3];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType3.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := bank.services[ServName3];		// RESOURCE QUANTITY
	self.setServiceRate(service, debtor, "01/01/2013".Date,10);

	
	transType := app.myRoot.allTransactionTypesByDesc["UTResTrans"];
	if transType &lt;&gt; null then
		trxtTypeType := transType.trxType;
	else
		trxtTypeType := app.myRoot.allTransactionTypes.last.trxType + 1;
	endif;
	
	transType := self.addTransactionType("UTResTrans", "CM_TaskComplete", trxtTypeType, TRANS_TYPE_GROUP_TI,true);
	self.assertTrueMsg(transType &lt;&gt; null, "Trans Type Is Null!");

	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", ctype);
	self.opts.addAssoc("TrxTypeOnCompletion", transType);
	
	
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");

	create toDoTaskList transient;
	toDoTaskList.add(toDoTaskDesc);	
	
	
	resourceType := app.myRoot.allTaskResourceTypes["UTPall"];
	if resourceType &lt;&gt; null then
		beginTransaction;
		resourceType.setPropertyValue("hasBeenUsed",false);
		commitTransaction;
		self.deleteResourceType("UTPall");
	endif;
		resourceType := self.addToDoTaskResource("UTPall",
											 "UT Pallet",
											 "PALL",
											 0,
											 false,
											 true,
											 toDoTaskList);
	self.assertNotNull(resourceType);
		
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(UseCashStatusAdvBGP, false);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	self.setTerminalConfig(CashRoadExitChkServices, true);
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	
	 // 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID' &amp; CrLf &amp; 
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,," &amp; CrLf &amp; 
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,Resource Mappings:UTPall,(Default),(Default) ›,(Default),,,**Any**,All,"  &amp; LineName3 &amp; CrLf &amp;
'Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,' &amp; LineName &amp; CrLf &amp;
"Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) ?,(Default),,,**Any**,All,"  &amp; LineName2;

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Release Road (plus Storage)
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	qty := 4;
	wgt := 16;
	vol := 8;
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",qty);
	self.opts.addAssoc("TotalWeight",wgt);
	self.opts.addAssoc("TotalVolume",vol);
	self.opts.addAssoc("CargoType",ctype.id);
	
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	effectTS := effectTS.addDays(-10);
	self.opts.purge();
	self.opts.addAssoc("EffectiveTimeStamp", effectTS);
	self.move(ti, blockStack1);
	
	self.assertTrueMsg(ti.locationId = "UT_BS1", " TI should be in block stack");
	self.assertTrueMsg(ti.isOnSite(), " TI should be in onsite");
	
	
	// ###### SPLIT
	cashTI1 := ti;
	origTI := cashTI1;
	create newTiIds transient;
	newTiIds.add(cargoId &amp; "-01");
	newTiIds.add(cargoId &amp; "-02");
	newTiIds.add(cargoId &amp; "-03");
	app.myTrxUA.trxSplitBreakBulkToNewID(	origTI.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											4,	// _weightOrVolume : Decimal;
											origTI.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 1 ");	
	

	create allTisToMerge transient;
	create allTIsForTODO transient;
	
	tempID := cargoId;
	cashTI1 := blockStack1.getTiById(tempID);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI0 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");

	invLine1Amt := 57.60;
	invLine2Amt := 3.9;
	rate1 := 28.8;
	rate2 := 8;
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, " cashTI0 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Split cashTI0 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt, "Merged cashTI0 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	allTIsForTODO.add(cashTI1);

	
	
	tempID := cargoId &amp; "-01";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI1 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI1 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI1 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI1 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI1 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI1 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-02";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI2 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI2 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI2 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI2 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI2 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI2 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI2 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI2 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = invLine1Amt,  tempID &amp; "  cashTI2 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	tempID := cargoId &amp; "-03";
	cashTI1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(cashTI1);
	allTIsForTODO.add(cashTI1);
	self.assertTrueMsg(cashTI1 &lt;&gt; null, tempID &amp; " cashTI3 is null");
	self.assertTrueMsg(cashTI1.totalQuantity = 1, tempID &amp; " cashTI3 QTY sbe 2");
	self.assertTrueMsg(cashTI1.totalVolume = 2, tempID &amp; " cashTI3 VOL sbe 2 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight= 4, tempID &amp; " cashTI3 WGT sbe 4 is " &amp; cashTI1.totalWeight.String);

	self.assertTrueMsg(cashTI1.invoiceLines.isNotEmpty(), tempID &amp; " cashTI3 should have invoice line");
	self.assertTrueMsg(cashTI1.invoiceLines.size = 1, tempID &amp; " cashTI3 should have 2 invoice lines");
	
	invLine := cashTI1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null,  tempID &amp; " cashTI3 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName,  tempID &amp; " Split cashTI3 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal =invLine1Amt,  tempID &amp; "  cashTI3 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	
	
	
	// ############### Add To DO TASK

	
	// ###### ADD TO DO TASK
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Palletised"];
	self.addToDoTask(toDoTaskDesc,allTIsForTODO);
	todotask := cashTI1.allToDoTasksToDo.first;
	self.assertTrueMsg(todotask &lt;&gt; null, toDoTaskDesc.description &amp; " not created on TI1");
	
	create resourceUsageProxys transient;
	foreach resourceType in toDoTaskDesc.allResourceTypes as CM_ResourceType do 
		create proxyResourceTypeUsage transient;
		proxyResourceTypeUsage.setProxy(	resourceType,					//_resourceType : CM_ResourceType;
											null,							//_transaction 	: CM_TITransaction;
											false,						    //_noCharge 	: Boolean;
											5.0,							//_quantity		: Decimal;
											resourceType.description,		//_remarks 		: String;
											CM_InvoiceLine.STATUS_NORMAL,	//_status 		: Integer;
											null, null,null,null,null);		
		resourceUsageProxys.add(proxyResourceTypeUsage);

	endforeach;
	
	self.completeToDoTask(toDoTaskDesc,allTIsForTODO , resourceUsageProxys);
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	
	// check trans and resources
	foreach onsiteTi2 in allTIsForTODO do
		tiTrx := onsiteTi2.allTransactions.last;
		self.assertTrueMsg(tiTrx &lt;&gt; null, "Transaction not created for " &amp; onsiteTi2.id &amp; " todo issue");
		self.assertTrueMsg( tiTrx.myToDoTask.toDoTaskDesc = toDoTaskDesc, 		"FAIL Completion of To Do Task '" 			  &amp; toDoTaskDesc.description &amp; "' for " &amp; onsiteTi2.id &amp; " to create transaction." );
		self.assertTrueMsg( tiTrx.allResourceUsages.size = toDoTaskDesc.allResourceTypes.size, toDoTaskDesc.description &amp; " Resource Count not correct" );
	
		self.assertTrueMsg(tiTrx.allInvoiceLines.isNotEmpty(),  toDoTaskDesc.description &amp;  " did not charge for " &amp; onsiteTi2.id);
		invLine := tiTrx.allInvoiceLines.first;
		self.assertTrueMsg(invLine &lt;&gt; null,  toDoTaskDesc.description &amp;  " no invoice line " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.invoiceLineDesc.narration = LineName3, toDoTaskDesc.description &amp;  " wrong invoice line type for " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.totalAmount = 50.00, "Merged OnsiteTi1 has wrong invoice total amount sbe 50.00 - 2.4SEA is " &amp; invLine.totalAmount.String);
	
	endforeach;	
	
	

	
	
	
	
	
	
	
	
	
	// ##### CASH create draft	
	voyCode := voyage.code;
	effectiveDate := effectiveDate.addDays(20);
	agentId := customagent.code;
		
	/*
	First, create a  draft receipt
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	cashReceipt1 := debtorTerminal.allCashReceipts[draftReceiptNumber];
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 12, "Cash receipt should have 12 payments");
	
	self.assertTrueMsg(cashReceipt1.cashValue = 660.80, "1. Total amount is not correct is " &amp; cashReceipt1.cashValue.String);
	self.assertTrueMsg(cashReceipt1.allTrackedItems.size = 4, "1. Cash Receipt should have 4 TIs, has " &amp; cashReceipt1.allTrackedItems.size.String);
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,4,5,7,8,10,11) then // SHIP RECEIVE and  TO DO TASK
			self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
			self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
			if idx.isOneOf(1,4,7,10) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 , "line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 57.6, "cash payment value &lt;&gt; 57.6 AAA");
			elseif idx.isOneOf(2,5,8,11) then // TO DO TASK
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType3 , "line type sbe invLineType3");
				self.assertTrueMsg(cashPay.cashValue = 50.0, "cash payment value &lt;&gt; 50.00 BBB");
			endif;
		else // ROAD RELEASE
			self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
			self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 , "line type sbe invLineType2");
			self.assertTrueMsg(cashPay.cashValue = 57.60, "cash payment value &lt;&gt; 57.60 CCCC");
		endif;
	
	idx += 1;
	endforeach;
	
	
	
	
	// SET TO HOLD (22)
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt1.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt1.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
