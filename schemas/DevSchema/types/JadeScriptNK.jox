    <JadeMethod name="findAutoVoyages" id="ed88077c-21e6-4c38-8a80-999e5a3e4275">
        <source>findAutoVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2024	navnk30	Initial creation

*/

vars
	voyage	: CM_Voyage;
	woTerm	: CM_Terminal;
begin
	woTerm := "2351.1564".asOid.CM_Terminal;
	foreach voyage in CM_Voyage.instances do
		if voyage.myVoyageProcess.isKindOf(CM_VoyageProcessAutomatic) then
			write voyage.code &amp; " " &amp; voyage.myTerminal.code;
			break;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForTblRow" id="efee08b5-1928-4437-b204-68484ed59912">
        <source>getDisplayStringForTblRow(
_ins: CM_InstructionsIssued): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2023	navnk30	Initial creation

*/

vars

begin
	return _ins.getParentType() &amp; Tab &amp;
			_ins.getInstructionDesc() &amp; Tab &amp;
			_ins.getInstructionCode() &amp; Tab &amp; 
			_ins.internalInstructions &amp; Tab &amp;
			_ins.externalInstruction;

epilog

end;</source>
        <Parameter name="_ins" type="CM_InstructionsIssued"/>
        <ReturnType type="String"/>
    </JadeMethod>
