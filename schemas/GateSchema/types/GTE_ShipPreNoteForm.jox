    <JadeMethod name="initForm" id="ecc02c2d-796d-44b6-8f27-e643eb9982aa">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------
// Created:	11 September 2003 By: cnwgd1
//--------------------------------------------------
// Changed on	By			Reason
// ----------	----------	------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars
	cmb     : ComboBox;
	port : String;
	thePort : CM_Port;
	int : Integer;
begin

		
	//self.doMnuEnhancedClick(not self.mnuEnhanced.checked);    //cnwas3 par 28400
	
	
	self.useTblDataContextMenu := false;
	self.allowDelete := false;
	self.allowPrint  	:= false;
	self.allowExportCSV	:= false;
	self.allowSearch := false;
	self.allowMultiSelectEdit := false;
	self.showFilterOnStartup := false;
	self.showDataOnStartup 	:= false;
	self.useProxyObject	:= false;
	self.isDataTableVisible	:= false;
	self.isThumbnailVisible	:= true;			

	self.cmbTransportMode.visible := false;
	self.lblTransportMode.visible := false;
	self.lastTransportMode := TI_TRANSMODE_SHIP;
	//self.viewTransportMode := app.getErrorString(BR_TYPE_DESCR_SHIP); // cnwrd1 par 18519 6.3.09	// PAR #27972
	self.viewTransportMode := BR_TYPE_SHIP_STR; // cnwrd1 par 18519 6.3.09							// PAR #27972
	
	// type can be global constants GTE_BookingRef_Parent (BR) or GTE_PreNote_Parent (PN)
	self.setType;

	tblExtra.setValueColumn(0, getSystemColor(Color_Window), false, false);
	
	beginLoad;
	
	self.initMainTable();
	self.initExtraTable();
	
	self.myAssistant.listTableDischarge(lstDischarge, null, null);
	self.myAssistant.resetHazardListTable(lstHazardList);	// CCMS 1203 JC
//	self.myAssistant.comboBoxOperator(cmbFiltOperator, null, null);

 	/*cmbCustomDetails.style := 0;
	cmbCustomDetails.useManualDropDown := true;
    cmb := cmbCustomDetails;
    self.myAssistant.comboBoxCustomDetails(cmb,null,null);*/
    
	self.txtQuantity.automaticCellControl := true;//cnwas3 par 23833
	self.myAssistant.comboBoxISOType(cmbCouISOType, null);
	self.doLoadIMEXStatuses();    
 
  	self.useTblData  := false;
  	self.useTblThumb := false;
 	
  	// Not interested in notes
  	self.endNotificationForSubscriber(self);
 
	self.initialMode := Mode_Add;
	self.setNavigatorHeading(self.caption);	

	self.doLoadStops();
	self.myAssistant.listTableToDoTasks(self.lstToDo, self.myTerminal);
	self.txtBookingRef.automaticCellControl := true; // dh 11/6/2008 par 16953
	self.cmbBRItem.automaticCellControl := true;	// dh 11/6/2008 par 16953
	self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, null, self.myTerminal); //15/04/2009 cnwdz2 ccms1735
	self.myAssistant.comboBoxConsignor(self.cmbConsignee, null, CONSIGNEE);			//+cnwml2 PAR25402
	
	//self.resetMeasurementRows(self.tblExtra);																						// PAR #31155
	//self.loadMeasurementTypes(self.tblExtra, self.tblExtra.myEntTableDef.name, self.tblExtra.myEntTableDef.allEntTableRows, true);	// PAR #31155

epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="51776e20-9575-49fc-9986-0062cb60f29b">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//cnwas3 par 28400

vars
	theXML, theXMLValue : String;	
	enhancedForm : Boolean;
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	theXML := _userWindow.xmlInfo;
	
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_EF);
 	enhancedForm := false;
 	if theXMLValue &lt;&gt; null then
 		enhancedForm := theXMLValue.Integer.Boolean;
 	endif; 	
	
 	self.btnEnhancedCargo.enabled := enhancedForm;
	self.mnuEnhanced.checked := enhancedForm;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
