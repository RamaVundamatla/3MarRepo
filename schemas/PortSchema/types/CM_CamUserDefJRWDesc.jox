    <JadeMethod name="xHandlerFile" id="9e9d194b-1bf4-4928-bc5f-6f22c2d68c7c">
        <source>xHandlerFile(_exceptionObj:FileException; _isFailed:Boolean io; _errorInfo:String io):Integer protected;
// --------------------------------------------------------------------------------
// Created:		27 August 2010 by cnwdad1
//
// Purpose:		This File Exception handler is implemeneted specifically to deal with
//				situations where, when creating a CAMS file directory, the location
//				is not available, such as where the location is on a network drive.
//
// Parameters:	_exceptionObj - A reference to the File Exception object.
//				_isFailed - A boolean flag that is returned to indicate there was an error.
//				_errorInfo - The details of the file error.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	details		: String;
	errorMsg	: String;
	causedBy	: String;
	nodeObj		: FileNode;
	
begin
	_isFailed	:=	true;
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	causedBy	:=	_exceptionObj.errorItem;
	nodeObj		:=	_exceptionObj.fileNode;
	
	details	:=	"'" &amp; nodeObj.fileName &amp; "' caused error " &amp; _exceptionObj.errorCode.String &amp; " (" &amp; errorMsg &amp; ")";
	
	if causedBy = null then
		details	:=	details &amp; ", the cause could not be identified.";
	else
		details	:=	details &amp; ", which was caused by '" &amp; causedBy &amp; "'.";
	endif;
	
	_errorInfo	:=	details;
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <Parameter name="_isFailed" type="Boolean" usage="io"/>
        <Parameter name="_errorInfo" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
