    <JadeMethod name="addHarbour" id="7ed8efb8-df34-4d5c-92d6-e29fbc9bf28e">
        <source>addHarbour(_harbourId, _harbourDesc: String) : HMS_Object;

/*

Purpose:		Add a Harbour

Date			Who		Reason
20/12/2011		cnwmh5	Initial creation

*/

vars

	pxyHarbour					: HMS_Harbour;
	harbourObj					: HMS_Object;
	harbour 					: HMS_Harbour;
	obj							: Object;
	
	terminalArray				: ObjectArray;

	index 						: Integer;
	
begin

	self.deleteHarbour(_harbourId);

	if self.opts.includesKey("IgnoreWarnings") then
		app.myPassport.setWarningsIgnored(self.opts.bool("IgnoreWarnings"));
	endif;
	
	
	create pxyHarbour transient;
	
	pxyHarbour.setProxy(app.myRoot);			// desription
	
	pxyHarbour.setPropertyValue("code", _harbourId);
	pxyHarbour.setPropertyValue("description", _harbourDesc);
		  
	app.myTrxCA.trxCreateHMSObject(pxyHarbour, harbourObj, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
			
	harbour := harbourObj.HMS_Harbour;
	
	if self.opts.includesKey("Terminals") then
		beginTransaction;
		terminalArray := self.opts.obj("Terminals").ObjectArray;
		foreach obj in terminalArray do
			harbour.allTerminalsByCode.add(obj.CM_Terminal);
		endforeach;
		commitTransaction;
	endif;
	
	beginTransaction;
	index := 5;
	while index &gt; 0 do
		harbour.defaultOrderTimesArrive.add(0);
		harbour.defaultOrderTimesDepart.add(0);
		harbour.defaultOrderTimesShift.add(0);
		index := index - 1;
	endwhile;
	commitTransaction;
	
	return harbourObj;

epilog
	delete pxyHarbour;
	
end;</source>
        <Parameter name="_harbourId" type="String"/>
        <Parameter name="_harbourDesc" type="String"/>
        <ReturnType type="HMS_Object"/>
    </JadeMethod>
    <JadeMethod name="addHarbourMovementPath" id="dd6ad4b1-ddfa-4e6f-8304-347fb3bd3d1b">
        <source>addHarbourMovementPath(_movementPathCode, _movementPathDesc : String; _pathSegmentArray : StringArray) : HMS_MovementPath;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars

	pxyMovementPath				: HMS_MovementPath;
	movementPath				: HMS_Object;
	fromRegion					: HMS_HarbourRegion;
	toRegion					: HMS_HarbourRegion;
	pathSegment					: HMS_PathSegment;
	
	pathSegmentStr				: String;
	
begin

	if _pathSegmentArray.isEmpty() then
		return null;
	endif;

	self.deleteHarbourMovementPath(_movementPathCode);
	
	create pxyMovementPath transient;
	
	pxyMovementPath.setPropertyValue('code', _movementPathCode);
	pxyMovementPath.setPropertyValue('description', _movementPathDesc);
	
	foreach pathSegmentStr in _pathSegmentArray do
		pathSegment := app.myRoot.allPathSegments[pathSegmentStr];
		if pathSegment &lt;&gt; null then
			pxyMovementPath.allPathSegments.add(pathSegment);	
		endif;
	endforeach;
	pxyMovementPath.allPathSegments.removeInvalidObjects();
	if pxyMovementPath.allPathSegments.isEmpty() then
		return null;
	endif;
	
	pathSegment := pxyMovementPath.allPathSegments.first.HMS_PathSegment;
	fromRegion := pathSegment.myRegionFrom;
	pathSegment := pxyMovementPath.allPathSegments.last.HMS_PathSegment;
	toRegion := pathSegment.myRegionTo;
	
	
	pxyMovementPath.setProxy(app.myRoot, 
							 fromRegion,
							 toRegion);

	app.myTrxCA.trxCreateHMSObject(pxyMovementPath, movementPath, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return movementPath.HMS_MovementPath;
							 
epilog

	delete pxyMovementPath;

end;

/*
vars
	pxyMovementPath	: HMS_MovementPath;
	tmpPathSegment 	: HMS_PathSegment;
	fromHarbourRegion,
	toHarbourRegion : HMS_HarbourRegion;
	theForm : SOP_HMS_TableMaintForm;
	fieldRoute : CMUI_FieldFrame;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_MovementPath transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyMovementPath := theForm.myProxyObject.HMS_MovementPath;
	theForm.tblInput1.setObjectFromTable(pxyMovementPath,null,false);
	
	pxyMovementPath.allPathSegments.clear();
	theForm.getSelected(pxyMovementPath.allPathSegments);
	pxyMovementPath.allPathSegments.removeInvalidObjects();		// cnwdad1 23/03/2007 - the last entry may be null because of how the maintenance form works.
		
	//
		
	/*if theForm.shtPathSegments.visible = true then
		pxyMovementPath.allPathSegments.clear();
		foreach fieldRoute in self.allRouteSegmentCtrls do
			if fieldRoute.visible and fieldRoute.getObject() &lt;&gt; null then
				pxyMovementPath.allPathSegments.add (fieldRoute.getObject().HMS_PathSegment);
			endif;
		endforeach;

	else
		pxyMovementPath.allPathSegments.clear();
		theForm.mulSelect1.getSelected(pxyMovementPath.allPathSegments);
		theForm.getSelected(pxyMovementPath.allPathSegments);
	endif;*/
	/*
	tmpPathSegment := pxyMovementPath.allPathSegments.last;
	
	if pxyMovementPath.allPathSegments.first &lt;&gt; null then
		fromHarbourRegion	:= pxyMovementPath.allPathSegments.first.myRegionFrom;
	endif;
	if tmpPathSegment &lt;&gt; null then
		toHarbourRegion		:= pxyMovementPath.allPathSegments.last.myRegionTo;
	endif;
	
	if tmpPathSegment = null then
		pxyMovementPath.setProxy(app.myRoot, fromHarbourRegion, null);
//		pxyMovementPath.setProxy(app.myRoot, theForm.cmbRegionSource.listObject.HMS_HarbourRegion, null);
	else
		pxyMovementPath.setProxy(app.myRoot, fromHarbourRegion, toHarbourRegion);
//		pxyMovementPath.setProxy(app.myRoot, theForm.cmbRegionSource.listObject.HMS_HarbourRegion, tmpPathSegment.myRegionTo);
	endif;

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyMovementPath, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyMovementPath, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;
*/</source>
        <Parameter name="_movementPathCode" type="String"/>
        <Parameter name="_movementPathDesc" type="String"/>
        <Parameter name="_pathSegmentArray" type="StringArray"/>
        <ReturnType type="HMS_MovementPath"/>
    </JadeMethod>
    <JadeMethod name="addHarbourMovementShift" id="685440a7-442f-4983-90d9-b867251e62e4">
        <source>addHarbourMovementShift(_occursOnDT : TimeStamp; _voyage : CM_Voyage; _berth : HMS_Berth);
/*
Purpose:			
Date		Who		Reason
09 January 2015	cnwab1	Initial creation
30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars
	pxyMovement, departMovement : HMS_VoyageMovement;
	realMovement : HMS_Object;
	aftClearanceFrom			: Decimal[9,2];
	aftClearanceTo				: Decimal[9,2];
	bowMarkTo					: Decimal[9,2];
	sternMarkTo					: Decimal[9,2];
	foreClearanceFrom			: Decimal[9,2];
	foreClearanceTo				: Decimal[9,2];
	locationPilotLaunch			: Integer;
	locationTug					: Integer;
	numContractTugs				: Integer;
	moveStatus					: Integer;
	numLineCrewRequired			: Integer;
	relativeOrderTimeLines		: Integer;
	relativeOrderTimePlaunch	: Integer;
	relativeOrderTimeTugs		: Integer;
	sideTo						: Integer;
	draftFwd					: Real;
	draftAft					: Real;	
	moveType					: String; 
	remarks						: String; 
	shipsMaster					: String; 
	occursOnDT					: TimeStamp;
	chargeForMove				: Boolean; 
	isAgentDefault				: Boolean; 
	overlapsWharfSection		: Boolean; 
	pilotExempt					: Boolean; 
	myPilot						: HMS_Pilot;
	myPilotLaunch				: HMS_PilotLaunch; 
	myLineCompany				: HMS_LineCompany; 
	myShippingAgent				: CM_ShippingAgent;
	myShippingLine				: CM_ShippingLine; 
	myContact					: CM_EmailAddress2; 
	myBerth						: HMS_Berth; 
	myTidalClass				: HMS_TidalClass;
	myMaster					: HMS_Master;
	prevMoveObj					: HMS_Movement;
	myHarbour : HMS_Harbour;
	//allPilots : HMS_PilotByCodeDict; // TFS 44438 after 040 cut/release
	allMovementPilotDetails		: HMS_MovementPilotDetailsSet; // TFS 44438
begin
	self.assertTrueMsg(_voyage &lt;&gt; null,"Voyage has no HMS data");

	self.assertTrueMsg(_voyage.myHMSVoyageData &lt;&gt; null, "Voyage has no HMS data");
	
	departMovement := _voyage.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);

	self.assertTrueMsg(departMovement &lt;&gt; null,"Voyage has no departure movement");
	
	aftClearanceFrom := ClearanceUnbounded;
	aftClearanceTo:= ClearanceUnbounded;
	bowMarkTo := 155;
	sternMarkTo := 255;
	foreClearanceFrom := 0;
	foreClearanceTo := 0;
	locationPilotLaunch := null;
	locationTug := null; 
	numContractTugs := 0;
	moveStatus := MovementStatus_Actual;
	numLineCrewRequired := 0;
	relativeOrderTimeLines := 0;
	relativeOrderTimePlaunch := 0;
	relativeOrderTimeTugs := 0;
	sideTo := OrientPortSideTo; 
	draftFwd := 0;
	draftAft := 0;
	moveType := HMSMovementTypeShift; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	remarks := ""; 
	shipsMaster := "";
	occursOnDT := _occursOnDT;
	chargeForMove:= true; 
	isAgentDefault := false;
	overlapsWharfSection := false;
	pilotExempt := true;
//	myPilot := departMovement.myPilot;
	myMaster := departMovement.myMaster;
	//myPilotLaunch := departMovement.myPilotLaunch; // TFS 44438 after 040 cut/release
	myLineCompany := departMovement.myLineCompany;
	myShippingAgent := departMovement.myShippingAgent;
	myShippingLine := departMovement.myShippingLine;
	myContact := departMovement.myContact;
	myBerth := _berth;
	myTidalClass := departMovement.myTidalClass;
	myHarbour := _voyage.myHMSVoyageData.myHarbour;
	
	//31 Oct 2018	NDL	TFS 41662
	/*myPilot := null; // --&gt; TFS 44438 after 040 cut/release
	create allPilots transient;
	if not departMovement.allPilots.isEmpty then
		 departMovement.allPilots.copy( allPilots );
	endif;
	if departMovement.getUnConvertedMyPilotRef &lt;&gt; null then
		allPilots.addNoDuplicates( departMovement.getUnConvertedMyPilotRef, false );
	endif;*/ // &lt;-- TFS 44438 after 040 cut/release

	create allMovementPilotDetails transient; // --&gt; TFS 44438
	if departMovement.allMovementPilotDetails &lt;&gt; null then
		departMovement.allMovementPilotDetails.copy(allMovementPilotDetails); // most likely need proxies here...
	endif; // &lt;-- TFS 44438
	
	create pxyMovement transient;
	
	pxyMovement.setProxy(aftClearanceFrom,
						aftClearanceTo,
						bowMarkTo,
						sternMarkTo,
						foreClearanceFrom,
						foreClearanceTo,
						locationPilotLaunch,
						locationTug, 
						numContractTugs, 
						moveStatus, 
						numLineCrewRequired, 
						relativeOrderTimeLines, 
						relativeOrderTimePlaunch,
						relativeOrderTimeTugs, 
						sideTo, 
						draftFwd, 
						draftAft,
						moveType, 
						remarks, 
						shipsMaster,
						occursOnDT,
						chargeForMove, 
						isAgentDefault, 
						overlapsWharfSection, 
						pilotExempt,
						myPilot,
						myMaster,
						myPilotLaunch,
						myLineCompany,
						myShippingAgent,
						myShippingLine,
						myContact,
						myBerth,
						myTidalClass,
						myHarbour,
						//allPilots,	//_allPilots : HMS_PilotByCodeDict // TFS 44438 after 040 cut/release
						allMovementPilotDetails // TFS 44438
						);


	pxyMovement.setMyHMSVoyageData(_voyage.myHMSVoyageData);

	app.myTrxCA.trxCreateHMSMovement(pxyMovement, realMovement, app.myPassport);

	self.assertNoTrxErrorsPassport("Add SHIFT movement issues &gt;&gt;&gt;");
	
	
epilog
	delete pxyMovement;
	//delete allPilots; // TFS 44438 after 040 cut/release
	delete allMovementPilotDetails; // TFS 44438
end;</source>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="addHarbourPathSegment" id="bc3642cc-f0a5-41de-8877-31fc18f313a8">
        <source>addHarbourPathSegment(_pathSegmentCode, _pathSegmentDesc, _from, _to : String; _steamingAToB : Integer; _harbour : HMS_Harbour) : HMS_PathSegment;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars

	pxyPathSegment			: HMS_PathSegment;
	pathSegment				: HMS_PathSegment;
	harbourRegion			: HMS_HarbourRegion;

begin

	self.deletePathSegment(_pathSegmentDesc);

	create pxyPathSegment transient;
	pxyPathSegment.setProxy(app.myRoot, 
							_harbour);
							
	
	pxyPathSegment.setPropertyValue('code', _pathSegmentCode);
	pxyPathSegment.setPropertyValue('description', _pathSegmentDesc);
	pxyPathSegment.setPropertyValue('steamingTimeAB', _steamingAToB);
		
	if _from &lt;&gt; null then
		harbourRegion := app.myRoot.allHMSHarbourRegions[_from];
		if harbourRegion &lt;&gt; null then
			beginTransaction;
			pxyPathSegment.setPropertyValue("myRegionFrom", harbourRegion);
			commitTransaction;
		endif;
	endif;
	
	if _to &lt;&gt; null then
		harbourRegion := app.myRoot.allHMSHarbourRegions[_to];
		if harbourRegion &lt;&gt; null then
			beginTransaction;
			pxyPathSegment.setPropertyValue("myRegionTo", harbourRegion);
			commitTransaction;
		endif;
	endif;
	
	app.myTrxCA.trxCreatePathSegement(pxyPathSegment, pathSegment, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return pathSegment;

epilog

	delete pxyPathSegment;

end;</source>
        <Parameter name="_pathSegmentCode" type="String"/>
        <Parameter name="_pathSegmentDesc" type="String"/>
        <Parameter name="_from" type="String"/>
        <Parameter name="_to" type="String"/>
        <Parameter name="_steamingAToB" type="Integer"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="HMS_PathSegment"/>
    </JadeMethod>
    <JadeMethod name="addHarbourResource" id="9431f1de-4b34-4125-a275-75bdfa3cfab0">
        <source>addHarbourResource(_resourceCode, _resourceDesc : String; _harbour : HMS_Harbour; _resourceType : HMS_ResourceType; _wharf : HMS_Wharf; 
		_startPosAlongWharf, _endPosAlongWharf : Integer; notAvailable : Boolean) : HMS_Resource;

/*

Purpose:		Add Harbour Resource	

Date			Who		Reason
01/02/2012		cnwmh5	Initial creation

*/

vars

	pxyResource				: HMS_Resource;
	resource 				: HMS_Resource;

begin

	self.deleteHarbourResource(_resourceCode, _harbour);

	create pxyResource transient;
	pxyResource.setProxy(_harbour, _wharf, null);
	pxyResource.setPropertyValue("code", _resourceCode.toUpper.trimBlanks); 			
	pxyResource.setPropertyValue("description", _resourceDesc);
	pxyResource.setPropertyValue("endPosnAlongWharf", _endPosAlongWharf);
	pxyResource.setPropertyValue("startPosnAlongWharf", _startPosAlongWharf);
	pxyResource.setPropertyValue("myResourceType", _resourceType);
	
	app.myTrxCA.trxCreateHMSResource(pxyResource, resource, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return resource;
	
epilog

	delete pxyResource;
	
end;</source>
        <Parameter name="_resourceCode" type="String"/>
        <Parameter name="_resourceDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <Parameter name="_startPosAlongWharf" type="Integer"/>
        <Parameter name="_endPosAlongWharf" type="Integer"/>
        <Parameter name="notAvailable" type="Boolean"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="addHarbourResourceUsed" id="2a6d84dd-f718-4cb3-b08f-7b6c2e45f3c2">
        <source>addHarbourResourceUsed(_harbour : HMS_Harbour; _resourceType : HMS_ResourceType);

vars

	proxy : HMS_ResourceUsed;
begin
	
	create proxy transient;
	//proxy.setProxy(_harbour, _resourceType, resource, pxyVTMISTrans, fromDateTime, toDateTime, unitsUsed, poc);

end;
</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="addHarbourRouteTemplate" id="384e73bf-7bd6-4b9a-babe-b434130842a3">
        <source>addHarbourRouteTemplate(_routeTemplateCode, _routeTemplateDesc : String; _allRegions : HMS_HarbourRegionArray) : HMS_RouteTemplate;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars

	pxyRouteTemplate			: HMS_RouteTemplate;
	routeTemplate				: HMS_RouteTemplate;


begin

	self.deleteHarbourRouteTemplate(_routeTemplateCode);

	create pxyRouteTemplate transient;
	pxyRouteTemplate.setProxy(_routeTemplateCode,
							  _routeTemplateDesc,
							  _allRegions,
							  app.myRoot);
							  
	app.myTrxCA.trxCreateRouteTemplate(pxyRouteTemplate, routeTemplate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return routeTemplate;							  

epilog

	delete pxyRouteTemplate;

end;</source>
        <Parameter name="_routeTemplateCode" type="String"/>
        <Parameter name="_routeTemplateDesc" type="String"/>
        <Parameter name="_allRegions" type="HMS_HarbourRegionArray"/>
