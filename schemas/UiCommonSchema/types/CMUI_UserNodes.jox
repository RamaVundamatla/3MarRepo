    <JadeMethod name="locksGraphDisplay" id="2d2ca5b8-e976-4a04-88aa-fb10cf4562ae">
        <updating/>
        <source>locksGraphDisplay() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	trxn		: CM_LockTransaction;
	tmpDict		: CM_LockTransactionByLockDTDict;
	iter		: Iterator;
	dateFrom,
	dateTo,
	trxnDate,
	currentDate	: Date;
	tsKey		: TimeStamp;
	totalNumLocks,
	numLocks,
	currentColor,
	currentHour,
	tmpViewLocksMode,
	trxnHour		: Integer;
	currentDateStr	: String;
	
begin

	if (not self.locksValidateForDisplay(dateFrom, dateTo)) then
		return;
	endif;
	
	tmpViewLocksMode := self.viewLocksMode;
	
	tmpDict := self.myGlobalProcessRoot.allLockTransactions;

	iter := tmpDict.createIterator;
	tmpDict.startKeyGeq(dateFrom.TimeStamp, iter);
	
	currentDate := null;
	currentHour := null;
	currentColor := self.graphColor1;
	
	self.grfLocks.clearGraph;
	
	if tmpViewLocksMode = self.ViewLocksBy_GraphDay then
		self.grfLocks.init(app.getErrorString2(CMUI_LocksGraphHeading, dateFrom.shortFormatJMT(), dateTo.shortFormatJMT()),
							app.getErrorString(DateStr), app.getErrorString(CMUI_UserNodesNoExceptions));
	else
		self.grfLocks.init(app.getErrorString2(CMUI_LocksGraphHeading, dateFrom.shortFormatJMT(), dateTo.shortFormatJMT()),
							app.getErrorString(CMUI_UserNodes_TimeDate), app.getErrorString(CMUI_UserNodesNoExceptions));
	endif;
	beginLoad;
	
	while iter.next(trxn) do
		tmpDict.getIteratorKeys(tsKey, iter);
		trxnDate := tsKey.date;
		if trxnDate &gt; dateTo then
			break;
		endif;
		
		if tmpViewLocksMode = ViewLocksBy_GraphHour then
			trxnHour := tsKey.Time.hour;
		endif;
		
		if currentDate = null then
			// first time
			currentDate := trxnDate;
			currentDateStr := currentDate.shortFormatJMT();

			if tmpViewLocksMode = ViewLocksBy_GraphHour then
				// need to add values up till trxnHour
				currentHour	:= 1;
				while currentHour &lt; trxnHour do
					self.addValueToGraph(currentHour.String, currentDateStr, numLocks, currentColor);
					currentHour := currentHour + 1;
					currentDateStr := null;		// only output for the first hour of each day
				endwhile;
			else
				currentHour := trxnHour;
			endif;

		elseif currentDate &lt;&gt; trxnDate then
			
			if tmpViewLocksMode = ViewLocksBy_GraphDay then
				self.addValueToGraph(currentDateStr, null, numLocks, currentColor);
			else
				// need to add values up till end of day
				while currentHour &lt;= 24 do
					self.addValueToGraph(currentHour.String, currentDateStr, numLocks, currentColor);
					currentHour := currentHour + 1;
				endwhile;
				currentHour := 1;
			endif;

			currentDate := currentDate + 1;
			currentDateStr := currentDate.shortFormatJMT();
			
			while currentDate &lt; trxnDate do
				if tmpViewLocksMode = ViewLocksBy_GraphDay then
					self.addValueToGraph(currentDateStr, null, numLocks, currentColor);
				else
					currentHour := 1;
					while currentHour &lt;= 24 do
						self.addValueToGraph(currentHour.String, currentDateStr, numLocks, currentColor);
						currentHour := currentHour + 1;
						currentDateStr := null;
					endwhile;
				endif;
				currentDate := currentDate + 1;
				currentDateStr := currentDate.shortFormatJMT();
				currentHour := 1;
			endwhile;
			
		elseif tmpViewLocksMode = ViewLocksBy_GraphHour and
				trxnHour &lt;&gt; currentHour then
			self.addValueToGraph(currentHour.String, currentDateStr, numLocks, currentColor);

			currentHour := currentHour + 1;
			while currentHour &lt; trxnHour do
				self.addValueToGraph(currentHour.String, currentDateStr, numLocks, currentColor);
				currentHour := currentHour + 1;
				currentDateStr := null;
			endwhile;

			currentHour := trxnHour;
				
		endif;
		
		numLocks := numLocks + 1;
		totalNumLocks := totalNumLocks + 1;
		
	endwhile;
	
	if currentDate &lt;&gt; null then
		// we found some data
		if tmpViewLocksMode = ViewLocksBy_GraphDay then
			self.grfLocks.addValue(currentDateStr, null, numLocks, currentColor);
		else
			self.grfLocks.addValue(currentHour.String, currentDateStr, numLocks, currentColor);
		endif;
	endif;
	
	if tmpViewLocksMode = ViewLocksBy_GraphDay then
		self.grfLocks.useXAxisLabelLine2 := false;
	else
		self.grfLocks.useXAxisLabelLine2 := true;
	endif;

	self.grfLocks.drawGraph();

	staMain.caption := app.getErrorString1(CMUI_UserNodes_LocksStatusLine, totalNumLocks.String);

epilog
	endLoad;
	delete iter;		// PAR #26678
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="locksInit" id="82e5db01-b726-4be9-9efa-9e54ad597f88">
        <updating/>
        <source>locksInit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	today	: Date;
	
begin
	today := app.actualTimeServer.date();
	
	self.txtDateFrom.setDate(today - 6);
	self.txtDateTo.setDate(today);
	
	self.grfLocks.maxBarWidth := 100;
	
	self.initViewLocksBy();
	self.locksGraphDisplay();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="locksPrintDeveloper" id="036505f4-d39e-4f3e-8071-c16ad5620358">
        <source>locksPrintDeveloper(_selectedOnly : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     Prints the selected data for developer (with stack dump info)
// ---------------------------------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	theReport 	: CMUI_LockTransactionReport;
	now			: TimeStamp;
	trans		: CM_LockTransaction;
	tmpReport 	: JadeReport;
	transArray	: CM_LockTransactionArray;
	numRows,
	idx			: Integer;
	jadeRow		: JadeTableRow;	
begin

	if app.msgBox('Output as CSV', '', MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.doExportCSV();
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	create transArray transient;
	numRows := tblLocks.rows;
	
	// to this way so that we print out in the
	// same order as the data is currently displayed
	
	foreach idx in tblLocks.fixedRows + 1 to numRows do
		jadeRow := tblLocks.accessRow(idx);
		if _selectedOnly then
			if jadeRow.selected then
				transArray.add(jadeRow.itemObject.CM_LockTransaction);
			endif;
		else
			transArray.add(jadeRow.itemObject.CM_LockTransaction);
		endif;
	endforeach;
	
	create tmpReport transient;
	app.printer.printPreview := false;
	app.printer.setMargins(Print_Portrait,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);

	create theReport transient;
	// setup header information
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	theReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	theReport.lblMainHeading.caption := 'Lock Exceptions from ' &amp; txtDateFrom.getDate().shortFormatJMT() &amp; ' to ' &amp; txtDateTo.getDate().shortFormatJMT();
	theReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.date.String &amp; ", " &amp; now.time.format("H:mm").String;
	// set header
	app.printer.setHeader(theReport.frmHeader);
	app.printer.setFooter(null);
	theReport.printReport(transArray);

	app.printPreview(tmpReport, true);

epilog
	app.printer.close;
	app.mousePointer := MousePointer_Default;
	delete theReport;
	delete transArray;
end;</source>
        <access>protected</access>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="locksTableDisplay" id="447885f7-b954-494b-a43b-fb52a906e53f">
        <updating/>
        <source>locksTableDisplay() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	trxn		: CM_LockTransaction;
	tmpDict		: CM_LockTransactionByLockDTDict;
	iter		: Iterator;
	dateFrom,
	dateTo,
	trxnDate	: Date;
	numLocks,
	rowColor1,
	rowColor2,
	currentColor,
	idx			: Integer;
	tsKey		: TimeStamp;
	tmpStr		: String;
	
begin

	if (not self.locksValidateForDisplay(dateFrom, dateTo)) then
		return;
	endif;
	
	tmpDict := self.myGlobalProcessRoot.allLockTransactions;

	iter := tmpDict.createIterator;
	tmpDict.startKeyGeq(dateFrom.TimeStamp, iter);
	
	currentColor := self.colorRow1;
	
	self.tblLocks.rows := self.tblLocks.fixedRows;
	
	rowColor1	:= self.colorRow1;
	rowColor2	:= self.colorRow2;
	currentColor	:= rowColor1;

	beginLoad;
	
	while iter.next(trxn) do
		tmpDict.getIteratorKeys(tsKey, iter);
		trxnDate := tsKey.date;
		if trxnDate &gt; dateTo then
			break;
		endif;
		
		tmpStr := trxn.getAttributeStringForDefArray(self.tblLocks.allTblDataEntRows);
		
		if currentColor = rowColor1 then
			currentColor	:= rowColor2;
		else
			currentColor	:= rowColor1;
		endif;

		idx := self.tblLocks.addItemObject(trxn, tmpStr);
		self.tblLocks.accessRow(idx).backColor := currentColor;
		
		numLocks := numLocks + 1;
		
	endwhile;

	staMain.caption := app.getErrorString1(CMUI_UserNodes_LocksStatusLine, numLocks.String);
	
epilog
	endLoad;
	delete iter;		// PAR #26678
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="locksTableInit" id="fddf7198-4bab-4db0-ad3c-7608272821b2">
        <source>locksTableInit() protected;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpTbl	: CM_DataTable;
	
begin

	tmpTbl := self.tblLocks;

	tmpTbl.selectionType 	:= Table.SelectMode_FixedRow;
	tmpTbl.autoSize			:= Table.AutoSize_Column;
	
	if self.isDeveloper then
		tmpTbl.multiSelect := CM_DataTable.MultiSelect_Simple;
	endif;
	
	tmpTbl.left				:= 0;
	tmpTbl.stretchWidth		:= true;
	tmpTbl.stretchHeight	:= true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="locksValidateForDisplay" id="27c4f82a-2f6e-407f-a487-6e4ec237022e">
        <updating/>
        <source>locksValidateForDisplay(_dateFrom, _dateTo : Date output) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myGlobalProcessRoot = null then
		// attempt to set this
		self.myGlobalProcessRoot := CM_GlobalProcessRoot.firstInstance;
		if self.myGlobalProcessRoot = null then
			// need to use Lock Manager message
			self.grfLocks.setAndShowGraphTitle(app.getErrorString(CMUI_UserNodesNoLocksRecorded));
			return false;
		endif;
	endif;

	_dateFrom := txtDateFrom.getDate();
	_dateTo := txtDateTo.getDate();
	
	if _dateFrom = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Date_From), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Date_From), null, null); // cnwdb2	PAR 35364
		txtDateFrom.setFocus();
		return false;
	endif;

	if _dateTo = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Date_To), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Date_To), null, null); // cnwdb2	PAR 35364

		txtDateTo.setFocus();
		return false;
	endif;
	
	if _dateTo &lt; _dateFrom then
		// date from error
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Date_From), app.getErrorString(Date_To), null, null);
		txtDateFrom.setFocus();
		return false;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_dateFrom" type="Date" usage="output"/>
        <Parameter name="_dateTo" type="Date" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
