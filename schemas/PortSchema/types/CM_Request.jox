    <JadeMethod name="getVoyageAllocCCAttributes" id="cbb3ad49-a6b5-403a-a505-af3b0f54e501">
        <source>getVoyageAllocCCAttributes(_allVoyageAllocCCAttributes : CMIF_VoyageAllocCCAttrDict input) : CMIF_VoyageAllocCCAttributes;
/*

Date		Who		Reason
21 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	voyageAllocation  : CM_VoyageAllocation;
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
begin
	if  not self.getUseVoyageAllocations then
		return null;
	endif;
		
	voyageAllocation:=self.getVoyageAllocations().first.CM_VoyageAllocation;
	if voyageAllocation &lt;&gt; null then
		voyageAllocCCAttributes:= _allVoyageAllocCCAttributes[voyageAllocation];
		if voyageAllocCCAttributes = null then
			create voyageAllocCCAttributes transient;
			voyageAllocCCAttributes.setLengthAttributes(voyageAllocation); //only need lenght of ti stats
			_allVoyageAllocCCAttributes.add(voyageAllocCCAttributes);
		endif;	
		return voyageAllocCCAttributes;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_allVoyageAllocCCAttributes" type="CMIF_VoyageAllocCCAttrDict" usage="input"/>
        <ReturnType type="CMIF_VoyageAllocCCAttributes"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocationGroupDesc" id="eca5ca77-9ec1-443f-bc72-49a7cf9b27a4">
        <source>getVoyageAllocationGroupDesc(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2012	cnwer1	Initial creation Par 28967

*/

vars
	desc : String;	
	criteria : CM_YACriteria;
	iso : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	cargoType : CM_CargoType;
begin
	criteria := self.getAttrByType(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		isoGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup;
	endif;

	if isoGroup = null then
		criteria := self.getAttrByType(YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			iso := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType;
			if iso &lt;&gt; null then
				isoGroup := iso.myISOTypeGroup;
			endif;
		endif;
	endif;
	
	//epr par 28967 if it doesn't have a iso/iso group must not be a Container use the cargo type
	if isoGroup = null and iso = null then
		criteria := self.getAttrByType(YACriteriaType_CargoType);
		if criteria &lt;&gt; null then
			cargoType := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
		endif;
		
		if cargoType = null then
			desc := "???";
		else
			desc := cargoType.abbreviation;
		endif;
	else
		if isoGroup = null then
			desc:="???";
		else
			desc := isoGroup.code;
		endif;
	endif;
	
	if self.getAttrPowerRequired() then
		desc := desc &amp; ' ' &amp; app.getErrorString(SummaryDesc_Integral);
	endif;
	if self.getAttrEmpty() then
		desc := desc &amp; ' ' &amp; app.getErrorString(SummaryDesc_Empty);
	endif;				
	
	return desc;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
