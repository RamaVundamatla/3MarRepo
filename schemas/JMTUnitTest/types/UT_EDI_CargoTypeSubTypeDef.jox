    &lt;voyageCode&gt;'&amp;voyageName&amp;'&lt;/voyageCode&gt;
	&lt;AllBOLDetails&gt;
    &lt;BOLDetails&gt;
      &lt;consignee&gt;KOTAHI LOGISTICS LP LIMITED&lt;/consignee&gt;
      &lt;height&gt;12.0000&lt;/height&gt;
      &lt;length&gt;13.0000&lt;/length&gt;
      &lt;volume&gt;0.0005&lt;/volume&gt;
