    <JadeMethod name="containsSubstring" id="f3d41bb9-40e4-41d5-8c76-79fef335dff4">
        <source>containsSubstring(searchText:String; locale : CM_Locale):Boolean;

// linear search,  replaced by keyword search

vars
	translation : XLAT_Translation;
begin
	foreach translation in allTextByLocale do
		if locale = null or 								// any locale
		   translation.myLocale = locale 					// selected locale
		then
			if translation.containsSubstring(searchText) 	// selected text
			then
				return true;
			endif;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="searchText" type="String"/>
        <Parameter name="locale" type="CM_Locale"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
