        <source>setupMyDriver() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	conkc1	Initial creation

*/

vars

begin
	if self.txtDriver.text.trimBlanks = null then
		self.myDriver := null;
	endif;
	
	self.myDriver := self.txtDriver.text.trimBlanks;
epilog

end;</source>
    </JadeMethod>
