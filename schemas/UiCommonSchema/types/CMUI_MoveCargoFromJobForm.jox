    <JadeMethod name="doInspectObject" id="e761c344-2770-4d88-9dfc-962b25141dae">
        <source>doInspectObject();
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	table : CM_DataTable;
begin
	table := self.tblCargoList;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		table.accessRow(table.row).itemObject.inspect;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="4e38a964-7a6b-4fd3-8f81-8840873db922">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
vars
	voyageWLE : CM_VoyageWLE;
	rowIdx : Integer;
	tbl : CM_DataTable;
	requests : CM_RequestSet;
	result : Integer;
	selectAll : Boolean;
begin
	

	tbl := self.tblCargoList;
	
	create requests transient;
	
	if self.myVoyageJob = null or self.cmbJob.listObject = null then
		return;  //something wasn't populated.  can't continue
	endif;	
	
	if self.myVoyageJob = self.cmbJob.listObject then
		return;  //no new job selected
	endif;
	
	if tbl.selectedCount = 0 then
		if app.msgBox(app.getErrorString(WLES_MOVE_ALL),"",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			selectAll := true;
		endif;
	endif;
	
	foreach rowIdx in 1 to tbl.rows do
		if CM_VoyageWLE.hasInstance(tbl.accessRow(rowIdx).itemObject) then
			if tbl.accessRow(rowIdx).selected or selectAll then
				voyageWLE := tbl.accessRow(rowIdx).itemObject.CM_VoyageWLE;
				requests.add(voyageWLE.myRequest);
			endif;
		endif;
	endforeach;
	
	if requests.size &gt; 0 then
		while true do
			app.myTrxUA.trxTransferCompletedJobs(self.myVoyageJob,self.cmbJob.listObject.CM_VoyageJob,requests,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					app.mousePointer := MousePointer_HourGlass;
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					// only reprocess the jobs that had warnings.
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;			
		endwhile;
	endif;
	
	inheritMethod();
epilog
	delete requests;
end;	
</source>
    </JadeMethod>
    <JadeMethod name="doSort" id="7dc221b7-d947-478c-a9bd-51275c7ba49b">
        <source>doSort();
// --------------------------------------------------------------------------------
// Created:		01 September 2010 by cnwjo3
//
// Purpose:		set the column to sort.  At the moment we only have 1 sort column
//
vars
	tbl : CM_DataTable;
begin
	tbl := self.tblCargoList;
	tbl.sortAsc[1] := true;
	tbl.sortColumn[1] := tbl.getColumnByRowName(ETRow_SeqNumAsString);
	tbl.sortType[1]:=Table.SortType_Numeric;
	tbl.resort();
	tbl.accessSheet(1).displaySorting := Table.DisplaySorting_AllColumns;
end;</source>
    </JadeMethod>
