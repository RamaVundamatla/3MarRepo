<Class name="CM_StopsTable">
    <JadeMethod name="exportPDXMLMyCollections" id="94351038-486a-4f3e-b384-04e389a071a3">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details

vars
	obj: Object;
	criteria : CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
begin
	//if _property.name = CM_StopsTable::allCargoTypesNew.name then			//20 Jul 2022	navsj20	TFS 53862
	if _property.name = CM_StopsTable::myStopCriteria.name then				//20 Jul 2022	navsj20	TFS 53862
		//_file.writeLine('&lt;'&amp;CM_StopsTable::allCargoTypesNew.name&amp;'&gt;');	//20 Jul 2022	navsj20	TFS 53862
		_file.writeLine('&lt;'&amp;CM_StopsTable::myStopCriteria.name&amp;'&gt;');		//20 Jul 2022	navsj20	TFS 53862
		if self.myStopCriteria &lt;&gt; null then 								//20 Jul 2022	navsj20	TFS 53862
			foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	//27 Jul 2022	navsj20	TFS 53862
				foreach obj in criteria.myYAData.CM_YADataObjects.allObjects do	//27 Jul 2022	navsj20	TFS 53862
					_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
					_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
				endforeach;
			endforeach;			//27 Jul 2022	navsj20	TFS 53862
		endif;																//20 Jul 2022	navsj20	TFS 53862
		//_file.writeLine('&lt;/'&amp;CM_StopsTable::allCargoTypesNew.name&amp;'&gt;');	//20 Jul 2022	navsj20	TFS 53862
		_file.writeLine('&lt;/'&amp;CM_StopsTable::myStopCriteria.name&amp;'&gt;');		//20 Jul 2022	navsj20	TFS 53862
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="f5aa6382-a5dc-484a-af95-5c4b34f389a0">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);
//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
vars
	proxyArray: ObjectArray;
	newObject: Object;
	criteria	: CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
begin
	create proxyArray transient;
	//if _name = CM_StopsTable::allCargoTypesNew.name then	//20 Jul 2022	navsj20	TFS 53862
	if _name = CM_StopsTable::myStopCriteria.name then		//20 Jul 2022	navsj20	TFS 53862
		self.importPLXMLOldDictWorkerInt(_collectionsBlock, _name, self.myRoot.allCargoTypesById, proxyArray);
		foreach newObject in proxyArray do
			//self.allCargoTypesNew.add(newObject.CM_CargoType);	//20 Jul 2022	navsj20	TFS 53862
			if self.myStopCriteria &lt;&gt; null then 					//20 Jul 2022	navsj20	TFS 53862	
				foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	//27 Jul 2022	navsj20	TFS 53862
					criteria.myYAData.CM_YADataObjects.allObjects.add(newObject.CM_CargoType);	//20 Jul 2022	navsj20	TFS 53862
				endforeach;																												//27 Jul 2022	navsj20	TFS 53862
			endif;													//20 Jul 2022	navsj20	TFS 53862
		endforeach;
	endif;
epilog
	delete proxyArray;
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="8a30e9e4-0ee4-4d6a-8de2-d7267f8800e6">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_StopsTable::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
