    <JadeMethod name="setProxyFromObject" id="13b9fafc-831f-46af-90d2-b75933f8b699">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodMarineServicesDepart) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2018	jlger1	Initial creation 41539

*/

vars
	marineServiceDetail : CM_WodMarineServiceDetail;
	wsHMSResourceUsed : WS_HMSResourceUsed;
begin
	inheritMethod(_object);
	
	self.bowMarkTo:=_object.bowMarkTo;
	self.draftAft:=_object.draftAft;
	self.draftFwd:=_object.draftFwd;
	self.occursOnDT:=_object.requiredByDT.asStringForWebInterface;
	
	//epr TFS 41539 31/10/18
	foreach marineServiceDetail in  _object.allMarineServiceDetails discreteLock do
		create wsHMSResourceUsed transient;
		wsHMSResourceUsed.setProxyFromMarineService(marineServiceDetail);
		self.allHMSResourcesUsed.add(wsHMSResourceUsed);
		
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodMarineServicesDepart"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="f105d269-915e-4d7e-9979-488e87e48f2a">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodMarineServicesDepart input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2018	jlger1	Initial creation
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars
	voyage  		: CM_Voyage;
	voyageStatus  	: CM_VoyageStatus;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	pxyResourceUsed : HMS_ResourceUsed;
	hmsResource 	: HMS_Resource;
begin
	inheritMethod(_pxyWorkOrder);
	
	_pxyWorkOrder.setPxyMarineDetails(self.draftAft,
											self.draftFwd,
											self.bowMarkTo	);
	
	_pxyWorkOrder.setRequiredByDT(self.occursOnDT.asTimeStampFromWebInterface);
	
	voyage:= _pxyWorkOrder.myParent.getMyVoyageObject;
	//epr TFS 41539 31/10/18
	if voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending ];
	endif;	
	
	create allPxyHMSResourcesUsed transient;
	
	if voyageStatus &lt;&gt; null then
		foreach wsHMSResourceUsed in self.allHMSResourcesUsed discreteLock do
			create pxyResourceUsed transient;
			wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
			if pxyResourceUsed.myResource = null and pxyResourceUsed.myResourceType &lt;&gt; null then
				foreach hmsResource in voyageStatus.allHMSResourcesAllowed do
					if hmsResource.myHarbour &lt;&gt; voyage.myHMSVoyageData.myHarbour then
						continue;
					endif;
			
					if hmsResource.myResourceType = null or hmsResource.myResourceType.isNotAvailableForEntry or
						hmsResource.myResourceType.isMarineService then
						continue;
					endif;
					if hmsResource.myResourceType = pxyResourceUsed.myResourceType then
						pxyResourceUsed.setMyResource(hmsResource);
						break;
					endif;
				endforeach;
			endif;
			allPxyHMSResourcesUsed.add(pxyResourceUsed);		
		endforeach;
	endif;

	
	_pxyWorkOrder.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);

epilog
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
	endif;
	delete allPxyHMSResourcesUsed;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodMarineServicesDepart" usage="input"/>
    </JadeMethod>
</Class>
