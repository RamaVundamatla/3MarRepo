    <JadeMethod name="extractFile" id="cf956eb0-03f6-4084-bd21-89964445fc71">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	ediDataCustomStop: CM_EDIDataCustomStop;
	ediTI: CM_EDITrackedItem;
	file: File;
	tiNumber,count: Integer;
	voyageCode: String;
	operator :CM_Operator;
	firstTime: Boolean;
	str : String;
begin
//
//	not used in the current GUI - maybe used for generating test messages at a later stage - JC 01/09/2004
//

	if (not CM_EDIDataCustomStop.hasInstance(_ediFile.ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, _ediFile.ediData.class.name, null, null);
		return;
	endif;
	ediDataCustomStop := _ediFile.ediData.CM_EDIDataCustomStop;
	operator := app.myRoot.allOperators[ediDataCustomStop.operatorCode];

	str := str &amp; "UNB+UNOA:s+CUSMOD:ZZZ+PORTNZWGL:ZZZ+" &amp; "990322:0953" &amp; "+" &amp; _number.String &amp; "'" &amp; CrLf;
	tiNumber := 1;
	firstTime := false;
	foreach ediTI in ediDataCustomStop.allEDITrackedItems do
//		if voyageCode &lt;&gt; ediTI.CM_EDICustomStopTI.voyageCode then	// cnwrl1 09/06/2010 PAR 24299 - what it was
		if voyageCode &lt;&gt; ediTI.CM_EDICustomStopTI.getVoyageCode() then
			if firstTime = true then
				count := count + 1;
				str := str &amp; "UNT+" &amp; count.String &amp; "+" &amp; tiNumber.String &amp; "'" &amp; CrLf;
				count := 0;
			endif;
			firstTime := true;
			str := str &amp; "UNH+" &amp; tiNumber.String &amp; "+CUSRES:D:96B:UN+080922'" &amp; CrLf;
			count := count + 1;
			str := str &amp; "BGM+932+" &amp; tiNumber.String &amp; "+:01'" &amp; CrLf;
			count := count + 1;
//			str := str &amp; "TDT+20+" &amp; ediTI.CM_EDICustomStopTI.voyageCode.trimBlanks &amp; "+1+++++:::" &amp; ediTI.CM_EDICustomStopTI.vesselName.trimBlanks &amp; "'" &amp; CrLf;	// cnwrl1 09/06/2010 PAR 24299 - what it was
			str := str &amp; "TDT+20+" &amp; ediTI.CM_EDICustomStopTI.getVoyageCode().trimBlanks &amp; "+1+++++:::" &amp; ediTI.CM_EDICustomStopTI.vesselName.trimBlanks &amp; "'" &amp; CrLf;
			count := count + 1;
			str := str &amp; "GIS+834:120:143'" &amp; CrLf;
			count := count + 1;
		endif;
		str := str &amp; self.extractTI(ediTI.CM_EDICustomStopTI,tiNumber,operator);
		count := count + 2;
		tiNumber := tiNumber + 1;
//		voyageCode := ediTI.CM_EDICustomStopTI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		voyageCode := ediTI.CM_EDICustomStopTI.getVoyageCode();
	endforeach;
	count := count + 1;
	str := str &amp; "UNT+" &amp; count.String &amp; "+" &amp; tiNumber.String &amp; "'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="43f141e7-669a-4cae-b819-358191a5e9c2">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	code: String;
	str : String;
begin
	
	str := "DOC+25'" &amp; CrLf;
	
	if _ediTI.fullOrMT = "E" then
		code := "4";
	elseif _ediTI.fullOrMT = "F" then
		code := "5";
	elseif _ediTI.fullOrMT = "L" then
		code := "7";
	elseif _ediTI.fullOrMT = "B" then
		code := "8";
	endif;

	str := str &amp; "EQD+CN+" &amp; _ediTI.id &amp; "++++" &amp; code &amp; "'" &amp; CrLf;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="f5fed9ba-0c70-44d5-95a3-48f0ba4e060e">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
//	ediData : CM_EDIData;

begin
	_ediDataClass	:=	CM_EDIDataCustomStop;
	_dataType			:=	EDIDataType_CustomStop;
	_fileTypeCode	:=	self.type;
	
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
