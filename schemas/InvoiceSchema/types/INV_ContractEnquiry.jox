    <JadeMethod name="getXMLSettingsForSave" id="2fa7de25-843e-43b3-9ec2-09af95bf7cea">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			

Date		Who		Reason
16DEC2022	NAVAB1	TFS CR 55645 TASK 55662
18 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	theXML : String;
begin

	theXML := inheritMethod();
	theXML := theXML &amp; self.tblData.getXmlStrForColumns(false);
	theXML := theXML &amp; self.tblDetails.getXmlStrForColumns(false);				//18.10.2024 navlc30 #19508
	theXML := theXML &amp; self.tblRates.getXmlStrForColumns(false);				//18.10.2024 navlc30 #19508
	theXML := theXML &amp; global.formatAsXML(self.XML_TagShowParams,chkShowParameters.value.Integer.String);
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="8cfd7a37-a46e-4294-92f5-f9fce6097ec2">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			

Date		Who		Reason
16DEC2022	NAVAB1	TFS CR 55645 TASK 55662
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	showParams : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	theXML := userWindow.xmlInfo;
	
	
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowParams);
 	showParams := false;
 	if theXMLValue &lt;&gt; null then
 		showParams := theXMLValue.Integer.Boolean;
 	endif;
 	
	self.chkShowParameters.value := showParams;
	self.chkShowParameters_click(self.chkShowParameters);
end;</source>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="c5c313fe-5c61-432e-bb32-4c6ccf44a98c">
        <source>haltProgress(pe : CM_ProgressException) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2023	navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts

*/
vars

begin

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNote" id="652ebe9e-c2ad-45b9-8600-12e31bd79cc2">
        <updating/>
        <source>handleUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	event : Integer;
	contract : CM_InvoiceContract;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
//write method.qualifiedName &amp; " - " &amp; eventType.String &amp; " = event: " &amp; event.String &amp;  " theObject: " &amp; theObject.String &amp; " userInfo: " &amp; userInfo.String;

	if userInfo.isKindOf(CM_InvoiceContract) then
		contract := userInfo.CM_InvoiceContract;
	elseif theObject.isKindOf(CM_InvoiceContract) then
		contract := theObject.CM_InvoiceContract;
	endif;
	
	if event = Event_InvContractCreate then
		if contract &lt;&gt; null then
			if self.includeContract(contract, true) then
				self.addRowToTable(contract);
			endif;
		endif;
		
	elseif event = Event_InvContractUpdate then
		if contract &lt;&gt; null then
			self.tblData.findObjectInRow(contract,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := contract.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvContractDelete then
		self.tblData.findObjectInRow(contract,idx);
		if idx &gt; self.tblData.fixedRows then
			self.tblData.deleteRow(idx);
		endif;
		
	elseif eventType = EventFileAdd
	or eventType = EventFileDelete then // does not wrap terminal edition around the event number
		if contract &lt;&gt; null then
			self.tblData.findObjectInRow(contract,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := contract.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	endif;
	
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="hideShowParameters" id="435dcb82-a30c-4bb2-bec7-2316c69437fd">
        <source>hideShowParameters();
/*
Purpose:			

Date		Who		Reason
15 December 2022	navab1	TFS CR 55645 TASK 55662
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars

begin
	self.frmParameters.visible := self.chkShowParameters.value;
	
	if self.chkShowParameters.value then
		self.tblData.top := self.frmParameters.top + self.frmParameters.height + 5;// ### TFS BUG 61268 28NOV2023 NAVAB1
		self.tblDetails.top := self.frmParameters.top + self.frmParameters.height + 5;	//04.10.2024 navlc30 #19508
		self.tblRates.top := self.frmParameters.top + self.frmParameters.height + 5;	//04.10.2024 navlc30 #19508
	else
		self.tblData.top := self.frmParameters.top + 5;
		self.tblDetails.top := self.frmParameters.top + 5;								//04.10.2024 navlc30 #19508
		self.tblRates.top := self.frmParameters.top + 5;								//04.10.2024 navlc30 #19508		
	endif;

	self.tblData.height := self.btnAttachments.top - self.tblData.top - 10;
	self.tblDetails.height := self.btnAttachments.top - self.tblDetails.top - 10;		//04.10.2024 navlc30 #19508
	self.tblRates.height := self.btnAttachments.top - self.tblRates.top - 10;			//04.10.2024 navlc30 #19508		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeContract" id="15f55e65-d78e-4f86-9acf-68754e8d83b9">
        <source>includeContract(_contract : CM_InvoiceContract; _checkDetails : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	invalid, detailOK, hasCurrent : Boolean;
	contDetail : CM_InvoiceContractDetails;
	localTS : TimeStamp;
begin
	on Exception do app.handleDeletedObject(exception, _contract, invalid);

	if not self.allDebtors.isEmpty() // If empty show all debtors
	and not self.allDebtors.includes(_contract.myDebtor) then
		return false;
	endif;
	
	if invalid then
		return false;
	endif;
	
	// ### TFS BUG 62180 25JAN2024 NAVAB1
	if _contract.myTerminal &lt;&gt; self.myTerminal then
		return false;
	endif;
	if self.myCurrentBank &lt;&gt; null
	and _contract.myBusinessUnit &lt;&gt; self.myCurrentBank then
		return false;
	endif;
	
	// ### Primary, Active, Contract
	if self.filterQueryPrimary then // Primary Only
		if not _contract.primary then
			return false;
		endif;
	endif;
	
	if self.filterQueryActive then // Active Only
		if not _contract.active then
			return false;
		endif;
	endif;
	
	if self.filterQueryContract &lt;&gt; "" then
		if _contract.contractId.toUpper().pos(self.filterQueryContract,1) &lt; 1 then
			return false;
		endif;
	endif;
	
	if self.filterQueryDescription &lt;&gt; "" then
		if _contract.description.toUpper().pos(self.filterQueryDescription,1) &lt; 1 then
			return false;
		endif;
	endif;

	// ### CONTRACT from/to date/time
	localTS := self.systemToLocalTime(_contract.fromTS); // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
	if self.filterQueryContractFromStart.isValid() then
		if localTS &lt; self.filterQueryContractFromStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.filterQueryContractFromEnd.isValid() then
		if localTS &gt; self.filterQueryContractFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	localTS := self.systemToLocalTime(_contract.toTS); // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
	if self.filterQueryContractToStart.isValid() then
		if localTS &lt; self.filterQueryContractToStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.filterQueryContractToEnd.isValid() then
		if localTS &gt; self.filterQueryContractToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;

	if _checkDetails then
		if _contract.allInvoiceContractDetails.isNotEmpty() then
			detailOK := false;
			foreach contDetail in _contract.allInvoiceContractDetails discreteLock do
				if self.includeDetail(contDetail, true) then
					detailOK := true;
					break;
				endif;
			endforeach;
			
			if not detailOK then 
				return false;
			endif;
		else
			// ### TFS BUG 60044 25AUG2023 NAVAB1
			// no details so if query includes criteria or lines then exclude this contract.
			if self.myFilterCriteria.allSearchCriteria.isNotEmpty then
				return false;
			endif;
			if self.allInvoiceLineTypes.isNotEmpty then
				return false;
			endif;
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_contract" type="CM_InvoiceContract"/>
        <Parameter name="_checkDetails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeDetail" id="81c25a72-63e6-4536-adcd-9df51c9bdc30">
        <source>includeDetail(_detail : CM_InvoiceContractDetails; _includeRates : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
16 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	rate : CM_InvoiceContractRate;
	rateOK, hasRateEntries : Boolean;
begin
	// ### TFS CR 55624 TASK 55698 23JAN2023 NAVAB1
	if self.filterQueryDetailVolBasedOnly then 
		if not _detail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then
			return false;
		endif;
	
	endif;

	// ### DETAIL from/to date/time
	if self.filterQueryDetailFromStart.isValid() then
		if self.systemToLocalTime(_detail.fromTS) &lt; self.filterQueryDetailFromStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.filterQueryDetailFromEnd.isValid() then
		if self.systemToLocalTime(_detail.fromTS) &gt; self.filterQueryDetailFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.filterQueryDetailToStart.isValid() then
		if self.systemToLocalTime(_detail.toTS) &lt; self.filterQueryDetailToStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.filterQueryDetailToEnd.isValid() then
		if self.systemToLocalTime(_detail.toTS) &gt; self.filterQueryDetailToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
			return false;
		endif;
	endif;
	
	if self.allInvoiceLineTypes &lt;&gt; null
	and not self.allInvoiceLineTypes.isEmpty()
	and not self.allInvoiceLineTypes.includes(_detail.myInvoiceLineType) then
		return false;
	endif;
	if not self.includeDetailForCriteria(_detail) then
		return false;
	endif;
	
	
	if _includeRates 
	and _detail.allInvoiceContractRates.isNotEmpty() then
		rateOK := false;
		hasRateEntries := false; // ### TFS BUG 56883 02MAR2023 NAVAB1
		
		foreach rate in _detail.allInvoiceContractRates discreteLock do
			if rate.allInvoiceContractRateEntries.isEmpty() then
				continue;
			endif;
			
			hasRateEntries := true; // ### TFS BUG 56883 02MAR2023 NAVAB1
			
			if self.includeRate(rate, _includeRates) then
				rateOK := true;
				break;
			endif;
		endforeach;
		
		if not hasRateEntries then // ### TFS BUG 56883 02MAR2023 NAVAB1
			return true; // ### TFS BUG 56883 02MAR2023 NAVAB1
		endif;
		
		if not rateOK then 
			return false;
		endif;	
	endif;
	return true;
	
epilog

end;</source>
        <Parameter name="_detail" type="CM_InvoiceContractDetails"/>
        <Parameter name="_includeRates" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeDetailForCriteria" id="e6f26e61-99b3-484c-ac34-3dc01ec6d5cc">
        <source>includeDetailForCriteria(_detail : CM_InvoiceContractDetails) : Boolean;
/*
Purpose:			

Date		Who		Reason
19 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	elementObj			: CMIF_Object;
	searchCriteria,
	criteriaObj			: CM_YACriteria;
	searchCriteriaType		: CM_YACriteriaType;
	allocationObj		: CM_YardAllocation;
	includeActive,
	includeDisabled		: Boolean;
	matches 			: Boolean;
	
	
begin
		
	if self.myFilterCriteria.allSearchCriteria.isEmpty then
		return true;
	endif;
	// ### TFS BUG 60044 25AUG2023 NAVAB1
	if _detail.myInvoiceContractCriteria = null then
		return false;
	endif;
	
	matches:=false;
	
	foreach elementObj in self.myFilterCriteria.allSearchCriteria do
		searchCriteria		:=	elementObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		searchCriteriaType	:=	searchCriteria.myYACriteriaType;
		criteriaObj:= _detail.myInvoiceContractCriteria.getCriteriaFor(searchCriteriaType.type);
		if criteriaObj = null then
			matches := false;
			break;
		endif;
		if criteriaObj.myYAData.doDataComparison(searchCriteria.myYAData) then
			if criteriaObj.myYAData.isStringValue and searchCriteria.myYAData.isStringValue then
				if searchCriteria.myYAData.CM_YADataString.doesValueMatch(criteriaObj.myYAData.CM_YADataString.value) then
					matches := true;
				endif;
			else
				matches:=true;
			endif;
		else	
			matches := false;
			break;
		endif;	
	endforeach;

	return matches;
end;</source>
        <Parameter name="_detail" type="CM_InvoiceContractDetails"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeRate" id="2a194e84-02ba-44d0-9b3c-889f7dea1cb7">
        <source>includeRate(_rate : CM_InvoiceContractRate; _includeEntries : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
16 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	rateEntry : CM_InvoiceContractRateEntry;
	includeRate : Boolean;
begin
	
	if self.allServices &lt;&gt; null
	and not self.allServices.isEmpty()
	and not self.allServices.includes(_rate.myService ) then
		return false;
	endif;

	if _includeEntries then
		includeRate := false;
		
		// ### Need to check all the rates to see if one of them matches
		foreach rateEntry in _rate.allInvoiceContractRateEntries discreteLock do
		
			if self.includeRateEntry(rateEntry) then
				includeRate := true;
				break;
			endif;
		endforeach;
		

		
		return includeRate;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
        <Parameter name="_includeEntries" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeRateEntry" id="c0d94014-9d5b-4916-aa2a-992635d24db9">
        <source>includeRateEntry(rateEntry : CM_InvoiceContractRateEntry) : Boolean;
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

begin
		if rateEntry.costPerUnit &lt; self.filterQueryRateAmountFrom
		or rateEntry.costPerUnit &gt; self.filterQueryRateAmountTo then
			return false;
		endif;
		
		// ### Rate from/to date/time
		if self.filterQueryRateFromStart.isValid() then
			if self.systemToLocalTime(rateEntry.fromTS) &lt; self.filterQueryRateFromStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				return false;
			endif;
		endif;
		
		if self.filterQueryRateFromEnd.isValid() then
			if self.systemToLocalTime(rateEntry.fromTS) &gt; self.filterQueryRateFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				return false;
			endif;
		endif;
		
		if self.filterQueryRateToStart.isValid() then
			if self.systemToLocalTime(rateEntry.toTS) &lt; self.filterQueryRateToStart then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				return false;
			endif;
		endif;
		
		if self.filterQueryRateToEnd.isValid() then
			if self.systemToLocalTime(rateEntry.toTS) &gt; self.filterQueryRateToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				return false;
			endif;
		endif;
		
		return true;
epilog

end;</source>
        <Parameter name="rateEntry" type="CM_InvoiceContractRateEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblContractDetails" id="58165e7a-61d9-4385-9340-f28b097fad6c">
        <source>initTblContractDetails(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblDetails;										//14.10.2024 navlc30 #19508
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceContractDetails);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblDetails);	
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblContractRate" id="0af2045c-a1b8-45d1-a08d-9db48d38dbb7">
        <source>initTblContractRate(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
