    <JadeMethod name="rel842_par36957" id="92bfe5b7-6528-4b6b-b6b1-b2183ac8eeea">
        <source>rel842_par36957();
//	take back stuff to 842 for TFS 370 to do task enhancements
vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	transAgent 	: CM_TranslationAgent;
	
begin
	app.initialize();
	create etAgent transient;
	create transAgent transient;
	create array transient;

	array.add('Task_to_Add');
	array.add('Task_to_Complete');
	array.add('Task_to_Remove');
	array.add('Task_Remarks');
	array.add('CannotUpdateTaskNothingSelectd');
	transAgent.trxLoadSpecificErrors(array);
	
	array.clear();
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	array.add ("ETRow_Description");
	array.add ("ETRow_Remove");
	array.add ("ETRow_Add");
	array.add ("ETRow_Clear");
	array.add ("ETRow_Remarks");
	array.add ("ETRow_SortKey");
	array.add ("ETRow_ToDoTaskDesc");
	array.add ("ETDef_ToDoTasks");
	array.add ("ETDef_ToTasksAdd");
	array.add ("ETGrp_ToDoTasksList");
	etAgent.trxUpdateFromConstant(array);
	return;
	
	write Task_to_Add;
	write Task_to_Complete;
	write Task_to_Remove;
	write Task_Remarks;
	write CannotUpdateTaskNothingSelectd;
	
	write ETRow_Description;
	write ETRow_Remove;
	write ETRow_Add;
	write ETRow_Clear;
	write ETRow_Remarks;
	write ETRow_SortKey;
	write ETRow_ToDoTaskDesc;
	write ETDef_ToDoTasks;
	write ETDef_ToDoTasksAdd;
	write ETGrp_ToDoTasksList;
epilog
	delete etAgent;
	delete array;
	delete transAgent;
end;
</source>
