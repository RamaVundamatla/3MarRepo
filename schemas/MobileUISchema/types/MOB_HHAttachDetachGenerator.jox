    <JadeMethod name="doClickPartCargoIdSearch" id="e5655f1c-e922-47ca-b6c2-e709135e630d">
        <updating/>
        <source>doClickPartCargoIdSearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	
		app.myMobileCargoFindAgent.setPreventSiteChange(true); 
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="89c1d035-915c-4da1-a122-0ad867bb46d8">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/
vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight,
	dateWidth,
	labelsWidth : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	timeWidth : Integer;
begin
	tabIndex := 4000;
	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	//cWidth := stdWidth - self.getSearchButtonSpace();	
		cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := self.getStdControlHeight;
	
	dateWidth := ( self.txtDate.getTextExtent( "DD/MM/YY" ) + ( self.resizedMargin * 2 ) ).Integer;
	labelsWidth := ( self.lblNoCharge.getTextExtent( self.lblNoCharge.caption ) + stdHeight ).Integer;
	timeWidth := ( self.txtTime.getTextExtent( "HH:MM" ) + ( self.resizedMargin * 2 ) ).Integer;

	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );
	self.lblCargoId.top := self.txtCargoId.top;
	self.lblCargoId.visible := false;
	
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move( self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );

	
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.txtGenerator.setAndIncrementTabIndex( tabIndex );
		self.txtGenerator.visible := true;
		self.txtGenerator.enabled := true;
	endif;
	self.txtGenerator.move( self.resizedMargin,
							 cTop,
							 stdWidth,
							 cHeight ); 
	
	self.lblGeneratorId.top := self.txtGenerator.top;
	self.lblGeneratorId.visible := false;
	cTop := cTop + self.txtGenerator.height + self.resizedMargin;
	
	if _initialSetup then
		self.lblDate.setAndIncrementTabIndex( tabIndex );
		self.lblDate.visible := false;
	endif;
	

	self.lblDate.move(	cLeft,
						cTop,
						labelsWidth,
						stdHeight +2
					);
	
	//Text Date
	if _initialSetup then
		self.txtDate.setAndIncrementTabIndex( tabIndex );
	endif;

	self.txtDate.move(	cLeft + lblDate.width,
						cTop,
						dateWidth,
						stdHeight +2
					);
	
	//Label Time
	cTop := cTop + self.lblDate.height + self.resizedMargin;
	self.lblTime.move(	cLeft,
						cTop,
						labelsWidth,
						stdHeight +2
					);
					
	//TextTime
	if _initialSetup then
		self.txtTime.setAndIncrementTabIndex( tabIndex );
	endif;

	self.txtTime.move(	cLeft + lblDate.width ,
						cTop,
						timeWidth,
						stdHeight +2
					);

	//Label Location 
	cTop := cTop + self.txtTime.height + self.resizedMargin;
	self.lblLocation.move(	cLeft,
						cTop,
						labelsWidth,
						stdHeight +2
					);
	// Text Location
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
	endif;

	self.txtLocation.move( cLeft + lblLocation.width ,
							 cTop,
							 stdWidth - lblLocation.width,
							 stdHeight +2 ); 
	

	// NoCharge Label
	cTop := cTop + self.txtLocation.height + self.resizedMargin;
	self.lblNoCharge.move(	cLeft,cTop,labelsWidth,	stdHeight +2);
	
	if _initialSetup then
		self.chkNoCharge.setAndIncrementTabIndex( tabIndex );
	endif;

	self.chkNoCharge.move( cLeft + lblNoCharge.width,
							 cTop,
							 chkNoCharge.width,
							 chkNoCharge.height  ); 


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="c7ab51f8-05a5-405e-abb2-a1555b9cc9a1">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	errMsg : String;
	success : Boolean;
	connectParams	: CMIF_ConnectParams;
	attachDetachDate			: TimeStamp;
	errorMsg : String;
	loadState : Boolean;
	pxyTI,pxyGen : CM_TrackedItem;
	targetController : CM_LocationsController;
	foundHeight : Integer;
	result 	: Integer;
		parentID : String;
begin
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myTrackedItem = null then
		app.msgBox(app.getErrorString(No_Cargo_selected), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtCargoId.setFocus();
		return false;
	endif;
	
	attachDetachDate.setDate(self.txtDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblDate.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtDate.setFocus();
		return false;
	endif;

	attachDetachDate.setTime(self.txtTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtTime.setFocus();
		return false;
	endif;
	
	
	
	if self.myGenerator = null then
			app.msgBox( app.getErrorString1(Generator_not_found,self.txtGenerator.text), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.isAttach then
		if self.myGenerator.CM_Generator.reefersRelatedTo.size &gt; 0 then
				if self.myGenerator.CM_Generator.reefersRelatedTo.first.CM_TIReeferProperties.myParent &lt;&gt; null then
					parentID :=  self.myGenerator.CM_Generator.reefersRelatedTo.first.CM_TIReeferProperties.myParent.CM_TrackedItem.id;
				endif;
				errorMsg := app.getErrorString2(Generator_already_attached,self.myGenerator.id,parentID);
				if errorMsg &lt;&gt; null then
					self.txtCargoId.setFocus;
					app.msgBox(errorMsg, app.getErrorString(Error), 0);
					return false;
				endif;
			endif;
	endif;
	
	create connectParams transient;

 	app.cmsBeginLoad(loadState);
 	pxyTI := self.myTrackedItem.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	connectParams.dateTime := attachDetachDate;
	connectParams.noCharge := self.chkNoCharge.value;
	connectParams.myTerminal := self.myTerminal;
	connectParams.myTrackedItem := pxyTI;
	connectParams.userId := app.getMyUserCode();
	
	
	if self.isAttach then
		connectParams.action := ACTION_ATTACH;
		connectParams.type := TRANS_TYPE_AttachGenerator;
		connectParams.locationsController := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
		app.cmsBeginLoad(loadState);
		pxyGen :=  self.myGenerator.CM_TrackedItem.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		connectParams.myOtherTrackedItem := pxyGen;
	else
		connectParams.action := ACTION_DETACH;
		connectParams.type := TRANS_TYPE_DetachGenerator;
		app.cmsBeginLoad(loadState);
		pxyGen :=  pxyTI.getGenerator;
		app.cmsEndLoad(loadState);
		connectParams.myOtherTrackedItem := pxyGen;
		self.myTerminal.findLocationFromString( self.txtLocation.text, false, targetController, foundHeight);
		if targetController = null then
			app.msgBox(app.getErrorString1(Location_invalid,self.txtLocation.text),app.getErrorString(Error), 0);
			return false;
		endif;
		connectParams.locationsController := targetController;
	endif;

	while true do 
			
		if self.isAttach then
		
			app.myTrxUA.trxUpdateAttach(connectParams,app.myPassport);
		else
			
			app.myTrxUA.trxUpdateDetach(connectParams,app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
				return true;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

	return true;
epilog
	app.cmsEndLoad(loadState);
	delete pxyGen;
	delete pxyTI;
	if errMsg &lt;&gt; null then
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
	endif;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge();
		delete connectParams;
	endif;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="a8b1c024-447e-4bf9-86a2-08d34f63745e">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	if not self.doSave() then
		return;
	endif;
	clearFields();
epilog

end;</source>
