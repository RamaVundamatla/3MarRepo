        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="47a5e1f0-95df-4b04-a17a-c70f583b22ed">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels

*/
vars
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;
	tiTrans : CM_TITransaction;

begin
	tiTrans := _aSBController.myTransaction;
	if tiTrans &lt;&gt; null then
		
		// ### CHECK SPECIAL MAPPINGS FOR DEBTOR
		if not self.allDebtorMapsByDebtor.isEmpty then
			tmpDebtor := self.getDebtorForTransaction(_aSBController).CM_Debtor;
			if  tmpDebtor &lt;&gt; null then
				aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
				if aDM &lt;&gt; null then
					app.invLog("Debtor map found for " &amp; tmpDebtor.name, LogTRACE.String);
					aDM.getInvoiceLineDesc(_aSBController);
					return;
				endif;
			endif;
		endif;
	endif;
	
	if not _aSBController.isInvoiceCargoAllocation then		// no debtor map from cargo allocations
		app.invLog("Debtor map for DEFAULT", LogTRACE.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescVTMIS" id="c9cac60d-a203-4d87-8545-11b1daa62457">
        <source>getInvoiceLineDescVTMIS(_debtor : CM_DebtorNode; _poc : Boolean): CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		find the invoice line description. If a debtor has been passed in the check if that debtor has a special mappinig, 
//				stored on the CM_DebtorMap,  if not used the default stored on the service broker.
//
// ---------------------------------------------------------------------------
vars
begin
	return null;
end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getLimitingDebtors" id="e5dc7103-2949-4210-bf65-0851d136dede">
        <source>getLimitingDebtors() : String;

vars
	aDebtor : CM_DebtorNode;
	aString : String;
	aDM : CM_DebtorMap;
begin
	if self.allDebtorMapsByDebtor.isEmpty then
		return null;
	endif;
	
	foreach aDM in self.allDebtorMapsByDebtor do
		aDebtor := aDM.myDebtorNode;
		aString := aString &amp; aDebtor.name &amp; " ";
	endforeach;
	return aString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
