<Class name="CMIF_CompanyCustDocDetail" id="6ad8f772-8de5-435a-9cbc-d068f586b9f9">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="customs"/>
    <ImplicitInverseRef name="allProxies" id="51a49d24-0eee-4912-a92f-410f7aaa4ef9">
        <memberTypeInverse/>
        <type name="CM_CustomDocumentDetailSet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTIs" id="af3d33ea-eeb6-4c0d-bf0c-09604d1b4740">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="inwardDocCode" id="dea28505-9247-4f73-a1d3-5d2d5a89a30f">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releasedTruckID" id="1fa3240a-c0c6-4310-9e10-555c24086ce4">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createCompanyDocument" id="8d8291c6-57e5-45d1-a9ce-68dfd9913a5d">
        <updating/>
        <source>createCompanyDocument(_terminal : CM_Terminal; _custDocType : CM_CustomDocumentType; _license : CM_CustomLicense; _direction : Integer) : CM_CustomDocument updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	subTI, ti		: CM_TrackedItem;
	subPxyDetail, pxyCustDocDetail, cdd : CM_CustomDocumentDetail;
	cgti : CM_CargoGroup;
	totalWeight,
	totalVolume : Decimal[14,4];
	totalQuantity : Integer;
	pxyCustomDocument	: CM_CustomDocument;
	realCustDoc 		 : CM_CustomDocument;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn        : Integer;
	tempCode	: String;
	now			: TimeStamp;
begin

	create cmifCustDocDetail transient;
	
	create pxyCustomDocument transient;
	// Code will be auto generated at the end of the trx, put a dummy code for now
	tempCode := "tempCode";
	pxyCustomDocument.setProxy(_terminal, tempCode, null, null, null, null, now, null, null, _direction, 1, _custDocType, _license, null, null, 1);
	
	foreach ti in self.allTIs do
		create pxyCustDocDetail transient;
		
		totalWeight := ti.totalWeight;
		totalVolume := ti.totalVolume;
		totalQuantity := ti.totalQuantity;
		
		if ti.getCustDocIsPartiallyCleared() then
			cdd := ti.allCustomDocDetails.getLastActive(); // current detail // ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
			if cdd &lt;&gt; null and cdd.clearedQuantity &lt; ti.totalQuantity then 
				totalWeight := ti.totalWeight - cdd.clearedWeight;
				totalVolume := ti.totalVolume - cdd.clearedVolume;
				totalQuantity := ti.totalQuantity - cdd.clearedQuantity;
			endif;
		endif;
		
		pxyCustDocDetail.setProxy(totalQuantity, totalWeight, totalVolume, true, ti, pxyCustomDocument, null);
		cmifCustDocDetail.allProxyCustDocDetails.add(pxyCustDocDetail);		
		self.allProxies.add(pxyCustDocDetail);
		
		
		if ti.isCargoGroupItem then
			cgti := ti.CM_CargoGroup;
			foreach subTI in cgti.allAssignedTrackedItems discreteLock do
				create subPxyDetail transient;
				totalWeight := subTI.totalWeight;
				totalVolume := subTI.totalVolume;
				totalQuantity := subTI.totalQuantity;
				
				subPxyDetail.setProxy(totalQuantity,totalWeight,totalVolume,true,subTI,null,pxyCustDocDetail);			
				cmifCustDocDetail.allSubProxyCustDocDetails.add(subPxyDetail);
				self.allProxies.add(subPxyDetail);
			endforeach;
		endif;
	endforeach;
	
	
	while true do
		app.myTrxCA.trxCreateCustDocAndDetails(pxyCustomDocument, realCustDoc, cmifCustDocDetail, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			return realCustDoc;
		else
			theReturn := app.showErrorWarningDialog("Custom Doc", app.myPassport, 20);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		break;
	endwhile;
	
	return null;
	
epilog
	delete cmifCustDocDetail;
	self.allProxies.purge();
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
        <Parameter name="_license" type="CM_CustomLicense"/>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
</Class>
