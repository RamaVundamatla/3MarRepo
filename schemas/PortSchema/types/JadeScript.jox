    <JadeMethod name="ndls001" id="78f1e75c-4394-4d4d-bd0e-e8de8fda73ee">
        <source>ndls001();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2019	jlgndl1	Initial creation

*/

vars

	otherMaintPermissions : IntegerArray;
	otherViewPermissions : IntegerArray;

begin

	create otherMaintPermissions transient;
	create otherViewPermissions transient;
	
	
	otherMaintPermissions.add( PmAdmAdminMenuAccess );
	otherMaintPermissions.add( PmAdmAllowStopOverride );
	otherMaintPermissions.add( PmAdmApproveCreditCheck );
	otherMaintPermissions.add( PmAdmCargoDelete );
	otherMaintPermissions.add( PmAdmCargoEnquiryConfigCopy );
	otherMaintPermissions.add( PmAdmCashCredit );  // Doesn't appear to be used anywhere
	otherMaintPermissions.add( PmAdmCashRecPaymentStatusChang );
	otherMaintPermissions.add( PmAdmDeliveryReleaseNumEdit );
	otherMaintPermissions.add( PmAdmDoorDirectionsUpdate );
	otherMaintPermissions.add( PmAdmEDICAMSProtocol ); // Used for maint and view
	otherMaintPermissions.add( PmAdmEdiReprocess ); // Not used
	otherMaintPermissions.add( PmAdmEmailSystem );
	otherMaintPermissions.add( PmAdmFlexiGateRemove );
	otherMaintPermissions.add( PmAdmGeneratorTypeUpdate );
	otherMaintPermissions.add( PmAdmHHGate1 );
	otherMaintPermissions.add( PmAdmHHRailConfirm );
	otherMaintPermissions.add( PmAdmHHShip1 );
	otherMaintPermissions.add( PmAdmIgnoreOpRestrictions );
	otherMaintPermissions.add( PmAdmInvLineOverrideRate );
	otherMaintPermissions.add( PmAdmInvLineReEvaluate );
	otherMaintPermissions.add( PmAdmInvListExportInv );
	otherMaintPermissions.add( PmAdmInvListOverrideRates );
	otherMaintPermissions.add( PmAdmInvListReEvaluate );
	otherMaintPermissions.add( PmAdmInvListStatusClose );
	otherMaintPermissions.add( PmAdmInvListStatusReturn );
	otherMaintPermissions.add( PmAdmInvoiceLineStatusNormal );
	otherMaintPermissions.add( PmAdmInvoiceLineStatusVoid );
	otherMaintPermissions.add( PmAdmInvoiceSetBank );	// Not used
	otherMaintPermissions.add( PmAdmInvoiceStatusDisputed );
	otherMaintPermissions.add( PmAdmInvoiceStatusPost );
	otherMaintPermissions.add( PmAdmInvoiceStatusPrepend );
	otherMaintPermissions.add( PmAdmInvoiceStatusVoid );
	otherMaintPermissions.add( PmAdmKEA );	// Not used
	otherMaintPermissions.add( PmAdmMoveCargoFromJob );
	otherMaintPermissions.add( PmAdmMoveContainer );
	otherMaintPermissions.add( PmAdmMultiCompany );
	otherMaintPermissions.add( PmAdmOpExpReleaseNumEdit );
	otherMaintPermissions.add( PmAdmOpImpReleasePinEdit );
	otherMaintPermissions.add( PmAdmOrganizeMenus );
	otherMaintPermissions.add( PmAdmPINEmailDefUpdate );
	otherMaintPermissions.add( PmAdmRecheckFinance );
	otherMaintPermissions.add( PmAdmResyncTrans );
	otherMaintPermissions.add( PmAdmSelectorEntry );
	otherMaintPermissions.add( PmAdmSetCurrentVoyage );	//not used
