    <JadeMethod name="xCM_Train" id="0598ca1e-9d70-4318-bdd8-4e7a7914bfd8">
        <updating/>
        <source>xCM_Train(_features : CMIF_ExternalDBFeatureSet input) updating;

/*

Purpose:		aadd trains to sql native, par #36230	

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2015	cnwrd1	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	xdbFeature  : CMIF_ExternalDBFeature;
begin

	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::arrivalDT.name, "CM_Train", "arrivalDT", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::departureDT.name, "CM_Train", "departureDT", "CM_Train", _features); //epr TFS 2447 5/8/16

