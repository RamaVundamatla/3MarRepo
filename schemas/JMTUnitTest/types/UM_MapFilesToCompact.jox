    <JadeMethod name="create" id="78ae0c45-da32-45a5-81a2-61d798b55a8e">
        <updating/>
        <source>create() updating;

/*

Purpose:		Create the record

Date			Who		Reason
16/04/2015		cnwmh5	Initial creation

*/

vars

	root					: UM_Root;

begin

	root := UM_Root.firstInstance;
	if root = null then
		create root;
	endif;
	self.myRoot := root;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fc5efdc1-a34f-48d5-a9ec-2ae07e7dfa0e">
        <updating/>
        <source>delete() updating;

/*

Purpose:		Delete

Date			Who		Reason
16/04/2015		cnwmh5	Initial creation

*/

vars

	cleanUpDetails						: UM_CleanUpDetails;

begin

	foreach cleanUpDetails in self.allCleanUpDetails do
		delete cleanUpDetails;	
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateDetails" id="2310d910-7a86-4c07-8285-fdc0600df403">
        <updating/>
        <source>updateDetails(_mapFileName : String; _whenToCompact : Integer) updating;

/*

Purpose:		

Date			Who		Reason
16/04/2015		cnwmh5	Initial creation

*/

vars

begin

	self.mapFileName := _mapFileName;
	self.whenToCompact := _whenToCompact;

epilog

end;</source>
        <Parameter name="_mapFileName" type="String"/>
        <Parameter name="_whenToCompact" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateWhenToCompact" id="1d82a4fc-bd7a-4335-ba83-c79e8e7000c6">
        <updating/>
        <source>updateWhenToCompact(_whenToCompact : Integer) updating;

/*

Purpose:		Updating when to compact

Date			Who		Reason
17/04/2015		cnwmh5	Initial creation

*/

vars

begin

	self.whenToCompact := _whenToCompact;

epilog

end;</source>
        <Parameter name="_whenToCompact" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="whenToCompactStr" id="e1acf5dc-61dc-4dfd-8fb2-37d4ef3e5b47">
        <methodInvocation>mapping</methodInvocation>
        <source>whenToCompactStr(set: Boolean; _value: String io) mapping;

/*

Purpose:		

Date			Who		Reason
16/04/2015		cnwmh5	Initial creation

*/

vars

begin

	if set then
		return;
	else
		if self.whenToCompact = self.WhenToCompactNext then
			_value := self.WhenToCompactNextStr;
		elseif self.whenToCompact = self.WhenToCompactNull then
			_value := self.WhenToCompactNullStr;
		elseif self.whenToCompact = self.WhenToCompactWeekly then
			_value := self.WhenToCompactWeeklyStr;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
