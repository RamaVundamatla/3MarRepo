    <JadeMethod name="showGraphicFillStylesForm" id="890a11ad-5187-4f1b-8169-46b4be3a2b74">
        <source>showGraphicFillStylesForm(_parentForm : CM_BaseForm; _pxyDeckItemLayout : CM_DeckItemLayout input);
/*
Date		    Who			Reason
04 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	form 		: CMUI_GraphicStyles;

begin
	
	form := app.loadForm(CMUI_GraphicStyles, SHP_Assistant, false, false, true, self.myTerminal, null).CMUI_GraphicStyles;	
	
	if form = null then
		return;
	endif;	
	
	
	form.setParentForm(_parentForm);
	form.setFormParent(_parentForm);
	

	form.myCurrentDeckItemLayout := _pxyDeckItemLayout;
	if form.myParentForm.isKindOf(SHP_ROROLayoutLayersForm) then
		form.myParentForm.SHP_ROROLayoutLayersForm.myUIStylesFrame := form;
		if form.myParentForm.SHP_ROROLayoutLayersForm.myParentForm.isKindOf(SHP_RORODeckDefinitionForm) then
			form.myParentForm.SHP_ROROLayoutLayersForm.myParentForm.SHP_RORODeckDefinitionForm.myUIStylesFrame := form;
		endif;
	endif;
	
	form.show;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_pxyDeckItemLayout" type="CM_DeckItemLayout" usage="input"/>
    </JadeMethod>
