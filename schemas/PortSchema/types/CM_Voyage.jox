    <JadeMethod name="getFirstPortInRotation" id="7a82bc1d-b6a4-443b-8189-ec814809e2f5">
        <source>getFirstPortInRotation():CM_Port;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18/08/2018	jlgma1	Bug 40102: PEL1 - Voyage Request Report (PKK) - Expose fields request
21/11/2018	jlgdap1	TFS 42024 PEL1 Incorrect Ports in Voyage Request
1/10/2021	jlier1	TFS 51963 
*/

vars
	firstPort : CM_Port;
	wod : CM_WodVoyageRequest;			// TFS 42024
begin
	if not self.isDefaultVoyageProcess then	// TFS 42024
		wod := self.getWorkOrderForVoyageRequest();							// TFS 42024
		if wod &lt;&gt; null and wod.portCode1 &lt;&gt; null then						// TFS 42024
			return app.myRoot.allPorts[wod.portCode1];						// TFS 42024
		endif;																// TFS 42024
	endif;																	// TFS 42024
	
	if self.allPortRotations.isEmpty() then
		return null;
	endif;
	
	firstPort := self.allPortRotations.first.CM_PortRotation.myPort;
	return firstPort;
	
epilog

end;</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getFirstReceiveShipTrx" id="b947ee5a-08eb-4191-bafa-7761631690b0">
        <source>getFirstReceiveShipTrx():CM_ReceiveShip;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2020	jlgndl1	Initial creation	TFS 48646 - for RWR use at ASPA

*/

vars

	js : CM_VoyageJobSheet;
	tiTrx : CM_TITransaction;

begin

	foreach js in self.allJobSheets do
		if js.allShipReceivals.isEmpty then
			continue;
		endif;
		tiTrx := js.allShipReceivals.first;
		if tiTrx &lt;&gt; null and tiTrx.isKindOf( CM_ReceiveShip ) then
			return tiTrx.CM_ReceiveShip;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_ReceiveShip"/>
    </JadeMethod>
    <JadeMethod name="getGeneralLandingDate" id="45e8241f-f947-4af4-99d8-a0777f9014cd">
        <source>getGeneralLandingDate( _dbValueOnly : Boolean ):Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2016	cnwndl1	Initial creation	TFS 1407

if _dbValueOnly = true, we only want the value recorded in the database.
if _dbValueOnly = false, we return the db value if its been set, other wise we try to calculate a date.

*/

vars

	glDate : Date;
	arrived : Date;
	departed : Date;
	days : Integer;
	incrementDays : Integer;

begin

	glDate := null;

	if _dbValueOnly then
		return self.generalLandingDate;
// TFS 4272	elseif not glDate.isValid then
	else// TFS 4272 always re claculate for users without permission e.g. _dbValueOnly = false
		
		arrived := self.arrivedDT.date();
		departed := self.departedDT.date();
		if arrived.isValid and departed.isValid then
			days := departed - arrived;
			if days = 0 then
				glDate := arrived;
			else
				incrementDays := (days / 2).Decimal.truncatedTo(0).Integer;
				glDate := arrived + incrementDays;
			endif;
		endif;
		
	endif;
	
	return glDate;

epilog

end;</source>
        <Parameter name="_dbValueOnly" type="Boolean"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getGlobalVoyage" id="d0662e86-2e9a-4a4f-9a30-079be7069f6c">
