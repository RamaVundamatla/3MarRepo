    <JadeMethod name="set" id="6a32e4d8-e093-472a-9ea3-5662828ed601">
        <updating/>
        <source>set(_gridArea : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aGR : CM_GridRow;
	aGC : CM_GridColumn;
	idx, idy : Integer;
begin

	self.myGridArea := _gridArea;

	
	tblRows.rows := 0;
	foreach aGR in self.myGridArea.allGridRows do
		if aGR.hasGap then
			continue;
		endif;
		
		idx := tblRows.addAttribute(aGR.label.String, (idx + 1).String.padLeadingZeros(2) &amp; aGR.getNiceName(), Table.InputType_TextNumeric, 0, true);
		tblRows.setValue(idx, aGR.gpsY.String);
		tblRows.accessCell(idx,1).itemObject := aGR;
		tblRows.accessCell(idx,2).maxLength := 15;
	endforeach;

	tblColumns.rows := 0;
	foreach aGC in self.myGridArea.allGridColumns do
		if aGC.hasGap then
			continue;
		endif;
		
		idx := tblColumns.addAttribute(aGC.label.String, aGC.getNiceName(), Table.InputType_TextNumeric, 0, true);
		tblColumns.setValue(idx, aGC.gpsX.String);
		tblColumns.accessCell(idx,1).itemObject := aGC;
		tblColumns.accessCell(idx,2).maxLength := 15;
	endforeach;

	self.caption := self.myGridArea.id &amp; " GPS Co-ordinates";
	tblRows.moveFirst();
	self.refreshNow;
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setProxyGridObjectFromImport" id="1fca457a-59bf-4ba0-a474-717231f9a1a1">
        <source>setProxyGridObjectFromImport(_controller : CMIF_GridGPSController input; _type : String; _ord : Integer; _value : Real);
// ---------------------------------------------------------------------------
// Created:		22 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		Using teh ordinal get the real row or column. Then make a proxy of it and add value.
//					In JMT we have 2 system rows for each lane. Liebherr only know about the rows that will have actual cargo in.
//					So their ordinal is not exactly the same as ours.
//
// ---------------------------------------------------------------------------
vars
	pxyRow, gr : CM_GridRow;
	pxyColumn, gc : CM_GridColumn;
	export : String;
	idx : Integer;
begin
	if _type = self.LBL_ROW then
	
		foreach gr in self.myGridArea.allGridRowsByLabel do			
			if gr.hasGap then
				continue;
			endif;
			idx := idx + 1;
			
			// Matches with the ordinal
			if idx = _ord then
				pxyRow := app.createUpdateProxy(gr).CM_GridRow;
				
				pxyRow.setPxyGPS(_value);
				_controller.allPxyGridRows.add(pxyRow);
				return;
			endif;
		endforeach;
	endif;
	
	if _type = self.LBL_COL then
		foreach gc in self.myGridArea.allGridColumnsByLabel do
	
			if gc.hasGap then
				continue;
			endif;

			idx := idx + 1;
			// Matches with the ordinal
			if idx = _ord then
				pxyColumn := app.createUpdateProxy(gc).CM_GridColumn;
				
				pxyColumn.setPxyGPS(_value);
				_controller.allPxyGridColumns.add(pxyColumn);
				return;
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_controller" type="CMIF_GridGPSController" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_ord" type="Integer"/>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
