    <JadeMethod name="doRedrawWeightsAndHeights" id="e8864cb3-389d-4b3a-92fb-4e74b212fe67">
        <updating/>
        <source>doRedrawWeightsAndHeights(_slotController : CM_ROROSlotController) updating;
/*
Date		    Who			Reason
26 October 2011	cnwas3	  Initial creation: par 28401
*/

vars
	x,y,colour,width,height,fontSize 	: Integer;
	slotDefn							: CM_ROROSlotDefnVoyage;
	locnDefn							: CM_ROROLocnDefn;
	locnDefnVoyage						: CM_ROROLocnDefnVoyage;
	x1,y1,x2,y2,
	x21,x22,y21,y22						: Integer;
	backSlotController,
	firstSlotController					: CM_ROROSlotController;
	theTIs								: CM_TIArray;
	ti									: CM_TrackedItem;
	aftLocnDefnVoyage					: CM_ROROLocnDefnVoyage;
	foundFirst,foundSecond,
	fortyFrontEnd 						: Boolean;
	backSlot : CM_ROROSlotController;
begin
	
	slotDefn := _slotController.mySlotDefn;	
	
	create theTIs transient;
	_slotController.getProposedTIs(theTIs);
	if not theTIs.isEmpty() then
		ti := theTIs.first();		
	endif;
	
	if slotDefn &lt;&gt; null then
		locnDefn := slotDefn.myROROLocnDen ;
		if locnDefn &lt;&gt; null then				
			locnDefnVoyage := locnDefn.CM_ROROLocnDefnVoyage;
		endif;
	endif;
	
	if ti = null and locnDefnVoyage.myAdjacentSlotFwd &lt;&gt; null then
		backSlot := locnDefnVoyage.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal[locnDefnVoyage.myAdjacentSlotFwd.ordinal,slotDefn.ordinal].CM_ROROSlotDefnVoyage.mySlotController;
		backSlot.getProposedTIs(theTIs);
		if not theTIs.isEmpty() then
			ti := theTIs.first();
		else
			//21/12/2011 cnwdz2 par28870
			//self.doRefresh();//for when unplanning, temp solution!!!!!
			return;
		endif;
	endif;
	
	if ti &lt;&gt; null and not ti.is20() then
		if _slotController.isBackEnd(ti,PLANNING_MODE) then
			aftLocnDefnVoyage := locnDefnVoyage.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
			backSlotController := aftLocnDefnVoyage.allROROSlotDefnByOrdinal.first().CM_ROROSlotDefnVoyage.mySlotController;
		// PAR 28939
		elseif _slotController.isBackEnd(ti,REAL_MODE) then
			aftLocnDefnVoyage := locnDefnVoyage.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
			backSlotController := aftLocnDefnVoyage.allROROSlotDefnByOrdinal.first().CM_ROROSlotDefnVoyage.mySlotController;
		// PAR 28939
		elseif _slotController.isBackEnd(ti,QUEUE_MODE) then
			aftLocnDefnVoyage := locnDefnVoyage.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
			backSlotController := aftLocnDefnVoyage.allROROSlotDefnByOrdinal.first().CM_ROROSlotDefnVoyage.mySlotController;
		else
			fortyFrontEnd := true;
			aftLocnDefnVoyage := locnDefnVoyage.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
			backSlotController := aftLocnDefnVoyage.allROROSlotDefnByOrdinal.first().CM_ROROSlotDefnVoyage.mySlotController;
		endif;
	endif;	
	firstSlotController := locnDefnVoyage.allROROSlotDefnByOrdinal.first().CM_ROROSlotDefnVoyage.mySlotController;	
	
	if backSlotController &lt;&gt; null then
		foundSecond := self.frmLocationSlots.getPointsForObject(backSlotController, x21, y21, x22, y22);
		foundFirst  := self.frmLocationSlots.getPointsForObject(firstSlotController, x1, y1, x2, y2);
		
		if not foundFirst then
			x1 := (x21 + (x22-x21)/2 + self.myROROLocnDrawingController.interLocnSlotsWidth/2).Integer;
			y1 := y21;		
		endif;
		if not foundSecond then
			x21 := (x1 + (x2-x1)/2 + self.myROROLocnDrawingController.interLocnSlotsWidth/2).Integer;
			y21 := y1;		
		endif;		
		
		if fortyFrontEnd then
			self.frmLocationSlots.doRedrawWeightsAndHeights(aftLocnDefnVoyage,x1,y1 + self.myROROLocnDrawingController.slotHeight,Black,self.myROROLocnDrawingController.locnDefnWidth,self.myROROLocnDrawingController.slotHeight);			
			self.frmLocationSlots.doRedrawWeightsAndHeights(locnDefnVoyage,x21,y21 + self.myROROLocnDrawingController.slotHeight,Black,self.myROROLocnDrawingController.locnDefnWidth,self.myROROLocnDrawingController.slotHeight);
		else
			self.frmLocationSlots.doRedrawWeightsAndHeights(locnDefnVoyage,x21,y21 + self.myROROLocnDrawingController.slotHeight,Black,self.myROROLocnDrawingController.locnDefnWidth,self.myROROLocnDrawingController.slotHeight);			
			self.frmLocationSlots.doRedrawWeightsAndHeights(aftLocnDefnVoyage,x1,y1 + self.myROROLocnDrawingController.slotHeight,Black,self.myROROLocnDrawingController.locnDefnWidth,self.myROROLocnDrawingController.slotHeight);
		endif;
	else
		foundFirst  := self.frmLocationSlots.getPointsForObject(firstSlotController, x1, y1, x2, y2);	
		self.frmLocationSlots.doRedrawWeightsAndHeights(locnDefnVoyage,x1,y1 + self.myROROLocnDrawingController.slotHeight,Black,self.myROROLocnDrawingController.locnDefnWidth,self.myROROLocnDrawingController.slotHeight);
	endif;
	
epilog
	delete theTIs;
end;</source>
        <Parameter name="_slotController" type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="d4c79412-9951-4caa-ab49-42c2e73ffab1">
        <updating/>
        <source>doRefresh() updating, protected;
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars

begin 
	self.frmLocationSlots.isSideView := true;
	self.myROROLocnDrawingController.drawSelf(false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveSlotRemarks" id="cc4c13f6-e8b8-476f-81ef-483a81d8263f">
        <source>doRemoveSlotRemarks(_slot :CM_ROROSlotController) protected;
/*
Date		Who		Reason
13 Aug 2012	cnwcs5	Initial creation - par 29124
*/
vars
	coll			:ObjectSet;
	obj				:Object;
	control 		:Control;
	slotDefn		:CM_ROROSlotDefnVoyage;
	slot			:CM_ROROSlotController;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, slotDefn, gotException);
	
	coll := self.allRemarksControls;
	
	foreach obj in coll do
		control		:= obj.Control;
		slotDefn	:= control.userObject.CM_ROROSlotDefnVoyage;
		slot		:= slotDefn.mySlotController;
		
		if gotException or slot = _slot then
			coll.remove (control);
			delete control;
			gotException := false;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_slot" type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="doRepositionRemarks" id="c33a7ed1-a0b7-42ae-ad3c-2a8d206188de">
        <source>doRepositionRemarks() protected;
/*
Date		Who		Reason
30 July 2012	cnwcs5	Initial creation - par 29124
*/
vars
	obj			:Object;
	control		:Control;
	slot		:CM_ROROSlotDefnVoyage;
	left, top	:Real;	// note same name as form properties
begin
	// we may need to re-position remarks
	foreach obj in self.allRemarksControls do
		control := obj.Control;
		
		if not control.name = self.picRemarks.name then
			continue;
		endif;
		// user object is the slot
		slot := control.userObject.CM_ROROSlotDefnVoyage;
		
		if slot = null then
			continue;
		endif;
		
		// find the top left position for the location
		if not self.getPositionForRemarks (slot, left, top) then
			// should not happen
			continue;
		endif;
		
		control.move (left, top, control.width, control.height);
	endforeach;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="895e5d97-db52-4d74-bf96-b39ab9fc6887">
        <updating/>
        <source>doResize() updating;
/*
Date		    Who			Reason
18 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
31 Jul 2012		cnwcs5		par 29124 - edi stowage remarks.  Changed doArrangeFramesAndGroups to use parent aspect.
26 Jan 2018     cnwma1		Bug 36807: MSL - side location view - show caption
*/

vars

begin 
	inheritMethod();


	self.frmLocationPos.move(0,self.frmToolbar.height,frmLocationPos.width,self.clientHeight -self.frmToolbar.height-230); // 26.1.2018   cnwma1		Bug 36807
	self.frmStatus.move(0,self.frmToolbar.height,self.clientWidth,self.clientHeight - self.frmToolbar.height);             // 26.1.2018   cnwma1		Bug 36807
	
	self.frmLocationSlots.top :=  self.frmLocationPos.top;  // 26.1.2018   cnwma1		Bug 36807
	self.frmLocationSlots.height := (self.grpHazDetails.height + self.grpHazDetails.top ) -  self.frmToolbar.height ; // 26.1.2018   cnwma1		Bug 36807

	self.frmLocationPos.doResize();
	
	self.frmLocationSlots.doResize();
epilog

end;</source>
    </JadeMethod>
