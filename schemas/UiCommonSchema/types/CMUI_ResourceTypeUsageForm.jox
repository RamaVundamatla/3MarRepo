    <JadeMethod name="create" id="5d8dbf4c-1b56-4bac-a6da-51dd5ab2cbde">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	self.permissionView  := PmAdmTaskResourceView;
	self.permissionMaint := PmAdmTaskResourceMaint;
	
epilog

end;</source>
