    <JadeMethod name="doSaveSubQueueProxy" id="1c7db74f-ab58-45c8-90c4-6046c2af0b6b">
        <updating/>
        <source>doSaveSubQueueProxy() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theProxySQ		: CM_SubQueue;
	theID 						: String;
	isUni				: Boolean; 
	theparent					: CM_RadioTelemetryQueue;
	lookForFromAreaMove,
	lookForToAreaMove			: Boolean;
	allAllowedMachineGroupTypes	: IntegerArray;
	allAllowedDict				: CM_MachineTypeGroupByType;
	machineGroupType			: CM_MachineTypeGroup;
	allFromAreas,
	allToAreas					:CM_TAMasterByIdDict;
	allLCsFrom,
	allLCsTo						: CM_LCArray;
	
begin
	if self.mode = self.Mode_Add then
		create self.myProxyObject as CM_SubQueue transient;
	endif;
	theProxySQ := self.myProxyObject.CM_SubQueue;
		
	theID := self.tblMain.getValueByName(ETRow_Id).String;
	isUni := self.cmbDirectional.listIndex &lt;&gt; 1 ;
	theparent := self.cmbParent.listObject.CM_RadioTelemetryQueue;
	
	create allFromAreas transient;
	create allToAreas transient;
	create allLCsFrom transient;
	create allLCsTo transient;

	self.grpAreasCovered1.getSelected(allFromAreas);
	self.grpAreasCovered2.getSelected(allToAreas);
	if not isUni then
		lookForFromAreaMove	:= self.optGetSame1.value;
		lookForToAreaMove	:= self.optGetSame2.value;
	endif;
	
	create allAllowedMachineGroupTypes transient;
	create allAllowedDict transient;
	self.grpMachineTypeGr.getSelected(allAllowedDict);
	foreach machineGroupType in allAllowedDict do
		allAllowedMachineGroupTypes.add(machineGroupType.type);
	endforeach;
	
	self.grpFrmLocations.getSelected(allLCsFrom);
	self.grpToLocations.getSelected(allLCsTo);
	theProxySQ.setProxy(theID, theparent,isUni, allLCsFrom, allLCsTo, allFromAreas, allToAreas, lookForFromAreaMove, lookForToAreaMove, allAllowedMachineGroupTypes, app.myPassport.myTerminal);
	theProxySQ.setQueueType(self.cmbType.getCurrentItemData);
	if theProxySQ.queueType = QTYPE_VOYAGEYARD then
		theProxySQ.setProxyVoyageYard(self.cmbVoyage.listObject.CM_Voyage,self.cmbVoyageJobType.listData);
	endif;
	
epilog
	
	delete allAllowedMachineGroupTypes;
	delete allAllowedDict;
	delete allFromAreas;
	delete allToAreas;
	delete allLCsFrom;
	delete allLCsTo;
end;</source>
        <access>protected</access>
    </JadeMethod>
