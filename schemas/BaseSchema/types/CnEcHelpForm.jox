    <JadeMethod name="loadForm" id="bec87d74-f042-4f70-998b-5025a8835ef1">
        <updating/>
        <source>loadForm() updating;

//	sets up form for initial display

vars
	date	: Date;
	form	: Form;

begin
	aEarliestDate := date;	// set to today
	txtStartDate.text := (aEarliestDate - 7).format(self.DATE_FORMAT);

	lstForms.visible := false;
	tblSelectedForms.columnWidth[1] := 210;
	tblSelectedForms.columnWidth[2] := 85;
	btnB.visible := false;

	self.setOptionButtons(self.LIST_ONLY);	// set to list
	optAllForms.value := true;		// set to All forms

	create self.aAllValidFormsAsClasses transient;
	create self.aAllForms transient;

	// populate forms collection

	foreach form in Form.instances do
//		write(form.name);
		if not self.aAllForms.includes(form) then
			self.aAllForms.add(form);
		endif;
	endforeach;

	self.populateSchemas();
	self.populateForms();
end;</source>
    </JadeMethod>
