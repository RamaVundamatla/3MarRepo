    <JadeMethod name="actionFromMenuDtl" id="e7465814-56c9-4095-9881-b3a81478f66f">
        <updating/>
        <source>actionFromMenuDtl(_forceNew : Boolean; _userWindow : CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
20/09/2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	theForm		: Form;
	idx,
	numForms	: Integer;
	invalid		: Boolean;
	found		: Boolean;
	this		: CMUI_MenuAction;
	menuDtl		: CM_MenuDtlSystem;
	
begin
	menuDtl := self.myMenuDtl.CM_MenuDtlSystem;
	
	if (not _forceNew) then
	
		if menuDtl.isSystemDtl then	//don't have to look for form instance of correct terminal because only one
			theForm := app.getForm(menuDtl.windowClassName);
			
			if theForm &lt;&gt; null then
				self.myForm := theForm.CM_BaseForm;
				self.goToObject(theForm, null, true, null);
				delete self;
				return;
			endif;
			
		else //have to loop through all of same form type to bring foward form with correct terminal
			numForms := app.formsCount;
			
			foreach idx in 1 to numForms do
			    theForm := app.forms(idx);
				
			    if theForm.name = self.myMenuDtl.windowClassName then
			        if CM_BaseForm.hasInstance(theForm) then
			        	if theForm.CM_BaseForm.myTerminal = self.myTerminal then
			        		self.myForm := theForm.CM_BaseForm;
			        		found := true;
			        		break;
			        	endif;
			        endif;
			    endif;
			endforeach;
			
			if found then
				self.goToObject(theForm, null, true, null);
				delete self;
				return;
			endif;
		endif;
	endif;

	self.myController	:= app.myController;

// cnwdad1 11/07/2008 - PAR #17493 - Only send notification if the form is successfully opened.
	theForm	:=	self.goToObject(null, null, true, _userWindow);
	// 37017 if the form unloads itself because the user does not have access, 'self' will be deleted and go invalid
	//   so don't do the causeEvent in this case to avoid an exception in the receiving userNotify
	if theForm &lt;&gt; null then
		this := self;
		on Exception do app.handleDeletedObject(exception, this, invalid);
		this.creationTime();  //cause exception if invalid
			
		//if not global.isValidObject(menuEnt) then
		if not invalid then
			app.causeEvent(CMUI_NavObject_Add, true, self);
		endif;
	endif;
end;</source>
        <Parameter name="_forceNew" type="Boolean"/>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getFormClass" id="b714de09-dbe8-4d1d-92b6-9b9d786e5a2c">
        <source>getFormClass(_formCls, _assistCls : Class output) protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	subSys		: CMUI_SubSystem;
		
begin

	subSys := app.myController.allSubSystems[self.myMenuDtl.schemaName];

	if subSys = null then
		self.getLocalFormDetails(self.myMenuDtl.windowClassName, _formCls, _assistCls);
	else
		subSys.getFormDetails(self.myMenuDtl.windowClassName, _formCls, _assistCls);
	endif;
			
end;</source>
        <access>protected</access>
        <Parameter name="_formCls" type="Class" usage="output"/>
        <Parameter name="_assistCls" type="Class" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLocalFormDetails" id="4bd36e44-4f8d-4edf-a3bc-9629b4404315">
        <source>getLocalFormDetails(pFormName : String; pFormClass, pAssistantClass : Class output) protected;
// ---------------------------------------------------------------------------
// Created:     23 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pFormClass := self.class.schema.getClass(pFormName);
	pAssistantClass := CMUI_Assistant;

end;</source>
        <access>protected</access>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pFormClass" type="Class" usage="output"/>
        <Parameter name="pAssistantClass" type="Class" usage="output"/>
    </JadeMethod>
    <JadeMethod name="goToObject" id="dd96ccf3-93b9-44ae-b1a1-44d053226e5c">
        <updating/>
        <source>goToObject(pWindow : Window; pFieldName : String; pDoFormShow : Boolean; _userWindow : CM_UserWindow) : CM_BaseForm updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	form		: CM_BaseForm;
	mdiForm		: Form;
	tbl			: CM_EntryTable;
	theRow		: Integer;
	fieldFound	: Boolean;
	cntrl		: Control;
	indx		: Integer;
	formCls,
	assistCls	: Class;
	subSys		: CMUI_SubSystem;
	savePointer	: Integer;
	tmpWindowClassName	: String;
		
begin

	savePointer := app.mousePointer;
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.myForm &lt;&gt; null then
		form := self.myForm;
	else
		if form = null then
		
			tmpWindowClassName := self.myMenuDtl.windowClassName;
				//cls := app.myController.allSubSystems.first.getFormClass(self.actionCode);
			subSys := app.myController.allSubSystems[self.myMenuDtl.schemaName];

			if subSys = null then
				if currentSchema.name = self.myMenuDtl.schemaName then
					self.getLocalFormDetails(tmpWindowClassName, formCls, assistCls);
				else
					app.msgBox(app.getErrorString1(VB_SECSHOW, self.myMenuDtl.heading), "Security Warning", MsgBox_Stop_Icon);
					return form;
				endif;
			else
				subSys.getFormDetails(tmpWindowClassName, formCls, assistCls);
			endif;
			
			// DCTG 14063 error
			if formCls = null then
				return null;
			endif;
			
			
			form := app.loadForm(formCls, assistCls, false, false, false, self.myTerminal, self).CM_BaseForm;

			if form = null then
				// user does not have permission to view this form
				return form;
			else
				self.myForm := form;
				self.myFormWhenMaster := form;
				self.setMyWindowControl(form, null);
				form.setMyTerminal(self.myTerminal);
				if _userWindow &lt;&gt; null then
					form.myUserWindow := _userWindow;
				else
					form.myUserWindow := app.getUserWindow(tmpWindowClassName, false);
				endif;
				if pDoFormShow then
					form.show;
				else
					return form;
				endif;
			endif;
		endif;
	endif;
	// if unload in a form load self is invalid
	if (not global.isValidObject(self)) then // AKB2003MAR added
		return null;
	endif;

	if app.userSavedWindowSettings then
		// as just opened windows at start do not bother
		// setting focus, etc
		return form;
	endif;
	
	if form.windowState = Form.WindowState_Minimized then
		form.windowState := Form.WindowState_Normal;
	endif;
	
	form.setFocus;
	form.zOrder(1);

	if self.myWindowControl &lt;&gt; null then
		if self.myWindowControl.isKindOf(Control) and self.windowControlId &lt;&gt; null then
			self.myWindowControl.Control.getControl(self.windowControlId).setFocus;
		else
			self.myWindowControl.setFocus;
		endif;
	endif;

	if pWindow &lt;&gt; null then
		pWindow.setFocus;

		if pFieldName &lt;&gt; null then
			fieldFound := false;
			
			if pWindow.isKindOf(CM_EntryTable) then
				tbl := pWindow.CM_EntryTable;
				if tbl.goToRowByName(pFieldName) then
					fieldFound := true;
				endif;
			endif;
			
			if not fieldFound then
				// search controls which have pWindow as a parent
				foreach indx in 1 to form.controlCount do
					cntrl := form.controls(indx);
					if cntrl.parent = pWindow then
						if cntrl.name = pFieldName then
							cntrl.setFocus;
							fieldFound := true;
							break;
						endif;
						if cntrl.isKindOf(CM_EntryTable) then
							tbl := cntrl.CM_EntryTable;
							if tbl.goToRowByName(pFieldName) then
								tbl.setFocus;
								fieldFound := true;
								break;
							endif;
						endif;
					endif;
				endforeach;
			endif;

			if not fieldFound then
				
			endif;

		endif;
	endif;
	
	/*
		Date	Who		Reason
	26 Sep 2008	cnwdz2	Par17034 - resize the form before show the form.
	*/
	if pDoFormShow then
		form.resizePostInitialShow(); // PAR 37202  - if the form is maximised it is only maximised after the form.show above. if controls need to have their size and position set this has to be done after the form maximise.
		form.doResize();
	endif;
	
	return form;
	
epilog
	app.mousePointer := savePointer;
end;</source>
        <Parameter name="pWindow" type="Window"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pDoFormShow" type="Boolean"/>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
        <ReturnType type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="handleDblClick" id="df8d5923-0923-4077-9622-d15c8a1a6bdf">
        <updating/>
