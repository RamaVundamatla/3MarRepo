    <JadeMethod name="verifyReceiveDate" id="ec618e39-3e5f-4a28-8e19-19a05858bec3">
        <source>verifyReceiveDate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2014	cnwrd1	Initial creation
par 35163

*/

vars

begin
	
	if self.receiveDate &gt; app.actualTimeServer then
		app.raiseCMWarning(Recei_date_great_than_curre_sy ,ETRow_ReceiveDate, self, self);
	endif;
	
epilog
end;</source>
    </JadeMethod>
