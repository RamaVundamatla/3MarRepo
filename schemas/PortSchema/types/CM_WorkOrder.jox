    <JadeMethod name="canAccessCashReceipts" id="f9878447-f1d5-4af5-9f4a-d98c18eabff8">
        <source>canAccessCashReceipts(_user : CM_User; _passport : CM_Passport) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Dec 2018	jlger1	Initial creation 42345
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	cashReceipt : CM_CashReceipt;
	failedDAC   : CM_DataAccessController;
	debtor		: CM_Debtor;
	
begin
	
	foreach cashReceipt in  self.allCashReceipts do
		// PEL UAT WP Testing 20SEP18
		if cashReceipt.allCashPayments.isEmpty() then
			continue;
		endif;
		debtor := cashReceipt.getDebtor();					//12.01.2023 navma1 #56141 Task#56147
		if debtor = null then
			continue;
		endif;
		if not debtor.canUserAccessSelf(_user, failedDAC, _passport) then
			continue;
		endif;
		return true;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="7a0df353-ceca-4c23-9321-ea4a453abed1">
        <source>canAccessConsigneeConsignor(_user : CM_User) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
//
vars
	woDtl : CM_WorkOrderDtl;

begin
	foreach woDtl in self.allWoDtls discreteLock do
		if woDtl.canAccessConsigneeConsignor(_user) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
