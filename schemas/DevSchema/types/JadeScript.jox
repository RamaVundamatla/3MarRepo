    <JadeMethod name="eprTestTINav" id="cca2c63c-9679-4521-8484-329b58863644">
        <source>eprTestTINav();
/*

Date		Who		Reason
03 February 2015	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	allPermissions : IntegerArray;
	menuDtl			: CM_MenuDtlNav;
	tmpClassName	: String;
	tmpClass		: Class;
	userDtl			: CM_MenuUserDtl;
	menuAction		: CM_MenuAction;
		ut				: CM_UserTerminal;
begin

	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	ti:="2367.6357982".asOid.CM_TrackedItem;
	app.myPassport.setMyTerminal(ti.myTerminal);
	
	//app.zGetTranslatedText(EntTableRows, ETRow_MyHeight)
	create allPermissions transient;
/*	if ti = null then
		return;
	endif;
	
	allPermissions.add(PmAdmCargoEnquiryView);
	if ti.jobRoadReceive &lt;&gt; null or ti.jobRoadRelease &lt;&gt; null then
		
		
		allPermissions.add(PmAdmRoadopsdualView);
	endif;
	
	if ti.allVisitRecords.size &gt; 0 then
		allPermissions.add(PmGteVisitRecordView);
	endif;*/
	
	menuDtl:=app.myRoot.myMenuRoot.allMenuDtlsByPermValue[PmAdmCargoEnquiryView];
	if menuDtl.classNameToCreate &lt;&gt; null then
		tmpClass := currentSchema.getClass(menuDtl.classNameToCreate);
		write tmpClass;
		ut := app.myPassport.myUser.getUserTerminal(app.myPassport.myTerminal);
		if ut &lt;&gt; null then
			userDtl := menuDtl.getMenuUserDtl(ut).CM_MenuUserDtl;
			create menuAction as tmpClass transient;
		
			menuAction.setFromMenuDtl(userDtl,menuDtl);
			menuAction.actionFromMenuDtl(true, null);
		endif;
	endif;
epilog
	delete allPermissions;
	delete menuAction;
end;</source>
