<CollClass name="CM_ReserveDetailSet" id="cf63e889-8815-4f40-bc7b-462cd1ce7924">
    <loadFactor>98</loadFactor>
    <memberType name="CM_ReserveDetail"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="getReserveDetailForTi" id="9bf14e4f-35eb-48b6-a074-efcfea0d8abc">
        <source>getReserveDetailForTi(_expectedRelease : String) : CM_ReserveDetail;
/*

Purpose:			Gets the Reserve Detail from the ti matching the release request supplied

Parameters:			_expectedRelease	String	The expected release request code for the reserve detail line so we get the correct one

Return Value:		CM_ReserveDetail	Representing the reserve detail for the release request code specified

Date			Who		Reason
20 June 2023	navpw1	Initial creation TFS: 57876 (58721)

*/

vars
	iter			: Iterator;
	reserveDetail	: CM_ReserveDetail;
	reserveHeader	: CM_BulkRelease;
	found			: Boolean;
	
begin
	iter := self.createIterator;
	
	while iter.next(reserveDetail) do
		reserveHeader := reserveDetail.myReserveHeader;
		
		if reserveHeader &lt;&gt; null and reserveHeader.code = _expectedRelease then
			return reserveDetail;
			
		endif;
		
	endwhile;
	
	return null;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_expectedRelease" type="String"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getReserveTiFor" id="8e10c83a-7d6d-4091-ba0a-1a0d5d15379d">
        <source>getReserveTiFor( _ti : CM_TrackedItem ):CM_ReserveTI;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2017	jlgndl1	Initial creation	TFS 5477

*/

vars

	iter : Iterator;
	resDetail : CM_ReserveDetail;
	resTi : CM_ReserveTI;

begin

	if _ti = null then
		return null;
	endif;

	iter := self.createIterator;
	while iter.next( resDetail ) do
		if resDetail.isKindOf( CM_ReserveTI ) then
			resTi := resDetail.CM_ReserveTI;
			if resTi.getTI = _ti then
				return resTi;
			endif;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ReserveTI"/>
    </JadeMethod>
</CollClass>
