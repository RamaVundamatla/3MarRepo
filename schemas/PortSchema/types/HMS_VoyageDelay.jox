    <JadeMethod name="archive" id="ce720328-2da9-4a85-a663-bd2f31e25b78">
        <updating/>
        <source>archive(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	// not deleted only archived therefore no transaction needed
	//self.createTransaction(TRANS_TYPE_DeleteVoyageDelay, null, null, _passport);

	self.archived := true;
	self.archivedDT := app.serverTimestampAtTrxStart;
	self.myVoyageDataArchived := self.myVoyageData;
	self.myVoyageData := null;
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
