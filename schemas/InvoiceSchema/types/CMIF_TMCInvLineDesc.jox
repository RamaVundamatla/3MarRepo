    <JadeMethod name="getPicture" id="95e03946-8759-4242-8723-cdf97096766a">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picInvLineDesc;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
