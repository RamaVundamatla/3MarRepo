    <JadeMethod name="rel842_tfs1987" id="b6e14379-0f1e-4958-b054-c6c050bdb1cf">
        <source>rel842_tfs1987();
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars
	xlationTable : CM_XlationTable;
	newXlationTable : CM_XlationTable;
	xlation : CM_Xlation;
	xlation2 : CM_Xlation;
	cargoType : CM_CargoType;
	oldCargoType : CM_CargoType;
	firstTime : Boolean;
	entAgent : EntTableAgent;
	entArray : StringArray;
	transAgent : CM_TranslationAgent;
	transArray : StringArray;
	operator : CM_Operator;
begin
	app.initialize();
	create entAgent transient;
	create entArray transient;
	entAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	entArray.add("ETRow_CargoType");
	entArray.add("ETDef_EDIXlations");
	entAgent.trxUpdateFromConstant(entArray);
	app.writeStatement("Finished EntTable");
	
	beginTransaction;
	foreach xlationTable in CM_XlationTable.instances do
		if xlationTable.type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
			if xlationTable.getMyCargoType = null then
					operator := xlationTable.myOperator;
//write class.name&amp;'::'&amp;method.name&amp;' 10 '&amp;xlationTable.getDisplayDetails(true);

				foreach xlation in xlationTable.allInwardTranslations do
//write class.name&amp;'::'&amp;method.name&amp;' 20 '&amp;xlation.getDisplayDetails(true);
					cargoType := xlation.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product.myCargoType;
					if cargoType = null then
//write class.name&amp;'::'&amp;method.name&amp;' 30 '&amp;xlation.getDisplayDetails(true);
//write class.name&amp;'::'&amp;method.name&amp;' 40 write mess wee have beer.';
	
					else
//write class.name&amp;'::'&amp;method.name&amp;' 45 '&amp;cargoType.abbreviation;
						if oldCargoType = null then
							xlationTable.setMyCargoType(cargoType);
						else
							if oldCargoType = cargoType then
							else
								newXlationTable := operator.allXlationTables[XLATION_TYPE_CARGOSUBTYPE_BYOP, cargoType];
								if newXlationTable = null then
								create newXlationTable;
								newXlationTable.setProxy(xlationTable.type, xlationTable.myRoot, operator, xlationTable.myOperatorTerminal, cargoType,null);
//write class.name&amp;'::'&amp;method.name&amp;' 50 '&amp;newXlationTable.getDisplayDetails(true);
//write class.name&amp;'::'&amp;method.name&amp;' 55 '&amp;xlation.getDisplayDetails(true);
								else
//write class.name&amp;'::'&amp;method.name&amp;' 60 '&amp;newXlationTable.getDisplayDetails(true);
//write class.name&amp;'::'&amp;method.name&amp;' 65 '&amp;xlation.getDisplayDetails(true);
								endif;
								xlation.setXlationTable(newXlationTable);
								foreach xlation2 in xlationTable.allOutwardTranslations do
//write class.name&amp;'::'&amp;method.name&amp;' 70 '&amp;xlation2.getDisplayDetails(true);
									if xlation2.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product.myCargoType = newXlationTable.getMyCargoType then
//write class.name&amp;'::'&amp;method.name&amp;' 75 '&amp;xlation2.getDisplayDetails(true);
										xlation2.setXlationTable(newXlationTable);
									endif;
								endforeach;	
							endif;
						endif;
						oldCargoType := cargoType;
//write class.name&amp;'::'&amp;method.name&amp;' 80 '&amp;cargoType.abbreviation;
					endif;
				endforeach;
				foreach xlation in xlationTable.allInwardTranslations do
//write class.name&amp;'::'&amp;method.name&amp;' 90 '&amp;xlation.getDisplayDetails(true);
					cargoType := xlation.getPropertyValue(CM_Xlation::mySystemObject.name).CM_Product.myCargoType;
					if cargoType &lt;&gt; xlationTable.getMyCargoType then
//write class.name&amp;'::'&amp;method.name&amp;' 92 '&amp;xlation.getDisplayDetails(true);
						newXlationTable := operator.allXlationTables[XLATION_TYPE_CARGOSUBTYPE_BYOP, cargoType];
//write class.name&amp;'::'&amp;method.name&amp;' 94 '&amp;newXlationTable.getDisplayDetails(true);
						xlation.setXlationTable(newXlationTable);
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	commitTransaction;
return;
	write(ETRow_CargoType);
	write(ETDef_EDIXlations);
end;
</source>
    </JadeMethod>
