    <JadeMethod name="addConstantsServer" id="af0e687e-9012-4ad7-9baf-7cd1c6f64d5a">
        <executionLocation>server</executionLocation>
        <source>addConstantsServer(_category, _constantStr : String; _rtnStr : String output) : Integer serverExecution;
// ---------------------------------------------------------------------------
// Created:     21 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	Hdr	: String = 	'jadeVersionNumber "5.2.08";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=802, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';
vars
	f		: File;
	args	: StringArray;
	result	: Integer;
	rtnStr	: String;
		
begin

	result := -1;

	create f transient;
	f.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	f.fileName := 'c:\temp\etLoad' &amp; app.actualTimeServer.date.formatAsYYYYMMDD() &amp; app.actualTimeServer.Time.format('HHmmss') &amp; '.scm';// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	f.writeLine(Hdr);

	rtnStr := rtnStr &amp; CrLf &amp; '  creating ' &amp; f.fileName;

	f.writeLine('categoryDefinition ' &amp; _category);
	f.writeLine(_constantStr);
	
	f.close;
	
	create args transient;
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; f.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; f.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=currentSchemaVersion');
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant - adding to server - fileName: ' &amp; 
		f.fileName &amp; ' external process details: ' &amp; rtnStr, LogINFO);															// 20/09/2012 cnwmh5
		
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant - return result: ' &amp; result.String, LogINFO);		// 20/09/2012 cnwmh5
	
	return result;
	
epilog
	_rtnStr := rtnStr;
	delete args;
	if f &lt;&gt; null then
		f.close;
//		f.purge;
	endif;
	delete f;
	
end;</source>
        <Parameter name="_category" type="String"/>
        <Parameter name="_constantStr" type="String"/>
        <Parameter name="_rtnStr" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcAverageSEDMean" id="5a3f42e9-84fa-458c-be6b-b2158bc1e001">
        <source>calcAverageSEDMean(_len, _vol : Decimal; _numItems : Integer) : Decimal;
// ---------------------------------------------------------------------------
// Created:     25 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	//averageSED			: Decimal[12,3];
	averageSED			: Decimal[12,5];
	wrk,
	avVol				: Decimal[12,3];
	
begin

	// returned to previous method as per PAR-4655 and response from John Ellis @ Owens

	if _len &lt;= 0 or _vol &lt;= 0 or _numItems &lt;= 0 then
		averageSED := 0;
	elseif _len &lt; 6.0 then
		averageSED := ((10000 * _vol / _len) / _numItems).Real.sqrt;
	else
		averageSED := ((((10000 * _vol / _len) / _numItems).Real.sqrt) - ((_len.truncated - 4)/2));
	endif;
	
	return averageSED.roundedTo(3);

/*

 	//CNWTH2 - method ammended to produce average SED result that co-insides with
 	//what Northport claim to be the correct and only formula. Prior method produced
 	//a discrepancy due to precision of the average volume value used in this calculation.
 	
 	//Commented lines are taken from the Access app northport use to crunch this number

	if _len &lt;= 0 or _vol &lt;= 0 or _numItems &lt;= 0 then
		return 0;
	endif;
	
	avVol := (_vol / _numItems);		// this is rounded to 3 dp and was the cause of the discrepancy.

   	if _len &lt; 6 then
        averageSED := ((avVol * 10000) / _len).Real.sqrt;
	    //Me.Result = Sqr(Me.AvVolume * 10000 / Me.Len)
    else
        wrk := (_len.Integer - 4) / 2;
        averageSED := ((avVol * 10000) / _len).Real.sqrt - wrk;
       //     wrk = (Int(Me.Len) - 4) / 2
       // Me.Result = Sqr(Me.AvVolume * 10000 / Me.Len) - wrk

    endif;
    
    return averageSED.roundedTo(2);
*/	
	/*Prior methodology - only difference is the rounding of the (_vol / _numItems) to 3 dp.
	
	if _len &lt;= 0 or _vol &lt;= 0 or _numItems &lt;= 0 then
		averageSED := 0;
	elseif _len &lt; 6.0 then
		averageSED := ((10000 * _vol / _len) / _numItems).Real.sqrt.roundedTo(3);
	else
		averageSED := ((((10000 * _vol / _len) / _numItems).Real.sqrt) - ((_len.truncated - 4)/2)).roundedTo(3);
	endif;
	
	return averageSED;
	*/

	
end;</source>
        <Parameter name="_len" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_numItems" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calcAverageSEDMeanMixed" id="cebfeeaf-4de8-4fca-91e2-ae86372c6b43">
        <source>calcAverageSEDMeanMixed(_len, _meanSED : DecimalArray; _numItems : IntegerArray) : Decimal;
// ---------------------------------------------------------------------------
// Created:     25 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	tot			: Integer;
	averageSED	: Decimal[6,2];
	numerator,
	denominator	: Real;
	sed,
	len			: Decimal[10,4];
	num			: Integer;

begin

	tot := _len.size;

	if tot &lt;&gt; _meanSED.size or
	   tot &lt;&gt; _numItems.size then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Number of items in each array must be equal (' &amp;
				tot.String &amp; ', ' &amp; _meanSED.size.String &amp; ', ' &amp; _numItems.size.String &amp; ')');
		return averageSED;
	endif;
	
	foreach idx in 1 to tot do
		sed	:= _meanSED[idx];
		len	:= _len[idx]; 
		num	:= _numItems[idx];
		
		if sed &lt;= 0 or len &lt;= 0 or num &lt;= 0 then
			continue;
		endif;
		numerator 	:= numerator + (sed * sed * len * num);
		denominator	:= denominator + _len[idx] * _numItems[idx];
	endforeach;
	
	if denominator &lt;&gt; 0 then
		averageSED := (numerator / denominator).sqrt.roundedTo(5);
	endif;
	
	return averageSED;

end;</source>
        <Parameter name="_len" type="DecimalArray"/>
        <Parameter name="_meanSED" type="DecimalArray"/>
        <Parameter name="_numItems" type="IntegerArray"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calcJASVolume" id="5843a180-110f-4272-ae36-c87ec28c6de4">
        <source>calcJASVolume(_sedMean, _length : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jasVolume	: Decimal[12,3];
	diameter,
	calLength,
	tmpVolume	: Real;
	calLength2	: Integer;
begin

	diameter := _sedMean;
	if diameter = NULL_UNSCALED_LOG_SED then
		jasVolume := 0;
		return jasVolume;
	endif;

	calLength := _length;

	if calLength &lt; 6 then
		tmpVolume := (diameter.squared * calLength) / 10000;
	else
		calLength2 := calLength.truncated;
		tmpVolume := (diameter + (calLength2 - 4)/2).squared * (calLength /10000);
	endif;
	
	jasVolume := tmpVolume.roundedTo(3);

	return jasVolume;
	
end;</source>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calcSEDMean" id="af67173e-17b9-4175-b7f1-5a4abc511794">
        <source>calcSEDMean(_sedMin, _sedMax : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	difference : Integer;
	sedMean		: Decimal[6,2];

begin
	
	if _sedMin = NULL_UNSCALED_LOG_SED or
	   _sedMax = NULL_UNSCALED_LOG_SED then
	   	sedMean := NULL_UNSCALED_LOG_SED;
	   	return sedMean;
	endif;
	
	if _sedMin = NULL_NEVERSCALED_LOG_SED or
	   _sedMax = NULL_NEVERSCALED_LOG_SED then
		// In this case SEDMean is going to be set manually
	   	return sedMean;
	endif;	

	difference := (_sedMax - _sedMin).Integer;
	sedMean := _sedMin;		//????
	if _sedMin &gt;= 14 and _sedMin &lt; 40 then
		sedMean := sedMean + ((difference div 6) * 2);
	elseif _sedMin &gt;= 40 then
		sedMean := sedMean + ((difference div 8) * 2);
	endif;
	
	sedMean := sedMean.roundedTo(2);
	
	return sedMean;
	
end;</source>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMax" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calcSEDMeanFromVolume" id="9c9c0ffc-dea0-4eef-8df3-85af34d833ed">
        <source>calcSEDMeanFromVolume(_jasVolume, _length : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     12 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sedMean, 
	jasVolume	: Decimal[12,3];
	diameter,
	calLength	: Real;
	calLength2	: Integer;
begin

	calLength := _length;
	if calLength = 0 then
		return sedMean;
	endif;
	if calLength &lt; 6 then
//		tmpVolume := (diameter.squared * calLength) / 10000;
		diameter := ((_jasVolume * 10000) / calLength).Real.sqrt;
	else
		calLength2 := calLength.truncated;
//		tmpVolume := (diameter + (calLength2 - 4)/2).squared * (calLength / 10000);
		diameter := (_jasVolume * (10000 / calLength)).Real.sqrt - ((calLength2 - 4) / 2);
	endif;
	
	sedMean := diameter.roundedTo(3);

	return sedMean;
	
end;</source>
        <Parameter name="_jasVolume" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="certifyDataBase" id="5873183e-7d7a-43c8-b6d1-41328bcf10fa">
        <source>certifyDataBase();	// serverExecution;
// ---------------------------------------------------------------------------
// Created:     29 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dba			: JadeDatabaseAdmin;
	allFiles	: DbFileArray;
	dbf			: DbFile;
	numErrors	: Integer;

begin

	create dba transient;
	create allFiles transient;

	// Find what files we are going to backup
	dba.getAllDbFiles(allFiles);
	foreach dbf in allFiles do
		app.writeStatement(dbf.name);
		numErrors := dbf.certifyFile();
		if numErrors &lt;&gt; 0 then
			app.writeStatement( 'found errors &gt;&gt;' &amp; numErrors.String);
		else
			app.writeStatement( 'no errors');
		endif;
	endforeach;

epilog
	delete dba;
	delete allFiles;
end;</source>
    </JadeMethod>
