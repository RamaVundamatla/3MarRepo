	self.myVoyage := self.myMobileGenericAgent.myVoyage; //12 Sep 2016	NDL	TFS 2246
	self.setVoyageCounts();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="93021e80-43b1-4037-8746-d2b5a5c1480a">
