    <JadeMethod name="copyFrom" id="699fe491-2001-478a-85b5-52d7a6208f32">
        <updating/>
        <source>copyFrom(_map : CM_ProductGroupMap; _productGroup : CM_ProductGroup; _parent : CM_TIServiceMap) updating;
// 32311 set up self from the parameter plus the new product, copy all of the parameter map children under self.
vars
	pm			: CM_ProductMap;
	newPM		: CM_ProductMap;
begin
	self.myProductGroup := _productGroup;
	if _parent = null then
		self.myCargoTypeMap := _map.myCargoTypeMap;
	else
		self.myCargoTypeMap := _parent;
	endif;
	// copy of cargo type or product group just takes the default
	foreach pm in _map.allProductMaps do
		if not pm.myProduct = null then
			continue;
		endif;
		create newPM as pm.class persistent;
		newPM.copyFrom(pm, pm.myProduct, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_ProductGroupMap"/>
        <Parameter name="_productGroup" type="CM_ProductGroup"/>
        <Parameter name="_parent" type="CM_TIServiceMap"/>
    </JadeMethod>
