    <JadeMethod name="checkForJadescriptMethods" id="ae9a0712-ee0e-4a89-a03f-ea2c1d10aba5">
        <source>checkForJadescriptMethods(_hasMethod, _hasAppMethod, _hasRun : Boolean io; _str : String; _checkMethods : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2013	cnwmc5	Initial creation	PAR 32864

*/

vars
	tokens			: StringArray;
	
	token			: String;
	containsJS		: Boolean;
	pos				: Integer;
begin
	containsJS := false;
	
	create tokens transient;
	_str.getTokensForDelimiter(' ', tokens);
	
	foreach token in tokens do
		if token = 'JadeScript' then
			containsJS := true;
			break;
		endif;
	endforeach;
	
	if not containsJS then
		return;
	endif;
	
	if _checkMethods then
		pos := 1;	
		foreach token in tokens do
			if token = 'appJadeScript' then
				_hasAppMethod := true;
			elseif token.cnContains('_') and token.toUpper().scanUntil('_', pos) = ('REL' &amp; CM_Version.VERSION.replaceString('.', '')) then
				_hasMethod := true;
			endif;
		endforeach;
	else
		foreach token in tokens do
			if token = 'Run' then
				_hasRun := true;
			endif;
		endforeach;
	endif;
epilog
	delete tokens;
end;</source>
        <Parameter name="_hasMethod" type="Boolean" usage="io"/>
