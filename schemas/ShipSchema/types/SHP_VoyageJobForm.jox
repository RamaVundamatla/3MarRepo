    <JadeMethod name="doUserNotes" id="47457288-9b09-42f0-bc79-5ccf08e26f76">
        <updating/>
        <source>doUserNotes(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------
// Created:	10 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	event : Integer;
begin

	inheritMethod(eventType, theObject, eventTag, userInfo);
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if theObject = self.filterVoyage then
		if userInfo &lt;&gt; null and userInfo.isKindOf(CM_VoyageJob) then
			if event = VoyageJob_Create_Event then
				self.zTblDataSysNotifyCreate(eventType, userInfo.CM_VoyageJob, eventTag);
			endif;
		endif;
	endif;
			
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getActualEndTS" id="a667e586-9391-4e4b-b925-057e40ae7297">
        <source>getActualEndTS(endTs : TimeStamp io) : Boolean;

vars
	theDate : Date;
	theTime : Time;
	localTS : TimeStamp;
begin
	theDate  := null;
	theTime  := null;
	theDate:=self.tblJobEdit.getValueAsDate(ETRow_ActualEndDate);
	theTime:=self.tblJobEdit.getValueByName(ETRow_ActualEndTime).Time;
	
	localTS.setDate(theDate);
	localTS.setTime(theTime);
	
	endTs := self.localToSystemTime(localTS);	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	return true;
end;
</source>
        <Parameter name="endTs" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActualStartTS" id="42372d24-83c4-4842-8ded-95cdc9d2c041">
        <source>getActualStartTS(startTs : TimeStamp io) : Boolean;

vars
	theDate : Date;
	theTime : Time;
	localTS : TimeStamp;
begin
	theDate  := null;
	theTime  := null;
	theDate  :=self.tblJobEdit.getValueAsDate(ETRow_ActualStartDate);
	theTime  := self.tblJobEdit.getValueByName(ETRow_ActualStartTime).Time;

	localTS.setDate(theDate);
	localTS.setTime(theTime);
	
	startTs := self.localToSystemTime(localTS);	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	return true;
end;
</source>
        <Parameter name="startTs" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="34112389-2cd2-4dea-b7c6-5f65db8e6ba2">
        <updating/>
        <source>includeObject(_job: CM_Job; _passport : CM_Passport): Boolean updating;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin

	if (self.filterStatus = FILTER_STATUS_NULL or self.filterStatus = _job.status) 
	and (self.filterJobId = null or self.filterJobId = _job.jobId) then
		return true;
	endif;
		
	return false;

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="19801fab-dbd3-470a-be09-2f15429c346c">
        <updating/>
        <source>initDataTable() updating;
//--------------------------------------------------------------
//Created: 22 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	theDef : EntTableDef;
begin

	theDef := app.myController.getEntTableDef(ETDef_JobTbl);
	self.tblData.setTblDataEntRowsFromDef(theDef);
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_JobId, false);
	

end;</source>
