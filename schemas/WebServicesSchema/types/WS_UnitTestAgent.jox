    <JadeMethod name="wsRESTGetCustomers" id="128cd32c-a959-480f-a79e-382a7b7137f9">
        <source>wsRESTGetCustomers(_queryParamString : String; _testDesc: String; _response : String io; _errors : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2023	navra1	Initial creation for TFS 56641
20/07/2023		navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice
24 Feb 2024 	navhn30	ChangeRequest 59198: MTN - REST GET /Customers and /Customer/Id TerminalConfiguration optional
04 Mar 2024		navlw1	ChangeRequest 62669: MTN - MTN | Unit Tests - add validation checks to getCustomer
*/

vars
	request				: WS_MAPICustomer;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;	
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	jsonFormat			: String;
	newJson 			: String;
	customer 			: WS_RestCustomerObject;
	authToken 			: String;	
	respCust 			: WS_CustomerArray;
	errorListStr 		: String;
	dict 				: WS_QueryStringParamDict;
	startFrom 			: Integer;
	relEnts 			: Boolean;
	spConfig 			: Boolean;
	jsonHelper 			: JMTJadeJson;
	
begin
	
	create webService transient;
	create parser transient;
	create transientJSONObjs transient;		
	
	self.loginREST(webService);	
	
	webService.qsData.parseNameValuePair(_queryParamString);
	
	response := webService.getCustomers();
	
	if response = null then
		return "Response is null"; 
	endif;
	
	// check if we have any errors
	if response.allErrors.isNotEmpty then
		return response.allErrors.first.text;
	endif;
	
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response.WS_CustomerResponse.customers[1], JadeJson.Format_Json_Microsoft);
	
	//verification stuff
	if _testDesc = "RELENT_T_NOSTART" then
		startFrom := 1;			//since there was not start specified
		relEnts := true;
		respCust := response.WS_CustomerResponse.customers;
		// get the first debtor
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);		
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;			
		endif;
	elseif _testDesc = "REL_ENT_TRUE_START_200" then
		startFrom := 200;			
		relEnts := true;
		respCust := response.WS_CustomerResponse.customers;
		// get the first customer, should be different from the above check as starting position is different
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "RELENT_F_NOSTART" then
		startFrom := 1;			
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
		
	elseif _testDesc = "RELENT_T_START10" then
		startFrom := 10;			
		relEnts := true;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "RELENT_F_START10" then
		startFrom := 10;			
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "RELENT_F_START_OVERFLOW" then
		startFrom := 1;			
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "RELENT_F_START_UNDERFLOW" then
		startFrom := 1;			
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, relEnts, null, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	
	elseif _testDesc = "SPLCONFIG_T_NOSTART" then			// 26.02.24		navhn30		TFS #59198
		startFrom := 1;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		// just return the terminal config as the response
		_response := jsonHelper.generateJson(response.WS_CustomerResponse.customers[1].terminalSpecificConfiguration, JadeJson.Format_Json_Microsoft);
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "SPLCONFIG_TRUE_START_200" then
		startFrom := 200;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "SPLCONFIG_F_NOSTART" then
		startFrom := 1;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "SPLCONFIG_T_START10" then
		startFrom := 10;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "SPLCONFIG_F_START10" then
		startFrom := 10;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "SPLCONFIG_F_START_OVERFLOW" then
		startFrom := 1;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "SPLCONFIG_F_START_UNDERFLOW" then
		startFrom := 1;			
		spConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifyCustomers(respCust, null, spConfig, startFrom, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTGetCustomers.name; 
	
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");
	
	dict := webService.qsData;
	dict.purge();
	
	// 20/07/2023	navcs2	ChangeRequest 57650 Start
	// Removed code that deleted transients here and moved it to the classes themselves
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	// 20/07/2023	navcs2	ChangeRequest 57650 End
	
	delete webService;
	
	delete parser;
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete jsonHelper;
end;</source>
