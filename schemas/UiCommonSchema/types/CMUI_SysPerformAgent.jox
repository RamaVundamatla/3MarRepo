    <JadeMethod name="addGraphDetails" id="aeaa257c-115f-4c3b-82cb-388c2ef58253">
        <updating/>
        <source>addGraphDetails(_gblDtl : CM_GlobalProcessDetail; _plotValues : IntegerArray input) subschemaHidden, updating;
/*
------------------------------------------------------------------------
Created:			15 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	if self.showAvgAbort then
		_plotValues.add(_gblDtl.avgAbortTransMin);
	endif;
	if self.showAvgBegnNote then
		_plotValues.add(_gblDtl.avgBeginNotesMin);
	endif;
	if self.showAvgCommit then
		_plotValues.add(_gblDtl.avgCommitTransMin);
	endif;
	if self.showAvgCreates then
		_plotValues.add(_gblDtl.avgCreateObjectsMin);
	endif;
	if self.showAvgDeletes then
		_plotValues.add(_gblDtl.avgDeleteObjectsMin);
	endif;
	if self.showAvgDlvNotes then
		_plotValues.add(_gblDtl.avgDeliveredNotesMin);
	endif;
	if self.showAvgEndNotes then
		_plotValues.add(_gblDtl.avgDeliveredNotesMin);
	endif;
	if self.showAvgGetLocks then
		_plotValues.add(_gblDtl.avgGetQdLocksMin);
	endif;
	if self.showAvgGets then
		_plotValues.add(_gblDtl.avgGetObjectsMin);
	endif;
	if self.showAvgLocks then
		_plotValues.add(_gblDtl.avgLockObjectsMin);
	endif;
	if self.showAvgServerExec then
		_plotValues.add(_gblDtl.avgServerExecsMin);
	endif;
	if self.showAvgUnlocks then
		_plotValues.add(_gblDtl.avgUnlockObjectsMin);
	endif;
	if self.showAvgUpdates then
		_plotValues.add(_gblDtl.avgUpdateObjectsMin);
	endif;
	if self.showChkNumAvailFat then
		_plotValues.add(_gblDtl.numAvailableFat);
	endif;
	if self.showChkNumAvailThin then
		_plotValues.add(_gblDtl.numAvailableThin);
	endif;
	if self.showChkThin then
		_plotValues.add(_gblDtl.numThin);
	endif;
	if self.showChkNumProcesses then
		_plotValues.add(_gblDtl.totalProcesses);
	endif;
	if self.showChkNumProcLic then
		_plotValues.add(_gblDtl.numProcessLicenses);
	endif;
end;</source>
        <subAccess>hidden</subAccess>
        <Parameter name="_gblDtl" type="CM_GlobalProcessDetail"/>
        <Parameter name="_plotValues" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addGraphLegends" id="1a8a9403-6405-431a-b339-d4012c4f6e49">
        <updating/>
        <source>addGraphLegends(_grph : CMUI_LineGraph input; _colours : IntegerArray input) subschemaHidden, updating;
/*
------------------------------------------------------------------------
Created:			15 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	colourFound : Integer;
begin

	if self.showAvgAbort then
		_grph.addGraphLegend('Avg Abort Trans/Min');
		colourFound := app.getRandomColour;
		_colours.add(colourFound);
	endif;
	if self.showAvgBegnNote then
		_grph.addGraphLegend('Avg Begin notes/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgCommit then
		_grph.addGraphLegend('Avg Commits/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgCreates then
		_grph.addGraphLegend('Avg Creates/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgDeletes then
		_grph.addGraphLegend('Avg Deletes/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgDlvNotes then
		_grph.addGraphLegend('Avg Notes delivered/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgEndNotes then
		_grph.addGraphLegend('Avg End notes/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgGetLocks then
		_grph.addGraphLegend('Avg Get Queued locks/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgGets then
		_grph.addGraphLegend('Avg Get objects/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgLocks then
		_grph.addGraphLegend('Avg Locks/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgServerExec then
		_grph.addGraphLegend('Avg Server executions/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgUnlocks then
		_grph.addGraphLegend('Avg Unlocks/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showAvgUpdates then
		_grph.addGraphLegend('Avg Object updates/Min');
		_colours.add(app.getRandomColour);
	endif;
	if self.showChkNumAvailFat then
		_grph.addGraphLegend('Num Background processes');
		_colours.add(app.getRandomColour);
	endif;
	if self.showChkNumAvailThin then
		_grph.addGraphLegend('Num GUI processes');
		_colours.add(app.getRandomColour);
	endif;
	if self.showChkThin then
		_grph.addGraphLegend('Num Nodes');
		_colours.add(app.getRandomColour);
	endif;
	if self.showChkNumProcesses then
		_grph.addGraphLegend('Num processes');
		_colours.add(app.getRandomColour);
	endif;
	if self.showChkNumProcLic then
		_grph.addGraphLegend('Num process licenses');
		_colours.add(app.getRandomColour);
	endif;
end;</source>
        <subAccess>hidden</subAccess>
        <Parameter name="_grph" type="CMUI_LineGraph" usage="input"/>
        <Parameter name="_colours" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="318c6cda-3e1b-4196-bdd6-7ef42bff0d83">
