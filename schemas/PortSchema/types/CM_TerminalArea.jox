    <JadeMethod name="setProxyTerminalArea" id="2d8a76fe-3458-4718-9489-148df68a14b8">
        <updating/>
        <source>setProxyTerminalArea(
		_id,
		_comment			: String;
		_type				: Integer;
		_actAsReleasePoint	: Boolean;
		_terminal			: CM_Terminal;
		_autoRestrictions,
		_stockControlled	: Boolean;
		_hideFromOverView 	: Boolean;
		_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) protected, updating;
//26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars
		icArea : CM_InterchangeArea;
begin

	inheritMethod(_id,
				_comment,
				_type,
				_actAsReleasePoint,
				_terminal,
				_autoRestrictions,
				_stockControlled,
				_hideFromOverView,
				_allInterchangeAreas,
				_defaultInterchangeArea);
	
	self.actAsReleasePoint 				:= _actAsReleasePoint.Integer;
	self.hideFromOverView				:= _hideFromOverView;
	self.autoRestrictionsEnabled 		:= _autoRestrictions;
	
	self.allAssociatedInterchangeAreas.clear; //epr par 23003 9/3/10
	if _allInterchangeAreas &lt;&gt; null then
		foreach icArea in _allInterchangeAreas do
			if not self.allAssociatedInterchangeAreas.includes(icArea) then
				self.allAssociatedInterchangeAreas.add( icArea);
			endif;
		endforeach;
	endif;

	self.myDefaultInterchangeArea:=_defaultInterchangeArea;
	
	
	
	if self.canBeStockControlled then
		self.isStockControlled := _stockControlled;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_actAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_autoRestrictions" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
