    <JadeMethod name="setAssociatedObject" id="138add4e-732c-471b-9758-61d8d54187dd">
        <updating/>
        <source>setAssociatedObject(pTheObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets a reference to an object that is associated with a calendar
//				date/event (CnEcCalendarControl).
//
// Parameters:	pTheObject - A reference to the associated object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.myAssociatedObject &lt;&gt; pTheObject then 
		self.myAssociatedObject	:=	pTheObject;
	endif;
end;</source>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setCalendarControl" id="0e94cfdb-7ffa-4458-9f0d-c9e6bc8be137">
        <updating/>
        <source>setCalendarControl(pTheCalendar : JSSCalendar) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets a reference to the event's Calendar control.
//
// Parameters:	pCalendar - The calendar control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCalendar &lt;&gt; pTheCalendar then
		self.myCalendar	:=	pTheCalendar;
	endif;
end;</source>
        <Parameter name="pTheCalendar" type="JSSCalendar"/>
    </JadeMethod>
    <JadeMethod name="setDisplayText" id="38df5019-fc8b-4063-b66b-ed909e0fd9d3">
        <updating/>
        <source>setDisplayText(pDisplayText: String) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets the display value of a Calendar date/event.
//
// Parameters:	pDisplayText - The display values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.displayText &lt;&gt; pDisplayText then 
		if pDisplayText.length &gt; 50 then
			self.displayText	:=	pDisplayText[1:50];
		else
			self.displayText	:=	pDisplayText;
		endif;
	endif;
end;</source>
        <Parameter name="pDisplayText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEventDate" id="721e60fe-7a9f-4051-8937-8baf2a899f13">
        <updating/>
        <source>setEventDate(pEventDate: Date) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets the date of a Calendar event.
//
// Parameters:	pEventDate - The date of the event.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.eventDate &lt;&gt; pEventDate then 
		self.eventDate	:=	pEventDate;
	endif;
end;</source>
        <Parameter name="pEventDate" type="Date"/>
    </JadeMethod>
</Class>
