    <JadeMethod name="xHandler" id="3239cab0-96d1-49dd-92ff-1444a3184bc5">
        <source>xHandler(_exp : Exception; _bgpObject : BGP_Object input) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars

begin
	// This exception handler allows the user to open the form if somehow the display method cannot
	// find the appropriate class for the controller due to a developer inadvertently changing a request
	// class name. The controllers won't start but this handler
	// will clear out the problem when the bgp form is opened.
	if _exp.isKindOf(CM_Exception) and _exp.errorCode = 79574 then
		if _bgpObject &lt;&gt; null and not _bgpObject.isRunning() then
			if _bgpObject.isKindOf(BGP_Controller) then
				beginTransaction;
				_bgpObject.BGP_Controller.allRequestClassesToProcess.clear();
				commitTransaction;
			endif;
		endif;
		return Ex_Resume_Next;
	elseif _exp.isKindOf(LockException) then
		abortTransaction;			// PAR #28753
		abortTransientTransaction;
		return Ex_Abort_Action;
	endif;	

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exp" type="Exception"/>
        <Parameter name="_bgpObject" type="BGP_Object" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
