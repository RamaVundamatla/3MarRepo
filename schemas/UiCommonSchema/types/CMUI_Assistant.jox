    <JadeMethod name="comboBoxDamagePositons" id="d9e16627-816e-4c66-9125-c322d18c1950">
        <source>comboBoxDamagePositons(_combo : ComboBox; _damageInterface : IF_DamageDetails);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 24 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//
//----------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
	damagePos : CM_DamagePosition;
	idx : Integer;
	collection : CM_DamagePositionByCodeDict;
	
begin
	create collection transient;
	//self.getDamagePositionsForObject(_masterObject, collection);
	if _damageInterface &lt;&gt; null then
		_damageInterface.getDamagePositions(collection);
	endif;
	foreach damagePos in collection do
		_combo.itemObject[_combo.addItem(damagePos.code &amp; ' - ' &amp; damagePos.description)] := damagePos;	
	endforeach;
epilog
	delete collection;
end;</source>
