    <JadeMethod name="importFromXMLDocReference" id="9ca8eac4-65d9-48f1-afcc-29266b8587e8">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	allPointElements : JadeXMLElementArray;
	pointElement : JadeXMLElement;
	point : Point;
	pointData : String;
begin
	if _property = CM_Graphic::pointsPolygon then
		create allPointElements transient;
		_xmlElement.getAllElementsByTagName(Point.name,allPointElements);
		
		foreach pointElement in allPointElements do
			pointData:=pointElement.textData;
			point:=pointData.Point;
			self.pointsPolygon.add(point);
		
		endforeach;
		
	endif;
	
	

epilog
	delete allPointElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
