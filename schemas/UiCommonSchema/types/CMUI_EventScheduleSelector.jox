    <JadeMethod name="doSelectPrint" id="a2346caa-204b-4021-b8c3-25bb1c7c2f65">
        <updating/>
        <source>doSelectPrint() protected, updating;
// -------------------------------------------
// Created 30 June 2004 by cnwdvb1
// -------------------------------------------
vars
	msg	: String;
begin
	// CPL CCMS 2120 Nov 2011 use this form for invoice packages as well as voyages
	if self.lstSchedules.allSelectedObjects.isEmpty then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Invoice) then
			msg := 'Invoice Package';
		else
			msg := app.getErrorString(Event_Schedule);
		endif;
		app.msgBox(app.getErrorString1(Please_Select_An, msg), self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Invoice) then
		msg := 'Do you want to run the selected package(s) ' &amp; self.theCaption;
	else
		msg := app.getErrorString1(RunEventSchedule, self.theCaption);
	endif;
	if app.msgBox(msg, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	self.lstSchedules.allSelectedObjects.copy(self.allSelectedSchedules);
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fillTable" id="84c2badb-b746-471c-8117-6224f4c42fd2">
        <updating/>
        <source>fillTable() updating;
/*

Purpose:			fills in the auto event scheduler table	

Date				Who		Reason
06 November 2018	jlgzm1	TFS41408 SNO - ordering of vessel enquiry auto scheduler
*/

vars
	item: CM_AutoSchedule;
begin
	if self.allAutoSchedules &lt;&gt; null then
		foreach item in self.allAutoSchedules do
			self.lstSchedules.addItemObject(item.description, item);
		endforeach;
		self.lstSchedules.sortColumn[1] := 2;
		self.lstSchedules.sortAsc[1] := true;
		self.lstSchedules.resort();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="lstSchedules_displayRow" id="7f6b8c86-af82-4369-9d6f-4b75b5e080fe">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchedules_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// -------------------------------------------
// Created 30 June 2004 by cnwdvb1
// -------------------------------------------
vars

	selected	: Boolean;

begin
	//TFS41408 jlgzm1 method no longer called, replaced with CMUI_EventScheduleSelector.fillTable()
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CM_AutoSchedule.description;
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_AutoSchedule.description;
	endif;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
