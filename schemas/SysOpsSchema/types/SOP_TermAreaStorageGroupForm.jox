    <JadeMethod name="doDelete" id="6f370918-bd17-469e-89bc-8ae82886365b">
        <updating/>
        <source>doDelete() updating, protected;

vars
	result	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myStorageGroup &lt;&gt; null then
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, self.myStorageGroup.code), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteTerminalAreaStorageGp(self.myStorageGroup, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.myStorageGroup := null;
				self.populateStorageGroups();
				break;
			else
				theResult := app.showErrorWarningDialog('Terminal Area Storage Group', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNew" id="0f41f9ac-d8c5-4ed1-aa20-491f0296f71d">
        <updating/>
        <source>doNew() updating, protected;

vars

begin
	self.cmbCodes.visible := false;
	self.txtCode.visible := true;
	self.cmbCodes.left := 320;
	self.txtCode.tabIndex := self.txtDescription.tabIndex - 1;
	self.txtCode.text := null;
	self.txtDescription.text := null;

	self.myStorageGroup := null;
	self.showStorageGroup();
	
	self.txtCode.setFocus();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="269933c2-d702-454f-831b-182827fa72a5">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// save new or update
vars
	ls 			: Boolean;
	result		: Integer;
	code		: String;
	description	: String;
	
	terminalAreas	: CM_TerminalAreaArray;
	proxyTASG	: CM_TerminalAreaStorageGroup;
	termAreaStorageGroup	: CM_TerminalAreaStorageGroup;
begin
	create terminalAreas transient;
	
	if self.myStorageGroup = null then
		create proxyTASG transient;
		code := self.txtCode.text.trimBlanks();
	else
		app.cmsBeginLoad(ls);
		proxyTASG := app.createUpdateProxy(self.myStorageGroup).CM_TerminalAreaStorageGroup;
		app.cmsEndLoad(ls);
		code := self.myStorageGroup.code;
	endif;
	
	description := self.txtDescription.text;
	self.mulTermAreas.getSelected( terminalAreas );
	
	proxyTASG.setProxy(code, description, terminalAreas, self.myTerminal);
	
	if self.myStorageGroup = null then
		while true do
			app.myTrxCA.trxCreateTerminalAreaStorageGp(proxyTASG, termAreaStorageGroup, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Terminal Area Storage Group', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					self.myStorageGroup := termAreaStorageGroup;
					continue;
				else
					return false;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	else
		while true do
			app.myTrxUA.trxUpdateTerminalAreaStorageGp(proxyTASG, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Terminal Area Storage Group', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				elseif (not app.myPassport.noErrors) then
					return false;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	endif;

	self.populateStorageGroups();
	
epilog
	app.cmsEndLoad(ls);
	delete proxyTASG;
	delete terminalAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAvailableTerminalAreas" id="4a441c11-09e6-4f28-9eeb-b30c2b068d4f">
        <source>getAvailableTerminalAreas(_termAreas : CM_TAByIdDict input) protected;
// get all terminal areas filtered by type
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------
// 03/07/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 08 Sep 2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
vars
	termArea	: CM_TerminalArea;
begin
	foreach termArea in self.myTerminal.allTerminalAreas do
		if termArea.type = TA_TYPE_BLOCK_STACK or
		   termArea.type = TA_TYPE_CONT_PACK_REPACK or
		   termArea.type = TA_TYPE_DAIRY or
		   termArea.type = TA_TYPE_DEPOT_LCL or
		   termArea.type = TA_TYPE_FORK_LIFT_STACK or
		   termArea.type = TA_TYPE_FUMIGATION_AREA or
		   termArea.type = TA_TYPE_HIDE or
		   termArea.type = TA_TYPE_REPAIR or
		   termArea.type = TA_TYPE_STRADDLE_STACK or
		   termArea.type = TA_TYPE_SUBBLOCK_STACK or
		   termArea.type = TA_TYPE_SWAP or
		   termArea.type = TA_TYPE_WASH_AREA or
		   termArea.type = TA_TYPE_RTG or
		   termArea.type = TA_TYPE_BULK or
		   termArea.type = TA_TYPE_IRREGULAR_BLOCK_AREA or // PAR 32820
		   termArea.type = TA_TYPE_RMG or
		   termArea.type = TA_TYPE_RMG_LANE or
		   termArea.type = TA_TYPE_RTG_LANE or
		   termArea.type = TA_TYPE_GEN_CARGO_ALLOC_ROW or		// TFS 49453
		   termArea.type = TA_TYPE_RORO_LANE_AREA or
		   termArea.type = TA_TYPE_MAFI
		   then
			_termAreas.add(termArea);
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_termAreas" type="CM_TAByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTermAreaName" id="ebf3c242-ecd8-4ae9-9881-64a05039bb70">
        <source>getTermAreaName(_ta : CM_TerminalArea) : String protected;
// called from mulTermAreas
vars

begin
	if _ta = null then
		return null;
	else
		return _ta.id &amp; "   " &amp; _ta.typeString;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateStorageGroups" id="a082fe90-aa7f-4629-b107-9a88d231597a">
        <updating/>
        <source>populateStorageGroups() updating, protected;

vars
	storageGroup	: CM_TerminalAreaStorageGroup;
begin
	self.cmbCodes.clear();
	foreach storageGroup in self.myTerminal.allTerminalAreaStorageGroups do
		self.cmbCodes.addItemObject(storageGroup.code, storageGroup);
	endforeach;
	if self.cmbCodes.listCount() &gt; 0 then
		if self.myStorageGroup = null then
			self.cmbCodes.listIndex := 1;
			self.myStorageGroup := self.cmbCodes.itemObject[1].CM_TerminalAreaStorageGroup;
		else
			self.cmbCodes.listIndex := self.cmbCodes.findObject(self.myStorageGroup);
		endif;
		self.showStorageGroup();
		self.txtCode.visible := false;
		self.cmbCodes.visible := true;
		self.cmbCodes.left := 120;
		self.cmbCodes.tabIndex := self.txtDescription.tabIndex - 1;
		self.cmbCodes.setFocus();
	else
		self.cmbCodes.visible := false;
		self.txtCode.setFocus();
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="07108a73-2fe8-4471-9d64-ac29cb49733f">
        <updating/>
        <source>setupForm() updating;

vars
	allTermAreas	: CM_TAByIdDict;
begin
	inheritMethod();
	
	create allTermAreas transient;
	
	self.getAvailableTerminalAreas(allTermAreas);
	
	self.mulTermAreas.myAvailableListBox.sorted := true;
	self.mulTermAreas.mySelectedListBox.sorted := true;
	self.mulTermAreas.setupControl(app.getErrorString(TerminalAreas), allTermAreas, SOP_TermAreaStorageGroupForm::getTermAreaName.name);
	self.mulTermAreas.setVisibleButtons(true, true, false);	// don't need the up/down buttons - sequence has no significance
	self.mulTermAreas.width := self.width - 70;
	self.mulTermAreas.height := self.height - self.mulTermAreas.top - 80;
	
	self.populateStorageGroups();

	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnSave.enabled:= false;
		self.mulTermAreas.readOnly := true;
	endif;

epilog
	delete allTermAreas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showStorageGroup" id="0e3410eb-800b-48bc-ba6e-0922321bc644">
        <updating/>
        <source>showStorageGroup() updating, protected;

vars
	selectedTermAreas	: CM_TAByIdDict;
begin
	create selectedTermAreas transient;
	
	if self.myStorageGroup &lt;&gt; null then
		self.myStorageGroup.allTerminalAreas.copy(selectedTermAreas);
		self.txtDescription.text := self.myStorageGroup.description;
	endif;
	
	self.mulTermAreas.setSelected( selectedTermAreas );

epilog
	delete selectedTermAreas;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="56f1779e-a457-42a5-b236-94b572121054">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 June 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019148, locale);
	btnClose.translateCaption(Xlat_0019149, locale);
	btnDelete.translateCaption(Xlat_0019150, locale);
	btnNew.translateCaption(Xlat_0019151, locale);
	btnSave.translateCaption(Xlat_0019152, locale);
	lblCode.translateCaption(Xlat_0019153, locale);
	lblDescription.translateCaption(Xlat_0019154, locale);
end;</source>
    </JadeMethod>
</GUIClass>
