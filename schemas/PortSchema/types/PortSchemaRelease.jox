    <JadeMethod name="createAuditConfigs" id="8910c9b7-9b25-40a0-be42-18409c2aab5b">
        <source>createAuditConfigs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 January 2021		jlgndl1	Initial creation	TFS 50152
01 December 2021	navmd1	TFS 52490 - Prevent No Audit Config exists for 'CM_AuditConfig' by creating it first!

*/

vars

	root : CM_Root;
	schema : Schema;
	auditConfig : CM_AuditConfig;
	cmObjectClass : Class;
	
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	dummyObj : CM_Object;
	transObj : CM_Object;
	canHaveAudits: Boolean;
	auditClass: Class;
	
	iterAuditConfig : Iterator;

begin

	root := CM_Root.firstInstance;
	
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	cmObjectClass := CM_Object;
	
	classColl := schema.getAllClasses(false);
	iterClass := classColl.createIterator;
	
	beginTransaction;
	
		// We Audit the fact that we're enabling/disabling CM_AuditConfigs
		// But We might not have one yet, so lets do that first up
		auditConfig := root.allAuditConfigs[ CM_AuditConfig.name ];
		if auditConfig = null then
			//its not there add it.	
			root.createAuditConfig( CM_AuditConfig );	
		endif;
	
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			//only interested in classes under CM_Object
			continue;
		endif;
		
		if class.abstract or class.transient then
			continue;
		endif;
		
		if class = CM_AvailableForRelease then
			continue;
		endif;
		
		//check to see whether its supposed to be available
		dummyObj := class.firstInstance.CM_Object;
		
		if dummyObj = null or dummyObj.class = CM_Object then
			create transObj as class transient;
			dummyObj := transObj;
		endif;
						
		canHaveAudits := dummyObj@canHaveAudits;
		auditClass := dummyObj@auditClass;
		
		delete transObj;
		
		if not canHaveAudits or auditClass = null then
			//this class is not audited.
			continue;
		endif;
		
		//If we get to here the class should be able to be audited.
		//check that the audit config has been created
		auditConfig := root.allAuditConfigs[ auditClass.name ];
		if auditConfig = null then
			//its not there add it.	
			auditConfig := root.createAuditConfig( auditClass );
			if not auditConfig.canBeUserDisabled then
				app.myUtilityUA.updAuditConfigSetIsEnable( true, auditConfig, app.myPassport);
			endif;
		endif;
		
	endwhile;
	
	//And one special case - "CM_Edit" / 'Tracked Item Edit' Creates audits against CM_Tracked Item that
	//replicate the values in the 'Edits' created via the Container Enquiry Form.
	auditConfig := root.allAuditConfigs[ CM_Edit.name ];
	if auditConfig = null then
		//its not there add it.	
		root.createAuditConfig( CM_Edit );	
	endif;
	
	//clean up any CM_AuditConfig objects for classes that have been deleted and have no associated audits.
	//i.e. at th etime of writing there was a "CM_TIMasterGroup"
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
		class := schema.getClass( auditConfig.className );
		if class = null and auditConfig.allAuditObjects.isEmpty then
			delete auditConfig;
		endif;
	endwhile;
	
	commitTransaction;

epilog

	delete classColl;
	delete iterClass;
	delete iterAuditConfig;

end;</source>
    </JadeMethod>
    <JadeMethod name="createCamProtocolEditTriggers" id="fef5e82d-f26d-48c0-8818-65766c9f980d">
        <source>createCamProtocolEditTriggers();
/*

Date		Who		Reason
12 October 2015	cnwer1	Initial creation PAR 37035

*/

vars

	camProtocolDesc : CM_CamUserDefRepDesc;
	field, existField		: CM_Field;
	fields 			: CM_FieldByTypeSysNameDict;
	fieldsToDelete : ObjectSet;
begin
	beginTransaction;
	camProtocolDesc := CM_CamUserDefRepDesc.firstInstance;
    if camProtocolDesc = null then
        create camProtocolDesc.CM_CamUserDefRepDesc;
        camProtocolDesc.setMyRoot();
    endif;
	
	create fields transient;
	self.getCamTriggerFields(fields, CM_CamEditTriggerField);
	
	create fieldsToDelete transient;
	// first look for ones we should delete 
	foreach existField in camProtocolDesc.allCamEditTriggerFields do
		if    fields.getAtKey (existField.systemTypeName, existField.systemName) = null then // has been removed
			 fieldsToDelete.add(	existField);	
		endif;
	endforeach;
	
	fieldsToDelete.purge;
	
	foreach field in fields do
		if camProtocolDesc.allCamEditTriggerFields[field.systemTypeName,field.systemName] = null then
			field.CM_CamEditTriggerField.setCamUserDefRepDesc(camProtocolDesc);
		else
			fieldsToDelete.add(field);
		endif;
	endforeach;
	
	fieldsToDelete.purge;

	commitTransaction;
epilog
	delete fields;
	delete fieldsToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIConfigForTerminals" id="8cab86d6-c698-4dec-ae32-e11382dab722">
        <source>createEDIConfigForTerminals();
//----------------------------------------------------------------
//	Created:	30 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	root		: CM_Root;
	term		: CM_Terminal;
	ediControl	: CM_EDIControllerAgent;
begin
	//this is now done on initiateTerminal but old terminals (logs mainly) will be lacking their ediConfig object
	
	root := CM_Root.firstInstance;
	create ediControl transient;
	
	foreach term in root.allTerminals do
		ediControl.setupConfig(term);
	endforeach;
	
epilog
	delete ediControl;
end;</source>
    </JadeMethod>
    <JadeMethod name="createInternalUsers" id="d2c166f3-8dd9-4afb-87b8-03ba0fa3369f">
        <source>createInternalUsers(_releaseController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2021	navndl1	Initial creation	TFS 51310

*/

vars
	user : CM_User;
	userName : String;
	result : String;
	
begin

	//super user
	user := null;
	userName := SUPERUSER_Str;
	user := app.myRoot.allUsers[userName];
	if user = null then
		beginTransaction;
		app.myRoot.createSuperuser();
		commitTransaction;
		user := app.myRoot.allUsers[userName];
		if user = null then
			_releaseController.logEntry("Error occurred no Super User");
		endif;
	else
		beginTransaction;
		user.updateStatus(EnabledNormalUser);
		app.jmtSetSUPW();
		commitTransaction;
	endif;
	

	//Support user
	user := null;
	userName := JMTSUPPORT_Str;
	user := app.myRoot.allUsers[userName];
	if user = null then
		beginTransaction;
		app.myRoot.createJMTSupportUser();
		commitTransaction;
		user := app.myRoot.allUsers[userName];
		if user = null then
			_releaseController.logEntry("Error occurred no Support User");
		endif;
	else
		beginTransaction;
		user.updateStatus(EnabledNormalUser);
		app.setJMTSupportPW();
		commitTransaction;
	endif;
	
	
	//Nav ops user
	user := null;
	userName := OPSVIEWUSER_Str;
	user := app.myRoot.allUsers[userName];
	if user = null then
		beginTransaction;
		app.myRoot.createNavOpsViewUser();
		commitTransaction;
		user := app.myRoot.allUsers[userName];
		if user = null then
			_releaseController.logEntry("Error occurred no Ops View User");
		endif;
	else
		beginTransaction;
		user.updateStatus(EnabledNormalUser);
		app.setNavOpsViewPW();
		commitTransaction;
	endif;
	
	
	_releaseController.logEntry("Completed checking Internal MTN Users");

epilog

	abortTransaction;
	
end;</source>
        <Parameter name="_releaseController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createJMTSupportUser" id="341ae5c4-e51d-4ae7-90dd-8fa66474eddc">
        <source>createJMTSupportUser(_releaseController : CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2019	jlgdi1	Initial creation

*/

vars
	user : CM_User;
	result : String;
	
begin
	user := app.myRoot.allUsers[JMTSUPPORT_Str];
	if user &lt;&gt; null then		
		result := "JMTSUPPORT user already exist.";
		_releaseController.logEntry(result);
		return;
	endif;
		
	result := "Creating JMTSUPPORT user started";
	_releaseController.logEntry(result);
	
	beginTransaction;
	app.myRoot.createJMTSupportUser();
	commitTransaction;

	user := app.myRoot.allUsers[JMTSUPPORT_Str];
	if user &lt;&gt; null then 
		result := "JMTSUPPORT user successfully created";
	else
		result := "Failed to create JMTSUPPORT user";		
	endif;

	_releaseController.logEntry(result);
end;</source>
        <Parameter name="_releaseController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createMutexes" id="9f00722c-90e4-4c29-89d1-546de0f06416">
        <source>createMutexes() protected;
/*

Purpose:			

Parameters:			

Return Value:		

