/*
------------------------------------------------------------------------
Created:			07 October 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if _slot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slot Ref', null, null);	
	endif;	
	if _slot.ordinalDeck &lt;&gt; DeckOnDeck then
		return false;
	endif;
	return ((_slot.ordinalCell &lt;= self.ordinalODEndCell) and (_slot.ordinalCell &gt;= self.ordinalODStartCell));
end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bcc6a7d2-6086-4294-ac5f-56f9943643c8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy:SelfType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="aab975bd-7720-46be-9b54-1d0a8405a940">
        <updating/>
        <source>setForCreate(_proxy:SelfType;
			_realVesselVoyage : CM_Object; 
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	_proxy.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxy,_passport);
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
