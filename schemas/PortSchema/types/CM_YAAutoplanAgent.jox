        <source>initialiseForTrxStart() updating;
// -------------------------------------------
// Created 30 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	self.allLCsToIgnore.clear;
	self.isFindOverstowLocation:=false; // epr ccms 1025 21/1/10
	self.ignorePlanQueuedTIForOS := false;	//17 Jan 2019	NDL	TFS 42292
	self.isOnlyCheckRealCargo:=false;   //  epr ccms 1025 
	self.numberOfFreeSpacesRequired:=0; // epr ccms 1025
	self.myCurrentSpecificTA:=null;
	self.myCurrentSpecificColumn:=null;
	self.myCurrentSpecificRow:=null;
	if self.myCurrentCMIFYAAutoPlan &lt;&gt; null and global.isValidObject(self.myCurrentCMIFYAAutoPlan) then
		self.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.clear();
		self.myCurrentCMIFYAAutoPlan.allLocationsForSplit.clear();	//16 Jun 2016	NDL	TFS 2172
	endif;
	if not self.allMultiRangeCMIFs.isEmpty then	//16 Jun 2016	NDL	TFS 2172
		self.allMultiRangeCMIFs.purge();
	endif;
end;</source>
