    <JadeMethod name="hasCompleteTransaction" id="9fcf14ef-a309-4c45-adc3-5b588fc2d24b">
        <source>hasCompleteTransaction():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks

*/

vars
	woTrans			: CM_WOTransaction;
	transType,
	woTranstype		: Integer;
begin
	woTranstype := self.getTransTypeByMode();						
	woTrans 	:= self.getLastTransOfType(woTranstype);
	
	if woTrans &lt;&gt; null then
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
