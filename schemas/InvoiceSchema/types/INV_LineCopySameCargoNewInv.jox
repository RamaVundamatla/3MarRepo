    <JadeMethod name="create" id="4eae2c34-39e3-4dec-b3c8-bfb663a8b15e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes
*/

vars

begin
	self.permissionView		:= PmAdmDiffInvSameCargoView;
	self.permissionMaint	:= PmAdmDiffInvSameCargoMaint;
	
	self.helpFileName		:= HelpFile_Invoicing;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="c3908068-8254-4ed4-8348-1b0fdeba3664">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			Saves the data entered on the form for an invoice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes
26 April 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	pxyInvoice : CM_Invoice;
	theReturn	: Integer;
	controller : CMIF_InvoiceLineCopy;
	date	   : Date;
	time       : Time;
	dateTime   : TimeStamp;
	status 	: Integer;
	allWorkOrders	: CM_WorkOrderSet;
begin
	status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];	// 26.4.2023 navmk20 TFS 57663
	create allWorkOrders transient;//navtnr20 23-05-2023 BUG 58089
	self.mulWorkOrder.getSelected(allWorkOrders);
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myCurrentBank,
								self.cmbDebtorInvProp.listObject.CM_Debtor,
								self.cmbDebtorAddressProp.listObject.CM_Address,
								self.cmbVoyageInvProp.listObject.CM_Voyage,
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								//self.cmbStatusInvProp.text = app.getErrorString(Suspense), // 26.4.2023 navmk20 TFS 57663
								status,	// 26.4.2023 navmk20 TFS 57663
								true,
								self.myCurrentTI,
								self.myBillOfLading,
								self.myBookingRef,
								self.myCurrentCargoGroup,
								self.myReleaseRequest,
								self.cmbCategory.itemData[self.cmbCategory.listIndex],
								self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,  // ### BUG 56925 07MAR2023 NAVAB1
								self.myCurrentBank.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								allWorkOrders,	 //navtnr20 23-05-2023 BUG 58089
								self.txtNarr.text, //14/08/2023	navkc1	Bug 59803
								self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade, //14/08/2023	navkc1	Bug 59803
								self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,	//14/08/2023	navkc1	Bug 59803
								self.cmbCurrencyType.listObject.CM_CurrencyType,	//14/08/2023	navkc1	Bug 59803
								self.cmbLocale.listObject.CM_Locale,	//14/08/2023	navkc1	Bug 59803,
								self.cmbDebtorAltAddrProp.listObject.CM_Address	//14/08/2023	navkc1	Bug 59803
								);
								
	date := self.tblInvProperties.getValueByName(ETRow_StartDate).Date;
	time := self.tblInvProperties.getValueByName(ETRow_EndDate).Time;
	
	dateTime := app.actualTimeAppServer;
	if date.isValid then
		dateTime.setDate(date);
		dateTime.setTime(time);
	endif;
								
	create controller transient;
	self.allSelectedInvoiceLines.copy(controller.allSelectedInvoiceLines);
	controller.setValues(true,false,true,pxyInvoice,null,dateTime);
	while true do
		app.myTrxCA.trxCopyInvoiceLine(controller,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Copy", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;					
	
	self.unloadForm();
	
epilog
	delete pxyInvoice;
	delete controller;
	delete allWorkOrders;
end;</source>
        <access>protected</access>
    </JadeMethod>
