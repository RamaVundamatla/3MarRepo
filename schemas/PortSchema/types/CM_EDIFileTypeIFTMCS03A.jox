    <JadeMethod name="getEDIPartyRules" id="e02b10c2-701c-4dce-9a0c-8f51f9d39368">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
/*
Date		Who		Reason
22 July 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileType_IFTMCS03A);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getUNBData" id="cdb04e37-fcd1-427a-821c-1ccef196d3db">
        <source>getUNBData(_ediData :CM_EDIData input; _msgHelper : CMIF_EDIFACTHelper;  _senderOperatorCode : String output; _rawSenderCode : String output; _rawRecipientCode : String output;
			_senderPartyRules :CM_EDIPartyRules output; _senderOperator : CM_Operator output; _creationTS : TimeStamp output; _sequence : String output) protected;
/*
Date		Who		Reason
22 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
//27 Jul 2015	cnwrs1	Par 32883 - EDI File Type sequence number
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
*/
vars

begin
	inheritMethod(_ediData, _msgHelper, _rawSenderCode, _senderOperatorCode, _rawRecipientCode, _senderPartyRules, _senderOperator, _creationTS, _sequence);

	// seems we always set the operator code
	
	if _senderOperator &lt;&gt; null then
		_ediData.operatorCode := _senderOperator.code;
		_ediData.setOperator (_senderOperator);
	else
		_ediData.operatorCode := _rawSenderCode[1:4];
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper"/>
        <Parameter name="_senderOperatorCode" type="String" usage="output"/>
        <Parameter name="_rawSenderCode" type="String" usage="output"/>
        <Parameter name="_rawRecipientCode" type="String" usage="output"/>
        <Parameter name="_senderPartyRules" type="CM_EDIPartyRules" usage="output"/>
        <Parameter name="_senderOperator" type="CM_Operator" usage="output"/>
        <Parameter name="_creationTS" type="TimeStamp" usage="output"/>
        <Parameter name="_sequence" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTBooking_FTX" id="defaca5f-da69-4baf-b47d-104ac9e4bdf0">
        <source>processEDIFACTBooking_FTX(_msgHelper: CMIF_EDIFACTHelper input; _params : CMIF_EDIFACTParams input; _bookingItem :CM_EDIBookingItemTI input; _ediPartyRules :CM_EDIPartyIFTMCSRules) protected;
/*
Date		Who		Reason
11 July 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	group		:Integer;
	fieldValue	:String;
begin
	if _ediPartyRules &lt;&gt; null then 
		// we could have rules for:
		// FTX1.1 Booking - Cargo Remarks
		// FTX4.1 Booking - Booking Ignore Text
		// FTX4.1 Booking - Ventilation

		if _ediPartyRules.processBookingFTXSegment (_msgHelper.currentMessage, _bookingItem) then 
			// already processed		
			return;
		endif;
	endif;
	
	group := _msgHelper.currentGroup;
	
	if group = 35 then
		_msgHelper.setNextField;
		
		if _msgHelper.currentField = "AAA" then
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			
			fieldValue	:=  _msgHelper.currentSubItem[1:30];
			
			self.setRawCommodityValue (_msgHelper.currentGroup, _bookingItem, fieldValue);
			
//			if _params.mySenderOperator = null then
//				_bookingItem.commodity := fieldValue[1:4];
//			endif;				
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="input"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams" usage="input"/>
        <Parameter name="_bookingItem" type="CM_EDIBookingItemTI" usage="input"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFTMCSRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTSegment" id="14e94eba-efb2-4fc1-953b-824c83f73287">
        <source>processEDIFACTSegment(_msgHelper: CMIF_EDIFACTHelper io; _ediFile: CM_EDIFile input; _ediData: CM_EDIData input; _ediOperator: CM_Operator; _ediPartyRules: CM_EDIPartyRules; _reload: Boolean;_version:String) protected;
/*
Date		Who		Reason
10 July 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
26 Jul 2013 	cnwah9 	removed error messages and unnecessary code
20 Sep 2013 cnwah9 removed error messages and unnecessary code
14 Jun 2016 cnwma1	TFS #2048 POL - HSD EDI Empty Release Request Adding version to the signature
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 28 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 9
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	params 				: CMIF_EDIFACTParams;
	bookingHdr 			: CM_EDIBookingHeaderTI; 
	bookingItem 		: CM_EDIBookingItemTI;
	defaultISOType		: CM_ISOType;
	tag, messageMode, hazards, undg, fieldValue, code	: String;
	group				: Integer;
	foundMatch			: Boolean;
begin
	params 		:= _msgHelper.myCurrentParams;
    bookingHdr 	:= params.myEDIBookingHeaderTI;
    bookingItem := params.myEDIBookingItemTI;
	tag			:= _msgHelper.currentTag;
	group		:= _msgHelper.currentGroup;
//BGM
	if tag = "BGM" then
		group := 0;
		
		_msgHelper.setNextField;
		
        params.clearAll();
		
		// if we get 2 consequtive message for the same booking then we just overwrite the 1st booking
		// maybe not correct but consistent with old behaviour
		params.myEDIBookingHeaderTI := bookingHdr;
		params.myEDIBookingItemTI := bookingItem;
		
		if _msgHelper.currentField = "770" then
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			
		if _msgHelper.currentField = "1" then
			_msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_DELETE);
			
        elseif _msgHelper.currentField = "5" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_UPDATE);
			
        elseif _msgHelper.currentField = "9" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_ADD);
			
			endif;
		endif;
		
		// set up sender details - may be vaild operator or not
		params.mySenderOperator := _ediOperator;
		
        if _ediOperator &lt;&gt; null then            
			params.senderOperatorCode := _ediOperator.code;
        endif;
		
		// make sure sender code is on the ediData - this may or may not be a valid operator
		if _ediData.operatorCode = null then
			if params.senderOperatorCode &lt;&gt; null then
				_ediData.operatorCode	:= params.senderOperatorCode;
			endif;
		endif;
//DGS*
	elseif tag = "DGS" then
		if group = 35 then
			_msgHelper.setNextField;
			
			if _msgHelper.currentField = "IMD" then
				_msgHelper.setNextField;
				
				hazards := _msgHelper.currentSubItem;
				
				_msgHelper.setNextField;
				
				undg := _msgHelper.currentSubItem;	// par26798 
				
				bookingItem.imCodes.add(hazards &amp; ":+" &amp; undg);
			endif;
		endif;
//DTM*
	elseif tag = "DTM" then
		if group = 0 then
			_msgHelper.setNextField();
			
			if _msgHelper.currentSubItem = "137" then 	// PAR #22216.
				_msgHelper.setNextSubItem();
				
				fieldValue	:=	_msgHelper.currentSubItem.trimBlanks();
				
				_msgHelper.setNextSubItem();
				
				params.ediFileIssueDateTime	:=	fieldValue.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
			endif;
		endif;
//EQD*
	elseif tag = "EQD" then
		if group &lt; 35 then
			group := 35;
		endif;
		
		if group = 35 then
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = "CN" or _msgHelper.currentField = "T75" then
				bookingHdr.setCargoType(TI_CargoType_Container);
				
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				
				fieldValue := _msgHelper.currentField[1:4];
				
				//now use xlation CCMS 1157
				if _ediOperator &lt;&gt; null then
					bookingItem.isoType := _ediOperator.getXlationSystemCode(fieldValue, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
				else
					bookingItem.isoType := fieldValue.trimBlanks();
				endif;
				
				if bookingItem.isoType = null then
					defaultISOType	:= app.myPassport.myTerminal.getConfig(DefISOType).CM_ISOType;
					
					if defaultISOType &lt;&gt; null then
						bookingItem.isoType := defaultISOType.code;
					endif;
				endif;
				
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				_msgHelper.setNextField();
				
				if _msgHelper.currentField = "4" then
					bookingItem.fullOrMT := "E";
								
				elseif _msgHelper.currentField = "5" then
					bookingItem.fullOrMT := "F";
				endif;
				
				// par 31259 - there was some code in here that tried to set a default temperature using the isoType (isIntegral) and
				// commodity (hasTemp)  At this stage it is hard to see how the commodity could be anything but the default commodity 
				// so i have taken the code out.
				
			
			endif;
		endif;
//EQN*		
	elseif tag = "EQN" then
		if group = 35 then
			_msgHelper.setNextField;
						
			bookingItem.number := bookingItem.number + _msgHelper.currentSubItem.Integer;  //par26223 cnwrs1 4 Nov 2010 fixup number of item to process
		endif;
//FTX*
	elseif tag = "FTX" then
		self.processEDIFACTBooking_FTX(_msgHelper, params, bookingItem, _ediPartyRules.CM_EDIPartyIFTMCSRules);
//GID*
	/*elseif tag = "GID" then
		if group = 35 then
		endif;*/
//LOC**
	elseif tag = "LOC" then
		if group = 0 then
			group := 1;
		endif;
		_msgHelper.setNextField;
		if group = 1 or
		   group = 8 then
			if _msgHelper.currentField = "7" then
				_msgHelper.setNextField;
				
				fieldValue 		:= _msgHelper.currentSubItem[1:5].trimBlanks;
				
				if _ediOperator &lt;&gt; null then
					bookingHdr.destinationPort := _ediOperator.getXlationSystemCode(fieldValue, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
				else
					bookingHdr.destinationPort := fieldValue[1:5];
				endif;
				
			elseif _msgHelper.currentField = "9" then
				_msgHelper.setNextField;
				
				fieldValue := _msgHelper.currentSubItem[1:5].trimBlanks;

				// *** ever notice we do nothing with this field ***
				
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField;
				
				fieldValue := _msgHelper.currentSubItem[1:5].trimBlanks;
				
				if _ediOperator &lt;&gt; null then
					bookingHdr.dischargePort := _ediOperator.getXlationSystemCode(fieldValue, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
				else
					bookingHdr.dischargePort := fieldValue[1:5];
				endif;
				
			endif;
		endif;
//MEA*
	elseif tag = "MEA" then
		if group = 35 then
			_msgHelper.setNextField;
			
			if _msgHelper.currentField = "AAE" then
				_msgHelper.setNextField;
				
				if _msgHelper.currentField = "AAB" then
					_msgHelper.setNextField;
					if _msgHelper.currentSubItem = "KGM" then
						_msgHelper.setNextSubItem;
						bookingItem.weight := _msgHelper.currentSubItem.Integer;
					elseif _msgHelper.currentSubItem = "LBR" then
						_msgHelper.setNextSubItem;
						bookingItem.weight := (_msgHelper.currentSubItem.asEDIReal()/2.2).Integer;
					endif;
				// Additions for PAR 19766 cnwgb1 26.5.09 (From COPARN file)
				elseif _msgHelper.currentField = "AAO" then //Humidity
					_msgHelper.setNextField;
					_msgHelper.setNextSubItem;
					bookingItem.setHumidity( _msgHelper.currentSubItem.asDecimalJMT );
				elseif _msgHelper.currentField = "AAS" then //Air flow
					_msgHelper.setNextField;
					_msgHelper.setNextSubItem;
					bookingItem.vent := _msgHelper.currentSubItem.Real;
				elseif _msgHelper.currentField = "CD" then //Carbondioxide (temporary code)
					_msgHelper.setNextField;
					_msgHelper.setNextSubItem;
					bookingItem.setCarbonDioxide( _msgHelper.currentSubItem.asDecimalJMT );
				elseif _msgHelper.currentField = "ZO" then //Oxygen
					_msgHelper.setNextField;
					_msgHelper.setNextSubItem;
					bookingItem.setOxygen( _msgHelper.currentSubItem.asDecimalJMT );
				// End additions for PAR 19766 cnwgb1 26.5.09
				/*elseif _msgHelper.currentField = "AAW" then
*/				endif;
			endif;
		endif;
//NAD*
	elseif tag = "NAD" then
		if group &lt; 11 then
			group := 11;
		endif;
		
		if group = 11 then
			_msgHelper.setNextField;
			if _msgHelper.currentField = "CA" then		// should be Sender Operator
				_msgHelper.setNextField;

				fieldValue		:= _msgHelper.currentSubItem;
				code			:= app.myRoot.getXlationSystemOperatorCode( _ediOperator, fieldValue, foundMatch )[1:4];
				
				if _ediOperator = null then
					// no send from UNB segment
					if params.mySenderOperator = null then
						// sender has not subsequently been set from TDT segment
						params.mySenderOperator		:= app.myRoot.allOperators[ code ];
						params.senderOperatorCode	:= code;
					endif;
				endif;
				
				bookingHdr.operatorCode	:= code;
				
			elseif _msgHelper.currentField = "CZ" then
				_msgHelper.setNextField;
				
				if _msgHelper.currentSubItem &lt;&gt; null then
					if _ediOperator &lt;&gt; null then
						bookingHdr.consignee := _ediOperator.getXlationSystemCode(_msgHelper.currentField, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						bookingHdr.consignee := _msgHelper.currentField[1:30];
					endif;
				else
					_msgHelper.setNextField;
					
					bookingHdr.consignee := _msgHelper.currentField[1:10];
				endif;				
			endif;
		endif;

//RFF*
	elseif tag = "RFF" then
		if group &lt; 3 then
			group := 3;
		endif;
		
		if group = 3 then
			_msgHelper.setNextField;
			
			if _msgHelper.currentSubItem = "SI" then
			
			elseif _msgHelper.currentSubItem = "BN" then				
				
				_msgHelper.setNextSubItem;
				
				fieldValue := _msgHelper.currentSubItem[1:30].toUpper;
				
				if bookingHdr = null or fieldValue &lt;&gt; bookingHdr.id then
					if bookingHdr &lt;&gt; null then //finish any previous bookingref 
						bookingHdr.rawEDIData := params.rawEDIData;
					endif;
					
					params.rawEDIData := null;

					// 1st time or change of booking id
					create bookingHdr persistent; 
					params.myEDIBookingHeaderTI	:= bookingHdr;					
					bookingHdr.setForCreateNew(_ediData);
					
					create bookingItem persistent;
					params.myEDIBookingItemTI := bookingItem;		
					bookingItem.setForCreateNew(_ediData);
				endif;
				// cnwdad1 29/01/2010 - PAR #22216.
				bookingHdr.ediFileIssueDateTime	:= params.ediFileIssueDateTime;
				bookingHdr.setId(fieldValue);		// par 26223
				bookingItem.setId(fieldValue); 	// CCMS 1882 25 May 2010
				bookingItem.myParent 			:= bookingHdr;	//cnwrs1 Par 27392 

				// Use the operator voyage code translation if it exists.
				code	:= self.getXlationOperatorVoyageCode(	_ediOperator,
																	params.myVoyageOperator,
																	params.voyageCode,
																	params.vesselName,
																	params.lloydsNumber,
																	params.callsign );
				
				// make sure the manual collection on CM_EDIConfig gets maintained
				bookingHdr.setVoyageCode( code[1:30] );
				
				bookingHdr.messageMode 	:= _msgHelper.currentMessageMode;
			endif;
		endif;
//TDT*
	elseif tag = self.TDT then
		if group &lt; 8 then
			group := 8;
		endif;
		
		_msgHelper.setNextField();
		
		if group = 8 then
			if _msgHelper.currentField = "20" then
				self.getVoyageDetailsFromTDT(	_msgHelper,
												params.voyageCode,
												params.voyageOperatorCode,
												params.myVoyageOperator,			// cnwrl1 26/07/2010 PAR 25093
												params.vesselName,
												params.lloydsNumber,
												params.callsign );
				
				// PAR 25093 - Because some of Nelson's clients (ANL and COS) in particular do not send
				// through the mandatory UNB record the operator is not getting set up.
				// To cater for this we will use the first valid TDT+20 operator
				// if and only if the operator is not already set up.
				if _ediOperator = null and params.mySenderOperator = null then
					// no sender from UNB segment
					params.mySenderOperator		:= params.myVoyageOperator;
					params.senderOperatorCode	:= params.voyageOperatorCode;
				endif;
				
				bookingHdr.operatorCode	:= params.senderOperatorCode;
				
				if params.vesselName &lt;&gt; null then
					bookingHdr.vesselName := params.vesselName;
				endif;
				
				// Use the operator voyage code translation if it exists.
				params.voyageCode	:= self.getXlationOperatorVoyageCode(	params.mySenderOperator, 
																			params.myVoyageOperator, 
																			params.voyageCode, 
																			params.vesselName, 
																			params.lloydsNumber, 
																			params.callsign );
				// make sure the manual collection on CM_EDIConfig gets maintained
				bookingHdr.setVoyageCode(params.voyageCode);
			endif;
		endif;
//TMP*
	elseif tag = "TMP" then
		if group = 35 then
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = "2" or _msgHelper.currentField = '5' then	//par 13138 dec 2006
				_msgHelper.setNextField();
				
				fieldValue := _msgHelper.currentSubItem; //.asEDIReal();
				
				_msgHelper.setNextSubItem();

				if _msgHelper.currentSubItem = "CEL" then
					bookingItem.temperature := fieldValue.asEDIReal;
					
				elseif _msgHelper.currentSubItem = "FAH" then
					bookingItem.temperature := app.temperatureConversion(false, fieldValue.asEDIReal);
					// I think we should leave this error here so we don't miss important temperatur information
					//self.addFileErrors("Unknown TMP+2" &amp; Tab &amp; _msgHelper.currentSubItem &amp; Tab &amp; _msgHelper.currentMessage, _msgHelper.currentMessageNumber, _ediFile );
				endif;
			endif;
		endif;
	endif;

epilog
	_msgHelper.setCurrentGroup (group);
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyRules"/>
        <Parameter name="_reload" type="Boolean"/>
        <Parameter name="_version" type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="59709e76-fe91-496a-a92d-d2f598953b79">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
//
// 15 aug 2012 	cnwrs1 par 30203 failing to load with muliple UNH/UNTs
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
// 22 Jul 2013	cnwcs5	par 31942
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 28 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 9
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	
begin
	self.processEDIFACTFile(_ediFile, _ediFile.ediData, false);
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRawCommodityValue" id="b6641b0f-9dee-484a-a8f3-cac254b41b64">
        <source>setRawCommodityValue(_group :Integer; _ediTI: CM_EDITrackedItem; _value :String) protected;
/*
Date		Who		Reason
09 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
12 Dec 2014	cnwgb1	Copy multiple FTX handling to IFTMCS Par 33710 from COPARN
*/
vars
	key, value	:String;
	coll		:CM_StateDataDict;
begin
	key 	:= ETRow_CommodityDesc;
	coll	:= _ediTI.getAllExtraData;
	
    global.getExtraData (coll, key, value);
    
    if value &lt;&gt; null then
        value := value &amp; ':' &amp; _value;
    else
        value := _value;
    endif;
    
    global.setExtraData (coll, _ediTI, key, value);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
