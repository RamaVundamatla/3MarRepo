    <JadeMethod name="isRunningInDMAST" id="62983209-74b4-461b-8d83-c128700b8a6d">
        <source>isRunningInDMAST() : Boolean;

/*

Purpose:			Return if we are running in CNWDMAST	


Date		Who		Reason
17/02/2020	jlgmh5	Initial creation

*/

vars

	isCNWDMAST					: Boolean;
	miscDirPath					: String;

begin

	isCNWDMAST := false;

	miscDirPath := app.cnGetServerMiscPath[4:end];
	if miscDirPath[4:5].toUpper() = "DMAST" then
		isCNWDMAST := true;
	endif;
	
	return isCNWDMAST;
	
epilog

end;</source>
