// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	listbox.cnEcExpandItem(listbox.listIndex, true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSchemas_pictureClick" id="56c47842-b0fa-441d-a416-8dad4d056cab">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchemas_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
//	listbox.cnEcExpandItem(picIndex, true);
	listbox.itemExpanded[picIndex]	:=	(not listbox.itemExpanded[picIndex]);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
