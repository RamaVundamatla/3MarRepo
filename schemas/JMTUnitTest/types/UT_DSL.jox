    <JadeMethod name="updateTrainEvent" id="22fb74cd-a257-48d0-9b32-cd04e7047b4d">
        <source>updateTrainEvent(_train : CM_Train io; _eventTypeNo : Integer; _postDatedTime : TimeStamp) : Boolean;
// --------------------------------------------------------------------------------
// Created:	21 Jan 2014	cnwrs1	Par 33035 - add diagnostic message for train depart/arrival event
//
// Purpose:		Update Existing Train event
vars
	now : TimeStamp;
	success : Boolean;
//	firstEventType : CM_EventType;
	eventType : CM_EventType;
//	iter : Iterator;
//	foundEventType : Boolean;
	//pxyET : CM_EventType;
	pxyET : CM_EventTransaction;
	realTransaction : CM_EventTransaction;
	loadState : Boolean;
begin
	realTransaction := _train.allTransactions.getAtKeyGeq(_eventTypeNo, null);
	if realTransaction.type &lt;&gt; _eventTypeNo then
		realTransaction := null;
		return false;
	endif;
//	iter := app.myRoot.allEventTypesByCategory.createIterator;
	eventType := app.myRoot.allEventTypesByType[_eventTypeNo];
/*
	if firstEventType &lt;&gt; null then
		iter.startAtObject(firstEventType);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; CM_EventType.TRAIN_EVENT then
				break;
			endif;
			
			if eventType.type = _eventTypeNo then
				foundEventType := true;
				break;
			endif;
		endwhile;
	endif;	*/
	app.cmsBeginLoad(loadState);
	pxyET := realTransaction.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyET.setDetails(eventType, _postDatedTime, _train.getTerminal(), app.myPassport.myUser.code, false,0);
	
	app.myTrxUA.trxUpdateTrainEvent(pxyET, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		success := true;
	endif;
	
	return success;
	
epilog
	delete pxyET;
//	delete iter;
end;
</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_eventTypeNo" type="Integer"/>
        <Parameter name="_postDatedTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTrainWagon" id="60ba134f-5c9a-448a-b9a6-d757af6c0798">
        <source>updateTrainWagon(_wagon : CM_Wagon ;_train :CM_Train);
/*

Purpose: Update Wahon Details 			

Date		Who		Reason
27/03/2014	cnwma1	Initial creation

*/

vars

	pxyWagon 	 : CM_Wagon;
	wagon	 	 : CM_Wagon;
	carrier  	 : CM_Carrier;
	recStevedore : CM_Stevedore;
	relStevedore : CM_Stevedore;
begin

	wagon 		 := self.getWagon(_wagon.id.String,_train);
	carrier 	 := self.getCarrier("MADWY");
	recStevedore := app.myRoot.allStevedores["UTRECEIVE"];    //02.10.2020 cnwma1 TFS #50112
	relStevedore := app.myRoot.allStevedores["UTRELEASE"];   //02.10.2020 cnwma1 TFS #50112
	
	beginLoad;
		pxyWagon := wagon.pxyCreateUpdateProxy();
	endLoad;
	
	
	pxyWagon.setProxy(self.getTerminal(),
						wagon.id,
						wagon.myWagonClass,
						_train,
						_train,
						"Unit Test Update",
						wagon.maxCargoHeight,
						wagon.maxCargoWeight,
						wagon.tareWeight,
						carrier,
						recStevedore,        //02.10.2020 cnwma1 TFS #50112
						relStevedore);       //02.10.2020 cnwma1 TFS #50112
	
	app.myTrxUA.trxUpdateTrainWagon(pxyWagon,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete pxyWagon;
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="updateTransactionResync" id="7b2b62c5-83b4-49f0-9ca8-32ed1da70060">
        <source>updateTransactionResync(_trans : CM_TransactionSet; _ti : CM_TrackedItem; _options : StringArray);
// ---------------------------------------------------------------------------
// Created:     21 July 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	controller : CMIF_TiTransactionResync;
begin

	create controller transient;
	
	controller.myTrackedItem := _ti;
	
	_trans.copy(controller.allTransactions);
	if _options &lt;&gt; null then
		// extend this list as needed
		if _options.includes(UTTI_CustomsAgent) then
			controller.updateCustomsAgent := true;
		endif;
	endif;
	
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);

epilog

	delete controller;

end;</source>
        <Parameter name="_trans" type="CM_TransactionSet"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_options" type="StringArray"/>
    </JadeMethod>
