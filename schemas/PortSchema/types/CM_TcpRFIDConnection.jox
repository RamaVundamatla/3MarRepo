    <JadeMethod name="checkForJBUSError" id="377d5666-c8e3-4e5f-b0a0-31e031c2b7a3">
        <source>checkForJBUSError(_msg : String) : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
constants 
	JBUSError ="83";
	
vars

begin
	
	if _msg .length &lt; 4 then
		return null;
	endif;
	
	if _msg[3:2] = JBUSError then
		return _msg[5:2].Integer;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJBUSMessageValue" id="3c901c83-e717-440e-b895-db7a2ceb4a4e">
        <source>getJBUSMessageValue(_fullMessage : String) : String;
/*

Purpose:			the format of the full message is
					1 btye    |   1 byte  | 1 byte     | n bytes  | 2 byte
					channel   |  function | nb chars   | values	  | crc 16

					this method extracts values from the full message
Return Value:		


Date		Who		Reason
14 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	values,valuesHex : String;
	nbCharsHex: String;
	nbChars : Integer;
	i : Integer;
begin
	// get the nb values 
	nbCharsHex:=_fullMessage[5:2];
	nbChars:=nbCharsHex.cnEcHexValue();
	
	//covert to decimal (its in hex)
	if _fullMessage.length &lt;&gt; (6 + (nbChars * 2) + 4 ) then
		app.writeLog(method.name &amp; " msg length =  " &amp; _fullMessage.length.String &amp; " not " &amp; nbChars.String,LogDEBUG);
		//somethings wrong;
		return null;
	else
		valuesHex:=_fullMessage[7:nbChars*2];
		return valuesHex;
	endif;
	//get values


	return values;
epilog

end;</source>
        <Parameter name="_fullMessage" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRFIDTagReader" id="a96b5d94-aafe-43b0-b64e-fe0e7de1ed09">
        <source>getRFIDTagReader() : CM_RFIDTagReader protected;

// Created by cnwdvb1 on 26 June 2007
/*

Date		Who		Reason
07 Sep 2009	cnwkpd1	PAR #20601 - Add in Port number check to the 

*/

vars

	theReaderIpAddress	: String;
	terminal			: CM_Terminal;
	reader				: CM_RFIDTagReader;
	port				: Integer;

begin
	theReaderIpAddress := self.remoteIpAddress.trimBlanks();
	port := self.port;		// PAR #20601
	
	// We will still have tag reader attached so using that to get to correct tag reader
	app.writeLog('Looking up the reader IP address:' &amp; theReaderIpAddress &amp; " and Port:" &amp; port.String, LogINFO);
	
	foreach terminal in app.myRoot.allTerminals do
		reader := terminal.getTagReaderFromAddress(theReaderIpAddress, port);
		if reader &lt;&gt; null then
			return reader;
		endif;
	endforeach;
	
	app.createAlert('Could not locate reader with IP address:' &amp; theReaderIpAddress &amp; " and Port:" &amp; port.String, true);
	return null;
	

epilog	
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_RFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="getValuesString" id="a353e322-242a-44e4-8dc7-60dd9e7f9e4e">
        <source>getValuesString(_valuesHex :String) : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	i : Integer;
	values :String;
begin
	i:=1;
	while i &lt; _valuesHex.length do
		values := values &amp; _valuesHex[i:2].cnEcHexValue.Character;
		i:=i+2;
	endwhile;

	return values;

end;
</source>
        <Parameter name="_valuesHex" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="5d1471a7-fb9d-4075-aa97-afa98dec2778">
        <updating/>
        <source>init(_tagReader : CM_RFIDTagReader) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hasErrors : Boolean;
	errorMsg : String; 
	now : TimeStamp;
begin
	self.myRFIDTagReader 	:= _tagReader;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.myRFIDTagReader.context	= TagReaderContext_Machine then
		if self.myRFIDTagReader.ipAddress = null  then
			errorMsg:='RFID Tag Reader ' &amp;  self.myRFIDTagReader.code &amp; ' has null ipAddress';
			app.writeLog(errorMsg,LogDEBUG);
			hasErrors:=true;
		endif;
		if self.myRFIDTagReader.portNumber = null then
			errorMsg:=errorMsg &amp; CrLf &amp; 'RFID Tag Reader ' &amp;  self.myRFIDTagReader.code &amp; " has null port number";
			app.writeLog('RFID Tag Reader ' &amp;  self.myRFIDTagReader.code &amp; " has null port number",LogDEBUG);
			hasErrors:=true;
		endif;
		self.name				:= self.myRFIDTagReader.ipAddress;
		if hasErrors then
			self.causeEvent(Event_RFIDInfo,true,now.display  &amp;  " - " &amp; errorMsg);
			return;
		endif;
	else
		self.localInterface				:= self.myRFIDTagReader.ipAddressListener;//_tagReader.ipAddress;	
	endif;
	
	self.port				:= _tagReader.portNumber;
	
	self.timeout			:= null;
	
	if self.myRFIDTagReader.context	= TagReaderContext_Machine then
		self.timeout	:= 30000;
		//do tag Read now
		if not self.usePresentationClient then
			self.usePresentationClient:=true;
		endif;
		self.fillReadBuffer 	:= false;
		app.writeLog('RFID Tag Reader state = ' &amp; self.state.String,LogDEBUG);
		if self.state &lt;&gt; Connection.Disconnected then
			self.causeEvent(Event_RFIDInfo,true,now.display  &amp;  " - Cannot open connection as it is already open ... closing connection ");
			self.close;
			return;
		endif;
		
		
		
		self.causeEvent(Event_RFIDInfo,true,now.display  &amp; " - Trying to open connection on ip address "  &amp; self.name &amp; " : " &amp; self.port.String );
		self.openAsynch(self,CM_TcpRFIDConnection::openCB.name );
	
		
	else
		self.fillReadBuffer 	:= true;
		app.writeLog('Listening continuous asynch - IP:' &amp; self.localInterface &amp; ', Port:' &amp; self.port.String, LogINFO);
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-Listening continuous asynch - IP:' &amp; self.localInterface &amp; ', Port:' &amp; self.port.String);
		self.listenContinuousAsynch(self, CM_TcpRFIDConnection::listenContAsynchCallBack.name);
	endif;
	

end;



</source>
        <Parameter name="_tagReader" type="CM_RFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="listenContAsynchCallBack" id="8d267d08-5508-4498-b545-64c9ab3b1b01">
        <source>listenContAsynchCallBack(_tcpConnection, newTcpConnection : CM_TcpRFIDConnection);
/*
----------   ----------  --------------------------------------------------
Created:	04 September 2006 By cnwth2

Purpose:	called following the listenContinuousAsynch call in the init method. 
			so is part of a new stack from the app initialization.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	//i.e. call the following method when you get enough data transmitted to you from the tag reader to fill the buffer length
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; '- received', LogINFO);
	newTcpConnection.readBinaryAsynch(CM_RFIDAccess7CERead.Msg_Length, self, 'readBinaryAsynchCallback');

end;


</source>
        <Parameter name="_tcpConnection" type="CM_TcpRFIDConnection"/>
        <Parameter name="newTcpConnection" type="CM_TcpRFIDConnection"/>
    </JadeMethod>
    <JadeMethod name="openCB" id="fbbf7efb-da1f-46b8-ac6d-c3395d997e26">
        <source>openCB(_tcp : CM_TcpRFIDConnection);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 October 2007	cnwer1	Initial creation - PAR#xxxx

///////////////////////////////////////////////////////
//NOT SUPPORTED IN UNICODE SYSTEM
// 11/3/16  cnwns1 PAR 36286 unicode version
//////////////////////////////////////////////////////

*/
vars
	now : TimeStamp;
begin
		self.causeEvent(Event_RFIDInfo,true,now.display &amp; " - Successfully opened connection on ip address "  &amp; self.name &amp; " : " &amp; self.port.String );
		app.writeLog(class.name &amp; '::' &amp; method.name, LogDEBUG );
	
	//	self.writeJBUSCommand(#01.Character,JBUS_CLEAR_LOG.String,#00.Character &amp; #01.Character &amp; #02.Character  &amp;  #43.Character &amp; #03.Character);	
	self.writeJBUSCommand(#01.Character,JBUS_GET_NUM.String,#00.Character &amp; #01.Character);
	//	self.writeJBUSCommand(#01.Character,JBUS_RESET_RECORD.String,#00.Character &amp; #00.Character);
	//	self.writeJBUSCommand(#01.Character,JBUS_GET_MAX_RECORD.String,#00.Character &amp; #01.Character);
	//	self.writeJBUSCommand(#01.Character,JBUS_GET_STATUS.String,#00.Character &amp; #01.Character);
	//	self.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD_LENGTH.String,#00.Character &amp; #01.Character);
	//	self.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD.String,#00.Character &amp; #17.Character );
		//self.writeJBUSCommand(#01.Character,JBUS_GET_PREVIOUS_RECORD.String,#00.Character &amp; #08.Character);
	//	self.writeJBUSCommand(#'01',GET_STATUS_MEMORY.String,#'01' &amp; #'08');
	//	self.writeJBUSCommand(#01.Character,JBUS_GET_LOG_STATUS.String,#00.Character &amp; #01.Character);
	//	self.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD.String,#00.Character &amp; #26.Character);

epilog

end;</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
    </JadeMethod>
    <JadeMethod name="readBinaryAsynchCallback" id="6c659bb8-86fc-427c-a4fd-4036dd713a9d">
        <source>readBinaryAsynchCallback(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*
----------   ----------  --------------------------------------------------
Created:	04 September 2006 By cnwth2

Purpose:	called following the readBinaryAsynch call from the listenContAsynchCallBack method. 
			If we're in here it means the connection has received enough data from the RFID tag 
			reader to fill the buffer to the specified length (27 chars)
			
			Example data to expect:

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	newTcp				: CM_TcpRFIDConnection;
	connection			: CM_TcpRFIDConnection;
	theTagReader		: CM_RFIDTagReader;
	errCode		: Integer;
	theConnection,
	errTxt		: String;
	
begin

	on Exception do app.alertExceptionHandler(exception, null, 'RFID Server Processing', errCode, errTxt, false, false);
	on LockException do app.alertLockExceptionHandler(exception);
	
	newTcp := _tcp;
	if self.name &lt;&gt; null then
		theConnection := self.name;
	else
		theConnection := self.localInterface;
	endif;
	
	app.writeStatement('Connection ' &amp; theConnection &amp; ', on port ' &amp; self.port.String &amp; ', received ' &amp; _buffer.String);
	app.writeLog('Connection ' &amp; theConnection &amp; ', on port ' &amp; self.port.String &amp; ', received ' &amp; _buffer.String, LogINFO);
	
	theTagReader := newTcp.getRFIDTagReader();
	//self.myRFIDTagReader.doProcessBinary(_buffer);
	
	if theTagReader &lt;&gt; null then
		app.writeLog('Found tag reader ' &amp; theTagReader.code, LogINFO);
		app.writeStatement('Found tag reader ' &amp; theTagReader.code);
		theTagReader.doProcessBinary(_buffer);
	else
		// Need exception here.
		app.writeLog('Unable to locate tag reader', LogINFO);
		app.writeStatement('Unable to locate tag reader');
	endif;
	
	newTcp.fillReadBuffer := true;
	//call this method again next time you receive data
	newTcp.readBinaryAsynch(CM_RFIDAccess7CERead.Msg_Length, self, CM_TcpRFIDConnection::readBinaryAsynchCallback.name);
	
end;


</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readClearLogCB" id="f5613327-ebf2-4bba-ab0b-990b020b27ed">
        <source>readClearLogCB(tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars	
	responseString, values : String;
	jbusError : Integer;
	now : TimeStamp;
begin
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	self.causeEvent(Event_RFIDInfo,true, now.display &amp;  " Clear Log got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		return;
	endif;

	values:=self.getJBUSMessageValue(responseString);
	app.writeLog(values,LogDEBUG);

epilog
	self.close;

end;</source>
        <Parameter name="tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetCurrentRecordCB" id="b8bd2371-39b5-4a13-a006-6e86f277ebc7">
        <source>readGetCurrentRecordCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString : String;
	values,valuesHex,userCode : String;
	jbusError :Integer;
	nbCharsHex : String;
	nbChars : Integer;
	typeHex ,serialNumber:String;
	type : Integer;
	tag : String;
	error : Boolean;
	theDate : Date;
	theTime : Time;
begin
	error:=false;
	
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; _buffer.String,LogDEBUG);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String);
		error:=true;
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values
	nbCharsHex :=responseString[5:2];
	nbChars:=nbCharsHex.cnEcHexValue();
	//valuesHex:=self.getJBUSMessageValue(responseString);
	
	app.writeLog(method.name &amp; " tag found " &amp; valuesHex.String,LogDEBUG);
	if nbChars &lt;= 20 then
		app.writeLog(method.name &amp; " no tag in log",LogDEBUG);
		self.causeEvent(Event_RFIDInfo,true, "No tag(s) in log");
		error:=true;
		return;
	endif;
	
	typeHex:=responseString[19:2];
	type:=typeHex.cnEcHexValue();
	
	if type &lt;&gt; 0 then
		app.writeLog(method.name &amp; "type &lt;&gt; tag " &amp;type.String,LogDEBUG );
		self.causeEvent(Event_RFIDInfo,true, "Last log record is not a tag read");
		error:=true;
		return;
	endif;
	valuesHex:=responseString[21:end];
	values:=self.getValuesString(valuesHex);
	userCode:=values;
	//first 3 bytes = date
	//second 3 bytes = time
	// 7 byte = type this must be 0
	// rest = 
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " tag found " &amp; userCode, LogDEBUG);
	//self.causeEvent(Event_RFIDInfo,true, "Tag found with value " &amp; userCode);
	if self.myRFIDTagReader &lt;&gt; null then
		serialNumber:=self.myRFIDTagReader.doProcessBinary(userCode.Binary);
		if serialNumber = null then
			self.causeEvent(Event_RFIDInfo,true, "No Tag found in JMT with value  " &amp; userCode);
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; " tag found in JMT with value  " &amp; userCode,LogDEBUG);
		else
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; " Found RFID Tag in JMT  " &amp; serialNumber,LogDEBUG);
			self.causeEvent(Event_RFIDInfo,true, "Found RFID Tag in JMT  " &amp; serialNumber);
		endif;
	endif;
	
	self.writeJBUSCommand(#01.Character,JBUS_CLEAR_LOG.String,#00.Character &amp; #01.Character &amp; #02.Character  &amp;  #43.Character &amp; #03.Character);
epilog
	
	if error then
		self.close;
	endif;
end;</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetCurrentRecordLengthCB" id="807e5c99-de1a-4f26-bb0d-b17d8927378e">
        <source>readGetCurrentRecordLengthCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString : String;
	values,userCode : String;
	jbusError, valueInt :Integer;
	error:Boolean;
begin
	
	
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String);
		error:=true;
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values

	values:=self.getJBUSMessageValue(responseString);
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; values,LogDEBUG);

	if values[1:2].Integer = 0 then
	//	error:=true;
	//	return;
	endif;
	valueInt:=values[1:2].cnEcHexValue.Integer + 1;
	values:=(values[1:2].cnEcHexValue.Integer ).asHex(2);
	
	if valueInt.isOdd then 
		valueInt:=valueInt - 1;
	endif;
	valueInt:=(valueInt/2).Integer;
	
	//app.writeLogServer(valueInt.String);
	app.writeLog( values.cnEcHexValue.String,LogDEBUG);
	
	//process.sleep(20);
	self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got record length " &amp; valueInt.String);
	
	
	self.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD.String,#00.Character &amp;  valueInt.String.cnEcHexValue.Character);//&amp; #17.Character );

epilog
	if error then
		self.close;
	endif;
end;</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetLogStatusCB" id="cbfd6d22-a15d-4744-96bc-d31868f13a0c">
        <source>readGetLogStatusCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);

vars
	responseString : String;
	values,valuesHex,userCode : String;
	jbusError :Integer;
	nbCharsHex : String;
	nbChars : Integer;
	typeHex ,serialNumber:String;
	type : Integer;
	tag : String;
	error : Boolean;
begin
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		error:=true;
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values
	nbCharsHex :=responseString[5:2];
	nbChars:=nbCharsHex.cnEcHexValue();
	valuesHex:=self.getJBUSMessageValue(responseString);
	
	values:=self.getValuesString(valuesHex);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; values,LogDEBUG);
end;
</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetMaxRecordLengthCB" id="e02c0de9-aedf-4e23-bb7b-e0be42364484">
        <source>readGetMaxRecordLengthCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString : String;
	values,userCode : String;
	jbusError :Integer;
	error:Boolean;
begin
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String);
		error:=true;
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values

	values:=self.getJBUSMessageValue(responseString);
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; values,LogDEBUG);

	if values[1:2].Integer = 0 then
	//	error:=true;
	//	return;
	endif;
	values:=(values[1:2].cnEcHexValue.Integer + 1).asHex(2);
	//app.writeLogServer(values);
	//app.writeLogServer( values.cnEcHexValue.String);
	
	//process.sleep(20);
	self.causeEvent(Event_RFIDInfo,true, class.name &amp; '::' &amp; method.name &amp; " got record length " &amp; values.String);

epilog
	self.close;
end;</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetNumCB" id="6bdcfda9-8c17-4712-9dde-faa7cc1cfdc7">
        <source>readGetNumCB(tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString,values : String;
	jbusError : Integer;
	error : Boolean;
begin
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	//self.causeEvent(Event_RFIDInfo,true,class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String);
		error:=true;
		return;
	endif;

	values:=self.getJBUSMessageValue(responseString);
	
	values:=(values[1:4].cnEcHexValue.Integer).asHex(4);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got num of " &amp; values,LogDEBUG);
	self.causeEvent(Event_RFIDInfo,true,class.name &amp; '::' &amp; method.name &amp; " got num of " &amp; values);
	
	if not error then
		self.writeJBUSCommand(#01.Character,JBUS_RESET_RECORD.String,#00.Character &amp; #00.Character);
	endif;	
epilog
	if error then
		self.close;
	endif;

end;</source>
        <Parameter name="tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
