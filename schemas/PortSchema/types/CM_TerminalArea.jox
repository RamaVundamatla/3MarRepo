    <JadeMethod name="setICAreas" id="3d9644e2-d75c-4655-8c5f-5515ee89bf7e">
        <source>setICAreas(_coll :CM_InterchangeAreaArray);
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     Update the list of interchanges areas for a terminal area
// Parameters:  _coll - new list of interchange areas
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_InterchangeArea;
begin
	self.allAssociatedInterchangeAreas.clear; 
	
	if _coll &lt;&gt; null then
		foreach area in _coll do
			if not self.allAssociatedInterchangeAreas.includes(area) then
				self.allAssociatedInterchangeAreas.add( area);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_coll" type="CM_InterchangeAreaArray"/>
    </JadeMethod>
