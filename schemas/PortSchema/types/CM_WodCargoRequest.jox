    <JadeMethod name="getMoveAmountDisplay" id="7b63687c-9b2a-492d-a827-9796fd09de18">
        <source>getMoveAmountDisplay() : String;
/*
Purpose:	// TFS 42221 19DEC18		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	ct			: CM_CargoType;
	moveWeight 	: Decimal[14,4];
	density 		: Decimal[14,4];

begin
	
	ct := self.myCargoType;

	if ct &lt;&gt; null 
	and ct.isBulkMulti() then
		if self.myCargoSubType &lt;&gt; null then
			if self.myCargoSubType.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
				density :=  self.myCargoSubType.getDensityValue();
				return ct.getBulkTrackByDisplayForWeight(self.totalWeight,density,true);
			endif;
		endif;
		if ct.mySystemProductType &lt;&gt; null then
			density := ct.mySystemProductType.getDensityValue;
			return ct.getBulkTrackByDisplayForWeight(self.totalWeight,density,true);
		endif;
	
		return self.totalWeight.asStringJMT;
		
	endif;		
	
	return self.totalQuantity.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountStr" id="becf7541-7e0c-4b57-b47d-16b04522f8ce">
        <source>getMoveAmountStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2018	jlgndl1	Initial creation	TFS 40050

*/

vars

	measurementType : CM_MeasurementType;

begin

	if self.myCargoType &lt;&gt; null and self.myCargoType.isBulkByVolume then
		measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
		return app.convertMeasurementForDisplay(measurementType.shortName, self.totalVolume) &amp; " " &amp; measurementType.shortName;
	
	elseif self.myCargoType &lt;&gt; null and self.myCargoType.isBulkByWeight and self.totalWeight &gt; 0 then
		measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		return app.convertMeasurementForDisplay(measurementType.shortName, self.totalWeight) &amp; " " &amp; measurementType.shortName;
	
	elseif self.totalQuantity &lt;&gt; 0 then
		return "x " &amp; self.totalQuantity.String;
	
	endif;
	
	return "1";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
