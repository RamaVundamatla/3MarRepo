    <JadeMethod name="cnEcGetDuplicate" id="214443c1-da89-42f2-899e-1b652d5871ff">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2014	cnwndl1	Initial creation

*/

vars

	oidTable : CnEcOidTable;
	id : String;
	rtDev : CM_RTDeviceVehicleMount;
	machineOid : String;
	xmlObj : CnEcXmlStructureInstance;
	xmlObj2 : CnEcXmlStructureInstance;
	currentOidValue : String;
	obj : Object;
	machObj : CM_Machine;

begin

	id := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "id" ).String;

	if id &lt;&gt; null then
		xmlObj	:=	pInput.findStructure("myMachine");
		if xmlObj &lt;&gt; null then
			xmlObj2	:=	xmlObj.findStructure("OID");
			if xmlObj2 &lt;&gt; null then
				machineOid := xmlObj2.tagData;
				if machineOid &lt;&gt; null then
					//grubby, grubby, but should be OK if Hubble being used correctly.
					if not CnEcOidTable.instances.isEmpty then
						oidTable := CnEcOidTable.lastInstance;
					endif;
					if oidTable &lt;&gt; null then
						obj := oidTable.getObject(machineOid);
					endif;
					if obj &lt;&gt; null and obj.isKindOf(CM_Machine) then
						machObj := obj.CM_Machine; 
					endif;
				endif;
			endif;
		endif;
		
		if machObj &lt;&gt; null then
			rtDev := machObj.myRTDevice;
		endif;
	
	endif;
	
epilog

	return rtDev;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="340898b9-0de6-43c9-9bec-aec02a03eab0">
        <source>getDisplay(): String;
// -------------------------------------------
// Created 29 October 2003 by cnwdvb1
// -------------------------------------------
vars

	machine : CM_Machine;
	machId		: String;

begin

	machine := self.myMachine;
	if machine &lt;&gt; null then
		machId := 'Vehicle ' &amp; machine.id;	
	endif;
	return machId &amp; ' ' &amp; inheritMethod();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
