    <JadeMethod name="getAllCriteriaValues" id="916eb27a-02df-4c14-9dbc-348f8582617a">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2016	cnwdap1		Initial creation TFS 3040 SNO Empty Container Pool Management
//
vars

begin
	_terminalObj.allMTPoolingParties.copy(_allCriteriaValues);

epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
