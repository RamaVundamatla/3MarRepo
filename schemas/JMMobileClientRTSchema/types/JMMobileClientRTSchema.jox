    <JadeMethod name="initializeScreenColors" id="c8067d81-dcca-413d-a663-5cfa6d7a94fd">
        <updating/>
        <source>initializeScreenColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Initializes the screen background/foreground color values.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	isSuccessful	: Boolean;
	tempForm		: LogonForm;
	
begin
	isSuccessful	:=	app.getSystemColorsFromIni(	self.colorBackGeneral,
													self.colorForeGeneral,
													self.colorBackTables,
													self.colorForeTables);
	
	if (not isSuccessful) or errorMessage &lt;&gt; null then
		create tempForm transient;
		// There was an error fetching the screen colors, so just use the default Windows colors.
		self.colorBackGeneral	:=	tempForm.getSystemColor(Window.Color_3DFace);
		self.colorForeGeneral	:=	tempForm.getSystemColor(Window.Color_WindowText);
		self.colorBackTables	:=	tempForm.getSystemColor(Window.Color_3DFace);
		self.colorForeTables	:=	tempForm.getSystemColor(Window.Color_WindowText);
	endif;
epilog
	delete tempForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
