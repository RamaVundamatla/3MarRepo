    <JadeMethod name="create" id="d39a99aa-1592-43d7-8e57-09227f8d8f33">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_ISOTypeGroup;
	self.permissionView	 := PmAdmGrouptableView;
	self.permissionMaint := PmAdmGrouptableMaint;
	self.myDataClass := CM_ISOTypeGroup;
	
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);	//18 Mar 2014	NDL	Par 33268

end;</source>
