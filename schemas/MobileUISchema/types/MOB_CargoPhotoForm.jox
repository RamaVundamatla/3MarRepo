    <JadeMethod name="doResizeControls" id="2b89ccbf-828c-41f4-8b9c-de1cc46948e3">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdHeight : Real;
	stdWidth : Real;
	thirdWidth : Real;
	twoThirdsWidth : Real;
	vTop : Real;
	vLeft : Real;
	vHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - ( 2 * self.resizedMargin );
	thirdWidth := ( stdWidth - self.resizedMargin ) / 3;
	twoThirdsWidth := thirdWidth * 2;
	vTop := self.resizedMargin;
	vLeft := self.resizedMargin;
	
	if _initialSetup then
		self.lblDesc.enabled := true;
	endif;
	self.lblDesc.move(	vLeft,
						vTop,
						thirdWidth,
						stdHeight
						);
	
	
	vLeft := self.lblDesc.left + self.lblDesc.width + self.resizedMargin;
	self.txtDesc.move(	vLeft,
						vTop,
						twoThirdsWidth,
						stdHeight
						);
						
	if _initialSetup then
		self.txtDesc.enabled := true;
		self.txtDesc.text := "";
		self.txtDesc.setFocus();
	endif;
	
	vLeft := self.resizedMargin;
	vTop := self.lblDesc.top + self.lblDesc.height + self.resizedMargin;
	vHeight := self.clientHeight - vTop - self.resizedMargin - self.getCMDButtonsHeight();
	self.photoPreview.move(vLeft, 
						   vTop, 						  
						   stdWidth, 
						   vHeight
						   );

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="b728fc00-9069-444a-872e-ec0db4da2892">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	#cnwdz2	 CCMS MES 1005 par 22294
21 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	newPhoto,
	proxyPhoto : CM_Photo;
	errorMess : String;
	file : File;
begin
	create proxyPhoto transient;

	proxyPhoto.setDescription(self.txtDesc.text);
	proxyPhoto.setMyParent(self.myTrackedItem);
	
	proxyPhoto.setPhotoContent(self.originalPhoto); //04/02/2011 cnwdz2 par26872
	//proxyPhoto.setThumbnailContent(self.photoPreview.picture);                        //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, newPhoto, app.myPassport);
		
	if not app.myPassport.trxCompletedOK then
		errorMess := "Error occurred! Please try again.";//app.getErrorString(Some_cargo_unconfirmed);
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, false);
		return;
	endif;
	
	create file transient;
	file.fileName := picFileName;
	file.purge();
	self.unloadForm();
epilog
	delete file;
end;</source>
        <access>protected</access>
    </JadeMethod>
