    <JadeMethod name="isCarrier_Match" id="bf167acc-50f9-4614-acba-25419c657f30">
        <source>isCarrier_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars

	carrier	: Object;
	code	: String;

begin

	//code := self.myTrackedItem.carrier.trimBlanks();
	code := self.myTrackedItem.releaseCarrier.trimBlanks();	// 17 Aug 2011	NDL	Par 27953
	
	// Only priorities will be empty.
	if code &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;

	// Do we have a match?
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isCarrier_Compare, code);

end;</source>
