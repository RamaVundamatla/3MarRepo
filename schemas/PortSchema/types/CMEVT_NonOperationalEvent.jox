Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2023	navcs2	Initial creation

*/

vars

begin
	inheritMethod(_pxyEvent);
	
epilog

end;</source>
        <Parameter name="_pxyEvent" type="CM_EventTransaction"/>
    </JadeMethod>
</Class>
