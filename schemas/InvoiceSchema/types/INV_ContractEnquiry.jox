    <JadeMethod name="setFilters" id="25f4d3f5-e41f-4f30-a25d-e6f23c8c9bb0">
        <updating/>
        <source>setFilters() updating;
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

begin
    self.allDebtors.clear();
	self.msgDebtors.getSelected(self.allDebtors);
	
	self.allInvoiceLineTypes.clear();
	self.msgLineTypes.getSelected(self.allInvoiceLineTypes);
	
	self.allServices.clear();
	self.msgServices.getSelected(self.allServices);
	
	self.filterQueryActive := self.chkActive.value;
	self.filterQueryContract := self.txtContractId.text.trimBlanks().toUpper();
	self.filterQueryDescription := self.txtDescription.text.trimBlanks().toUpper();
	
	self.filterQueryPrimary := self.chkPrimary.value;
	self.filterQueryCurrent := self.chkValidOnly.value;

	self.filterQueryContractFromStart.setDate(self.mskContractFromStart.getDate());
	self.filterQueryContractFromEnd.setDate(self.mskContractFromEnd.getDate());
	self.filterQueryContractFromStart.setTime(self.mskContractFromStartTime.getTime());
	self.filterQueryContractFromEnd.setTime(self.mskContractFromEndTime.getTime());

	self.filterQueryDetailFromStart.setDate(self.mskDetailFromStart.getDate());
	self.filterQueryDetailFromEnd.setDate(self.mskDetailFromEnd.getDate());
	self.filterQueryDetailFromStart.setTime(self.mskDetailFromStartTime.getTime());
	self.filterQueryDetailFromEnd.setTime(self.mskDetailFromEndTime.getTime());
	self.filterQueryDetailVolBasedOnly := self.chkVolBasedOnly.value; // ### TFS CR 55624 TASK 55698 23JAN2023 NAVAB1

	self.filterQueryRateFromStart.setDate(self.mskRateFromStart.getDate());
	self.filterQueryRateFromEnd.setDate(self.mskRateFromEnd.getDate());
	self.filterQueryRateFromStart.setTime(self.mskRateFromStartTime.getTime());
	self.filterQueryRateFromEnd.setTime(self.mskRateFromEndTime.getTime());

	self.filterQueryContractToStart.setDate(self.mskContractToStart.getDate());
	self.filterQueryContractToEnd.setDate(self.mskContractToEnd.getDate());
	self.filterQueryContractToStart.setTime(self.mskContractToStartTime.getTime());
	self.filterQueryContractToEnd.setTime(self.mskContractToEndTime.getTime());

	self.filterQueryDetailToStart.setDate(self.mskDetailToStart.getDate());
	self.filterQueryDetailToEnd.setDate(self.mskDetailToEnd.getDate());
	self.filterQueryDetailToStart.setTime(self.mskDetailToStartTime.getTime());
	self.filterQueryDetailToEnd.setTime(self.mskDetailToEndTime.getTime());

	self.filterQueryRateToStart.setDate(self.mskRateToStart.getDate());
	self.filterQueryRateToEnd.setDate(self.mskRateToEnd.getDate());
	self.filterQueryRateToStart.setTime(self.mskRateToStartTime.getTime());
	self.filterQueryRateToEnd.setTime(self.mskRateToEndTime.getTime());
	
	
	self.filterQueryRateAmountFrom := self.txtRateCPUFrom.text.Decimal;
	self.filterQueryRateAmountTo := self.txtRateCPUTo.text.Decimal;
end;</source>
