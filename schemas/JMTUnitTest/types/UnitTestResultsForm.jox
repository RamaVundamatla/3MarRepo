    </JadeMethod>
    <JadeMethod name="getGraphDetails" id="5e2b62a1-9fe2-4e56-a808-2bcc339352d8">
        <source>getGraphDetails(_dict : DynaDictionary input; _allXLabelsMain, _allXLabelsOther : StringArray io; _allPlotValuesRunTime, _allPlotValues3Hours, _allPlotValuesNoTests,
 _allPlotValuesPassed, _allPlotValuesFailed, _allPlotValuesIgnored, _allPlotValuesRunnable, _allPlotValuesNoTestRun : IntegerArray io);

/*

Purpose:		Setup the graph arrays

Date			Who		Reason
02/05/2012		cnwmh5	Initial creation

*/

vars

	testRuns				: UM_UnitTestRun;									// 10/09/2013 cnmwh5
	
	iter					: Iterator;
	
	keyName					: String;
	ts						: TimeStamp;
	currentDate				: Date;
	
begin

	currentDate := self.startTimeStamp.date;
	
	// 10/09/2013 cnwmh5
	iter := _dict.createIterator;
	while iter.next(testRuns) do
	
		_dict.getIteratorKeys(keyName, ts, iter);
	
		if keyName = 'Daily' or keyName = 'DailyLogResult' or keyName = 'DailySchLogResult' or 
				keyName = 'DailySch' or keyName = "LogResult" then
			_allXLabelsMain.add(testRuns.startTS.date.format("dd/MM"));
			_allPlotValues3Hours.add(180);
			_allPlotValuesRunTime.add(testRuns.elapsedTime.Integer);
		elseif keyName = 'TotRunnable' then
			_allPlotValuesRunnable.add(testRuns.totalRunnable);
		elseif keyName = 'Passed' then
			_allPlotValuesPassed.add(testRuns.numPassed);
		elseif keyName = 'Failed' then
			_allPlotValuesFailed.add(testRuns.numFailed);
		elseif keyName = 'Ignored' then
			_allPlotValuesIgnored.add(testRuns.numIgnored);
		elseif keyName = 'NoTestRun' then
			_allPlotValuesNoTestRun.add(testRuns.numRun);
		endif;	
	
	endwhile;
	
	_allXLabelsMain.copy(_allXLabelsOther);
	
epilog
	
	delete iter;
	
end;</source>
        <Parameter name="_dict" type="DynaDictionary" usage="input"/>
        <Parameter name="_allXLabelsMain" type="StringArray" usage="io"/>
        <Parameter name="_allXLabelsOther" type="StringArray" usage="io"/>
        <Parameter name="_allPlotValuesRunTime" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValues3Hours" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesNoTests" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesPassed" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesFailed" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesIgnored" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesRunnable" type="IntegerArray" usage="io"/>
        <Parameter name="_allPlotValuesNoTestRun" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGraphTitles" id="6041548e-93ef-4442-a4ae-5eab296b8245">
        <source>getGraphTitles(_titleMain, _titleOther : String output);

/*

Purpose:		Get the titles of the graphs based on what is selected

Date			Who		Reason
02/04/2012		cnwmh5	Initial creation

*/

vars

begin
	
	// get the graph title
	_titleMain := "Automated Test Run Times";
	_titleOther := null;
	
	// Main
	if self.chkDaily.value then
		_titleMain := _titleMain &amp; " - Daily";
	endif;
	if self.chkDailySche.value then
		_titleMain := _titleMain &amp; " - Daily (incl SCHEDULE)";
	endif;
	if self.chkLogResult.value then
		_titleMain := _titleMain &amp; " - Log Result";
	endif;
	if self.chkRunnable.value then
		_titleMain := _titleMain &amp; " - Total Runnable";
	endif;
	
	// Other
	if self.chkPassed.value then
		_titleOther := _titleOther &amp; "Passed";
	endif;
	if self.chkFailed.value then
		if _titleOther &lt;&gt; null then
			_titleOther := _titleOther &amp; " / ";
		endif;
		_titleOther := _titleOther &amp; "Failed";
	endif;
	if self.chkIgnored.value then
		if _titleOther &lt;&gt; null then
			_titleOther := _titleOther &amp; " / ";
		endif;
		_titleOther := _titleOther &amp; "Ignored";
	endif;
	if self.chkTotNoTests.value then
		if _titleOther &lt;&gt; null then
			_titleOther := _titleOther &amp; " / ";
		endif;
		_titleOther := _titleOther &amp; "Total No. Tests";
	endif;
	if self.chkNoTestsRun.value then
		if _titleOther &lt;&gt; null then
			_titleOther := _titleOther &amp; " / ";
		endif;
		_titleOther := _titleOther &amp; "No. Tests Run";
	endif;

epilog

end;</source>
        <Parameter name="_titleMain" type="String" usage="output"/>
        <Parameter name="_titleOther" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getJDORunDetails" id="fb48b2b8-3560-4122-a84d-fc1aa3111a15">
        <source>getJDORunDetails(_jdo : JadeDynamicObject input; _startTimeStamp, _runTimeStamp : TimeStamp output; _lastPassedDate : Date output; 
		_failureDetails, _result, _ownerName, _emailedTo : String output; _elapsedTime : String output);

/*

Purpose:		Return the details for the store object	

Date			Who		Reason
26/04/2012		cnwmh5	Initial creation

*/

vars
	failedResults 			: Binary;
	passedResults			: Binary;
	
	testResultElement		: JadeXMLElement;
	xmlElement				: JadeXMLElement;
	xmlDocument				: JadeXMLDocument;
	
begin

	_startTimeStamp := _jdo.getPropertyValue("startTimeStamp").TimeStamp;
	_runTimeStamp := _jdo.getPropertyValue("runTimeStamp").TimeStamp;
	_lastPassedDate := _jdo.getPropertyValue('lastPassedDate').Date;
	
	failedResults := _jdo.getPropertyValue('failedResults').Binary;
	
	passedResults := _jdo.getPropertyValue('passedResults').Binary;
	
	create xmlDocument transient;
	if failedResults &lt;&gt; null then
		xmlDocument.parseString(failedResults.uncompressToStringJMT());
	elseif passedResults &lt;&gt; null then
		xmlDocument.parseString(passedResults.uncompressToStringJMT());
	endif;
	
	testResultElement := xmlDocument.getElementByTagName('TestResult');
	if testResultElement &lt;&gt; null then
		xmlElement := testResultElement.getElementByTagName('result');
		if xmlElement &lt;&gt; null then
			_result := xmlElement.textData;
		endif;
		xmlElement := testResultElement.getElementByTagName('ownerName');
		if xmlElement &lt;&gt; null then
			_ownerName := xmlElement.textData;
		endif;
		xmlElement := testResultElement.getElementByTagName('emailedTo');
		if xmlElement &lt;&gt; null then
			_emailedTo := xmlElement.textData;
		endif;
		xmlElement := testResultElement.getElementByTagName('elapsedTime');
		if xmlElement &lt;&gt; null then
			_elapsedTime := xmlElement.textData;
		endif;
		xmlElement := testResultElement.getElementByTagName('failureDetails');
		if xmlElement &lt;&gt; null then
			_failureDetails := xmlElement.textData;
		endif;
	endif;
	
epilog

	delete xmlDocument;

end;</source>
        <Parameter name="_jdo" type="JadeDynamicObject" usage="input"/>
        <Parameter name="_startTimeStamp" type="TimeStamp" usage="output"/>
        <Parameter name="_runTimeStamp" type="TimeStamp" usage="output"/>
        <Parameter name="_lastPassedDate" type="Date" usage="output"/>
        <Parameter name="_failureDetails" type="String" usage="output"/>
        <Parameter name="_result" type="String" usage="output"/>
        <Parameter name="_ownerName" type="String" usage="output"/>
        <Parameter name="_emailedTo" type="String" usage="output"/>
        <Parameter name="_elapsedTime" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTestCreationDetails" id="f6360cb6-4a72-4454-a44e-8311910295ec">
        <source>getTestCreationDetails();

/*

Purpose:		Dump to a csv file creation details for all runnable tests descending
				All - Get all Details
				&lt;start &amp; end date&gt; - Get details between the dates (inclusive)

Date			Who		Reason
07/03/2016		cnwmh5	Initial creation

*/
constants	

	DELIM								: String = ",";
	Capitals							: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars

	file								: File;
	klass								: Class;
	meth								: Method;
	dict								: DynaDictionary;
	
	classes								: ClassColl;
	methodsDict							: MethodNDict;
	
	iter								: Iterator;

	dontTestDates						: Boolean;
	inputValue							: String;
	inputValueCount						: Integer;
	date								: Date;
	startDate							: Date;
	endDate								: Date;
	fileNamePart						: String;
	ts 									: TimeStamp;
	
begin

	ts := app.getServerStartTime();
	ts := ts.addMonths(-1);
	startDate := null;
	endDate := null;

	while true do
	
		inputValue := ts.date.format("dd/MM/yyyy");
		read inputValue;
		
		if inputValue = null then
			app.msgBox("Input Value is NULL.  Exiting...", "Null Value Error", MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
		
		// ALL required
		if inputValue.toUpper = "ALL" then
			inputValueCount := 0;
			dontTestDates := true;
			fileNamePart := "_ALL";
			break;
		endif;
		
		// checking the dates
		if not inputValue.asDate().isValid() then
			app.msgBox("Invalid Date Entered.  Exiting...", "Invalid Date", MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		elseif inputValue.trimBlanks().length = 10 then
			if inputValueCount = 0 then
				startDate.setDate(inputValue[1:2].Integer, inputValue[4:2].Integer, inputValue[7:4].Integer);
			else
				endDate.setDate(inputValue[1:2].Integer, inputValue[4:2].Integer, inputValue[7:4].Integer);
			endif;
			inputValueCount := inputValueCount + 1;
		elseif inputValue.trimBlanks().length = 8 then
			if inputValueCount = 0 then
				startDate.setDate(inputValue[1:2].Integer, inputValue[3:2].Integer, inputValue[5:4].Integer);
			else
				endDate.setDate(inputValue[1:2].Integer, inputValue[3:2].Integer, inputValue[5:4].Integer);
			endif;
			inputValueCount := inputValueCount + 1;
		endif;
		
		if inputValueCount = 2 then
			fileNamePart := fileNamePart &amp; endDate.year.String &amp; endDate.month.padLeadingWith("0",2) &amp; endDate.day.padLeadingWith("0",2);
			break;
		endif;
	
		ts := app.getServerStartTime();
		fileNamePart := "_" &amp; startDate.year.String &amp; startDate.month.padLeadingWith("0",2) &amp; startDate.day.padLeadingWith("0",2) &amp; "_To_"; 
	
	endwhile;
	
	create file transient;
	file.fileName := "c:\temp\TestCreationDetails" &amp; fileNamePart &amp; ".csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Class" &amp; DELIM &amp; "Method" &amp; DELIM &amp; "Creation Date" &amp; DELIM &amp; "Creation Time" &amp; DELIM &amp; 
		"Modified Date" &amp; DELIM &amp; "Modified Time" &amp; DELIM &amp; "By");
	
	create classes transient;
	klass := currentSchema.getClass("UT_DSL");
	klass.allLocalSubclasses(classes);
	
	create dict transient;
	dict.setMembership(Method);
	dict.addExternalKey(TimeStamp, null, true, false);			// Creation TimeStamp
	dict.addExternalKey(String, 64, false, true);		// Class Name
	dict.addExternalKey(String, 64, false, true);		// Method Name
	dict.endKeys(false);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isTestToBeCounted() or 
				(meth.name[1:1] = "v" and Capitals.pos(meth.name[2:1], 1) &gt; 0) do	
			if meth.cnGetModifiedTimeStamp() &lt; meth.creationTime then
				ts := meth.cnGetModifiedTimeStamp();
			else
				ts := meth.creationTime;
			endif;
			
			if not dontTestDates then
				if ts.date &lt; startDate or ts.date &gt; endDate then
					continue;
				endif;			
			endif;
			
			dict.putAtKey(ts, klass.name, meth.name, meth);
		endforeach;
	
	endforeach;
	
	iter := dict.createIterator;
	while iter.next(meth) do
		file.writeLine(meth.getSchemaType().name &amp; DELIM &amp; meth.name &amp; DELIM &amp; meth.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp; 
			meth.creationTime.time.String &amp; DELIM &amp; meth.cnGetModifiedTimeStamp().date.format("dd/MM/yyyy") &amp; DELIM &amp;
			meth.cnGetModifiedTimeStamp().time.String &amp; DELIM &amp; meth.getMethodCreator());	
	endwhile;
	
epilog

	delete file;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="getUserInputJiraItem" id="af420e85-0cd1-4865-9d9b-beb47c85f48e">
        <source>getUserInputJiraItem(pTitle:String; pInstruction:String; pDefaultValue:String; inputValue :String output;modalStatus : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2025	navbs1	Initial creation Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	inputFormObj	: CnEcUserInputForm;
begin
	create inputFormObj;
