    <JadeMethod name="setColorsFromController" id="3fe8bb56-46c4-407e-a0be-ac24290c7103">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);
	
	tmpBackColor	:= self.backColor;
	
	self.frmPrintOptions.backColor	:= tmpBackColor;
	self.grpQryDetails.backColor	:= tmpBackColor;
	self.grpUserQueries.backColor	:= tmpBackColor;
	
	self.lstQuery.backColor			:= self.colorControlBack;		// TFS 51086 navmd1 29/04/2021 JADE2020 Skin Fixes
	
	self.setColorsForEntryTable(self.tblQueryEnt);
	self.setColorsForTable(self.tblCriteria);
	self.setColorsForTable(self.tblResults);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="d2cd845c-99c2-44c9-9813-0b1702a287f3">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbArgument.style := 3;
	self.cmbAttr.style := 2;
	self.cmbBulkRelease.style := 3;
	self.cmbJRWReport.style := 2;
	self.cmbMeasure.style := 2;
	self.cmbOperator.style := 2;
	self.cmbReserveDetail.style := 3;
	self.cmbSelectorMode.style := 2;
	self.cmbTerminal.style := 2;


epilog

end;</source>
    </JadeMethod>
