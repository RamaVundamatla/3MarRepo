    <JadeMethod name="cnwdad1_ListOutstandingWork" id="59f9cbe5-e613-496c-a4a8-27207a355e26">
        <source>cnwdad1_ListOutstandingWork() protected;
// --------------------------------------------------------------------------------
// Created:		10 May 2006 by cnwdad1
//
// Purpose:		Searches for references to my global::cnwdad1() method, and produces
//				a printable list of those references, so that I know what work I have
//				yet to finish.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	METHOD_NAME		: String = "cnwdad1";			// The name of the method we're looking for.
	METHOD_CLASS	: String = "global";			// The class in which the method is implemented.
//	DOUBLE_QUOTE	: Character = 34.Character;		// A double-quote character (").

vars
	searchMethodObj	: Method;			// The method whose references we're looking for.
	refMethodObj	: Method;			// The method in which "searchMethodObj" is referenced (invoked).
	methodRefSet	: MethodSet;		// A set of the methods in which "searchMethodObj" is referenced (invoked).
	methodSource	: String;			// The reference method's source code.
	sourcePos		: Integer;			// The position within the method source where the method is called.
	referenceName	: String;			// The name of the class and method where "searchMethodObj" is referenced.
	lineOfCode		: String;			// The line of code where "errorMethod" is referenced.
	quotedLine		: String;			// Line of code enclosed in quotes ("?").
	lengthOfSource	: Integer;			// The length of the line of code where "searchMethodObj" is referenced.
	referenceCount	: Integer;			// The number of references to "searchMethodObj" that were found.

begin
	write "List of Darrell's uncompleted coding:";
	write "====================================";
	searchMethodObj	:=	GBaseSchema.getMethod(METHOD_NAME);	// Get the method in question from the schema Type (Class).
	create methodRefSet transient;							// Create a set for the references.
	searchMethodObj.getMethodRefs(methodRefSet);			// Get the set of references to the method.

	foreach refMethodObj in methodRefSet do
		referenceName	:=	refMethodObj.schemaType.schema.name &amp; "::" &amp; refMethodObj.qualifiedName();
		methodSource	:=	refMethodObj.getSource();

		sourcePos		:=	methodSource.pos(METHOD_CLASS &amp; "." &amp; METHOD_NAME, 1);

		// The method may be referenced more than once in this method, so we'll
		// keep looping until it is no longer found in the source code.

		while sourcePos &gt; 0 do
			// We'll get the length of the line of code by looking for the terminating semi-colon
			// at the end of the line of code.  If a semi-colon is used as a literal anywhere in
			// the line of code, then this will produce spurious results.  Hopefully, translatable
			// strings are used instead of literal values, in which case this will work okay.
			lengthOfSource	:=	methodSource.pos(";", sourcePos) - (sourcePos - 1);
			lineOfCode		:=	methodSource[sourcePos:lengthOfSource];
			quotedLine		:=	lineOfCode;

			referenceName	:=	referenceName &amp; CrLf &amp; Tab &amp; "(" &amp; sourcePos.cnEcNumberFormat() &amp; ") " &amp; quotedLine;

			referenceCount	:=	referenceCount + 1;
			sourcePos		:=	methodSource.pos(METHOD_CLASS &amp; "." &amp; METHOD_NAME, (sourcePos + lengthOfSource));
		endwhile;
		
		write referenceName;
	endforeach;
epilog
	delete methodRefSet;
	
	write CrLf &amp; referenceCount.String &amp; " references to " &amp; METHOD_CLASS &amp; "::" &amp; METHOD_NAME &amp; "() were found.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_List_Class_Features" id="308b4261-1b23-401d-b494-1a51eecec36d">
        <source>cnwdad1_List_Class_Features();
// --------------------------------------------------------------------------------
// Created:		02 MarchMay 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	typeObj			: Type;
	classObj		: Class;
	propertyObj		: Property;
	propertyDisplay	: String;
	accessType		: Character;
	propertyAccess	: String;
	propertyLength	: Integer;
	allMethods		: MethodNDict;
	methodObj		: Method;
	allConstants	: ConstantNDict;
	constantObj		: Constant;
	underline		: String;
	startTime		: Integer;
	featureNo		: Integer;

begin
	startTime	:=	app.clock();
	typeObj		:=	Schema;
	underline	:=	"Type is '" &amp; typeObj.name &amp; "'";
	write underline;
	underline.fillString("=");
	write underline;
	featureNo	:=	0;
	
	if not typeObj.isKindOf(PrimType) then
		write "Listing Properties...";
		classObj	:=	typeObj.schema.getClass(typeObj.name);
		
		foreach propertyObj in classObj.getProperties() do
			featureNo	:=	featureNo + 1;
			
			if propertyObj.getName() &lt;&gt; "_persistentImpRefs.name"
			and propertyObj.getName() &lt;&gt; "_transientImpRefs"
			then
				// First, add a row to the table for the property features.
		
				accessType	:=	propertyObj.access;
		
				if accessType = 0.Character then
					propertyAccess	:=	"Public";
				elseif accessType = 1.Character then
					propertyAccess	:=	"Read only";
				elseif accessType = 2.Character then
					propertyAccess	:=	"Protected";
				endif;
				
				propertyDisplay	:=	propertyObj.getName() &amp;
									"::" &amp; propertyObj.type.name &amp;
									", " &amp; propertyAccess;
									
				propertyLength	:=	propertyObj.getLength();
		
				if propertyObj.type.name = "String" then				
					if propertyLength = -1 then
						propertyDisplay	:=	propertyDisplay &amp; ", length = Maximum";
					else
						propertyDisplay	:=	propertyDisplay &amp; ", length = " &amp; (propertyLength - 1).String;
					endif;
				else
					propertyDisplay	:=	propertyDisplay &amp; ", length = " &amp; propertyLength.String;
				endif;
				
				write featureNo.padLeadingWith("0", 3) &amp; ". " &amp; propertyDisplay;
			endif;
		endforeach;
		
		write "";
	endif;
	
	write "Listing Methods...";
	create allMethods transient;
	typeObj.getMethods(allMethods);
	
	foreach methodObj in allMethods do
		featureNo	:=	featureNo + 1;
		write featureNo.padLeadingWith("0", 3) &amp; ". " &amp; methodObj.makeHeader();
	endforeach;
	
	write "";
	
	write "Listing Class Constants...";
	
	create allConstants transient;
	
	typeObj.getConstants(allConstants);
	
	foreach constantObj in allConstants do
		featureNo	:=	featureNo + 1;
		write featureNo.padLeadingWith("0", 3) &amp; ". " &amp; constantObj.name &amp; " (Type=" &amp; constantObj.type.name &amp; ", Value=" &amp; constantObj.getSource().trimBlanks() &amp; ")";
	endforeach;
	
	write "";
	write "Text...";
	write typeObj.text;
	write "";
	write "User Text...";
	write typeObj.userText;
epilog
	delete allMethods;
	delete allConstants;
	
	write CrLf &amp; "Class features listed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_List_JadeUserProfiles" id="c9775d09-e8a8-40ff-ab4c-944c26bd56d3">
        <source>cnwdad1_List_JadeUserProfiles();
// -----------------------------------------------------------------------------
// Created:		03 October 2001 by cnwdad1
