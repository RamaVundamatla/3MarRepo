    <JadeMethod name="tRoroVehiclePark" id="11801661-b1df-466d-a745-bdf5403a3891">
        <updating/>
        <source>tRoroVehiclePark() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2022	navlw1	Initial creation tfs 53172

*/
constants
	CargoId 	= "UA125121";
	CargoId2 	= "UA125122";
	CargoId3  	= "UA125123";
	Voyage 		= "UATRoroVoyage";
	Vessel 		= "LauraTestVessel";
vars
	ti ,
	ti2,
	ti3 				: CM_TrackedItem;
	terminal 			: CM_Terminal;
	cargoId,
	cargoId2,
	cargoId3        	: String;
	roroArea       	 	: CM_RoRoLaneArea;
	location 			: CM_LocationsController;
	planned				: Boolean;
	dateRecieved 		: TimeStamp;
	operator 			: CM_Operator;
	remarks				: String;
	auto 				: Boolean;
	ta	 				: CM_YardAllocation;
	ya 					: CM_YardAllocationsByCodeDict;
	yardAllArray		: CM_YardAllocationArray;
	voyage				: CM_Voyage;
	vessel				: CM_Vessel;
	stowage 			: CM_TITransaction;
	confirmRemarks,	
	cargoRemarks    	: String;
	queuedTask			: CM_RTQueueTask;
	dischargePort		: CM_Port;
	voyAlloc        	: CM_VoyageAllocation;
	firstLane,lastLane 	: CM_RoRoController;
begin
	app.setIsWebApp(true); // Need to execute our methods like we are a web app
	
	operator := app.myRoot.allOperators["LAUR"];

	terminal := app.myPassport.myTerminal;
	auto := terminal.getConfig(AutoPlanPreNotifications).Boolean;
	self.setTerminalConfig(AutoPlanPreNotifications, false);
	
	cargoId := CargoId;
	cargoId2 := CargoId2;
	cargoId3 := CargoId3;
	
	self.deleteTrackedItem(cargoId, false); // delete the tracked item if exists
	self.deleteTrackedItem(cargoId2, false); // delete the tracked item if exists
	self.deleteTrackedItem(cargoId3, false); // delete the tracked item if exists
	
	self.deleteVessel(Vessel);
	self.deleteVoyage(Voyage);
	self.deleteTerminalArea("ROROLane1");
		
	self.opts.purge();
	self.opts.addAssoc("Commodity", "GENL");
	
	// create the vessel and voyage
	vessel := addVesselCellular(Vessel,operator);
	self.assertTrueMsg(vessel &lt;&gt; null, "No Vessel Created");
	voyage := addVoyageWithContainerStructur(Voyage, Vessel, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, "No Voyage Created");
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	// Create the TrackItem one 
	self.opts.purge();
	self.opts.addAssoc("CargoType", TI_CargoType_Car);
	
	ti := self.addCargoForVoyage(voyage,CargoId);
	
	self.assertNotNullMsg(ti, "[Pre Test Validation] cargo item : " &amp; CargoId &amp; " does not exist therefore test cannot continue");
	remarks := "-43.4925628012391" &amp; "," &amp; "172.55940913916885"; // gps location
	
	// test one
	app.myTrxUA.trxRoroVehicleConfirm(ti,null,null,null,true,true,null,null,remarks,"UATUser01");
	self.assertNoTrxErrors();
	
	// check that the stowage confirmation transaction has the relevant data
	stowage := ti.getTransactionOfType(TRANS_TYPE_STOWAGE_CONFIRM);
	self.assertTrueMsg(stowage &lt;&gt; null, "No Stowage Transaction Created");
	confirmRemarks := stowage.getStowageRemarks();
	self.assertTrueMsg(confirmRemarks = "UATUser01", "No Stowage confirmed remarks");
	cargoRemarks := ti.remarksAdditional1;
	self.assertTrueMsg(cargoRemarks = remarks, "No cargo additional remarks");
	
	// Test Two Tracked_item_already_queued error check
	
	ti3 := self.addCargoForVoyage(voyage,CargoId3);
	self.assertNotNullMsg(ti3, "[Pre Test Validation] cargo item : " &amp; CargoId3 &amp; " does not exist therefore test cannot continue");
	
	// create the yard allocation
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,null,null,TI_CargoType_Car,false,false);
	
	// Create Roro Area
	roroArea := self.addROROArea("ROROLane1",7,60);
	assertNotNull(roroArea);	
	
	location :=roroArea.allLocationsControllers.first;
	firstLane := location.CM_RoRoController;
	
	self.moveQueued(ti3, firstLane);
	app.myTrxUA.trxRoroVehicleConfirm(ti3,null,null,null,true,true,null,null,remarks,"UATUser01");
	self.expectTrxError(Tracked_item_already_queued);
	self.assertNoTrxErrorsOrWarnings();
	
	// test Three Failed_auto_plan error check
	
	create yardAllArray transient;
	ya := app.myPassport.myTerminal.allYardAllocatonsByCode;
	beginTransaction;
	foreach ta in ya discreteLock do 
		if ta.isDisabled = false then
			yardAllArray.add(ta);
			ta.setPropertyValue(CM_YardAllocation::isDisabled.name, true);
		endif;
	endforeach;
	commitTransaction;
	
	ti2 := self.addCargoForVoyage(voyage,CargoId2);
	
	beginTransaction;
		ti2.setMyOperator(operator);
	commitTransaction;
	
	self.assertNotNullMsg(ti2, "[Pre Test Validation] cargo item : " &amp; CargoId2 &amp; " does not exist therefore test cannot continue");

	app.myTrxUA.trxRoroVehicleConfirm(ti2,null,null,null,true,true,null,null,null,null);
	self.expectTrxError(Failed_auto_plan);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	app.setIsWebApp(false); //We always want to set this to false
	self.setTerminalConfig(AutoPlanPreNotifications, auto);
	ya := app.myPassport.myTerminal.allYardAllocatonsByCode;
	// we need to enable the yard alocations so that othe tests do not fail
	beginTransaction;
	foreach ta in yardAllArray do
		ta.setPropertyValue(CM_YardAllocation::isDisabled.name, false);
	endforeach;
	commitTransaction;
	delete yardAllArray;
	self.deleteTerminalArea("ROROLane1");
end;</source>
    </JadeMethod>
    <JadeMethod name="tSourceLocationMaint" id="5a3b79b8-52f3-46ae-9b1d-36115bb43587">
        <source>tSourceLocationMaint();
// cnwns1
// cnwmc5
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2014	cnwdb2	Initial creation

*/
constants

	CODE_GROUP : String = "UT_Source";
	
vars

	realCodeGroup : CM_CodeGroup;
	
begin

	self.webServiceCall( CM_UnitTestAgent::wsSourceLocationMaint.name );
	
epilog
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_SourceLocation, CODE_GROUP];
	if realCodeGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteCodeGroupSrcLocTree(realCodeGroup, app.myPassport);
	endif; 
end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicleVisitMaint" id="c1c40de6-2259-4d89-bb78-c85032ab3d35">
        <updating/>
        <source>tVehicleVisitMaint() updating;
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwmc5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants

	CODE_GROUP 	: String = "UT_Source";
	PRENOTE		: String = "UTMC00001";
	BOOKING		: String = "UTBK00001";
	VOYAGE		: String = "UTMCVOY01";
	VESSEL		: String = "UTMCVES01";
	CARRIER		: String = "UTMC";
	DRIVER		: String = "MCDRIVER";
	RELREQ		: String = "UTRELMC1";
	
vars

	realCodeGroup 		: CM_CodeGroup;
	
	booking				: CM_BookingRef;
	ti					: CM_TrackedItem;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	carrier				: CM_Carrier;
	vessel				: CM_Vessel;
	driver				: CM_DriverDetails;
	br					: CM_BulkRelease;
	
	pin 				: String;
	carrierCode			: String;
	
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	allCarriers			: CM_CarrierByCodeDict;
	allVehicles			: CM_VehicleSet;
	allPINs				: StringArray;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteReleaseRequest(RELREQ);
	self.deleteContainer(PRENOTE);
	self.deleteBooking(BOOKING);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteCarrier(CARRIER);
	//self.vehicle
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create allPINs transient;
	create pinEmailAddresses transient;
	create allCarriers transient;
	create allVehicles transient;
	carrier := self.addCarrier(CARRIER, "UT MC Carrier", pinEmailAddresses, false, false, true, null);
	assertNotNull(carrier);
	allCarriers.add(carrier);
	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["UTMC"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
			if not opCrit1.allCarriers.includes(carrier1) then
				beginTransaction;
				opCrit1.allCarriers.add(carrier1);
				commitTransaction;
			endif;
			if not opCrit1.allCarriers.includes(carrier2) then
				beginTransaction;
				opCrit1.allCarriers.add(carrier2);
				commitTransaction;
			endif;
		endif;
	endforeach;
	//driver := self.createDriverDetails(DRIVER, allCarriers, allVehicles);
	vessel := self.addVesselCellular(VESSEL, operator);
	voyage := self.addVoyageWithContainerStructur(VOYAGE, VESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	booking := self.addBookingForContainer(BOOKING, operator, voyage, "NZAKL", "2200", "GENL");
	assertNotNull(booking);
	
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "Bob");
	self.opts.addAssoc("AuthorisedPerson", "John");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, PRENOTE);
	assertNotNull(ti);
	pin := ti.getPinNumber();
	allPINs.add(pin);
	
	br := self.addReleaseByTypeRequest(RELREQ, BR_TYPE_ROAD, TI_CargoType_Container, "2201");
	assertNotNull(ti);
	pin := br.getPinNumber();
	allPINs.add(pin);
	
	carrierCode := carrier.code;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsVehicleVisitMaint.name, allPINs, carrierCode, driver);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete allPINs;
	delete pinEmailAddresses;
	delete allCarriers;
	delete allVehicles;
end;
</source>
    </JadeMethod>
