    <JadeMethod name="displayExtraInfoForObj" id="17538cfc-f546-4408-9c52-c06518320eab">
        <source>displayExtraInfoForObj(_obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwrd1	Initial creation

*/


//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------
// 25/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
//--------------------------------------------------------------
vars
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
	dataContainer : CM_DataContainer;
	useNew : Boolean;
begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;

	if (not CM_Object.hasInstance(_obj)) then
		return;
	endif;

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
			
	if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then
		_obj.CM_Object.getExtraInfo(dataContainer);
		//self.getExtraInfoForObj(_obj.CM_Object, dataContainer);
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;

	
epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
	delete strArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="displaySchStatus" id="f7e2f89a-0434-4dcf-ae69-e67b26bab545">
        <source>displaySchStatus( _obj : Object) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Dec 2009	cnwrd1	Initial creation
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
begin
	return app.workOrderStatusEnumToString(	_obj.CM_Association.getValue().Integer );		//15.02.2023 navma1 #56561

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="3e3424a2-352b-4578-9b69-34be510b21b6">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 December 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	objArray 			: ObjectArray; 
	obj				: Object;
	voyWoToInclude 	: IntegerArray;		
	cargoWoToInclude: IntegerArray;	
	toDoWoToInclude : IntegerArray;		
begin	
	if _resultCollection.isEmpty then
		return;
	endif;
	
	create voyWoToInclude transient;	
	self.getVoyWOdtlTaskNos( voyWoToInclude );		
	
	create cargoWoToInclude transient;				
	self.getCargoWOdtlTaskNos( cargoWoToInclude );	

	create toDoWoToInclude transient;				
	self.getToDoWOdtlTasksNos( toDoWoToInclude );
	
	create objArray transient;
	
	_resultCollection.copy(objArray);
	
	self.tblData.rows := self.tblData.fixedRows;
	self.enquiryType := self.EnqType_WorkOrder;
	self.doHideSearcherClick();
	
	foreach obj in objArray do
		self.addRowToTable( obj.CM_WOTransaction.myWorkOrder , self.tblData,voyWoToInclude,cargoWoToInclude, toDoWoToInclude);
	endforeach;
epilog
	delete objArray;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayTable" id="304699e9-5b83-4ddd-9bc3-408b1dfacb25">
        <updating/>
        <source>displayTable()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Aug 2009	cnwmd1	Initial creation
25 Sep 2019 jlgka1  TFS 46742 PEL1 - Urgent Error Max Table Row Work Order
15 Aug 2022	navcs2 	Bug 54326: MTN - Work Order - Work Order can not searched if the Work Order ID is in lower case
16 Aug 2022	navcs2	Bug 54237: MTN - Work Order Maintenance - Lookup Work Order Type
15 dec 2022 navcs2  54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
10/03/2023	navcs2	ChangeRequest Task 57034:[57035]: EUP - Status bar to show work order count at Work order Enquiry Screen
17 Jun 2024 navlc30 ChangeRequest 64360: MTN - Multithreading For Work Order Enquiry Screen	
04 Jun 2025	navsp1	JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars

	tbl 		     	: CM_DataTable;
	workOrder 	     	: CM_WorkOrder;
	voyWoToInclude   	: IntegerArray;		//19 Jul 2018	NDL	TFS 39813
	cargoWoToInclude 	: IntegerArray;		//22 Aug 2018	NDL	TFS 40157
	toDoWoToInclude	 	: IntegerArray;		//15/12/2022    navcs2 #54698:[54264]
	transModeToInclude	: IntegerArray; 	//26/11/2024	navkc1 JIRA Story MTN-19092
	startAtText 	 	: String;
	iter 			 	: Iterator;
	idx 			 	: Integer; 			//jlgka1 TFS 46742
	allFilteredWODict	: CM_WorkOrderByIdDict;
	iterFilteredWo   	: Iterator;	
	form 			 	: CM_BaseForm;
	allFilteredWoDtl 	: CM_WorkOrderDtlArray;
	workOrderDtl     	: CM_WorkOrderDtl;
	taskType		 	: Integer;
	locReqByFromTS,
	sysReqByFromTS	 	: TimeStamp; 		//26/11/2024	navkc1 JIRA Story MTN-19092
	organisation	 	: CM_Organisation; 	//26/11/2024	navkc1 JIRA Story MTN-19092
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	tbl 	 		  := self.tblData;
	//23/06/2025	navkc1 JIRA MTN 34973
	tbl.clearAllData();
	//tbl.rows 		  := tbl.fixedRows;
	self.doNotableClear();
	
	//New way  20 Aug 2018	NDL	TFS 40249 - So we can do starts with searches
	create voyWoToInclude transient;
	self.getVoyWOdtlTaskNos( voyWoToInclude );
	
	//22 Aug 2018	NDL	TFS 40157
	create cargoWoToInclude transient;
	self.getCargoWOdtlTaskNos( cargoWoToInclude );
	
	create toDoWoToInclude transient;				//15/12/2022  navcs2 #54698:[54264]
	self.getToDoWOdtlTasksNos( toDoWoToInclude );	//15/12/2022  navcs2 #54698:[54264]
	
	create transModeToInclude transient; //26/11/2024	navkc1 JIRA Story MTN-19092
	self.getTransportModes(transModeToInclude); //26/11/2024	navkc1 JIRA Story MTN-19092
	
    locReqByFromTS := self.filterMskRequestedByFromTS;             //JIRA-34585
    
	//26/11/2024	navkc1 JIRA Story MTN-19092
	if locReqByFromTS.isValid() then
		sysReqByFromTS := self.localToSystemTime(locReqByFromTS);
	endif;
	
	organisation := self.cmbOrganisation.listObject.CM_Organisation; //26/11/2024	navkc1 JIRA Story MTN-19092
	
	//26/11/2024	navkc1 JIRA Story MTN-19092
	if sysReqByFromTS.isValid() and organisation &lt;&gt; null then
		iter := organisation.allWorkOrders.createIterator();
		workOrder := organisation.allWorkOrders.getAtKeyGeq(sysReqByFromTS);
		if workOrder &lt;&gt; null then
			iter.startAtObject(workOrder); 
		else
			return;
		endif;
	else
		iter 		:= self.myTerminal.allWorkOrders.createIterator;
		//startAtText := self.txtWorkOrderNum.text.toUpper;
		startAtText := self.filterWorkOrderNum.toUpper(); //13/06/2025	navkc1 JIRA MTN 35077
		
		if startAtText &lt;&gt; null then
			workOrder := self.myTerminal.allWorkOrders.getAtKeyGeq( startAtText );
			if workOrder &lt;&gt; null and workOrder.id[1:startAtText.length].toUpper = startAtText then  // 16/08/2022 NAVCS2 Bug 54326
				iter.startAtObject( workOrder );
			else
				//none matching
				return;
			endif;
		endif;
	endif;
	
	idx := 1;
	create allFilteredWODict transient; 			//17.06.2024 navlc30 #64360
	create allFilteredWoDtl transient;				//17.06.2024 navlc30 #64360	
	while iter.next( workOrder ) do
		if startAtText &lt;&gt; null then
			if workOrder.id[1:startAtText.length].toUpper &lt;&gt; startAtText then // 15/08/2022 NAVCS2 Bug 54326
				break;
			endif;
		endif;
		
		//if not self.includeObject( workOrder, voyWoToInclude, cargoWoToInclude, toDoWoToInclude) then  // 16/08/2022 navcs2 #54237 //15/12/2022  navcs2 #54698:[54264]
		if not self.includeObject( workOrder) then  // 16/08/2022 navcs2 #54237 //15/12/2022  navcs2 #54698:[54264] //JIRA-34585
			continue;
		endif;
		
		// to check
		//jlgka1 TFS 46742 --&gt;
		if idx &gt;= JadeTableRowLimit then		
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		//jlgka1 TFS 46742 &lt;--

		//populate Filtered WO collection
		allFilteredWODict.add(workOrder);																																//17.06.2024 navlc30 #64360
		//self.addRowToTable(workOrder, tbl,voyWoToInclude,cargoWoToInclude, toDoWoToInclude); // 16/08/2022 navcs2 #54237 //15/12/2022  navcs2 #54698:[54264]			//17.06.2024 navlc30 #64360
		idx := idx + 1;
	endwhile;
	
	form := self;																					//17.06.2024 navlc30 #64360	
	if self.isEnqType_WorkOrder then																//17.06.2024 navlc30 #64360																																																																
		
		//tbl.getDataAndDisplayRowsMultith(allFilteredWODict, true, form, true);
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, allFilteredWODict, true); //23/06/2025	navkc1 JIRA MTN 34973
		
	elseif self.isEnqType_Task then
		iterFilteredWo := allFilteredWODict.createIterator;
		while iterFilteredWo.next(workOrder) do
			//Populate Filtered WO Details Collection													
			foreach workOrderDtl in workOrder.allWoDtls do
				
				/* //26/11/2024	navkc1 JIRA Story MTN-19092
				taskType   := workOrderDtl.getWorkOrderTaskIdByClass();	
				
				if workOrderDtl.isKindOf(CM_WorkOrderVoyageDtl) then
					if not voyWoToInclude.includes(taskType) then
						continue;
					endif;
				elseif workOrderDtl.isKindOf(CM_WorkOrderToDoDtl) then									//#54698:[54264]
					if not toDoWoToInclude.includes(taskType) then
						continue;
					endif;
				else
					if not cargoWoToInclude.includes(taskType) then
						continue;
					endif;
				endif;
				*/
				
				//26/11/2024	navkc1 JIRA Story MTN-19092
				if not self.includeObjectWODtl(workOrderDtl, false) then    //JIRA-34585
					continue;
				endif;
				
				allFilteredWoDtl.add(workOrderDtl);
			endforeach; 
		endwhile;	
		
		
		//tbl.getDataAndDisplayRowsMultith(allFilteredWoDtl, true, form, true);
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, allFilteredWoDtl, true);	//23/06/2025	navkc1 JIRA MTN 34973
		
	endif;

	
	self.updateStatusBarCount();	//10.03.2023	navcs2 #57034:[57035]
	
epilog

	delete iter;
	delete voyWoToInclude;			 //19 Jul 2018	NDL	TFS 39813
	delete cargoWoToInclude;    	 //19.08.2022 #54237
	delete toDoWoToInclude;          //15/12/2022  navcs2 #54698:[54264]
	self.mousePointer := Window.MousePointer_Default;
	delete allFilteredWODict;		 //17.06.2024 navlc30 #64360
	delete iterFilteredWo;			 //17.06.2024 navlc30 #64360
	delete allFilteredWoDtl; 		 //17.06.2024 navlc30 #64360
	delete transModeToInclude;		//26/11/2024	navkc1 JIRA Story MTN-19092
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActionCargo" id="480729cb-42a1-4bb2-adbe-13708942f451">
        <source>doActionCargo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/


vars
	actionForm 		: YRD_WorkOrderAction;
	task 			: CM_WorkOrderDtl;
	selObj 			: Object;
	row 			: Integer;
begin
	
	row    := self.tblData.row;
	selObj := self.tblData.accessRow(row).itemObject;
	
	if self.isEnqType_WorkOrder then
		// shouldnt be in work order mode with this  menu option
		return;
		
	elseif self.isEnqType_Task() then
		
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_task), app.getErrorString(No_Task_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrderDtl) then
			task := selObj.CM_WorkOrderDtl;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
	endif;
	
	if task = null then
		return;
	endif;
	
	//29.09.2021 navma1 #51925
	if self.myTerminal.isUseYardJobsForCargoWo then
		actionForm := app.getForm(YRD_WorkOrderAction.name).YRD_WorkOrderAction;
		if actionForm = null then
			actionForm := app.loadForm(YRD_WorkOrderAction, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderAction;
		endif;
	endif;
	
	if actionForm = null then
		return;
	endif;
	
	actionForm.centreWindow;
	actionForm.setMyTerminal(self.myTerminal);
	actionForm.setWorkOrderTask( task );
	actionForm.showModal();
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doActionTask" id="02e1af92-a4ef-4da5-bf40-ac74a4082ea9">
        <source>doActionTask( _task : CM_WorkOrderDtl input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/01/2010	cnwrd1	Initial creation
28/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/
vars
	
begin
	if _task = null then
		return;
	endif;
	
	if _task.isKindOf(CM_WorkOrderTIDtl) then
		self.doActionTaskForCargo(_task);
	elseif _task.isKindOf(CM_WorkOrderVoyageDtl) then
		self.doActionTaskForVoyage(_task);
	elseif _task.isKindOf(CM_WorkOrderToDoDtl) then
		self.doActionTaskForToDo(_task.CM_WorkOrderToDoDtl);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskForCargo" id="fce79e07-6453-4457-bdc3-845d33240ad8">
        <source>doActionTaskForCargo(_task : CM_WorkOrderDtl input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 29/10/2021   navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 14/07/2022	navcs2		ChangeRequest 53932: MTN - Jobs Changes
// 20/01/2023	navcs2		ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
// 13/03/2023 	navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
// 13 Sep 2023 	navhl20 	ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
// 27 Nov 2023  navhl20 	ChangeRequest 61506: EUP | Ship Operations in DD - [54176.010] - [Release] Work Order Detail Grouping
// 18 Dec 2023  navhl20 	ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
// 03 Jan 2023 	navhl20 	Defect 61895: EUP - Ship Operations - Release Ship WOs are not grouping based on the Cargo types.
// 02 May 2024  navhl20 	ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
vars
	result 			: Integer;
	woActionIF 		: CMIF_WorkOrderAction;
	realJob			: CM_Job;
	grpMethod		: CM_WorkOrderJobGroupMethod;
	grpData			: Any;
begin
	
	if _task = null then
		return;
	endif;
	
	if not _task.isKindOf(CM_WorkOrderTIDtl) then
		return;
	endif;
	
	if self.hasVasSubscription then														//13.9.2023 navhl20 #60063
		grpData := self.isWorkOrderNeedGrpMethod(_task);											//03.05.2024 navhl20 #63971
		if grpData.isKindOf(CM_WorkOrderJobGroupMethod) then
			grpMethod := grpData.CM_WorkOrderJobGroupMethod;
		elseif grpData.isKindOf(Integer) and grpData.Integer = MsgBox_Return_Cancel then
			return;
		endif;
	endif;
		
	create woActionIF transient;
	
	woActionIF.myWorkOrderDtl 		 := _task;
	woActionIF.numberFromKnownCargo  := _task.CM_WorkOrderTIDtl.allSelectedTIs.size;
	woActionIF.useYardJobs			 := self.myTerminal.isUseYardJobsForCargoWo();		//12.04.2023 navma1 #57569:[57570]
	app.mousePointer := MousePointer_HourGlass;
	
	while true do
		//app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 			//12.04.2023 navma1 #57569:[57570]
		//app.myTrxUA.trxWorkOrderAction(woActionIF,realJob, app.myPassport);			//19.9.2023 navhl20 #60063 
		app.myTrxUA.trxWorkOrderAction(woActionIF,realJob,grpMethod, app.myPassport);	//19.9.2023 navhl20 #60063
		
		if app.myPassport.trxCompletedOK then
			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
	delete woActionIF;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskForToDo" id="a0aafa4d-73c1-40e7-b8b0-8bb62fff729e">
        <source>doActionTaskForToDo(_wodtl: CM_WorkOrderToDoDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023	navcs2	Initial creation
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
19 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
*/

vars
	result 			: Integer;
	woActionIF 		: CMIF_WorkOrderAction;
	realJob			: CM_Job;
begin
	
	if _wodtl = null then
		return;
	endif;
	
	create woActionIF transient;
	
	woActionIF.myWorkOrderDtl 		 := _wodtl;
	
	while true do
		//app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 			//12.04.2023 navma1 #57569:[57570]
		//app.myTrxUA.trxWorkOrderAction(woActionIF,realJob, app.myPassport);			//19.9.2023 navhl20 #60063 
		app.myTrxUA.trxWorkOrderAction(woActionIF,realJob,null, app.myPassport);		//19.9.2023 navhl20 #60063 
		
		if app.myPassport.trxCompletedOK then
			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
	delete woActionIF;
end;</source>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskForVoyage" id="2ce10370-2f8a-421c-8a76-662e3b3963a6">
        <source>doActionTaskForVoyage(_task : CM_WorkOrderDtl) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	result : Integer;
	woActionIF : CMIF_WorkOrderAction;

begin
	if _task = null then
		return;
	endif;
	
	create woActionIF transient;
	woActionIF.myWorkOrderDtl := _task;
	
	while true do
		app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete woActionIF;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="doApproveCreditCheck" id="8646afe2-e336-4f3c-9345-5c700b16ae31">
        <source>doApproveCreditCheck(_wo : CM_WorkOrder);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
24/10/2018  cnwma1  ChangeRequest 41495: PEL1 - SAP Integration - Override statuses
28/02/2019  cnwma1	Bug 43514: PEL1 - SAP Credit check approval option
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	wo 			: CM_WorkOrder;
	theReturn   : Integer;
begin
		
	wo := _wo;
	while true do
		app.myTrxUA.trxUpdateWOApproved(wo,true ,null,null,app.myPassport);		//02.05.2024 navhl20 #63971
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Confirmation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		return;
	endwhile;	

	
epilog
end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboBOL" id="c4a16f4f-303d-4ed4-bb0e-d45fb4b53659">
        <source>doBuildComboBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	voyage 		: CM_Voyage;
	bol			: CM_BOL;
	comboBOL 	: CMUI_ComboBox;
	
begin
	
	comboBOL := self.cmbBOL;
	
	comboBOL.clear();
	comboBOL.sorted := true;
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if voyage = null then
	
	else
		foreach bol in voyage.allBOLInByTypeStatusNumDT discreteLock do
			comboBOL.addItemObject(bol.number, bol);
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboOperator" id="639a6f43-8320-4b6b-aabb-0e61ffd7d317">
        <source>doBuildComboOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	comboOperator 	: CMUI_ComboOperator;
	voyage			: CM_Voyage;
begin
	
	comboOperator := self.cmbOperator;
	
	comboOperator.clear();
	comboOperator.sorted := true;
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	comboOperator.resetCollectionForVoyage(voyage);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboToDoTaskDesc" id="82245513-0e02-4634-9198-856614ad399b">
        <source>doBuildComboToDoTaskDesc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	toDoTaskDesc	: CM_ToDoTaskDesc;
	toDoTaskCombo 	: CMUI_ComboBox;
	root			: CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
begin
	toDoTaskCombo := self.cmbToDoTask;
	
	toDoTaskCombo.clear();
	toDoTaskCombo.sorted := true;
	
	create taskDict transient;
	
	app.myPassport.myUser.getToDoTaskDescList( taskDict,null,self.myTerminal, null);
	root := app.myRoot;
	
	foreach toDoTaskDesc in root.allToDoTaskDescriptions discreteLock do
		if toDoTaskDesc.type = TODO_TYPE_GROUP_CARGOGROUP or toDoTaskDesc.type = TODO_TYPE_GROUP_TI then
			taskDict.tryAdd(toDoTaskDesc);
		endif;
	endforeach;
	
	foreach toDoTaskDesc in taskDict do
		toDoTaskCombo.addItemObject(toDoTaskDesc.getFullName(), toDoTaskDesc);
	endforeach;
	
	toDoTaskCombo.sorted := false;
	toDoTaskCombo.addItemAt("",1);
epilog
	delete taskDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTrain" id="cafe3e81-3c76-4b16-8d3d-87216a43372f">
        <source>doBuildComboTrain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	train				: CM_Train;
	comboTrain	 		: CMUI_ComboBox;
	terminal			: CM_Terminal;
	arrivalDateLocalStr : String;
begin
	
	comboTrain := self.cmbTrain;
	
	comboTrain.clear();
	comboTrain.sorted := true;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		
	else
		foreach train in terminal.allTrainsOnTerminal discreteLock do
			arrivalDateLocalStr := app.systemToLocalTime(train.arrivalDT).date().asStringJMT();
			if arrivalDateLocalStr = null then
				arrivalDateLocalStr := "n/a";
			endif;
			comboTrain.addItemObject(train.code &amp; " (" &amp; arrivalDateLocalStr &amp; ")", train);			
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVehicleVisit" id="02dc9147-e75d-4d9c-88af-121e39e01de4">
        <source>doBuildComboVehicleVisit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	allVVRs				: CM_VehicleVisitRecordSet;
	vvr					: CM_VehicleVisitRecord;
	comboVehicleVisit	: CMUI_ComboBox;
	terminal			: CM_Terminal;
begin
	
	comboVehicleVisit := self.cmbVehicleVisit;
	
	comboVehicleVisit.clear();
	comboVehicleVisit.sorted := true;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		
	else
		create allVVRs transient;
		terminal.getAllCurrentVehicleVisits(allVVRs);
		
		foreach vvr in allVVRs do
			comboVehicleVisit.addItemObject(vvr.visitNumber &amp; " - " &amp; vvr.regNumber, vvr);
		endforeach;
		
	endif;
	
epilog
	delete allVVRs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyage" id="3668031a-fcb2-46d1-9da3-6a638c2798e0">
        <source>doBuildComboVoyage();

/*

Purpose:		TFS 41026	

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2018	jlgab1	Initial creation
26/11/2024			navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability
*/

vars
	voyage 			: CM_Voyage;
	vessel			: CM_Vessel;
	voyageCombo 	: CMUI_ComboBox;
	terminal		: CM_Terminal;
begin
	//26/11/2024	navkc1 JIRA Story MTN-19092
	voyageCombo := self.cmbVoyage;
	
	voyageCombo.clear();
	voyageCombo.sorted := true;
	
	//26/11/2024	navkc1 JIRA Story MTN-19092
	vessel := self.cmbVessel.listObject.CM_Vessel; 
	
	//26/11/2024	navkc1 JIRA Story MTN-19092
	terminal := self.myTerminal;
	
	//26/11/2024	navkc1 JIRA Story MTN-19092
	if vessel = null then
		foreach voyage in terminal.allVoyagesByCode do
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.myHMSVoyageData = null then
				continue;
			endif;
			if voyage.archived then
				continue;
			endif;
			voyageCombo.addItemObject(voyage.getId(), voyage);
		endforeach;
	else
		//26/11/2024	navkc1 JIRA Story MTN-19092
		foreach voyage in vessel.allVoyagesByTermCodeArrival discreteLock do
			if voyage.myTerminal &lt;&gt; terminal then
				continue;
			endif;
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.myHMSVoyageData = null then
				continue;
			endif;
			if voyage.archived then
				continue;
			endif;
			voyageCombo.addItemObject(voyage.getId(), voyage);
		endforeach;
	endif;
	
	voyageCombo.sorted := false;
	voyageCombo.addItemAt("",1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboWagon" id="11af922f-a600-4917-93fd-f7f4b7c4579c">
        <source>doBuildComboWagon();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	train				: CM_Train;
	comboWagon	 		: CMUI_ComboBox;
	wagon 				: CM_Wagon;
	
begin
	
	comboWagon := self.cmbWagon;
	
	comboWagon.clear();
	comboWagon.sorted := true;
	
	train := self.cmbTrain.listObject.CM_Train;
	
	if train = null then
		
	else
		foreach wagon in train.allWagonsByIdInward discreteLock do
			comboWagon.addItemObject(wagon.id, wagon);
		endforeach;
		
		foreach wagon in train.allWagonsByIdOutward discreteLock do
			// Prevent adding the same wagon twice
			if comboWagon.findObject(wagon) = -1 then
				comboWagon.addItemObject(wagon.id, wagon);
			endif;
		endforeach;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCashCreateReceipt" id="5c210a96-6b4f-47d4-afa0-96edddd1e7a7">
        <updating/>
        <source>doCashCreateReceipt() updating;
/*

Purpose:			TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation
14 Nov       2018   cnwma1  Bug 41993: PEL1 - IMSR Cash receipt
*/

vars
	theReturn : Integer;
	selObj 		: Object;
	workOrder 	: CM_WorkOrder;
	controller : CMIF_ProformaWOController;
begin

	selObj := self.tblData.allSelectedObjects.first;
	if selObj = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	workOrder := selObj.CM_WorkOrder;
	
	create controller transient;	
	
	controller.initialise(workOrder);
	
	
	while true do
		app.myTrxCA.trxCreateProformaPaymentWO(controller,"",  app.myPassport);
		if app.myPassport.trxCompletedOK 
		or app.myPassport.allErrors.isEmpty() then // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Work Orders", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	
	
	
	
	if not workOrder.allCashReceipts.isEmpty() then
		//14.11.2018 cnwma1 TFS #41993
		if workOrder.isWorkOrderForIMSR then
			//This will be used to send SAP Request if there is configuation error and the user click on create cash Receipt on the work order screen
			app.myTrxCA.trxCreateSAPRequest(workOrder,false,app.myPassport);
		endif;
		//14.11.2018 cnwma1 TFS #41993
		app.msgBox(app.getErrorString1(Success, self.mnuCashCreateReceipt.caption),app.getErrorString(Information),MsgBox_OK_Only);
	
	else
		// TFS 45953
		app.msgBox(app.getErrorString1(Cash_recei_not_creat_chXck_deb, controller.getDescription()),app.getErrorString(Information),MsgBox_OK_Only);
		
	endif;
	
	
epilog
	if controller&lt;&gt; null then
		controller.purger();
		delete controller;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="doCashDeleteReceipt" id="a0a1987a-788e-4a68-a717-d7c7916deea9">
        <updating/>
        <source>doCashDeleteReceipt() updating;
/*

Purpose:			TFS 39721

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2018	jlgab1	Initial creation

*/

vars

	theReturn : Integer;
	selObj 		: Object;
	workOrder 	: CM_WorkOrder;
	cr : CM_CashReceipt;
begin

	selObj := self.tblData.allSelectedObjects.first;
	if selObj = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	workOrder := selObj.CM_WorkOrder;
	cr := workOrder.allCashReceipts.first();
	
	theReturn := app.msgBox(app.getErrorString1(Please_confirm_deletion, 
					app.getErrorString(Cash_receipt)),
					app.getErrorString(Confirmation),MsgBox_OK_Cancel);
	if theReturn &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	// TFS 39349 MULTI CASH RECEIPTS
	foreach cr in workOrder.allCashReceipts 	discreteLock do
		while true do
			app.myTrxDA.trxDeleteCashReceipt(cr);
			if app.myPassport.trxCompletedOK 
			or app.myPassport.allErrorWarnings.isEmpty() then // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Work Orders", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endforeach;
	
	
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="doCashShowInvoices" id="862487aa-86eb-4cb2-b326-b3247b695547">
        <source>doCashShowInvoices();
/*

Purpose:			TFS 39349

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation

*/

vars


	selObj 		: Object;
	workOrder 	: CM_WorkOrder;
	form : Form;
	debtorNode : CM_DebtorNode;
	debtor : CM_Debtor;

	sch : Schema;
	formClass, assistClass : Class;
	mth : Method;
	who : String;
	whn : TimeStamp;
	controller : CMIF_ProformaWOController;
begin

		
	sch := rootSchema.getSchema("InvoiceSchema");
	formClass := sch.getClass("INV_ListInvoices");
	assistClass := sch.getClass("INV_Assistant");


	form := app.getForm(formClass.name);
	if form = null then
		form := app.loadForm(formClass, assistClass, false, false, false, self.myTerminal, null);
	endif;
	

	selObj := self.tblData.allSelectedObjects.first;
	if selObj = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	workOrder := selObj.CM_WorkOrder;

	if workOrder.allInvoices.isEmpty() then
		return;
	endif;	
	
	if form &lt;&gt; null then
		form.setPropertyValue("myCurrentWorkOrder",workOrder);
		form.show;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCashShowReceipts" id="2ed1cf68-b90e-4b69-9108-8ce3b59d1db3">
        <source>doCashShowReceipts();
/*

