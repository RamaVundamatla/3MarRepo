    <JadeMethod name="addToTable" id="3dae814d-b564-46cd-8c6d-98dd07a865f2">
        <source>addToTable(_deck : CM_DeckVessel);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars

	newRow : Integer;
begin
	if _deck = null then
		return;
	endif;
	
	newRow:=self.tblDecks.rows+1;
	self.tblDecks.rows:=newRow;
	if _deck.isKindOf(CM_DeckVesselSub) then
		self.tblDecks.accessRow(newRow).backColor:=LightSkyBlue;
	else
		self.tblDecks.accessRow(newRow).backColor:=SkyBlue;
	endif;
	self.tblDecks.accessCell(newRow,1).text:= _deck.code;
	self.tblDecks.accessCell(newRow,2).text:=  _deck.code;
	self.tblDecks.accessRow(newRow).itemObject:=_deck;
	
epilog

end;</source>
        <Parameter name="_deck" type="CM_DeckVessel"/>
    </JadeMethod>
