        <controlMethod name="CM_Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblProperties_keyDown( table : Table input; keyCode : Integer io; shift : Integer ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
22 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if shift = null then			// not control or alt or shift pressed
		self.tblProperties.doSearch( keyCode.Character.display, 1 );
	endif;
	
epilog
	
end;
