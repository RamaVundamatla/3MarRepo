        <Parameter name="_groupSupervisorUser" type="String"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_custRemarks" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
