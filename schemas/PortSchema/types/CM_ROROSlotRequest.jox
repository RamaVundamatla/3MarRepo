    <JadeMethod name="getAllUnworkedTIs" id="6cb4b41b-adfc-40c2-86a7-f2cfe1e6830b">
        <source>getAllUnworkedTIs(_theTIs: CM_TIArray input);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars

begin
	

	if self.getAttrIsBackend() then 
		if self.mySlotRequestForward &lt;&gt; null then
			self.mySlotRequestForward.getAllUnworkedTIs(_theTIs);
		endif;
	else
		inheritMethod(_theTIs);
	endif;


end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
