<GUIClass name="JSSFMFileBrowserChildForm" id="87961aaf-c6e1-4248-918a-880fafcabac6">
    <superclass name="JSSFMFileBrowserForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="doFormLoad" id="2e363dc9-b01a-4322-a916-421574c85e80">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form load event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	mnuFile.visible					:=	false;
	mnuPrefs.visible				:=	false;
	mnuView.visible					:=	false;
	mnuFileChunkSeparator.visible	:=	true;
	mnuFileChunkSize.visible		:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
