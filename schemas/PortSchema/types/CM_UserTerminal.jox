    <JadeMethod name="addNewReport" id="d3e2d7ef-1487-43ae-bb0b-f50301fb5c3d">
        <source>addNewReport(_qryReport : CM_QryReport);
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     Assumes already in trx state
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myReportMenuRoot = null then
		return;
	endif;
	
	if self.canDoReport(_qryReport.menuId) then
		_qryReport.addToUserMenuRoot(self.myReportMenuRoot);
	endif;

end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="canDo" id="2b15f6dc-5d00-4354-bf81-c941e98be39e">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _doWhat &gt; Mod_BaseView then
		// belts and braces - should never happen
		return false;
	endif;
	
	//if app.isSpecial() then
	if app.isSpecial() and app.getMyUser() = self.myUser then
		return true;
	endif;
	
	if self.mySecurityRole = null then
		return false;
	endif;

	return self.mySecurityRole.canDo(_doWhat);
	
end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoReport" id="d2c3cf8d-2f3a-4310-ac12-5df033c36672">
        <source>canDoReport(_rptId : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
//	if app.isSpecial() then
		// Makes it too difficult to update security roles successfully.
//		return true;
//	endif;
	
	if self.mySecurityRole = null then
		return false;
	endif;

	return self.mySecurityRole.allQryReports.includesKey(_rptId);	
	
end;</source>
        <Parameter name="_rptId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkNavMenuAgainstPermissions" id="45e61f71-c96a-4a3b-9420-516eb5bd11ea">
        <source>checkNavMenuAgainstPermissions(_resetPictures : Boolean);
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     Don't even look at this method - you'll break it...
//			 
// ----------   ----------  --------------------------------------------------
vars
	newUserItem,
	userItem		: CM_MenuUserItem;
	menuHdr			: CM_MenuUserHdr;
	userSysItem,
	sysItem			: CM_MenuItem;
	sysDtl			: CM_MenuDtl;
	sysDict			: CM_MenuItemByTypeMenuIdDict;
	user			: CM_User;
	term			: CM_Terminal;
	isSiteLicense,
	isLicensed,
	tmpCanDo,
	found			: Boolean;
	hdrSet			: CM_MenuEntitySet;
	licenseNum		: Integer;
	tmpRoot			: CM_Root;
	tmpMenuRoot		: CM_MenuRootUserTerminal;

begin

	tmpRoot := app.myRoot;
	sysDict := tmpRoot.myMenuRoot.allMenuItems;
	user := self.myUser;
	term := self.getRealTerminal;
	tmpMenuRoot	:= self.myMenuRoot;
	if tmpMenuRoot = null then
		return;
	endif;
	if _resetPictures then
		tmpMenuRoot.resetPictures();
	endif;
	
	isSiteLicense := tmpRoot.canDo(PmSite);

	create hdrSet transient;
	//delete items for which we no longer have permission
	foreach userItem in tmpMenuRoot.allMenuUserItemsWithAMenuItem do
		//userItem.resetPictures(); - deleting these so just do later one for found ones
		if (not CM_MenuUserDtl.hasInstance(userItem)) then
			continue;
		endif;
		
		sysItem := userItem.CM_MenuUserDtl.myMenuDtl;
		if sysItem = null then
			delete userItem;
			continue;
		endif;
		
		if _resetPictures then
			userItem.resetPictures();
		endif;
		
		if CM_MenuDtlNav.hasInstance(sysItem) and
		   (not sysItem.CM_MenuDtlNav.allChildValues.isEmpty) then
		
			isLicensed := false;
			foreach licenseNum in sysItem.CM_MenuDtlNav.allChildValues do
				if isSiteLicense then
					isLicensed := tmpRoot.canDo(licenseNum);
				else
					isLicensed := term.canDo(licenseNum);
				endif;
				if isLicensed then
					break;
				endif;
			endforeach;

			if (not isLicensed) then
				delete userItem;
				continue;
			endif;
		
			/*
			licenseNum := sysItem.CM_MenuDtlNav.childValue;
			if licenseNum &gt; 0 then
				if isSiteLicense then
					tmpCanDo := tmpRoot.canDo(licenseNum);
				else
					tmpCanDo := term.canDo(licenseNum);
				endif;
				
				if (not tmpCanDo) then
					delete userItem;
					continue;
				endif;
			endif;
			*/
		endif;
		
		if (not user.canDo(term, sysItem.constantValue)) then
			delete userItem;
			continue;
		endif;
	endforeach;

	//add items for which we now have permission, but did not previously
	foreach sysItem in sysDict do
		//if sysItem.isKindOf(CM_MenuDtl) then
		if CM_MenuDtl.hasInstance(sysItem) then

			if CM_MenuDtlNav.hasInstance(sysItem) and
			   (not sysItem.CM_MenuDtlNav.allChildValues.isEmpty) then
				tmpCanDo := false;
				foreach licenseNum in sysItem.CM_MenuDtlNav.allChildValues do
					if isSiteLicense then
						tmpCanDo := tmpRoot.canDo(licenseNum);
					else
						tmpCanDo := term.canDo(licenseNum);
					endif;
					if tmpCanDo then
						break;
					endif;
				endforeach;

				if (not tmpCanDo) then
					userItem := tmpMenuRoot.allMenuUserItemsWithAMenuItem[sysItem];
					delete userItem;
					continue;
				endif;

				/*				
				licenseNum := sysItem.CM_MenuDtlNav.childValue;
				if licenseNum &gt; 0 then
					if isSiteLicense then
						tmpCanDo := tmpRoot.canDo(licenseNum);
					else
						tmpCanDo := term.canDo(licenseNum);
					endif;
					if (not tmpCanDo) then
						userItem := tmpMenuRoot.allMenuUserItemsWithAMenuItem[sysItem];
						delete userItem;
						continue;
					endif;
				endif;
				*/
			endif;

			if user.canDo(term, sysItem.constantValue) then
				userItem := tmpMenuRoot.allMenuUserItemsWithAMenuItem[sysItem];
				if userItem = null then
					sysItem.CM_MenuDtl.addToUserMenuRoot(tmpMenuRoot);	
				endif;
			endif;
		endif;
	endforeach;

	//delete headers that have no children
	foreach userItem in tmpMenuRoot.allMenuUserItemsWithAMenuItem do
		//if userItem.isKindOf(CM_MenuUserHdr) then
		if CM_MenuUserHdr.hasInstance(userItem) then
			if (not userItem.CM_MenuUserHdr.hasDtlChildren) then
				hdrSet.add(userItem);
				continue;
			endif;
		endif;

		if _resetPictures then
			userItem.resetPictures();
		endif;

	endforeach;
	
	hdrSet.purge();
	
epilog
	delete hdrSet;
end;</source>
        <Parameter name="_resetPictures" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkReportMenuAgainstSecurity" id="d3e26b47-cfea-4acc-a382-6d85b9eae9cd">
        <source>checkReportMenuAgainstSecurity();
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     Assumes already in trx state
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Nov 2015	cnwkpd1	PAR #37128 - JMTRelease application performance
20 May 2021	navmd1	TFS 51190 Handle crap data a little better
	
*/

vars
	newUserItem,
	userQryReport,
	userItem		: CM_MenuUserItem;
	menuHdr			: CM_MenuUserHdr;
	menuItem		: CM_MenuItem;
	qryReport		: CM_QryReport;
	sysDict			: CM_MenuItemByTypeMenuIdDict;
	hdrSet			: CM_MenuEntitySet;
	
begin
	create hdrSet transient;
	sysDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	if self.myReportMenuRoot = null then
		return;
	endif;
	//delete items for which we no longer have permission
	foreach userItem in self.myReportMenuRoot.allMenuUserItemsWithAMenuItem do
		if userItem.isKindOf(CM_MenuUserDtl) then
			qryReport := userItem.CM_MenuUserDtl.myMenuDtl.CM_QryReport;
			if qryReport = null then
				continue;
			endif;
			
			if not self.canDoReport(qryReport.menuId) then
				delete userItem;
			endif;
		elseif userItem.isKindOf(CM_MenuUserReport) then																	// TFS 51190
			// Don't show templates that have been deleted and are still referenced in the system default (somehow)			// TFS 51190
			if userItem.CM_MenuUserReport.myQryReport = null and userItem.CM_MenuUserReport.myReportTemplate = null then	// TFS 51190
				delete userItem;																							// TFS 51190
			endif;																											// TFS 51190
		endif;
	endforeach;
	//add items for which we no have permission, but did not previously
	foreach menuItem in sysDict do
		if menuItem.isKindOf(CM_QryReport) then
			qryReport := menuItem.CM_QryReport;
			if self.canDoReport(qryReport.menuId) then
				// Do we already have access?
				userQryReport := self.myReportMenuRoot.allMenuUserItemsWithAMenuItem[qryReport];
				
				// If not, then add it
				if userQryReport = null then
					qryReport.addToUserMenuRoot(self.myReportMenuRoot);
				endif;
			endif;
		endif;
	endforeach;
	//delete headers that have no children
	foreach userItem in self.myReportMenuRoot.allMenuUserItemsWithAMenuItem do
		if CM_MenuUserHdr.hasInstance(userItem) and 
		   (not userItem.CM_MenuUserHdr.hasDtlChildren) then
		   if userItem.isUserDefinedReportsHeader() then	//25 Nov 2015	NDL	Par 36846
				continue;
		   endif;
			hdrSet.add(userItem);
		endif;
	endforeach;
	
	hdrSet.purge();
		
epilog
	delete hdrSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearMenu" id="3dad2063-1bce-44b6-8faa-2f3caee79816">
        <source>clearMenu();
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);
	if self.myMenuRoot &lt;&gt; null then
		self.myMenuRoot.allChildren.purge;
	endif;

end;</source>
