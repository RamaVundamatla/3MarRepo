    <JadeMethod name="setComboValues" id="f2dda358-14f4-48ed-9b2d-a0dfab040639">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:	21 May 2008 By Graeme Black cnwgb1 PAR 16415
// Creates the items for the "equal to"/"not equal to" combo
// And if there is a current item, select it. (i.e. user clicked on selector line)
// ---------------------------------------------------------------------------
vars
	selected : Integer;
begin
	_combo.clear();
	_combo.addItem("20");
	_combo.addItem("30");
	_combo.addItem("40");
	_combo.addItem("45");
	_combo.addItem("53");
	
	
	selected := 0;
	if _queryOperator &lt;&gt; null then
		if _queryOperator.isKindOf(CM_QIntegerLookupEqual) then
			selected := _queryOperator.CM_QIntegerLookupEqual.searchValue;
		elseif _queryOperator.isKindOf(CM_QIntegerLookupNotEqual) then
			selected := _queryOperator.CM_QIntegerLookupNotEqual.searchValue;
		endif;
	endif;
	if selected = 0 then
		selected := 20;
	endif;
	_combo.text := selected.String;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="118a214e-997d-4d34-af1b-24750faf83f8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:	22 May 2008 By Graeme Black cnwgb1 PAR 16415
// Creates the checkbox/value table in the "is one of" multi-select combo
// ---------------------------------------------------------------------------
vars
	lengthArray : IntegerArray;
	length : Integer;
	idx : Integer;
begin
	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create lengthArray transient;
	lengthArray.add(20);
	lengthArray.add(30);
	lengthArray.add(40);
	lengthArray.add(45);
	lengthArray.add(53);
	
	foreach length in lengthArray do
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(length) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; length.String);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; length.String);	
		endif;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;
	
epilog
	delete lengthArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="223b3154-3ed6-410a-997a-b04196a9a854">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:	22 May 2008 By Graeme Black cnwgb1 PAR 16415
// Retrieves an array of lengths checked in the "is one of" multi-select combo
// ---------------------------------------------------------------------------
vars
	chkString	: String;
	lenString	: String;
	numRows 	: Integer;
	idx			: Integer;
	lenArray	: IntegerArray;

begin

	create lenArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		chkString := _tbl.accessCell(idx, 1).text;
		if chkString = TableCheckBox_Selected then
			lenString := _tbl.accessCell(idx, 2).text;
			lenArray.add(lenString.Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(lenArray);

epilog
	delete lenArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="9abe5f3d-76d3-4b7d-ba5c-6b26bb033488">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/10/2019	jlgdap1		Initial creation TFS 46869 STWO Container Length Incorrect in Selector Query
//
vars
	int : Integer;
	rtnVal : String;
	inputStr, str : String;
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnVal := rtnVal &amp; int.String &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal :=rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		inputStr := _value.String;
		create strArray transient;
		create intArray transient;
		inputStr.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			intArray.add(str.Integer);
		endforeach;
		return intArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
