    </JadeMethod>
    <JadeMethod name="tResourceType" id="f835cff5-505f-4d4a-9c92-be383606fc9c">
        <source>tResourceType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/05/2014 cnwma1	Initial creation
*/

constants
	CNTR1 ="APL111";
	CNTR2 = "APL222";
vars
	 resourceType : CM_ResourceType;
	 toDoTask     : CM_ToDoTaskDescBySortKey;
	 toDoTaskDesc :CM_ToDoTaskDesc ;
	 ti1,ti2      : CM_TrackedItem;
	 tiSet		  : CM_TISet;
	 tiTask1 : CM_ToDoTask;
	 tiTask2 : CM_ToDoTask;
	 
begin


	deleteContainer(CNTR1);
	deleteContainer(CNTR2);
	//## Add ToDo Task Description
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["UTMA1"];
	deleteToDoTaskDescription(toDoTaskDesc);
	toDoTaskDesc := self.createToDoTaskDesc("UTMA1");
	self.assertNotNull(toDoTaskDesc);
	
	create toDoTask transient;
	toDoTask.add(toDoTaskDesc);
	//self.assertNotNull(toDoTask);

	
	resourceType := self.addToDoTaskResource("UTMARES1",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTask
											 );
	self.assertNotNull(resourceType);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["UTMA2"];
	deleteToDoTaskDescription(toDoTaskDesc);
	toDoTaskDesc := self.createToDoTaskDesc("UTMA2");
	self.assertNotNull(toDoTaskDesc);
	self.opts.purge;
	self.opts.addAssoc("TODO",toDoTaskDesc);
	
	self.updateResourceType(resourceType);
	self.assertEqual(resourceType.unitDescription,"UPUNIT");
	
	
	ti1 := createContainer(	CNTR1,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator("APL"),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti1);
	ti2 := createContainer(	CNTR2,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator("APL"),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	
	beginTransaction;
	tiTask1 := ti1.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	tiTask2 := ti2.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	
	self.assertEqual(ti1.allToDoTasksToDo.first.toDoTaskDescShort,"UTMA2");
	self.assertEqual(ti2.allToDoTasksToDo.first.toDoTaskDescShort,"UTMA2");
	create tiSet transient;
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	app.myTrxUA.trxUpdateTIToDoTaskRemBulk(toDoTaskDesc,tiSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNull(ti1.allToDoTasksToDo.first);
	self.assertNull(ti2.allToDoTasksToDo.first);
											 
epilog
	
	delete toDoTask;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tResourceTypeGroup" id="16b3f5e2-4905-4a36-ada9-26c56e56955d">
        <updating/>
        <source>tResourceTypeGroup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

constants
	UT_UpperCaseCode	: String = "TEST";
	UT_Code				: String = "Test";
	UT_Code_6			: String = "UT_58761-6";
	UT_Code_7			: String = "UT_58761-7";
	UT_Code_7_Upd		: String = "UT_58761-7Upd";
	UT_Code_8			: String = "UT_58761-8";
	UT_Description		: String = "Test Description";
	UT_Description_Upd	: String = "Test Description Upd";
	UT_RT_Code1			: String = "UT_58761-1";
	UT_RT_Code2			: String = "UT_58761-2";
	
	UT_TaskDesc_Code1	: String = "UT_58761-1";
	UT_TaskDesc_Code2	: String = "UT_58761-1";
	
vars
	pxyResourceTypeGroup,
	realResourceTypeGroup	: CM_ResourceTypeGroup;
	realResourceType1,
	realResourceType2		: CM_ResourceType;
	utSystemHelper			: UT_HelperAdmSys;
	toDoTasks				: CM_ToDoTaskDescBySortKey;
	toDoTaskDesc1,
	toDoTaskDesc2: CM_ToDoTaskDesc;
	pxyTaskCriteria1,
	pxyTaskCriteria2,
	realTaskCriteria1,
	realTaskCriteria2: CM_TaskCriteria;
	actions					: IntegerArray;
	completeTestString,
	testString : String;
	availableResourceGroups,
	mandatoryResourceGroups		: CM_ResourceTypeGroupByCode;
	
begin
	//Global Test Setup
	testString := "Test";
	
	create utSystemHelper transient;
	utSystemHelper.setActiveProfile;
	utSystemHelper.currentMethodBeingRun := UT_SystemAdmin::tResourceTypeGroup;
	
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code1);
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code2);
	
	create toDoTasks transient;
	
	realResourceType1 := self.addToDoTaskResource(UT_RT_Code1, UT_RT_Code1, "MT", 1, false, true, toDoTasks);
	realResourceType2 := self.addToDoTaskResource(UT_RT_Code2, UT_RT_Code2, "MT", 1, false, true, toDoTasks);
	
	delete toDoTasks;
	
	//Test 1.1 Create Uppercase code - UI Test
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.1" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_UpperCaseCode);
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_UpperCaseCode, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	
	delete pxyResourceTypeGroup;
	
	//Test 1.2 Create with mixed case code - Web Test
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.2" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code);
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	
	delete pxyResourceTypeGroup;
	
	//Test 1.3 Create with duplicate code - check should raise an exception
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.3" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code);
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	
	delete pxyResourceTypeGroup;
	
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code, UT_Description, false);
	app.myTrxCA.trxCreateResourceTypeGroup(pxyResourceTypeGroup, realResourceTypeGroup, app.myPassport);
	delete pxyResourceTypeGroup;
	
	self.assertTrxErrorMsg(Resource_type_group_dup, completeTestString &amp; " should raise a duplictae object error.");
	
	//Test 1.4 Create with empty code - check should raise an exception
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.4" &amp; Colon;
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(null, UT_Description, false);
	app.myTrxCA.trxCreateResourceTypeGroup(pxyResourceTypeGroup, realResourceTypeGroup, app.myPassport);
	delete pxyResourceTypeGroup;
	
	self.assertTrxErrorMsg(Resource_Type_Group_CodeReq, completeTestString &amp; " should raise a null code error.");
	
	//Test 1.5 Create with multiple resource types
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.5" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code);
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code, UT_Description, false);
	pxyResourceTypeGroup.allResourceTypes.add(realResourceType1);
	pxyResourceTypeGroup.allResourceTypes.add(realResourceType2);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.isNotEmpty, completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: is not empty | Actual: is empty");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.size = 2, completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: 2 items | Actual: " &amp; realResourceTypeGroup.allResourceTypes.size.String);
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.includes(realResourceType1), completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: includes '" &amp; UT_RT_Code1 &amp; "' | Actual: not included");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.includes(realResourceType2), completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: includes '" &amp; UT_RT_Code2 &amp; "' | Actual: not included");
	
	delete pxyResourceTypeGroup;
	
	//Test 1.6 Create Not available for entry
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.6" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_6);
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code_6, UT_Code_6, true);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	self.assertTrueMsg(realResourceTypeGroup.isNotAvailableForEntry, completeTestString &amp; " realResourceTypeGroup.isNotAvailableForEntry Expected: 'true' | Actual: '" &amp; realResourceTypeGroup.isNotAvailableForEntry.String &amp; "'");
	
	delete pxyResourceTypeGroup;
	
	//Test 2.1 Update
		//allAvailableResourceGroups &amp; allMandatoryResourceGroups do not worry about
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "2.1" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_7);
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_7_Upd);
	
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code_7, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	self.assertTrueMsg(not realResourceTypeGroup.isNotAvailableForEntry, completeTestString &amp; " realResourceTypeGroup.isNotAvailableForEntry Expected: 'false' | Actual: '" &amp; realResourceTypeGroup.isNotAvailableForEntry.String &amp; "'");
	delete pxyResourceTypeGroup;
	
	//7.1 Check updating trx when the updated code is not already existing in the db
	pxyResourceTypeGroup := app.createUpdateProxy(realResourceTypeGroup).CM_ResourceTypeGroup;
	pxyResourceTypeGroup.setProxy(UT_Code_7_Upd, UT_Description, false);
	utSystemHelper.xUpdateResourceTypeGroup(pxyResourceTypeGroup);
	delete pxyResourceTypeGroup;
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	self.assertNotNullMsg(realResourceTypeGroup, method.qualifiedName &amp; " - Test 7.1: realResourceTypeGroup");
	self.assertTrueMsg(realResourceTypeGroup.code = UT_Code_7_Upd, method.qualifiedName &amp; " - Test 7.1: realResourceTypeGroup.code Expected: '" &amp; UT_Code_7_Upd &amp; "' | Actual '" &amp; realResourceTypeGroup.code &amp; "'");
	self.assertTrueMsg(realResourceTypeGroup.description = UT_Description, method.qualifiedName &amp; " - Test 7.1: realResourceTypeGroup.description Expected: '" &amp; UT_Description &amp; "' | Actual '" &amp; realResourceTypeGroup.description &amp; "'");
	self.assertFalseMsg(realResourceTypeGroup.isNotAvailableForEntry, method.qualifiedName &amp; " - Test 7.1: realResourceTypeGroup.isNotAvailableForEntry Expected: 'false' | Actual: '" &amp; realResourceTypeGroup.isNotAvailableForEntry.String &amp; "'");
	
	//7.2 Check updating trx when the updated code already exists in the db
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code_7, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroup, method.qualifiedName &amp; " - Test 7.2: realResourceTypeGroup");
	self.assertTrueMsg(not realResourceTypeGroup.isNotAvailableForEntry, method.qualifiedName &amp; " - Test 7.2: realResourceTypeGroup.isNotAvailableForEntry Expected: 'false' | Actual: '" &amp; realResourceTypeGroup.isNotAvailableForEntry.String &amp; "'");
	delete pxyResourceTypeGroup;
	
	pxyResourceTypeGroup := app.createUpdateProxy(realResourceTypeGroup).CM_ResourceTypeGroup;
	pxyResourceTypeGroup.setProxy(UT_Code_7_Upd, UT_Description_Upd, true);
	app.myTrxUA.trxUpdateResourceTypeGroup(pxyResourceTypeGroup, app.myPassport);
	delete pxyResourceTypeGroup;
	
	self.assertTrxErrorMsg(Resource_type_group_dup, method.qualifiedName &amp; " - Test 7.2: should raise a duplicate object error.");
	
	//7.3 Check updating trx when we change isNotAvailableForEntry &amp; description
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	pxyResourceTypeGroup := app.createUpdateProxy(realResourceTypeGroup).CM_ResourceTypeGroup;
	pxyResourceTypeGroup.setProxy(UT_Code_7_Upd, UT_Description_Upd, true);
	app.myTrxUA.trxUpdateResourceTypeGroup(pxyResourceTypeGroup, app.myPassport);
	delete pxyResourceTypeGroup;
	
	self.assertTrueMsg(realResourceTypeGroup.code = UT_Code_7_Upd, method.qualifiedName &amp; " - Test 7.3: realResourceTypeGroup.code Expected: '" &amp; UT_Code_7_Upd &amp; "' | Actual '" &amp; realResourceTypeGroup.code &amp; "'");
	self.assertTrueMsg(realResourceTypeGroup.description = UT_Description_Upd, method.qualifiedName &amp; " - Test 7.3: realResourceTypeGroup.description Expected: '" &amp; UT_Description_Upd &amp; "' | Actual '" &amp; realResourceTypeGroup.description &amp; "'");
	self.assertTrueMsg(realResourceTypeGroup.isNotAvailableForEntry, method.qualifiedName &amp; " - Test 7.3: realResourceTypeGroup.isNotAvailableForEntry Expected: 'true' | Actual: '" &amp; realResourceTypeGroup.isNotAvailableForEntry.String &amp; "'");
	
	//7.4 Check updating trx when we change allResourceTypes adding
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code);
	utSystemHelper.xDeleteResourceTypeGroup(UT_UpperCaseCode);
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	pxyResourceTypeGroup := app.createUpdateProxy(realResourceTypeGroup).CM_ResourceTypeGroup;
	pxyResourceTypeGroup.allResourceTypes.add(realResourceType1);
	pxyResourceTypeGroup.allResourceTypes.add(realResourceType2);
	utSystemHelper.xUpdateResourceTypeGroup(pxyResourceTypeGroup);
	delete pxyResourceTypeGroup;
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	
	self.assertNotNullMsg(realResourceTypeGroup, method.qualifiedName &amp; " - Test 7.4: realResourceTypeGroup");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.isNotEmpty, method.qualifiedName &amp; " - Test 7.4: realResourceTypeGroup.allResourceTypes Expected: is not empty | Actual: is empty");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.size = 2, method.qualifiedName &amp; " - Test 7.4: realResourceTypeGroup.allResourceTypes Expected: 2 items | Actual: " &amp; realResourceTypeGroup.allResourceTypes.size.String);
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.includes(realResourceType1), method.qualifiedName &amp; " - Test 7.4: realResourceTypeGroup.allResourceTypes Expected: includes '" &amp; UT_RT_Code1 &amp; "' | Actual: not included");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.includes(realResourceType2), method.qualifiedName &amp; " - Test 7.4: realResourceTypeGroup.allResourceTypes Expected: includes '" &amp; UT_RT_Code2 &amp; "' | Actual: not included");
	
	
	//7.5 Check updating trx when we change allResourceTypes removing
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "7.5" &amp; Colon;
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code);
	utSystemHelper.xDeleteResourceTypeGroup(UT_UpperCaseCode);
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	pxyResourceTypeGroup := app.createUpdateProxy(realResourceTypeGroup).CM_ResourceTypeGroup;
	pxyResourceTypeGroup.allResourceTypes.clear();
	utSystemHelper.xUpdateResourceTypeGroup(pxyResourceTypeGroup);
	delete pxyResourceTypeGroup;
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	
	self.assertNotNullMsg(realResourceTypeGroup, completeTestString &amp; " realResourceTypeGroup");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.isEmpty, completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: is not empty | Actual: is empty");
	self.assertTrueMsg(realResourceTypeGroup.allResourceTypes.size = 0, completeTestString &amp; " realResourceTypeGroup.allResourceTypes Expected: 0 items | Actual: " &amp; realResourceTypeGroup.allResourceTypes.size.String);
	
	app.writeLog(completeTestString &amp; "Completed", LogINFO);
	app.writeLog(completeTestString &amp; "Completed", LogINFO);
	
	//Test 8.1 Delete
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "8.1" &amp; Colon;
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.setProxy(UT_Code_8, UT_Description, false);
	realResourceTypeGroup := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	delete pxyResourceTypeGroup;
	self.assertNotNullMsg(realResourceTypeGroup,  completeTestString &amp; " realResourceTypeGroup");
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_8);
	self.assertIsDeletedMsg(realResourceTypeGroup,  completeTestString &amp; " realResourceTypeGroup");
	
	//8.2 allAvailableResourceGroups
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "8.2" &amp; Colon;
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7];
	
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code1);
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code2);
	
	toDoTaskDesc1 := utSystemHelper.xCreateToDoTaskDesc(method.qualifiedName, UT_TaskDesc_Code1, "CONT");
	self.assertNoTrxErrorsOrWarnings();
	
	create pxyTaskCriteria1 transient;
	create actions transient;
	actions.add(TRANS_TYPE_PackComplete);
	actions.add(TRANS_TYPE_UnpackComplete);
	self.assertEqualMsg(actions.size(), 2, completeTestString &amp; " wrong number of children");
	
	create availableResourceGroups transient;
	availableResourceGroups.add(realResourceTypeGroup);
	create mandatoryResourceGroups transient;
	pxyTaskCriteria1.setProxyBaseData(actions, QUEUE_MODE, PLANNING_MODE, app.myPassport.myTerminal, toDoTaskDesc1, availableResourceGroups, mandatoryResourceGroups);
	realTaskCriteria1 := utSystemHelper.xCreateTaskCriteria(pxyTaskCriteria1);
	delete actions;
	delete pxyTaskCriteria1;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	self.assertNotNullMsg(realTaskCriteria1,  completeTestString &amp; " realTaskCriteria1");
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7];
	app.myTrxDA.trxDeleteResourceTypeGroup(realResourceTypeGroup, app.myPassport);
	self.assertTrxErrorMsg(Resource_type_grp_del_ava_Task,  completeTestString &amp; " realResourceTypeGroup.allAvailableTaskCriteria should raise an exception with code: " &amp; Resource_type_grp_del_ava_Task.String);
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code1);
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_7);
	
	// 8.3 allMandatoryResourceGroups
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "8.3" &amp; Colon;
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	toDoTaskDesc2 := utSystemHelper.xCreateToDoTaskDesc(completeTestString, UT_TaskDesc_Code2, "CONT");
	self.assertNoTrxErrorsOrWarnings();
	
	create pxyTaskCriteria2 transient;
	create actions transient;
	actions.add(TRANS_TYPE_PackComplete);
	actions.add(TRANS_TYPE_UnpackComplete);
	self.assertEqualMsg(actions.size(), 2, completeTestString &amp; " wrong number of children");
	
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	mandatoryResourceGroups.add(realResourceTypeGroup);
	pxyTaskCriteria2.setProxyBaseData(actions, QUEUE_MODE, PLANNING_MODE, app.myPassport.myTerminal, toDoTaskDesc2, availableResourceGroups, mandatoryResourceGroups);
	realTaskCriteria2 := utSystemHelper.xCreateTaskCriteria(pxyTaskCriteria2);
	delete actions;
	delete pxyTaskCriteria2;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	self.assertNotNullMsg(realTaskCriteria2, completeTestString &amp; " realTaskCriteria2");
	
	realResourceTypeGroup := app.myRoot.allResourceTypeGroups[UT_Code_7_Upd];
	app.myTrxDA.trxDeleteResourceTypeGroup(realResourceTypeGroup, app.myPassport);
	self.assertTrxErrorMsg(Resource_type_grp_del_man_Task, completeTestString &amp; " realResourceTypeGroup.allMandatoryTaskCriteria should raise an exception with code: " &amp; Resource_type_grp_del_man_Task.String);
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code2);
	utSystemHelper.xDeleteResourceTypeGroup(UT_Code_7_Upd);
	
	//Global Test Cleanup
	
epilog
	delete utSystemHelper;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tSFTPEntity" id="97872168-4671-4ed0-9d41-aa686218ed98">
        <source>tSFTPEntity();
// jlgmd1
/*

Purpose:			Test valid authentication combos for the new SFTP
					As of cnwssh.dll 1.0.0.13 these are:
					Username + Password
					Username + Private Key
					Username + Private Key + Key Passphrase

Parameters:			

