    <JadeMethod name="getDisplayAttributeHeading" id="2a3307ff-5974-4d30-9b98-4f2c7b74e935">
        <source>getDisplayAttributeHeading(_name : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/02/2015	cnwjre1	Initial creation	Par 35440

*/

vars

	attrName : String;
	prodAttr : CM_ProductAttr;
	displayName	: String;

begin

	attrName := _name;
	displayName := _name;

	if self.isEntTableSpecialProductAttr( attrName ) then
		prodAttr := self.getProdAttrFromName( attrName );
		if prodAttr &lt;&gt; null then
			if prodAttr.getDisplayStringForAttribute( ETRow_SystemName, false ) &lt;&gt; prodAttr.displayName then
				displayName := prodAttr.displayName;
			endif;
		endif;
	endif;

	return displayName;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a267a138-233a-4aaa-a4f1-776943fa634e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     23 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 30/01/09		cnwrd1		par #18821
// 30/11/2009	cnwdap1		CCMS 1007 - new reefer attributes
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_EntCargoType or
	   _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Colour then
//		return null;
		return self.colour.String;	
	elseif _attrName = ETRow_DisplayValue then
		return null;
	
	elseif _attrName = ETRow_EntCode then
		return self.code;
		
	elseif _attrName = ETRow_EntDescription then
		return self.description;
	
	elseif _attrName = ETRow_EntHandling then
		return self.myHandlingType.description;
	
	elseif _attrName = ETRow_HandlingType then
		if self.myHandlingType &lt;&gt; null then
			return self.myHandlingType.description;
		else
			return null.String;
		endif;
		
	elseif _attrName = ETRow_HandlingSubType then	//31 Mar 2017	NDL	TFS 3414
		if self.myHandlingSubType &lt;&gt; null then
			return myHandlingSubType.description;
		endif;
		return null;

	elseif _attrName = ETRow_EntOperator then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.code &amp; '   ' &amp; self.myOperator.description;
		else
			return null;
		endif;		
		
	elseif _attrName = ETRow_OperatorCode or
	   _attrName = ETRow_Operator or
	   _attrName = ETRow_MyOperator or
	   _attrName = ETRow_Supplier then
		if self.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return self.myOperator.description;						// TFS 53362
			else														// TFS 53362
				return self.myOperator.code;
			endif;														// TFS 53362
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_StowageFactor then
//		return 'not yet implemented';
		return null; // put 29/07/2005 for some screen grabs (looks nicer) 
	elseif _attrName = ETRow_MyWidth then
		return self.myWidth.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyWidthString then
		return self.myWidthString.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyHeight then
		return self.myHeight.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyHeightString then
		return self.myHeightString.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyLength then
		return self.myLength.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyLengthString then
		return self.myLengthString.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyQuantity then
		return self.myQuantity.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyVolume then
		return self.myVolume.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyDensity then
		return self.myDensityDec.getDefaultValueString(_attrName);	// ### TFS 52193 22Nov2021 NAVPW1
	
	elseif _attrName = ETRow_MyWeight then
		return self.myWeight.getDefaultValueString(_attrName);
	
	elseif _attrName = ETRow_MyType then
		return self.myType.getDefaultValueString(_attrName);
	
//	elseif _attrName = ETRow_MyColour then
//		return self.colour.getDefaultValueString(_attrName);

	elseif _attrName = ETRow_Reefer then	// CCMS 1007
		return self.isReefer.getYesNo;		// CCMS 1007
											// CCMS 1007
	elseif _attrName = ETRow_Powered then	// CCMS 1007
		return self.isPowered.getYesNo;		// CCMS 1007
											// CCMS 1007
	elseif _attrName = ETRow_Integral then	// CCMS 1007
		return self.isIntegral.getYesNo;	// CCMS 1007
											// CCMS 1007
	elseif _attrName = ETRow_Fan then		// CCMS 1007
		return self.isFan.getYesNo;			// CCMS 1007
	elseif _attrName = ETRow_IsNotAvailableForEntry then
		return self.isNotActive.getYesNo;
	
	//25 Jan 2018	NDL	TFS 36697
	elseif _attrName = ETRow_AutoWeightCalculate then
		return self.autoWeightCalculate.getYesNo;
		
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueForWeight" id="b01acab8-8ad4-4783-a8d1-4b4ce9b96c62">
        <source>getDisplayValueForWeight(_value : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     17 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myWeight = null then
		return _value;
	endif;
	
	return self.myWeight.multiplyValue(_value).Decimal; //30.1.09 cnwrd1 par #18821
	
end;
</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getEDIAttrMeasure" id="f7a20def-c817-4de9-a9cb-9b83b9823097">
        <source>getEDIAttrMeasure(_ediTI : CM_EDITrackedItem; _propName : String) : CM_MeasurementType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07 Oct 2024	navdap1		Initial creation MTN-19242 TPT| User Defined Cargo Sub Type Uploads
//
vars
	fileTypeUser : CM_EDIFileTypeUser;
	mappingType : CM_EDIFieldMappingType;
	mapping : CM_EDIFieldMapping;

begin
	if _ediTI.myEDIData = null or _ediTI.myEDIData.myEDIFile = null or _ediTI.myEDIData.myEDIFile.myEDIFileType = null then
		return null;
	endif;
	
	if not _ediTI.myEDIData.myEDIFile.myEDIFileType.type= EDIFileType_UserDefined then
		return null;
	endif;
	
	fileTypeUser := _ediTI.myEDIData.myEDIFile.myEDIFileType.CM_EDIFileTypeUser;
	foreach mappingType in fileTypeUser.allEDIFieldMappingTypes discreteLock do
		foreach mapping in mappingType.allEDIFieldMappings discreteLock do
			if mapping.propName.toUpper = _propName[3:end].toUpper then
				return mapping.myMeasurementType;
			endif;
		endforeach;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
