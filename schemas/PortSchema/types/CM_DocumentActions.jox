    <JadeMethod name="getCompletedAmount" id="732811fd-5b97-4f46-9301-689c009e0769">
        <source>getCompletedAmount(	_id : String;
					_stop : CM_StopsTable;
					_task : CM_ToDoTaskDesc
					) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	completedAmount : Real;
	tiTrx : CM_TITransaction;
	stopTrx : CM_StopClearedDocAction;
	taskTrx : CM_TaskCompleteDocAction;
	iter : Iterator;
	invalidObj : Boolean;

begin

	if _id = null then
		return completedAmount;
	endif;
	
	on Exception do app.handleDeletedObject( exception, tiTrx, invalidObj );
	
	if _stop &lt;&gt; null then
		iter := self.allCompletedStopTrx.createIterator;
		while iter.next( tiTrx ) do
			invalidObj := false;
			if not tiTrx.isStopClearedDocAction then
				continue;
			endif;
			if invalidObj then
				continue;
			endif;
			if tiTrx.deleted then
				continue;
			endif;
			stopTrx := tiTrx.CM_StopClearedDocAction;
			if stopTrx.stopID &lt;&gt; _stop.id then
				continue;
			endif;
			if _id = stopTrx.myTrackedItem.id then
				completedAmount := completedAmount + stopTrx.amount;
			endif;
		endwhile;
		
		
	elseif _task &lt;&gt; null then
		iter := self.allCompletedTaskTrx.createIterator;
		while iter.next( tiTrx ) do
			invalidObj := false;
			if not tiTrx.isTaskCompleteDocAction then
				continue;
			endif;
			if invalidObj then
				continue;
			endif;
			if tiTrx.deleted then
				continue;
			endif;
			taskTrx := tiTrx.CM_TaskCompleteDocAction;
			if taskTrx.todoTaskCode &lt;&gt; _task.code then
				continue;
			endif;
			if _id = taskTrx.myTrackedItem.id then
				completedAmount := completedAmount + taskTrx.amount;
			endif;
		endwhile;
	
	endif;
	
	return completedAmount;

epilog

	delete iter;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Real"/>
    </JadeMethod>
