<Class name="CollClass">
    <JadeMethod name="cnEcDocumentCollection" id="e34d40d8-5f05-4313-a2f4-53a2d8a378f9">
        <source>cnEcDocumentCollection(	pParameterObj:CnEcDocParameter;
						pHtmlFileObj:File io;
						pIsIncludeRootSchemaClasses:Boolean;
						pSchemaCollObj:SchemaColl;
						pPathToIndex:String) protected;
// --------------------------------------------------------------------------------
// Created:		13 October 2000 by cnwdad1
//
// Purpose:		Appends details of the Collection to an HTML file to document for the
//				receiver class.
//
// Parameters:	pParameterObj - A reference to the class documentation parameter object.
//				pHtmlFileObj - The target documentation file.
//				pIsIncludeRootSchemaClasses (Boolean) - If true, RootSchema classes
//					will also be documented (useful for showing hyperlinks from
//					Class property references).
//				pSchemaCollObj - The collection (Array) of schemas that
//					are a valid list of schemas to be documented (used when including
//					hyperlinks from Class property references to the documentation
//					for for the reference type's Class).
//				pPathToIndex - The file path if the documentation index file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/10/2000	cnwdad1		Added a hyperlink to the collection's membership class
//							back to its class documentaton file.
// 05/07/2001	cnwdad1		Changed to check whether the membership class was found
//							(such where the membership is a primitive).  In such
//							cases, the name of the Type will be used instead of the
//							name of the membership class.
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// --------------------------------------------------------------------------------
vars
	membershipClassObj		: Class;
	memberClassHyperlink	: String;
	collectionTypeName		: String;
	membershipName			: String;
	
begin
	collectionTypeName	:=	self.cnEcGetCollectionTypeName();
	membershipClassObj	:=	self.schema.getClass(self.getMemberType.name);
	
	// cnwdad1 05/07/2001 - Added check for membership class.
	if membershipClassObj = null then
		membershipName	:=	self.getMemberType.name;
	else
		membershipName	:=	membershipClassObj.name;
	endif;
	
	// Add a hyperlink for the membership class back to its class documentation file.
	
	memberClassHyperlink	:=	self.cnEcDocumentGetClassHyperlink(	pParameterObj,
																	membershipName,
																	pIsIncludeRootSchemaClasses,
																	pSchemaCollObj,
																	pPathToIndex);
	
//	pHtmlFile.writeLine("&lt;P&gt;&lt;H2&gt;&lt;STRONG&gt;" &amp; collectionTypeName &amp; " Membership:&lt;/STRONG&gt; " &amp; theMembershipClass.name &amp; "&lt;/H2&gt;");
	pHtmlFileObj.writeLine("&lt;P&gt;&lt;H2&gt;&lt;STRONG&gt;" &amp; collectionTypeName &amp; " Membership:&lt;/STRONG&gt; " &amp; memberClassHyperlink &amp; "&lt;/H2&gt;");
	
	if self.inheritsFrom(Dictionary) then
		self.cnEcDocumentDictionaryKeys(pParameterObj, pHtmlFileObj, pIsIncludeRootSchemaClasses, pSchemaCollObj, pPathToIndex);
	endif;

	if self.duplicatesAllowed then
		pHtmlFileObj.writeLine("&lt;P&gt;*** Duplicates are allowed ***&lt;/P&gt;");
	else
		pHtmlFileObj.writeLine("&lt;P&gt;*** Duplicates are not allowed ***&lt;/P&gt;");
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pHtmlFileObj" type="File" usage="io"/>
        <Parameter name="pIsIncludeRootSchemaClasses" type="Boolean"/>
        <Parameter name="pSchemaCollObj" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentDictionaryKeys" id="38900405-f6b3-4b90-a926-de2f0a164a10">
        <source>cnEcDocumentDictionaryKeys(	pParameterObj:CnEcDocParameter;
							pHtmlFileObj:File io;
							pIsIncludeRootSchemaClasses:Boolean;
							pSchemaCollObj:SchemaColl;
							pPathToIndex:String) protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2000 by cnwdad1
//
// Purpose:		Appends details of Dictionary keys to an HTML file to document for the
//				receiver Collection class.
//
// Parameters:	pParameterObj - 
//				pHtmlFileObj - The target documentation file.
//				pIsIncludeRootSchemaClasses (Boolean) - If true, RootSchema classes
//					will also be documented (useful for showing hyperlinks from
//					Class property references).
//				pSchemaCollObj - The collection (Array) of schemas that
//					are a valid list of schemas to be documented (used when including
//					hyperlinks from Class property references to the documentation
//					for for the reference type's Class).
//				pPathToIndex - The file path if the documentation index file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// --------------------------------------------------------------------------------
vars
	keyCollObj				: KeyColl;
	dictKeyObj				: Key;
	membershipClassObj		: Class;
	propertyLength			: Integer;
	propertyName			: String;
	propertyObj				: Property;
	scanPosition			: Integer;

begin
	membershipClassObj	:=	self.schema.getClass(self.getMemberType.name);
	keyCollObj			:=	self.getKeys();		// Find the keys for this dictionary class.
	
	pHtmlFileObj.writeLine("&lt;H2&gt;&lt;STRONG&gt;Keys&lt;/STRONG&gt;&lt;/H2&gt;&lt;BR&gt;");
	pHtmlFileObj.writeLine("&lt;TABLE WIDTH=" &amp; 34.Character &amp; "100%" &amp; 34.Character &amp; "&gt;");
	pHtmlFileObj.writeLine("&lt;TR&gt;&lt;TD&gt;&lt;STRONG&gt;Attribute&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Type&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Length&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Access&lt;/STRONG&gt;&lt;/TD&gt;&lt;/TR&gt;");

	foreach dictKeyObj in keyCollObj do
		if dictKeyObj.isKindOf(ExternalKey) then
			// An ExternalKey is not a "Property" in its own right, however it does hold
			// the normal attributes of a Property itself.
			
			pHtmlFileObj.writeLine("&lt;TR&gt;");
			pHtmlFileObj.writeLine("&lt;TD&gt;" &amp; dictKeyObj.ExternalKey.name &amp; "&lt;/TD&gt;");
			pHtmlFileObj.writeLine("&lt;TD&gt;" &amp; dictKeyObj.ExternalKey.type.getName &amp; "&lt;/TD&gt;");
			
			propertyLength	:=	dictKeyObj.ExternalKey.length;
	
			if dictKeyObj.ExternalKey.type.getName = "String" then				
				if propertyLength = -1 then
					pHtmlFileObj.writeLine("&lt;TD&gt;Maximum&lt;/TD&gt;");
				else
					pHtmlFileObj.writeLine("&lt;TD&gt;" &amp; (propertyLength - 1).String &amp; "&lt;/TD&gt;");
				endif;
			else
				pHtmlFileObj.writeLine("&lt;TD&gt;" &amp; propertyLength.String &amp; "&lt;/TD&gt;");
			endif;
	
			pHtmlFileObj.writeLine("&lt;TD&gt;N/A&lt;/TD&gt;");
			pHtmlFileObj.writeLine("&lt;/TR&gt;");

		else
			scanPosition	:=	2;
			propertyName	:=	dictKeyObj.MemberKey.getName.scanUntil(" ", scanPosition);	// Byte 1 = Tab, then scan upto the first space.
			propertyObj		:=	membershipClassObj.getProperty(propertyName);
			
			if propertyObj = null then
				pHtmlFileObj.writeLine("&lt;TR&gt;");
				pHtmlFileObj.writeLine("&lt;TD&gt;???" &amp; dictKeyObj.getName() &amp; "&lt;/TD&gt;");
				pHtmlFileObj.writeLine("&lt;/TR&gt;");
			else
				propertyObj.cnEcDocumentSelf(pParameterObj, null, pHtmlFileObj, pIsIncludeRootSchemaClasses, pSchemaCollObj, pPathToIndex);
			endif;
		endif;
	endforeach;

	pHtmlFileObj.writeLine("&lt;/TABLE&gt;&lt;BR&gt;");
end;</source>
        <access>protected</access>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pHtmlFileObj" type="File" usage="io"/>
        <Parameter name="pIsIncludeRootSchemaClasses" type="Boolean"/>
        <Parameter name="pSchemaCollObj" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCollectionTypeName" id="ef98431c-0732-424c-a652-383231c4ae6f">
        <source>cnEcGetCollectionTypeName():String;
// --------------------------------------------------------------------------------
// Created:		13 October 2000 by cnwdad1
//
// Purpose:		Returns the name of the CollClass Type.
//
// Parameters:	None
//
// Returns:		The name of the collection type.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	collectionTypeName	: String;
	
begin
	if self.inheritsFrom(DynaDictionary) then
		collectionTypeName	:=	DynaDictionary.name;
		
	elseif self.inheritsFrom(ExtKeyDictionary) then
		collectionTypeName	:=	ExtKeyDictionary.name;
		
	elseif self.inheritsFrom(MemberKeyDictionary) then
		collectionTypeName	:=	MemberKeyDictionary.name;
		
	elseif self.inheritsFrom(Set) then
		if self.inheritsFrom(ObjectSet) then
			collectionTypeName	:=	ObjectSet.name;
		else
			collectionTypeName	:=	Set.name;
		endif;
		
	elseif self.inheritsFrom(Array) then
		if self.inheritsFrom(ObjectArray) then
			collectionTypeName	:=	ObjectArray.name;
		else
			collectionTypeName	:=	Array.name;
		endif;
		
	endif;
epilog
	return collectionTypeName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsCollection" id="961d95c6-cc63-453b-bef5-bd9807796f53">
        <source>cnEcIsCollection(): Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Collection Type.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Collection Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
