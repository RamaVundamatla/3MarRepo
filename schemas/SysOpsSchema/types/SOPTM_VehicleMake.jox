    <JadeMethod name="setupThumbnailDetails" id="960b2130-acef-40fe-aaa9-0e67a0fa633b">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_VehicleMake);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_VehicleMake);	
	self.myForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="12ab9d57-b1a6-4095-a453-a0ceb26749fd">
        <updating/>
        <source>showThumbnail(_vehicleMake : CM_VehicleMake) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Make, _vehicleMake.make);

epilog

end;</source>
        <Parameter name="_vehicleMake" type="CM_VehicleMake"/>
    </JadeMethod>
</Class>
