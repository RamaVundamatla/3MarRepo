    <JadeMethod name="doResetSearch" id="3a4ab333-34a0-450a-9d3f-653675928b48">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 27 Mar 2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	now : Date;
begin
	inheritMethod();
	now := self.systemToLocalTime(app.actualTimeServer).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.cmbTrades.listIndex := -1;
	self.txtDateDebtor.setDate(now);
	//self.txtDateTrade.setDate(now);				//07.06.2018 cnwma1 ChangeRequest #38953
	//self.txtDateVessel.setDate(now);				// TFS 37794 //07.06.2018 cnwma1 ChangeRequest #38953
	// 24052 multi-select, clear debtor and service selections
	self.msgbDebtors.clearSelected();
	self.msgbServices.clearSelected();
	self.msgbVessels.clearSelected();				// TFS 37794
	self.msgbVessServ.clearSelected();				// TFS 37794
	self.msgbVesselTypes.clearSelected();	//07.06.2018 cnwma1 ChangeRequest #38953
	self.msgbVessTypeServ.clearSelected();  //07.06.2018 cnwma1 ChangeRequest #38953
	
	self.msgbVisitTypes.clearSelected();	//07.06.2018 cnwma1 ChangeRequest #38953
	self.msgbVisitTypeServ.clearSelected(); //07.06.2018 cnwma1 ChangeRequest #38953
	
	self.msgbBerths.clearSelected();		//07.06.2018 cnwma1 ChangeRequest #38953
	self.msgbBerthServ.clearSelected();  	//07.06.2018 cnwma1 ChangeRequest #38953
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="2cf1c321-c78d-43aa-92aa-8725eda8aaba">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

