    <JadeMethod name="translateForm" id="8476e051-6213-48f9-b241-0c4867e3f22d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 October 2024 12:50:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006004, locale);
	btnApply.translateBubbleHelp(Xlat_0001944, locale);
	btnApply.translateCaption(Xlat_0001946, locale);
	btnClose.translateBubbleHelp(Xlat_0001945, locale);
	btnClose.translateCaption(Xlat_0001947, locale);
	btnResourcesUsed.translateBubbleHelp(Xlat_0001880, locale);
