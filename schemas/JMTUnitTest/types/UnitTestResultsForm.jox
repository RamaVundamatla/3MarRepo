/*

Purpose:		Refresh the form details	

Date			Who		Reason
01/05/2012		cnwmh5	Initial creation

*/

vars

begin
	
	if self.fldUnitTests.topSheet = self.shtGraph then
		self.populateGraphs();
		self.populateLastRunDetails();
	elseif self.fldUnitTests.topSheet = self.shtResults then
		self.initTableResults();
		self.populateResultsTable();
	elseif self.fldUnitTests.topSheet = self.shtTestStats then
		self.loadTableStats();
	elseif self.fldUnitTests.topSheet = self.shtAllTestAvg then
		self.loadTableAverage();
	elseif self.fldUnitTests.topSheet = self.shtCleanUp then
		self.initTableCleanUpResults();
		self.populateCleanUpResultsTable();
	endif;
	
epilog

end;</source>
