    <JadeMethod name="btnOK_click" id="82601556-f427-459d-b5eb-a2f345dc3560">
        <controlMethod name="Button::click"/>
        <final/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating, final;
begin
	if update() then
		modalResult := 1;
		unloadForm();
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkPathName" id="df57088d-4d43-4655-b6f7-64d83281ce2d">
        <final/>
        <executionLocation>server</executionLocation>
        <source>checkPathName(pathname: String) : Integer serverExecution, final;
vars
	f:	FileFolder;
begin

	create f;
	// override default in case executed from single-user app server, we need to ensure validation
	// occurs on the database server and not the presentation client
	f.usePresentationFileSystem := false;
	// ideally File::isValidPathName would be a class method, in the meantime we need to
	// create an instance
	if not f.isValidPathName(pathname) then
		return PathInvalid;
	endif;

	f.fileName := pathname;
	if not f.isAvailable then
		return PathNotAvail;
	endif;	

	return PathOk;

epilog
	delete f;
end;</source>
        <Parameter name="pathname" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="chkFilter_change" id="0c820c9f-7c45-48f0-8de6-fa0187e0e8ad">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkFilter_change(checkbox: CheckBox input) updating;

vars

begin
	if checkbox.value then
		lblStartTime.enabled := true;
		lblEndTime.enabled := true;
		jemStartDate.enabled := true;
		jemEndDate.enabled := true;
		jemStartTime.enabled := true;
		jemEndTime.enabled := true;
	else
		lblStartTime.enabled := false;
		lblEndTime.enabled := false;
		jemStartDate.enabled := false;
		jemEndDate.enabled := false;
		jemStartTime.enabled := false;
		jemEndTime.enabled := false;
	endif;
end;
</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="f6c25c30-5028-4395-8630-9e97f63a8205">
        <controlMethod name="Form::load"/>
        <final/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating, final;
begin

	loadDialogParams();
	centreWindow();
	lblStartTime.enabled := false;
	lblEndTime.enabled := false;
	jemStartDate.enabled := false;
	jemEndDate.enabled := false;
	jemStartTime.enabled := false;
	jemEndTime.enabled := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDialogParams" id="f3ad483c-ceb0-4a05-9bff-db6dd36a5879">
        <final/>
        <source>loadDialogParams()  final;
vars
	sectionName	: String;
begin
	sectionName := app.name;
	txtJournalDir.text := app._getIniStringParamAppServer(sectionName, "JournalDirectory", "");
	txtOutputFile.text := app._getIniStringParamAppServer(sectionName, "OutputFile", "");

end;</source>
    </JadeMethod>
    <JadeMethod name="saveDialogParams" id="fe8cc258-e717-4a4c-8ab1-536ada2e8107">
        <final/>
        <source>saveDialogParams()  final;
vars
begin
	
	// save dialog settings
	app.setProfileStringAppServer(app.getIniFileNameAppServer, app.name, "JournalDirectory", journalDirectory);
	app.setProfileStringAppServer(app.getIniFileNameAppServer, app.name, "OutputFile", outputFileName);

end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="60b12e59-7b61-48c0-920c-ff78c837e55b">
        <final/>
        <updating/>
        <source>update() : Boolean updating,  final;

begin

	if validate() then
        journalDirectory := txtJournalDir.text;
		outputFileName := txtOutputFile.text;
		startJournal := txtStartJournal.getTextAsInteger();
		endJournal := txtEndJournal.getTextAsInteger();
		if chkFilter.value then
			filterStartTime.setDate(jemStartDate.getTextAsDate());
			filterStartTime.setTime(jemStartTime.text.Time);
			if jemEndDate.isValid() then
				filterEndTime.setDate(jemEndDate.getTextAsDate());
				filterEndTime.setTime(jemEndTime.text.Time);
			endif;
		endif;
		
        saveDialogParams();

		return true;
	endif;

	return false;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1e75b740-b53f-4f68-b1b2-8d95016ba5e4">
        <final/>
        <updating/>
        <source>validate() : Boolean updating, final;

begin
	if txtJournalDir.text = null then
		app.msgBox("Journal directory required", "Error", MsgBox_OK_Only);
		txtJournalDir.setFocus();
		return false;
	endif;
	if txtOutputFile.text = null then
		app.msgBox("Output filename required", "Error", MsgBox_OK_Only);
		txtOutputFile.setFocus();
		return false;
	endif;
	if txtStartJournal.getTextAsInteger() = 0 then
		app.msgBox("Start journal number required", "Error", MsgBox_OK_Only);
		txtStartJournal.setFocus();
		return false;
	endif;
	if chkFilter.value then
		if not jemStartDate.isValid() then
			app.msgBox("Invalid Filter Start Date", "Error", MsgBox_OK_Only);
			return false;
			jemStartDate.setFocus();
		endif;
		if not jemEndDate.isValid() then
			app.msgBox("Invalid Filter End Date", "Error", MsgBox_OK_Only);
			jemEndDate.setFocus();
			return false;
		endif;
	endif;
		
	return true;		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
