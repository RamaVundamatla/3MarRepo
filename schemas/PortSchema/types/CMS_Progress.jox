    <JadeMethod name="activate" id="dad1b64e-5941-4163-9816-9bf9d453f39f">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2003  by Jason Chapman  (cnwjc2)
