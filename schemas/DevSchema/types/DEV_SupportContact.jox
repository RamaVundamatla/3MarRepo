    <JadeMethod name="getMovedToDevTS" id="060d19d7-d794-464f-9ed9-281501c584b5">
        <source>getMovedToDevTS(): TimeStamp;

/*
Date			Who		Reason
09 August 2016	cnwar2	Initial creation

*/
vars
	state : DEV_SupportState;
	
begin
	foreach state in self.allStates do
		if state.type = 'Active Development' then
			return state.startTS;
		endif;
	endforeach;
	
	return null;
			
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getRemainingTimeKPI1" id="897ea381-a117-45ae-9833-df39dec88c04">
        <source>getRemainingTimeKPI1() : String;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	state 			: DEV_SupportState;
	duration		: Integer;
	timeRemaining	: Decimal[10,1];
	ts				: TimeStamp;
	date			: Date;
	
begin
	if self.kpi1Done then
		return "Done";
	endif;
	
	date.setDate(1,1,3000);
	ts.setDate(date);
	foreach state in self.allStates do
		if state.type = 'Active Support' then
			duration := duration + state.getDurationInMinutes(ts);
		endif;
	endforeach;

	timeRemaining := (4*60) - duration;
	timeRemaining := timeRemaining/60;
	
	return timeRemaining.String &amp; "h";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingTimeKPI2" id="9c360704-a161-4721-b37c-40edd3797293">
        <source>getRemainingTimeKPI2() : String;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	state 			: DEV_SupportState;
	duration		: Integer;
	timeRemaining	: Decimal[10,1];
	ts				: TimeStamp;
	date			: Date;
	
begin
	if self.kpi2Done then
		return "Done";
	endif;

	date.setDate(1,1,3000);
	ts.setDate(date);
	foreach state in self.allStates do
		if state.type = 'Active Support' or state.type = 'Architect/Dev Support' then
			duration := duration + state.getDurationInMinutes(ts);
		endif;
	endforeach;
	
	timeRemaining := (48*60) - duration;
	timeRemaining := timeRemaining/60;
	
	return timeRemaining.String &amp; "h";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingTimeKPI3" id="6b1d385a-5797-455e-a55a-2db8d67ca5df">
        <source>getRemainingTimeKPI3() : String;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	state 	  : DEV_SupportState;
	endTime   : TimeStamp;
	tsInt 	  : TimeStampInterval;
	totalDays : Decimal[10,1];
	
begin
	foreach state in self.allStates do
		if state.endTS.isValid then
			endTime := state.endTS;
		else
			endTime := app.actualTimeServer();
		endif;
	
		if state.type = 'Active Support' or state.type = 'Active Development' or state.type = 'Architect/Dev Support' then
			tsInt := tsInt + (endTime - state.startTS);
		endif;
	endforeach;
	totalDays 	:= (((tsInt.getMilliseconds()/1000)/60)/60)/24;
	

	return (30 - totalDays).String &amp; "d";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeInCurrentState" id="49a1cf27-e3ec-4866-b3e3-2c868e59da43">
        <source>getTimeInCurrentState(): String;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	state 	: DEV_SupportState;
	endTS 	: TimeStamp;
	logging	: String;
	
begin
	state := self.allStates.last();
	return state.getDurationStr(logging);
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalDuration" id="e9d9e8c2-cdde-47fc-80ec-f94280bfb426">
        <source>getTotalDuration(): String;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	lastState 	: DEV_SupportState;
	tsInt		: TimeStampInterval;
	totalDays	: Decimal[10,1];
	
begin
	lastState := self.allStates.last;
	
	if lastState.type &lt;&gt; 'Closed' then
		return "";
	else
		tsInt 		:= lastState.startTS - self.openedTS;
		totalDays 	:= (((tsInt.getMilliseconds()/1000)/60)/60)/24;

		return totalDays.String &amp; "d";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
