    <JadeMethod name="clear" id="78f8487d-2b32-4bc0-a08c-6edbeb37f6c9">
        <updating/>
        <source>clear() updating;
//
//19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	self.camVoyages.purge;
	self.messageCount := 0;
	self.segmentCount := 0;
end;
</source>
    </JadeMethod>
    <JadeMethod name="clearMessageCount" id="c749c0c8-6637-4306-a1ef-5f0fbadbba6e">
        <updating/>
        <source>clearMessageCount() updating;
// cnwrs1 aug 2005
vars

begin
	self.messageCount := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="decrementMessageCount" id="c00b79b6-7116-4e11-bfca-9010b0c67630">
        <updating/>
        <source>decrementMessageCount() updating;
//
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars

begin
	self.messageCount := self.messageCount - 1;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getFirstCamMessage" id="70f4ea0b-c50c-4e3f-bf1d-3fd4417eb04b">
        <source>getFirstCamMessage():CM_CamMessage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2018	jlgndl1	Initial creation	TFS 37406

*/

vars

	camVoyage : CM_CamVoyage;

begin

	if not self.camVoyages.isEmpty then
		camVoyage := self.camVoyages.first;
		if not camVoyage.camMessages.isEmpty then
			return camVoyage.camMessages.first;
		endif;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
    <JadeMethod name="incrementMessageCount" id="217d58ce-5004-4e19-83f3-03754487cc81">
        <updating/>
        <source>incrementMessageCount() updating;
// cnwrs1 aug 2005
vars

begin
	self.messageCount := self.messageCount + 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="isAnyData" id="49c80c19-412c-43f9-9336-91f1b48c0edb">
        <source>isAnyData() : Boolean;
//
//12 May 2016	cnwrs1	Par 37829 single transaction per file not sending output file when the are some discardable transactions
//
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	str : String;
begin
	foreach camVoyage in self.camVoyages do
		foreach camMessage in camVoyage.camMessages do
			foreach str in camMessage.group3 do
				if str &lt;&gt; null then
					return true;
				endif;
			endforeach;
			foreach str in camMessage.group4 do
				if str &lt;&gt; null then
					return true;
				endif;
			endforeach;
			foreach str in camMessage.group5 do
				if str &lt;&gt; null then
					return true;
				endif;
			endforeach;
		endforeach;
	endforeach;
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
