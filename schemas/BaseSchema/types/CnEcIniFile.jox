    <DbClassMap file="base"/>
    <ExplicitInverseRef name="allIniSections" id="0cb668c4-30dd-453e-99b2-002c93f31f1d">
        <kind>parent</kind>
        <type name="CnEcIniSectionDict"/>
        <access>readonly</access>
        <Inverse name="CnEcIniSection::myIniFile"/>
    </ExplicitInverseRef>
    <PrimAttribute name="fileName" id="9e3c1d86-8b13-495b-8990-35f65e90b3e2">
