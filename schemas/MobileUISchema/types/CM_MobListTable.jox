    <JadeMethod name="purgeTableObjects" id="ed92127d-3649-4297-84d5-7ba453e3e112">
        <updating/>
        <source>purgeTableObjects() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	self.allMySelectedObjects.clear;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowChecked" id="4479f148-cb47-47b9-8116-77aefeaa9c14">
        <updating/>
        <source>rowChecked(pRow : Integer) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_Selected then
			return true;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="0617bd60-a13e-40b6-8092-ffa9403aba07">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rowColumnChg(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	inheritMethod(table);
	
	if table.column &lt;&gt; self.chkBoxColumn then
		// always set the column to the checkBox column so that the
		// spacebar can be used to set/unset the checkbox.
		table.column := self.chkBoxColumn;
		self.doManually := true;
	else
		self.doManually := false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectAll" id="71f7fe9f-aa48-4ff6-89c3-747e2afa62c4">
        <updating/>
        <source>selectAll()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	if numRows = 0 then
		return;
	endif;
	
	self.allMySelectedObjects.clear();

	foreach rowIdx in 1 to numRows do
		jRow := self.accessRow(rowIdx);
		if not jRow.visible then
			continue;
		endif;
		if jRow.itemObject &lt;&gt; null then
			self.addSelectedObject(jRow.itemObject);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToFalse" id="cdf3f21a-2e03-4146-9d2d-40347f037a1a">
        <updating/>
        <source>setAllToFalse()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;
	
	objArray := self.allMySelectedObjects;
	foreach idx in 1 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		
		obj := self.accessRow(idx).itemObject;
		if (objArray.includes(obj)) then
			objArray.remove(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToTrue" id="c1443852-c238-490f-88af-59d023b05232">
        <updating/>
        <source>setAllToTrue()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;
	
	objArray := self.allMySelectedObjects;
	foreach idx in 1 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		
		obj := self.accessRow(idx).itemObject;
		if (not objArray.includes(obj)) then
			objArray.add(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setChkBoxColumn" id="90dc9a6a-8685-4637-bd13-a55c00165541">
        <updating/>
        <source>setChkBoxColumn(pInt :Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin
	chkBoxColumn	:= pInt;
end;</source>
        <Parameter name="pInt" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowSelect" id="1ef522a6-5315-4d7c-9462-ac50f2fed934">
        <updating/>
        <source>setRowSelect(pRow : Integer; _select : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	obj : Object;
begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		
		obj := self.accessRow(pRow).itemObject;
		
		if obj &lt;&gt; null then
			if _select then
				if (not self.allMySelectedObjects.includes(obj)) then
					self.allMySelectedObjects.add(obj);
				endif;
			elseif self.allMySelectedObjects.includes(obj) then
				self.allMySelectedObjects.remove(obj);
			endif;
		endif;
		
		if self.allMySelectedObjects.includes(self.accessRow(pRow).itemObject) then
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_Selected;
		else
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		endif;

	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_select" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="3ff6fe55-40d7-41af-93f3-b5d8c45bfb9f">
        <updating/>
        <source>setSelected(_objs : Collection) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	max		: Integer;

begin
 
	self.allMySelectedObjects.clear;
	
	if _objs &lt;&gt; null then
		_objs.copy(self.allMySelectedObjects);
	endif;
	
	max := self.rows;
	
	foreach idx in 1 to max do
		if self.allMySelectedObjects.includes(self.accessRow(idx).itemObject) then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		else
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		endif;
	endforeach;

end;</source>
        <Parameter name="_objs" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setSelectedString" id="143505f8-6744-4e95-a931-05a88233cc2b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setSelectedString(_string: String)updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	col,
	idx,
	max	: Integer;
	obj : Object;
begin
	if _string = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _string');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		obj := self.accessRow(idx).itemObject;
		if CM_TransactionType.hasInstance(obj) then
			if obj.CM_TransactionType.description = _string then
				self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;					
			endif;
		elseif self.accessCell(idx, col).text = _string then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;		
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_string" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="9b67f91a-868a-47e2-9d0f-fd3fcc445ee1">
        <controlMethod name="CM_Table::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	col	: JadeTableColumn;
	idx	: Integer;

begin

	inheritMethod(cntrl, persistCntrl);
	
	if self.columns &lt;= 1 then
		self.columns := 2;
	endif;
 
	foreach idx in 1 to self.columns do
		col := self.accessColumn(idx);
		if idx = self.chkBoxColumn then
			// setup the checkbox column
			col.inputType := InputType_CheckBox;
		else
			// setup the text column
			col.inputType := InputType_None;
			col.partialTextIndication := true;
		endif;
	endforeach;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
