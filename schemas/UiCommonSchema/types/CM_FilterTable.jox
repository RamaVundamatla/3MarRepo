    <JadeMethod name="alignFilterHeaderColumns" id="a4b1bc26-640a-4b80-b9f1-2a889ccda563">
        <updating/>
        <source>alignFilterHeaderColumns() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;

begin

	if self.tblFilterHeaders &lt;&gt; null then
		if self.tblFilterHeaders.columns &lt;&gt; self.columns then
			self.tblFilterHeaders.columns := self.columns;
		endif;
		foreach colIndex in 1 to self.columns do
			self.tblFilterHeaders.accessColumn( colIndex ).width := self.accessColumn( colIndex ).width;
			self.tblFilterHeaders.accessCell( 1, colIndex ).text := self.accessCell( 1, colIndex ).text;
			if colIndex = self.leftColumn then
				self.tblFilterHeaders.leftColumn := colIndex;
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="applyColumnFilterToRow" id="0237cab5-9874-4a38-99a3-783b2561874a">
        <updating/>
        <source>applyColumnFilterToRow( _rowIndex : Integer; _callPostProcessing : Boolean ) updating;
/*

Purpose:			

Parameters:			Used to apply the filters against an individual row
					I.e. for the likes of processing a row that has been added to the table,
					or altered in a table as a result of a notification

Return Value:		

Date		Who		Reason
14 January 2015	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	colIndex : Integer;
	cloneListTable : CMUI_ListTable;
	startRow : Integer;
	filterStringsArray : StringArray;
	filterText : String;

begin

	if _rowIndex &lt;= self.rows then
		return;
	endif;
	if _rowIndex &gt; self.fixedRows then
		return;
	endif;
	
	//start by making it visible;
	self.accessRow(rowIndex).visible := false;
	
	create filterStringsArray transient;
	
	foreach colIndex in 1 to self.columns do
		cloneListTable := self.lstFilterValues.getControl(colIndex);
		if cloneListTable &lt;&gt; null then
			filterStringsArray.clear();
			//get the valid filtering values for this column
			foreach rowIndex in 1 to cloneListTable.rows do
				if cloneListTable.accessCell( rowIndex, 1 ).text = TableCheckBox_Selected then
					filterText := cloneListTable.accessCell( rowIndex, 2 ).text;
					filterStringsArray.add( filterText );
				endif;
			endforeach;
			if not filterStringsArray.isEmpty and filterStringsArray.includes(self.AllValues) then
				//every thing in this column is included, just continue on to the next column...
				continue;
			endif;
			if filterStringsArray.isEmpty then
				//nothing selected, make it invisible and bail, no point in checking any more columns for this row.
				self.accessRow(rowIndex).visible := false;
				break;
			endif;	
			if not filterStringsArray.includes( self.accessCell( _rowIndex, colIndex ).text.trimBlanks[1:MaxMatchLength] ) then
				self.accessRow(rowIndex).visible := false;
				//no point in checking any further for this row
				break;
			endif;
		endif;
	endforeach;
	
	if _callPostProcessing then
		self.doPostFilterTableProcessing();
	endif;

epilog

	delete filterStringsArray;

end;</source>
        <Parameter name="_rowIndex" type="Integer"/>
        <Parameter name="_callPostProcessing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="btnApplyFilterChg_click" id="b98e9c6c-909a-4a32-8e5b-50bf3c6f01ba">
        <updating/>
        <source>btnApplyFilterChg_click( _btn : CMUI_Button ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	cloneListTable : CM_FilterTableList;
	msg : String;
	rowIndex : Integer;
	cloneString : String;

begin

	app.mousePointer :=	Busy;

	cloneListTable := self.myProxiedFilterToUpdate;
	if cloneListTable = null then
		return;
	endif;
	
	cloneListTable.rows := 0;
	foreach rowIndex in 1 to lstFilterProxy.rows do
		cloneString := lstFilterProxy.getCellText(rowIndex,1) &amp; Tab &amp; lstFilterProxy.getCellText(rowIndex,2);
		cloneListTable.addItem( cloneString );
	endforeach;
	
	self.columnFilterApplyFilters();
	
	self.myProxiedFilterToUpdate := null;
	self.frmUpdFilter.visible := false;

epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_btn" type="CMUI_Button"/>
    </JadeMethod>
