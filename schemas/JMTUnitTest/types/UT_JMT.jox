    <JadeMethod name="tIntegerStringLeadingZeros" id="f0775300-64da-42d7-a9ec-fe3a645761e0">
        <source>tIntegerStringLeadingZeros();
// jlgmd1
// cnwkpd1

/*

Purpose:			Check Integer method stringWithLeadingZeros

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2010	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	i				: Integer;
	str				: String;
	
begin
	i := 0;
	assertEqual(i.stringWithLeadingZeros(0), "0".String);
	assertEqual(i.stringWithLeadingZeros(5), "00000");
	
	i := 12345;
	assertEqual(i.stringWithLeadingZeros(0), "12345");
	assertEqual(i.stringWithLeadingZeros(5), "12345");
	assertEqual(i.stringWithLeadingZeros(10), "0000012345");
	
	i := 123456789;
	assertEqual(i.stringWithLeadingZeros(0), "123456789");
	assertEqual(i.stringWithLeadingZeros(5), "123456789");
	assertEqual(i.stringWithLeadingZeros(10), "0123456789");
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveContainer" id="5af768fd-0032-4a81-bc10-0ead867c133d">
        <source>tMoveContainer();
// cnwrs1
// --------------------------------------------------------------------------------
// Created:		23 November 2009 by cnwdad1
//
// Purpose:		Test to validate transaction that are created when a container is
//				moved.  This needs to test instant moves as well as planned moves.
//
//	Tests:		Road to Yard
//				Road to Rail
//				Road to Ship
//				Rail to Yard
//				Rail to Road
//				Rail to Ship
//				Ship to Yard
//				Ship to Road
//				Ship to Rail
//				Yard to Road
//				Yard to Rail
//				Yard to Ship
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/03/2015	cnwdap1		PAR #35874 TFS 265 New parameters for app.myMobileAgent.updateTemperatureOfProxy
// --------------------------------------------------------------------------------
constants
	TERMINAL_AREA	: String = "UTBS1";
	CONTAINER_ID	: String = "CPAT111113";
	VOYAGE_ID		: String = "";
	VEHICLE_ID		: String = "";
	TRAIN_ID		: String = "";
	WAGON_ID		: String = "";
	WAGON_MASTER_ID	: String = "";
	
vars
	bsObj			: CM_BlockStack;
	tiObj			: CM_TrackedItem;
	pxyTI			: CM_TrackedItem;
	moveCont		: CMIF_MoveController;
	locationID		: String;
	loc				: CM_GridController;
	nextLoc			: CM_GridController;
	prevLoc			: CM_GridController;
	termArea		: CM_RTGArea;
	trainObj		: CM_Train;
	wagonClassObj	: CM_WagonClass;
	wagonMasterObj	: CM_WagonMaster;
	
begin
	return;
	
	// Delete everything from previous tests.
	
	self.deleteTerminalArea(TERMINAL_AREA);
	bsObj	:=	addBlockStack(TERMINAL_AREA, 100, null);
	self.deleteContainer(CONTAINER_ID);
	
	// Create some containers
	tiObj	:=	self.addContainer(CONTAINER_ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()), "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	wagonClassObj	:=	app.myRoot.allWagonClasses[WAGON_ID];
	if wagonClassObj &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClassObj);
	endif;
	
	self.deleteTrain(TRAIN_ID,null);

	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_ID];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;
	
	self.deleteRailArea("");
	
	// Start the test.
	
	beginTransaction;
	
	commitTransaction;
	
	// Validate thwe test.
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"5.0",null,null), "Update 1 Failed");		// PAR #35874
	
	assertTrueMsg(tiObj.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = 5.0, "Last Reading temperature not correct (1)");
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"-5.0",null,null), "Update 2 Failed");		// PAR #35874
	
	assertTrueMsg(tiObj.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = -5.0, "Last Reading temperature not correct (2)");
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"0.0",null,null), "Update 3 Failed");		// PAR #35874
	
	assertTrueMsg(tiObj.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = 0.0, "Last Reading temperature not correct (3)");
end;</source>
    </JadeMethod>
    <JadeMethod name="tObjectExtensions" id="1ffc85b3-7f4f-4b7c-8a03-ba57566e9d57">
        <source>tObjectExtensions();
// jlgmd1
// cnwkpd1
/*

Purpose:			Test CM_ObjectExtension code

Parameters:			None

Return Value:		None

Date		Who		Reason
27 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

constants
	ContID			= "UTKD9000001";
	Key1			= "utExtensionKey1";
	Value1			= "value1".String;
	Key2			= "utExtensionKey2";
	Value2			= true.Boolean;
	Key3			= "utExtensionKey3";
	Value3			= 27.Integer;
	Key4			= "utExtensionKey4";
	Value4			= 123.45.Decimal;
	Key5			= "utExtensionKey5";
	Value5			= "value5".Binary;
	Key6			= "utExtensionKey6";
	Value6			= 456.789.Real;
	Key7			= "utExtensionKey7";
	Key8			= "utExtensionKey8";

vars
	ti				: CM_TrackedItem;
	ext				: CM_ObjectExtension;
	value			: Any;
	
begin
	// Just need any old object to hang extension off
	ti := self.addContainer(ContID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// Check no extension exists to start with
	self.assertEqual(ti.getMyObjectExtension(), null);
	
	// Check no values returned to start with
	self.assertEqual(ti.getExtensionObjectValue(Key1), null);
	
	// Check setting a String value
	beginTransaction;
	ti.setExtensionObjectValue(Key1, Value1);
	commitTransaction;
	ext := ti.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := ti.getExtensionObjectValue(Key1);
	self.assertEqual(value, Value1);
	self.assertTrue(value.isKindOf(String));
	
	// Check clearing a String value - should result in the extension being deleted
	beginTransaction;
	ti.setExtensionObjectValue(Key1, null);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), null);
	self.assertEqual(ti.getExtensionObjectValue(Key1), null);
	
	// Check setting a Boolean value
	beginTransaction;
	ti.setExtensionObjectValue(Key2, Value2);
	commitTransaction;
	ext := ti.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := ti.getExtensionObjectValue(Key2).Boolean;
	self.assertEqual(value, Value2);

	// Check setting an Integer value
	beginTransaction;
	ti.setExtensionObjectValue(Key3, Value3);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), ext);
	value := ti.getExtensionObjectValue(Key3);
	self.assertEqual(value, Value3);
	self.assertTrue(value.isKindOf(Integer));

	// Check setting a Decimal value
	beginTransaction;
	ti.setExtensionObjectValue(Key4, Value4);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), ext);
	value := ti.getExtensionObjectValue(Key4);
	self.assertEqual(value, Value4);
	self.assertTrue(value.isKindOf(Decimal));

	// Check setting a Binary value
	beginTransaction;
	ti.setExtensionObjectValue(Key5, Value5);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), ext);
	value := ti.getExtensionObjectValue(Key5);
	self.assertEqual(value, Value5);
	self.assertTrue(value.isKindOf(Binary));

	// Check setting a Real value
	beginTransaction;
	ti.setExtensionObjectValue(Key6, Value6);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), ext);
	value := ti.getExtensionObjectValue(Key6).Real;
	self.assertEqual(value, Value6);
	self.assertTrue(value.isKindOf(Real));

	// Check setting a Reference value
	beginTransaction;
	ti.setExtensionObjectValue(Key7, app.myRoot);
	commitTransaction;
	self.assertEqual(ti.getMyObjectExtension(), ext);
	value := ti.getExtensionObjectValue(Key7);
	self.assertEqual(value, app.myRoot);
	

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tObjectExtensionsConversion" id="7e0cbc45-014f-44cb-855c-8eb87dea0a72">
        <source>tObjectExtensionsConversion();
// cnwrs1
/*
Date		Who		Reason
19/03/2012	cnwcs5	Initial creation - par 29257 EDI Booking Cutoff
29/03/2012	cnwcs5	par 29012 - add in conversion of a reference
*/
constants
	ContID			= "UTKD9000003";
	StringKey		= "utStringKey";
	BooleanKey		= "utBooleanKey";
	IntegerKey		= "utIntegerKey";
	DecimalKey		= "utDecimalKey";
	RefKey			= 'utRefKey';
	IAKey			= "utIAKey";
vars
	ti				: CM_TrackedItem;
	br				: CM_BulkRelease;
	ext				: CM_ObjectExtension;
	value			: Any;
	strValue		: String;
	blnValue		: Boolean;
	intValue		: Integer;
	decValue		: Decimal [12,6];
	refValue		: CM_Object;
	ia				: IntegerArray;
begin
	// Just need any old object to hang extension off
	self.deleteContainer (ContID);
	
	ti := self.addContainer(ContID, self.getOperator("MSK"),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// Check no extension exists to start with
	self.assertEqual(ti.getMyObjectExtension(), null);
	
	// Check no values returned to start with
	self.assertEqual(ti.getExtensionObjectValue(StringKey), null);
	self.assertEqual(ti.getExtensionObjectValue(BooleanKey), null);
	self.assertEqual(ti.getExtensionObjectValue(IntegerKey), null);
	self.assertEqual(ti.getExtensionObjectValue(DecimalKey), null);
	self.assertEqual(ti.getExtensionObjectValue(RefKey), null);
	
	// Check setting a String value
	strValue := 'Test Remarks';
	
	beginTransaction;
	ti.setExtensionObjectValue(StringKey, strValue);
	commitTransaction;
	ext := ti.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := ti.getExtensionObjectValue(StringKey);
	self.assertEqual(value, strValue);
	self.assertTrue(value.isKindOf(String));
		
	// Check setting a Boolean value
	blnValue := true;
	
	beginTransaction;
	ti.setExtensionObjectValue(BooleanKey, blnValue);
	commitTransaction;
	ext := ti.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := ti.getExtensionObjectValue(BooleanKey).Boolean;
	self.assertEqual(value, blnValue);

	// Check setting an Integer value
	intValue := 999;
	
	beginTransaction;
	ti.setExtensionObjectValue(IntegerKey, intValue);
	commitTransaction;
	value := ti.getExtensionObjectValue(IntegerKey);
	self.assertEqual(value, intValue);
	self.assertTrue(value.isKindOf(Integer));

	// Check setting integer array value
	create ia transient;
	
	beginTransaction;
	create br persistent;
	commitTransaction;
	
	ia.add (99);
	ia.add (98);
	
	beginTransaction;
	br.setExtensionObjectValue(IAKey, ia);
	commitTransaction;
	value := br.getExtensionObjectValue(IAKey);
	self.assertNotNull (value);
	self.assertTrue(value.isKindOf(IntegerArray));
	self.assertTrue (value.IntegerArray.size = 2);
	self.assertTrue (value.IntegerArray.first = 99);
	self.assertTrue (value.IntegerArray.last = 98);
		
	// Check setting a reference value
	refValue := self.getOperator ("ANL");
	
	beginTransaction;
	ti.setExtensionObjectValue(RefKey, refValue);
	commitTransaction;
	
	ext := ti.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := ti.getExtensionObjectValue(RefKey).Object;
	self.assertEqual(value, refValue);
	
	// now do conversions
	beginTransaction;
	ti.convertExtensionObjectValue (StringKey, CM_TrackedItem::remarks);
	ti.convertExtensionObjectValue (BooleanKey, CM_TrackedItem::isValid);
	ti.convertExtensionObjectValue (IntegerKey, CM_TrackedItem::quantity);
	br.convertExtensionObjectValue (IAKey, CM_BulkRelease::allAvailabilityGrades);
	ti.convertExtensionObjectValue (RefKey, CM_TrackedItem::myOperator);
	commitTransaction;
	
	// Check correct values returned after conversion
	self.assertEqual(ti.getExtensionObjectValue(StringKey), null);
	self.assertEqual (ti.remarks, strValue);
	
	self.assertEqual(ti.getExtensionObjectValue(BooleanKey), null);
	self.assertEqual (ti.isValid, blnValue);
	
	self.assertEqual(ti.getExtensionObjectValue(IntegerKey), null);
	self.assertEqual (ti.quantity, intValue);
	
	self.assertEqual(br.getExtensionObjectValue(IAKey), null); 
	self.assertEqual (br.allAvailabilityGrades.asCSV(false), ia.asCSV(false));
	
	self.assertEqual(ti.getExtensionObjectValue(RefKey), null);
	self.assertEqual (ti.myOperator, refValue);
	return;
	
	// the following types are yet to be added to this test
	self.assertEqual(ti.getExtensionObjectValue(DecimalKey), null);

epilog
	beginTransaction;
	ti.setRemarks(CrLf &amp; self.createdByUnitTest(ti.remarks), true);						// 10/09/2015 cnwmh5
	delete br;
	commitTransaction;
	
	delete ia;
end;</source>
    </JadeMethod>
    <JadeMethod name="tObjectExtensionsTransient" id="d00ce0c8-ef56-42af-bf2b-9aa637fd3f08">
        <source>tObjectExtensionsTransient();
// jlgmd1
// cnwkpd1
/*

Purpose:			Test CM_ObjectExtension code

Parameters:			None

Return Value:		None

Date		Who		Reason
24 Feb 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms - check new transient code as well

*/

constants
	ContID			= "UTKD9000002";
	Key1			= "utExtensionKey1";
	Value1			= "value1".String;
	Key2			= "utExtensionKey2";
	Value2			= true.Boolean;
	Key3			= "utExtensionKey3";
	Value3			= 27.Integer;
	Key4			= "utExtensionKey4";
	Value4			= 123.45.Decimal;
	Key5			= "utExtensionKey5";
	Value5			= "value5".Binary;
	Key6			= "utExtensionKey6";
	Value6			= 456.789.Real;
	Key7			= "utExtensionKey7";
	Key8			= "utExtensionKey8";

vars
	ti,
	proxyTI			: CM_TrackedItem;
	ext				: CM_ObjectExtension;
	value			: Any;
	ia				: IntegerArray;
begin
	// Just need any old object to hang extension off
	ti := self.addContainer(ContID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	proxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	
	// Check no extension exists to start with
	self.assertEqual(proxyTI.getMyObjectExtension(), null);
	
	// Check no values returned to start with
	self.assertEqual(proxyTI.getExtensionObjectValue(Key1), null);
	
	// Check setting a String value
	proxyTI.setExtensionObjectValue(Key1, Value1);
	ext := proxyTI.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := proxyTI.getExtensionObjectValue(Key1);
	self.assertEqual(value, Value1);
	self.assertTrue(value.isKindOf(String));
	
	// Check clearing a String value - should result in the extension being deleted
	proxyTI.setExtensionObjectValue(Key1, null);
	self.assertEqual(proxyTI.getMyObjectExtension(), null);
	self.assertEqual(proxyTI.getExtensionObjectValue(Key1), null);
	
	// Check setting a Boolean value
	proxyTI.setExtensionObjectValue(Key2, Value2);
	ext := proxyTI.getMyObjectExtension();
	self.assertNotEqual(ext, null);
	value := proxyTI.getExtensionObjectValue(Key2).Boolean;
	self.assertEqual(value, Value2);

	// Check setting an Integer value
	proxyTI.setExtensionObjectValue(Key3, Value3);
	self.assertEqual(proxyTI.getMyObjectExtension(), ext);
	value := proxyTI.getExtensionObjectValue(Key3);
	self.assertEqual(value, Value3);
	self.assertTrue(value.isKindOf(Integer));

	// Check setting a Decimal value
	proxyTI.setExtensionObjectValue(Key4, Value4);
	self.assertEqual(proxyTI.getMyObjectExtension(), ext);
	value := proxyTI.getExtensionObjectValue(Key4);
	self.assertEqual(value, Value4);
	self.assertTrue(value.isKindOf(Decimal));

	// Check setting a Binary value
	proxyTI.setExtensionObjectValue(Key5, Value5);
	self.assertEqual(proxyTI.getMyObjectExtension(), ext);
	value := proxyTI.getExtensionObjectValue(Key5);
	self.assertEqual(value, Value5);
	self.assertTrue(value.isKindOf(Binary));

	// Check setting a Real value
	proxyTI.setExtensionObjectValue(Key6, Value6);
	self.assertEqual(proxyTI.getMyObjectExtension(), ext);
	value := proxyTI.getExtensionObjectValue(Key6).Real;
	self.assertEqual(value, Value6);
	self.assertTrue(value.isKindOf(Real));

	// Check setting a Reference value
	proxyTI.setExtensionObjectValue(Key7, app.myRoot);
	self.assertEqual(proxyTI.getMyObjectExtension(), ext);
	value := proxyTI.getExtensionObjectValue(Key7);
	self.assertEqual(value, app.myRoot);
	
	// Check setting an IntegerArray value
	create ia transient;
	ia.add (1); ia.add (2); ia.add (3);
	proxyTI.setExtensionObjectValue (Key8, ia);
	value := proxyTI.getExtensionObjectValue (Key8);
	self.assertNotNull (value);
	self.assertTrue (value.isKindOf(IntegerArray));
	self.assertTrue (value.IntegerArray.size = 3);
epilog
	delete proxyTI;
	delete ia;
end;</source>
    </JadeMethod>
    <JadeMethod name="tScannedCargoIdsConv" id="37c42212-3acb-4cfb-ae99-2ddf28c603bc">
        <source>tScannedCargoIdsConv();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	rawScannedIdArray : StringArray;
	expectdIdArray : StringArray;
	expectdAltIdArray : StringArray;
	
	rawScannedId : String;
	expectdId : String;
	expectdAltId : String;
	id : String;
	index : Integer;
	
	cmifID : CMIF_IDConversion;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	
	textBox : TextBox;
	cargoType : Integer;
	imexStatus : Integer;
	voyage : CM_Voyage;
	
	reference : Integer;

begin

	create textBox transient;

	self.doCargoIdConversionSetup( true, true );
	
	terminal := self.getTerminal;
	
	create rawScannedIdArray transient;
	create expectdIdArray transient;
	create expectdAltIdArray transient;
	
	rawScannedIdArray.add( "*MMEMC71XXGH031214*" );  // VIN number wrapped in asterix(s)
	expectdIdArray.add( "MMEMC71XXGH031214" );
	expectdAltIdArray.add( "MMEMC71XXGH031214" );
	
	rawScannedIdArray.add( "JTJHY00W6G421386011" );	// VIN with added suffix
	expectdIdArray.add( "JTJHY00W6G4213860" );
	expectdAltIdArray.add( "JTJHY00W6G4213860" );
	
	rawScannedIdArray.add( "I1C3CCCABXGN177954" );	// VIN with 'I' prefix
	expectdIdArray.add( "1C3CCCABXGN177954" );
	expectdAltIdArray.add( "1C3CCCABXGN177954" );
	
	rawScannedIdArray.add( "DUMMYLENGTHGTRTHAN20ABCDEFGHIJKL" );  // greater than 20 characters, outside of the specific rules, should just truncate at 20 and 30 respectively
	expectdIdArray.add( "DUMMYLENGTHGTRTHAN20" );
	expectdAltIdArray.add( "DUMMYLENGTHGTRTHAN20ABCDEFGHIJ" );
	
	//08 Aug 2016	NDL	TFS 2504
	rawScannedIdArray.add( "MR1KU8FS2G0011903B" );	// Toyota (from Thailand?)
	expectdIdArray.add( "MR1KU8FS2G0011903" );
	expectdAltIdArray.add( "MR1KU8FS2G0011903" );
	
	//10 Aug 2016	NDL TFS 2519
	rawScannedIdArray.add( "C52 251131" );	//Hyundai Santa Fei
	expectdIdArray.add( "251131" );
	expectdAltIdArray.add( "251131" );
	
	reference := HookType_CargoIdConversion; // here to provide some sort of reference....
	
	foreach index in 1 to rawScannedIdArray.size do
	
		rawScannedId := rawScannedIdArray[index];
		expectdId := expectdIdArray[index];
		expectdAltId := expectdAltIdArray[index];
	
		//using basic cmif returning string for cargo id
		create cmifID transient;
		cmifID.scannedValue := rawScannedId;
		cmifID.myTerminal := terminal;
		cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567
		id := app.convertScannedCargoId( null, null, false, cmifID );
		delete cmifID;
		
		self.assertTrueMsg( expectdId = id, "Test 1, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdId &amp; "', but found '" &amp; id &amp; "'");
		
		//using basic cmif returning string for alternate id
		create cmifID transient;
		cmifID.scannedValue := rawScannedId;
		cmifID.myTerminal := terminal;
		cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567
		id := app.convertScannedCargoId( null, null, true, cmifID );
		delete cmifID;
		
		self.assertTrueMsg( expectdAltId = id, "Test 2, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdAltId &amp; "', but found '" &amp; id &amp; "'");
			
		//using pre-populated textbox and termnal for cargo id
		textBox.text := rawScannedId;
		app.convertScannedCargoId( terminal, textBox, false, null );
		id := textBox.text;
		
		self.assertTrueMsg( expectdId = id, "Test 3, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdId &amp; "', but found '" &amp; id &amp; "'");
		
		//using pre-populated textbox and termnal for alternate id
		textBox.text := rawScannedId;
		app.convertScannedCargoId( terminal, textBox, true, null );
		id := textBox.text;
		
		self.assertTrueMsg( expectdAltId = id, "Test 4, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdAltId &amp; "', but found '" &amp; id &amp; "'");
		
		if rawScannedId = "C52 251131" then
			// this is the one that is truncated and will be using reverse dictionary
			//following checks not appropriate.
			continue;
		endif;
		
		// find the ti we set up, so we can grab the details from it
		ti := terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(expectdId,null);
		self.assertTrueMsg( ti &lt;&gt; null, "Test 5 &amp; 6  setup, Step " &amp; index.String &amp; ", Didn't find cargo item '" &amp; expectdId &amp; "'");
		
		self.assertTrueMsg( ti.id = expectdId, "Test 5 &amp; 6  setup, Step " &amp; index.String &amp; ", Found wrong cargo item '" &amp; ti.id &amp; "' instead of '" &amp; expectdId &amp; "'");
		cargoType := ti.cargoType;
		imexStatus := ti.getImExStatus;
		voyage := ti.myVoyage;
		
		//using all cmif options returning string for cargo id
		create cmifID transient;
		cmifID.scannedValue := rawScannedId;
		cmifID.myTerminal := terminal;
		cmifID.cargoType := cargoType;
		cmifID.isAlternateId := false;
		cmifID.myVoyage := voyage;
		cmifID.imexStatus := imexStatus;
		cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567
		id := app.convertScannedCargoId( null, null, false, cmifID );
		delete cmifID;
		
		self.assertTrueMsg( expectdId = id, "Test 5, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdId &amp; "', but found '" &amp; id &amp; "'");
		
		//using all cmif options returning string for alternate id
		create cmifID transient;
		cmifID.scannedValue := rawScannedId;
		cmifID.myTerminal := terminal;
		cmifID.cargoType := cargoType;
		cmifID.isAlternateId := true;
		cmifID.myVoyage := voyage;
		cmifID.imexStatus := imexStatus;
		cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567
		id := app.convertScannedCargoId( null, null, false, cmifID );
		delete cmifID;
		
		self.assertTrueMsg( expectdAltId = id, "Test 6, Step " &amp; index.String &amp; ", input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdAltId &amp; "', but found '" &amp; id &amp; "'");
	
	endforeach;
	
	self.doCargoIdConversionSetup( false, true );

epilog

	delete rawScannedIdArray;
	delete expectdIdArray;
	delete expectdAltIdArray;
	delete cmifID;
	delete textBox;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSplitTrackedItem" id="e541ce0b-11a5-4a74-96b5-e3664782fb9d">
        <source>tSplitTrackedItem();
// cnwmh5
// cnwrd1
/*

Purpose:			to test splitting tracked item.

Parameters:			

Return Value:		


Date			Who		Reason
08 April 2010	cnwrd1	Initial creation
24/09/2012		ccnwmh5	#30120/#29876 - check isSplitByQuantity

*/
constants
	CONTAINER_ID	: String = "SPLT12345";
	SPLIT1 			: String = "SPLT12345_1";
	SPLIT2 			: String = "SPLT12345_2";
	SPLIT3 			: String = "SPLT12345_3";
	CONTAINER_ID2	: String = "SPLIT54321";
	SPLIT2A			: String = "SPLT54321_1";
	SPLIT2B			: String = "SPLT54321_2";
	SPLIT2C			: String = "SPLT54321_3";
	SPLIT2C1		: String = "SPLT54321_4";
	SPLIT2C2		: String = "SPLT54321_5";
vars
	blockStack : CM_BlockStack;
	mainTI,
	ti : CM_TrackedItem;
	tisToCreate : CMIF_TISplitSet;
	splitee1, splitee2, splitee3, splitee4, splitee5 : CMIF_TISplit;
	root: CM_Root;
	result : Decimal[14,4];
begin 

	root := CM_Root.firstInstance;
	
	deleteTerminalArea("SPLIT1");
	blockStack := addBlockStack("SPLIT1", 10, null);
	
	self.deleteContainer(CONTAINER_ID);
	self.deleteContainer(SPLIT1);
	self.deleteContainer(SPLIT2);
	self.deleteContainer(SPLIT3);
	
	self.deleteContainer(CONTAINER_ID2);								// 24/09/2012 cnwmh5 #30120/#29876
	self.deleteContainer(SPLIT2A);
	self.deleteContainer(SPLIT2B);
	self.deleteContainer(SPLIT2C);
	self.deleteContainer(SPLIT2C1);
	self.deleteContainer(SPLIT2C2);
	
	
	//********************************************************//
	// test by weight split                                   //
	//********************************************************//
	mainTI	:=	self.addContainer(CONTAINER_ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()), "2200", "ALUM", TI_IMEX_STATUS_STORAGE).CM_Container;
	move(mainTI, blockStack);
	
	create tisToCreate transient;
	create splitee1 transient;
	splitee1.id := SPLIT1;
	splitee1.isSplitByWeight := true;
	splitee1.weight := 600;
	splitee1.myLocation := mainTI.myPrimaryActualLocation;
	create splitee2 transient;
	splitee2.id := SPLIT2;
	splitee2.isSplitByWeight := true;
	splitee2.weight := 400;
	splitee2.myLocation := mainTI.myPrimaryActualLocation;
	create splitee3 transient;
	splitee3.id := SPLIT3;
	splitee3.isSplitByWeight := true;
	splitee3.weight := 1000;
	splitee3.myLocation := mainTI.myPrimaryActualLocation;
	tisToCreate.add(splitee1);
	tisToCreate.add(splitee2);
	tisToCreate.add(splitee3);
	
	//do the split
	self.splitTI(mainTI ,tisToCreate );
	

	ti := self.getTerminal.lookupTrackedItem( SPLIT1 , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 600;
	self.assertEqual(ti.totalWeight, result);
	
	ti := self.getTerminal.lookupTrackedItem( SPLIT2 , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 400;
	self.assertEqual(ti.totalWeight, result);
	
	ti := self.getTerminal.lookupTrackedItem( SPLIT3 , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 1000;
	self.assertEqual(ti.totalWeight, result);
	
	
	//********************************************************//
	// test by quantity split                                 //
	//********************************************************//
	// 24/09/2012 cnwmh5 #30120/#29876
	self.opts.purge();
	self.opts.addAssoc("quantity", 20);
	mainTI	:=	self.addContainer(CONTAINER_ID2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()), "2200", "ALUM", TI_IMEX_STATUS_STORAGE).CM_Container;
	move(mainTI, blockStack);
	
	tisToCreate.purge;
	create splitee1 transient;
	splitee1.id := SPLIT2A;
	splitee1.isSplitByQuantity := true;
	splitee1.quantity := 6;
	splitee1.myLocation := mainTI.myPrimaryActualLocation;
	create splitee2 transient;
	splitee2.id := SPLIT2B;
	splitee2.isSplitByQuantity := true;
	splitee2.quantity := 4;
	splitee2.myLocation := mainTI.myPrimaryActualLocation;
	create splitee3 transient;
	splitee3.id := SPLIT2C;
	splitee3.isSplitByQuantity := true;
	splitee3.quantity := 10;
	splitee3.myLocation := mainTI.myPrimaryActualLocation;
	tisToCreate.add(splitee1);
	tisToCreate.add(splitee2);
	tisToCreate.add(splitee3);
	
	//do the split
	self.splitTI(mainTI ,tisToCreate );

	ti := self.getTerminal.lookupTrackedItem( SPLIT2A , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 6;
	self.assertEqual(ti.totalQuantity, result.Integer);
	
	ti := self.getTerminal.lookupTrackedItem( SPLIT2B , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 4;
	self.assertEqual(ti.totalQuantity, result.Integer);
	
	ti := self.getTerminal.lookupTrackedItem( SPLIT2C , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 10;
	self.assertEqual(ti.totalQuantity, result.Integer);
	
	// split the last one (SPLIT2C)
	mainTI := ti;
	tisToCreate.purge;
	create splitee4 transient;
	splitee4.id := SPLIT2C1;
	splitee4.isSplitByQuantity := true;
	splitee4.quantity := 3;
	splitee4.myLocation := mainTI.myPrimaryActualLocation;
	create splitee5 transient;
	splitee5.id := SPLIT2C2;
	splitee5.isSplitByQuantity := true;
	splitee5.quantity := 7;
	splitee5.myLocation := mainTI.myPrimaryActualLocation;
	tisToCreate.add(splitee4);
	tisToCreate.add(splitee5);
	
	//do the split
	self.splitTI(mainTI ,tisToCreate );

	ti := self.getTerminal.lookupTrackedItem( SPLIT2C1 , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 3;
	self.assertEqual(ti.totalQuantity, result.Integer);
	
	ti := self.getTerminal.lookupTrackedItem( SPLIT2C2 , TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);	
	self.assertNotNull(ti);
	result := 7;
	self.assertEqual(ti.totalQuantity, result.Integer);
	
	
epilog
	tisToCreate.purge();
	delete tisToCreate;
	
	app.myPassport.getTIAuditController().initialiseTransaction;	// deletes the subTransactionController transient.
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStringArrayXmlConversion" id="3a5de8f5-c325-47c9-aec0-814439cdd470">
        <source>tStringArrayXmlConversion();
// jlgmd1
/*

Purpose:			Test mechanism to convert StringArray to/from XML, and to/from long strings

Date		Who		Reason
27 Feb 2012	cnwkpd1	23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
22 Mar 2024	navmd1	TFS 63103 Allow large .NET errors to be displayed in the System Alerts details screen

*/

constants
	HeaderTag = "array";
	DetailTag = "entry";
	
vars
	sa1,
	sa2,
	sa3				: StringArray;
	xmlString,
	xmlString2,
	longString,
	longString2		: String;
	s1,
	s2				: String;
	i				: Integer;
	
begin
	// Firstly check an empty array
	create sa1 transient;
	xmlString := sa1.asXmlString(HeaderTag, DetailTag);
	
	create sa2 transient;
	sa2.setFromXmlString(xmlString, HeaderTag, DetailTag);
	
	self.assertTrue(sa2.isEmpty());
	
	// Now populate with test data
	sa1.add("standard text in entry 1");
	sa1.add("entry 3 is null");
	sa1.add(null);
	sa1.add("entry 4 has some &lt;cdata&gt; characters in it");
	sa1.add("entry 5 has multiple " &amp; CrLf &amp; "lines of text in it");

	// Convert to and from XML
	xmlString := sa1.asXmlString(HeaderTag, DetailTag);
	
	sa2.setFromXmlString(xmlString, HeaderTag, DetailTag);
	
	// Check the two arrays are the same
	self.assertEqual(sa1.size(), sa2.size());
	foreach i in 1 to sa1.size() do
		self.assertEqualMsg(sa1[i], sa2[i], "Array entry number " &amp; i.String);
	endforeach;

	// Check that the XML value returned from array 2 is the same as the original one
	xmlString2 := sa2.asXmlString(HeaderTag, DetailTag);
	
	self.assertEqual(xmlString, xmlString2);
	
	// Check set clears array first, by using target array again
	sa2.setFromXmlString(xmlString, HeaderTag, DetailTag);
	self.assertEqual(sa1.size(), sa2.size());
	
	// Now test long string conversion as well
	longString := sa1.asLongString();
	self.assertEqual(longString, sa2.asLongString());
	
	sa2.setFromLongString(longString, null);
	self.assertEqual(longString, sa2.asLongString);
	
	// Finally test taking XML from one array, storing as a long string in a second, then unbusting it into a
	// third, and comparing the result
	xmlString := sa1.asXmlString(HeaderTag, DetailTag);
	sa2.setFromLongString(xmlString, null);
	
	longString := sa2.asLongString();
	
	create sa3 transient;
	sa3.setFromXmlString(longString, HeaderTag, DetailTag);
	
	// Check the two arrays are the same
	self.assertEqual(sa1.size(), sa3.size());
	foreach i in 1 to sa1.size() do
		self.assertEqualMsg(sa1[i], sa3[i], "Array entry number " &amp; i.String);
	endforeach;
	
epilog
	delete sa1;
	delete sa2;
	delete sa3;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStringToLongConversion" id="60bcb937-d959-4e50-a998-b7cfb2b480e5">
        <source>tStringToLongConversion();
// jlgmd1
// cnwkpd1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Apr 2010	cnwkpd1	PAR #23610 - 64-bit conversion

*/

vars
	
begin
	self.uStringToLong(null, 0);
	
	self.uStringToLong("10", 16);

	self.uStringToLong("0A", 10);

	self.uStringToLong("BC614E", 12345678);

	self.uStringToLong("ZZZZ", 0);

	self.uStringToLong("AZZZZ", 10);

	self.uStringToLong("AZAZZZ", 10);

	self.uStringToLong(" 0a", 10);

	self.uStringToLong("-0a", -10);

	self.uStringToLong("-0a-", -10);

	self.uStringToLong("--0a-", 0);

	self.uStringToLong("+0a-", 10);
	
	self.uStringToLong("7048860DDF79", Max_Integer);

	self.uStringToLong("-7048860DDF79", Min_Integer);
	
	self.uStringToLong("x", 0);
	
	self.uStringToLong("-", 0);
	
	self.uStringToLong("+", 0);
	
	self.uStringToLong("0", 0);
	
	self.uStringToLong("F", 15);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tStringTrimWhiteSpace" id="8a0196d0-5b14-4d7b-9e81-e08eee670df4">
        <source>tStringTrimWhiteSpace();
// jlgmd1
// cnwkpd1
/*

Purpose:			Check String method trimWhiteSpace


Date		Who		Reason
26 Oct 2011	cnwkpd1	Framework performance

*/

vars

begin
	self.assertEqual(null.String.trimWhiteSpace(), null.String);
	self.assertEqual("A".String.trimWhiteSpace(), "A".String);
	self.assertEqual("ABC".String.trimWhiteSpace(), "ABC".String);
	self.assertEqual("A B C".String.trimWhiteSpace(), "A B C".String);
	self.assertEqual((Tab &amp; "ABC".String).trimWhiteSpace(), "ABC".String);
	self.assertEqual((Tab &amp; "ABC".String &amp; Tab).trimWhiteSpace(), "ABC".String);
	self.assertEqual((Cr &amp; "ABC".String &amp; Cr).trimWhiteSpace(), "ABC".String);
	self.assertEqual((CrLf &amp; "ABC".String &amp; CrLf).trimWhiteSpace(), "ABC".String);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tStringasTimeStampJMT" id="d9a7e7a7-b5e4-4bf5-9831-1a22b957b575">
        <source>tStringasTimeStampJMT();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:	22 January 2009 By Graeme Black cnwgb1
// Purpose:	Tests fixes for PAR 18780 - Making String::asTimeStampJMT()
//          more robust
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	ts : TimeStamp;
	strTime : String;
	date : Date;
begin
	strTime := null;
	assertNull(strTime.asTimeStampJMT() );
	assertNull("".asTimeStampJMT() );
	assertNull("PAR18780".asTimeStampJMT() );
	ts := app.actualTimeServer;			// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	ts := ts.truncateToMinute();
	strTime := ts.shortCurrentLocaleFormat();

	assertEqual( strTime.asTimeStampJMT(), ts );
	
	date := ts.date;
	strTime := date.asStringJMT();
	ts.setTime(null);
	
	assertEqual( strTime.asTimeStampJMT(), ts );
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tTimeZoneHelper" id="30598ff7-5784-45b7-843c-a9c50289410c">
        <source>tTimeZoneHelper();
// jlgmd1
/*	cnwkpd1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

constants
	NZST			= "New Zealand Standard Time";
	AEST			= "AUS Eastern Standard Time";
	
vars
	timeZoneSupport	: CMIF_TimeZoneHelper;
	systemTimeZoneId : String;
	timeZones : CMIF_TimeZoneInfoArray;
	timeZone : CMIF_TimeZoneInfo;
	ts, ts1, ts2 : TimeStamp;
	foundSystem : Boolean;
	
begin
	timeZoneSupport := app.myTimeZoneHelper;
	
	// Check app initialisation is OK
	self.assertNotNull(timeZoneSupport);
	self.assertNotNull(timeZoneSupport.myTimeZoneHelper);
	
	// Get the system TimeZone, should be NZ
	systemTimeZoneId := timeZoneSupport.getSystemTimeZoneID();
	app.writeLog("System TimeZone reported as |" &amp; systemTimeZoneId &amp; "|", null);
	self.assertEqual(systemTimeZoneId, NZST);
	
	// Get all the TimeZones defined
	create timeZones transient;
	timeZoneSupport.getSystemTimeZones(timeZones);
	
	app.writeLog(timeZones.size().String &amp; " system TimeZones found", null);
	self.assertNotNull(timeZones.size());
	
	foreach timeZone in timeZones do
		app.writeLog("|" &amp; timeZone.id &amp; "|" &amp; timeZone.displayName &amp; "|", null);
		if timeZone.id = systemTimeZoneId then
			foundSystem := true;
		endif;
	endforeach;
	self.assertTrue(foundSystem);
	
	// Check a known time conversion
	ts := "01/03/2016 10:00".TimeStamp;
	ts1 := timeZoneSupport.convertTime(ts, NZST, AEST);
	app.writeLog(ts.String &amp; " " &amp; NZST &amp; " converts to " &amp; ts1.String &amp; " " &amp; AEST, null);	
	self.assertEqual(ts1, ts.addHours(-2));
		
	// Check a known time conversion to and from UTC
	ts := "01/03/2016 10:00".TimeStamp;
	ts1 := timeZoneSupport.convertTimeToUtc(ts, NZST);
	app.writeLog(ts.String &amp; " " &amp; NZST &amp; " converts to " &amp; ts1.String &amp; " UTC", null);	
	self.assertEqual(ts1, ts.addHours(-13));
	
	ts2 := timeZoneSupport.convertTimeFromUtc(ts1, NZST);
	app.writeLog(ts1.String &amp; " UTC converts to " &amp; ts2.String &amp; " " &amp; NZST, null);	
	self.assertEqual(ts2, ts);
	
epilog
	if timeZones &lt;&gt; null then
		timeZones.purge();
		delete timeZones;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckForIcons" id="82a87a7c-5068-42aa-b575-23af8a24ca79">
        <source>uCheckForIcons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2012	cnwmc5	Initial creation

*/

vars
	userToolbarMenu			: CM_MenuUserToolbar;
	sysMenu					: CM_MenuDtlSystem;
	toolbarMenu				: CM_MenuToolbar;
	
	output					: String;
begin
	
	foreach sysMenu in CM_MenuDtlSystem.instances discreteLock do
		//Toolbar checks for users
		foreach userToolbarMenu in CM_MenuUserToolbar.instances where userToolbarMenu.mySystemToolbar.myMenuDtlSystem = sysMenu do
			if userToolbarMenu.pictureIcon = null or userToolbarMenu.pictureButton = null then
				output := output &amp; "Toobar icon missing: " &amp; userToolbarMenu.String &amp; " - " &amp; userToolbarMenu.heading;
				if userToolbarMenu.myMenuUserToolbarRoot &lt;&gt; null then
					output := output &amp; " - " &amp; userToolbarMenu.myMenuUserToolbarRoot.myUser.code &amp; " - " &amp; 
						userToolbarMenu.myMenuUserToolbarRoot.myUser.userName &amp; CrLf;
				else
					output := output &amp; CrLf;
				endif;
			endif;
		endforeach;
		
		//Toolbar checks
		foreach toolbarMenu in CM_MenuToolbar.instances where toolbarMenu.myMenuDtlSystem = sysMenu do
			if toolbarMenu.pictureIcon = null or toolbarMenu.pictureButton = null then
				output := output &amp; "Toolbar icon missing: " &amp; toolbarMenu.String &amp; " - " &amp; toolbarMenu.heading &amp; CrLf;
			endif;
		endforeach;
	endforeach;
	
	//Navigation checks
	foreach sysMenu in CM_MenuDtlSystem.instances discreteLock do
		if sysMenu.pictureIcon = null then
			output := output &amp; "Navigation icon missing: " &amp;  sysMenu.String &amp; " - " &amp; sysMenu.heading &amp; CrLf;
		endif;
	endforeach;
	
	self.assertNullMsg(output, output);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckMethodsText" id="75296f68-396b-4e90-b2e9-7d476f624384">
        <source>uCheckMethodsText();

/*

Purpose:		Checks to see what's in a methods text	

Parameters:			

Return Value:		


Date			Who		Reason
29 April 2011	cnwmh5	Initial creation

*/

vars

	klass		: Class;
	meth		: Method;
	
	classes		: ClassColl;
	methods		: MethodNDict;

begin

	klass := currentSchema.getClass(UT_DSL.name);
	create classes transient;
	klass.allSubclasses(classes);
	
	create methods transient;
	
	foreach klass in classes do
		
		methods.clear();
		klass.getMethods(methods);
		
		foreach meth in methods do
			if meth.text &lt;&gt; null then
				app.writeStatement(klass.name &amp; '::' &amp; meth.name &amp; Tab &amp; meth.text);
			endif;
		endforeach;
		
	endforeach;

epilog

	delete methods;
	delete classes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckTICreationTimeAllToday" id="b78f1625-111c-4008-83e2-f50c0d543f79">
        <source>uCheckTICreationTimeAllToday();

/*

Purpose:		Checks that all ti's are created today	

Parameters:			

Return Value:		


