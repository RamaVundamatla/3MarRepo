    <JadeMethod name="showTrainOutwardDefinition" id="ef0c184f-c810-4f14-8b01-63e3e1d001f6">
        <source>showTrainOutwardDefinition( _train : CM_Train; _masterMenuAction : CMUI_MenuAction );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars
	form : YRD_TrainOutwardDefinition;
begin
	if _train = null then
		return;
	endif;
	
	form := app.loadForm(YRD_TrainOutwardDefinition, YRD_Assistant, false, false, false, self.myTerminal, _masterMenuAction).YRD_TrainOutwardDefinition;
	if form = null then
		return;
	endif;

	form.myTrain := _train;
	form.showModal();
epilog

