    <JadeMethod name="load" id="7c0a02a4-67aa-4cb7-89bd-35b807d839bd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2022	navpw1	Initial creation

*/

vars

begin
	self.setupForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="run" id="a3677383-bb31-405c-b420-0c63443e17d4">
        <updating/>
        <source>run() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2022	navpw1	Initial creation

*/

vars

begin
	self.controlBox := false;
	self.lblModalMessage.caption := "Running Source Comparison";
	self.frmModalDialog.visible := true;
	self.lblModalInfo.caption := "";
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAdditionalInfo" id="d6de0458-4647-41cb-b1c8-1f0286386237">
        <updating/>
        <source>setAdditionalInfo(_text : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2023	navmd1	Initial creation

*/

vars

begin
	self.lblModalInfo2.caption := _text;
	self.lblModalInfo2.visible := true;
	self.lblModalInfo2.refreshNow();
epilog

end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="08d754f2-9ffa-4f42-8951-ae4ed6abc690">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2022	navpw1	Initial creation

*/

vars

begin
	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 400;
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.top := 50;

	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.lblModalMessage.move(0,10,self.frmModalDialog.width,40);
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.move(0,60,self.frmModalDialog.width,20);
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.pbProgressBar.move(10,40,self.frmModalDialog.width-25,self.pbProgressBar.height);
	self.pbProgressBar.height := 20;		// set in painter when able
	self.pbProgressBar.foreColor := Blue;
	self.pbProgressBar.backColor := White;
	self.pbProgressBar.thinClientUpdateInterval := 1000;
	self.pbProgressBar.showTaskBarProgress := true;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.pbProgressBar.visible := true;
	self.controlBox := false;
	self.lblModalMessage.caption := "Running Source Comparison";
	self.frmModalDialog.visible := true;
	self.lblModalInfo.caption := "";
	
	self.lblModalInfo2.move(0, self.frmModalDialog.top + self.frmModalDialog.height + 20, self.frmModalDialog.width, 20);
	self.lblModalInfo2.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo2.visible := false;
	self.lblModalInfo2.caption := "";
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPb" id="df25b272-0094-4ad1-adda-01c8ceac22fc">
        <source>setupPb(_filesToProcess : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2022	navpw1	Initial creation

*/

vars

begin
	self.pbProgressBar.partsInJob := _filesToProcess + 1;
epilog

end;</source>
        <Parameter name="_filesToProcess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupPbCleanup" id="c5f7f077-56ca-4e93-93c6-d27a7f3cca93">
        <source>setupPbCleanup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navpw1	Initial creation

*/

vars

begin
	self.lblModalInfo.caption := "Cleaning up old Source Compare Reports";
	self.pbProgressBar.partsInJob := 100;
	self.pbProgressBar.partsDone := 0;
	self.pbProgressBar.doWindowEvents(2);
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(0);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stop" id="ce366919-96d1-4bc1-9dd0-23e64e2b8e9d">
        <updating/>
        <source>stop() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2022	navpw1	Initial creation

*/

vars

begin
	self.controlBox := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updatePb" id="938d9391-9545-4d82-8252-057b1695a05f">
        <source>updatePb(_caption : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2022	navpw1	Initial creation

*/

vars

begin
	self.lblModalInfo.caption := _caption;
	self.pbProgressBar.partsDone := self.pbProgressBar.partsDone + 1;
	self.pbProgressBar.refreshNow();
	//self.pbProgressBar.doWindowEvents(2);
	/*if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(0);
	endif;*/
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
</GUIClass>
