    <JadeMethod name="doHandleNotification" id="6d7856f8-fb9e-4662-8100-288a074c959b">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58238: UI - Notifications
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
*/

vars
	dataLine	: String;
	ownershipDtl : CM_OwnershipChangeDetail;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_OwnershipChangeDetail) then
		ownershipDtl := userInfo.CM_OwnershipChangeDetail;
	elseif theObject.isKindOf(CM_OwnershipChangeDetail) then
		ownershipDtl := theObject.CM_OwnershipChangeDetail;
	endif;
	
	if event = Event_COODtlCreate then
		if ownershipDtl &lt;&gt; null then			
			self.displayDetails();
			//self.displayStatus(); //09/08/2023 navmv20 CR 59391 Task 59417
		endif;
	elseif event = Event_COODtlUpdate then
		if ownershipDtl &lt;&gt; null then
			self.tblData.findObjectInRow(ownershipDtl,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := ownershipDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_COODtlDelete then
		self.tblData.removeItemObject(ownershipDtl);
	endif;
	self.displayStatus();//09/08/2023 navmv20 CR 59391 Task 59417
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doMeasurementVolume" id="33852301-0ad4-455a-9d23-8f6ac9c29582">
        <updating/>
        <source>doMeasurementVolume() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2025	navkc1 JIRA Bug MTN-33535: MTN - Ownership Change Detail - Current Weight / Volume issue
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;

begin
	
	self.myMeasurementTypeForVolume :=  app.getDefaultMeasurementForType(Type_Volume);
	
	ti := self.allTiSet.first();
	
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		ti :=  ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
		
		if ct &lt;&gt; null then
			if ct.isBulk then
				if ct.myVolumeMeasurementType &lt;&gt; null then
					self.myMeasurementTypeForVolume :=  ct.myVolumeMeasurementType;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMeasurementWeight" id="01e31c72-23c5-42d5-9317-d43c1a0d8bf8">
