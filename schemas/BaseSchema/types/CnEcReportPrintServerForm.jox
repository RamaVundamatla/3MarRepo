    <JadeMethod name="tblQueue_displayRow" id="d2d4c74c-1cf8-4750-8791-640872008dd2">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueue_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
