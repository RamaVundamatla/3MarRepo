    <JadeMethod name="initTblData" id="516ef5c3-7d3f-4cec-a301-5b55366c72b2">
        <source>initTblData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	#cnwdz2	 par21593

*/

vars

begin
	self.tblData.setTblDataEntRowsFromDef(self.getTblDataDef());
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="71378ebc-ccf0-4eac-bc4d-27226e99bffb">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/

vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
