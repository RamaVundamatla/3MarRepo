    <JadeMethod name="handleMenuItemClick" id="06ffa4e6-c707-4309-bd97-a65bc0cc9c9e">
        <source>handleMenuItemClick( menuItem : MenuItem input );

/*

Purpose:			

Parameters:			A method called 'clickSelectorMenuItem', will have been called on the form when a click occured
					on one of our cloned menu items.
					That method, calls this one.

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890
12 Oct 2012		cnwer1 par 30571
*/

vars

	enqController : CM_EnquiryController;
	hasResults : Boolean;
	objArray : ObjectArray;
	invalidObject : Boolean;
	enqObj : Object;
begin

	if menuItem = null then
		return;
		
	elseif menuItem.caption = app.getErrorString(Close) then
		return;
		
	elseif menuItem.caption = app.getErrorString(Clear_query) then
		self.clickBtnClear( false );
		return;
		
	elseif menuItem.caption[1:6] = app.getErrorString(Run_Query)[1:6] then
		self.clickBtnRun();
		return;
		
	elseif menuItem.caption[1:6] = app.getErrorString(Edit_query)[1:6] then
		self.editQuery();
		return;
		
	endif;
	
	self.form.CM_BaseForm.getEnquiryController( enqController );
	on Exception do app.handleDeletedObject( exception, enqController, invalidObject);
	hasResults := enqController &lt;&gt; null and not enqController.allObjects.isEmpty and self.lblSelected.caption &lt;&gt; null;
	if not hasResults or invalidObject then
		return;
	endif;
	
	if menuItem.caption = app.getErrorString(Send_enquiry) then
		create objArray transient;
		//epr par 30571
		foreach enqObj in  enqController.allObjects.CM_ObjectSet do
			if enqObj.isKindOf(CM_TrackedItem) then
				objArray.add(enqObj);
			elseif enqObj.isKindOf(CM_TITransaction) then
				if enqObj.CM_TITransaction.myTrackedItem &lt;&gt; null then
					objArray.add(enqObj.CM_TITransaction.myTrackedItem);
				endif;
			endif;
		endforeach;
		self.sendToEnquiry( objArray );
		return;
	
	elseif menuItem.caption = app.getErrorString(Send_report) then
		create objArray transient;
		//epr par 30571
		foreach enqObj in  enqController.allObjects.CM_ObjectSet do
			if enqObj.isKindOf(CM_TrackedItem) then
				objArray.add(enqObj);
			elseif enqObj.isKindOf(CM_TITransaction) then
				if enqObj.CM_TITransaction.myTrackedItem &lt;&gt; null then
					objArray.add(enqObj.CM_TITransaction.myTrackedItem);
				endif;
			endif;
		endforeach;
		self.sendToReport( objArray );
		return;
	
	elseif menuItem.caption = app.getErrorString(Summarise_all) then
		create objArray transient;
		//epr par 30571
		foreach enqObj in  enqController.allObjects.CM_ObjectSet do
			if enqObj.isKindOf(CM_TrackedItem) then
				objArray.add(enqObj);
			elseif enqObj.isKindOf(CM_TITransaction) then
				if enqObj.CM_TITransaction.myTrackedItem &lt;&gt; null then
					objArray.add(enqObj.CM_TITransaction.myTrackedItem);
				endif;
			endif;
		endforeach;
		self.summariseAll( objArray );
		return;
	
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="paint" id="457ea002-4e9e-4d67-b597-fad2180eae06">
        <controlMethod name="Frame::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>paint(frame: Frame input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	inheritMethod(frame);
	
	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.isBuilt := true;
		self.buildSelf;
	endif;

epilog

end;</source>
