    <JadeMethod name="addBerthPreferenceToColls" id="e0e0507c-eb99-4f45-9528-52a8755969fe">
        <updating/>
        <source>addBerthPreferenceToColls(_berthPref : HMS_BerthPreferenceVoyageData) updating;
//--------------------------------------------------
// Created:	26 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _berthPref = null then
		return;
	endif;

	if (not self.allBerthPreferencesByName.includes(_berthPref)) then
		self.allBerthPreferencesByName.add(_berthPref);
	endif;
	
	if (not self.allBerthPreferencesArray.includes(_berthPref)) then
		self.allBerthPreferencesArray.add(_berthPref);
	endif;	
	
end;</source>
        <Parameter name="_berthPref" type="HMS_BerthPreferenceVoyageData"/>
    </JadeMethod>
    <JadeMethod name="arrivesInPort" id="514028a6-1487-4988-9ddb-1ccdbf04e445">
        <methodInvocation>mapping</methodInvocation>
        <source>arrivesInPort(set: Boolean; _value: TimeStamp io) mapping;
//Determines when the vessel arrives into port as opposed to arriving at anchor
vars
    pm : HMS_VoyageMovement;
begin
	if not set then
		foreach pm in self.allVoyageMovements where pm.getMyBerth().noMarineServices = false do
			_value := pm.occursOnDTNEW;
			return;
		endforeach;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="6e7fa877-7847-45e6-b40c-e0a92baa099a">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myVoyage.canUserAccessSelf(_user, _failedDAC, passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoToDischarge" id="c02206ff-0b34-4db2-b8ed-ba658fd82f48">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoToDischarge(set: Boolean; _value: Boolean io) mapping;
//--------------------------------------------------
// Created:	31 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//_value := (not self.allCommodityDischarge.isEmpty);						 // ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	_value := (not self.myVoyage.allCargoForecasts.dischargeCommoditiesIsEmpty); // ### TFS 53132 20Apr2022 NAVPW1
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cargoToLoad" id="214bb88d-ecb9-4cba-89d0-19f2b25401f8">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoToLoad(set: Boolean; _value: Boolean io) mapping;
//--------------------------------------------------
// Created:	31 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//_value := (not self.allCommodityLoad.isEmpty);						// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	_value := (not self.myVoyage.allCargoForecasts.loadCommoditiesIsEmpty); // ### TFS 53132 21Apr2022 NAVPW1
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkIfMovementAlreadyExists" id="1555036b-7f65-4045-9a5e-482d5ec0ebae">
        <source>checkIfMovementAlreadyExists(_pxyMovement : HMS_VoyageMovement) : Boolean;
 
/*

Purpose:		Returns true if finds a matching movement for the voyage	

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2010	cnwmh5	Initial creation #23248

*/

vars

	movement	: HMS_VoyageMovement;
	currentMovement : HMS_VoyageMovement;
	
	found		: Boolean;
	tsToCheck	: TimeStamp;
	expectedEdition : Integer;
	
begin

	// get the occursOnDt from current move to check
	tsToCheck := _pxyMovement.occursOnDT;
	
	// get the real object that the proxy was created from
	_pxyMovement.pxyGetRealObjectAndEdition(currentMovement, expectedEdition);

	// set the key to proxys occursOnDT and see if already exists
	movement := self.allVoyageMovements.getAtKey(tsToCheck);
	if movement &lt;&gt; null then
		if movement &lt;&gt; currentMovement and movement &lt;&gt; _pxyMovement then
			found := true;
			app.raiseCMException3(Canno_date_time_movmt_exists, movement.getVoyageCode(), 
				tsToCheck.time.asStringJMT, tsToCheck.date.asStringJMT, null, null);
		endif;
	endif;
	
	return found;
	
epilog

end;</source>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVesselArrayPosn" id="fc6cedc5-aaf3-4613-b2e2-557f81d19987">
        <updating/>
        <source>checkVesselArrayPosn() updating;

vars
 	voyageNext:			CM_Voyage;
	otherVesselVoyage:	CM_Voyage;
	insertPosn:			Integer;
	currPosn:			Integer;
	arryNextVoyage:		CM_Voyage;
	arryPrevVoyage:		CM_Voyage;
	posnOK:				Boolean;
	vessel:				CM_Vessel;
begin
 	// Modified by Russell 06/04/99
	// ------------------------------------------------------------------------------
	// Update the vessel's collection of allPermVoyages
	// Decide where to insert voyage entry into vessel.CM_Vessel.allPermVoyages array
	// NOTE: This is decided by arrivedDT
	// Check to see if voyage already exists and is in the correct position
/*	if self.myHMSVesselData.allVoyages.includes(self) then
		// Get current position	
		currPosn:=self.myHMSVesselData.allVoyages.indexOf(self.myVoyage);
		// Test to see if positions either side of the currPosn exist
		if currPosn&gt;1 and currPosn&lt;self.myHMSVesselData.allVoyages.size then 
			// currPosn is not at the ends of the array
			arryNextVoyage:=self.myHMSVesselData.allVoyages[(currPosn+1)].CM_Voyage;
			arryPrevVoyage:=self.myHMSVesselData.allVoyages[(currPosn-1)].CM_Voyage;
		elseif currPosn&gt;1 and self.myHMSVesselData.allVoyages.allPermVoyages.size then
			// currPosn is at the end of the array
			arryNextVoyage:=null;
			arryPrevVoyage:=self.myHMSVesselData.allVoyages[(currPosn-1)].CM_Voyage;
		elseif currPosn=1 and currPosn&lt;self.myHMSVesselData.allVoyages.size then
			// currPosn is at the start of the array
			arryNextVoyage:=self.myHMSVesselData.allVoyages[(currPosn+1)].CM_Voyage;
			arryPrevVoyage:=null;
		else
			// this voyage is the only entry in the vessel.CM_HMS_Vessel.allPermVoyages array
			arryNextVoyage:=null;
			arryPrevVoyage:=null;
		endif;	

		// Test that current position is OK
		posnOK:=true;
		if arryNextVoyage&lt;&gt;null then
			if arryNextVoyage.arrivedDT&lt;=self.arrivedDT then
				// Next voyage does not arrive after the currentVoyage
				posnOK:=false;
			endif;
		endif;
		if arryPrevVoyage&lt;&gt;null then
			if arryPrevVoyage.arrivedDT&gt;=self.arrivedDT then
				// Prev voyage does not arrive before the currentVoyage
				posnOK:=false;
			endif;
		endif;
		if posnOK=false then
			// Remove voyage from array
			vessel.CM_HMS_Vessel.allPermVoyages.remove(self);
		endif;
	else
		// Voyage not currently included in the array
		posnOK:=false;
	endif;


	if posnOK=false then
		// Insert voyage at correct position in array
		foreach otherVesselVoyage in self.myHMSVesselData.allVoyages reversed do 
			if otherVesselVoyage.arrivedDT&lt;self.arrivedDT then
				break;
			else
				// Set reference to voyage immediately after the point where this voyage
				// needs to be inserted
				voyageNext:=otherVesselVoyage.CM_Voyage;
			endif;
		endforeach;
		if voyageNext=null then
			// Add voyage to end of vessel.CM_HMS_Vessel.allPermVoyages array
			self.myHMSVesselData.allVoyages.add(self);
		else
			// Insert the voyage at the position of the current voyageNext - this
			// will push all other voyages down 
			insertPosn:=self.myHMSVesselData.allVoyages.indexOf(voyageNext);
			if insertPosn&gt;0 then
				self.myHMSVesselData.allVoyages.insert(insertPosn,self);
			else
				self.myHMSVesselData.allVoyages.add(self);
			endif;
		endif;
	endif;
	// ------------------------------------------------------------------------------
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="92e0ea51-90d6-4408-9173-3bf73f7a475e">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	19 January 2006 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	newVoyageData : HMS_VoyageData;
	newDeptMove,
	newArrvMove,
	deptMove,
	arrivalMove : HMS_VoyageMovement;
begin
	newVoyageData := self.cloneSelf(_transient);

   newVoyageData.setMyBerth ( self.getMyBerth);
    newVoyageData.myHarbour				:= self.myHarbour;
	newVoyageData.myLineCompany 		:= self.myLineCompany;
	newVoyageData.myShippingAgent 		:= self.myShippingAgent;
	newVoyageData.myVisitType			:= self.myVisitType;
	newVoyageData.myTidalClass 			:= self.myTidalClass;
	newVoyageData.myTidalClassDept 		:= self.myTidalClassDept;
 	newVoyageData.myVesselCategoryIn 	:= self.myVesselCategoryIn;
 	newVoyageData.myVesselCategoryOut 	:= self.myVesselCategoryOut;	
	newVoyageData.myVesselType			:= self.myVesselType;
	newVoyageData.myPilot			 	:= self.myPilot;	
	newVoyageData.myMaster				:= self.myMaster;
	
	arrivalMove := self.allVoyageMovements.first;
	deptMove := self.allVoyageMovements.last;
	if arrivalMove &lt;&gt; null then
		newArrvMove := arrivalMove.cloneMySelfAsMoveType(arrivalMove.moveType, app.actualTimeServer, _transient, app.myPassport);
		newArrvMove.setPropertyValue(HMS_VoyageMovement::myHMSVoyageData.name, newVoyageData);
		newArrvMove.setTimings(app.actualTimeServer, newArrvMove.steamingTime, false); //jlgka1 TFS 45620
	endif;	
	
	if deptMove &lt;&gt; null then
		newDeptMove := deptMove.cloneMySelfAsMoveType(deptMove.moveType, app.actualTimeServer.cnEcAddDays(1), _transient, app.myPassport);
		newDeptMove.setPropertyValue(HMS_VoyageMovement::myHMSVoyageData.name, newVoyageData);	
		newDeptMove.setTimings(app.actualTimeServer.cnEcAddDays(1), newDeptMove.steamingTime, false); //jlgka1 TFS 45620
	endif;
	
	
	return newVoyageData;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="fc5b73de-e8d2-4dfa-8e55-ae005a964c9f">
        <updating/>
        <source>cloneReferences(_copyFrom : HMS_VoyageData) updating;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthPref 		: HMS_BerthPreference;
	voyageDelay 	: HMS_VoyageDelay;
begin
	
	self.setMyBerth( _copyFrom.getMyBerth);
    self.myHarbour			:= _copyFrom.myHarbour;	
	self.myLineCompany 		:= _copyFrom.myLineCompany;
	self.myShippingAgent 	:= _copyFrom.myShippingAgent;
	self.myVisitType 		:=	_copyFrom.myVisitType;
	self.myTidalClass 		:= _copyFrom.myTidalClass;
	self.myTidalClassDept 	:= _copyFrom.myTidalClassDept;
	self.myVesselCategoryIn := _copyFrom.myVesselCategoryIn;
	self.myVesselCategoryOut := _copyFrom.myVesselCategoryOut;
	self.myVesselType 		:= _copyFrom.myVesselType;
	
	self.myPilot	 := _copyFrom.myPilot;
	self.myMaster	 :=	_copyFrom.myMaster;	
	
	//_copyFrom.allCommodityDischarge.copy(self.allCommodityDischarge);	// ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	//_copyFrom.allCommodityLoad.copy(self.allCommodityLoad);			// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
	_copyFrom.allStevedoresDischarge.copy(self.allStevedoresDischarge);
	_copyFrom.allStevedoresLoad.copy(self.allStevedoresLoad);
	
	/*
	//_copyFrom.allVoyageMovements.copy(self.allVoyageMovements);
	foreach tmpMovement in _copyFrom.allVoyageMovements do
		newMovement := tmpMovement.pxyCreateUpdateProxy();
		pxyMovement.setPropertyValue(HMS_VoyageMovement::myHMSVoyageData.name, self);
	endforeach;									

	foreach berthPref in _copyFrom.allBerthPreferencesArray do
		self.allBerthPreferencesArray.add(berthPref.pxyCreateUpdateProxy);
	endforeach;									
		
	self.allBerthPreferencesByName.copy(self.allBerthPreferencesArray);
	*/

end;</source>
        <Parameter name="_copyFrom" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="copyFromWorkingDelay" id="6e52a1b0-0747-48d5-bfac-cd7b216b04bb">
        <updating/>
        <source>copyFromWorkingDelay(workingVoyage:CMIF_HMS_WorkingVoyage; _passport : CM_Passport input)updating;

vars
	workingDelay 	: CMIF_HMS_VoyageDelay;
	permanentDelay	: HMS_VoyageDelay;
	objA			: ObjectArray;
	now:			TimeStamp;
begin

	create objA transient;
	foreach workingDelay in workingVoyage.allCMIFVoyageDelays do
		if workingDelay.myPersistentVoyageDelay &lt;&gt; null then
			objA.add(workingDelay.myPersistentVoyageDelay);
		endif;
	endforeach;
	
	foreach permanentDelay in self.allVoyageDelays do
		// Archive delays no longer required
		if (not objA.includes(permanentDelay)) then	
			//delete permanentDelay;
			// Create delete delay transaction
			permanentDelay.cancelVoyageDelay(_passport);
		endif;
	endforeach;

	foreach workingDelay in workingVoyage.allCMIFVoyageDelays do
		workingDelay.myHMSVoyageData := self;
		permanentDelay := workingDelay.myPersistentVoyageDelay;					
		if permanentDelay &lt;&gt; null
		and self.allVoyageDelays.includes(permanentDelay) then
			// Create EDIT delay transaction
			permanentDelay.setFromWorkingDelay(workingDelay, TRANS_TYPE_EditVoyageDelay, _passport);
		else
			create permanentDelay;
			// Create ADD delay transaction
			permanentDelay.setFromWorkingDelay(workingDelay, TRANS_TYPE_AddVoyageDelay, _passport);
		endif;
	endforeach;

epilog
	delete objA;
end;</source>
        <Parameter name="workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyFromWorkingVoyage" id="bbe8a971-bc11-4c0d-915c-a62aa0ed508a">
        <updating/>
        <source>copyFromWorkingVoyage(_workingVoyage : CMIF_HMS_WorkingVoyage input; _passport : CM_Passport input) updating;

vars
	workingMovement: 	CMIF_HMS_WorkingMovement;
	permanentMovement:	HMS_VoyageMovement;
	cargo:				CM_Commodity;
	stevedore:			CM_Stevedore;
	realVoyage:			CM_Voyage;
	voyageData:			HMS_VoyageData;
	addMode:			Boolean;
	realVoyageGlobal:	CM_VoyageGlobal;
begin
	// This method copies all attributes and references from the workingVoyage
	// to the permanent voyage

	// Create update transactions
	if _workingVoyage.ofPermanentVoyage = null then
		// Add mode
		addMode := true;
		self.createTransaction(TRANS_TYPE_HMSVoyageAdd, _workingVoyage, null, null, _passport);		
	else
		// Edit mode
		self.createTransaction(TRANS_TYPE_HMSVoyageEdit, _workingVoyage, null, null, _passport);		
	endif;
	
// cnwdad1 28/01/2008 - PAR #15772.
	if _workingVoyage.ofPortFrom = null then
		self.portArrivingFromCode	:=	null;
	else
		self.portArrivingFromCode 	:=	_workingVoyage.ofPortFrom.code;
	endif;
	
// cnwdad1 28/01/2008 - PAR #15772.
	if _workingVoyage.ofPortTo = null then
		self.portDepartingToCode	:=	null;
	else
		self.portDepartingToCode	:=	_workingVoyage.ofPortTo.code;
	endif;
	
    self.shortComment			:= _workingVoyage.shortComment;
    self.voyageStatus			:= _workingVoyage.voyageStatus;    

 	self.myVesselCategoryIn 	:=_workingVoyage.ofClassIn;
 	self.myVesselCategoryOut 	:=_workingVoyage.ofClassOut;
	
	voyageData					:= _workingVoyage.myHMSVoyageData;
    self.setMyBerth( voyageData.getMyBerth);
    self.myHarbour				:= voyageData.myHarbour;
	self.myLineCompany 			:= voyageData.myLineCompany;
	self.myShippingAgent 		:= voyageData.myShippingAgent;
	self.myVisitType			:= voyageData.myVisitType;
	self.myTidalClass 			:= voyageData.myTidalClass;
	self.myTidalClassDept 		:= voyageData.myTidalClassDept;
	self.myVesselType			:= voyageData.myVesselType; 
	self.myPilot 				:= voyageData.myPilot;
	self.myMaster				:= voyageData.myMaster; 	
	
 	// Update discharge cargo
 	// -------------------------------------------------------------------------
 	// Deselect discharge cargo that is no longer selected
 	//self.allCommodityDischarge.clear();									// ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//_workingVoyage.allCargoDischarge.copy(self.allCommodityDischarge);	// ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	
	// Update load cargo
 	// -------------------------------------------------------------------------
 	// Deselect load cargo that is no longer selected
 	//self.allCommodityLoad.clear();										// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//_workingVoyage.allCargoLoad.copy(self.allCommodityLoad);				// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage

 	// Modified by Russell 04/05/99
 	// ---------------------------------------------------------------------------
 	// Update discharge stevedores
 	// -------------------------------------------------------------------------
 	// Deselect discharge stevedores that is no longer selected
 	self.allStevedoresDischarge.clear();
	_workingVoyage.allStevedoresDischarge.copy(self.allStevedoresDischarge);

 	// Update load stevedores
 	// -------------------------------------------------------------------------
 	// Deselect load stevedores that is no longer selected
	self.allStevedoresLoad.clear();
 	_workingVoyage.allStevedoresLoad.copy(self.allStevedoresLoad);
 	
	self.copyFromWorkingDelay(_workingVoyage, _passport);
	// Modified by Russell 06/04/99
	// ------------------------------------------------------------------------------
	// Update the vessel's collection of allPermVoyages
	//checkVesselArrayPosn;
	// ------------------------------------------------------------------------------

	if self.myVoyage = null then
		//must be adding new voyage via scenario
		create realVoyage persistent;
		realVoyage.setHMSVoyageData(self);
		_workingVoyage.ofPermanentVoyage := realVoyage;
		
		// LORCAN here we need to set up VoyageGlobal and the waitingtime etc on the movemements

		// NEW VOYAGE VIA GRAPHICAL VIEW NEED TO SET THE VOYAGE DEFAULTS FROM THE VESSEL
	endif;
	
	self.myVoyage.setFromWorkingVoyage(_workingVoyage, _passport);

	if self.myVoyage.myVoyageGlobalArrival = null then	//Par 21301 Oct 2009. self.myVoyage &lt;&gt; null and = realVoyage, when creating a new scenario voyage (this is becouse of realVoyage.setHMSVoyageData(self) )
	//if realVoyage.myVoyageGlobalArrival = null then
		create realVoyageGlobal persistent;		//Par 16752 May 2009. cnwvu1
		//realVoyage.setMyVoyageGlobalArrival(realVoyageGlobal);
		self.myVoyage.setMyVoyageGlobalArrival(realVoyageGlobal);	//Par 21301 (PAR21612) Dec 2009
		realVoyageGlobal.setForCreateFromScenarioVoyage(self.myVoyage);
	endif;
	
	//Par9375 12/01/2005
	if addMode then
		self.setDefaultBerthPreferences(_passport);
	endif;
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChanges" id="090401b2-15a7-473b-bb49-440e198d92e8">
        <source>createPropertyChanges(_transaction : HMS_Transaction; _workingVoyage : CMIF_HMS_WorkingVoyage);
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	vesselCode,
	oldStr,
	newStr:				String;
	tmpSteveDict:		CM_StevedoreByCodeDict;
	tmpDict:			CM_CommodityByCodeDict;
	theVoyage:			CM_Voyage;
 	propertyChange:		HMS_PropertyChange;
 	commodity:			CM_Commodity;
 	stevedore:			CM_Stevedore;
 	cargoToLoad,
 	cargoHasChanged:	Boolean;	
 	stevedoresChanged:	Boolean;
begin
	// Voyage
	theVoyage := self.myVoyage;
	if theVoyage &lt;&gt; null then
		if theVoyage.code &lt;&gt; _workingVoyage.code then
	    	// Property has changed
			create propertyChange;
			propertyChange.set(_transaction, "Voyage code", theVoyage.code, _workingVoyage.code);
		endif;
		// Ship
		vesselCode := theVoyage.vesselCode;
	endif;

	if vesselCode &lt;&gt; _workingVoyage.myHMSVoyageData.vesselCode then
    	// Property has changed
		create propertyChange;
		oldStr := vesselCode;
		newStr := _workingVoyage.myHMSVoyageData.vesselCode;
  		propertyChange.set(_transaction, "Vessel", oldStr, newStr);   			
	endif;


    // Comments
    if self.shortComment &lt;&gt; _workingVoyage.shortComment then
    	// Property has changed
		create propertyChange;
   		propertyChange.set(_transaction, "Voyage comments", self.shortComment, _workingVoyage.shortComment);
	endif;

	// Vessel Class IN
	if self.myVesselCategoryIn &lt;&gt; _workingVoyage.ofClassIn then
    	// Property has changed
		create propertyChange;
   		if self.myVesselCategoryIn &lt;&gt; null then
   			oldStr := self.myVesselCategoryIn.description;
   		else
   			oldStr := "None Selected";
   		endif;
   		if _workingVoyage.ofClassIn &lt;&gt; null then
   			newStr := _workingVoyage.ofClassIn.description;
   		else
   			newStr := "None Selected";
   		endif;	
   		propertyChange.set(_transaction, "Ship Class IN", oldStr, newStr);
	endif;

	// Vessel Class OUT
	if self.myVesselCategoryOut &lt;&gt; _workingVoyage.ofClassOut then
    	// Property has changed
		create propertyChange;
   		if self.myVesselCategoryOut &lt;&gt; null then
   			oldStr := self.myVesselCategoryOut.description;
   		else
   			oldStr := "None Selected";
   		endif;
   		if _workingVoyage.ofClassOut &lt;&gt; null then
   			newStr := _workingVoyage.ofClassOut.description;
   		else
   			newStr := "None Selected";
   		endif;	
   		propertyChange.set(_transaction, "Ship Class OUT", oldStr, newStr);
	endif;

	// Discharge cargo
	/*if (not self.cargoToDischarge) and (not _workingVoyage.cargoToDischarge) then
		// No property change
	elseif self.cargoToDischarge and _workingVoyage.cargoToDischarge then
		// Compare cargo's new:old
		cargoHasChanged := false;
		if self.allCommodityDischarge.size &lt;&gt; _workingVoyage.allCargoDischarge.size then
			// Cargo added or removed - ie Cargo assignment has changed
			cargoHasChanged:=true;
		else
			// Number of cargo type selected is same - directly compare members of each collection
			foreach commodity in self.allCommodityDischarge do
				if (not _workingVoyage.allCargoDischarge.includes(commodity)) then
					cargoHasChanged:=true;
				endif;
			endforeach;
			foreach commodity in _workingVoyage.allCargoDischarge do
				if (not self.allCommodityDischarge.includes(commodity)) then
					cargoHasChanged:=true;
				endif;
			endforeach;
		endif;
		if cargoHasChanged=true then
			// Cargo assignments have changed
			// Property has changed
			create propertyChange;
	   		if self.allCommodityDischarge.isEmpty then
				oldStr := "None Selected";
			else
		   		foreach commodity in self.allCommodityDischarge do
		   			oldStr := oldStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				oldStr := oldStr[1:(oldStr.length-2)];
			endif;
			if _workingVoyage.allCargoDischarge.isEmpty then
				newStr := "None Selected";			
			else
		   		foreach commodity in _workingVoyage.allCargoDischarge do
		   			newStr := newStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				newStr := newStr[1:(newStr.length-2)];
			endif;
	   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
		endif;
	elseif (not self.cargoToDischarge) and
	   _workingVoyage.cargoToDischarge and
	   (not _workingVoyage.allCargoDischarge.isEmpty) then
		// Property changed;  old=None Selected; new=All discharge charge
		// Cargo has been selected for discharge
		create propertyChange;
   		oldStr := "None selected";	
   		foreach commodity in _workingVoyage.allCargoDischarge do
	   		newStr := newStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		newStr := newStr[1:(newStr.length-2)];
   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
	elseif self.cargoToDischarge and
	   (not _workingVoyage.cargoToDischarge) and
	   (not self.allCommodityDischarge.isEmpty) then
		// Property changed;  old=All discharge charge; new=None Selected
		// Cargo has been selected for discharge
		create propertyChange;
   		newStr := "None selected";	
   		foreach commodity in self.allCommodityDischarge do
	   		oldStr := oldStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		oldStr := oldStr[1:(oldStr.length-2)];
   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
	endif;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage


   	// Load cargo
   	/*cargoToLoad := self.cargoToLoad;
   	tmpDict := self.allCommodityLoad;
	if cargoToLoad=false and _workingVoyage.cargoToLoad=false then
		// No property change
	elseif cargoToLoad=true and _workingVoyage.cargoToLoad=true then
		// Compare cargo's new:old
		cargoHasChanged:=false;
		if tmpDict.size&lt;&gt;_workingVoyage.allCargoLoad.size then
			// Cargo added or removed - ie Cargo assignment has changed
			cargoHasChanged:=true;
		else
			// Number of cargo type selected is same - directly compare members of each collection
			foreach commodity in tmpDict do
				if _workingVoyage.allCargoLoad.includes(commodity)=false then
					cargoHasChanged:=true;
				endif;
			endforeach;
			foreach commodity in _workingVoyage.allCargoLoad do
				if tmpDict.includes(commodity)=false then
					cargoHasChanged:=true;
				endif;
			endforeach;
		endif;
		if cargoHasChanged=true then
			// Cargo assignments have changed
			// Property has changed
			create propertyChange;
	   		if (not tmpDict.isEmpty) then
		   		foreach commodity in tmpDict do
		   			oldStr := oldStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				oldStr := oldStr[1:(oldStr.length-2)];
			else
				oldStr := "None Selected";
			endif;
			if (not _workingVoyage.allCargoLoad.isEmpty) then
		   		foreach commodity in _workingVoyage.allCargoLoad do
		   			newStr := newStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				newStr :=newStr[1:(newStr.length-2)];
			else
				newStr := "None Selected";
			endif;
	   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
		endif;
	elseif cargoToLoad=false and _workingVoyage.cargoToLoad=true and _workingVoyage.allCargoLoad.size&gt;0 then
		// Property changed;  old=None Selected; new=All discharge charge
		// Cargo has been selected for discharge
		create propertyChange;
   		oldStr := "None selected";	
   		foreach commodity in _workingVoyage.allCargoLoad do
   			newStr := newStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		newStr := newStr[1:(newStr.length-2)];
   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
	elseif cargoToLoad and (not _workingVoyage.cargoToLoad) and (not tmpDict.isEmpty) then
		// Property changed;  old=All discharge charge; new=None Selected
		// Cargo has been selected for discharge
		create propertyChange;
   		newStr := "None selected";	
   		foreach commodity in tmpDict do
	   		oldStr :=oldStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		oldStr := oldStr[1:(oldStr.length-2)];
   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
	endif;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage

	// Stevedores for cargo discharge
	// Compare stevedore's new:old
	stevedoresChanged:=false;
	tmpSteveDict := self.allStevedoresDischarge;
	if tmpSteveDict.size&lt;&gt;_workingVoyage.allStevedoresDischarge.size then
		// Stevedores added or removed - ie Stevedore assignment has changed
		stevedoresChanged:=true;
	else
		// Number of stevedores selected is same - directly compare members of each collection
		foreach stevedore in tmpSteveDict do
			if _workingVoyage.allStevedoresDischarge.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
		foreach stevedore in _workingVoyage.allStevedoresDischarge do
			if tmpSteveDict.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
	endif;
	if stevedoresChanged=true then
		// Stevedore assignments have changed
		// Property has changed
		create propertyChange;

   		if (not tmpSteveDict.isEmpty) then
	   		foreach stevedore in tmpSteveDict do
	   			oldStr := oldStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr :=oldStr[1:(oldStr.length-2)];
		else
			oldStr := "None Selected";
		endif;
		if (not _workingVoyage.allStevedoresDischarge.isEmpty) then
	   		foreach stevedore in _workingVoyage.allStevedoresDischarge do
	   			newStr := newStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr := newStr[1:(newStr.length-2)];
		else
			newStr := "None Selected";
		endif;
   		propertyChange.set(_transaction, "Stevedore/s for discharge", oldStr, newStr);		
	endif;

   	// Stevedores for discharge 
   	// Compare stevedore's new:old
	stevedoresChanged:=false;
	tmpSteveDict := self.allStevedoresLoad;
	if tmpSteveDict.size&lt;&gt;_workingVoyage.allStevedoresLoad.size then
		// Stevedores added or removed - ie Stevedore assignment has changed
		stevedoresChanged:=true;
	else
		// Number of stevedores selected is same - directly compare members of each collection
		foreach stevedore in tmpSteveDict do
			if _workingVoyage.allStevedoresLoad.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
		foreach stevedore in _workingVoyage.allStevedoresLoad do
			if tmpSteveDict.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
	endif;
	if stevedoresChanged=true then
		// Stevedore assignments have changed
		// Property has changed
		create propertyChange;
   		if (not tmpSteveDict.isEmpty) then
	   		foreach stevedore in tmpSteveDict do
	   			oldStr := oldStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr := oldStr[1:(oldStr.length-2)];
		else
			oldStr := "None Selected";
		endif;
		if _workingVoyage.allStevedoresLoad.size&gt;0 then
	   		foreach stevedore in _workingVoyage.allStevedoresLoad do
	   			newStr := newStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr := newStr[1:(newStr.length-2)];
		else
			newStr := "None Selected";
		endif;
   		propertyChange.set(_transaction, "Stevedore/s for loading", oldStr, newStr);		
	endif;

end;</source>
