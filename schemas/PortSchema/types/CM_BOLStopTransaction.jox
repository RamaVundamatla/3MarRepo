    <JadeMethod name="setStop" id="228c5bd9-3cd0-415f-be1f-862f3374de2c">
        <updating/>
        <source>setStop(_stopTable: CM_StopsTable) updating, protected;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 October 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars

begin
	if _stopTable &lt;&gt; null then
		self.stopDescription := _stopTable.heading;
		self.stopID := _stopTable.id;
	else
	//	app.raiseCMException1(REQUIRED_FIELD, 'myStopTable', null, null);
		app.raiseCMException(Input_required_field_myStpTab, null, null); // cnwdb2	PAR 35364
		
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
</Class>
