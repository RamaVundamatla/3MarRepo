    <JadeMethod name="doMatch" id="3e347828-62f4-4be9-813b-84f396cf8b18">
        <source>doMatch(_value: Any): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	if not _value.Time.isValid then
          return false;
	endif;
	
	return _value.Time &gt; self.searchValue;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
