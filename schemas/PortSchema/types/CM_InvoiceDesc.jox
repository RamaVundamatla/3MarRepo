    <JadeMethod name="erase" id="88c78fe1-0306-4f33-87e0-837e64cf99cd">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			
Date		Who		Reason
28 May 2013	cnwab1	Initial creation
*/

vars
	invLine : CM_InvoiceLine;
	invChg : CM_Charge;
begin
	// 37200 delete of transient proxy from INV_InvoiceLineDesc was going through all of the code below 
	//	which could take a minute or more and was not required at all, for a transient.
	if self.isTransient then
		delete self;
		return;
	endif;

	if _eraseLevel = FORCED_ERASE then
		self.allInvoices.purge();
	endif;

	inheritMethod(_eraseLevel); // This will erase all actual invoicelines of this type as the actual invoice lines are children!

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="generateNarration" id="eac0a964-f9a8-4c7d-92ed-5d3b3fff9a34">
        <source>generateNarration(invoice: CM_Invoice): String;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 new narrative types
// 26/08/2016   cnwma1		TFS #2602 PAR #38167 CPL - Invoice Type with 'Separate Invoices For' set to Cargo Type does not print narration correctly
//
vars
	strNarration 	: String;
	index 			: Integer;
	fieldNo 		: Integer;
	isText 			: Boolean;
	str 			: String;
	voyage			: CM_Voyage;			// PAR #30860
begin

	index := 1;
	isText := true;
	
	// PAR #30860 see if we have a voyage that we can use
	if invoice.myVoyage &lt;&gt; null then				// PAR #30860
		voyage := invoice.myVoyage;					// PAR #30860
	elseif invoice.myTrackedItem &lt;&gt; null then		// PAR #30860
		voyage := invoice.myTrackedItem.myVoyage;	// PAR #30860
	endif;											// PAR #30860
	if voyage &lt;&gt; null and voyage.isNullVoyage then	// PAR #30860
		voyage := null;								// PAR #30860
	endif;											// PAR #30860
	
	foreach str	in arrNarrationDesc do
		if isText then
			strNarration := strNarration &amp; str;
		else
			fieldNo := CM_InvoiceDesc.Field_None;
			if str[1:11] = "___field = " then
				// field definition stored as "___field = ?"
				// where ? is in range 0 to 6  (as at 1999.05.26)
				fieldNo := str[12:end].Integer;
			endif;
			if fieldNo = CM_InvoiceDesc.Field_None then
				// do nothing
			elseif fieldNo = CM_InvoiceDesc.Field_Debtor_Name then
				strNarration := strNarration &amp; invoice.debtor.name.trimBlanks;
			elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Code then	
				
				//	strNarration := strNarration &amp; invoice.voyageCode.trimBlanks; //26/08/2016 cnwma1 TFS #2602
				if  invoice.isCargoItemSpecific then					      //26/08/2016 cnwma1 TFS #2602
					if invoice.myTrackedItem &lt;&gt; null then
						strNarration := strNarration &amp; invoice.myTrackedItem.voyageCode;
					endif;
				else 
					strNarration := strNarration &amp; invoice.voyageCode.trimBlanks;
				endif;
			elseif fieldNo = CM_InvoiceDesc.Field_Vessel_Name then
				
				//strNarration := strNarration &amp; invoice.vesselName.trimBlanks;   //26/08/2016 cnwma1 TFS #2602
				if   invoice.isCargoItemSpecific then						      //26/08/2016 cnwma1 TFS #2602
					if invoice.myTrackedItem &lt;&gt; null then
						strNarration := strNarration &amp; invoice.myTrackedItem.vesselName;
					endif;
				else
					strNarration := strNarration &amp; invoice.vesselName.trimBlanks;
				endif;
				
				
			elseif fieldNo = CM_InvoiceDesc.Field_Business_Unit then
				strNarration := strNarration &amp; invoice.bank.mailingName.trimBlanks;
			elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date then
				if invoice.toDT.isValid then
					strNarration := strNarration &amp; invoice.toDT.date.String;
				else
				endif;
			elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date_And_Time then
				if invoice.toDT.isValid then
					strNarration := strNarration &amp; invoice.toDT.String;
				else
				endif;
				
			elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Code then		// PAR #30860
				/*if voyage &lt;&gt; null then									    // PAR #30860  //26/08/2016 cnwma1 TFS #2602
					strNarration := voyage.myOperator.code;						// PAR #30860
				else															// PAR #30860
				endif;	*/														// PAR #30860
				if   invoice.isCargoItemSpecific then						    //26/08/2016 cnwma1 TFS #2602
					if invoice.myTrackedItem &lt;&gt; null then
						strNarration := strNarration &amp; invoice.myTrackedItem.operatorCode;
					endif;
				else
					if voyage &lt;&gt; null then										
						strNarration := strNarration &amp; voyage.myOperator.code;						
					else
					endif;
				endif;
			elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Desc then		// PAR #30860
				/*if voyage &lt;&gt; null then										// PAR #30860   //26/08/2016 cnwma1 TFS #2602
					strNarration := voyage.myOperator.description;				// PAR #30860
				else															// PAR #30860
				endif;*/														// PAR #30860
				if   invoice.isCargoItemSpecific then						    //26/08/2016 cnwma1 TFS #2602
					if invoice.myTrackedItem &lt;&gt; null then
						strNarration := strNarration &amp; invoice.myTrackedItem.operatorDescription;
					endif;
				else
					if voyage &lt;&gt; null then										
						strNarration := strNarration &amp; voyage.myOperator.description;						
					else
					endif;
				endif;														// PAR #30860
			elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Arrival_Date then		// PAR #30860
				if voyage &lt;&gt; null then											// PAR #30860
					strNarration := strNarration &amp; voyage.arrivedDT.asStringJMT();// PAR #30860  //26/08/2016 cnwma1 TFS #2602
				else															// PAR #30860
				endif;															// PAR #30860
			elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Departure_Date then	// PAR #30860
				if voyage &lt;&gt; null then											// PAR #30860
					strNarration := strNarration &amp; voyage.departedDT.asStringJMT();			// PAR #30860  //26/08/2016 cnwma1 TFS #2602
				else															// PAR #30860
				endif;															// PAR #30860
			endif;
		endif;
		index := index + 1;
		isText := not isText;
	endforeach;

	return strNarration[1:640];		// from 37141

end;</source>
        <Parameter name="invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAccrualTypeDescDebtor" id="fe625bf4-f6d1-4dd6-8d20-22f12fb9e36e">
        <source>getAccrualTypeDescDebtor(_debtor : CM_Debtor): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2022	navrk21	Bug 55204: MTN - Accural Type for Debtor is incorrect

*/

vars
	str:   String;
	allInvSep	: CM_InvTypeDebtorSeparationDict;
	accrType  	: CM_FinancialPeriodEnd;
begin
	if self.mySurchargeAndExemptions &lt;&gt; null and self.mySurchargeAndExemptions.allInvoiceTypeDebtorSeparation.isNotEmpty then
		allInvSep := self.mySurchargeAndExemptions.allInvoiceTypeDebtorSeparation;
		if _debtor &lt;&gt; null and allInvSep[_debtor] &lt;&gt; null then																									
			accrType := allInvSep[_debtor].myAccrualType;				
		endif;
		if accrType = null and allInvSep[self.company.rootDebtor] &lt;&gt; null then
			accrType := allInvSep[self.company.rootDebtor].myAccrualType;
		endif;
	endif;
	if accrType &lt;&gt; null and _debtor &lt;&gt; null then
		str := accrType.description;
	else
		str := self.getAccrualTypeDescription();
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAccrualTypeDescription" id="ee47eb41-54a1-4070-a1db-955405e4a490">
        <source>getAccrualTypeDescription(): String;

vars
	str:   String;
	realMe : SelfType;
begin
	if accrualType = Accrue_For_Financial_Period then
		if self.isTransient then
			realMe := self.pxyGetRealObject;
			if realMe &lt;&gt; null and realMe.myFinancialPeriodEnd &lt;&gt; null then // PAR 37242
				str := realMe.myFinancialPeriodEnd.description;
			else
				str := "Financial Period";
			endif;
		else
			if self.myFinancialPeriodEnd&lt;&gt; null then // PAR 37242
				str := self.myFinancialPeriodEnd.description;
			else // PAR 37242
				str := "Financial Period"; // PAR 37242
			endif;
		endif;
	elseif accrualType = Accrue_Until_Manually_Closed then
		str := "Until Closed";
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
