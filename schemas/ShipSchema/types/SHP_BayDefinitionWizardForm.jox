    <JadeMethod name="loadDefaults" id="94d2d343-fb9e-436f-bb29-420a831988d2">
        <updating/>
        <source>loadDefaults() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars
	defaultCellularVessel : CM_CellularVesselStructure;
	cell : CM_CellDefn;
	tier : CM_TierDefn;
begin
	
	if defaultCellularVessel = null then 	
		self.txtBayOrder.text := "01-31";
		
	endif;

	if self.myCurrentCellularVessel &lt;&gt; null then
		self.caption:="Bay Definition Wizard - " &amp; self.myCurrentCellularVessel.getDisplayDetails(false);
	endif;
	
	self.createDefaultBayProxy();
	self.txtOnDeckCells.text :=null;
	self.txtOnDeckTiers.text:=null;
	self.txtUnderDeckCell.text:=null;
	self.txtUnderDeckTier.text:=null;
	
	foreach cell in self.myProxyBayDefn.allCellsOnDeckByOrdinal do
		self.txtOnDeckCells.text :=self.txtOnDeckCells.text &amp;  cell.id &amp; " ";
	endforeach;	
	foreach tier in self.myProxyBayDefn.allTiersOnDeck do
		self.txtOnDeckTiers.text := self.txtOnDeckTiers.text &amp; tier.id &amp; " ";
	endforeach;
	foreach cell in self.myProxyBayDefn.allCellsUnderDeckByOrdinal do
		self.txtUnderDeckCell.text :=self.txtUnderDeckCell.text &amp;  cell.id &amp; " ";
	endforeach;	
	foreach tier  in self.myProxyBayDefn.allTiersUnderDeck do
		self.txtUnderDeckTier.text := self.txtUnderDeckTier.text &amp; tier.id &amp; " ";
	endforeach;
	//draws the default bay
	self.frmGridArea.doDrawBay(self.myProxyBayDefn, self.frmScrollDraw,3, null);
	
epilog

end;</source>
    </JadeMethod>
