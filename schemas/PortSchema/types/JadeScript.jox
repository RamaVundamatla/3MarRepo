    <JadeMethod name="nsCommandParser" id="97bb4c71-4036-446c-9b66-62b25a2ecbe5">
        <source>nsCommandParser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2016	cnwns1	Initial creation
Logic of this method extracts weight from Metler Toledo serial response format
Correct request liiks like this:
S
Correct response looks like this
S S     100.00 lb

&lt;ID&gt; &lt;status&gt; &lt;value&gt; &lt;unit&gt;

*/

constants
	SEPARATOR		: String = " ";
	STABLE 			: String = "S";
	DYNAMIC 		: String = "D";
	
	
	SYNTAXERROR		: String = "ES";
	TRANSMISSIONERROR: String = "ET";
	LOGICALERROR	: String = "EL";
	
	
	
vars 

	_commandLine : String;
	valueDec : Decimal[15,3];
	unit	: String;
	sa	 : StringArray;
	command : String;
	status : String;
	valueStr : String;
	success : Boolean;
	ind : Integer;
	weightType : CM_MeasurementType;

begin 

app.initialize;

create sa transient;

	sa.add("S S     100.00 lb");
	sa.add("S S     100.00 kg");
	sa.add("S S    100.009 t");
	sa.add("S D      100.0 g");
	sa.add("ST S     100.0 g");
	sa.add("ET");
	sa.add("ES");
	sa.add("EL");
	sa.add("S S 99999999 kg");
	sa.add("S S 9.99999999 g");
	sa.add("S S        160 fred");

	foreach _commandLine in sa do
	
		write "----'" &amp; _commandLine &amp; "'----";	//debug
	
	
	//start	
		if _commandLine.length &gt;= 16 then
			ind := 1;
			command := _commandLine.scanUntil(SEPARATOR,ind);	
			if command = STABLE then
				status := _commandLine[3:1];
				if status = STABLE then	
					valueStr :=  _commandLine[5:10];
					if valueStr.isDecimal then
						valueDec := valueStr.Decimal;
						unit := _commandLine[15:end].trimBlanks;	
						write valueDec.String &amp; Tab &amp; unit; //you now have the correct date
					else
						//do fail stuff
						write "ERR1 " &amp; _commandLine;
						continue;
					endif;
				else	
					write "ERR2 " &amp; _commandLine;
					//do fail stuff
					continue;
				endif;		
			else	
				write "ERR3 " &amp; _commandLine;
				// do fail stuff
				continue;
			endif;
		else
			write "ERR4 " &amp; _commandLine;
			//do fail stuff	
			continue;
		endif;
		
		if unit = "lb" then
			unit := "lbs";
		endif;
		
		if unit = "t" then
			unit := "MT";
		endif;
		
		weightType := app.myRoot.allMeasurementTypesByShortName[unit];
		
		if weightType = null or weightType.measurementType &lt;&gt; Type_Weight then
			//do fail stuff
			write "ERR5 " &amp; _commandLine;
			continue;
		endif;
		write "weightType.shortName is&gt;&gt;" &amp; weightType.shortName;
		write "valueDec is &gt;&gt; " &amp; valueDec.String;
		write "ConverMeasurementType is&gt;&gt;" &amp; app.convertMeasurementForStorage(weightType.shortName,valueDec).String;
		
	
	endforeach;
	

delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="omsnTi" id="8dc66bb6-89d6-4aff-a3c4-220a63f4e376">
        <source>omsnTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2018	jlgma1	Initial creation

*/

vars
ti,ti1 : CM_TrackedItem;
group : CM_ConsigneeConsignorGroup;
grpCode : String;
dict		: CM_TIByCargoTypeIdDict;
	iter		: Iterator;
		cargoTypeKey: Integer;
	counter		: Integer;
	idKey,consignee ,keyTiId: String;
	
begin

ti :="2365.30785".asOid.CM_TrackedItem;

if ti.myConsignee &lt;&gt; null then
	if ti.myConsignee.myConsignGroup &lt;&gt; null then
		grpCode :=  ti.myConsignee.myConsignGroup.code;
	
	endif;
	app.msgBox("",grpCode,0);

endif;
	dict := ti.myTerminal.allOnsiteTIsByCargoTypeId;
	iter := dict.createIterator;
		dict.startKeyGeq(10056, null, iter);
		// Add Onsite cargo to table
		while iter.next(ti1) do
			
			dict.getIteratorKeys(cargoTypeKey, keyTiId, iter);
			if cargoTypeKey &gt; 10056 then
				break;
			endif;
		if ti1.myConsignee &lt;&gt; null  and ti1.myConsignee.myConsignGroup &lt;&gt; null then
			if   ti1.myConsignee.myConsignGroup.code = 'SAUD' then 
					counter:= counter + ti.totalQuantity;
				endif;
			endif;	
			
		endwhile;	

app.msgBox("",counter.asStringJMT,0);

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="pelFixInvoicePaymentStatus" id="7dfe16d4-61b4-42c7-a1a5-9eacec0dcf2a">
        <source>pelFixInvoicePaymentStatus();
/*

Purpose:			
	Sets Invoice.paymentStatus to CM_Invoice.INVOICE_PAYMENT_PAID and sets the taxDT and externalTaxNumber on the invoice
	Can be run from IDE or JMT
Parameters:			

Return Value:		

Date		Who		Reason
03 October 2019		jlgns1	Initial creation

*/

vars

	term : CM_Terminal;
	pel : CM_Pelindo1Interface;
	invoice: CM_Invoice;
	tNum : String;
	pxyInvoice : CM_Invoice;
	message : String;
	bank    : CM_Bank;
begin
	
	if app.myPassport = null then
		app.initialize;
	endif;

	
	term := app.myRoot.allTerminals["1012"]; 
	bank := term.companies["DOM"];
	invoice := bank.allInvoices[term,bank,1717];
	pel := CM_Pelindo1Interface.firstInstance;
	
	
	if term = null or invoice = null or pel = null or bank = null then 
		return;
	endif;
		
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(term);
		
	pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
	
	message := term.code &amp; Tab &amp; term.name &amp; CrLf &amp;
	pxyInvoice.bank.code &amp; CrLf &amp;
	pxyInvoice.sequenceNum.String &amp; Tab &amp; pxyInvoice.externalFinancialId &amp; " " &amp; pxyInvoice.getPaymentStatusStr &amp; "' '" &amp; pxyInvoice.taxDT.asStringJMT &amp; "' '" &amp; pxyInvoice.externalTaxNumber &amp; "'" ;
	
	if  app.msgBox(message,"Continue?",MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	
		
	app.myTrxUA.trxUpdateInvoicePaymentStatus(pxyInvoice,CM_Invoice.INVOICE_PAYMENT_PAID,app.myPassport);

		
	
	tNum := pel.getTaxNumber(invoice,null);
	if tNum &lt;&gt;	null then
		beginTransaction;
		invoice.setTaxDetails(tNum,app.actualTimeServer);
		commitTransaction;
		
		message := message &amp; CrLf &amp;
		invoice.sequenceNum.String &amp; Tab &amp; invoice.externalFinancialId &amp; "  " &amp; invoice.getPaymentStatusStr &amp; "' '" &amp; invoice.taxDT.asStringJMT &amp; "' '" &amp; invoice.externalTaxNumber &amp; "'" ;

	else
		message := message &amp; CrLf &amp; "TAX DETAILS NOT SET";
	endif;
	app.msgBox(message,"Done",MsgBox_OK_Only);
		
	
	
	
epilog

	delete pxyInvoice;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pelGenIterfaceSeq" id="75ed6a40-9074-48a3-9c1e-59016f453efb">
        <source>pelGenIterfaceSeq();
/*

Purpose:			
	This Script will be used to set the intial value of the sequence for Pelindo
Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	cnwma1 Bug 42082: PEL1 - Sequence Numbers for Estimations,Invoices and Payment codes

*/


vars
 cashRecSeq 	: CM_AutoExternalReceiptGen;
 invSeq         : CM_AutoExternalNumberGen;
 paymentCodeSeq : CM_AutoPaymentIdGen;
 
 pelInterface   : CM_Pelindo1Interface;
 startSeq       : Real;
begin

  app.initialize();
  pelInterface := CM_Pelindo1Interface.firstInstance;
  
    if pelInterface &lt;&gt; null then
		/*First Step Create Object*/
		if pelInterface.myAutoExternalNumberGen = null then     //Create Invoice External 
			beginTransaction;
				pelInterface.createMyAutoExternalNumberGen();
		    commitTransaction;
		
		endif;
		if pelInterface.myAutoExternalReceiptGen = null then    //Create Cash Receipt 
			beginTransaction;
				pelInterface.createMyAutoExtReceiptNbrGen();
		    commitTransaction;
		endif;
		
		if pelInterface.myAutoPaymentIdGen = null then   // Create Payment Code
			beginTransaction;
				pelInterface.createMyAutoPaymentIdGen();
		    commitTransaction;
		endif;
		
		/*Second Step set the Seq*/
		startSeq := 10000;
		
		/*Invoice Seq*/
		invSeq := CM_AutoExternalNumberGen.firstInstance;
		beginTransaction;
			invSeq.nextSequenceNumArray[ 18 ] := startSeq;
		commitTransaction;
		
		/*Cash Receipt Seq */
		cashRecSeq := CM_AutoExternalReceiptGen.firstInstance;
		beginTransaction;
			cashRecSeq.nextSequenceNumArray[ 18 ] := startSeq;
		commitTransaction;
		
		
		/*Payment Code Seq */
		paymentCodeSeq:= CM_AutoPaymentIdGen.firstInstance;
		beginTransaction;
			paymentCodeSeq.nextSequenceNumArray[ 18 ] := startSeq;
		commitTransaction;
    endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pelGetMatchingReceipt" id="c7f1c88b-3164-48b7-be72-a4571d931451">
        <source>pelGetMatchingReceipt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2019	jlgma1	Initial creation

*/


vars

	term : CM_Terminal;
	pel : CM_Pelindo1Interface;
	invoice: CM_Invoice;
	bank    : CM_Bank;
	cashRecsExcluded: ObjectArray;
	invLine			: CM_InvoiceLine;
	voyage      	: CM_Voyage;
	wo 			 	: CM_WorkOrder;
	cashRec      	: CM_CashReceipt;
	proforma     	: CM_ProformaDetails;
	cashRecMatched  : ObjectArray;
	obj : Object;
	lFile      		: File;
begin
	
	if app.myPassport = null then
		app.initialize;
	endif;

	
	term := app.myRoot.allTerminals["1012"]; 
	bank := term.companies["DOM"];
	invoice := bank.allInvoices[term,bank,1717];
	pel := CM_Pelindo1Interface.firstInstance;
	
	
	if term = null or invoice = null or pel = null or bank = null then 
		app.msgBox("false","",0);
	endif;
			
	
	if invoice.myVoyage = null then
		app.msgBox("false","",0);
	endif;
	
	voyage :=invoice.myVoyage;

	create cashRecsExcluded transient;
	create cashRecMatched transient;
	foreach invLine   in invoice.invoiceLines discreteLock do  //Invoice Lines Loop
		
		if invLine.manual then
			continue;
		endif;
		
		foreach wo in voyage.allWorkOrders discreteLock do  			  // Work Order Loop //02.10.2019 cnwma1 #46853
			
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts discreteLock do    // Cash Receipt Loop  //02.10.2019 cnwma1 #46853
				
				if cashRec.getDebtor &lt;&gt; invoice.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; invoice.paymentType then
					continue;
				endif;
				
				/*
				First Iteration
				*/
				if not cashRecsExcluded.includes(cashRec) then
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  invoice.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
							
						if proforma.quantity &lt;&gt; invLine.quantity then
							continue;
						endif;
						
						if proforma.lineTotal &lt;&gt; invLine.lineTotal then
							continue;
						endif;
						//return cashRec;
						cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					
					/*
					21.11.2018 cnwma1 TFS #42129
					A second iteration of searching without taking the invoice line qty or total as a factor
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  invoice.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
						
						
						if invLine.myTransactionHMS &lt;&gt; null then
							if proforma.transactionType &lt;&gt; invLine.myTransactionHMS.type then
								continue;
							endif;
						endif;
						cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					/*
						08.12.2018 cnwma1 Bug #42441
						3rd Iteration to handle creating invoices from estimations with diffrent invoice line type,
						The Only thing we going to match here the GL Code of the invoice line used by the esstimation and invoice line
						used by the invoice.
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do       //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;	
						endif;
						if proforma.myInvoiceLineType.invoiceType &lt;&gt; invLine.invoiceLineDesc.invoiceType then
							continue;
						endif;
						
						/* Checking the GL Code*/
						
						if proforma.getServiceGLCode &lt;&gt;  invLine.getServiceGLCode  then
							continue;
						endif; 
						if proforma.getServiceGLCode &lt;&gt; null and invLine.getServiceGLCode &lt;&gt; null then 
							cashRecMatched.addExclusive(cashRec);
							cashRecsExcluded.addExclusive(cashRec);
						endif;
					endforeach;
				endif;
			endforeach;
		endforeach; // Work Order Loop

	endforeach;   //Invoice Lines Loop
	
	if cashRecMatched.isNotEmpty then
		create lFile transient;
		   lFile.open;
		lFile.fileName := "C:\TEMP\PIL.csv";
		foreach obj in cashRecMatched discreteLock do
			lFile.writeLine(obj.CM_CashReceipt.externalInvoiceNumber);
		
		endforeach;
		 lFile.close;
	endif;
	
epilog
	delete cashRecMatched;
	delete cashRecsExcluded;
		delete lFile;
end;</source>
    </JadeMethod>
