    <JadeMethod name="translateForm" id="79a577cd-aa28-4664-a5b2-6c19148e8305">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 11:25:47.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026300, locale);
	btnAddItems.translateCaption(Xlat_0026301, locale);
	btnApprove.translateCaption(Xlat_0026302, locale);
	btnAttachment.translateCaption(Xlat_0026303, locale);
	btnAudit.translateCaption(Xlat_0026558, locale);
	btnAudits.translateCaption(Xlat_0026304, locale);
 //	btnClear.translateBubbleHelp(Xlat_0026403, locale);
 //	btnClear.translateCaption(Xlat_0026305, locale);
	btnClose.translateCaption(Xlat_0026306, locale);
	btnHSCode.translateCaption(Xlat_0026335, locale);
	btnRemove.translateCaption(Xlat_0026307, locale);
	btnSave.translateCaption(Xlat_0026308, locale);
	btnUpdate.translateCaption(Xlat_0026309, locale);
	cargoDetails.translateCaption(Xlat_0026310, locale);
	chkSelectAll.translateCaption(Xlat_0026871, locale);
	chkShowDataEntry.translateCaption(Xlat_0026441, locale);
	chkShowSubDtls.translateCaption(Xlat_0026311, locale);
	lblCode.translateCaption(Xlat_0026312, locale);
	lblCustomLicense.translateCaption(Xlat_0026313, locale);
	lblCustomsAgent.translateCaption(Xlat_0026314, locale);
	lblDesc.translateCaption(Xlat_0026315, locale);
	lblDirection.translateCaption(Xlat_0026316, locale);
	lblDocType.translateCaption(Xlat_0026317, locale);
	lblEffectiveDate.translateCaption(Xlat_0026318, locale);
	lblExtRef.translateCaption(Xlat_0026319, locale);
	lblHSCode.translateCaption(Xlat_0026320, locale);
	lblNumber.translateCaption(Xlat_0026321, locale);
	lblRemarks.translateCaption(Xlat_0026322, locale);
	lblStatus.translateCaption(Xlat_0026323, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026324, locale);
	mnuContextMenu.translateCaption(Xlat_0026325, locale);
	mnuInspectObject.translateCaption(Xlat_0026326, locale);
	statusBar.translateCaption(Xlat_0026327, locale);
	statusline.translateCaption(Xlat_0026328, locale);
end;</source>
