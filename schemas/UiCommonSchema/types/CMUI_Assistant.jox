    <JadeMethod name="listTableLostFocus" id="2158ed65-7e4c-4e6f-a091-2f39e4dd7e7b">
        <source>listTableLostFocus(pTable : CM_EntryTable input; saveHeight : Real io; pListTable : CMUI_ListTable; pAttrName : String; _useDisplay : Boolean);
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow,
	idx		: Integer;
	str		: String;
	tbl		: CM_EntryTable;
	obj		: Object;
	lstTbl	: CMUI_ListTable;
begin
	
	
	
	tbl := pTable;
	lstTbl := pListTable;
	
	theRow := tbl.getRowByControlName(lstTbl.name);

	if (theRow &gt; tbl.fixedRows) and (theRow &lt;= tbl.rows) then
		// Only doing this when saveHeight is greater than 0 (is it ever!?) leaves GTE_ReleaseRequests::lstColour on the form when viewing a release detail line
		//if saveHeight &gt; 0 then
			tbl.accessRow(theRow).height := saveHeight.Integer;
			lstTbl.height := saveHeight.Integer; 
		//endif;
		saveHeight := 0;		// set to 0 so that can use in tbl.cellInputReady;
		tbl.scrollBars := Table.ScrollBars_Both;
		
		if _useDisplay then
			str := lstTbl.getSelectedFromDisplay();
		else
			str := lstTbl.getSelectedString(pAttrName);
		endif;
		tbl.setValue(theRow, str);
		
	endif;
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="saveHeight" type="Real" usage="io"/>
        <Parameter name="pListTable" type="CMUI_ListTable"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_useDisplay" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listTableLostFocusXML" id="8e99e36f-ed95-44c1-b7a4-cd7ea9f21e96">
        <source>listTableLostFocusXML(pTable : CM_EntryTable input; saveHeight : Real io; pListTable : CMUI_ListTable; pAttrName : String);

// cnwdvb1 20 March 2003 

vars
	theRow,
	idx		: Integer;
	str		: String;
	tbl		: CM_EntryTable;
	obj		: Object;
	
begin

	theRow := pTable.getRowByControlName(pListTable.name);

	if theRow &lt;&gt; 0 then
		pTable.accessRow(theRow).height := saveHeight.Integer;
		saveHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
		pTable.scrollBars := Table.ScrollBars_Both;
		
		str := pListTable.getSelectedStringXML(pAttrName, 'display');
		pTable.setValue(theRow, str);
	endif;

end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="saveHeight" type="Real" usage="io"/>
        <Parameter name="pListTable" type="CMUI_ListTable"/>
        <Parameter name="pAttrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="listTableMTGrade" id="bc1c2f97-ac84-43f0-8f25-540a16c09aeb">
        <updating/>
        <source>listTableMTGrade(pListTable : CMUI_ListTable input; _operator : CM_Operator; _operatorGroup : CM_OperatorGroup) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mtGrade		: CM_MTGrade;
	mtGradeDict	: CM_MTGradeByCodeDict;
	code		: CM_Code;
	canDisplay	: Boolean;
begin

	pListTable.rows := 0;
	mtGradeDict := app.myRoot.allAvailableAvailabilityGrades;

	foreach mtGrade in mtGradeDict do
		mtGrade.getTranslationForOperator(null,_operator, _operatorGroup, code, canDisplay);
		if code &lt;&gt; null then
			pListTable.addItemObject(code.description, mtGrade);
		elseif canDisplay then
			pListTable.addItemObject(self.displayEntryMTGrade(mtGrade), mtGrade);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="pListTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="listTableMTGradeSubTerm" id="7f765a92-ceac-405f-88e8-8bc94e7b636c">
        <updating/>
        <source>listTableMTGradeSubTerm(pListTable : CMUI_ListTable input; _operator : CM_Operator; _operatorGroup : CM_OperatorGroup; _subTerm : CM_SubTerminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2012	cnwrd1	Initial creation

*/

vars
	haz			: CM_HazardClass;
	theRow		: Integer;
	mtGrade		: CM_MTGrade;
	mtGradeDict	: CM_MTGradeByCodeDict;
	code		: CM_Code;
	canDisplay	: Boolean;
	
begin
	pListTable.rows := 0;
	mtGradeDict := app.myRoot.allAvailableAvailabilityGrades;

	foreach mtGrade in mtGradeDict do
		mtGrade.getTranslationForOperator(null,_operator, _operatorGroup, code, canDisplay);
		
		if _subTerm &lt;&gt; null then
			if code &lt;&gt; null then
				if _subTerm.allAllowedEditAvailGrades.includes( mtGrade ) then
					pListTable.addItemObject(code.description, mtGrade);
				endif;
			elseif canDisplay then
				if _subTerm.allAllowedEditAvailGrades.includes( mtGrade ) then
					pListTable.addItemObject(self.displayEntryMTGrade(mtGrade), mtGrade);
				endif;
			endif;
		else
			if code &lt;&gt; null then
				pListTable.addItemObject(code.description, mtGrade);
			elseif canDisplay then				
				pListTable.addItemObject(self.displayEntryMTGrade(mtGrade), mtGrade);
			endif;
		endif;

	endforeach;
	
epilog
end;</source>
        <Parameter name="pListTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_subTerm" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="listTableOperators" id="885d7742-47fb-4dd7-b169-6a11c4319e6c">
        <source>listTableOperators(_lstTbl : CMUI_ListTable input;
					_displayCode,
					_displayDescription : Boolean;
					_operatorsToSelect : CM_OperatorByCodeDict);
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	opDict		: CM_OperatorByCodeDict;
	op			: CM_Operator;
	rowStr		: String;
	row			: Integer;
begin
	_lstTbl.clearSelected();
	_lstTbl.rows := 0;
	
	if _operatorsToSelect = null then //don't just return - this is an error
		app.raiseUnexpectedProgramError(class.name, method.name, '_operatorsToSelect dictionary passed in was null');
		return;
	endif;
	
	opDict := app.myRoot.allOperators;

	foreach op in opDict do
		if _operatorsToSelect.includesKey(op.code) then
			rowStr := '1' &amp; Tab;
			_lstTbl.allSelectedObjects.add(op);
		else
			rowStr := '0' &amp; Tab;		
		endif;
		
		if _displayCode then
			rowStr := rowStr &amp; op.code &amp; '   ';
		endif;
		
		if _displayDescription then
			rowStr := rowStr &amp; op.description;
		endif;
		
		_lstTbl.accessRow(_lstTbl.addItem(rowStr)).itemObject := op;
	endforeach;
	
	
end;</source>
        <Parameter name="_lstTbl" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_displayCode" type="Boolean"/>
        <Parameter name="_displayDescription" type="Boolean"/>
        <Parameter name="_operatorsToSelect" type="CM_OperatorByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="listTablePackLocations" id="aa2e4a06-48f2-4fb7-a00d-07c7fd7754e7">
        <source>listTablePackLocations(_lstTable : CMUI_ListTable input);
/*
----------   ----------  --------------------------------------------------
Created:	07 June 2007 By cnwth2

Purpose:	

/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	ta 				: CM_TerminalArea;
	
begin

	_lstTable.clearAllSelected();
	_lstTable.rows := _lstTable.fixedRows;

	foreach ta in self.myTerminal.allTerminalAreas do
		if ta.myType = null then
			continue;
		endif;
		if ta.myType.type = TA_TYPE_IRREGULAR_BLOCK_AREA		// was TA_TYPE_GENERAL_CARGO_AREA 
		or ta.myType.type = TA_TYPE_DEPOT_LCL then // PAR 10059
			_lstTable.addItemObject(ta.id, ta);
		endif;
	endforeach;
	

end;

</source>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
