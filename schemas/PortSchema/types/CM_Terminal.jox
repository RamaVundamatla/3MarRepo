    <JadeMethod name="getOtherTerminals" id="feb91cef-1bf6-4d07-8601-0475e9ed1fc3">
        <source>getOtherTerminals(_termDict : CM_TerminalByCodeDict input);
//----------------------------------------------------------------
//	Created:	23 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	term : CM_Terminal;
begin
	if _termDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _termDict passed to method');
		return;	
	endif;
	
	_termDict.clear();
	foreach term in self.myRoot.allTerminals do
		if term &lt;&gt; self then
			_termDict.add(term);
		endif;
	endforeach;		
	
end;</source>
        <Parameter name="_termDict" type="CM_TerminalByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPendingEventRequestStops" id="fe52325d-4717-4661-8711-a55a0907db36">
        <updating/>
        <source>getPendingEventRequestStops(_trackedItem : CM_TrackedItem input; _stops : CM_StopsTableSet input) updating;
// --------------------------------------------------------------------------------
// Created:		23 September 2009 by cnwdad1
//
// Purpose:		Processes Event Request Stops.
//
// NOTE: This method was originally implemented on CM_Root.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/09/2009	cnwrs2		PAR 20395 - forst implemented.
// --------------------------------------------------------------------------------
vars
	iteratorObj		: Iterator;
	tmpEventRequestTI : CM_EventRequestTI;
	tmpStopRequest	: CM_EventRequestStops;
	
begin
	if _trackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _trackedItem');
		return;
	endif;
	
	// Check for stops
	iteratorObj	:=	self.allEventRequestStopsByCargoID.createIterator();
	self.allEventRequestStopsByCargoID.startKeyGeq(_trackedItem.id, iteratorObj);
	
	while iteratorObj.next(tmpEventRequestTI) do
		if tmpEventRequestTI.cargoId &lt;&gt; _trackedItem.id then
			break;
		endif;
		
		if tmpEventRequestTI.type &lt;&gt; EventRequestTypeStops then
			continue;
		endif;
		
		tmpStopRequest:=tmpEventRequestTI.CM_EventRequestStops;
		if tmpStopRequest.isActioned() then
			// do not reprocess PAR13403
			continue;
		endif;
		
		if tmpStopRequest.isClear then
			if _stops.includes(tmpStopRequest.myStopsTable) then
				_stops.remove(tmpStopRequest.myStopsTable);
			endif;
		else
			if (not _stops.includes(tmpStopRequest.myStopsTable)) then
				_stops.add(tmpStopRequest.myStopsTable);
			endif;
		endif;
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stops" type="CM_StopsTableSet" usage="input"/>
    </JadeMethod>
