    <JadeMethod name="validateLanesForCreate" id="e54b61fa-c36a-4bfa-a0b1-26e2ebce912b">
        <source>validateLanesForCreate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars
	lane	: CM_RoRoController;
begin
	foreach lane in self.allLanesByLaneNumber do
		lane.validateForCreate(app.myPassport);
