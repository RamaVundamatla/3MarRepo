    <JadeMethod name="timerEvent" id="17a0e335-ae98-445d-ad3e-28b46010d0e3">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/03/2025	navkc1 JIRA Story MTN-34219: MTN | Notification Framework

*/

vars

begin

	if eventTag = self.BaseForm_TimerNotes then
		if self.notificationLevel = self.NoteLevelDoNotes then
			if self.allNoteRecords.size() &gt; 100 then
				self.doNoteRefresh();
			else
				self.doNoteHandlingAll();
			endif;
			
			//self.allNoteRecords.purge();
			//self.doClearNoteRecords(false); //27/03/2025	navkc1 JIRA Story MTN-34156
			self.doClearNoteRecords(false, false); //23/06/2025	navkc1 JIRA MTN 34973
		endif;
	elseif eventTag = self.BaseForm_TimerRefresh then
		self.doNoteRefresh();
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="e67b20e6-be4e-49a3-94a1-22579b2fe8c6">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.showToolbarCaptions := _showCaptions;
	if _showCaptions then
		self.topMargin := CMUI_Toolbar.HeightWithCaptions;
	else
		self.topMargin := CMUI_Toolbar.HeightWithoutCaptions;
	endif;
	self.frmToolbar.showCaptions := _showCaptions;
	self.doResize;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateCaption" id="27d61a4a-c012-406c-adde-c73afcd63120">
        <updating/>
        <source>translateCaption(_id : Integer; _locale : CM_Locale) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Mar 2010	cnwkpd1	PAR #22713 - correct translation of form caption
26 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	translation	: XLAT_Translation;
begin
//	if _locale = null then
//		return;
//	endif;
	// An appropriate translation is provided or nothing happens
	// and the default bubbleHelp text from Painter is displayed.
	translation	:= app.zGetTranslatedText(XLAT_FormCaptions, _id);
	if translation &lt;&gt; null then
		self.caption := translation.text;
	endif;
	
	self.captionId := _id;			// PAR #34210
	
end;
</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2b5f27bb-4f80-4205-bcd5-497f8699c8c7">
        <updating/>
        <source>translateForm() updating;

	// This method is called by the CM_BaseForm::load method.
	// Subforms reimplement the method to provide caption and bubbleHelp text
	// that has been translated for locales supported by the system.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
