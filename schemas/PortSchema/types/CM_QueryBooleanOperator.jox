    <JadeMethod name="doMatch" id="861ca0b0-98d4-4192-a3c5-d5c03ee329d4">
        <source>doMatch(_value: Boolean): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.notApplicable then	//23 Mar 2015	NDL	Par 35886
		return true;
	endif;
	
	return self.searchValue = _value;


end;</source>
        <Parameter name="_value" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="bddc88df-b0cd-4ee9-90d3-496335f2480d">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	_searchValueA			:= null;
	_searchValueB			:= null;
	_searchValueBoolean		:= self.searchValue;
	_isStringProperty		:= false;
	_isStringBetweenProperty:= false;
	_isBooleanProperty		:= true;
	
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="1d80b1aa-0ff3-495b-849b-9ef15257d6f6">
        <source>getSearchValue(): Any;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.searchValue;


end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="5d02499c-d9ce-4ce3-8804-b3e0d4bb285b">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.notApplicable then	//23 Mar 2015	NDL	Par 35886
		return app.getErrorString(NotApplicable);
	endif;
	
	return _prop.translateToDisplayValue(self.searchValue);

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
