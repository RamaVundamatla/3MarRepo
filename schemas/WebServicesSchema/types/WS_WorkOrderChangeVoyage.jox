    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="voyageOid" id="91a88d5b-34f9-4b1b-917a-38e039ff7f10">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="00d9fdfe-4e25-48a7-847b-714cbe53886f">
        <source>createProxyWorkOrder(): CM_WorkOrderTIDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars

	pxyWorkOrder : CM_WodNullVoyage;

