    <JadeMethod name="setCMIF_RakeRegion" id="6de6ab57-5ce0-4646-90a1-2015f6b3f65e">
        <source>setCMIF_RakeRegion(_cmifRakeRegion : CMIF_RakeRegion input);
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	railObj : CM_Rail;
	outRake : CM_RailJSInOutRake;
	
begin
	_cmifRakeRegion.myTrain := self.cmbTrains.listObject.CM_Train;
	
	railObj := self.cmbRailArea.listObject.CM_Rail;
	if railObj = null then
		return;
	endif;

	foreach obj in railObj.allRailJSInOut do
		if obj.isKindOf(CM_RailJSInOutRake) and obj.CM_RailJSInOutRake.inOut.outwards = Rail_JSIO_Type_Out then
			outRake := obj.CM_RailJSInOutRake;
			break;
		endif;
	endforeach;
	
	if outRake = null then
		return;
	endif;


	_cmifRakeRegion.startPosition := self.cmbRakePos1.text.Integer;
	_cmifRakeRegion.endPosition := self.cmbRakePos2.text.Integer;
	

	_cmifRakeRegion.myRailArea := self.cmbRailArea.listObject.CM_Rail;
	_cmifRakeRegion.myRailJSIORake := outRake;

	_cmifRakeRegion.clearAll := false;	
	
	//if self.tblClearRake.getValueByName(ETRow_RailLine).String = 'All' then
		
	if self.cmbRailRake.listObject &lt;&gt; null then
		_cmifRakeRegion.allRailLines.add(self.cmbRailRake.listObject.CM_RailLine);
	else
		_cmifRakeRegion.clearAll := true;
		if _cmifRakeRegion.myRailArea &lt;&gt; null then
			_cmifRakeRegion.myRailArea.allRailLines.copy(_cmifRakeRegion.allRailLines);
		endif;
	endif;
	
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion" usage="input"/>
    </JadeMethod>
