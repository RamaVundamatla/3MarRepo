    <JadeMethod name="setMainDwellTM" id="0a01064c-f3be-401f-84cd-dfd064bf06f8">
        <updating/>
        <source>setMainDwellTM(_inv : CM_Invoice)updating;

/*


Parameters:			

Return Value:		

Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/
vars
	invLine : CM_InvoiceLine;
	tiArray  : CM_TIArray;
	ti      : CM_TrackedItem;
	dwTExpTmp,
	dwTImpTmp,
	dwTExp,
	dwTImp  : Real;
	cnt : Integer;
	muatTmp,
	muat ,
	
	bonkarTmp,
	bonkar     : Real;
begin
	
	create tiArray transient;
	foreach invLine in _inv.invoiceLines discreteLock do
		if invLine.myTransactionTI &lt;&gt; null then
				if invLine.myTransactionTI.myTrackedItem &lt;&gt; null then
					ti := invLine.myTransactionTI.myTrackedItem;
					if not tiArray.includes(ti) then
						tiArray.add(ti);
					endif;
				endif;
		endif;
	endforeach;
	
	foreach ti in tiArray do 
		if ti.isKindOf(CM_Container) then
			cnt := cnt +1;
			if ti.receivedDT.isValid and ti.releasedDT.isValid then
				
				if ti.isImport then
					dwTImpTmp  := ti.releasedDT.Date.addDays(1)- ti.receivedDT.Date ;
					write ti.id &amp; " " &amp; "DWL :" &amp; dwTImpTmp.String;
					dwTImp := dwTImp + dwTImpTmp;
				elseif ti.isExport then
					dwTExpTmp  := ti.releasedDT.Date.addDays(1)- ti.receivedDT.Date ;
					write ti.id &amp; " " &amp; "DWL :" &amp; dwTExpTmp.String;
					dwTExp := dwTExp + dwTExpTmp;
					
				endif;
			endif;
		endif;
	endforeach;
	
	if dwTImp &gt; 0 and cnt &gt; 0 then
		self.dwellTMImp := dwTImp/cnt;
	endif;
	if dwTExp &gt; 0 and cnt &gt; 0 then
		self.dwellTMExp := dwTExp/cnt;
	endif;
	
	cnt := 0;
	
	foreach ti in tiArray do 
		if not ti.isKindOf(CM_Container) then
			bonkarTmp := 0 ;
			muatTmp   := 0;
				cnt := cnt +1;
			if ti.receivedDT.isValid and ti.releasedDT.isValid then
			
				if ti.isImport then
					bonkarTmp  := ti.releasedDT.Date.addDays(1)- ti.receivedDT.Date ;
					write ti.id &amp; " " &amp; "DWL :" &amp; bonkarTmp.String;
					bonkar := bonkar + bonkarTmp;
				elseif ti.isExport then
					muatTmp  := ti.releasedDT.Date.addDays(1)- ti.receivedDT.Date ;
					write ti.id &amp; " " &amp; "DWL :" &amp; muatTmp.String;
					muat := muat + muatTmp;
					
				endif;
			endif;
		endif;
	endforeach;
	
	if muat &gt; 0 and cnt &gt; 0 then
		muat                      := muat.roundedTo(0);
		self.dwellTMMuat      := muat/cnt;
	endif;
	if bonkar &gt; 0 and cnt &gt; 0 then
		bonkar                      := bonkar.roundedTo(0);
		self.dwellTMBongkar      := bonkar/cnt;
	endif;

epilog
	
	delete tiArray; //02 Oct 2019	NDL	 - Transient leak, found when writing unit tests for TFS 46758
	
end;
</source>
        <Parameter name="_inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setMainProductivities" id="0dd94797-38f3-4471-a8af-f88c9a15d5aa">
        <updating/>
        <source>setMainProductivities(_moveTrans : CM_ObjectArray;_prodType : Integer;_movement : HMS_Movement ;_delay : CM_Delay;_start ,_end :TimeStamp;_holdET :Real):Real updating;
/*

Purpose:			
	2.	Productivities, whichconsists of :
		a.	Ton/Gang/Hour;
		b.	Ton/Ship/Hour;
		c.	Box/Crane/Hour;
Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
*/

vars
	prodLiq,
	prodContainer,
	productiv		: Real;
begin
		
		if _prodType = CMIF_Kinerja.PROD_LIQUID_BULK then
			prodLiq := self.getTotalWTProdLiquid(_moveTrans,_movement,_delay,_start,_end);
			if prodLiq &lt;&gt; 0 and _holdET &lt;&gt; 0 then
				prodLiq := prodLiq/1000;
				prodLiq := prodLiq /_holdET;
				
				return prodLiq;
			endif;
		endif;
		
		if _prodType = CMIF_Kinerja.PRODUKTIVITAS then
			productiv := self.getTotalWTProduktvitas(_moveTrans,_movement,_delay,_start,_end);
			if productiv &lt;&gt; 0 and _holdET &lt;&gt; 0 then
				productiv := productiv/1000;
				productiv := productiv /_holdET;
				return productiv;
			endif;
		endif;
		
		if _prodType = CMIF_Kinerja.PROD_CONTAINER then
			write "*********************** Start Prod Container ****************************";
			write " Delay : " &amp;  _delay.getDescription(false);
			write " Hold ET : " &amp; _holdET.String;
			prodContainer := self.getTotalTEUConatiner(_moveTrans,_movement,_delay,_start,_end);
			if prodContainer &lt;&gt; 0 and _holdET &lt;&gt; 0 then
				prodContainer := prodContainer /_holdET;
				return prodContainer;
			endif;
			write "*********************** End Prod Container ****************************";
		endif;
		
	return null;
epilog

end;</source>
        <Parameter name="_moveTrans" type="CM_ObjectArray"/>
        <Parameter name="_prodType" type="Integer"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_holdET" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setMainServiceTM" id="026ad4cc-0c55-4737-9216-2df472a8caa8">
        <updating/>
        <source>setMainServiceTM(_movement : HMS_Movement)updating;
/*

Purpose:			
	1.	Service Time,whichconsists of :
		a.	Waiting Time;
		b.	Postpone Time;
		c.	Approach Time;
		d.	Berth Working Time;
		e.	Effective Time;
		f.	Idle Time;
		g.	Not Operation Time;
		h.	Berthing Time;
		i.	Turn Round Time.
Parameters:			

Return Value:		

Date		Who		Reason
04 Se 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
*/

vars

begin
	//The Sequence is  important
	self.setSTWaitingPilotTM(_movement);
	self.setSTWaitingDermagaTM(_movement);   
	self.setSTBerthTMAndRealization(_movement); 
	self.setSTApproachTM(_movement);
	self.setSTBerthWorkingTM(_movement);     
	self.setSTTurnRoundTM(_movement);
	self.setSTeTbT(_movement);
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setMainUtilization" id="4ecf1773-f4ba-44e5-888f-8177cba831b8">
        <updating/>
        <source>setMainUtilization(_movement : HMS_Movement;_period : Integer) updating;
/*

Purpose:			
	3.	Utilization, whichconsists of :
		a.	Berth Occupancy Ratio;
		b.	Berth Through Put;
		c.	Shed Occupancy Ratio;
		d.	Shed Through Put;
		e.	Yard Occupancy Ratio;
		f.	Yard Through Put;
		g.	Utilizes ;
		h.	Available Time;
		i.	Possible Time;
		j.	Operation Time;
		k.	Down Time;
		l.	Availability.

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars

begin
	self.setUTBerthOccupancyRatio(_movement,_period);
	self.setUTBerthThroughPut(_movement);

epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_period" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="8b9be43d-b948-4e7d-b033-b9bcb76f321d">
        <updating/>
        <source>setMyVoyage(_voy : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	
begin
	self.myVoyage := _voy;
