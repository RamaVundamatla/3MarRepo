    <JadeMethod name="base64DecodeToString" id="75115063-f06b-4a94-832a-7e97be83d104">
        <source>base64DecodeToString():String;
/*

Purpose:			

Parameters:			For use against the string embedded within Web messages etc. that is actually a binary base64encoded
					and decodes it and returns user readable string.
					The value within &lt;jmt:message&gt; &lt;/jmt:message&gt; tags in the soap messages sent in web based EDI is a good example.
Return Value:		

Date				Who		Reason
11 February 2021	jlgndl1	Initial creation	TFS 50767
09 July 2024		navmd1 Change to work on Unicode systems too

*/

vars

	binary : Binary;
	str : String;

begin

	binary := self.base64Decode();
	//str := binary.asStringJMT;
	str := binary.ansiToString;		// base64 can be safely assumed to be of the ANSI characterset
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="binaryAsInteger" id="357255b3-59de-4826-8164-5b5d255ed992">
        <source>binaryAsInteger() : Integer;
// ---------------------------------------------------------------------------
// Created:     03 April 2003 by cnwrs2
//
// Purpose:     Assumes self is made up of 1 &amp; 0 as a binary number
//
// Returns:     The integer equivalent of self
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	revStr		: String;
	maxLen,
	idx,
	tmpValue,
	rtnValue	: Integer;
	tmpChar		: Character;	

begin

	revStr := self.reverse.trimBlanks;
	
	maxLen := revStr.length;
	
	foreach idx in 1 to maxLen do
		tmpChar := revStr[idx];
		if tmpChar = '1' then
			tmpValue := 2 ^ (idx -1);
		elseif tmpChar = '0' then
			tmpValue := 0;
		else
			// invalid char so break
			break;
		endif;
		rtnValue := rtnValue + tmpValue;
	endforeach;
	
	return rtnValue;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="compressToBinaryWithTruncation" id="da3cf4de-1959-4359-bd01-10cb1f54ee30">
        <source>compressToBinaryWithTruncation(_maxLength : Integer) : Binary;

/*

Purpose:			Compress the receiver to a Binary equivalent, with a maximum length of
					the value passed in.  If the resulting Binary value is longer than this
					maximum, then first try a higher compression ratio.  If this also fails 
					then truncate the input String until the result is no larger than the 
					_maxLength

Parameters:			Maximum length of the Binary to return

Return Value:		Binary compressed equivalent of the receiver


Date		Who		Reason
19 Jun 2008	cnwkpd1	Reduce EDI file lines size in DB, and allow for files or &gt; 512 byte lines

*/

vars
	outputBinary	: Binary;
	truncatedSelf	: String;
	outputLen,
	truncLen,
	newLen,
	oversize		: Integer;
	
begin
	// Handle error condition first
	if _maxLength &lt;= 0 then
		return null;
	endif;
//write method.qualifiedName &amp; " self.length = " &amp; self.length.String;
//write method.qualifiedName &amp; " _maxLength = " &amp; _maxLength.String;

	// Try fast compression 
	outputBinary := self.compressToBinary(Binary.Compression_ZLibFast);
//write method.qualifiedName &amp; " Compression_ZLibFast length = " &amp; outputBinary.length.String;	
	if outputBinary.length &lt;= _maxLength then
		return outputBinary;
	endif;

	// If fast mode this fails, then try the highest compression
	outputBinary := self.compressToBinary(Binary.Compression_ZlibSmall);
	outputLen := outputBinary.length;
//write method.qualifiedName &amp; " Compression_ZlibSmall length = " &amp; outputBinary.length.String;	
	if outputLen &lt;= _maxLength then
		return outputBinary;
	endif;
	
	// If we get to here, we need to truncate the receiver and try again
	truncatedSelf := self;
	while true do
		truncLen := truncatedSelf.length;
//write method.qualifiedName &amp; " truncLen = " &amp; truncLen.String;	
		oversize := outputLen - _maxLength;
//write method.qualifiedName &amp; " oversize = " &amp; oversize.String;	
		if oversize &gt;= truncLen then			// Can't get enough, so bail and return null
			return null;
		endif;
		
		// Calculate new truncated length 
		newLen := truncLen - oversize;
//write method.qualifiedName &amp; " newLen = " &amp; newLen.String;			
		truncatedSelf := truncatedSelf[1:newLen];
		
		outputBinary := truncatedSelf.compressToBinary(Binary.Compression_ZlibSmall);
		outputLen := outputBinary.length;
//write method.qualifiedName &amp; " truncated Compression_ZlibSmall length = " &amp; outputBinary.length.String;	
		if outputLen &lt;= _maxLength then
			return outputBinary;
		endif;
	endwhile;

	return null;
	
	
epilog

end;</source>
        <Parameter name="_maxLength" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="containsOneOf" id="c8f65bb9-586d-47c2-901e-a0a36ce72b39">
        <source>containsOneOf(str : String) : Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 12 March 2007
//
//  Basic check to see if the receiver contains any of the characters that have been passed in.
//  If one of the characters exists then the str will be different when compared.
//
//----------------------------------------------------------------------
vars
	newString 	: String;
	pos 	: Integer;
begin
	//If the string is null then we can't contain any of the passed characters.
	if self = null then
		return false;
	endif;
	//Are we checking for anything?
	if str.length = 0 then
		return true;
	endif;
	
	pos := 1;
	newString := self.scanUntil(str, pos);
	
	//Compare the new string with the original.  If the new string is the same then I didn't find any of the characters that I'm checking for.
	if newString = self then
		return false;
	endif;
	
	//Yes we found one of the characters if we get to here.
	return true;
epilog

end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="containsOnlyAlphaAndReal" id="1f996929-fc0f-46ce-bf81-a7c50d8b93b4">
        <source>containsOnlyAlphaAndReal():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	#cnwdz2	 

*/

vars
	char         : String;
	idx, len : Integer;
begin
	len := self.length();
	
	foreach idx in 1 to len do
		char :=  self[idx:1];
		if not char.isReal and not char.isAlpha then
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="containsOnlyUppAlphaAndNumeric" id="3fb41e39-903a-476d-9f9b-9c438faca753">
