    <JadeMethod name="setupControls" id="38282ab7-f511-4630-9b9a-79b5a6c9b488">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	selectedTi : CM_TrackedItem;
	btn : MOB_Button;
	selectedButton : MOB_Button;
	ti : CM_TrackedItem;
	selectedSheet : MOB_Sheet;
	index : Integer;
	previousCaption : String;	//10 Mar 2017 NDL	TFS 3676

begin

	previousCaption := self.myMobileGenericAgent.stringField1;	//10 Mar 2017 NDL	TFS 3676
	self.myMobileGenericAgent.setStringField1(null);
	
	self.populateCmbSortBy();
	self.cmbSortBy.listIndex := 1;
	self.populateLblBookings();
	self.populateCmbLocation( self.myMobileGenericAgent.myLocationsController );

	self.doResizeControls(true);
	
	self.populateCargo();
	
	selectedTi := self.myMobileGenericAgent.myNextTiToAction;
	
	if app.myMobileCargoFindAgent.myYardLoc &lt;&gt; null then
		self.txtTargetLoc.text := app.myMobileCargoFindAgent.myYardLoc.getFullId;
		self.txtTargetLoc.userObject := app.myMobileCargoFindAgent.myYardLoc;
		app.myMobileCargoFindAgent.setMyYardLoc( null );
	endif;
	
	if selectedTi &lt;&gt; null then
	
		self.myMobileGenericAgent.setAllReserveDetails( null );
		self.myMobileGenericAgent.setAllBookingRefItems( null );
		self.myMobileGenericAgent.setMyNextTiToAction( null );
		
		self.cmbSortBy.listIndex := self.myMobileGenericAgent.decimalField1.Integer;
		self.myMobileGenericAgent.setDecimalField1( 0 );
		
		self.doFindCargoButton( null, selectedTi );
			
	endif;
	
	//10 Mar 2017 NDL	TFS 3676
	if previousCaption &lt;&gt; null then
		if self.shtStored.caption = previousCaption then
			self.fldStripped.topSheet := self.shtStored;
		elseif self.shtToComplete.caption = previousCaption then
			self.fldStripped.topSheet := self.shtToComplete;
		endif;
	endif;
	
	self.txtTargetLoc.lostFocus( self.txtTargetLoc );
	
	 //10 Mar 2017 NDL	TFS 3676
	if self.fldStripped.topSheet = self.shtToComplete then
		self.txtCargoId.setFocus();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3e00be8a-abea-4e56-a912-ec6030b34696">
