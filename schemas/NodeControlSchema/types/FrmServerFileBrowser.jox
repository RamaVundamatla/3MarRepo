    <JadeMethod name="collapseNode" id="277daaf4-6c33-4c37-8d37-fd162371c30a">
        <source>collapseNode(lb : ListBox; index : Integer);
vars
	i : Integer;
	lvl : Integer;

begin
	if not lb.itemHasSubItems(index) or not lb.itemExpanded[index] then
		return;
	endif;

	lvl := lb.itemLevel[index];
	i := index + 1;
	while i &lt;= lb.listCount and lb.itemLevel[i] &gt; lvl do
		lb.removeItem(i);
	endwhile;

	addDummyNode(i, lvl + 1);

	lb.itemExpanded[index] := false;
	if lvl &gt; 1 then
		lb.itemPictureType[index] := ListBox.ItemPictureType_Closed;
	endif;

end;</source>
        <Parameter name="lb" type="ListBox"/>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dirTreeList_click" id="8b762284-09fe-4d61-8083-cdc7fac1e8f5">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dirTreeList_click(listbox: ListBox input) updating;

vars

begin
   selectedItem := getPathFromNode(listbox.listIndex);
   lblPathName.caption := selectedItem;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dirTreeList_dblClick" id="2d84e644-e37c-4369-af91-facfc1767ffb">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dirTreeList_dblClick(listbox: ListBox input) updating;

vars

begin
	if listbox.itemExpanded[listbox.listIndex] then
		collapseNode(listbox, listbox.listIndex);
	else
		expandNode(listbox, listbox.listIndex);
	endif;

	dirTreeList_click(listbox);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dirTreeList_keyDown" id="8494024a-d40f-44db-9930-98ef00d89ee3">
        <controlMethod name="ListBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dirTreeList_keyDown(listbox:ListBox input; keyCode:Integer io; shift:Integer) updating;

begin
//	write keyCode;
	if keyCode=38 and shift=2 then  // Ctrl+Up
		listbox.topIndex:=listbox.topIndex-2;
		keyCode:=0;

	elseif keyCode=40 and shift=2 then  // Ctrl+Down
		listbox.topIndex:=listbox.topIndex+2;
		keyCode:=0;
		
	elseif keyCode=39 then  // right arrow
		if listbox.itemExpanded[listbox.listIndex] = false then
			expandNode(listbox, listbox.listIndex);
		else
			listbox.listIndex:=listbox.listIndex+1;
		endif;

	elseif keyCode=37 then  // left arrow
		if listbox.itemExpanded[listbox.listIndex] = true then
			collapseNode(listbox, listbox.listIndex);
		else
			while listbox.itemLevel[listbox.listIndex]&gt;1 do
				listbox.listIndex:=listbox.listIndex-1;
				if listbox.itemExpanded[listbox.listIndex] = true then
					break;
				endif;
			endwhile;
			listbox.itemSelected[listbox.listIndex]:=true;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dirTreeList_pictureClick" id="f4cae6db-a535-4fe7-924c-8edb0c1e28e1">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dirTreeList_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;

vars

begin
	if whatClicked = listbox.PictureClick_PlusMinus then
		if listbox.itemExpanded[picIndex] then
			collapseNode(listbox, picIndex);
		else
			expandNode(listbox, picIndex);
		endif;
	endif;

	listbox.listIndex := picIndex;
	dirTreeList_click(dirTreeList);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="expandNode" id="db2ab4d2-3202-4036-9daa-15e4132d0939">
        <source>expandNode(lb : ListBox input; index : Integer);
vars
    pathName : String;
    level    : Integer;
begin
    pathName := getPathFromNode(index);
	// Only expand an item if it has subitems and it isn't already expanded
    if lb.itemHasSubItems(index)  and not lb.itemExpanded[index] then
		if lb.itemText[index + 1] = Dummy then
			// Remove the placeholder entry
			lb.removeItem(index + 1);
            level := lb.itemLevel[index] + 1;
            addDirectoryNodes(index + 1, level, pathName);

			lb.itemExpanded[index] := true;
			lb.topIndex:=index-2;
			if level &gt; 2 then
				lb.itemPictureType[index] := ListBox.ItemPictureType_Open;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="lb" type="ListBox" usage="input"/>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNodeFromPath" id="fee78df3-410f-4a9d-8d93-2c96ff8dcfbb">
        <updating/>
        <source>getNodeFromPath(lb:ListBox input; s:String; level:Integer) updating;

vars
	i,j,k:Integer;
	t:String;
begin
	i:=1;
	t:=s.scanUntil("\:/",i).toUpper;
	if i = 0 and t = null then return; endif;
	if level = 1 then
		t:=t&amp;":\";
	endif;
	
	j:=lb.listIndex;
	k:=lb.listCount;
	while j &lt;= k do
		if lb.itemLevel[j] = level and lb.itemText[j].toUpper &gt;= t then
			lb.listIndex:=j;
			lb.itemSelected[j]:=true;
			if lb.itemText[j].toUpper &gt; t and not lb.itemHasSubItems(j) then
				break;
			endif;
			if i &lt;&gt; 0 then
				t:=s.scanWhile("\:/",i);
			endif;
			if i &lt;&gt; 0 and lb.itemHasSubItems(j) then
				expandNode(lb, j);
				getNodeFromPath(lb, s[i:end], level+1);
			endif;
			break;
		endif;
		j:=j+1;
	endwhile;
end;</source>
        <Parameter name="lb" type="ListBox" usage="input"/>
        <Parameter name="s" type="String"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPathFromNode" id="9402b0d3-d3b2-4f30-a605-cc26cbfbcf8b">
        <source>getPathFromNode(index : Integer) : String;
vars
	pathName :	String;
	s :			String;
	level :		Integer;
	i :			Integer;
begin
	level := dirTreeList.itemLevel[index] + 1;
	foreach i in index to 1 step -1 do
		if dirTreeList.itemLevel[i] &lt; level then
			s := dirTreeList.itemText[i];
			if s[s.length] &lt;&gt; dirSep and pathName &lt;&gt; null then
				s := s &amp; dirSep;
			endif;
		    pathName := s &amp; pathName;

			level := dirTreeList.itemLevel[i];
		endif;
		if level &lt; 2 then
			break;
		endif;
	endforeach;

	return pathName;
end;</source>
        <Parameter name="index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasFile" id="1875a431-0fdd-4359-af7c-51618c45e423">
        <executionLocation>server</executionLocation>
        <source>hasFile(dirname : String) : Boolean serverExecution;
vars
	ff : FileFolder;
	fn  : FileNode;
begin
	create ff;
	ff.fileName := dirname;
	ff.mask := "*.*";

	foreach fn in ff.files do
		if fn.isKindOf(File) then
			return true;
		endif;
	endforeach;

	return false;

epilog
	delete ff;
end;</source>
        <Parameter name="dirname" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSubdirectory" id="e59a351d-0af7-433c-869d-d5fe781a7faf">
        <source>hasSubdirectory(dirname : String) : Boolean;
vars
	ff : FileFolder;
	fn  : FileNode;
begin
	create ff;
	ff.fileName := dirname;
	ff.mask := "*.*";

	foreach fn in ff.files do
		if fn.isKindOf(FileFolder) then
			return true;
		endif;
	endforeach;

	return false;

epilog
	delete ff;
end;</source>
        <Parameter name="dirname" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="079c956b-feac-4385-ac3a-0a89b528206f">
        <updating/>
        <source>init(title : String; heading : String; startFolder : String) updating;

vars

begin
	caption := title;
	lblHeading.caption := heading;
	lblPathName.caption := selectedItem;
end;</source>
        <Parameter name="title" type="String"/>
        <Parameter name="heading" type="String"/>
        <Parameter name="startFolder" type="String"/>
    </JadeMethod>
    <JadeMethod name="initDirectoryTree" id="18c3c701-8c88-4bc3-b754-6cab9e3487e3">
        <updating/>
        <source>initDirectoryTree() updating;

vars

begin
	dirTreeList.hasTreeLines := true;
	dirTreeList.hasPictures := true;
	dirTreeList.hasPlusMinus := true;

	if node._isUnixServerPlatform then
		initDirectoryTreeUnix();
	else
	    initDirectoryTreeWindows();
	endif;

    dirTreeList.listIndex := 1;
	if selectedItem &lt;&gt; null then
		getNodeFromPath(dirTreeList, selectedItem, 1);
    endif;
    dirTreeList_click(dirTreeList);
end;</source>
    </JadeMethod>
    <JadeMethod name="initDirectoryTreeUnix" id="f09bfd97-cf0a-4cd9-ba4c-9020e9b0db40">
        <source>initDirectoryTreeUnix();
begin

	// add root node
	addDirectoryNode(1, 1, "/");
	// add first level of directories from root
	addDirectoryNodes(2, 2, "/");

	// expand root
	dirTreeList.itemExpanded[1] := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="initDirectoryTreeWindows" id="e2057192-d1ca-46ca-bb94-b02a73f3d9e0">
        <updating/>
        <source>initDirectoryTreeWindows() updating;

vars
	driveList : Integer;
	i 		  : Integer;
	drivestr  : String;
begin
	// obtain bit mask of fixed disk and network drives on the server
//	driveList := app._getServerLogicalDriveMask();  // deimplemented in 6.2
//	driveList := app.getLogicalDriveMask();	
	drivestr := "?:\";

	// add a node for each drive
	foreach i in 0 to 26 do
//		if driveList.bitAnd(2 ^ i) &lt;&gt; 0 then
			drivestr[1] := ('A'.Integer + i).Character;
			addDriveNode(drivestr);
			addDummyNode(0, 2);
//		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="a2548494-55f7-41f9-8cb5-fe36e3a71a92">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
    f 		: FileNode;
    cls 	: Class;
begin
	centreWindow;
	if node._isUnixServerPlatform then
		dirSep := "/";
	else
	    dirSep := "\";
	endif;
	
	create folder;
	initDirectoryTree;
	dirTreeList.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="4207fe56-2df4-4fae-8613-01860d5d5de3">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin
	delete folder;
end;</source>
    </JadeMethod>
