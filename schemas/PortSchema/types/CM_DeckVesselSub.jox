        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a4162bb6-d3fa-4761-833c-23bf82431032">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxySubDeck : CM_DeckVesselSub;
	completedOK		: Boolean;
begin
	pxySubDeck:= inheritMethod();
	pxySubDeck.myParentDeck:=self.myParentDeck;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySubDeck;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySubDeck;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1c038149-c41e-41a8-aadb-f8740cd6a23e">
        <updating/>
        <source>setForCreate(_proxyDeck: CM_DeckVesselSub input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	lastDeck : CM_Deck;	
	realParentDeck : CM_DeckVessel;
begin
	
	realParentDeck:=_proxyDeck.myParentDeck;
	if realParentDeck.isTransient then
		realParentDeck :=realParentDeck.pxyGetRealObject();
	endif;
	
	
	self.myParentDeck:=realParentDeck;
	
	lastDeck:= self.myParentDeck.allSubDecks.last;
	if lastDeck = null then
		self.ordinal:=1;
	else
		self.ordinal:=lastDeck.ordinal+1;
	endif;
	
	inheritMethod(_proxyDeck, _passport);

	
	
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVesselSub" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="66187aa2-d45c-44e6-80a5-828c13008c01">
        <updating/>
        <source>setForCreateImport(_proxyDeck: CM_DeckVesselSub input; 
				_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	lastDeck : CM_Deck;	
	roroStructure : CM_ROROVesselStructure;
begin
	
	
	
	lastDeck:= self.myParentDeck.allSubDecks.last;
	if lastDeck = null then
		self.ordinal:=1;
	else
		self.ordinal:=lastDeck.ordinal+1;
	endif;
	
	inheritMethod(_proxyDeck, _passport);

	roroStructure:=self.myParentDeck.myROROStructure;
	if roroStructure &lt;&gt; null then
		if _proxyDeck.pxyGetRealObject = null then
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_CREATE, self);		
		else
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVesselSub" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="adaa6029-f98d-4bee-a745-793a0435c29f">
        <updating/>
        <source>setForUpdate(_proxyDeck: CM_Deck input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVesselStructure;
begin
	inheritMethod(_proxyDeck, _passport);

	roroStructure:=self.myParentDeck.myROROStructure;
	if roroStructure &lt;&gt; null then
		if _proxyDeck.pxyGetRealObject = null then
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_CREATE, self);		
		else
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
