    <JadeMethod name="getCargoGroupID" id="ecf29c69-c072-4443-8917-74f7cbcc7ae4">
        <source>getCargoGroupID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	cgID			: String;
	reserveDetail	: CM_ReserveDetail;
	ti				: CM_TrackedItem;
	cg				: CM_CargoGroup;
begin
	
	reserveDetail := self.getMyReserveDetail();
	
	if reserveDetail = null then
		ti := self.getFirstTI();
		
		if ti &lt;&gt; null then
			cg := ti.myCargoGroup;
			
			if cg &lt;&gt; null then
				cgID := cg.id;
			endif;
		endif;
	else
		cgID := reserveDetail.getMyCargoGroupId();
	endif;
	
	return cgID;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
