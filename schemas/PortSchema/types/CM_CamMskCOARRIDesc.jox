    <JadeMethod name="formatSeal" id="6916ef7d-87e9-4af1-a09f-1a41f816e57a">
        <source>formatSeal(_sealNumber: String; _camGroup: CM_CamGroup; _ti: CM_Container): String;
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	str 				: String;
    seal 				: String;
	pos 				: Integer;
	minLength 			: Integer;
	sealLength 			: Integer;
	prefix, suffix 		: String;
	customSeals 		: HugeStringArray; //jlgka1 TFS 44020
	sealNumCustomsFirst : String;
begin
	if app.myRoot.isClientPortOtago then //ccms 1693 cnwrs1 May 2008 new reformatting rules 
		//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustomsStringArray'
		create customSeals transient;
		_ti.getSealNumCustomsStringArray(customSeals);
		
		if not customSeals.isEmpty then
			seal := customSeals.first;
			
			if customSeals.size &gt; 1 then //must be 1 
				foreach str in customSeals do
					if str[1:5] = "NZMAF" or
					   str[1:5] = "NZFSA" then
						seal := str; //use first of these 
						break;
					endif;
				endforeach;
			endif;
		
	/*	if _ti.sealNumCustoms &lt;&gt; null then
			seal := _ti.sealNumCustoms;
			if _ti.allCustomsSealNumbers.size &gt; 1 then //must be 1 
				foreach str in _ti.allCustomsSealNumbers do
					if str[1:5] = "NZMAF" or
					   str[1:5] = "NZFSA" then
						seal := str; //use first of these 
						break;
					endif;
				endforeach;
			endif;
		elseif _ti.sealNum &lt;&gt; null then
			seal := _ti.sealNum;  */
			
		elseif _ti.getSealNum &lt;&gt; null then	//15 Sep 2010	NDL	Par 25608
			seal := _ti.getSealNum;	//15 Sep 2010	NDL	Par 25608
		elseif _ti.getSealNumShipper &lt;&gt; null then//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
			seal := _ti.getSealNumShipper;//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
		else
			return null;
		endif;
		// setup minlength 
		if seal[1:5] = 'ML-NZ' then
			minLength := 12;
		else
			minLength := 13;
		endif;
		if seal.length &gt;= minLength then
			return seal; //longer then min so do not reformat
		else
			pos := 1;
			prefix := seal.scanUntil('0123456789', pos); //find alpha prefix
			if pos &lt; 2 then // 0 all alpha, 1 starts numeric
				return seal; //no alpha prefix or no numeric following alpha prefix then do nothing
			else 
				sealLength := seal.length; //save current length
				suffix := seal[pos:sealLength-pos+1];
				str := prefix &amp; suffix.padZeros(minLength-prefix.length); //newseal is prefix and suffix padded with zeros
				return str;
			endif;
		endif;
	else //ccms 1693 cnwrs1 May 2008 leave existing behaviour alone for non Port Otago
	
		//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustomsFirst' or 'getSealNumCustoms'
		sealNumCustomsFirst := _ti.getSealNumCustomsFirst;
		seal := sealNumCustomsFirst.cnEcPadTrailing(12, ' ');//PAR 11771 [1:12];
		if sealNumCustomsFirst.length = 0 then
		elseif
		   (sealNumCustomsFirst.length = 11 or
			sealNumCustomsFirst.length = 12) and 
			seal[1:5] = 'NZMAF' and
			seal[6:sealNumCustomsFirst.length] = seal[6:sealNumCustomsFirst.length].Integer.String then
			str := sealNumCustomsFirst;
			return str;
		else
			str := 'NZMAF' &amp; seal.stripAlpha.padZeros(8)[1:8];
			return str;
		endif;
	endif;
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
    seal := _ti.getSealNum.cnEcPadTrailing(12, ' ');//PAR 11771 [1:12];
	if _ti.getSealNum.length = 0 then
	elseif
	   _ti.getSealNum.length = 12 and 
		seal[1:5] = 'ML-NZ' and
		seal[6:_ti.getSealNum.length] = seal[6:_ti.getSealNum.length].Integer.String then
		str := _ti.getSealNum;
		return str;
	else
		str :='ML-NZ' &amp; seal.stripAlpha.padZeros(7)[1:7];
		return str;
	endif;
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
	str := _ti.getSealNumShipper;
	return str;
	
epilog

	delete customSeals;
	
end;</source>
        <Parameter name="_sealNumber" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_ti" type="CM_Container"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatSealMsk" id="a5e2c9b1-3195-41b1-96e2-2587035ba8a8">
        <source>formatSealMsk(_sealType: String; _camGroup: CM_CamGroup; _ti: CM_Container; _sealParty : String output): String;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Jan 2013	cnwmc5	CCMS 2238	Initial creation 
16 Sep 2013 cnwmc5  PAR 32467  	changed for Port Nelson, they were getting incorrect formatting.
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	str			: String;
	seal		: String;
	prefix		: String;
	pos 		: Integer;	
	custSeals	: HugeStringArray; // jlgka1 TFS 44020
begin
	pos := 1;
	
	if _sealType = SealType_Operator then
		seal := _ti.getSealNum.cnEcPadTrailing(12, ' ');
		prefix := seal.scanUntil('0123456789', pos);
		
		if prefix = 'ML-NZ' then
			if _ti.getSealNum.length = 12 
			and seal[6:_ti.getSealNum.length] = seal[6:_ti.getSealNum.length].Integer.String then
				str := 'NZ' &amp; seal[6:_ti.getSealNum.length];
			else
				str := 'NZ' &amp; seal.stripAlpha.padZeros(7)[1:7];
			endif;
			_sealParty := "CA";
		elseif prefix = 'MLNZ' then
			if _ti.getSealNum.length = 11 
			and seal[5:_ti.getSealNum.length] = seal[5:_ti.getSealNum.length].Integer.String then
				str := 'NZ' &amp; seal[5:_ti.getSealNum.length];
			else
				str := 'NZ' &amp; seal.stripAlpha.padZeros(7)[1:7];
			endif;
			_sealParty := "CA";
		elseif prefix = 'NZ' then
			if _ti.getSealNum.length = 9
			and seal[3:_ti.getSealNum.length] = seal[3:_ti.getSealNum.length].Integer.String then
				str := 'NZ' &amp; seal[3:_ti.getSealNum.length];
			else
				str := 'NZ' &amp; seal.stripAlpha.padZeros(7)[1:7];
			endif;
			_sealParty := "CA";
		else
			str := seal;
			_sealParty := "SH";
		endif;
	elseif _sealType = SealType_Shipper then
		str := _ti.getSealNumShipper.cnEcPadTrailing(12, ' ');
		_sealParty := "SH";
	elseif _sealType = SealType_Customs then
		create custSeals transient;
		_ti.getSealNumCustomsStringArray( custSeals );
		foreach seal in custSeals do
			if seal[1:5] = "NZFSA" or seal[1:5] = "NZMAF" then
				str := seal;
				break;
			endif;
		endforeach;
		if str = null then
			str := _ti.getSealNumCustomsFirst();
		endif;
		_sealParty := "CU";
	endif;
	
	return str;
epilog
	delete custSeals;
end;</source>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_sealParty" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
