<Class name="CnEcTimeRange" id="2cc2a23a-ebab-4685-87d1-464050d8bdde">
    <superclass name="CnEcValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
