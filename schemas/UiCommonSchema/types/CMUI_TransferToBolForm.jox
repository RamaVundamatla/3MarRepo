    <JadeMethod name="populateCmbBOL" id="a3adb67d-772d-450f-b4cf-daf658a28776">
        <source>populateCmbBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	index : Integer;
	bol : CM_BOL;

begin

	self.cmbBOL.clear();

	if self.myVoyage &lt;&gt; null then
	
		foreach bol in self.myVoyage.allBOLInByTypeStatusNumDT do
			if not CM_BOLIn.hasInstance(bol) then
				continue;
			endif;
			index := self.cmbBOL.addItem( bol.number );
			self.cmbBOL.itemObject[index] := bol;
			if bol = self.myFromBol then
				self.cmbBOL.itemEnabled[index] := false;
			endif;
		endforeach;

	endif;
	
	self.populateCmbOperConsign( null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbOperConsign" id="ffc1abb7-61f3-4227-ac44-895ed68cf193">
        <source>populateCmbOperConsign( _bol : CM_BOL );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	consignor : CM_ConsigneeConsignor;
	failedDAC  :CM_DataAccessController;

begin

	self.cmbOperator.clear();
	self.cmbConsignee.clear();

	if _bol &lt;&gt; null then

		self.myAssistant.comboBoxOperator(self.cmbOperator, _bol.myOperator, self.myVoyage);
		self.cmbOperator.listIndex := self.cmbOperator.findObject( _bol.myOperator );
	
		foreach consignor in app.myRoot.allConsigneeConsignors where consignor.isConsignee do
			//if we don't have access to the consign passed in, list it - it SHOULD be included regardless
			if (not consignor.canUserAccessSelf(null, failedDAC, app.myPassport) or consignor.isNotAvailableForEntry) then
				continue;
			endif;
			self.cmbConsignee.itemObject[self.cmbConsignee.addItem(self.myAssistant.displayEntryConsignor(consignor))] := consignor;
		endforeach;
		
		self.cmbConsignee.listIndex := self.cmbConsignee.findObject( _bol.myConsignee );
	
	endif;

epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setMyFromBOL" id="38c98c46-8f61-4979-b73a-60201c4923a4">
        <updating/>
        <source>setMyFromBOL( _bol : CM_BOL; _selectedCargo : ObjectArray ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	self.myFromBol := _bol;
	if _bol &lt;&gt; null then
		self.myVoyage := _bol.getMyVoyage;
	else
		self.myVoyage := null;
	endif;
	
	if not _selectedCargo.isEmpty then
		_selectedCargo.copyNoDups( self.allSelectedCargo );
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_selectedCargo" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8bc6590d-5a63-4e2c-9b8a-6a554dac68b2">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	ti : CM_TrackedItem;
	str : String;
	ct : CM_CargoType;
	convertedAmount : String;
	
begin

	inheritMethod();
	
	populateCmbBOL();
	
	foreach ti in self.allSelectedCargo do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; ti.id;
	endforeach;
	
	self.lblAmount.visible := false;
	self.lblNewId.visible := false;
	self.tblAmount.visible := false;
	self.txtNewId.visible := false;
	self.txtQuantity.visible := false;
	if self.allSelectedCargo.size = 1 then
		ti := self.allSelectedCargo.first;
		if ti &lt;&gt; null and ti.canSplitTotalQuantity then
			ct := ti.myCargoType;
			self.lblNewId.visible := true;
			self.txtNewId.visible := true;
		endif;
		if ct &lt;&gt; null then
			self.lblAmount.visible := true;
			if ct.isBulkMulti then
				self.tblAmount.visible:=true;
				if ct.isTrackByWeight then
					self.lblAmount.caption:= app.getErrorString(CM_Weight);
					self.tblAmount.setup(Type_Weight, self.backColor);
					convertedAmount := ti.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
					self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
				else
					self.lblAmount.caption:= app.getErrorString(CM_Volume);
					convertedAmount := ti.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
					self.tblAmount.setup(Type_Volume, self.backColor);		
					self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
				endif;
			else
				self.lblAmount.caption:= app.getErrorString(CM_Quantity);
				self.txtQuantity.visible:=true;
			endif;
		endif;
	endif;
	
	self.lblSelected.caption := str;
	self.lblSelectedCargo.caption := self.lblSelectedCargo.caption &amp; " (x" &amp; self.allSelectedCargo.size.String &amp; ")";
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="transferCargo" id="9c2b92b9-4567-411e-bd93-9f6d7079783d">
        <source>transferCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	toBolIn : CM_BOLIn;
	operator : CM_Operator;
	consignee : CM_ConsigneeConsignor;
	theReturn : Integer;
	
	tiToSplit : CM_TrackedItem;
	newId : String;
	splitWeight : Decimal [16,4];
	splitVolume : Decimal [16,4];
	splitQuantity : Integer;

begin

	if not validate(	toBolIn,	//_bol : CM_BOLIn output;
						operator,	//_operator : CM_Operator output;
						consignee,	//_consignee : CM_ConsigneeConsignor output;
						tiToSplit,	//_tiToSplit : CM_TrackedItem output;
						newId,	//_newId : String output
						splitWeight,	//_splitWeight : Decimal output;
						splitVolume,	//_splitVolume : Decimal output;
						splitQuantity	//_splitQuantity : Integer output
						) then
		return false;
	endif;
	

	while true do 
	
		app.myTrxUA.trxTransferToBOL(	toBolIn,	//_newBol : CM_BOLIn;
										operator,	//_newOperator : CM_Operator;
										consignee,	//_newConsignee : CM_ConsigneeConsignor
										self.allSelectedCargo,	//_tis : CM_TIArray;
										tiToSplit.CM_Cargo,	//_tiToSplit : CM_Cargo 10;
										newId,	//_newId : String;
										splitWeight,	//_splitWeight : Decimal;
										splitQuantity,	//_splitQuantity : Integer;
										app.myPassport	//_passport : CM_Passport input
										);
	
		
		if not app.myPassport.trxCompletedOK then	
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transfer_cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;
	
	return true;
			
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4d4a8372-be39-4d5d-a9c6-81b6a0c198d4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 07 June 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021245, locale);
	lblAmount.translateCaption(Xlat_0021257, locale);
	lblBOL.translateCaption(Xlat_0021246, locale);
	lblConsignee.translateCaption(Xlat_0021247, locale);
	lblNewId.translateCaption(Xlat_0021258, locale);
	lblOperator.translateCaption(Xlat_0021248, locale);
	lblSelected.translateCaption(Xlat_0021249, locale);
	lblSelectedCargo.translateCaption(Xlat_0021250, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="80c214d3-313f-4c4d-84aa-9eb9d50a25c2">
        <source>validate(	_bol : CM_BOLIn output;
			_operator : CM_Operator output;
			_consignee : CM_ConsigneeConsignor output;
			_tiToSplit : CM_TrackedItem output;
			_newId : String output;
			_splitWeight : Decimal output;
			_splitVolume : Decimal output;
			_splitQuantity : Integer output
			):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2016	cnwndl1	Initial creation	TFS 1903
07 Jun 2016	 NDL - Now we have to allow for cargo splits (not just bol splits, as per ABs new requirements in TFS 1904)
*/

vars
	
	msg : String;
	
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	typeString : String;
	newQuantity : Integer;
	newWeight : Decimal [16,4];
	newVolume : Decimal [16,4];
	newId : String;
	existingTi : CM_TrackedItem;
	location : CM_LocationsController;
	allJobs : CM_JobSet;
	job : CM_Job;
	wle : CM_WorkListEntry;
	
begin
	
	_bol := self.cmbBOL.listObject.CM_BOLIn; 
	if _bol = null then
		msg := app.getErrorString(Input_required_field_bol);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.cmbBOL.setFocus();
		return false;
	endif;
	
	_operator := self.cmbOperator.listObject.CM_Operator; 
//	if _operator = null then
//		msg := app.getErrorString(Please_select_operator);
//		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
//		self.cmbOperator.setFocus();
//		return false;
//	endif;
	
	_consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor; 
	
	if self.allSelectedCargo.isEmpty then
		msg := app.getErrorString(Cargo_selected_transfer);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	if self.allSelectedCargo.size = 1 then
		newId := self.txtNewId.text.toUpper.trimBlanks;
		ti := self.allSelectedCargo.first;
		if ti &lt;&gt; null and ti.canSplitTotalQuantity then
			ct := ti.myCargoType;
		endif;
		if ct &lt;&gt; null then
			if ct.isBulkMulti then
				if ct.isTrackByWeight then
					typeString := app.getErrorString(CM_Weight);
					newWeight := self.tblAmount.getConvertedValue();
					if newWeight &gt; 0 and newWeight &lt;&gt; ti.totalWeight then
						if newWeight &gt; ti.totalWeight then
							msg := app.getErrorString1(Not_decla_quant_great_than_tot, ti.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName) );
							app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
							return false;
						else
							_tiToSplit := ti;
							_splitWeight := newWeight;
						endif;
					endif;
				else
					typeString := app.getErrorString(CM_Volume);
					newVolume :=self.tblAmount.getConvertedValue();
					newWeight := newVolume * ti.getDensity;
					if newVolume &gt; 0 and newVolume &lt;&gt; ti.totalVolume then
						if newVolume &gt; ti.totalVolume then
							msg := app.getErrorString1(Not_decla_quant_great_than_tot, ti.getConvertedTotalWeightIn(ct.myVolumeMeasurementType.shortName) );
							app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
							return false;
						else
							_tiToSplit := ti;
							_splitWeight := newWeight;
							_splitVolume := newVolume;
						endif;
					endif;
				endif;
			else
				typeString := app.getErrorString(Quantity);
				newQuantity := self.txtQuantity.text.Integer;
				if newQuantity &gt; 0 and newQuantity &lt;&gt; ti.totalQuantity then
					if newQuantity &gt; ti.totalQuantity then
						msg := app.getErrorString1(Not_decla_quant_great_than_tot, ti.totalQuantity.String );
						app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
						return false;
					else
						_tiToSplit := ti;
						_splitQuantity := newQuantity;
					endif;
				endif;
			endif;
			
			if _tiToSplit &lt;&gt; null then
				//we are trying to split some off and so far so good..
				if newId = null then
					msg := app.getErrorString(Must_enter_cargo_item_being_sp);
					app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
					return false;
				endif;
				// check there is no other cargo by the new id in the same area...
				location := _tiToSplit.myPrimaryActualLocation;
				if location = null then
					msg := app.getErrorString(Not_split_cargo_with_curre_loc);
					app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
					return false;
				endif;
				
				foreach ti in location.allTrackedItems do
					if ti.id &lt;&gt; newId then
						continue;
					endif;
					if ti.cargoType &lt;&gt; _tiToSplit.cargoType then
						continue;
					endif;
					existingTi := ti;
					break;
				endforeach;
				
				if existingTi &lt;&gt; null then
					msg := app.getErrorString1(Propos_alread_used_this_locati,newId);
					app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
					return false;
				endif;
				
				create allJobs transient;
				_tiToSplit.getAllJobs(allJobs);
				foreach job in allJobs discreteLock do
					if not job.isJobComplete then
						msg := app.getErrorString1(Not_split_items_while_incom_jo, _tiToSplit.id);
						app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
						return false;
					endif;
				endforeach;
				foreach wle in _tiToSplit.allWorklistEntries discreteLock do
					if wle.status &lt;&gt; WLE_COMPLETED then
						msg := app.getErrorString1(Not_split_items_while_incom_wo, _tiToSplit.id);
						app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
						return false;
					endif;
				endforeach;
				
				_newId := newId;
				
			else
				//we are not splitting anything, but they have entered a new id.
				if newId &lt;&gt; null then
					msg := app.getErrorString(Amount_equals);
					app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
					return false;
				endif;
			endif;
		endif;
	endif;
	
	return true;

epilog

	delete allJobs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn" usage="output"/>
        <Parameter name="_operator" type="CM_Operator" usage="output"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor" usage="output"/>
        <Parameter name="_tiToSplit" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_newId" type="String" usage="output"/>
        <Parameter name="_splitWeight" type="Decimal" usage="output"/>
        <Parameter name="_splitVolume" type="Decimal" usage="output"/>
        <Parameter name="_splitQuantity" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
