    <JadeMethod name="isSystemSecurityRole" id="a26321a2-3b4d-4a72-8b6e-9099a7979d87">
        <methodInvocation>mapping</methodInvocation>
        <source>isSystemSecurityRole(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := false;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9fd7c9a4-5f6d-465b-9bb5-d862c7237c0d">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if (not self.allUserTerminals.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Role ' &amp; self.name, 'users', null, null);
	endif;

end;</source>
    </JadeMethod>
