    </JadeMethod>
    <JadeMethod name="getTIs" id="1b25eb56-fd22-435d-92bd-8356077b0ff4">
        <source>getTIs(_array: CM_TIArray input; _mode: Integer; _clear: Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 31 Mar 2025  navma1 		MTN-34387 MTN - Removing Unnecessary Audits
//
vars
	lc : CM_LocationsController;
	col : CM_GeneralCargoAllocController;
	ti : CM_TrackedItem;
	
begin
	if _mode = REAL_MODE then
		// PAR 27749 - Add CLEAR param to this method and passed through to other methods
		if _clear then
			_array.clear();
		endif;
		foreach lc in self.allLocations discreteLock do
			
			/*
			31.03.2025 navma1 #MTN-34387
			foreach ti in lc.allTrackedItems discreteLock do
				_array.add(ti);
			endforeach;
			*/
			lc.allTrackedItems.copy(_array);						//31.03.2025 navma1 #MTN-34387
		endforeach;
	elseif _mode = PLANNING_MODE then
		foreach lc in self.allLocations discreteLock do
			lc.getAllPlannedTrackedItems(_array, _clear, false);
		endforeach;
	elseif _mode = QUEUE_MODE then
		foreach lc in self.allLocations discreteLock do
			lc.getAllQueuedTrackedItems(_array, _clear);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_array" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCoveredBy" id="5b44872e-af08-473f-8eef-e7a2eaee2497">
        <source>isCoveredBy( _allocation : CM_YardAllocation ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2021	navndl1	Initial creation	TFS 49912 

*/

vars

	lc : CM_LocationsController;
	yc : CM_YardController;

begin
	if self.allLocations.isEmpty then
		return false;
	endif;

	foreach lc in self.allLocations where lc.isYardLocation do
		yc := lc.CM_YardController;
		if not _allocation.allYardControllers.includes( yc ) then
			return false;
		endif;
	endforeach;

	return true;  //all of the locations within this 'Column Group' are within the Yard Allocation.

epilog

end;</source>
        <Parameter name="_allocation" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
