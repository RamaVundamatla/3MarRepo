    <JadeMethod name="trxCreateScaleType" id="82de5b9e-9afe-4476-a6d5-01bb7dbcb051">
        <updating/>
        <source>trxCreateScaleType(	pProxyScaleType : CM_WeighBridgeObjType input; 
					pNewScaleType : CM_WeighBridgeObjType output;
