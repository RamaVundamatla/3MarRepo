    <JadeMethod name="getTIProperties" id="5eaa072a-d946-43e5-a5a6-7a9773a7b0b8">
        <source>getTIProperties(_propArray: ObjectArray io);
//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	popColl	: PropertyNDict;
	property : Property;
begin
	inheritMethod(_propArray);
	// now the sub-class properties
	popColl	:= CM_EDICommodityTI.getProperties;
	foreach property in popColl do
		_propArray.add(property);
	endforeach;
epilog

end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="46096c03-91ab-431c-8a2c-214e7574c129">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Jul 2018	jlgrs1	TFS PLI01
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	allAddCommodity		: CM_CommodityArray;
	allUpdCommodity		: CM_CommodityArray;
	allDelCommodity		: CM_CommodityArray;
	pxyCommodityObj		: CM_Commodity;
	realCommodityObj	: CM_Commodity;
	ediCommodityTI		: CM_EDICommodityTI;
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	create allAddCommodity transient;
	create allUpdCommodity transient;
	create allDelCommodity transient;
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
		//self.zLoadDB(ediTI.CM_EDICommodityTI, passport);
		
		ediCommodityTI	:=	ediTI.CM_EDICommodityTI;
		realCommodityObj	:=	app.myRoot.allCommodities[ediCommodityTI.code];
		
		if realCommodityObj = null then
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				continue;
			endif;
			
			create pxyCommodityObj transient;
			ediCommodityTI.setProxyFromEDI(pxyCommodityObj);
			allAddCommodity.add(pxyCommodityObj);
		else
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				allDelCommodity.add(realCommodityObj);
			else
				pxyCommodityObj	:=	app.createUpdateProxy(realCommodityObj).CM_Commodity;
				ediCommodityTI.setProxyFromEDI(pxyCommodityObj);
				allUpdCommodity.add(pxyCommodityObj);
			endif;
		endif;
	endforeach;
	
	app.myTrxUA.trxProcessEDICommodity(self, allAddCommodity,
												allUpdCommodity,
												allDelCommodity,
												false, _passport);
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
epilog
	allAddCommodity.purge();
	allUpdCommodity.purge();
	
	delete allAddCommodity;
	delete allUpdCommodity;
	delete allDelCommodity;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCommoditys" id="4e8619bf-e7b6-4499-9ca5-bd0a37764712">
        <source>validateCommoditys(_allAddCommoditys, _allUpdCommoditys, _allDelCommoditys	: CM_CommodityArray) protected;

//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	pxyObj	: CM_Commodity;
	realObj	: CM_Commodity;
begin
	foreach pxyObj in _allAddCommoditys do
		app.myValCA.valCommodity(pxyObj);
	endforeach;
	
	foreach pxyObj in _allUpdCommoditys do
		realObj	:=	pxyObj.pxyGetRealObject();
		app.myValUA.valCommodity(realObj, pxyObj);
	endforeach;
	
	foreach realObj in _allDelCommoditys do
		app.myValDA.valCommodity(realObj);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allAddCommoditys" type="CM_CommodityArray"/>
        <Parameter name="_allUpdCommoditys" type="CM_CommodityArray"/>
        <Parameter name="_allDelCommoditys" type="CM_CommodityArray"/>
    </JadeMethod>
