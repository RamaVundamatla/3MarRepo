    <JadeMethod name="isSimilarQueueArea" id="cc439dc9-e539-417b-ac91-2fe3518d697e">
        <source>isSimilarQueueArea(_location: CM_LocationsController): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin

	if _location.isKindOf(CM_GridController) then
		foreach ta in self.allTAsByTypeId discreteLock do
			if ta.isSimilarQueueArea(_location) then
				return true;
			endif;
		endforeach;
	endif;
	return false;

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
