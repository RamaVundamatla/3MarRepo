    <JadeMethod name="frmExchDate_doTabOrder" id="a5ef196d-dd4d-432a-9bd4-1113aa0fa76f">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>frmExchDate_doTabOrder(_startTab: Integer):Integer protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2009	cnwdap1	Initial creation
*/
vars
	tabOrder	: Integer;

begin
	tabOrder					:= _startTab;
	tabOrder 					:= tabOrder + 1;
	txtExchDate.tabIndex 		:= tabOrder;
	tabOrder 					:= tabOrder + 1;
	btnUseShipExch.tabIndex 	:= tabOrder;
	return tabOrder;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="db7f8f6a-64e9-44d2-b3d5-c278c3943620">
        <source>loadData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

	aJS : CM_VoyageJobSheet;
	aTS : TimeStamp;
	crID : String;
	
begin

	if self.myCrane &lt;&gt; null then
		aTS := self.myVoyageJobSheet.workStarted;
		txtCPH.setValue(self.myCrane.targetRatePH.asStringJMT);
		txtExchDate.setDate(aTS.Date);
		txtExchTime.setValue(aTS.Time);
		txtStartJob.setValue(self.myCrane.jobSeed.asStringJMT);
		cmbOrder.setValue( self.myVoyageJobSheet.getCraneDirString() );
	else
		txtCPH.setValue(null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
