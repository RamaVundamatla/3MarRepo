    <JadeMethod name="tblCargo_keyUp" id="dd54c004-6674-42ac-8301-fd45ded47c31">
        <controlMethod name="CM_Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2013	cnwndl1	Initial creation	Par	32368

*/

vars

	
	rowIndex : Integer;

begin

	rowIndex := table.row;
	
	if rowIndex = self.tblCargo.getRow(ETRow_NumItems) then
		self.changeQuantity();
	endif;
	

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
