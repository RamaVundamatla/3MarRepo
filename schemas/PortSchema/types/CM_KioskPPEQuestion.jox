    <JadeMethod name="validateForUpdate" id="d1ac7dca-78e7-4d83-b766-b082e2cc0f43">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars
	
