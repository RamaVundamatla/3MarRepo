    <JadeMethod name="doPrint" id="470813f8-b60d-4c4c-8ed6-a2f0cbae9bce">
        <source>doPrint();
// ---------------------------------------------------------------------------
// Created:		19 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aServ : CM_Service;
	aServObj : CM_ServiceObject;
	aRate : CM_Rate;
	aDebtor,eDebtor : CM_DebtorNode;
	anAudit : CM_Audit;
	allDs : CM_DebtorNodeByNameDict;
	printedAudit	: Boolean;
begin
	self.setHeader();
	self.setFooter();
	create allDs transient;
	
	if self.myDebtor &lt;&gt; null then
		allDs.add(self.myDebtor);
	else
		app.myRoot.myRootCompany.debtorNodes.copy(allDs);
	endif;
	
	foreach eDebtor in allDs do
	foreach aServObj in self.myBank.serviceObjects discreteLock
		where (self.myService = null or self.myService = aServObj)  do : servLoop

		if not aServObj.isKindOf(CM_Service) then
			continue;
		endif;
		aServ := aServObj.CM_Service;
		
		foreach aRate in aServ.debtorNodeRates discreteLock do : rateLoop
			aDebtor := aRate.CM_DebtorRate.debtorNode;
//			if self.myDebtor &lt;&gt; null and aDebtor &lt;&gt; self.myDebtor then
			if aDebtor &lt;&gt; eDebtor then
				continue rateLoop;
			endif;
			
			foreach anAudit in aRate.qualifiedAudits 
				where anAudit.createdTime &gt;= self.dateFrom and anAudit.createdTime &lt;= self.dateTo do
			
				self.printAudit(anAudit.CM_FinAuditRateHistory, aServ, true, aDebtor);
				printedAudit := true;
			endforeach;

			foreach anAudit in aRate.unqualifiedAudits 
				where anAudit.createdTime &gt;= self.dateFrom and anAudit.createdTime &lt;= self.dateTo do
				self.printAudit(anAudit.CM_FinAuditRateHistory, aServ, false, aDebtor);
				printedAudit := true;
			endforeach;

		endforeach;
	endforeach;
	endforeach;
	
	// 19/9/2006 (12290)
	if not printedAudit then
		app.printer.print(self.frmNoData);
	endif;
	
epilog
	delete allDs;
end;</source>
    </JadeMethod>
    <JadeMethod name="printAudit" id="b9a9e2a6-9a0e-4274-b207-c0f669dbc66d">
        <source>printAudit(_audit : CM_FinAuditRateHistory; _serv : CM_Service; _quald : Boolean; _debtor : CM_DebtorNode) ;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support

constants
	Details_Width = 250;
	Remarks_Width = 340;
	After_Object_Spacing = 3;
vars
	aRE, dRE : CM_RateEntry;
	aRate : CM_Rate;
	oldR, newR, pcR : Real;
	code, remarks, dName : String;
	numline : Integer;
	isNew	: Boolean;
	auditCreatedTSLocal,
	aREStartTSLocal : TimeStamp;
begin
	
	if _audit.isDeleted then
		return ;
	endif;

	if _debtor.isKindOf(CM_Debtor) then
		code := _debtor.CM_Debtor.decfinName;
	else
		code := null;
	endif;
	if _debtor.name = "RDG" then
		remarks := "RDG";
	else
		remarks := _debtor.remarks;
	endif;

	isNew := (_audit.status = CM_FinAuditRateHistory.Status_Create);
	aRE := _audit.getRateEntryObject(true);
	oldR := _audit.previousCost;
	newR := _audit.newCost;
	pcR := 100;
	if oldR &lt;&gt; 0 then
		pcR := (((newR/oldR) - 1) * 100);
	endif;
	
	dName := _debtor.name.removeTabCrLfs();
	
	if not _quald then
		dName := "U " &amp; dName;
	endif;
			
	
	self.lblDtlDebtorCode.caption := code;
	self.lblDtlDebtorName.caption := dName;
	self.lblDtlDefRate.caption := "";
	
	
	if aRE &lt;&gt; null then
		self.lblDtlUser.caption := aRE.userId;
		// 18/9/2006 (12290)
		auditCreatedTSLocal := self.systemToLocalTime(_audit.createdTime);
		self.lblDtlEdited.caption := auditCreatedTSLocal.date.shortFormatJMT() &amp; " " &amp; auditCreatedTSLocal.time.shortFormatJMT;
		aREStartTSLocal := self.systemToLocalTime(aRE.startTimestamp);
		self.lblDtlEffective.caption := aREStartTSLocal.date.shortFormatJMT() &amp; " " &amp; aREStartTSLocal.time.shortFormatJMT();
		self.lblDtlDefRate.caption := null;
		if self.myDefaultDebtor &lt;&gt; null then
			aRate := self.myDefaultDebtor.serviceRates[_serv];
			dRE := aRate.getTimeRate(self.myBank,aRE.startTimestamp);
			if dRE &lt;&gt; null then
				self.lblDtlDefRate.caption := dRE.getDerivedCostPerUnit(aRE.startTimestamp).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
			endif;
		endif;
	else
		self.lblDtlDefRate.caption := null;
		self.lblDtlUser.caption := _audit.userId;
		auditCreatedTSLocal := self.systemToLocalTime(_audit.createdTime);
		self.lblDtlEdited.caption := auditCreatedTSLocal.date().shortFormatJMT() &amp; " " &amp; auditCreatedTSLocal.time.shortFormatJMT;
		self.lblDtlEffective.caption := null;
	endif;
	self.lblDtlNewRate.caption := newR.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
	if isNew then		// don't show the old rate and percentage changed for a new entry - it is confusing
		self.lblDtlOldRate.caption := '';
		self.lblDtlPCChanged.caption := '';
	else
		// TFS 2069 don't show old rate as zero for consistency with new rates
		if oldR = 0 then
			self.lblDtlOldRate.caption := '';
		else
			self.lblDtlOldRate.caption := oldR.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
		endif;
		// also from TFS 2069 percentage doesn't mean much when either old or new rate is zero, don't print it then
		if oldR = 0 or newR = 0 then
			self.lblDtlPCChanged.caption := '';
		else
			self.lblDtlPCChanged.caption := pcR.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
		endif;
	endif;
	self.lblDtlService.caption :=  _serv.name;

	
	self.lblDtlDebtorRmks.caption := null;
	self.lblDtlDebtorRmks.height := 16;
	if remarks &lt;&gt; null then
		
		numline := remarks.getNumberOfACharacter(Cr);
		numline := numline + 1;
		self.lblDtlDebtorRmks.height := 16 * numline;
		self.lblDtlDebtorRmks.caption := remarks;
	endif;
	
	self.lblDtlServiceRmk.caption :=  null;
	self.lblDtlServiceRmk.height := 16;
	if _serv.remarks &lt;&gt; null then
		remarks := _serv.remarks;
		numline := remarks.getNumberOfACharacter(Cr);
		numline := numline + 1;
		self.lblDtlServiceRmk.height := 16 * numline;

		self.lblDtlServiceRmk.caption :=  remarks;
	endif;
	
	app.printer.print(frmDetails);


end;</source>
        <Parameter name="_audit" type="CM_FinAuditRateHistory"/>
        <Parameter name="_serv" type="CM_Service"/>
        <Parameter name="_quald" type="Boolean"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setFooter" id="f7640d37-f46c-4641-a125-11287d90e8ff">
        <source>setFooter();
// ---------------------------------------------------------------------------
// Created:		19 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	self.lblTheDatePrinted.caption :=  now.String;
	self.lblTheUser.caption := app.getMyUser.userName;
	//Set Footer
	app.printer.setFooter(self.frFooter);

end;</source>
    </JadeMethod>
    <JadeMethod name="setHeader" id="33cd4b0f-da8c-4549-8f51-9789fb2fd957">
        <source>setHeader();
// ---------------------------------------------------------------------------
// Created:		19 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
begin
	if self.myDebtor &lt;&gt; null then
		self.lblDebtorData.caption := self.myDebtor.name;
	else
		self.lblDebtorData.caption := "ALL";
	endif;
	
	if self.myService &lt;&gt; null then
		self.lblServiceData.caption := self.myService.name;
	else
		self.lblServiceData.caption := "ALL";
	endif;
	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.lblDateData.caption := self.systemToLocalTime(self.dateFrom).date.shortFormatJMT() &amp; " to " &amp; self.systemToLocalTime(self.dateTo).date.shortFormatJMT();
	
	self.picLogoCompany.picture := app.getPicLogoPort();
	self.picLogoJMT.picture := app.getPicLogoProduct();

	// set header
	app.printer.setHeader(self.frHeader);
	
	
end;</source>
    </JadeMethod>
</GUIClass>
