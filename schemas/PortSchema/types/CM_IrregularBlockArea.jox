    <JadeMethod name="getRackYALocationString" id="c8638a72-0c6b-44cd-9635-8a7ec110e27f">
        <source>getRackYALocationString(pAllControllersObj: CM_LCArray input) : String;
/*
Purpose:		PAR 34205	
Date				Who			Reason
JUNE 2014		CNWAB1		Initial creation
*/

vars
	idx, x1, y1, z1 : Integer;
	rack : CM_IrregularBlockController;
	obj : Object;
	objs : ObjectSet;
	allRacks : CM_IrregularBlockLCsByRegion;
begin
	create allRacks transient;
	foreach obj in pAllControllersObj discreteLock do
		rack := obj.CM_IrregularBlockController;
		
		rack.getSortKeys(x1, y1, z1);

		allRacks.putAtKey(x1, y1, z1,rack);
	endforeach;
	
	return allRacks.getYALocationString();
	
epilog
	delete allRacks;
end;</source>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
