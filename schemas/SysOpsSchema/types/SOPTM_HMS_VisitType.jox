    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="0dc58fbc-44f1-4783-857d-ae7e5ed239dd">
        <updating/>
        <source>create() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.name := SOP_TableMaintForm.Table_VisitType;
	self.permissionView	 := PmHMSVisitTypeView;
	self.permissionMaint := PmHMSVisitTypeMaint;
	self.myDataClass := HMS_VisitType;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="5fea8cf9-bf39-4fec-98ae-fce5b2bc779f">
        <updating/>
        <source>doSave(): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj		: HMS_VisitType;
	formObj			: SOP_TableMaintForm;
	tableObj		: CM_EntryTable;
	vtCode			: String;
	vtDescription	: String;
		
begin
	formObj	:=	self.myForm.SOP_TableMaintForm;
	
	if formObj.myProxyObject = null then
		if formObj.mode = formObj.Mode_Add then
			create formObj.myProxyObject as HMS_VisitType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	proxyObj	:=	formObj.myProxyObject.HMS_VisitType;
	tableObj	:=	formObj.tblInput1;
	tableObj.setObjectFromTable(proxyObj, null, false);
	
	vtCode			:=	tableObj.getValueByName(ETRow_Code).String;
	vtDescription	:=	tableObj.getValueByName(ETRow_Description).String;
	proxyObj.setProxy(vtCode, vtDescription, app.myRoot);
	
	//Are we adding or updating
	if formObj.mode = formObj.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(proxyObj, formObj.myCurrentObject, app.myPassport);
	elseif formObj.mode = formObj.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(proxyObj, app.myPassport );
	else
		app.raiseUnexpectedProgramError( class.name,
										 method.name, 
										 '  Invalid mode (' &amp; formObj.mode.String &amp; ')' );
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="84fbe9da-2c18-410d-b04e-9ae0d062af06">
        <source>getCollection(): Collection;
// --------------------------------------------------------------------------------
// Created:		04 January 2006 by cnwdad1
//
// Purpose:		Returns a reference to the Root object's collection of Visit Types.
//
// Parameters:	None
//
// Returns:		A reference to the collection of Root Types.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return app.myRoot.allVisitTypes;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="isSystemItem" id="cfcd55bb-f223-4f07-9440-b3ed9013e753">
        <source>isSystemItem(): Boolean;
// --------------------------------------------------------------------------------
// Created:		09 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
