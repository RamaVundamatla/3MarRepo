        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandScape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isGapRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGridLeftRowHeaderTopDown" id="26f35dc5-eea1-4cec-a110-246bfe9e8254">
        <source>drawGridLeftRowHeaderTopDown(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	ty,
	headerX, headerY,
	noAccessDrawX,
	widthPixels,
	lengthPixels	: Real;
	label, accessLabel  : String;
	labelTextHeight : Real;
	gridArea : CM_TerminalArea;
	forkLiftStack : CM_ForkLiftStack;
	tmpTA	: CM_GridArea;
begin	
	if _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	gridLc := lc.CM_GridController;
	
	tmpTA := gridLc.getMyTerminalArea.CM_GridArea;
	//17/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;
		
	if _isLandScape then
		lengthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);	
		label := gridLc.getRowLabel();
	else
		lengthPixels := self.getSizeInPixels(self.heightFt, _scaleFactor);	
		label := gridLc.getColumnLabel(true);
	endif;
	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapRow then
			lengthPixels := lc.getGapWidthPixels(lengthPixels);
		endif;
	endif;
	
	if _flipH then 
		headerX := _x2 + (_x2-_x1)/2;
	else
		headerX := _x1 + (_x2-_x1)/2;		
	endif;
	
	labelTextHeight := _frame.drawTextHeight(label);
	
	if _flipV then
		headerY := _y2 - lengthPixels/2 - labelTextHeight/2;
	else
		headerY := _y1 + lengthPixels/2 - labelTextHeight/2;
	endif;
	
	accessLabel:=null;
	if _isLandScape then
		if (_flipV and gridLc.myGridRow.row = tmpTA.allGridRows.size) or 
			   (not _flipV and gridLc.myGridRow.row = 1) then	
			if _flipH and tmpTA.rightLabel &lt;&gt; null then
				accessLabel:=tmpTA.rightLabel;										
			endif;	
			if not _flipH and tmpTA.leftLabel &lt;&gt; null then	
				accessLabel:=tmpTA.leftLabel;
			endif;	
		endif;				
	else			
		if (_flipV and gridLc.myGridColumn.column = tmpTA.allGridColumns.size) or 
			   (not _flipV and gridLc.myGridColumn.column = 1) then			
		
			if _flipH and tmpTA.bottomLabel &lt;&gt; null then											
				accessLabel:=tmpTA.bottomLabel;
			endif;
		
			if not _flipH and tmpTA.topLabel &lt;&gt; null then	
				accessLabel:=tmpTA.topLabel;
			endif;	
		endif;
	endif;
 
	//epr par 29823 drawTextRotation is not supported on WindowsCe
	if accessLabel &lt;&gt; null and not app.cnThinClientOSIsWindowsMobile() then 
		_frame.drawTextRotation := 270;
		_frame.drawTextCharRotation := 270;
		_frame.drawTextAlign := Frame.DrawTextAlign_Left;	
		_frame.drawTextAt(accessLabel,headerX , headerY, Red);	
		headerX := headerX + 5;
		_frame.drawTextCharRotation := 0;
		_frame.drawTextRotation := 0;	
	endif;
	
	
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;			
	_frame.drawTextAt(label, headerX, headerY, Black);
	//16/06/2011 cnwdz2 27732
	if forkLiftStack &lt;&gt; null and 
	   not _isLandScape and		
	   	((not forkLiftStack.accessFront and  gridLc.myGridRow.row = tmpTA.allGridRows.size ) or
			(not forkLiftStack.accessBack and gridLc.myGridRow.row = 1 )) then			   

			
		_frame.drawWidth := 3;
		if _flipH then 
			noAccessDrawX := (_x2-_x1)-2;
		else
			noAccessDrawX := _x2-2;
		endif;
		_frame.drawLine(noAccessDrawX,_y1,noAccessDrawX,_y2,Red);					
	endif;

end;</source>
