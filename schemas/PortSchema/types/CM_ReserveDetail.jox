    <JadeMethod name="getStagingLocationSummary" id="b67f32ad-e8d5-498f-b2ac-2eecc00d03c1">
        <source>getStagingLocationSummary(tiSet : CM_TISet input; _firstStagingLC : CM_LocationsController io) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
20 Sep 2021		jlier1 TFS 51626
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti : CM_TrackedItem;
	locationArray : CM_LCArray;
	location : CM_LocationsController;
	integerArray : IntegerArray;
	indexOf : Integer;
	retStr : String;
	index : Integer;
	allTis	: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems  discreteLock do
	foreach ti in allTis  discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
			if not ti.isStagedFor( self.myReserveHeader ) and not ( ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isKindOf(CM_MachineController))  then 
				if ti.isAvailableToStageFor(   self.myReserveHeader  ) then	//21 Jan 2016	NDL	Par 37439
					tiSet.addNoDuplicates( ti, false );
				endif;
			elseif _firstStagingLC = null then	//21 Jan 2016	NDL	Par 37439
				_firstStagingLC := ti.myPrimaryActualLocation;
			endif;
	endforeach;
	
	if self.isKindOf(CM_ReserveSelection) then	
		if tiSet.isEmpty then
			//none actually assigned that aren't already in a staging area
			//so search the rest of the onsite cargo
			self.getNonStagedAvailSTW(tiSet);	// 17 Mar 2016	NDL	TFS 1684
		endif;
	endif;

	create locationArray transient;
	create integerArray transient;
	
	foreach ti in tiSet discreteLock do
		location := ti.myPrimaryActualLocation;
		if location &lt;&gt; null then
			indexOf := locationArray.indexOf( location );
			if indexOf &lt; 1 then
				locationArray.add( location );
				integerArray.add(1);
			else
				integerArray[indexOf] := integerArray[indexOf] + 1;
			endif;
		endif;
	endforeach;
		
	foreach index in 1 to locationArray.size discreteLock do
		if index = 1 then
			retStr := locationArray[index].CM_LocationsController.getFullId &amp; "(x" &amp; integerArray[index].String &amp; ")";
		else
			retStr := retStr &amp; " " &amp; locationArray[index].CM_LocationsController.getFullId &amp; "(x" &amp; integerArray[index].String &amp; ")";
		endif;
	endforeach;
	
	return retStr;
	
epilog
	delete locationArray;
	delete integerArray;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_firstStagingLC" type="CM_LocationsController" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
