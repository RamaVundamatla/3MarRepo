		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEndpointDetails_change" id="0c751d61-7d09-4743-ae4c-608e9721b901">
        <controlMethod name="CMUI_ApiEndpointTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEndpointDetails_change(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars

begin
	if self.tblEndPoints.accessCell(self.tblEndPoints.rows,2).cellControl = table then
		self.tblEndPointsAddLine(null); // ### JIRA 33544 17DEC2024 NAVAB1
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEndpointDetails_lostFocus" id="3caeff4e-ed96-40c2-951a-63b98138abf7">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEndpointDetails_lostFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	row : Integer;
	mainTbl : CM_DataTable;
	apiTable : CMUI_ApiEndpointTable;
begin
	mainTbl := self.tblEndPoints;
	
	foreach row in mainTbl.fixedRows + 1 to mainTbl.rows do
		if mainTbl.accessCell(row, 2).cellControl = table then
			apiTable := table.CMUI_ApiEndpointTable;
			mainTbl.accessedCell.text := apiTable.accessCell(1,1).text &amp; Space &amp; apiTable.accessCell(1,3).text;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2e8e280c-f38e-4b67-a2b3-8f2b9411aee8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 April 2023 10:00:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025963, locale);
	lblDef.translateCaption(Xlat_0025964, locale);
end;</source>
    </JadeMethod>
