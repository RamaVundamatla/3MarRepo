    <JadeMethod name="validateMoveTo" id="6efc8c3b-d984-4b7b-bb82-3f1fbda35916">
        <source>validateMoveTo(_control : CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			30 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
-----------		--------------	-----------------------------------------
29 Sep 2008		consw1			PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
25 Nov 2016		cnwdap1			TFS 2844 STWR Hazardous Details Enhancements
21 May 2019		jlgzm1			TFS 42840 MSL Direct Release between Voyages and Rail
---------------------------------------------------------------------------
*/
vars
	tmpTi 			: CM_TrackedItem;
	modeStr 		: String;
	moveWle 		: CM_WorkListEntry; 
	incompleteWLE 	: CM_WorkListEntry;
	moveJob 		: CM_Job;
	termArea		: CM_TerminalArea;
begin
	if _control.isForcedMove then
		return;
	endif;
	
	tmpTi := _control.myTrackedItem;
	
	//10 Mar 2021	NDL	TFS 50796
	if tmpTi.hasBeenMerged then
		if _control.myToPrimaryLocation &lt;&gt; null then
			app.raiseCMException( Cargo_been_merge_longe_able_mo, null, null );
		endif;
	endif;
	
	// TFS 45590 TBA can only be moved to a yard location.
	if _control.moveMode = REAL_MODE
	and tmpTi.isTBAorIsRRP() then
		if not self.isYardLocation() then
			app.raiseCMException(Targe_locat_move_this_item_inv,null, null);
		endif;
	endif;

	// Check TI already already here - Queued/Planned. Real already checked by now
 	if self = _control.myToPrimaryLocation and _control.moveMode &lt;&gt; REAL_MODE then
 		if self.includesTI(tmpTi, _control.moveMode) then
			if _control.moveMode = QUEUE_MODE then
				modeStr := 'Queued';
			elseif _control.moveMode = PLANNING_MODE then
				modeStr := 'Planned';
			endif;	
			if tmpTi.canMergeBreakBulk then
				app.raiseCMWarning3(TI_Already_QueudPlanned_Here, tmpTi.id,
									modeStr, self.ident, null, null, self);
			else	//27 May 2015	NDL	Par 36209
				app.raiseCMException3(TI_Already_QueudPlanned_Here, tmpTi.id,
									modeStr, self.ident, null, null);
			endif;
		endif;
		
		if not (_control.isRehandleMove and _control.isJobShipLoad()) then
			// CCMS 1577
			if self.includesTI(tmpTi, REAL_MODE) and not tmpTi.isMultiQueued() then
				app.raiseCMException2(ERR_ALREADY_HERE, tmpTi.id, self.getID(), null, null);		
			endif;
		endif;
	endif;

	
	// PAR 18682 - 	If the location is defined for a strict 30, 45 or 53 grid then check that no other length is in the way of the strict grid.
	//						for instance is a row has been defined as strict 30, but a 45 has been placed in the row, using flexi grid, 
	//						check that the 45s over hanging backend is not in the way of offset for my 30 foot strict grid.
	if tmpTi.isOverSizedContainer() then // is a 45 etc
		termArea := self.myTerminalArea;
		if  termArea &lt;&gt; null 
		and termArea.hasOverhangingBackends() 
		and self.offsetFlexi = termArea.locationLength then
			if not self.allTrackedItems.includes(tmpTi)  and not self.allTrackedItemOSBackEnds.includes(tmpTi) then
				app.raiseCMException2(ERR_TI_CANNOT_PLACE_OVERHANG, tmpTi.id, self.getFullId(), null, null);		
			endif;
		endif;
		
		if not self.isVoyageController then // PAR 25636 no strict grid on ship
		if self.isOKForOverSizedCargo() then // Strictly defined for 30, 45, 53
			if not self.allTrackedItemOSBackEnds.isEmpty() then // something over hanging
				if self.is30ft and tmpTi.isAttributeTrue(TI_Attrib_IsThirty) then // Strict for 30s and moving a 30 footer
					if self.offsetFlexi &gt; self.offset30 then // over hanging offset is crossing over my 30 foot strict offset
						app.raiseCMException5(ERR_OVERHANG_STRICT_GRID, tmpTi.id, "30", "30", "30",self.getFullId(), null, null);		
					endif;
				elseif self.is45ft and tmpTi.isAttributeTrue(TI_Attrib_IsFortyFive) then // Strict for 45s and moving a 45 footer
					if self.offsetFlexi &gt; self.offset45 then // over hanging offset is crossing over my 45 foot strict offset
						app.raiseCMException5(ERR_OVERHANG_STRICT_GRID, tmpTi.id, "45", "45", "45",self.getFullId(), null, null);		
					endif;
				elseif self.is53ft and tmpTi.isAttributeTrue(TI_Attrib_IsFiftyThree) then // Strict for 53s and moving a 53 footer
					if self.offsetFlexi &gt; self.offset53 then // over hanging offset is crossing over my 53 foot strict offset
						app.raiseCMException5(ERR_OVERHANG_STRICT_GRID, tmpTi.id, "53", "53", "53",self.getFullId(), null, null);		
					endif;
				endif;
			endif;
		endif;
		endif;
	endif;

	//  PAR 18682
	if self = _control.myToPrimaryLocation
	and not self.isSlotController	//23 Nov 2020	NDL	TFS 49891
	and self.is40ft and tmpTi.isForty() then
		if self.offset40 = CM_LocationsController.Offset40_Unavailable then
			app.raiseCMException5(ERR_STRICT_GRID, tmpTi.id, "40", "40", "40",self.getFullId(), null, null);		
		
		elseif self.offsetFlexi &gt; self.offset40 then // over hanging offset is crossing over my 40 foot strict offset
			app.raiseCMException5(ERR_OVERHANG_STRICT_GRID, tmpTi.id, "40", "40", "40",self.getFullId(), null, null);		
		endif;
	endif;
	//  PAR 18682
	if self = _control.myToPrimaryLocation
	and not self.isSlotController	//23 Nov 2020	NDL	TFS 49891
	and self.is20ft and tmpTi.isTwenty() then
		if self.offsetFlexi &gt; 0 then // over hanging offset is crossing over my 20 foot strict offset
			app.raiseCMException5(ERR_OVERHANG_STRICT_GRID, tmpTi.id, "20", "20", "20",self.getFullId(), null, null);		
		endif;
	endif;
	
	//13 May 2010	NDL Par 23928 -	If this move is as a result of a release job then, 
	//								check for incomplete wles against this ti that belong to a reciept job.
	//								All receipt jobs must be complete before you can complete a release job.
	if _control.moveMode = REAL_MODE then
		moveWle := _control.myWorkListEntry;
		moveJob := _control.jobForMove;
		if moveWle &lt;&gt; null then //there is a move associated with the controller 
			if not moveWle.isReceipt then	//and the move is a release.
				
				if  tmpTi.hasIncompleteWleForReceivalJob(incompleteWLE) then
					
					if incompleteWLE.isDRLinkedByFM and (incompleteWLE.isKindOf(CM_VoyageWLE) or
														incompleteWLE.isKindOf(CM_YardWLE)) then // TFS 42840
					
					elseif incompleteWLE.myTrackedItem.isKindOf(CM_TILC) and incompleteWLE.myTrackedItem = tmpTi then //epr par 34107 19/5/14
					
					elseif tmpTi.directDelivery and incompleteWLE.isKindOf(CM_VoyageWLE) then	//01 Feb 2013	NDL	Par 31102
						app.raiseCMException(DD_ship_truck_ShipOPS_Lander, null, null);
					else
						app.raiseCMException2(Uncomplete_receival_wle, tmpTi.id, incompleteWLE.job.getDisplayDetails(false), null, null);
					endif;
				endif;
			endif;
		elseif moveJob &lt;&gt; null then //there is a job associated with the controller
			if moveJob.isRelease then	//and the job is a release.
				if  tmpTi.hasIncompleteWleForReceivalJob(incompleteWLE) then
					app.raiseCMException2(Uncomplete_receival_wle, tmpTi.id, moveJob.getDisplayDetails(false), null, null);
				endif;
			endif; 
		endif;
	endif;
	// end of Par 23928
		
	//test for hazardous segregation violations - (will do nothing if no hazardous TI)
	if (not _control.hazardSegregationValidated) and (_control.myToPrimaryLocation &lt;&gt; null) then
		_control.myToPrimaryLocation.validateMoveToForHaz(_control);
		_control.hazardSegregationValidated := true;
	endif;
	
	//Check to see if TI is one of the OtherTIs and not the original
	if _control.allOtherTrackedItems.includes(_control.myTrackedItem) then
		// the below validation has already been done for the original TI
		return;
	endif;
	
	//-----------------------------------------------------------------------------
	// The validation from here down only needs to be done once for the original TI
	//-----------------------------------------------------------------------------
				
	if self.status &lt;&gt; LC_Status_Open then
		app.raiseCMException1(LocationIsClosed, self.getID, null, null);
		return;
	endif;

	// if planinning dont need to worry about labour restrictions (only on queue or real move)
	if _control.moveMode &lt;&gt; PLANNING_MODE then  
		//------------------
		//Validate for Labour Restriction in the area we are moving TO
		//------------------
		
		self.validateMoveLabourRestriction(_control);
		
		// Validate for Hazards Restriction in the area we are moving TO		// TFS 2844
		self.validateMoveHazardRestriction(_control);							// TFS 2844
	endif;
	
	if _control.myPassport.hasErrorsOrWarnings then
		return;
	endif;
	//------------------
	//Test  terminal differences.
	//------------------
	self.validateTerminalToTerminalMove(_control);
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHaz" id="593bcb06-b74f-4fdf-94c0-d4e97ea41b03">
        <source>validateMoveToForHaz(_control : CMIF_MoveController input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	22 November 2006 By cnwth2

Purpose:	
			

Changed On   Changed By  Reason
28 May 2024  navma1		 Bug 64224: MTN - DeadLocks Caused by Future Actors
----------   ----------  --------------------------------------------------
*/
vars
	ti					: CM_TrackedItem;	
	allHazardousTIs		: CM_TISet;
	allErrorWarnings	: CM_ErrorSet;
	error				: CM_Error;
	exObj				: CM_Exception;
	termArea			: CM_TerminalArea;
begin
	
	// epr par 29566 14/5/12
	termArea := self.myTerminalArea;							//28.05.2024 navma1 #64224
	if termArea &lt;&gt; null and (termArea.type = TA_TYPE_RECTRANS or termArea.type = TA_TYPE_RELTRANS) then
		return;
	endif;
	
	//get a set of all the hazardous TIs being moved in this trx
	create allHazardousTIs transient;
	create allErrorWarnings transient;
	if _control.myTrackedItem.isHazardous then
		allHazardousTIs.add(_control.myTrackedItem);
	endif;
	
	foreach ti in _control.allOtherTrackedItems where ti.isHazardous do
		if (not allHazardousTIs.includes(ti)) then
			allHazardousTIs.add(ti);
		endif;
	endforeach;
	
	if allHazardousTIs.isEmpty then
		return;//nothing to do
	endif;
	
	foreach ti in allHazardousTIs do
		self.validateMoveToForHazTI(ti, true, allErrorWarnings);
	endforeach;
	
	foreach error in allErrorWarnings do		
		//28 Jul 2015	NDL	Par 36660, - using raiseException reconverts from the params...
		create exObj transient;
		exObj.set(error.errorCode, error.text, error.warningOnly, error.fieldName, error.myUserObject, self);
		raise exObj;
		
		delete error;
		
	endforeach;
	
epilog
	
	delete allHazardousTIs;
	delete allErrorWarnings;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTI" id="2b7c5870-807a-418d-8fb7-cf298729533e">
        <source>validateMoveToForHazTI(_tiBeingMoved 		: CM_TrackedItem;
						_detailedErrMsg 	: Boolean;
						_allErrorWarnings 	: CM_ErrorSet input);
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	self is the to location

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hazTiToCheck		: CM_TrackedItem;
	notAllowedSameArea	: Boolean;
	
	lc					: CM_LocationsController;
	
	ruleType			: Integer;
	reasonWhyNot		: String;

begin
	
	ruleType := self.getHazardSegregationRuleType();
	///if self.myTerminalArea = null then					// 01/10/2010 cnwmh5 #25632
	///	return;
	///endif;

	// ACTUAL 
	if self.myTerminalArea &lt;&gt; null then						// 01/10/2010 cnwmh5 #25632
		foreach hazTiToCheck in self.myTerminalArea.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
			_tiBeingMoved.validateHazCanCoexistSameTA(hazTiToCheck, ruleType, _detailedErrMsg, _allErrorWarnings);
		endforeach;
	endif;

	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryActualLocation, ruleType, _detailedErrMsg, _allErrorWarnings);
	endforeach;

	// PAR 16097
	// QUEUED 
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, ruleType, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	// PLANNED 
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryPlannedLocation, ruleType, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	
epilog


end;


</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_detailedErrMsg" type="Boolean"/>
        <Parameter name="_allErrorWarnings" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTIGetTI" id="f6536de1-0b99-489f-81d6-f7f61a2144a7">
        <source>validateMoveToForHazTIGetTI(_tiBeingMoved 		: CM_TrackedItem; _clashTIs : CM_TIByIdDict input);
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		get the TIs taht are clashing with this HAZ TI
//
// ---------------------------------------------------------------------------
vars
	hazTiToCheck		: CM_TrackedItem;
	notAllowedSameArea	: Boolean;
	lc					: CM_LocationsController;
	ruleType			: Integer;
	reasonWhyNot		: String;
	allErrorWarnings 	: CM_ErrorSet;

begin
	
	ruleType := self.getHazardSegregationRuleType();
	///if self.myTerminalArea = null then		// 01/10/2010 cnwmh5 #25632
	///	return;
	///endif;
	create allErrorWarnings transient;
	
	// ACTUAL
	if self.myTerminalArea &lt;&gt; null then					// 01/10/2010 cnwmh5 #25632
		foreach hazTiToCheck in self.myTerminalArea.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
			if not _tiBeingMoved.validateHazCanCoexistSameTA(hazTiToCheck, ruleType, false, allErrorWarnings) then
				_clashTIs.addNoDuplicates(hazTiToCheck, false);
			endif;
		endforeach;
	endif;

	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryActualLocation, ruleType, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;

	// PAR 16097 
	// QUEUED
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryQueuedLocation, ruleType, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation, ruleType, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	
epilog

	delete allErrorWarnings;
end;


</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_clashTIs" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToOSBackend" id="9eb75ba2-3792-494d-a3bb-b3e22f6db6b2">
        <source>validateMoveToOSBackend(_control : CMIF_MoveController) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return true;
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSpannedtoOffsetLCs" id="c2603321-b14a-45c1-ac3f-6ebd8bca70ee">
        <source>validateSpannedtoOffsetLCs(_control : CMIF_MoveController input) : String;
// ---------------------------------------------------------------------------
// Created:		03 April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	primaryID	: String;
begin
	tmpTI := _control.myTrackedItem;
	
	 // PAR 16415 CCMS 1029
	if tmpTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		if not self.is45ft then
			// PAR 18647return "Can only place 45 foot container in designated areas. " &amp; self.getFullId() &amp; " is not defined for 45 foot containers.";
// PAR 18682			return app.getErrorString3(ERR_NOT_DEFINED_ODD, "45", self.getFullId(), "45"); // PAR 18647
		endif;
		if self.offset45 = CM_LocationsController.Offset45_Unavailable then
			// PAR 17845 Offset45_9 now = -1, or self.offset45 = CM_LocationsController.Offset45_9 then	//15843. 4 containers 45' from the left to the right have taken an extra slot, so the 5th container should be located to the next slot.
			primaryID := self.getPrimaryIDforOddLengths(TI_Attrib_IsFortyFive);// PAR 18215
			if primaryID &lt;&gt; null then
				// PAR 18647 was return tmpTI.id &amp; ", a 45 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location. " &amp; "Please use location " &amp; primaryID &amp; '.';
				return app.getErrorString4(ERR_NO_PRIMARY_ODD, tmpTI.id, "45", self.getFullId(), primaryID); // PAR 18647
			else
				// PAR 18647 was return tmpTI.id &amp; ", a 45 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location, and its prior location is also unavailable for 45ft";
				return app.getErrorString4(ERR_NO_PRIOR_MOVE_ODD, tmpTI.id, "45", self.getFullId(), "45"); // PAR 18647
				
			endif;
		endif;
		
	elseif tmpTI.isAttributeTrue(TI_Attrib_IsThirty) then
		if not self.is30ft then
			// PAR 18647  return "Can only place 30 foot container in designated areas. " &amp; self.getFullId() &amp; " is not defined for 30 foot containers.";
// PAR 18682			return app.getErrorString3(ERR_NOT_DEFINED_ODD, "30", self.getFullId(), "30"); // PAR 18647
		endif;
		if self.offset30 = CM_LocationsController.Offset30_Unavailable 
		or self.offset30 = CM_LocationsController.Offset30_3 then
			//return tmpTI.id &amp; ", a 30 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location. Please use location either side.";

			primaryID := self.getPrimaryIDforOddLengths(TI_Attrib_IsThirty);// PAR 18215
			if primaryID &lt;&gt; null then
				// PAR 18647 was return tmpTI.id &amp; ", a 30 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location. " &amp; "Please use location " &amp; primaryID &amp; '.';
				return app.getErrorString4(ERR_NO_PRIMARY_ODD, tmpTI.id, "30", self.getFullId(), primaryID); // PAR 18647

			else
				 // PAR 18647 return tmpTI.id &amp; ", a 30 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location, and its prior location is also unavailable for 30ft";
				return app.getErrorString4(ERR_NO_PRIOR_MOVE_ODD, tmpTI.id, "30", self.getFullId(), "30"); // PAR 18647			
			endif;
		endif;

	elseif tmpTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		if not self.is53ft then
			// PAR 18647    return "Can only place 53 foot container in designated areas. " &amp; self.getFullId() &amp; " is not defined for 53 foot containers.";
// PAR 18682			return app.getErrorString3(ERR_NOT_DEFINED_ODD, "53", self.getFullId(), "53"); // PAR 18647
		endif;
		if self.offset53 = CM_LocationsController.Offset53_Unavailable 
		or self.offset53 = CM_LocationsController.Offset53_8 then
			//return tmpTI.id &amp; ", a 53 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location. Please use location either side.";
			
			primaryID := self.getPrimaryIDforOddLengths(TI_Attrib_IsFiftyThree);// PAR 18215
			if primaryID &lt;&gt; null then
				 // PAR 18647 was return tmpTI.id &amp; ", a 53 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location. " &amp;"Please use location " &amp; primaryID &amp; '.';
				return app.getErrorString4(ERR_NO_PRIMARY_ODD, tmpTI.id, "53", self.getFullId(), primaryID); // PAR 18647

			else
				 // PAR 18647	 was return tmpTI.id &amp; ", a 53 footer,  cannot have " &amp; self.getFullId() &amp; " as it's primary location, and its prior location is also unavailable for 53ft";
				return app.getErrorString4(ERR_NO_PRIOR_MOVE_ODD, tmpTI.id, "53", self.getFullId(), "53"); // PAR 18647			
			endif;
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateTerminalToTerminalMove" id="8ebd3c70-a7ff-4bef-8516-351bc426b5e0">
        <source>validateTerminalToTerminalMove(control : CMIF_MoveController) protected;
/*
 ------------------------------------------------------------------------
Created:			26 September 2001 by cnwdwq1
Purpose:			If the move is between terminals, check to see that its ok.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpTi		: CM_TrackedItem;
	tmpVoyage	: String;
	
begin

	if control.myOriginatingLocation = null then
		//----------------------
		//The object is NOWHERE currently, assume Terminal is ok.
		//We may have to revisit this if the box is pre-noted.
		//----------------------
		return;
	endif;
		
	if control.myOriginatingLocation.myTerminal &lt;&gt; null then
		if control.myOriginatingLocation.myTerminal = control.myToTerminal then
			return;	//Internal same terminal move. 
		endif;
	else
		return; //This is a receival or offload from voyage
	endif;
	//----------------------------
	//At this point, we only check to see if the voyage for the TI is defined in the other
	//terminal. If its not, then thow an error.
	//----------------------------
	if control.myToTerminal &lt;&gt; null then
		if (not control.myToTerminal.lookupVoyage(control.myTrackedItem.voyageCode, null, false) = null) then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(Err_VoyageNotOnTargetTerm, control.myTrackedItem.id, control.myTrackedItem.voyageCode, null, null);
			return;	
		endif;
		if (not control.allOtherTrackedItems.isEmpty) then
			// check that the other tracked items have a valid voyage code in the other terminal
			// if it is not the same as the first ti
			tmpVoyage := control.myTrackedItem.voyageCode;
			foreach tmpTi in control.allOtherTrackedItems do
				if tmpTi.voyageCode &lt;&gt; tmpVoyage then
					app.setContinueCMExceptions(false);
					app.raiseCMException2(Err_VoyageNotOnTargetTerm, tmpTi.id, tmpVoyage, null, null);
					return;	
				endif;
			endforeach;
		endif;
	else
		//Must be going offsite
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="xHandlerAddProduct" id="ba519047-5083-46bb-86fc-e5cf4fef15ad">
        <source>xHandlerAddProduct(pExceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2005 by cnwdad1
//
// Purpose:		Exception handler for when the collection of used Products is being
//				fetched.  If a Product has already been added to the collection,
//				then we'll simply reume.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ERROR_1309	: Integer = 1309;
	
begin
	if pExceptionObj.errorCode = ERROR_1309 then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="yaBuildBlock" id="82f2f872-b4c5-4445-8cd8-fd0f9055ae12">
        <source>yaBuildBlock(pIsTransient:Boolean; pYardAllocationObj:CM_YardAllocation):CM_YABlock;
// --------------------------------------------------------------------------------
// Created:		06 April 2005 by cnwdad1:2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	
begin
	blockObj	:=	self.createYABlock(pIsTransient);
	
	if pIsTransient then
		blockObj.setProxy(self.ident, self.myTerminalArea);
	endif;
	
	return blockObj;
end;</source>
        <Parameter name="pIsTransient" type="Boolean"/>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="yaHasSubBlockStack" id="a9de9f01-7571-47f8-a545-f3d90a3341d7">
        <source>yaHasSubBlockStack():Boolean;
// --------------------------------------------------------------------------------
// Created:		14 April 2005 by cnwdad1:2
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has a sub-
//				block stack.  In most cases, this will be false, but this method
//				will be implemented to check for a reference to a sub-block stack
//				where appropriate.
//
// Parameters:	None
//
// Returns:		True if the receiver has a sub-block stack, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
