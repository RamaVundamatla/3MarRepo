    <JadeMethod name="addToJobTotalsCooled" id="94bddf3c-dedb-4bf2-85e1-dc069cdb7d05">
        <source>addToJobTotalsCooled(_theTotals: CMIF_JobTITotals input; _moveType: Integer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isFull then
		if self.isReefer or self.isPortHole or self.isIntegral or self.getCoolingType = ContainerWaterCooled then	// PAR 6967 AKB2003DEC
			if self.requiresTemperature then
				if self.isChilled then
					if _moveType = DISCHARGE_MOVETYPE or _moveType = LOAD_MOVETYPE then
						_theTotals.numChilled := _theTotals.numChilled + 1;
					elseif _moveType = DLR_MOVETYPE  then
						_theTotals.numChilledRH := _theTotals.numChilledRH + 1;
					elseif _moveType = SOB_MOVETYPE  then
						_theTotals.numChilledSOB := _theTotals.numChilledSOB + 1;
					endif;
				else
					if _moveType = DISCHARGE_MOVETYPE or _moveType = LOAD_MOVETYPE then
						_theTotals.numReefer := _theTotals.numReefer + 1;
					elseif _moveType = DLR_MOVETYPE  then
						_theTotals.numReeferRH := _theTotals.numReeferRH + 1;
					elseif _moveType = SOB_MOVETYPE  then
						_theTotals.numReeferSOB := _theTotals.numReeferSOB + 1;
					endif;
				endif;
			endif;
		elseif self.isFantainer then
			//ONLY increment totals if the Fantainer is using power
			// (they can be used for other contents, like wool)
			if self.requiresPower then
				if _moveType = DISCHARGE_MOVETYPE or _moveType = LOAD_MOVETYPE then
					_theTotals.numFantainer := _theTotals.numFantainer + 1;
				elseif _moveType = DLR_MOVETYPE  then
					_theTotals.numFantainerRH := _theTotals.numFantainerRH + 1;
				elseif _moveType = SOB_MOVETYPE  then
					_theTotals.numFantainerSOB := _theTotals.numFantainerSOB + 1;
				endif;
			endif;
		endif;

	endif;

end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToJobTotalsMove" id="836ac0d7-7b01-45c6-8423-506d32d11fad">
        <source>addToJobTotalsMove(_theTotals: CMIF_JobTITotals input; _moveType: Integer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	return; // leave do no want it to inherit


end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToJobTotalsSnapShot" id="aad61f19-1d2b-4551-b14a-8b4a17165b28">
        <source>addToJobTotalsSnapShot(_theTotals: CMIF_JobTITotals input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------

vars

begin
/* PAR 31756 822 REMOVE - NOT USED - AKB
	if self.isFull then
		if self.isChilled then
			//if self.isImport or self.isExport or self.isStorage then														// PAR #25021
			if self.isImport or self.isTranshipInbound or self.isExport or self.isTranshipOutbound or self.isStorage then	// PAR #25021
				_theTotals.numChilled := _theTotals.numChilled + 1;
			elseif self.isRehandle then
				_theTotals.numChilledRH := _theTotals.numChilledRH + 1;
			elseif self.isSOB then
				_theTotals.numChilledSOB := _theTotals.numChilledSOB + 1;
			endif; 
		elseif (self.typeAttributes.bitAnd(ISO_FAN) &lt;&gt; 0) then
			//if self.isImport or self.isExport or self.isStorage then														// PAR #25021
			if self.isImport or self.isTranshipInbound or self.isExport or self.isTranshipOutbound or self.isStorage then	// PAR #25021
				_theTotals.numFantainer := _theTotals.numFantainer + 1;
			elseif self.isRehandle then
				_theTotals.numFantainerRH := _theTotals.numFantainerRH + 1;
			elseif self.isSOB then
				_theTotals.numFantainerSOB := _theTotals.numFantainerSOB + 1;
			endif; 
		elseif self.isReefer then
			//if self.isImport or self.isExport or self.isStorage then														// PAR #25021
			if self.isImport or self.isTranshipInbound or self.isExport or self.isTranshipOutbound or self.isStorage then	// PAR #25021
				_theTotals.numReefer := _theTotals.numReefer + 1;
			elseif self.isRehandle then
				_theTotals.numReeferRH := _theTotals.numReeferRH + 1;
			elseif self.isSOB then
				_theTotals.numReeferSOB := _theTotals.numReeferSOB + 1;
			endif; 
		
		endif;
	endif; // isFull
	if self.is40 then
		_theTotals.numFortyFoot := _theTotals.numFortyFoot + 1;
	else
		_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + 1;
	endif;

	//if self.isImport or self.isExport or self.isStorage then														// PAR #25021
	if self.isImport or self.isTranshipInbound or self.isExport or self.isTranshipOutbound or self.isStorage then	// PAR #25021
		if self.isFull then
			_theTotals.numFull := _theTotals.numFull + 1;
			if self.is40 then
				_theTotals.numFull40 := _theTotals.numFull40 + 1;
			else
				_theTotals.numFull20 := _theTotals.numFull20 + 1;
			endif;
		else
			_theTotals.numEmpty := _theTotals.numEmpty + 1;
			if self.is40 then
				_theTotals.numEmpty40 := _theTotals.numEmpty40 + 1;
			else
				_theTotals.numEmpty20 := _theTotals.numEmpty20 + 1;
			endif;
		endif;
	elseif self.isRehandle then
		if self.isFull then
			_theTotals.numFullRH := _theTotals.numFullRH + 1;
			if self.is40 then
				_theTotals.numFull40RH := _theTotals.numFull40RH + 1;
			else
				_theTotals.numFull20RH := _theTotals.numFull20RH + 1;
			endif;
		else
			_theTotals.numEmptyRH := _theTotals.numEmptyRH + 1;
			if self.is40 then
				_theTotals.numEmpty40RH := _theTotals.numEmpty40RH + 1;
			else
				_theTotals.numEmpty20RH := _theTotals.numEmpty20RH + 1;
			endif;
		endif;
	elseif self.isSOB then
		if self.isFull then
			_theTotals.numFullSOB := _theTotals.numFullSOB + 1;
			if self.is40 then
				_theTotals.numFull40SOB := _theTotals.numFull40SOB + 1;
			else
				_theTotals.numFull20SOB := _theTotals.numFull20SOB + 1;
			endif;
		else
			_theTotals.numEmptySOB := _theTotals.numEmptySOB + 1;
			if self.is40 then
				_theTotals.numEmpty40SOB := _theTotals.numEmpty40SOB + 1;
			else
				_theTotals.numEmpty20SOB := _theTotals.numEmpty20SOB + 1;
			endif;
		endif;
	endif;
	*/
end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
