    <JadeMethod name="setComboValues" id="4b850d48-1e46-48b7-a360-32011070d1ec">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 August 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	voyage					: CM_Voyage;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	multiTerminal			: Boolean;
begin
	comboBox.clear();
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		
		foreach voyage in terminal.allVoyagesByCode do		
			if multiTerminal then
				comboBox.itemObject[comboBox.addItem(voyage.code &amp; Tab &amp; ' (' &amp; voyage.description &amp; ')' &amp; Tab &amp; "- " &amp; terminal.code)] := voyage;
			else
				comboBox.itemObject[comboBox.addItem(voyage.code &amp; Tab &amp; ' (' &amp; voyage.description &amp; ')')] := voyage;
			endif;			
		endforeach;
		
	endforeach;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		comboBox.listObject := terminal.lookupVoyage(queryOperator.CM_QStringLookup.selectionValue, null, false);
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		comboBox.listObject := terminal.lookupVoyage(queryOperator.CM_QStringLookupNotEqual.selectionValue, null, false);
	endif;	
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="67e9e8b7-dcd7-4611-9c73-413564d5741c">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage					: CM_Voyage;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	multiTerminal			: Boolean;
begin
	
	table.rows := table.fixedRows;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		
		foreach voyage in terminal.allVoyagesByCode do	
		
			selectionValue := 0;
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(voyage.code) then
				selectionValue := 1;
				array.add(voyage);
			endif;
			if multiTerminal then	
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; voyage.code &amp; ' (' &amp; voyage.description&amp; ')' &amp; Tab &amp; "- " &amp; terminal.code);
			else
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; voyage.code &amp; ' (' &amp; voyage.description&amp; ')');
			endif;
			table.accessRow(idx).itemObject := voyage;
		endforeach;
	endforeach;
epilog
	delete objectSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="2edac4b6-8ee1-4ab4-80d1-a1ba1e9aef07">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage 		: CM_Voyage;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			voyage := table.accessRow(idx).itemObject.CM_Voyage;
			strArray.add(voyage.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="24d00063-f58d-4f78-a397-46ae9d504d17">
        <source>translateToDisplayValue(_value: Any): String;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	
	if _value.isKindOf(CM_Voyage) then
		if _value &lt;&gt; null then
			return _value.CM_Voyage.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="314f7130-db4e-40b2-88af-40f6b08949bd">
        <source>translateToSearchValue(_value: Any): Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: CM_Voyage;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then		
			return _value;
		endif;

		if _value.isKindOf(CM_Voyage) then
			object := _value.CM_Voyage;
		endif;
		
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="af0b8d5d-bb2f-4daa-ace8-0cad48be17fa">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	returnVal, str : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		str := _value.String;
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		return strArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
