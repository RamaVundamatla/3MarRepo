    <JadeMethod name="deleteTranMapTI" id="ff75f2d4-f91a-4d3d-8061-6a0d303549f5">
        <source>deleteTranMapTI(_mapName : Any);
/*
Purpose - 	
Who - NAVAB1
Date - 14FEB2024
ADO -  BUG 62187
*/

vars

	bank						: CM_Bank;
	cargoMap					: CM_TranMap;
	mapName					: String;


begin
	bank := self.getTerminal().getDefaultCompanyBank();

	if _mapName.isKindOf(String) then
		cargoMap := bank.myCurrentTranMapCargo[_mapName.String];
	elseif _mapName.isKindOf(CM_TranMap) then
		cargoMap := _mapName.CM_TranMap;
	endif;
	

	if cargoMap &lt;&gt; null then
		mapName := cargoMap.name;
		app.myTrxDA.trxDeleteInvoiceTranMap(cargoMap, app.myPassport);
		cargoMap := bank.myCurrentTranMapCargo[mapName];
		self.assertTrueMsg(cargoMap = null, "Tran map " &amp; mapName &amp; " should have been deleted");
	endif;
	

epilog

end;</source>
        <Parameter name="_mapName" type="Any"/>
    </JadeMethod>
    <JadeMethod name="findReeferTransactionInvoice" id="2808f843-42e9-4761-a239-40559ed5c744">
        <source>findReeferTransactionInvoice(_ti : CM_TrackedItem) : CM_Invoice;

vars
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	invoice	: CM_Invoice;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_ReeferDaily) then
			foreach invLine in trans.allInvoiceLines do
				invoice := invLine.invoice;
				break;
			endforeach;
		endif;
		if invoice &lt;&gt; null then
			break;
		endif;
	endforeach;
	return invoice;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="findReportTemplate" id="64f9c514-37a5-4197-9e6d-5e6a2e6417b6">
        <source>findReportTemplate() : CM_ReportTemplate protected;

vars
	str		: String;
	user	: CM_User;
	foundTemplate,
	template	: CM_ReportTemplate;
	menuItem	: CM_MenuUserItem;
	qryReport	: CM_QryReport;
begin
	user := app.getMyUser();
	foreach template in CM_ReportTemplate.instances do
		foreach menuItem in template.allMenuUserReports do
			if menuItem.isKindOf(CM_MenuUserReport) then
				qryReport := menuItem.CM_MenuUserReport.myQryReport;
				if qryReport &lt;&gt; null then
					if qryReport.jrwReportName.size &gt; 0 then
						str := qryReport.jrwReportName[1];
						if qryReport.filterClassName = "CMQF_Invoice" and
						   str.pos("2120", 1) &gt; 0 then
							if template.myUserToRunAs = user then
								foundTemplate := template;
								break;
							else
								beginTransaction;
								template.setPropertyValue("myUserToRunAs", user);
								commitTransaction;
								foundTemplate := template;
								break;
							endif;
						endif;
					endif;
				endif;
			endif;
		endforeach;
		if foundTemplate &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	return foundTemplate;
end;
</source>
        <access>protected</access>
        <ReturnType type="CM_ReportTemplate"/>
    </JadeMethod>
    <JadeMethod name="firstLastStorage" id="cf5c1884-1b33-4de8-918c-0b40d7977729">
        <updating/>
        <source>firstLastStorage(_include : Boolean) updating;
// cnwjre1
/*	Test CCMS 2020 par 26107 
	A transaction map is loaded and set active, with invoice line descriptions and services using the new DAYSINCE_SHIP_ST and DAYSINCE_SHIP_EN
		calculation types.
	Cargo is created both on-site and on-ship.  The on-site transaction dates are then set back 20 days.
	Cargo is loaded and discharged.
	The transaction dates are then set back such that the first half of the unloads are 11 days old and the second half are 10 days old.
	This simulates an unload starting 11 days ago and taking two days.
	The transaction dates are then set back such that the first half of the loads are 9 days old and the second half are 8 days old.
	This simulates a load starting 9 days ago and taking two days.
	Storage transactions are automatically created from the load.
	The voyage ship exchange dates are also set to the start of unload (11 days ago) and end of load (8 days ago).
	Storage transactions are created for the imported cargo and the export storage transactions are re-evaluated.
	The import storage invoice lines should all be for 11 days, being the difference betwen the current date and start of unload.
	The export storage invoice lines should be re-evaluated to be all for 12 days, being the difference between the start date 20 days ago
		and the end of load (8 days ago).
	Test CCMS 2109 par 26108 - this method is called twice, once with the parameter false for the regular exclusive date range processing and 
								again with the parameter true for the inclusive date range processing.
								In the second case the invoice line quantities should all be one more than the values given above.
	
*/
vars
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
begin

//	self.deleteStorageConfig();
	self.setInclusiveStorageConfig(_include);
	
	self.tranMapLoadFirstLast();

	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 4);
	self.createCargoOnSite(voyage, 4, 20);
	
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	
	self.loadStart := null;
	self.unloadEnd := null;
	self.setExportTransDates(voyage);
	self.setImportTransDates(voyage);
	beginTransaction;
	voyage.setPropertyValue("shipExchangeDate", self.loadStart);
	voyage.setPropertyValue("shipExchangeCompleteDT", self.unloadEnd);
	commitTransaction;
	
	self.createImportStorage(voyage);
	self.reevalExportStorage(voyage);

	self.validateFirstLastImports(voyage, _include);
	self.validateFirstLastExports(voyage, _include);

epilog
	self.setInclusiveStorageConfig(false);
end;</source>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstLastStorage2" id="1a99c58e-4447-4c96-94bb-a83467dfda97">
        <updating/>
        <source>firstLastStorage2(_include : Boolean) updating;
// cnwjre1
/*	Copy of firstLastStorage originally created to test CCMS 2020 par 26107 , this copy to check Gulftainer contact 26895
	A transaction map is loaded and set active, with invoice line descriptions and services using the new DAYSINCE_SHIP_ST and DAYSINCE_SHIP_EN
		calculation types, and various quantity ranges as used in the contact.
	Using code from the UT_KPIVoyage tMain test, cargo is created both on-site and on-ship.
	Cargo is loaded and discharged.
	Storage transactions are automatically created from the load.
	The voyage ship exchange dates are set to a specific date of 25/08/2010 to match the contact.
	Storage transactions are created for the imported cargo at a specific date of 13/02/2011 to match the contact.
	
*/
vars
	ts	: TimeStamp;
	date : Date;
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
begin
	ts.setDate("25/08/2010".Date);			// this is the start of activity date
	date := "13/02/2011".Date;	
	
//	self.deleteStorageConfig();
	self.setInclusiveStorageConfig(_include);

	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 6);
	self.createCargoOnSite(voyage, 6, 20);
	
	// do after cargo creation so delete of old items will also delete invoice lines
	self.deleteInvoiceTransactionMap(1, 'UT_Storage3');
	self.tranMapLoadFirstLastRange();

	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	
	self.loadStart := null;
	self.unloadEnd := null;
	self.setExportTransDates(voyage);
	self.setImportTransDates2(voyage, ts.date);
	
	//ts.setDate("25/07/2010".Date);		// this is the date I suspect they actually used for the ship date
	beginTransaction;
	voyage.setPropertyValue("shipExchangeDate", ts);
	voyage.setPropertyValue("shipExchangeCompleteDT", ts);
	commitTransaction;
	
	self.createImportStorage2(voyage, date);

	self.validateFirstLastImports2(voyage, _include);

epilog
	self.resetDefaultTranMap();
	self.setInclusiveStorageConfig(false);
end;</source>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstLastStorage3" id="f42e1d2c-4fad-440e-82ee-5468dca97fd6">
        <updating/>
        <source>firstLastStorage3(_include : Boolean) updating;
// cnwjre1
/*	Copy of firstLastStorage originally created to test CCMS 2020 par 26107 , this copy to check Gulftainer contact 27229
	A transaction map is loaded and set active, with invoice line descriptions and services using the new DAYSINCE_SHIP_ST and DAYSINCE_SHIP_EN
		calculation types, and various quantity ranges as used in the contact.
	Cargo is created both on-site and on-ship.
	Cargo is loaded and discharged.
	Storage transactions are automatically created from the load.
	The voyage ship exchange dates are set to a specific date of 25/08/2010 to match the contact.
	Actual receival date is 09/10/2010
	Storage transactions are created for the imported cargo at a specific date of 27/03/2011 to match the contact.
	
*/
vars
	ts	: TimeStamp;
	date : Date;
	date2 : Date;
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
begin
	ts.setDate("25/08/2010".Date);			// this is the ship exchange date
	date := "27/03/2011".Date;				// this is the end of activity date (road release)
	date2 := "09/10/2010".Date;				// this is the start of activity date (ship receive)
	
//	self.deleteStorageConfig();
	self.setInclusiveStorageConfig(_include);

	self.expectTrxError(ERR_QUEUE_WLE_STAT);					// 20/08/2012 cnwmh5
	self.expectTrxError(SystemAlertCreated);
	
	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 8);
	self.createCargoOnSite(voyage, 8, 20);
	
	// do after cargo creation so delete of old items will also delete invoice lines
	self.deleteInvoiceTransactionMap(1, 'UT_Storage3');
	self.tranMapLoadFirstLast2();

	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	self.moveAllCargo(voyage, location);
	app.myPassport.clearErrorsWarnings();	// not all jobs got across ...
	
	self.loadStart := null;
	self.unloadEnd := null;

	self.setImportTransDates2(voyage, date2);
	
	beginTransaction;
	voyage.setPropertyValue("shipExchangeDate", ts);
	voyage.setPropertyValue("shipExchangeCompleteDT", ts);
	commitTransaction;
	
	self.createImportStorage2(voyage, date);

	self.validateFirstLastImports3(voyage, _include);

epilog
	self.resetDefaultTranMap();
	self.setInclusiveStorageConfig(false);
end;</source>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstLastStorage4" id="81fcfabc-df1c-4a91-9ad2-66a6e4e6b91d">
        <updating/>
        <source>firstLastStorage4(_include : Boolean) updating;
// cnwjre1
/*	Copy of firstLastStorage for contact 29752
	A transaction map is loaded and set active, with invoice line descriptions and services using the new DAYSINCE_SHIP_ST and DAYSINCE_SHIP_EN
		calculation types, and various quantity ranges as used in the contact.
	Cargo is created both on-site and on-ship.
	Cargo is loaded and discharged.
	Storage transactions are automatically created from the load.
	Import cargo on-ship is changed to tranship and the voyage used for the receive ship invoice is checked.
	
*/
vars
	ts	: TimeStamp;
	date : Date;
	date2 : Date;
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
	voyage2	: CM_Voyage;
begin
	ts.setDate("25/08/2010".Date);			// this is the ship exchange date
	date := "27/03/2011".Date;				// this is the end of activity date (road release)
	date2 := "09/10/2010".Date;				// this is the start of activity date (ship receive)
	
	self.setInclusiveStorageConfig(_include);
	
	voyage := self.createVesselVoyage3();
	self.createCargoOnShip(voyage, 99);
	self.createCargoOnSite(voyage, 99, 20);
	voyage2 := createVesselVoyage3();
	self.makeImportsTranship(voyage, voyage2);
	
	// do after cargo creation so delete of old items will also delete invoice lines
	self.deleteInvoiceTransactionMap(1, 'UT_Storage4');
	self.tranMapLoadFirstLast3();

	////self.moveAllCargo(voyage);
	app.myPassport.clearErrorsWarnings();	// not all jobs got across ...
	
	self.loadStart := null;
	self.unloadEnd := null;

	
	//self.validateFirstLastImports3(voyage, _include);

epilog
	self.resetDefaultTranMap();
	self.setInclusiveStorageConfig(false);
end;</source>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
