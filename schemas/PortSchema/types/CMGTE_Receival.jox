    <JadeMethod name="setPXYFromBooking" id="1d46210b-db31-4f05-8252-ef1b9b8c7b41">
        <updating/>
        <source>setPXYFromBooking(_booking : CM_BookingRefItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 03/12/2009		CCMS 1007		Moved reefer properties up from CMGTE_Container level
// ---------------------------------------------------------------------------

vars
	haz : CM_Hazard;
begin
	if _booking = null then
		return;
	endif;
	
	self.myProduct 		:= _booking.myProduct;	
	self.mark 			:= _booking.shippingMarks;
//	self.volume 		:= _booking.volume;
	self.setMyVolume(_booking.volume);	//18 Jul 2011	NDL	Par 27868
	self.density 		:= _booking.density;
	self.lengthString	:= _booking.lengthString;
	self.widthString 	:= _booking.widthString;
	self.heightString 	:= _booking.heightString;
	self.length 		:= _booking.length;
	self.width 			:= _booking.width;
	self.height 		:= _booking.height;
	self.weight 		:= _booking.weight;
	self.cargoType 		:= _booking.cargoType;
	self.description 	:= _booking.description;
	self.inspected 		:= _booking.inspected;
	self.commodity 		:= _booking.commodity;
	
	if _booking.myBookingReference.myVoyage &lt;&gt; null then // PAR 21232
		self.voyageCode 	:= _booking.myBookingReference.myVoyage.code;	
	endif;
	
	//31 Jan 2013	NDL	Par 31102
	if _booking.myBookingReference &lt;&gt; null then
		self.directDelivery := _booking.myBookingReference.directDelivery;
	endif;
	
	self.allTIHazards.clear();
	_booking.allTIHazards.copy(self.allTIHazards);
	
	// CCMS MES 1007 moved up from CMGTE_Container
	self.setCarbonDioxide( _booking.getCarbonDioxide );
	self.carriageTempC 	:= _booking.getTemperature();
	self.carriageTempF 	:= _booking.getTemperature();  //cnwrd1 par 29126 17.2.2012 
	self.curtainsIn 	:= _booking.getCurtainsIn();
	self.setHumidity( _booking.getHumidity );
	self.setOxygen( _booking.getOxygen );
	self.ventilation 	:= _booking.getVentilation();
	
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="531b7a98-8abd-4e16-b888-f6ca33d0693f">
        <updating/>
        <source>setPXYFromController(_flexi : CMIF_FlexiGateController) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 03/12/2009		cnwdap1			CCMS MES 1007 moved reefer properties up from container level
// 30/03/2010		cnwdap1			PAR #23442 Added wet attribute setting
// 06/04/2010		cnwdap1			PAR #23442 Added volume attribute setting
// 16/01/2013		cnwdap1			PAR #31018 CCMS POL 2223 Added transit on power attributes
// 05/03/2014		cnwdap1			PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
// 29/04/2015		cnwdap1			PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 25/11/2015		cnwma1  		PAR #36943 Shipping Reference error during extract
// 07/10/2020       cnwma1          ChangeRequest 50112: ASPA - GCI Stevedores
// 19/05/2022		jlika1			TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 14/06/2022		navak20			ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// 16/08/2022		navak20			TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 06/04/2023		navkc1			CR# 56431 Task 56438: UI - Cargo Enquiry
// 14/11/2023		jlika1			TFS 61131 61013 CUX | Cargo Priority - Prenotes and Add Cargo Forms
// 02/10/2025		navdap1			MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod(_flexi);
	
	self.myTranshipToPort := _flexi.myTranshipToPort;		// cnwjk3 PAR 23390 24/03/2010
	self.bookingReference := _flexi.bookingNumber;
	self.tiEdition := _flexi.tiEdition;
	self.imexStatus := _flexi.imexStatus;
	self.destinationPort := _flexi.destinationPort;
	self.dischargePort := _flexi.dischargePort;
	self.weightTotal := _flexi.weightTotal;
	self.isWeightCertified := _flexi.isWeightCertified;	//19 Mar 2014	NDL	Par 33268
	self.weightCertifiedName := _flexi.weightCertifiedName; //epr TFS 2011 3/6/16
	self.weightCertifiedReference:=_flexi.weightCertifiedReference; //epr TFS 2011 3/6/16
	self.weightCargo := _flexi.weightCargo;	// 19/02/2010 cnwar2 #22339
	self.weightTare := _flexi.weightTare;	// 19/02/2010 cnwar2 #22339
	self.commodity := _flexi.commodity;	
	if _flexi.myCarrier &lt;&gt; null then
		self.carrier := _flexi.myCarrier.code;	// 03/02/2012 cnwar2 #28799
	endif;
	self.remarks := _flexi.remarks;			//cnwmc5 - 19 May 2014 - PAR 34173
	self.companyCode  := _flexi.companyCode;
	self.consignorCode := _flexi.consignorCode;
	self.consigneeCode := _flexi.consigneeCode;
	self.customsAgentCode := _flexi.customsAgentCode;
	self.consignorVoyageCode := _flexi.consignorVoyageCode;
	self.directDelivery := _flexi.directDelivery;	//29 Jan 2013	NDL	Par 31102
	self.operatorExportReleaseNumber := _flexi.operatorExportReleaseNumber;
	self.customExportEntryNumber := _flexi.customEntryNumber;
	self.purchaseOrder := _flexi.purchaseOrder;
	self.serviceOrder := _flexi.serviceOrder;							// PAR #33193
	self.shippingReference :=_flexi.shippingReference;					//25/11/2015 cnwma1 PAR #36943
	self.width := _flexi.width;
	self.widthString := _flexi.widthString;
	self.dimLenFront := _flexi.dimLenFront;
	self.dimLenRear := _flexi.dimLenRear;
	self.dimWidthLeft := _flexi.dimWidthLeft;
	self.dimWidthRight := _flexi.dimWidthRight;
	self.isOverDimensions	:= _flexi.isOverDimensions;
	self.specialStow := _flexi.specialStow;
//	self.volumeTotal := _flexi.volumeTotal;
	self.setMyCargoVolume( _flexi.volumeTotal );	//18 Jul 2011	NDL	Par 27868
//	self.volume := _flexi.volume;				// PAR #23442
	self.setMyVolume(_flexi.volume);	//18 Jul 2011	NDL	Par 27868
	self.totalQuantity:=_flexi.numItems;
	self.density := _flexi.density;
	self.alternativeId := _flexi.alternativeId;
	self.colour := _flexi.colour;
	self.billOfLading := _flexi.billOfLading;
	self.cargoType := _flexi.cargoType;
	
	self.clientRef := _flexi.clientRef;  //cnwrd1 par 23337 20.5.2010
	
	self.allDischargePorts.clear();
	_flexi.allDischargePorts.copy(self.allDischargePorts);
	
	self.allStops.clear();
	_flexi.allStops.copy(self.allStops);
	
	self.allTIHazards.clear();
	_flexi.allTIHazards.copy(self.allTIHazards);
	
	self.allSpecialLifts.clear();
	_flexi.allSpecialLifts.copy(self.allSpecialLifts);
	
	self.shippingLineCode := _flexi.shippingLineCode;	// 14 June 2022 navak20 TFS 53195
	self.countryOfOriginCode := _flexi.countryOfOriginCode; 	// 16.08.2022 navak20 TFS 54441
	self.invoiceContractId	:= _flexi.invoiceContractId;//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	if not self.allStops.isEmpty() then
		self.doSetStops := true;
	else
		self.doSetStops := false;
	endif;
	
	self.allToDoTasks.clear();
	_flexi.allToDoTasks.copy(self.allToDoTasks);
	
	if not self.allToDoTasks.isEmpty() then
		self.doSetToDoTasks := true;
	else
		self.doSetToDoTasks := false;
	endif;
	
	// CCMS 1007 Reefer stuff
	self.allowableTimeOffPower := _flexi.allowableTimeOffPower;
	self.carriageTempC := _flexi.carriageTempC;
	self.carriageTempF := _flexi.carriageTempF;
	self.setCarbonDioxide( _flexi.getCarbonDioxide );
	self.setOxygen( _flexi.getOxygen );
	self.curtainsIn := _flexi.curtainsIn;
	self.setHumidity( _flexi.getHumidity );
	self.packDate := _flexi.packDate;
	self.packTime := _flexi.packTime;
	self.packTempC := _flexi.packTempC;
	self.packTempF := _flexi.packTempF;
	self.ventilation := _flexi.ventilation;
	// CCMS 1007 end
	
	// PAR #23442
	self.wet	:= _flexi.wet;
	
	self.createProxySeals( _flexi.allSeals );	//22 Sep 2010 NDL	Par 25608
	
	// PAR #31018 CCMS POL 2223 added transit on power attributes
	self.onPowerDuringTransit	:= _flexi.onPowerDuringTransit;		// PAR #31018
	self.transitOnPowerDate		:= _flexi.transitOnPowerDate;		// PAR #31018
	self.transitOnPowerTime		:= _flexi.transitOnPowerTime;		// PAR #31018
	self.transitOnPowerRemarks	:= _flexi.transitOnPowerRemarks;	// PAR #31018
	self.remainingTimeOffPower	:= _flexi.remainingTimeOffPower;	// PAR #31018
	
	self.expiryDate				:= _flexi.expiryDate;				// PAR #36094
	self.isExternallyMonitored 	:= _flexi.isExternallyMonitored;    //epr TFS 3581 15/3/17
	self.stevedoreCode 			:= _flexi.stevedoreCode;            //02.10.2020 cnwma1 TFS #50112
	// jlika1 TFS 53316 --&gt;
	self.diameter				:= _flexi.diameter;
	self.grade					:= _flexi.grade;
	self.grammage				:= _flexi.grammage;
	self.rollingLength			:= _flexi.rollingLength;
	// jlika1 TFS 53316 &lt;--
	//jlier1 TFS 53515 25/5/22
	self.myCargoGroup:=_flexi.myCargoGroup;
	if self.myCargoGroup = null then
		if _flexi.cargoGroupId &lt;&gt; null then
			self.setPxyCargoGroup(_flexi.cargoGroupId);
		endif;
	endif;
	
	self.hsCode:=_flexi.hsCode; //jlier1 TFS 55584 20/12/22
	
	self.attributeisOverlanded := _flexi.attributeisOverlanded;	//06/04/2023	navkc1	CR# 56431 Task 56438 
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	self.itemised := _flexi.itemised;
	self.secondaryBarcodeId := _flexi.secondaryBarcodeId;
	self.mySortingMethod := _flexi.mySortingMethod;
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	self.myCustomerPriority := _flexi.myCustomerPriority;
	
	self.cargoTypeContents := _flexi.cargoTypeContents;		// MTN-36141
	
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="setPxyAlternativeId" id="95eab20d-ab21-4986-998e-eceb2f1c2264">
        <updating/>
        <source>setPxyAlternativeId(_alternativeId : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.alternativeId := _alternativeId;
epilog

end;</source>
        <Parameter name="_alternativeId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxyCargoGroup" id="58f16778-921b-4b8b-9ef4-09305a6b9dad">
        <updating/>
        <source>setPxyCargoGroup(_cargoGroupID : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2022	jlier1	Initial creation 53515

*/

vars
	cgCargoType : CM_CargoType;
	operator : CM_Operator;
	pxyTI : CM_TrackedItem;
	subT : CM_SubTerminal;
begin
	if _cargoGroupID = null then
		return;
	endif;
	
	
	cgCargoType := self.myTerminal.getDefaultCargoGroupCargoType();
	if cgCargoType = null then
		app.raiseCMException( Unspecified_Cargo_Type, null, null );
		return;
	elseif not cgCargoType.isCargoGroup then
		app.raiseCMException1( Cargo_type_selec_not_defin_car, cgCargoType.description, null, null );
		return;
	endif;
	
	if self.operatorCode = null then
		app.raiseCMException( Please_select_operator, null, null );
		return;
	endif;
	operator := app.myRoot.allOperators.getAtKey( self.operatorCode );
	if operator = null then
		app.raiseCMException( Please_select_operator, null, null );
		return;
	endif;
	
	pxyTI := self.myTerminal.createTI(cgCargoType, true);
	pxyTI.zSetPxyTerminal( self.myTerminal );
	pxyTI.setCargoType(cgCargoType.id);

	pxyTI.setMyOperator(operator);
			
	pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);

	pxyTI.zSetPxyCompany(self.myTerminal.getDefaultCompanyBank);
		
	if app.isSubTerminalsOn(self.myTerminal) then
		subT := self.myTerminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	pxyTI.zSetPxyId( _cargoGroupID );
	
	self.myCargoGroup:=pxyTI.CM_CargoGroup;

epilog

end;</source>
        <Parameter name="_cargoGroupID" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxyContainerDimensions" id="3243a0ab-4e11-4a81-acda-0d1ffa5c54af">
        <updating/>
        <source>setPxyContainerDimensions(	_dimLenFront : Decimal;
							_dimLenRear : Decimal;
							_dimWidthLeft : Decimal;
							_dimWidthRight : Decimal;
							_height : Decimal
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.dimLenFront := _dimLenFront;
	self.dimLenRear := _dimLenRear;
	self.dimWidthLeft := _dimWidthLeft;
	self.dimWidthRight := _dimWidthRight;
	self.height := _height;

epilog

end;</source>
        <Parameter name="_dimLenFront" type="Decimal"/>
        <Parameter name="_dimLenRear" type="Decimal"/>
        <Parameter name="_dimWidthLeft" type="Decimal"/>
        <Parameter name="_dimWidthRight" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTI" id="f6d04c24-325a-439f-9aa8-49eb99677960">
        <updating/>
        <source>setPxyFromTI(_ti: CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/03/2010	cnwjk3	PAR 22502
30/03/2010	cnwdap1	PAR #23442 wet attribute
18/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 new On Power During Transit attributes
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Service Order field
20/02/2015	cnwdap1	PAR #35672 Rejig packTemp setting - packTemp on reefer properties is a string,
					so check this string is not null before setting / converting (null means unset in this case)
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
30/10/2015	cnwma1	PAR #36740 Creating Prenote and Cargo Onship does not save damage details
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
07/10/2020  cnwma1 	ChangeRequest 50112: ASPA - GCI Stevedores
12/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
14/06/2022	navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
16/08/2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
14/11/2023	jlika1	TFS 61131 61013 CUX | Cargo Priority - Prenotes and Add Cargo Forms
02/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/
vars
	pxyBulk			: CM_BreakBulkGeneric;
	todoTask		: CM_ToDoTask;
	damageInstance  : CM_DamageInstance;
	pxyDamage	 	: CM_DamageInstance;
	contents		: CM_CargoType;			// MTN-36141
begin
	inheritMethod(_ti);
	
	if _ti.myCustomsAgent &lt;&gt; null then
		self.customsAgentCode := _ti.myCustomsAgent.code;
	endif;

	self.myTrackedItem				:= _ti;
	self.cargoType					:= _ti.cargoType;
	self.carrier					:= _ti.carrier;
	self.billOfLading 				:= _ti.billOfLading;
	self.consignorVoyageCode 		:= _ti.consignorVoyageCode;
	self.customExportEntryNumber	:= _ti.customExportEntryNumber;
	self.density 					:= _ti.density;	
	self.destinationPort			:= _ti.destinationPort;
	self.dischargePort				:= _ti.dischargePort;
	self.myTranshipToPort			:= _ti.myTranshipToPort; //epr par 32621
	self.yardLocationTxt			:= _ti.locationId;
	self.purchaseOrder				:= _ti.purchaseOrder;
	self.serviceOrder				:= _ti.serviceOrder;					// PAR #33193
	self.shippingReference			:= _ti.shippingReference;				//25/11/2015 cnwma1 PAR #36943
	self.remarks					:= _ti.remarks;
	self.specialStow				:= _ti.specialStow;
	self.alternativeId				:= _ti.alternativeId;
	self.bookingReference 			:= _ti.bookingReference;
	self.commodity 					:= _ti.commodity;
//	self.volumeTotal 				:= _ti.getMyVolume;
	self.setMyCargoVolume( _ti.getMyTotalVolume );	//18 Jul 2011	NDL	Par 27868
//	self.weightTotal 				:= _ti.weight; //cnwrs1 7 may 2010 redundant as weightTotal is set later
	self.consigneeCode		 		:= _ti.consignee;
	self.consignorCode 				:= _ti.consignor;
	self.imexStatus 				:= _ti.getImExStatus();
	self.loadPort					:= _ti.loadPort;
	self.weightTare 				:= _ti.weightTare;
	self.weightCargo 				:= _ti.weightCargo;
	self.weightTotal 				:= _ti.totalWeight;
	self.weightDeclared 			:= _ti.weightDeclared;
	self.isWeightCertified 			:= _ti.isWeightCertified;
	self.weightCertifiedName		:= _ti.weightCertifiedName;
	self.weightCertifiedReference	:= _ti.weightCertifiedReference; //epr TFS 2011 2/6/16
	self.operatorExportReleaseNumber := _ti.getOperatorExpReleaseNo();
	self.allowableTimeOffPower 		:= _ti.getAllowableTimeOffPower();
	self.coolingType 				:= _ti.getCoolingType();
	self.voltageType 				:= _ti.getVoltageType();
	self.reeferRemarks 				:= _ti.getReeferRemarks();
	self.curtainsIn 				:= _ti.getCurtainsIn();
	self.setCarbonDioxide( _ti.getCarbonDioxide );
	self.setOxygen ( _ti.getOxygen );
	self.setHumidity( _ti.getHumidity );
	self.ventilation 				:= _ti.getVentilation();
	self.packDate 					:= _ti.packDate;
	self.packTime 					:= _ti.packTime;
	self.operatorCode 				:= _ti.operatorCode;
	self.shippingLineCode 			:= _ti.getShippingLineCode();		// 14 Jun 2022 navak20 TFS 53195
	self.countryOfOriginCode		:= _ti.getCountryOfOriginCode();		// 16.08.2022 navak20 TFS 54441
	self.invoiceContractId			:= _ti.contractId;//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	//cnwmc5 - 18 August 2014 - PAR 34590
	if _ti.myReeferProperties &lt;&gt; null and  _ti.myReeferProperties.packTempC &lt;&gt; null then	// PAR #35672
		self.packTempC				:= _ti.getPackTemp();									// PAR #35672
		self.packTempF				:= app.temperatureConversion(true,_ti.getPackTemp());	// PAR #35672
	endif;																					// PAR #35672

	self.allDischargePorts.clear();
	_ti.allDischargePorts.copy(self.allDischargePorts);

	self.setPxyHazards(_ti.allTIHazards);
	self.setPxySpecialLifts(_ti.allSpecialLifts);
	
	self.allStops.clear();
	
	// cnwjk3 04/06/2010 - changes to the way I collate stop ids as advised by cnwrl
	_ti.getStopsAsIntegerArray(self.allStops);
	
	self.allToDoTasks.clear();
	foreach todoTask in _ti.allToDoTasksToDo do
		self.allToDoTasks.add(todoTask.toDoTaskDesc);
		self.doSetToDoTasks := true;	//19 Feb 2016	NDL	Par 37538
	endforeach;
	
	foreach damageInstance in _ti.allDamageInstancesByPos do                  //30/10/2015 cnwma1 PAR #36740
		pxyDamage := damageInstance.cloneSelf(true).CM_DamageInstance;		  //30/10/2015 cnwma1 PAR #36740
		pxyDamage.setMyDamageDefinition(damageInstance.myDamageDefinition);   //30/10/2015 cnwma1 PAR #36740
		pxyDamage.setMyDamagePosition(damageInstance.myDamagePosition);      //30/10/2015 cnwma1 PAR #36740
		pxyDamage.setMySubject(self);          								 //30/10/2015 cnwma1 PAR #36740
	endforeach;																 //30/10/2015 cnwma1 PAR #36740
		
	//cnwrd1 par 29126 17.2.2012 - set both of these here
	//self.carriageTempF := _ti.getTemperature();									// PAR #31155
	self.carriageTempF := app.temperatureConversion(true,_ti.getTemperature());		// PAR #31155
	self.carriageTempC := _ti.getTemperature();

	//epr  TFS 1602 28/2/17 
	if _ti.isKindOf(CM_Container) then
		if _ti.isEmpty then	
			self.jobType:=self.JobType_EmptyIN;
			
		else
			self.jobType:=self.JobType_FullIN;
		endif;
	elseif _ti.isKindOf(CM_TILC) then
		self.jobType:=self.JobType_ChassisIN;
	else
		self.jobType:=self.JobType_GeneralIN;
	endif;
	
	
	if _ti.isKindOf(CM_BreakBulkGeneric) then
		// Note that we can't just override this method in CMGTE_BreakBulk, as CM_BreakBulk TIs are create from
		// CMGTE_Receivals.  CMGTE_BreakBulk class is not used.
		pxyBulk := _ti.CM_BreakBulkGeneric;
		
		self.widthString 		:= pxyBulk.widthString;
		self.heightString		:= pxyBulk.heightString;
		self.lengthString 		:= pxyBulk.lengthString;	 
		self.type				:= pxyBulk.type;
		self.totalQuantity		:= pxyBulk.totalQuantity;		//cnwmc5 - 22 Nov 2013 - PAR 33048
		self.quantity			:= pxyBulk.quantity;
	//	self.volume				:= pxyBulk.unsplitVolume;
		self.setMyVolume(pxyBulk.unsplitVolume);	//18 Jul 2011	NDL	Par 27868
		self.weight				:= pxyBulk.unsplitWeight;
		self.colour				:= pxyBulk.colour;
		// jlika1 TFS 53316 --&gt;
		//self.diameter 			:= pxyBulk.diameter.asStringJMT; 
		self.diameter 			:= pxyBulk.getDiameter().Decimal; 		// ### TFS 54021 29June2022 NAVPW1
		//self.grade 				:= pxyBulk.grade;
		self.grade 				:= pxyBulk.getGrade();					// ### TFS 54021 29June2022 NAVPW1
		//self.grammage 			:= pxyBulk.grammage;
		self.grammage 			:= pxyBulk.getGrammage().Decimal;		// ### TFS 54021 29June2022 NAVPW1
		//self.rollingLength 		:= pxyBulk.rollingLength;
		self.rollingLength 		:= pxyBulk.getRollingLength().Decimal;	// ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
	endif;
	
	// PAR #23442
	if _ti.isKindOf(CM_Timber) then
		self.wet				:= _ti.CM_Timber.wet;
	endif;
	
	self.createProxySeals( _ti.allSeals );	//22 Sep 2010 NDL	Par 25608
	
	// PAR #31018 On Power During Transit attributes				// PAR #31018
	self.onPowerDuringTransit	:= _ti.getOnPowerDuringTransit;		// PAR #31018
	self.remainingTimeOffPower	:= _ti.getRemainingTimeOffPower;	// PAR #31018
	self.transitOnPowerDate		:= _ti.getTransitOnPowerDate;		// PAR #31018
	self.transitOnPowerTime		:= _ti.getTransitOnPowerTime;		// PAR #31018
	self.transitOnPowerRemarks	:= _ti.getTransitOnPowerRemarks;	// PAR #31018
	
	self.expiryDate				:= _ti.getExpiryDate();				// PAR #36094
	self.receivalTemperature 	:= _ti.getReceivedTemperature();	// PAR #36094
	self.isExternallyMonitored	:= _ti.getExternalMonitoring(); 	//epr TFS 3581 15/3/17
	self.stevedoreCode		 	:= _ti.stevedoreCodeRecieve;        //02.10.2020 cnwma1 TFS #50112
	
	self.myCargoGroup:=_ti.myCargoGroup; //jlier1 TFS 53515 25/5/22
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	self.itemised := _ti.itemised;
	self.secondaryBarcodeId := _ti.secondaryBarcodeId;
	self.mySortingMethod := _ti.mySortingMethod;
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	self.myCustomerPriority := _ti.myCustomerPriority;
	
	// MTN-36141
	contents := _ti.getCargoTypeForContents();
	if contents &lt;&gt; null then
		self.cargoTypeContents := contents.id;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setPxyHazards" id="602050d9-0317-4422-b864-c8b1765367cc">
        <updating/>
        <source>setPxyHazards(_hazards : CM_HazardByCodeDict) updating, protected;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	-----------------------------------------------
11/06/2015	cnwdap1		PAR #36421 changed signature for CM_TIHazard::setProxy
09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
*/

vars
	obj		: Object;
	tiHaz	: CM_TIHazard;
	newHaz	: CM_TIHazard;
begin
	self.allTIHazards.clear;	//just clear

	if _hazards.isEmpty then
		return;
	endif;
	
	foreach obj in _hazards do
		if CM_TIHazard.hasInstance(obj) then
			tiHaz := obj.CM_TIHazard;
			create newHaz transient;
			//is transient need to use setProxy
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity);					// PAR #36421
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity,tiHaz.packingGroup);	// TFS 2842
			newHaz.setProxy(	tiHaz.code, 							// TFS 2842
								tiHaz.description, 						// TFS 2842
								tiHaz.allUNDGCodes.asCSV(false),		// TFS 2842
								null,									// TFS 2842
								tiHaz.limitedQuantity,					// TFS 2842
								tiHaz.packingGroup,						// TFS 2842
								tiHaz.flashpointTemperature,			// TFS 2842
								tiHaz.isMarinePollutant,				// TFS 2842
								tiHaz.acidsBases	);					// TFS 2842
			self.allTIHazards.add(newHaz);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setPxyId" id="d4e2c1df-9713-437c-a281-f281c3f62532">
        <updating/>
        <source>setPxyId( _id : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2011	cnwndl1	Initial creation	Par 27089

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.id := _id;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxySpecialLifts" id="e48f95cb-b560-4d8c-ba21-61e9343bd315">
        <updating/>
        <source>setPxySpecialLifts(_specialLifts : CM_SpecialLiftByCodeDict)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Jan 2010	cnwmd1	Initial creation
23 Sep 2024 navhl20	Bug 66248: SNO - Error 1309 while registering Cargo Checks during Road Gate process
*/

vars
	//specialLift, pxySpecialLift : CM_SpecialLift;
begin
	//_specialLifts.copy(self.allSpecialLifts); //+ cnwmd1 Par 22235 - allow transient to persistent	//23.09.2024 navhl20 #66248
	self.allSpecialLifts.clear();																		//24.09.2024 navhl20 #66248
	_specialLifts.tryCopy(self.allSpecialLifts);														//23.09.2024 navhl20 #66248
	
	/* //- cnwmd1, Par 22235
	self.allSpecialLifts.clear();
	
	if _specialLifts.isEmpty then
		return;
	endif;
	
	foreach specialLift in _specialLifts do
		if CM_SpecialLift.hasInstance(specialLift) then
			create pxySpecialLift transient;
			pxySpecialLift.setProxy(specialLift.code, specialLift.description);
			self.allSpecialLifts.add(pxySpecialLift);
		endif;
	endforeach;*/
epilog

end;</source>
        <Parameter name="_specialLifts" type="CM_SpecialLiftByCodeDict"/>
    </JadeMethod>
