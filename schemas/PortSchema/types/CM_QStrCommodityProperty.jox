    <JadeMethod name="create" id="496e0895-7f25-4ea2-9720-cb138db5661f">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	Bug 60595: Selector criteria built up incorrectly from release request

*/
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
