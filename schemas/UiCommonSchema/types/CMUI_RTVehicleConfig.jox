    <JadeMethod name="loadDataFromObject" id="aa16883b-187d-4a45-97e0-8e75dc8f7870">
        <updating/>
        <source>loadDataFromObject(_object : Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation
15 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
01 Jul 2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
15 Jul 2021	navdap1	TFS 51286 STWR Vehicle App Notification Message
01 Sep 2021 navma1  ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
15 Mar 2022 jlier1	TFS 52741 - showing primary and secondary for imvs now
03/10/2022 navds21 TFS 50083 MTN - Machine Delay Idle Time
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
18 Mar 2025	navpw1	JIRA: MTN-34259 - Added a config option to be set on a vehicle basis to Retain Cargo Id in Driver Mode for Overstowed containers

*/

vars
	rtConfig 		: CM_RTVehicleConfig;
	taskViewMode    : Integer;
	title 			: String;
	hookCode		: CM_HookCode;
	isIMV 			: Boolean;
	isForLift       : Boolean;
begin
	rtConfig:=self.myTerminal.getRTVehicleConfigForObject(_object);
	self.isoTypeHookCode:=null;
	self.doorDirHookCode:=null;
	self.locationHookCode:=null;
	self.grpUserHooks.visible:=_object.isKindOf(CM_Terminal);
	if _object.isKindOf(CM_Terminal) then
		self.getHookCodeSource(rtConfig,HookType_RTConfigIsoType,hookCode,self.myIsoTypeHookType,self.isoTypeHookCode);
		self.getHookCodeSource(rtConfig,HookType_RTConfigLocation,hookCode,self.myLocationHookType,self.locationHookCode);
		self.getHookCodeSource(rtConfig,HookType_RTConfigDoorDir,hookCode,self.myDoorDirHookType,self.doorDirHookCode);	
	endif;
	
	self.btnHookDoorDir.enabled:=_object.isKindOf(CM_Terminal);
	self.btnHookISO.enabled:=_object.isKindOf(CM_Terminal);
	self.btnHookLocation.enabled:=_object.isKindOf(CM_Terminal);
	
	isIMV:=_object.isKindOf(CM_Machine) and _object.CM_Machine.isIMV or 
		_object.isKindOf(CM_MachineType) and _object.CM_MachineType.isIMV;
	
	self.grpOstow.visible:=not isIMV;
	self.grpTaskView.visible:=not isIMV;
	self.shtVehAppPrimDir2.visible:= not isIMV;
	self.shtVehAppSecDir2.visible:= not isIMV;
	self.shtVehAppPrimCargo2.visible:=not isIMV;
	self.shtVehAppSecCargo2.visible:=not isIMV;
	self.chkAllowChgSet.visible:=not isIMV;
	self.chkAllowNonRT.visible:=not isIMV;
	self.chkAutoReseq.visible:=not isIMV;
	
	if rtConfig = null then
		return;
	endif;
	
	self.lblMainInfo.caption:=self.getMainInfo(_object,rtConfig);
	
	self.chkAllowNonRT.value:=rtConfig.allowNonRTMoves;
	self.btnTemplCritEdit.enabled := self.chkAllowNonRT.value;	// MES 1080 #24294 15/09/2010
	self.chkAutoPlanDriver.enabled:= self.chkAllowNonRT.value; // epr TFS 6846 8/9/17 
	if self.chkAutoPlanDriver.enabled then //epr TFS 6846 8/9/17
		self.chkAutoPlanDriver.value:=rtConfig.autoplanDriverInitiatedMove;
	else
		self.chkAutoPlanDriver.value:=false;
	endif;
	self.chkAllowColumnFiltering.value := rtConfig.allowColumnFiltering;
	self.chkIgnoreWarn.value:=rtConfig.ignoreWarnings;
	self.chkAllowChgSet.value:=rtConfig.allowChangeSetdown;
	self.chkAllowChgQ.value:=rtConfig.allowChangeQueue;
	self.chkAutoReseq.value:=rtConfig.autoResequenceJobs;
	self.chkTandemToDiffTargets.value := rtConfig.allowTandemToDiffTargets;	// 21/11/19 MAP TFS47394
	self.chkDoSwapChangeCargo.value := rtConfig.doSwapChangeCargo; //29/10/2025	navkc1 JIRA 36186
	
	self.txtAcceptDelay.text:= rtConfig.acceptTimerInterval.asStringJMT;
	self.txtPickupDelay.text:=rtConfig.pickupTimerInterval.asStringJMT;
	
	self.chkTaskList.value:=rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST or	rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH;
	self.chkTaskGetNext.value:=rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_GETNEXT or	rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH;
	self.chkAutoGetNext.value:=rtConfig.automaticGetNextTask;
	self.setDefaultTaskModeVisibility();
	self.setDefaultTaskMode(rtConfig.defaultTaskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST);
	

	self.txtNumOstow.text:=rtConfig.maxNumberOverstowForDriver.asStringOrBlank;
	self.txtNumQEntries.text:=rtConfig.maxNumberQueueEntries.asStringOrBlank;
		
	self.cmbOstowMode.listIndex:=rtConfig.overstowMoveMode + 1;
	self.cmbLocationDisplay.setIndexForItemData(rtConfig.locationDisplayFormat); //jlier1 TFS 52160 1/11/21
	
	self.mulPrimaryTask.setSelected(null);
	if rtConfig.myPrimaryTaskFields &lt;&gt; null then
		self.mulPrimaryTask.setSelected(rtConfig.myPrimaryTaskFields.allEntTableRows);
	endif;
	self.mulSecondaryTask.setSelected(null);
	if rtConfig.mySecondaryTaskFields &lt;&gt; null then
		self.mulSecondaryTask.setSelected(rtConfig.mySecondaryTaskFields.allEntTableRows);
	endif;
	self.mulPrimaryCargo.setSelected(null);
	if rtConfig.myPrimaryCargoFields &lt;&gt; null then
		self.mulPrimaryCargo.setSelected(rtConfig.myPrimaryCargoFields.allEntTableRows);
	endif;
	self.mulPrimaryDirector.setSelected(null);
	if rtConfig.myPrimaryDirectorFields &lt;&gt; null then
		self.mulPrimaryDirector.setSelected(rtConfig.myPrimaryDirectorFields.allEntTableRows);
	endif;
	self.mulSecondaryCargo.setSelected(null);
	if rtConfig.mySecondaryCargoFields &lt;&gt; null then
		self.mulSecondaryCargo.setSelected(rtConfig.mySecondaryCargoFields.allEntTableRows);
	endif;
	self.mulSecondaryDirector.setSelected(null);
	if rtConfig.mySecondaryDirectorFields &lt;&gt; null then
		self.mulSecondaryDirector.setSelected(rtConfig.mySecondaryDirectorFields.allEntTableRows);	
	endif;
	
	self.setAllCriteria(rtConfig);	// MES 1014 #24294 15/09/2010
	
	self.txtMachPoll.text:=rtConfig.messagePollingInterval.asStringJMT;
	self.txtListPoll.text:=rtConfig.listPollingInterval.asStringJMT;
	
	self.txtIdleTime.text := rtConfig.idleTimeAllowable.asStringOrBlank;	// TFS 49316
	self.txtIdleAlert.text := rtConfig.idleTimeUntilAlert.asStringOrBlank;	// TFS 49316
	self.chkIdleandDelayHistory.value := rtConfig.idleTimeRecordInHistory;			// TFS 49316
	self.txtDelayTime.text := rtConfig.delayTimeAllowable.asStringOrBlank;	// 03.10.2022 navds21 TFS 50083
	self.txtDelayAlert.text := rtConfig.delayTimeUntilAlert.asStringOrBlank;	// 03.10.2022 navds21 TFS 50083
	
	// TFS 51409 start
	self.chkAllowNonRTQ.value := rtConfig.allowNonRTQMoves;
	if not self.chkAllowNonRT.value then
		self.chkAllowNonRTQ.value := false;
		self.chkAllowNonRTQ.enabled := false;
	else
		self.chkAllowNonRTQ.enabled := true;
	endif;
	self.chkWarnChgSet.value := rtConfig.allowChangeQSetdown;
	if not self.chkAllowChgSet.value then
		self.chkWarnChgSet.value := false;
		self.chkWarnChgSet.enabled := false;
	else
		self.chkWarnChgSet.enabled := true;
	endif;
	if self.chkIgnoreWarn.value then
		self.chkWarnChgSet.value := false;
		self.chkWarnChgSet.enabled := false;
	endif;
	// TFS 51409 end
	
	self.chkDriverDismiss.value 	:= rtConfig.driverDismissMessages;		// TFS 51286
	
	self.chkDriverMultiMove.value	:= rtConfig.allowDriverMultiMoves;      //01.09.2021 navma1 #51485
	self.chkDriverMultiMove.enabled := false;
	
	isForLift := _object.isKindOf(CM_Machine) and _object.CM_Machine.isForkLift or           //01.09.2021 navma1 #51485
				 _object.isKindOf(CM_MachineType) and _object.CM_MachineType.isForkLift;     //01.09.2021 navma1 #51485
		
	self.chkDriverMultiMove.enabled := isForLift;											 //01.09.2021 navma1 #51485
	
	self.chkRetainCargoIdDriverMode.value := rtConfig.retainCargoIdDriverMode;				// ### JIRA: MTN-34259 18Mar2025 NAVPW1
	
epilog
	if rtConfig = null then	// need to clear self.allCriteria always. MES 1080 #24294 15/09/2010
		self.setAllCriteria(rtConfig);
	endif;

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="lstObject_click" id="e8fba084-6526-40c6-be85-04cf6aa72c1e">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstObject_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation

*/

vars
	obj : Object;
begin
