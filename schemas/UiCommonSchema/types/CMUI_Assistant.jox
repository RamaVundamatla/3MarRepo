    </JadeMethod>
    <JadeMethod name="comboBoxHSCodes" id="30b74fc6-d5a2-4e20-b834-334fbfbc0e25">
        <source>comboBoxHSCodes(_comboBox : CMUI_ComboBox input; _hsCode : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		jlizm1	Initial creation TFS 64736 HS Code edi allow invalid codes

*/

vars
	iter 	: Iterator;
	idx		: Integer;
	hs		: CM_HarmonizedSystem;
	root 	: CM_Root;
	
begin
	_comboBox.clear();
	_comboBox.addItem(null);
	
	root := app.myRoot;
	iter := root.allHSCodesActive.createIterator;
	
	while iter.next(hs) do
		idx := _comboBox.addItem(hs.getDisplayString());
		_comboBox.itemObject[idx] := hs;
	endwhile;
	
	if _hsCode = null then
		return;
	endif;
	
	hs := root.allHSCodesActive[_hsCode];
	
	if hs = null then
		_comboBox.addItemAt(_hsCode, 2);
		_comboBox.listIndex := 2;
		return;
	endif;
	
	_comboBox.listObject := hs;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_comboBox" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_hsCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHasRadio" id="f74e6cf6-1b38-44fc-ab1b-199e700ea888">
        <source>comboBoxHasRadio(_cmb : CMUI_ComboBox input; _hasRadio : Integer);
// ---------------------------------------------------------------------------
// Created:     Apr 2006 cnwrs1	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	default, idx1, idx2 : Integer;
begin
	_cmb.clear();	
	_cmb.sorted := false;
	foreach idx1 in CM_Car.UnknownRadio to CM_Car.HasRadio do
		idx2 := _cmb.addItem(app.myRoot.carHasRadioDisplay(idx1));
		_cmb.itemData[idx2] := idx1;
		
		if idx1 = _hasRadio then
			default := idx2;
		endif;
	endforeach;
	
	_cmb.listIndex := default;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_hasRadio" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHazardClass" id="1d198095-47f7-4731-a6bb-42144042b126">
        <source>comboBoxHazardClass(_cmb : CMUI_ComboBox input; _hazClass : CM_HazardClass );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwer1	Initial creation HAT 2189

*/

vars
	hazClass : CM_HazardClass;
	idx, selectedIdx : Integer;
begin
	_cmb.clear;
	foreach hazClass in app.myRoot.allHazardClasses discreteLock do
		idx:=_cmb.addItemObject(hazClass.code &amp; Tab &amp; hazClass.description, hazClass);
		if hazClass = _hazClass then
			selectedIdx:=idx;
		endif;
	endforeach;
	
	if selectedIdx  &gt; 0 then
		_cmb.listIndex :=selectedIdx;
	endif;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_hazClass" type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHdlCntr1" id="9dc63098-af4b-4cc5-a202-48db08faddd4">
        <source>comboBoxHdlCntr1(pCmb : ComboBox input; _contractor : CM_HandlingContractor1; pCodeGroup:CM_CodesByCodeDict);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if pCodeGroup &lt;&gt; null then
		pCmb.listCollection(pCodeGroup, false, 0);
	else
