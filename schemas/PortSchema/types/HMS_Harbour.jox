    <JadeMethod name="getDefaultBerthForMoveType" id="fbcd129a-1b77-4603-994f-f9288746ca75">
        <source>getDefaultBerthForMoveType(_moveType : String) : HMS_Berth;
//--------------------------------------------------
// Created:	23 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	theBerth : HMS_Berth;
begin
	// Returns initialise value for the movement 'BERTH'
	if _moveType = HMSMovementTypeArrival
	or _moveType = HMSMovementTypeShift then
		theBerth := self.defaultArrvBerth;
	elseif _moveType = HMSMovementTypeDeparture then
		theBerth := self.defaultDepartBerth;
	endif;
	
	if theBerth = null then
		theBerth := self.allBerths.first;
	endif;
	
	if theBerth = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Harbour Default Berths', null, null);
		app.raiseCMException(Input_required_field_harburDef, null, null); // cnwdb2	PAR 35364
	endif;	
	

	return theBerth;
end;</source>
        <Parameter name="_moveType" type="String"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
