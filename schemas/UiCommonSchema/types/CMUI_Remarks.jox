    <JadeMethod name="showData" id="95c1f9a2-f822-4314-b29a-049c9d1b86b8">
        <updating/>
        <source>showData() updating;
//--------------------------------------------------------------
//Created: 16 January 2003 By: cnwgd1
// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//--------------------------------------------------------------	
vars
	damaged,
	remarks,
	reeferRemarks	: String;
	ti				: CM_TrackedItem;
	txtHeight : Integer;
	yardRequest : CM_YardRequest;
begin
	if self.myCurrentObject = null then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then
		self.lbObject.caption := 'Tracked Item: ' &amp; self.myCurrentObject.CM_TrackedItem.id; 				
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti.damaged then
			damaged := '1';
		else
			damaged := '0';		
		endif;
		remarks := ti.remarks;
		if ti.isKindOf(CM_Container) then
			reeferRemarks := ti.CM_Container.getReeferRemarks;
			self.tblMain.accessCell(3,2).text := reeferRemarks;										
		endif;
		self.tblMain.accessCell(1,2).text := remarks;
		self.tblMain.accessCell(2,2).text := damaged;
	elseif self.myCurrentObject.isKindOf(CM_Wagon) then
		self.lbObject.caption := 'Wagon: ' &amp; self.myCurrentObject.CM_Wagon.id; 				
		remarks := self.myCurrentObject.CM_Wagon.remarks;
		self.tblMain.accessCell(1,2).text := remarks;				
	elseif self.myCurrentObject.isKindOf(CM_Train) then
		self.lbObject.caption := 'Train: ' &amp; self.myCurrentObject.CM_Train.code; 				
		remarks := self.myCurrentObject.CM_Train.remarks;
		self.tblMain.accessCell(1,2).text := remarks;				
	elseif self.myCurrentObject.isKindOf(CM_Train) then
		self.lbObject.caption := 'Train: ' &amp; self.myCurrentObject.CM_Wagon.id; 				
//		remarks := self.myCurrentObject.CM_Train.remarks;
		self.tblMain.accessCell(1,2).text := remarks;				
	elseif self.myCurrentObject.isKindOf(CM_VoyageJob) then
		self.lbObject.caption := 'Job: ' &amp; self.myCurrentObject.CM_VoyageJob.id; 				
		remarks := self.myCurrentObject.CM_VoyageJob.remarks;
		self.tblMain.accessCell(1,2).text := remarks;				
	elseif self.myCurrentObject.isKindOf(CM_YardRequest) then
		self.lbObject.caption := 'Yard Request: ' &amp; self.myCurrentObject.CM_YardRequest.myJob.jobId; 				
		remarks := self.myCurrentObject.CM_YardRequest.remarks;
		self.tblMain.accessCell(1,2).text := remarks;	
	elseif self.myCurrentObject.isKindOf(CM_YardWLE) then
		yardRequest:=self.myCurrentObject.CM_YardWLE.myRequest.CM_YardRequest;
		self.lbObject.caption := 'Yard Request: ' &amp; yardRequest.myJob.jobId; 				
		remarks := yardRequest.remarks;
		self.tblMain.accessCell(1,2).text := remarks;	
		
	elseif self.myCurrentObject.isKindOf(CM_Voyage) then
		self.lbObject.caption := 'Voyage: ' &amp; self.myCurrentObject.CM_Voyage.code; 				
		remarks := self.myCurrentObject.CM_Voyage.remarks;

		self.txtRemarks.move(self.tblMain.left,self.tblMain.top,self.tblMain.clientWidth,self.tblMain.clientHeight);
		self.txtRemarks.text := CrLf &amp; remarks;
		self.txtRemarks.setFocus();
		self.txtRemarks.visible := true;
		self.tblMain.visible := false;
		
	elseif self.myCurrentObject.isKindOf(CM_BayVoyage) then
		self.lbObject.caption := 'Bay: ' &amp; self.myCurrentObject.CM_BayVoyage.id; 				
		remarks := self.myCurrentObject.CM_BayVoyage.remarks;
		self.txtRemarks.move(self.tblMain.left,self.tblMain.top,self.tblMain.clientWidth,self.tblMain.clientHeight);
		self.txtRemarks.text := CrLf &amp; remarks;
		self.txtRemarks.setFocus();
		self.txtRemarks.visible := true;
		self.tblMain.visible := false;
	elseif self.myCurrentObject.isKindOf(CM_ROROGraphic) then
		self.lbObject.caption := 'Graphic: ' &amp; self.myCurrentObject.CM_ROROGraphic.label; 				
		remarks := self.myCurrentObject.CM_ROROGraphic.remarks;
		self.txtRemarks.move(self.tblMain.left,self.tblMain.top,self.tblMain.clientWidth,self.tblMain.clientHeight);
		self.txtRemarks.text := CrLf &amp; remarks;
		self.txtRemarks.setFocus();
		self.txtRemarks.visible := true;
		self.tblMain.visible := false;
	elseif self.myCurrentObject.isKindOf(CM_DeckItemLayout) then
		self.lbObject.caption := 'Graphic: ' &amp; self.myCurrentObject.CM_DeckItemLayout.code; 	
		self.caption := app.getErrorString(Remarks);
		remarks := self.myCurrentObject.CM_DeckItemLayout.remarks;
		self.txtRemarks.move(self.tblMain.left,self.tblMain.top,self.tblMain.clientWidth,self.tblMain.clientHeight);
		self.txtRemarks.text := remarks;
		self.txtRemarks.setFocus();
		self.txtRemarks.visible := true;
		self.tblMain.visible := false;
	//17 Apr 2012	NDL	Par 29444
	elseif self.myCurrentObject.isKindOf(CM_DeckItem) then
		self.lbObject.caption := 'Deck Item: ' &amp; self.myCurrentObject.CM_DeckItem.code; 	
		self.caption := app.getErrorString(Remarks);
		remarks := self.myCurrentObject.CM_DeckItem.remarks;
		self.txtRemarks.move(self.tblMain.left,self.tblMain.top,self.tblMain.clientWidth,self.tblMain.clientHeight);
		self.txtRemarks.text := remarks;
		self.txtRemarks.setFocus();
		self.txtRemarks.visible := true;
		self.tblMain.visible := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3a72310b-e907-4997-9066-e16348dbbbe8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008033, locale);
	btnCancel.translateCaption(Xlat_0000750, locale);
	btnSave.translateCaption(Xlat_0000751, locale);
	lblOne.translateCaption(Xlat_0000752, locale);
end;</source>
    </JadeMethod>
</GUIClass>
