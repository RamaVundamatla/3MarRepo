    <JadeMethod name="click" id="02724953-ae9f-4799-a72e-582e987dc424">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(listbox: ListBox input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	transientObj	: CMIF_YACriteriaPriority;
	selectedObj		: CM_YAEntity;
	listPointer		: Integer;
	listSize		: Integer;
	
begin
	inheritMethod(listbox);
	
	if self.isCriteriaList then
		if self.listIndex = CNEC_NULL_INDEX then
			self.myYAControl.setSelectedCP(null);
		else
			transientObj	:=	self.listObject.CMIF_YACriteriaPriority;
			self.myYAControl.setSelectedCP(transientObj.myCriteriaPriority);
			
			if self.myYACriteriaControl &lt;&gt; null then
				self.myYACriteriaControl.loadDetails(transientObj);
			endif;
		endif;
		
	elseif self.isBlocksList then
		self.myYAControl.enableDeckingOptionsButtons(	(self.listIndex &lt;&gt; CNEC_NULL_INDEX) and
														not (CM_YABlockBlock.hasInstance(self.listObject)) and
														not (CM_YABlockGroup.hasInstance(self.listObject))
													);
		
		if self.selectedCount() &gt; 1 then
			if not self.isDragging then
				selectedObj	:=	self.listObject.CM_YAEntity;
				listSize	:=	self.listCount();
				
				foreach listPointer in 1 to listSize do
					if self.itemSelected[listPointer] then
						if self.itemObject[listPointer].class &lt;&gt; selectedObj.class then
							app.msgBox(	"Only Groups or Blocks can be dragged at one time - not both.",
										"Error",
										MsgBox_Information_Icon + MsgBox_OK_Only);
							
							self.itemSelected[self.listIndex]	:=	false;
							break;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="c836e312-8988-4509-aea4-7e3b3575e0de">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(listbox: ListBox input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod(listbox);
	
	if self.myYACriteriaControl &lt;&gt; null then
		if self.isSelect then
			self.myYACriteriaControl.doSelect(false);
		elseif self.isUnselect then
			self.myYACriteriaControl.doUnselect(false);
		endif;
	elseif self.myYAControl &lt;&gt; null then
		self.myYAControl.doUpdateBlockGroup(false, false, true);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="35c0af65-df08-4825-a874-f42688019d69">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer): String updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(listbox, obj, lstIndex);
	
	if self.isCriteriaList then
		return obj.CMIF_YACriteriaPriority.getListDisplay();
// cnwdad1 10/05/2006 - CCMS #1010.
	elseif self.isBlocksList then
		return obj.CM_YAEntity.getYAListDisplay(self.myYAControl.isSortIn);
	else
		return null;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOpenNodes" id="f135d6b1-9919-4951-b410-e924a382bed6">
        <source>doOpenNodes();
// --------------------------------------------------------------------------------
// Created:		16 June 2006 by cnwdad1
//
// Purpose:		Opens nodes that were previously open before a rebuild of the tree.
//				As nodes are opened and closed, the object for that entry is added
//				or removed from the receiver's collection of open Block Groups.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	listSize	: Integer;
	
begin
	listSize	:=	self.listCount();
	
	foreach listPointer in 1 to listSize do
		if self.itemHasSubItems(listPointer) then
			self.itemExpanded[listPointer]	:=	true;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="4b9372d7-3864-4bac-9d35-da771a502614">
        <controlMethod name="ListBox::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;
// THis event is no longer used because if we set dragMode, then the mouseMove events
// are not fired, hence we lose the auto-scroll capability when the mouse pointer is
// moved to the top/bottom edge of the listbox.
/*
vars
	allDraggedObjects	: ObjectArray;
	startPoint			: Integer;
	endPoint			: Integer;
	listPointer			: Integer;
	dropPointer			: Integer;
	
begin
	inheritMethod(listbox, win, x, y);
	
//	write "Thunk! Dropped " &amp; self.myDragObject.String &amp; " on " &amp; self.dragListIndex.String &amp; ".";
	dropPointer		:=	self.dragListIndex();
	
	if dropPointer = CNEC_NULL_INDEX then
		return;
	endif;
	
	create allDraggedObjects transient;
	startPoint		:=	1;
	endPoint		:=	self.listCount();
	
	foreach listPointer in startPoint to endPoint do
		if listPointer = dropPointer then
			continue;
		endif;
		
		if self.itemSelected[listPointer] then
			allDraggedObjects.add(self.itemObject[listPointer]);
		endif;
	endforeach;
	
	if allDraggedObjects.isEmpty() then
		return;
	endif;
	
global.cnwdad1;
	self.myYAControl.doLocationsDragDrop(self.itemObject[dropPointer], allDraggedObjects);
epilog
	delete allDraggedObjects;
	self.dragMode	:=	DragMode_None;		
end;
*/</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBlockOrGroup" id="7c443346-9620-42e8-8413-041af5cb3c64">
        <source>getBlockOrGroup(_blockObj:CM_YABlock output; _groupObj:CM_YABlockGroup output):Boolean;
// --------------------------------------------------------------------------------
// Created:		16 May 2006 by cnwdad1
//
// Purpose:		Returns either a Block or a Block Group as an output parameter,
//				depending upon which type is currently selected.
//
// Parameters:	_blockObj - A reference to the selected Block object.
//				_groupObj - A reference to the selected Block Group object.
//
// Returns:		True if either a Block or a Group is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	selectedObj		: Object;
	
begin
	if not self.isBlocksList
	or self.listIndex = CNEC_NULL_INDEX
	then
		return false;
	else
		selectedObj	:=	self.listObject;
		
		if selectedObj.isKindOf(CM_YABlock) then
			_blockObj	:=	selectedObj.CM_YABlock;
		elseif selectedObj.isKindOf(CM_YABlockGroup) then
			_groupObj	:=	selectedObj.CM_YABlockGroup;
		endif;
		
		return true;
	endif;
end;</source>
        <Parameter name="_blockObj" type="CM_YABlock" usage="output"/>
        <Parameter name="_groupObj" type="CM_YABlockGroup" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="7c7dad43-02e1-46f5-b988-8f4424bfba8d">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(listbox, button, shift, x, y);
	
	self.enableEvent(ListBox::mouseMove.name, true);
	self.setOriginals(x.Integer, y.Integer, self.listIndex, self.listObject);
	
	if button = Window.MouseButton_Right
	and self.isBlocksList
	then
		if self.myYAControl.isBlockGroupsUsed then
			self.myYAControl.showPopupMenu(listbox, x, y);
		endif;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="26988d27-0d65-4245-8588-5cb3f5080c8d">
        <controlMethod name="ListBox::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	whichBorder	: Integer;
	pictureObj	: Picture;
	
begin
	inheritMethod(listbox, button, shift, x, y);
	
	// Do we need to auto-scroll up or down ?
	
	if button = Window.MouseButton_Left then
		if not self.isDragging then
			self.multiSelect	:=	ListBox.MultiSelect_Simple;
			self.isDragging		:=	true;
		endif;
		
		if self.isInScrollZone(x, y, whichBorder) then
			if whichBorder = ListBox.ZONE_TOP then
				listbox.scrollMe(false, false);
			elseif whichBorder = ListBox.ZONE_BOTTOM then
				listbox.scrollMe(true, false);
			endif;
		endif;
	endif;
	
	// Now check for any dragging operations that are going on...
	
	if (not self.allowDragDrop) 			// &lt;-- dragDrop not allowed.
	or button &lt;&gt; Window.MouseButton_Left	// &lt;-- not dragging.
	or self.myDragObject = null				// &lt;-- nothing selected.
	or not self.isBlocksList				// &lt;-- this is not a list of Locations.
	then
		return;
	endif;
	
	if app.dragDetected(x, y, self.origXPos, self.origYPos) then
// Setting drag mode causes the mouseMove event to stop firing.
//		self.dragMode	:=	self.DragMode_Drag;
//		self.dragCursor	:=	self.dragCursor;
		
		if self.itemData[self.origIndex] = CMUI_YardAllocationControl.LOCATION_GROUP then
			self.form.CM_BaseForm.setMoveMode(YA_GROUP_MODE);
		elseif self.itemData[self.origIndex] = CMUI_YardAllocationControl.LOCATION_BLOCK then
			self.form.CM_BaseForm.setMoveMode(YA_BLOCK_MODE);
		else
			// Do nothing.
		endif;
		
		create pictureObj transient;
		self.form.CM_BaseForm.setPictureDragCursor(pictureObj);
		
		if pictureObj.picture &lt;&gt; null then
			self.mouseCursor	:=	pictureObj.picture;
			self.mousePointer	:=	Control.MousePointer_Cursor;
		endif;
	endif;
epilog
	delete pictureObj;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="297b07e8-6941-4756-b365-fddd32184e89">
        <controlMethod name="ListBox::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allDraggedObjects	: ObjectArray;
	startPoint			: Integer;
	endPoint			: Integer;
	listPointer			: Integer;
	dropPointer			: Integer;
	
begin
	inheritMethod(listbox, button, shift, x, y);
	
	if self.myYAControl &lt;&gt; null and self.isDragging then
//		write "Thunk! Dropped " &amp; self.myDragObject.String &amp; " on " &amp; self.dragListIndex.String &amp; ".";
// We can't use dragMode because the mouseMove event are not fired with it set.
//		dropPointer		:=	self.dragListIndex();
		dropPointer		:=	self.getListIndex(x, y);
		
		if dropPointer = CNEC_NULL_INDEX
		or x &lt;= 0
		or x &gt; self.height
		or y &lt;= 0
		or y &gt; self.width
		then
			return;
		endif;
		
		create allDraggedObjects transient;
		startPoint		:=	1;
		endPoint		:=	self.listCount();
		
		foreach listPointer in startPoint to endPoint do
			if listPointer = dropPointer then
				continue;
			endif;
			
			if self.itemSelected[listPointer] then
				allDraggedObjects.add(self.itemObject[listPointer]);
			endif;
		endforeach;
		
		if allDraggedObjects.isEmpty() then
			return;
		endif;
		
		self.myYAControl.doLocationsDragDrop(self.itemObject[dropPointer], allDraggedObjects);
	endif;
epilog
	self.isDragging		:=	false;
	self.multiSelect	:=	ListBox.MultiSelect_Extended;
	self.mouseCursor	:=	null;
	self.mousePointer	:=	Control.MousePointer_Default;
	delete allDraggedObjects;
	self.enableEvent(ListBox::mouseMove.name, false);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="5bf32a5b-4f47-4eaf-abe0-9c5e86f28ade">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		11 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(listbox, picIndex, whatClicked);
	listbox.itemExpanded[picIndex]	:=	(not listbox.itemExpanded[picIndex]);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaControl" id="6a63cd03-7fb7-428b-8461-f7da40a4b6ba">
        <updating/>
        <source>setCriteriaControl(	pYACControlObj:CMUI_YASelectCriteriaCntl;
					pIsSelect:Boolean;
					pIsUnselect:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the parent Yard Allocation Criteria control,
//				and sets the context in which the receiver is used.
//
// Parameters:	pYACControlObj - A reference to the parent Yard Allocation Criteria control.
//				pIsSelect - True if a double-click selects an entry in the listbox.
//				pIsUnselect - True if a double-click unselects an entry in the listbox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYACriteriaControl	:=	pYACControlObj;
	self.isSelect				:=	pIsSelect;
	self.isUnselect				:=	pIsUnselect;
end;</source>
        <Parameter name="pYACControlObj" type="CMUI_YASelectCriteriaCntl"/>
        <Parameter name="pIsSelect" type="Boolean"/>
        <Parameter name="pIsUnselect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setYAControl" id="ddf1b391-cfb9-4053-8142-fec5fad04cfa">
        <updating/>
        <source>setYAControl(	pYAControl:CMUI_YardAllocationControl;
				pIsBlocksList:Boolean;
				pIsCriteriaList:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the parent Yard Allocation control, and sets the
//				context in which the receiver is used.
//
// Parameters:	pYAControl - A reference to the parent Yard Allocation control.
//				pIsBlocksList - True if the control is being used to list YA Blocks.
//				pIsCriteriaList - True if the control is being used to list YA Criteria.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYAControl		:=	pYAControl;
	self.isBlocksList		:=	pIsBlocksList;
	self.isCriteriaList		:=	pIsCriteriaList;
	
	if pIsBlocksList then
		self.allowDragDrop	:=	true;
	endif;
end;</source>
        <Parameter name="pYAControl" type="CMUI_YardAllocationControl"/>
        <Parameter name="pIsBlocksList" type="Boolean"/>
        <Parameter name="pIsCriteriaList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="88682b29-9d85-459d-86bb-666882b751fe">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 June 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	self.multiSelect	:=	ListBox.MultiSelect_Extended;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
