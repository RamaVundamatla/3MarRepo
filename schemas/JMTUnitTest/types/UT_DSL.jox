    <JadeMethod name="createDatedChargedTransaction" id="98ba10ec-de4e-437f-8893-868e41066820">
        <source>createDatedChargedTransaction(_realTI : CM_TrackedItem input; _dateTime : TimeStamp; _type : Integer; _charged  :Boolean) : CM_TITransaction;
// cnwjre1
vars
	transParams: CMIF_TITransactionController;
	transObj : CM_TITransaction;
begin
	if _type = TRANS_TYPE_STORAGE then
		create transParams as CMIF_StorageTransController transient;
	else
		create transParams transient;
	endif;
	transParams.type := _type;
	transParams.noCharge := not _charged;
	transParams.userId := app.getMyUserCode();
	transParams.dateTime := _dateTime;
	
	beginTransaction;
	transObj := _realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	return transObj;
epilog
	delete transParams;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_charged" type="Boolean"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createDatedTransaction" id="3e08dd58-ac9a-44db-80ca-2928997b80a4">
        <source>createDatedTransaction(_realTI : CM_TrackedItem input; _dateTime : TimeStamp; _type : Integer) : CM_TITransaction;
// cnwjre1
vars
	transParams: CMIF_TITransactionController;
	transObj : CM_TITransaction;
begin
	if _type = TRANS_TYPE_STORAGE then
		create transParams as CMIF_StorageTransController transient;
		transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	else
		create transParams transient;
	endif;
	transParams.type := _type;
	transParams.noCharge := false;
	transParams.userId := app.getMyUserCode();
	transParams.dateTime := _dateTime;
	
	beginTransaction;
	transObj := _realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	return transObj;
epilog
	delete transParams;
end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createDebtorInvoiceLineType" id="8b8f4e2d-db2a-4d86-a4cf-4de0625a96c4">
        <source>createDebtorInvoiceLineType(_debtor : CM_Debtor; _invLineType : CM_InvoiceLineDesc; _otherCode : String) : CM_DebtorInvLineType;
// --------------------------------------------------------------------------------
// Created:		Sep 2011 cnwjre1
//
// Purpose:		Create a debtor invoice line type

vars
	pxyDebtorInvLineType : CM_DebtorInvLineType;
	newDebtorInvLineType : CM_DebtorInvLineType;
begin
	create pxyDebtorInvLineType transient;
	
	pxyDebtorInvLineType.setProxy(_debtor,
								  _invLineType,
								  _otherCode);
	
	app.myTrxCA.trxCreateDebtorInvLineType(pxyDebtorInvLineType, newDebtorInvLineType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return newDebtorInvLineType;
epilog
	delete pxyDebtorInvLineType;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_otherCode" type="String"/>
        <ReturnType type="CM_DebtorInvLineType"/>
    </JadeMethod>
    <JadeMethod name="createDefinedText" id="3e60df4d-741e-425c-9dc7-cece4c9ec7af">
        <source>createDefinedText(context , sortOrder: Integer; text : String ;isnot: Boolean;_dt:CM_DefinedText io);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 October 2022	navvt20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	pxyDT,
	dt,
	dtOld  : CM_DefinedText;
begin
	foreach dt in self.getTerminal().allTerminalDefinedText do
		if dt.context = context and dt.sortOrder = sortOrder and dt.isNotAvailableForEntry = isnot then
			self.deleteDefinedText(_dt);
			break;
		endif;
	endforeach;
	
	create pxyDT transient;
	pxyDT.setProxy(context,sortOrder,isnot,text,self.getTerminal);
	
	app.myTrxCA.trxCreateDefinedText(pxyDT, dt, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	_dt := dt;
epilog
	delete pxyDT;
end;</source>
        <Parameter name="context" type="Integer"/>
        <Parameter name="sortOrder" type="Integer"/>
        <Parameter name="text" type="String"/>
        <Parameter name="isnot" type="Boolean"/>
        <Parameter name="_dt" type="CM_DefinedText" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createDelay" id="b7355a79-419f-41bc-8cf0-8b15476e644c">
        <source>createDelay(_startTS : TimeStamp; _machine : CM_Machine) : CM_Delay;
/*

Purpose:			
	

Date		Who		Reason
19/02/2014	cnwma1	Initial creation

*/

vars
	delayProxy 		: CM_Delay;
	delay, realDelay 			: CM_Delay;
	voy 			: CM_Voyage;
	delayType 		: CM_DelayType;
	startDT, 
	estEndDT, 
	endDT		    : TimeStamp;
	kpiShift 		: CM_KPI ;
	time 			: Time;
	//machine			: CM_Machine;

begin

	self.deleteDelay(_startTS, _machine);

	delayType := app.myRoot.allDelayTypes.first;
	self.assertTrueMsg((delayType &lt;&gt; null), "No delay types are setup!");
	voy := self.opts.obj("Voyage").CM_Voyage;
	self.assertNotNull(voy);
	
	endDT := _startTS;
	///endDT.setTime(endDT.time + (5*60000));			// Plus 5 mintue
	endDT := endDT.addMinutes(5);
	estEndDT := endDT;

	create delayProxy transient;
	delayProxy.setProxy(voy.myTerminal,
					voy,
					delayType,
					_startTS,
					estEndDT,
					endDT,
					_machine,
					app.getMyUser(),
					null,
					"Test Create");
	app.myTrxCA.trxCreateDelay(delayProxy, realDelay, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach delay in _machine.allDelays do	
		if delay.startDT = _startTS then
			break;
		endif;
	endforeach;
	
	return delay;	
	
epilog
	
	delete delayProxy;

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="createDetailedCargoTransaction" id="e6759710-959e-45ae-add8-af194643d2bd">
        <source>createDetailedCargoTransaction(_realTI : CM_TrackedItem input; _transParams: CMIF_TITransactionController input) : CM_TITransaction;
// pass in the CMIF_TITransactionController to get control of all transaction attributes
vars
	transObj : CM_TITransaction;
begin
	
	beginTransaction;
	transObj := _realTI.createTransaction(_transParams, app.myPassport);
	commitTransaction;

	return transObj;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transParams" type="CMIF_TITransactionController" usage="input"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createDischJobsForRORO" id="209d31ad-6937-43f2-9a15-63e66467d57c">
        <source>createDischJobsForRORO(voyage: CM_Voyage; _deck: CM_DeckVoyage; wpA, wpB: CM_WorkPoint);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	i, jobCount, ccSize: Integer;
	theJobParams : CMIF_VoyageJobParams;
	realVJob : CM_VoyageJob;
	job : CM_Job;
	iter : Iterator;
	slotController 	: CM_ROROSlotController;
	request : CM_ROROSlotRequest;
begin
	//create 8 jobs 
	i:= 1;
	ccSize:=(_deck.allROROSlotControllers.size/8).roundedUp;
	

	iter:=_deck.allROROSlotControllers.createIterator;
	create theJobParams transient;
	theJobParams.useNewMethod := true;
	theJobParams.isDischarge		:=	true;
	theJobParams.jobNumLinkedLoad	:=	null;
	theJobParams.myDeck				:= _deck;
	theJobParams.myVoyage			:=	voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		
	theJobParams.isSeqForJob		:=	false;
	
	while iter.next(slotController) do
		// get the discharge request
		request:= slotController.myRORORequestDischarge.CM_ROROSlotRequest;
		if request = null then
			continue;
		endif;
		// if this is a background request continue;
		if  request.isBackEndRequest() then
			continue;
		endif;
		
		if request.isSOB then
			continue;
		endif;
		
		if request.isRehandle then
			continue;
		endif;
		theJobParams.allROROControllers.add(slotController);
		theJobParams.allObjectEditions.add(slotController);
		
		if i = ccSize or slotController = _deck.allROROSlotControllers.last then
			if jobCount &gt; 4 then
				theJobParams.myWorkPoint		:= wpB;
				theJobParams.craneID:=wpB.code;	
			else
				theJobParams.myWorkPoint		:= wpA;
				theJobParams.craneID:=wpA.code;	
			endif;
			
			self.ignoreTrxWarnings(true);
			realVJob:=null;
			app.myTrxCA.trxCreateVoyageJob(theJobParams, realVJob, app.myPassport);	
			self.assertNoTrxErrorsOrWarnings();
			jobCount:=jobCount + 1;
			i:=0;
			
			delete theJobParams.myProxyJob;
			delete theJobParams;
			create theJobParams transient;
			theJobParams.useNewMethod := true;
			theJobParams.isDischarge		:=	true;
			theJobParams.jobNumLinkedLoad	:=	null;
			theJobParams.myDeck				:= _deck;
			theJobParams.myVoyage			:=	voyage;
			theJobParams.myProxyJob			:=	null;
			theJobParams.resquence			:=	true;		
			theJobParams.isSeqForJob		:=	false;		
		endif;
		
		i:=i+1;
	endwhile;
		
epilog
	delete iter;
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
		delete theJobParams;
	endif;
end;</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="wpA" type="CM_WorkPoint"/>
        <Parameter name="wpB" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="createDriverDetails" id="925e4002-c422-445f-9521-ce2858615a71">
        <source>createDriverDetails(_driverCode : String; _allCarriers : CM_CarrierByCodeDict; _allVehicleMachines : CM_VehicleSet) : CM_DriverDetails;

/*

Purpose:		Create Driver Details

Date			Who		Reason
04/10/2011		cnwmh5	Initial creation
18/10/2019		jlgdap1	TFS 46854 SNO Driver Identity Checking for Cargo Release
11/05/2023		navdap1	TFS 56801 EUP - EDI Message Type - Transport Status Message Processing
*/

vars
	pxyDriverDetails	 : CM_DriverDetails;
	newDriverDetails : CM_DriverDetails;
	driverName : String;		// TFS 56801
begin
	
	self.deleteDriverDetails(_driverCode);
	
	// TFS 56801 start
	driverName := _driverCode;
	if self.opts.includesKey("DriverName") then
		driverName := self.opts.str("DriverName");
	endif;
	// TFS 56801 end
	
	create pxyDriverDetails transient;
	
	//pxyDriverDetails.setProxy(_driverCode, _driverCode, null, CM_DriverDetails.Status_Allowed, self.getTerminal(), _allCarriers, _allVehicleMachines);		// TFS 46854
	//pxyDriverDetails.setProxy(_driverCode, _driverCode, null, CM_DriverDetails.Status_Allowed, null, self.getTerminal(), _allCarriers, _allVehicleMachines);	// TFS 46854
	pxyDriverDetails.setProxy(driverName, _driverCode, null, CM_DriverDetails.Status_Allowed, null, self.getTerminal(), _allCarriers, _allVehicleMachines);		// TFS 56801
	
	app.myTrxCA.trxCreateDriverDetails(pxyDriverDetails, newDriverDetails, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return newDriverDetails;
epilog
	delete pxyDriverDetails;
end;</source>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_allCarriers" type="CM_CarrierByCodeDict"/>
        <Parameter name="_allVehicleMachines" type="CM_VehicleSet"/>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="createEDIXlation" id="66a658ba-165c-4d07-aefa-8f412346acd5">
        <source>createEDIXlation(_foreignCode, _systemCode : String; _xlationType : Integer; _systemDefault :Boolean; _operator : CM_Operator; _cargoType : CM_CargoBOLType; _criteria :ParamListType) : Boolean;
// cnwrs1 2 july 2009
// create any type of EDI Xlation

// par 31259 - will create or maintain xlations
//19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
vars
	xlationIn, pxyXlationIn 		: CM_Xlation_In;
	xlationOut, pxyXlationOut		: CM_Xlation_Out;
	result 							: Boolean;
	xlationTable, pxyXlationTable  	: CM_XlationTable;
	pxyXlationCriteria				: CM_XlationCriteria;
	opTerm, pxyOpTerm 				: CM_OperatorTerminal;
	tempFrom, tempTo				: Real;
	text							: String;
	isImport : Boolean;
begin
	// first we need a proxy for the xlationTable
	if _xlationType = XLATION_TYPE_OPERATOR or
	   _xlationType = XLATION_TYPE_CUSTOMSAGENT or
	   _xlationType = XLATION_TYPE_SHIPPINGLINE or
	   _xlationType = XLATION_TYPE_VESSEL then
		
		xlationTable := app.myRoot.allXlationTables[_xlationType, null, null, null];
		
		if xlationTable = null then
			// new one
			create pxyXlationTable transient;
			pxyXlationTable.setProxy (_xlationType, app.myRoot, null, null, null,null);
		endif;
	elseif _xlationType = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		xlationTable := _operator.allXlationTables [_xlationType, _cargoType];
		
		if xlationTable = null then
			// new one
			create pxyXlationTable transient;
			pxyXlationTable.setProxy (_xlationType, null, _operator, null, _cargoType,null);
			pxyXlationTable.validateForCreate();
		endif;
	elseif _xlationType = XLATION_TYPE_VOYAGETERMINAL or _xlationType = XLATION_TYPE_INSTRUCTTERMINAL then 
		opTerm := self.getTerminal.allOperatorTerminals[_operator];
		
		if opTerm &lt;&gt; null then
			xlationTable := app.myRoot.allXlationTables[_xlationType, null, opTerm, null];
		endif;
		
		if xlationTable = null then
			// new one
			create pxyXlationTable transient;
			
			if opTerm &lt;&gt; null then
				pxyXlationTable.setProxy(_xlationType, null, null, opTerm, null,null);
			else
				create pxyOpTerm transient;
				pxyOpTerm.setMyOperator(_operator);
				pxyOpTerm.setMyTerminal(self.getTerminal);
				
				pxyXlationTable.setProxy(_xlationType, null, null, pxyOpTerm, null,null);
			endif;
		endif;

	else
		xlationTable := _operator.allXlationTables [_xlationType, null];
		
		if xlationTable = null then
			// new one
			create pxyXlationTable transient;
			pxyXlationTable.setProxy(_xlationType, null, _operator, null, null,null);
		endif;
	endif;
	
	if xlationTable &lt;&gt; null then
		beginLoad;
		pxyXlationTable := xlationTable.pxyCreateUpdateProxy;
		endLoad;
	endif;

	create pxyXlationIn transient;

	pxyXlationIn.setProxy(_systemCode, _foreignCode, pxyXlationTable);
	
	if pxyXlationIn.canHaveCriteria then
		if _xlationType = XLATION_TYPE_COMMODITY_BYOP and app.getParamListTypeLength (_criteria) = 2 then
			tempFrom := app.getParamListTypeEntry (1, _criteria).Real;
			tempTo := app.getParamListTypeEntry (2, _criteria).Real;
			
			if tempFrom &lt;&gt; NULL_TEMPERATURE and tempTo &lt;&gt; NULL_TEMPERATURE then				
				create pxyXlationCriteria as CM_XlCriteria_Commodity transient;
				
			
				pxyXlationCriteria.CM_XlCriteria_Commodity.setProxy (tempFrom, tempTo);
																	
				pxyXlationCriteria.setMyXlation (pxyXlationIn);
			endif;
		elseif _xlationType = XLATION_TYPE_MTGRADE_BYOP and app.getParamListTypeLength (_criteria) = 3 then
			tempFrom := app.getParamListTypeEntry (1, _criteria).Real;
			tempTo := app.getParamListTypeEntry (2, _criteria).Real;
			text := app.getParamListTypeEntry (3, _criteria).String;
			
			if 	(tempFrom &lt;&gt; NULL_TEMPERATURE and tempTo &lt;&gt; NULL_TEMPERATURE) or text &lt;&gt; null then
				if pxyXlationCriteria = null then
					create pxyXlationCriteria as CM_XlCriteria_MTGrade transient;
				endif;
				
				pxyXlationCriteria.CM_XlCriteria_MTGrade.setProxy (tempFrom, tempTo, text);
																	
				pxyXlationCriteria.setMyXlation (pxyXlationIn);
			endif;
		elseif _xlationType = XLATION_TYPE_VOYAGETERMINAL and app.getParamListTypeLength(_criteria) = 1 then		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			isImport := app.getParamListTypeEntry(1, _criteria).Boolean;
			if isImport then
				create pxyXlationCriteria as CM_XlCriteria_Import transient;
				pxyXlationCriteria.CM_XlCriteria_Import.setProxy(isImport);																
				pxyXlationCriteria.setMyXlation(pxyXlationIn);
			endif;
		endif;
	endif;
	
	// we may also need to create a proxy for the outward xlation
	if _systemDefault then
		// we are going to update the outward translation
		if xlationTable &lt;&gt; null then	
			xlationOut := xlationTable.allOutwardTranslations[_systemCode];
		endif;
		
		if xlationOut &lt;&gt; null then
			beginLoad;
			pxyXlationOut := xlationOut.pxyCreateUpdateProxy;
			endLoad;
			
		else
			create pxyXlationOut transient; 
		endif;
	
		pxyXlationOut.setProxy(_systemCode, _foreignCode, pxyXlationTable);
	endif;

	app.myTrxUA.trxUpdateXlation(pxyXlationTable, app.myPassport);
		
	// we don't expect errors
	self.assertNoTrxErrorsOrWarnings;
	
	result := true;
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	delete pxyXlationTable;
	delete pxyOpTerm;
	return result;
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_xlationType" type="Integer"/>
        <Parameter name="_systemDefault" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_criteria" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
