    <JadeMethod name="translateForm" id="8bdbff8e-11f4-4c70-b34b-188877f84303">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 October 2024 12:30:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006991, locale);
//	btnCheck.translateBubbleHelp(Xlat_0009641, locale);
//	btnCheck.translateCaption(Xlat_0009642, locale);
	btnExtDefAll.translateBubbleHelp(Xlat_0003806, locale);
	btnExtDefAll.translateCaption(Xlat_0003809, locale);
	btnExtDefChg.translateBubbleHelp(Xlat_0003807, locale);
	btnExtDefChg.translateCaption(Xlat_0003810, locale);
	btnExtract.translateCaption(Xlat_0003811, locale);
	btnExtractUpTo.translateCaption(Xlat_0003812, locale);
	btnSelector.translateCaption(Xlat_0003813, locale);
	btnViewChgTrkMon.translateBubbleHelp(Xlat_0003808, locale);
	btnViewChgTrkMon.translateCaption(Xlat_0003814, locale);
	chkExtractAllBGP.translateCaption(Xlat_0026994, locale);
	lblDateFrom.translateCaption(Xlat_0003815, locale);
	lblDateTo.translateCaption(Xlat_0003816, locale);
	lblExtObjClass.translateCaption(Xlat_0003817, locale);
	lblExtrUpTo.translateCaption(Xlat_0003818, locale);
	lblExtractClass.translateCaption(Xlat_0003819, locale);
	mnuAddJadeSQLMapping.translateCaption(Xlat_0014913, locale);
	mnuClassContext.translateCaption(Xlat_0006992, locale);
	mnuDelJadeSQLMapping.translateCaption(Xlat_0014914, locale);
	mnuDumpJadeSource.translateCaption(Xlat_0014915, locale);
	mnuDumpSQLTableDef.translateCaption(Xlat_0014916, locale);
	mnuDumpStoredProc.translateCaption(Xlat_0014917, locale);
	mnuEditJadeSQLMapping.translateCaption(Xlat_0014918, locale);
	mnuExtractBulkDataLoad.translateCaption(Xlat_0014919, locale);
	mnuExtractClassAll.translateCaption(Xlat_0006993, locale);
	mnuExtractClassChanged.translateCaption(Xlat_0006994, locale);
	mnuExtractClassSQL.translateCaption(Xlat_0006995, locale);
	mnuHistDisplayContext.translateCaption(Xlat_0006996, locale);
	mnuHistExtract.translateCaption(Xlat_0006997, locale);
	mnuSQLNativeCopyDef.translateCaption(Xlat_0014920, locale);
	mnuSQLNativeDefContext.translateCaption(Xlat_0014921, locale);
	mnuSQLNativeExportDef.translateCaption(Xlat_0014922, locale);
	mnuSQLNativeLoadDef.translateCaption(Xlat_0014923, locale);
	shtExtFeature.translateCaption(Xlat_0003820, locale);
	shtExtractClass.translateCaption(Xlat_0003821, locale);
	shtExtractDef.translateCaption(Xlat_0003822, locale);
	shtExtractHist.translateCaption(Xlat_0003823, locale);
	shtExtractObject.translateCaption(Xlat_0003824, locale);
end;</source>
