    </JadeMethod>
    <JadeMethod name="getNumberOfBlocksMovement" id="6354cdf5-41fc-4e66-9dea-dfb20b0898ba">
        <source>getNumberOfBlocksMovement(_diffMin : Integer; _hourBlock : Decimal; _wharf : HMS_Wharf; _firstResource : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		09 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	numHourBlocks : Integer;
	theCalcType : CM_CalculationType;
begin
	foreach theCalcType in app.myRoot.allCalculationTypesByCode discreteLock do
		if (theCalcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or theCalcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE)
		and theCalcType.hoursBlock = _hourBlock then

			numHourBlocks := theCalcType.getNumHourBlocks(_diffMin,true, _wharf);
			break;
		endif;
	endforeach;
	// 36605 the second resource (after the first 24 hours) can be zero if the total time at the wharf is less than 24 hours
	//   then we don't want to create a second resource usage for it so pass back zero
	if numHourBlocks &lt; 1 then
		if _firstResource then
			numHourBlocks := 1;
		else
			numHourBlocks := 0;
		endif;
	endif;

	return numHourBlocks;
end;</source>
        <Parameter name="_diffMin" type="Integer"/>
        <Parameter name="_hourBlock" type="Decimal"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <Parameter name="_firstResource" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfBlocksVisit" id="72bd71ff-5977-4427-874a-dc308b779438">
        <source>getNumberOfBlocksVisit(_hourBlock : Decimal; _diffMin : Integer io; _firstBlkMin : Integer io; _useFreeHours : Boolean; _firstHourBlock : Decimal; _resource : HMS_Resource) : Integer;
// ---------------------------------------------------------------------------
// Created:		09 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 31/07/2013	cnwdap1		PAR #31364 Use hourBlock type as input to getNumHourBlocks first time
//							Don't reset use3Hours unles we've used up all 24 hours of our free time
// ---------------------------------------------------------------------------
vars
	aVM,thePrevMove : HMS_VoyageMovement;
	tmpWharf : HMS_Wharf;
	aRes : HMS_Resource;
	totalNonChargeMinutes, diffMin, totDiffMin, firstBlockMinutes, tmpDiff : Integer;
	numHourBlocks : Integer;
	theCalcType : CM_CalculationType;
	stTS, endTS : TimeStamp;
	use3Hours, chargeableShift, ch24, isFirstBlock : Boolean;
	hmsBerthBlock1, firstBlockInHours : Integer;									// PAR #31364
//	twentyFourHours : Integer;									// PAR #31364
begin

	numHourBlocks := 0;
	use3Hours := true;
//	twentyFourHours := ((24 * MillisecondsPerHour) / MillisecondsPerMinute).Integer;	// PAR #31364
	firstBlockInHours := ((_firstHourBlock * MillisecondsPerHour) / MillisecondsPerMinute).Integer;	// PAR 35469

	// ### OUTER LOOP
	foreach aVM in self.allVoyageMovements do : outerLoop
		if aVM.moveType = HMSMovementTypeArrival then
			continue;
		endif;

		thePrevMove := aVM.getVoyageMovementPrevious(); 
		if thePrevMove &lt;&gt; null then
			tmpWharf := thePrevMove.getMyWharf();
			aRes := tmpWharf.getResourceForHarbourMovement(HMSMovementTypeShift,HMS_Wharf.First_Resource);
			
			if aRes = null then // not chargeable
				if diffMin &gt; 0 then
					firstBlockMinutes := diffMin;
					// ### INNER LOOP
					foreach theCalcType in app.myRoot.allCalculationTypesByCode discreteLock do : innerLoop
						if (theCalcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or theCalcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE)
						and theCalcType.hoursBlock = _hourBlock then
							if not ch24 then
// PAR 35469								numHourBlocks := numHourBlocks + theCalcType.getNumHourBlocks(diffMin,_hourBlock=HMSBerthBlock2, tmpWharf); // PAR 12319	// PAR #31364
								numHourBlocks := numHourBlocks + theCalcType.getNumHourBlocks(diffMin,_useFreeHours, tmpWharf); // PAR 35469
							endif;
							// PAR 25469 if diffMin &gt; twentyFourHours then	
							if diffMin &gt; firstBlockInHours then	// PAR 35469
							
							
							// PAR #31364												
								use3Hours := false; // only use the free hours once
							endif;																															// PAR #31364
							if theCalcType.hoursBlock = theCalcType.hoursMax then // this is so that it does not double dip. This happens to be 24 = 24
								ch24 := true;
								break innerLoop;   // PAR 13066 was outerLoop;
							else
								break innerLoop;
							endif;
						endif;
					endforeach;
					if numHourBlocks &lt; 0 then
						numHourBlocks := 0;
					endif;
				endif;

				diffMin := 0;
				continue outerLoop;
			endif;
			stTS := thePrevMove.occursOnDT;
			endTS := aVM.occursOnDT;
			
			tmpDiff := (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer; 
			diffMin := diffMin + (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer; 
			totDiffMin := totDiffMin + (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer;  // PAR 13066
		endif;
	endforeach;

	if firstBlockMinutes = 0 then
		firstBlockMinutes := totDiffMin;
	endif;
	if not ch24 and diffMin &gt; 0 then // for 6 hour blocks only
		if tmpWharf = null then
			tmpWharf := self.getMyBerth.myWharf;
		endif;
		
		// ### USE CONFIGURED CALC TYPE
		if _resource &lt;&gt; null and _resource.myCalculationTypeQuantity &lt;&gt; null then // PAR 35940 842 ONLY
			theCalcType := _resource.myCalculationTypeQuantity;
			if theCalcType &lt;&gt; null and theCalcType.isTimeBlockHours() then
				numHourBlocks := numHourBlocks + theCalcType.getNumHourBlocks(diffMin,use3Hours, tmpWharf); // PAR 35940 842 ONLY
			endif;
		// ### USE TRANSACTION MAP CALC TYPE
		elseif _resource &lt;&gt; null then // PAR 35940 842 ONLY
			theCalcType := _resource.getMappedInvoiceCalcType(self.myVoyage,false); // PAR 35469
			if theCalcType &lt;&gt; null and theCalcType.isTimeBlockHours() then
				numHourBlocks := numHourBlocks + theCalcType.getNumHourBlocks(diffMin,use3Hours, tmpWharf); // PAR 35940 842 ONLY
			endif;
		// ### USE GENERAL SYSTEM SEARCH REMOVED in 842
		/* PAR 35940
		else
			foreach theCalcType in app.myRoot.allCalculationTypesByCode discreteLock do : innerLoop
				if theCalcType.isTimeBlockHours() // PAR 35940
				and theCalcType.hoursBlock = _hourBlock then
					numHourBlocks := numHourBlocks + theCalcType.getNumHourBlocks(diffMin,use3Hours, tmpWharf);  // PAR 12319
					break innerLoop;
				endif;
			endforeach;
			*/
		endif;
		// 36605 the second resource (after the first 24 hours) can be zero if the total time at the wharf is less than 24 hours
		//   then we don't want to create a second resource usage for it so pass back zero
		if numHourBlocks &lt; 1 then
			if _useFreeHours then		// second resource
				numHourBlocks := 0;
			else
				numHourBlocks := 1;
			endif;
		endif;
	endif;

	// 36605 the second resource (after the first 24 hours) can be zero if the total time at the wharf is less than 24 hours
	//   then we don't want to create a second resource usage for it so pass back zero
	if numHourBlocks &lt; 1 then
		if _useFreeHours then		// second resource
			numHourBlocks := 0;
		else
			numHourBlocks := 1;
		endif;
	endif;

	_diffMin := totDiffMin;  // PAR 13066
	_firstBlkMin := firstBlockMinutes;  // PAR 13486
	return numHourBlocks;
end;</source>
        <Parameter name="_hourBlock" type="Decimal"/>
        <Parameter name="_diffMin" type="Integer" usage="io"/>
        <Parameter name="_firstBlkMin" type="Integer" usage="io"/>
        <Parameter name="_useFreeHours" type="Boolean"/>
        <Parameter name="_firstHourBlock" type="Decimal"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPilotsUsed" id="bc5eb38c-137c-4e78-b08e-83dd98774786">
        <source>getPilotsUsed() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement 

vars
	pilotsUsed : String;
	movement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
begin

	foreach movement in self.allVoyageMovements do
		// Check to see if selected pilot is used for any of the voyages movements
	/*	if movement.myPilot &lt;&gt; null then
			pilotsUsed	:= pilotsUsed &amp; movement.myPilot.description[1:20] &amp; "; ";
		else
			pilotsUsed := pilotsUsed &amp; "N/A; ";
		endif; */
		//31 Oct 2018	NDL	TFS 41662
		if not movement.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
			foreach movementPilotDetails in movement.allMovementPilotDetails do //pilot in movement.allPilots do // TFS 44438
				pilotsUsed	:= pilotsUsed &amp; movementPilotDetails.myPilot.description[1:20] &amp; "; "; //pilot.description[1:20] &amp; "; "; // TFS 44438
			endforeach;
		elseif movement.getUnConvertedMyPilotRef &lt;&gt; null then
			pilotsUsed	:= pilotsUsed &amp; movement.getUnConvertedMyPilotRef.description[1:20] &amp; "; ";
		else
			pilotsUsed := pilotsUsed &amp; "N/A; ";
		endif; 
		
	endforeach;
		
	if pilotsUsed.length &gt; 1 then
		// Trim last comma and space
	 	pilotsUsed := pilotsUsed[1:(pilotsUsed.length - 2)];
	endif;
	
	return pilotsUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="6aeff3a6-7ed7-4dee-a935-a6ad54a33aaa">
        <source>getRemarks() : String;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
