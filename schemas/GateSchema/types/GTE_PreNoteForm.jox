    <JadeMethod name="userNotify" id="8832c01f-f1c3-4342-8d16-04cd1f0df380">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     01 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termEvent	: Integer;

begin

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;

	if termEvent = TIEvent_PreNote_Add then
		self.zTblDataSysNotifyCreate(Object_Create_Event, theObject, eventTag);
	elseif termEvent = TIEvent_PreNote_Update then
		self.zTblDataSysNotifyUpdate(Object_Update_Event, theObject, eventTag);
	elseif termEvent = TIEvent_PreNote_Delete then
		self.zTblDataSysNotifyDelete(Object_Delete_Event, theObject, eventTag);
	elseif termEvent = TIEvent_Terminal_Receival then
		// treat as a delete because it has been removed from the collection for pre-notes
		self.zTblDataSysNotifyDelete(Object_Delete_Event, theObject, eventTag);
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="e979c6c3-1b1e-4386-9ed7-f2befb053c90">
        <updating/>
        <source>zDoAdd() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwdap1	Initial creation

*/

vars

begin
	//+cnwml2 PAR23230
	//when the user attempts to add an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;


	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	
	if self.isEnhanced then
		self.myAssistant.showCargoReceiptFromPreNote(	self, true, 3, 160, null, null, false, self.cmbTransportMode.text	);
	else
		inheritMethod();
	endif;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="947f7934-6d70-44b7-b875-5aa608d04a3f">
        <updating/>
        <source>zDoEdit() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2009	cnwdap1	Initial creation
03/02/2010	cnwmh5	PAR 18936 - On Edit 'Transport Mode' should not be enabled.
*/
vars

begin
	//+cnwml2 PAR23230
	//when the user attempts to edit an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;

	if (self.allowUpdate = false) or
	   (self.mode &lt;&gt; Mode_View) then 
		//Must not be already editing an object
		return;
	endif;
	
	//25 Oct 2012	NDL	Par 30465	- Don't use enhanced form for editing, just creation....
	//cnwmc5 - 18/01/2013 - PAR #31026
	self.editPreNote(self.tblData);

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyDelete" id="684684a7-064c-4da4-b285-346e1cba2cae">
        <updating/>
        <source>zTblDataSysNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
begin

	if theObject &lt;&gt; null then
		tmpTI := theObject.CM_TrackedItem;
		if self.allAddedPreNotes.includes(tmpTI) then
			self.allAddedPreNotes.remove(tmpTI);
		endif;
	endif;

	inheritMethod(eventType, theObject, eventTag);

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
