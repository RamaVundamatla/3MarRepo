    <JadeMethod name="setForUpdate" id="06d39161-7535-4fda-b049-65114d296f59">
        <updating/>
        <source>setForUpdate(_proxy: CM_StopCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

	realstop : CM_StopsTable;
	edition : Integer;

begin
	if self.myStopTable = null then
		if not self.isTransient then
			if _proxy.myStopTable &lt;&gt; null and _proxy.myStopTable.isTransient then
				realstop := _proxy.myStopTable.pxyGetRealObject();
			endif;
			if realstop = null then
				if not _proxy.myStopTable.isTransient then
					realstop := _proxy.myStopTable;
				endif;
			endif;
			self.myStopTable := realstop;
		else
			self.myStopTable := _proxy.myStopTable;
		endif;
	endif;
	
	inheritMethod(_proxy);

epilog
	//delete realstop;
end;</source>
        <Parameter name="_proxy" type="CM_StopCriteria"/>
    </JadeMethod>
