    <JadeMethod name="jssIsNotAvailable" id="e140c161-789e-47aa-94db-7b78e72f8ab2">
        <source>jssIsNotAvailable():Boolean;
// --------------------------------------------------------------------------------
// Created:		18 February 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver's filename
//				is not available on disk.  This method is the opposite of the
//				native "isAvailable" method.
//
// Parameters:	None
//
// Returns:		True if the filename is not available, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isAvailable());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
