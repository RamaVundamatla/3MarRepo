    <JadeMethod name="delete" id="b77d26e2-2037-407e-a584-feaec55bfb4c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwmc5	Initial creation

*/

vars

begin
	self.allTrackedItems.purge();
	self.allTrackedItemsReleased.purge();
	
	delete self.cargoType;
	delete self.isoGroup;
	delete self.isoType;
	delete self.product;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="7472b998-a0cf-4efe-9b40-b4daf37c4bb1">
        <updating/>
        <source>setProxyFromObject(_reserveSelection: CM_ReserveSelection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
07 Nov 2014	cnwmc5				Initial creation
28 JUl 2019	jlgka1 	TFS 45287	JMT Handheld Apps - Pack by Request - Pack Container Jade
16 Sep 2019	jlgka1 	TFS 46426	PEN - Truck Loader - search cargo with release request and consignee.
26/7/21		jlier1	52626		STW Release Staging 
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
============================================================================*/

vars
	ti						: CM_TrackedItem;
	wsTI					: WS_TrackedItem;
	invalidProduct 			: Boolean;
	productCode 			: String;
	measure					: CM_MeasurementType;
	allTis					: CM_TISet;
	reserveCType			: CM_CargoType;
	reserveIsoGroup			: CM_ISOTypeGroup;
	reserveIsoType			: CM_ISOType;
	reserveProduct			: CM_Product;
begin
	
	inheritMethod(_reserveSelection);
	
	create allTis transient; 							//23/06/2023	navkc1	CR 58406 Task 58408
	_reserveSelection.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	

	foreach ti in allTis discreteLock do 
		create wsTI transient;
		wsTI.setProxyFromObject(ti);
		self.allTrackedItems.add(wsTI);
	endforeach;
	
	foreach ti in _reserveSelection.allTrackedItemsReleased discreteLock do
		create wsTI transient;
		wsTI.setProxyFromObject(ti);
		self.allTrackedItemsReleased.add(wsTI);
	endforeach;
	
	reserveCType := _reserveSelection.myCargoType;
	if reserveCType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(reserveCType);
	endif;
	
	reserveIsoGroup := _reserveSelection.myISOGroup;
	if reserveIsoGroup &lt;&gt; null then
		create self.isoGroup transient;
		self.isoGroup.setProxyFromObject(reserveIsoGroup);
	endif;
	
	reserveIsoType := _reserveSelection.myISOType;
	if reserveIsoType &lt;&gt; null then
		create self.isoType transient;
		self.isoType.setProxyFromObject(reserveIsoType);
	endif;
	
	reserveProduct := _reserveSelection.myProduct;
	if reserveProduct &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,reserveProduct,invalidProduct);
		productCode	:= reserveProduct.code;
		if not invalidProduct then
		
			create self.product transient;
			self.product.setProxyFromObject(reserveProduct);
		endif;
	endif;
	
	self.clean 	   	    := _reserveSelection.clean;
	self.heavyDuty  	:= _reserveSelection.heavyRated;
	self.remarks 		:= _reserveSelection.remarks;
	self.totalRequested := _reserveSelection.totalRequested;
	self.colour 		:= _reserveSelection.colour;
	self.billOfLading 	:= _reserveSelection.getBOLNumber();
	self.mark 			:= _reserveSelection.markSelection;
	
	//cnwmc5 - 15 March 2015 - PAR 35864
	measure 		 := app.getDefaultMeasurementForType(Type_Volume);
	self.totalVolume := app.convertMeasurementForDisplay(measure.shortName, _reserveSelection.volumeSelection);
	measure 		 := app.getDefaultMeasurementForType(Type_Weight);
	self.totalWeight := app.convertMeasurementForDisplay(measure.shortName, _reserveSelection.weightRequested);
	
	
epilog
	delete allTis;
end;</source>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setProxyRoadReserveSummary" id="ff2aea6b-198e-408a-99e4-9c2829fd9ec0">
        <updating/>
        <source>setProxyRoadReserveSummary(reserveDetail : CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2025	navma1	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API

*/

vars

begin
	inheritMethod(reserveDetail);

epilog

end;</source>
        <Parameter name="reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
