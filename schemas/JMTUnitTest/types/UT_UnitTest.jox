    <JadeMethod name="runTest" id="5c3af16d-eb66-414c-a018-395a5ab67ce6">
        <updating/>
        <source>runTest(_testRun : UM_TestRun; _ignore : Boolean io; _test : Method; _firstTest: Boolean; _lastTest: Boolean) updating, protected;
//16 July 2008	cnwdw1	
//
vars

	blame : UM_Blame;
	logStr	: String;
	startTime	: TimeStamp;
	endTime		: TimeStamp;

begin
	on Exception do app.generalExceptionHandler(exception);
	on Exception do self.exHandlerTestFailure(exception);
	
	//cnwmc5 - 27 Sep 2012 - add this block to check if ignored first.
	if _test.name[1] = 'i' then
		if app.myUMTestRunONight &lt;&gt; null and app.overnightRun then
			///beginTransaction;
			///	app.myUMTestRunONight.updateIgnoreTotal();
			///commitTransaction;
			self.createUnitTestResult(_test, _testRun, true, null, null);					// 05/09/2013 cnwmh5
			_ignore := true;																// 16/11/2013 cnwmh5
			return;
		endif;
		//_ignore := true;
		//return;
	endif;
	

	startTime := app.actualTimeAppServer();
	
	self.initializeTest(_test);
	
	self.sendNote(_test, null);
	
	if (_firstTest &lt;&gt; _lastTest or (_firstTest = false and _lastTest = false ) )
			and self.checkForLeaks then
		if self.leakChecker &lt;&gt; null then
			delete self.leakChecker;
		endif;
		create self.leakChecker transient;
	endif;
	
	if self.methods or self.findBlame or (self.logResult and not app.isUnicode) then			// 29/06/2015 cnwmh5
		blame := self.startBlame( _test.name );
	endif;

	if _firstTest then
		self.unitTestBeforeClass();
		if self.isFailure() then
			return;
		endif;
	endif;

	self.unitTestBefore();
	if  self.isFailure() then
		return;
	endif;
	
	//cnwmc5 - 1/11/2012 - check to see if method has been compiled before running
	if _test.inError() then
		self.exceptionMessage := "4021 - Uncompiled exception.";
	else
		app.currentMethodBeingRun := _test.qualifiedName;
		self.sendMsg(_test.name);
		app.currentMethodBeingRun := null;
	endif;
	
	self.unitTestAfter( _test );
	
	if _lastTest then
		self.unitTestAfterClass();
		if self.isFailure() then
			return;
		endif;
	endif;
	
		
epilog

	app.currentMethodBeingRun := null;
	
	//endTime := app.actualTimeServer();
	endTime := app.actualTimeAppServer();
	app.writeLog(_test.getSchemaType().getName &amp; "::" &amp; _test.getName() &amp; Tab &amp; 'start: ' &amp; startTime.date.format("ddMMMyy") &amp; " " &amp;  
		startTime.time.format("HH:mm:ss") &amp; '.' &amp; startTime.time.milliSecond.stringWithLeadingZeros(3) &amp; 
		" end: " &amp; endTime.date.format("ddMMMyy") &amp; " " &amp;  endTime.time.format("HH:mm:ss") &amp; '.' &amp; 
		endTime.time.milliSecond.stringWithLeadingZeros(3) &amp; 
		' runTime: ' &amp; (endTime - startTime).String, LogINFO);
	
	self.finalizeTest(_testRun, _test, _ignore, blame);
	
end;</source>
        <access>protected</access>
        <Parameter name="_testRun" type="UM_TestRun"/>
        <Parameter name="_ignore" type="Boolean" usage="io"/>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_firstTest" type="Boolean"/>
        <Parameter name="_lastTest" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runTests" id="e8cdfa58-fd00-4ec3-bd72-4d9f81937f2f">
        <updating/>
        <source>runTests( _form : JUnitForm ) updating, protected;
//Date			Who		Reason
//17 July 2008	cnwdw1	
// 24/05/2011	cnwmh5	Change so that the order that they classes are run in is consistent with the way they are displayed and run from the form
// 28/11/2011	cnwmh5	Change so that if no form then copy all subclasses rather than always do this as in overnight it is incorrect as
//						at the point of running the unit tests it's already known what we are going to be running.
//30 April 2025	navpw1	JIRA: MTN-34212 - Added true to updateTesterAttributes so that results are by team not by user as default

vars
	allSubclasses: ClassColl;
	allMethods: MethodSet;
	meth: Method;
	subclass: Class;
	tester: UT_UnitTest;
	dynaDict : DynaDictionary;
	dynaObj : Object;
	testRun : UM_TestRun;
	logStr	: String;
	form	: JUnitForm;
	count	: Integer;
	obj		: Object;
	classToCheck	: Class;
	listBox		: ListBox;
	ignore			: Boolean;						// 28/09/2012 cnwmh5
	
begin

	if _form = null and self.logResult then
		beginTransaction;
		create testRun;
		commitTransaction;
	endif;
	
	ignore := false;								//  28/09/2012 cnwmh5
	
	// 24/05/2011 cnwmh5
	if self.class.name &lt;&gt; "UT_DSL" and self.class.name &lt;&gt; "UT_UnitTest" then
		classToCheck := self.class;
	endif;
		
	create allSubclasses transient;
	if _form &lt;&gt; null then							// 28/11/2011 cnwmh5
		self.class.allSubclasses(allSubclasses);
	endif;
	if not allSubclasses.includes(self.class) then
		allSubclasses.add(self.class);
	endif;
		
	foreach subclass in allSubclasses where not subclass.abstract do
		create tester as subclass transient;
		
		tester.updateTesterAttributes(self.checkForLeaks, self.logMessages, self.logResult, self.findBlame, self.methods, self.scheduleName, true);
		tester.setTesterProfile(self.testerProfile);
		create allMethods transient;
		subclass.allMethods(allMethods);
		foreach meth in allMethods do
			if not app.isUnitTestMethod(meth) then
				allMethods.remove(meth);
			endif;
		endforeach;
		
		if allMethods.size &gt; 0 then
			foreach meth in allMethods where meth.name[1] &lt;&gt; "t" do
				if meth.name[1] = 'i' and meth.name[2:1] = meth.name[2:1].toUpper() then
					self.createUnitTestResult(meth, testRun, true, null, _form = null);
				endif;
				allMethods.remove(meth);
			endforeach;
			
			create dynaDict transient;
			dynaDict.setMembership(Method);
			dynaDict.addMemberKey("name",false,true);
			dynaDict.endKeys(false);
			allMethods.copy(dynaDict);
			
			foreach dynaObj in dynaDict do
				meth := dynaObj.Method;
				tester.runTest(testRun, ignore, meth, meth = dynaDict.first, meth = dynaDict.last);
				if _form &lt;&gt; null and _form.doStop then
					break;
				endif;
			endforeach;	
			
			delete dynaDict;
			
			tester.saveTestResults(self.testResults);
		endif;
		delete tester;
		delete allMethods;
		if _form &lt;&gt; null and _form.doStop then
			break;
		endif;
	endforeach;	
epilog
	delete allMethods;
	delete allSubclasses;
	delete tester;
	delete dynaDict;
	delete form;
end;

</source>
        <access>protected</access>
        <Parameter name="_form" type="JUnitForm"/>
    </JadeMethod>
    <JadeMethod name="saveTestResults" id="48645413-80d4-4105-85c1-d74612f20ea3">
        <source>saveTestResults(_testResults: UT_TestResultsByName io);
//25 April 2009	cnwdw1	
//
vars

begin
	self.testResults.copy(_testResults);
	self.testResults.clear();
	if self.allTerminalsUsed &lt;&gt; null then
		self.allTerminalsUsed.clear();
	endif;
end;</source>
        <Parameter name="_testResults" type="UT_TestResultsByName" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sendNote" id="258be808-3f74-431f-a38e-39ac1aeb5fd8">
        <source>sendNote(_meth: Method; _testResult: UT_TestResult) protected;
//18 December 2008	cnwdw1	
//
vars
	int : Integer;
	form : JUnitForm;
begin
	// If running from the form, then don't send notes, just update the form directly inline
	if app.startupForm &lt;&gt; null and app.startupForm.isKindOf(JUnitForm) then
		form := app.startupForm.JUnitForm;
		form.userNotify(TestCompleted_Event, _meth, 9999, _testResult);
	else
		_meth.causeEvent(TestCompleted_Event, true, _testResult);
		if _testResult &lt;&gt; null then
			if  _testResult.hasPassed then
				int := 2;
			else
				int := 1;
			endif;
			_meth.causeEvent(TestCompleted_Event, true, int);
		endif;
	endif;
	app.doWindowEvents(10);
end;</source>
        <access>protected</access>
        <Parameter name="_meth" type="Method"/>
        <Parameter name="_testResult" type="UT_TestResult"/>
    </JadeMethod>
    <JadeMethod name="setActiveProfile" id="1714a234-105f-4a59-b453-9b171012518a">
        <updating/>
        <source>setActiveProfile() updating, protected;
//23 October 2008	cnwdw1	
//
begin
	self.testProfile := self.getTestProfile();
	if self.testProfile &lt;&gt; null then
		self.activeProfile := self.testProfile;
	elseif self.testerProfile &lt;&gt; null then
		self.activeProfile := self.testerProfile;
	else
		self.testProfile := self.getDefaultProfile();
		if self.testProfile &lt;&gt; null then
			self.activeProfile := self.testProfile;
		endif;
	endif;
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString]);
	app.myPassport.setMyUserFromCode(self.getProfileSetting(UT_Profile.P_USER).asString);
//	app.setSpecial('31/12/3000'.TimeStamp);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTesterProfile" id="dd26ce45-1767-489d-933d-dfde16e7e280">
        <updating/>
        <source>setTesterProfile(_profile: UT_Profile) updating;
//05 April 2009	cnwdw1	
//
vars

begin
	testerProfile := _profile;
end;</source>
        <Parameter name="_profile" type="UT_Profile"/>
    </JadeMethod>
