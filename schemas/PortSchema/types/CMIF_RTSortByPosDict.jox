<CollClass name="CMIF_RTSortByPosDict" id="12cb5fa9-a551-4226-9552-3a4fe6bc1f38">
    <duplicatesAllowed/>
    <memberType name="CMIF_RTSort"/>
    <superclass name="CMIF_Dicts"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CMIF_RTSort::position"/>
        <descending/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_RTSort::myTi"/>
    </MemberKey>
    <JadeMethod name="addTi" id="9ffa1ee0-8e90-40fc-849a-c8d2557ce8b1">
        <lockReceiver/>
        <updating/>
        <source>addTi(_pos : Integer; _ti : CM_TrackedItem) updating;

// cnwdvb1 21 July 2003 

vars

	tiSort	: CMIF_RTSort;

begin

	if self[_pos, _ti] = null then
		create tiSort transient;
		tiSort.position := _pos;
		tiSort.myTi 	:= _ti;
		self.add(tiSort);
	endif;
end;</source>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d5e75779-91ae-4404-95a3-9913141ce5a6">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;

// cnwdvb1 21 July 2003 

vars

begin

	self.purge();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="unLoadTis" id="e5c37b7e-3cef-417d-9dd4-004637e5f3be">
        <source>unLoadTis(_tiArray : CM_TIArray input);

// cnwdvb1 21 July 2003 

vars

	tiSort : CMIF_RTSort;

begin

	// Putting these tis in front of any others in tiArray.
	// Putting these tis in front of any others in tiArray.
	// Even though the task get resorted when they are added 
	// to the entry they need to be in the right order
	// here so the overstow auto logic finds the correct postion.
	foreach tiSort in self reversed do
		_tiArray.insert(1, tiSort.myTi);
	endforeach;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
</CollClass>
