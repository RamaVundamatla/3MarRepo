    <JadeMethod name="set" id="6266f518-294e-4d66-a235-a82129e8b33b">
        <updating/>
        <source>set(_code, _strString: String) updating;
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

