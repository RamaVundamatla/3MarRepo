    <JadeMethod name="doResizeControls" id="f48c4c06-3724-42e5-a017-e1f98f054871">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	left : Real;
	stdHeight : Real;
	stdWidth : Real;
	top : Real;
	width : Real;
	
	context : Integer;
	cargoCheck : CM_CargoCheck;
	formToDisplay : Class;

begin

	self.setResizeableMarginAndFontSize();
	left :=  self.resizedMargin;
	top :=  self.resizedMargin;
	stdWidth :=  self.clientWidth - (self.resizedMargin * 2);
	stdHeight := self.getStdControlHeight;
	
	self.txtCargoId.move(	left,
							top,
							stdWidth,
							stdHeight );
							
	self.txtContainerId.move(	left,
								top,
								stdWidth,
								stdHeight	);
							
	top := self.resizedMargin + self.txtCargoId.height + self.txtCargoId.top;
	self.lblCargoType.move(	left,
							top,
							stdWidth,
							stdHeight );
							
	top := top + self.lblCargoType.height + self.resizedMargin;
	self.lblCargoDesc.move( left,
							top,
							stdWidth,
							stdHeight ); 
							
	top := self.resizedMargin + self.txtContainerId.height + self.txtContainerId.top;
	self.cmbIsoType.move(	left,
							top,
							stdWidth,
							stdHeight	);
							
	
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		context := cargoCheck.context;
	endif;
	if self.myTerminal.hasNoCargoCheckItemsFor(context) then	//31 May 2012	NDL Par 29038
		self.tblCargoChecks.visible := false;
	else
		self.tblCargoChecks.visible := true;
		self.myHandHeldCheckerAgent.setupContextChecksTable(	self.tblCargoChecks,
															context,
															self,
															self.btnTick, self.btnCross, self.btnTickDown, self.btnCrossDown, self.btnButton,
															formToDisplay,
															null);
	endif;
	

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidation" id="2c15c4aa-f24b-4af5-9c9a-39c5b6f4f411">
        <source>doValidation() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2010	cnwdap1	Initial creation
// 10/12/2014  cnwdb2	PAR 35364

*/
vars
	idx			: Integer;
	checkItem	: CM_CargoCheckItem;

begin
	// validate table contents
	foreach idx in self.tblCargoChecks.fixedRows + 1 to self.tblCargoChecks.rows do
		checkItem := self.tblCargoChecks.accessRow(idx).itemObject.CM_CargoCheckItem;
		
		// check required fields
		if checkItem.required and not self.tblCargoChecks.accessCell(idx, self.tblCargoChecks.ColumnValue).selected and not self.tblCargoChecks.accessCell(idx, self.tblCargoChecks.ColumnValueExtra).selected then
			// no selection made for required item - error
		//	self.msgBox(app.getErrorString1(REQUIRED_FIELD, checkItem.name), app.getErrorString(Error35364), MsgBox_OK_Only, true);
			self.msgBox(app.getErrorString1(Input_required_field_Required, checkItem.name), app.getErrorString(Error35364), MsgBox_OK_Only, true); // cnwdb2	PAR 35364
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="272b86fe-6c9b-48b1-adfe-c00ae7b9d9b2">
        <source>getHelpDescr(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2010	cnwdap1	Initial creation
*/
vars

begin
	return self.HELP_DESCRIPTION;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="da0e416e-ca59-4493-9e19-019ba7c39952">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005
03 Oct 2017	jlgrh7 TFS5650 MSL - Ship Discharge Check - the system not put automatically the To do Task if the check is negative
*/
vars
	cargoId					: String;
	errMsg 					: String;
	lastForm				: Class;
	savedMyNextTiToAction	: CM_TrackedItem;
	
begin
	// validate the information in the table
	if not self.doValidation() then
		return;
	endif;

	savedMyNextTiToAction := self.myMobileGenericAgent.myNextTiToAction;	//PAR 23905 27/04/2010
	
	// Set up the next item - If we've come from the gate receival screen, 
	// the session agent has a collection of tracked items to confirm. 
	// If we've come from the ship lander discharge/load form, we only have one TI,
	// but we don;t want to clear the checker agent's myNextTiToAction because we use it elsewhere
	lastForm := self.getSessionAgent.allPreviousForms.last.Class;
	
	if lastForm = MOB_HHRailPlaceCargo then	//16 Aug 2010	NDL		Par 25215
		self.handleBtnTwo();
		return;
	endif;
	
	// get cargo/container id
	if CM_Container.hasInstance(self.myTrackedItem) then
		cargoId := self.txtContainerId.text.trimBlanks.toUpper;
	else
		cargoId := self.txtCargoId.text.trimBlanks.toUpper;
		cmbIsoType.listIndex := -1;	//26 Mar 2010	NDL	Par 23454
	endif;
	
	if lastForm = MOB_HHGateCheckAllCargo
	or lastForm = MOB_HHTruckUnloaderCargo
	or lastForm = MOB_HHUnpackContainerForm
	or lastForm = MOB_HHUnpackNewCargo
	or lastForm = MOB_HHPackContainerForm
	or lastForm = MOB_HHPackContainerFormSTW	//16 Apr 2018	NDL	TFS 38083
	or lastForm = MOB_HHBRLocLoaderCargo	//01 May 2015	NDL	Par 36084
	or lastForm = MOB_HHPackComplete	//08 Mar 2017	NDL	TFS 3635
	then
		if not self.myMobileGenericAgent.confirmsOK(cargoId, errMsg) then
			self.msgBox(errMsg ,app.getErrorString(Error), MsgBox_OK_Only, true);
			return;
		endif;
	endif;
	
	//if lastForm = MOB_HHGateCheckAllCargo or lastForm = MOB_HHTruckUnloaderCargo or lastForm = MOB_HHTruckLoaderCargo then
	if lastForm = MOB_HHGateCheckAllCargo
	or lastForm = MOB_HHTruckUnloaderCargo
	or lastForm = MOB_HHTruckLoaderCargo
	or lastForm = MOB_HHUnpackContainerForm
	or lastForm = MOB_HHUnpackNewCargo
	or lastForm = MOB_HHPackContainerForm
	or lastForm = MOB_HHPackContainerFormSTW	//16 Apr 2018	NDL	TFS 38083
	or lastForm = MOB_HHBRLocLoaderCargo	//01 May 2015	NDL	Par 36084
	or lastForm = MOB_HHPackComplete	//08 Mar 2017	NDL	TFS 3635
	or lastForm = MOB_HHLanderCargoMove 			//+TFS5650 				
	
	then	//04 Jul 2011	NDL	Par 26476
		
		if self.handleUpdates() &lt;&gt; IDOK then
			//PAR 23905 27/04/2010. Unfortunately, myNextTiToAction is set to null regardless validation for update
			if self.myMobileGenericAgent.myNextTiToAction = null then
				self.myMobileGenericAgent.setMyNextTiToAction( savedMyNextTiToAction ); //after validation messages, save the current value, because it is made null in confirmsOK()
			endif;
			////PAR 23905 27/04/2010. If update failed, I suppose this ti should be not confirmed still.
			if self.myMobileGenericAgent.tiIsConfirmed(self.myMobileGenericAgent.myNextTiToAction) then 
				self.myMobileGenericAgent.allConfirmedTis.remove(self.myMobileGenericAgent.myNextTiToAction);
			endif;
			return;
		endif;
		
		// if we've come from the truck unloader, just return to there
		if lastForm = MOB_HHTruckUnloaderCargo or lastForm = MOB_HHTruckLoaderCargo then	//01 Jun 2010	NDL	Par 23903
			//restore the "nextTI" on the agent
			self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
			self.handleBtnTwo();
			return;
		elseif lastForm = MOB_HHUnpackContainerForm then	//09 Mar 2017	NDL	TFS 3635
			//restore the "nextTI" on the agent for children only
			if self.myMobileGenericAgent.myUnpackTi &lt;&gt; self.myTrackedItem then
				self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
			endif;
			self.handleBtnTwo();
			return;
		elseif ( lastForm = MOB_HHPackContainerForm
				or lastForm = MOB_HHPackContainerFormSTW )	//16 Apr 2018	NDL	TFS 38083
		then	//04 Jul 2011	NDL	Par 26476
			//restore the "nextTI" on the agent
			self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
			self.handleBtnTwo();
			return;
		elseif lastForm = MOB_HHUnpackNewCargo then
			self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
			self.goBackToFirst(MOB_HHUnpackContainerForm);
			return;
		elseif lastForm = MOB_HHBRLocLoaderCargo then	//01 May 2015	NDL	Par 36084
			self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
			self.handleBtnTwo();
			return;
		elseif lastForm = MOB_HHPackComplete then	//08 Mar 2017	NDL	TFS 3635
			self.handleBtnTwo();
			return;
		endif;
	endif;

	if lastForm = MOB_HHGateCheckAllCargo then
		self.myMobileGenericAgent.getNextTiToConfirm;
	
		if self.myMobileGenericAgent.myNextTiToAction = null then
			self.handleBtnTwo();
			return;
		endif;
		
//	elseif lastForm = MOB_HHLanderCargoMove then
	elseif lastForm = MOB_HHLanderCargoMove or lastForm = MOB_HHLanderRailCargoMove then	//07 June 2013	NDL	Par 31680
		self.handleBtnTwo();
		return;
	endif;
	
	self.setupForm;
	
epilog

end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="bb6228c7-dc92-4000-84d5-316e4ebdf301">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	lastForm : Class;
	
begin
	// clear the cargo check item selection array
	
	
	
	lastForm := self.getSessionAgent.allPreviousForms.last.Class;
	if lastForm = MOB_HHUnpackContainerForm then	//09 Mar 2017	NDL	TFS 3635
		//clear the "nextTI" on the agent if we are checking the container currently being unpacked
		if self.myMobileGenericAgent.myUnpackTi = self.myTrackedItem then
			self.myMobileGenericAgent.setMyNextTiToAction( null );
		endif;
	endif;
		
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleF2Key" id="bfe92b61-ebbc-41ae-8f2d-c85965594e7c">
        <source>handleF2Key();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2010	cnwdap1	Initial creation
*/
vars
	result : Integer;
	errMsg : String;
	job : CM_Job;
	
begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.msgBox( app.getErrorString1( Autoplan_Continue, self.myTrackedItem.id ) , app.getErrorString(Warning), MsgBox_Yes_No, false ) = MsgBox_Return_No then
		return;
	endif;
	
	//26 Mar 2010	NDL	Par 23454
	if self.handleUpdates() &lt;&gt; IDOK then
		return;
	endif;
	//30 Mar 2010	NDL	Par 23486
//	if self.myHandHeldCheckerAgent.checksState = MOB_HandHeldCheckerAgent.GateReceipt then
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.GateReceipt or  self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckUnload then	//28 May 2010	NDL	Par 23698
		job := self.myTrackedItem.jobRoadReceive;
	endif;
	result := self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
	app.myMobileAgent.setMyProxy( self.myTrackedItem );  // rebuild the form proxy..
	
	
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		errMsg := app.getErrorString2( Tracked_item_queued, self.myTrackedItem.id, self.myTrackedItem.myPrimaryQueuedLocation.getFullId);
	else
		errMsg := app.getErrorString1( Not_queued_anywhere, self.myTrackedItem.id);
	endif;
	
	self.msgBox( errMsg, app.getErrorString(Warning), MsgBox_OK_Only, false );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleUpdates" id="af121741-e985-41fe-948e-30fe2e6d5ba3">
        <source>handleUpdates():Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2010	cnwndl1	Initial creation	CCMS MES 1005
04/03/2010	cnwdap1	PAR #22741 Is O/D updates
08/03/2010	cnwdap1	PAR #22694 Cargo Check Item can have just a To Do Task and no Required Extra Info
29/11/2017  cnwma1	TFS #8031 : QNS - Container ISO type verification
*/
vars
	idx				: Integer;
	checkItem		: CM_CargoCheckItem;
	result 			: Integer;
	updateRequired 	: Boolean;	// when any update occurs
	toDoTaskDesc	: String;
	toDoTasks		: IntegerArray;
	addingToDos		: BooleanArray;
	rowSelected		: Boolean;
	isoTypeChanged	: Boolean;
	job : CM_Job;
	
begin

	result := IDOK;
	create toDoTasks transient;
	create addingToDos transient;
	
	//Updates to damage, seals and dimensions happen on the forms called from this form
	// We only need to worry about updates to hazards and over dimensions if it's a chdeckbox, 
	// so see if we have one of these entries in the table
	foreach idx in tblCargoChecks.fixedRows + 1 to tblCargoChecks.rows do
		checkItem := tblCargoChecks.accessRow(idx).itemObject.CM_CargoCheckItem;
		rowSelected := tblCargoChecks.accessCell(idx, tblCargoChecks.ColumnValue).selected or tblCargoChecks.accessCell(idx, tblCargoChecks.ColumnValue).text = "1";
		
		if checkItem.requiredExtraInfo = EXTRA_INFO_HAZARD_SYMBOLS then
			if checkItem.myToDoTaskDesc &lt;&gt; null then
				updateRequired := true;
				if checkItem.myToDoTaskDesc &lt;&gt; null then
					toDoTasks.add(checkItem.myToDoTaskDesc.code);
					if (self.myTrackedItem.isHazardous and 						//cnwas3 par 23755 begin
					   not rowSelected) or
					   (rowSelected and
					   not self.myTrackedItem.isHazardous)then
						addingToDos.add(true);													//add the "to do" only if there's a clash between haz labels and haz status of the cargo
					else
						addingToDos.add(null);
					endif;														//cnwas3 par 23755 end
				endif;
			endif;
		
		elseif checkItem.requiredExtraInfo = EXTRA_INFO_IS_OD then
			if checkItem.myToDoTaskDesc &lt;&gt; null then
				toDoTaskDesc := checkItem.myToDoTaskDesc.description;
			else
				toDoTaskDesc := null;
			endif;
			//if self.myHandHeldCheckerAgent.updateDimensionOnProxy(rowSelected) then
			if self.myMobileGenericAgent.updateDimensionOnProxy(app.myMobileAgent.getMyProxyObject.CM_TrackedItem,rowSelected) then
				updateRequired := true;
				if checkItem.myToDoTaskDesc &lt;&gt; null then
					toDoTasks.add(checkItem.myToDoTaskDesc.code);
					addingToDos.add(rowSelected);
				endif;
			endif;
			
		// PAR #22694 update to do task if this is all we have
		elseif checkItem.requiredExtraInfo = null and checkItem.myToDoTaskDesc &lt;&gt; null then
			toDoTaskDesc := checkItem.myToDoTaskDesc.description;
			updateRequired := true;
			if checkItem.myToDoTaskDesc &lt;&gt; null then
				toDoTasks.add(checkItem.myToDoTaskDesc.code);
				addingToDos.add(rowSelected);
			endif;
			
		endif;
		
	endforeach;
	
	//handle change to isotype
	
	/*if cmbIsoType.listObject.CM_ISOType &lt;&gt; null then   //29.11.2017 cnwma1 TFS #8031
		//isoTypeChanged := self.myHandHeldCheckerAgent.updateISOTypeOnProxy( cmbIsoType.listObject.CM_ISOType );
		isoTypeChanged := self.myMobileGenericAgent.updateISOTypeOnProxy( app.myMobileAgent.getMyProxyObject.CM_Container, cmbIsoType.listObject.CM_ISOType );
		if isoTypeChanged then
			updateRequired := true;
		endif;
	endif;
	*/	
	if cmbIsoType.listObject.CM_ISOType &lt;&gt; null then						//29.11.2017 cnwma1 TFS #8031
		//let the trx in doRealTrackedItemUpdate handle errors and warnings
		app.myMobileAgent.getMyProxyObject.CM_Container.setISOType(cmbIsoType.listObject.CM_ISOType.code);		
		updateRequired := true;
	endif;
	
	// update the presistent tracked item
	if updateRequired then
		//result := self.myHandHeldCheckerAgent.doRealTrackedItemUpdate(toDoTasks, addingToDos);
		result := self.myMobileGenericAgent.doRealTrackedItemUpdate( app.myMobileAgent.getMyProxyObject.CM_TrackedItem, toDoTasks, addingToDos); 
	endif;
	
	//21 May 2010	NDL	Par 24063
	if isoTypeChanged and result = IDOK then
		//if self.myHandHeldCheckerAgent.checksState = MOB_HandHeldCheckerAgent.GateReceipt then
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.GateReceipt or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckUnload then//28 May 2010 NDL	Par 23698
			job := self.myTrackedItem.jobRoadReceive;
		endif;
		self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
	endif;
	
	return result;

epilog
	delete toDoTasks;
	delete addingToDos;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="194cea87-99a6-4332-ad64-926427feac6c">
        <updating/>
        <source>setupControls( state : Integer; lastForm : Class ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation

*/

vars

begin

	if CM_Container.hasInstance(self.myTrackedItem) then
		self.setupTxtContainerId(state, lastForm);
	else
		self.setupTxtCargoId(state, lastForm);
	endif;
	
	self.doResizeControls(true);

epilog

end;</source>
        <Parameter name="state" type="Integer"/>
        <Parameter name="lastForm" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6d1378a3-f127-4b60-bddd-42f0c60ee749">
        <updating/>
        <source>setupForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/01/2010	cnwndl1	Initial creation	CCMS MES 1005
08/03/2010	cnwdap1	PAR #22656 hide Cargo Check table if no checks configured
31/03/2010	cnwdap1	PAR #22741 Refactor cargo check context
*/
vars
	formToDisplay, lastForm	: Class;
	context, state			: Integer;
	cargoCheck				: CM_CargoCheck;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );
	self.btnOne.enabled := true;
	lastForm := self.getSessionAgent.allPreviousForms.last.Class;
	if lastForm = MOB_HHTruckUnloaderCargo then
		self.btnOne.caption := app.getErrorString(Save);
	elseif lastForm = MOB_HHRailPlaceCargo then	//16 Aug 2010	NDL		Par 25215
		self.setupCmdButtons( 1, app.getErrorString(Back), null, null, null, null );
	endif;
	
	inheritMethod();
	
	// PAR #22741 centralise context checking
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		context := cargoCheck.context;
	endif;
	// PAR #22741 end
	
	// 01 Apr 2010	NDL Par 23571 - reinstate state..
	state := self.myMobileGenericAgent.checksState;
	
	self.setupControls(state, lastForm);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTxtCargoId" id="71477052-d2df-4795-986a-bcefff64a34c">
        <updating/>
        <source>setupTxtCargoId(_state: Integer; _lastForm : Class) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
	term : CM_Terminal;
	displayId : Boolean;
	stdHeight : Real;
	stdWidth : Real;
	top : Real;
	tabIndex : Integer;
	desc1 : String;
	desc2 : String;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth :=  self.clientWidth - (self.resizedMargin * 2);
	tabIndex := 4000;
	
	// hide container id fields
	self.txtContainerId.visible := false;
	self.cmbIsoType.visible		:= false;
	
	// show cargo id fields
	self.txtCargoId.visible := true;
	self.txtCargoId.move( self.resizedMargin,
						 self.resizedMargin,
						 stdWidth,
						 stdHeight );
	
	term := self.myMobileDataAgent.myTerminal;
	//if _state.isOneOf(self.myHandHeldCheckerAgent.GateReceipt, self.myHandHeldCheckerAgent.GateRelease) then
	if _state.isOneOf(self.myMobileGenericAgent.GateReceipt, self.myMobileGenericAgent.GateRelease) or _state.isOneOf(self.myMobileGenericAgent.TruckUnload, self.myMobileGenericAgent.TruckLoad) then//28 May 2010 NDL	Par 23698
		displayId := not term.getConfig(GateCheckRequiresCargoId).Boolean;
	else
		displayId := true;
	endif;
	if self.myMobileGenericAgent.tiIsConfirmed(myTrackedItem) then	// re-visiting the form to change something??
		displayId := true;
	endif;
	if displayId or _lastForm = MOB_HHTruckUnloaderCargo then	// re-visiting the form to change something??
		self.txtCargoId.text := self.myTrackedItem.id;
	else
		self.txtCargoId.text := lblId.caption.toUpper;
	endif;
	self.txtCargoId.enabled := true;
	
	
	top := self.resizedMargin + self.txtCargoId.height + self.txtCargoId.top;
	self.lblCargoType.visible := true;
	self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	self.lblCargoType.move( self.resizedMargin,
							 top,
							 self.clientWidth - self.getSearchButtonSpace(),
							 stdHeight );
							 
	self.lblCargoType.caption := self.myMobileGenericAgent.myNextTiToAction.cargoTypeDescr;
	
	top := top + self.lblCargoType.height + self.resizedMargin;
	self.lblCargoDesc.visible := true;
	self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	self.lblCargoDesc.move( self.resizedMargin,
							 top,
							 stdWidth,
							 stdHeight ); 
							 
	self.myMobileGenericAgent.myNextTiToAction.getShortDescriptions( desc1, desc2 );
	self.lblCargoType.caption := desc1;
	self.lblCargoDesc.caption := desc2;
	
epilog

end;</source>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_lastForm" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setupTxtContainerId" id="a3018254-a3a2-4f79-8b8c-d9167d4ea442">
        <updating/>
        <source>setupTxtContainerId(_state : Integer; _lastForm : Class) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2010	cnwdap1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	term 				: CM_Terminal;
	iter 				: Iterator;
	isoType 			: CM_ISOType;
	index 				: Integer;
	displayId 			: Boolean;
	isoChgNotAllowed 	: Boolean;
	thirdWidth : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	// hide cargo id fields
	self.txtCargoId.visible := false;
	
	stdHeight := self.getStdControlHeight();
	
	// show container id fields
	self.txtContainerId.visible := true;
	self.txtContainerId.move(	self.resizedMargin,
								self.resizedMargin,
								self.clientWidth - self.getSearchButtonSpace(),
								stdHeight	);
	
	term := self.myMobileDataAgent.myTerminal;
	
	// gate check - do we need to enter cargo id manually?
	//if _state.isOneOf(self.myHandHeldCheckerAgent.GateReceipt, self.myHandHeldCheckerAgent.GateRelease) then
	if _state.isOneOf(self.myMobileGenericAgent.GateReceipt, self.myMobileGenericAgent.GateRelease) or _state.isOneOf(self.myMobileGenericAgent.TruckUnload, self.myMobileGenericAgent.TruckLoad) then//28 May 2010 NDL	Par 23698
		displayId := not term.getConfig(GateCheckRequiresCargoId).Boolean;
	endif;
	if self.myMobileGenericAgent.tiIsConfirmed(myTrackedItem) then	// re-visiting the form to change something??
		displayId := true;
		isoChgNotAllowed := true;
	endif;
	if self.myMobileGenericAgent.displayIdOnCheckForm then	// coming from another form
		displayId := true;
		isoChgNotAllowed := true;
	endif;
	
	//+cnwml2 PAR25814
	if self.myMobileGenericAgent.getEquipmentHasICargoChecks(myTrackedItem) then		
		displayId := true;
	endif;
	
	if displayId or _lastForm = MOB_HHTruckUnloaderCargo then	// re-visiting the form to change something??
		self.txtContainerId.text := self.myTrackedItem.id;
	else
		self.txtContainerId.text := lblId.caption.toUpper;
	endif;
	self.txtContainerId.enabled := true;
	
	thirdWidth := ( self.clientWidth / 3 ) - self.resizedMargin;
	self.cmbIsoType.visible := true;
	self.cmbIsoType.move(	self.resizedMargin,
							self.resizedMargin + self.txtContainerId.height + self.txtContainerId.top,
							thirdWidth * 2,
							stdHeight	);
							
	btnAutoPlan.visible := false;	//21 May 2010	NDL	 Par 23603	disabled and hidden 
	btnAutoPlan.enabled := false;	//21 May 2010	NDL	 Par 23603	disabled and hidden 
	
	self.btnAutoPlan.move(	self.cmbIsoType.left + self.cmbIsoType.width + self.resizedMargin,
							self.resizedMargin + self.txtContainerId.height + self.txtContainerId.top,
							thirdWidth,
							stdHeight	);
							 
	iter := app.myRoot.allISOTypes.createIterator;
	
	while iter.next(isoType) do
		index := self.cmbIsoType.addItem(isoType.code);
		self.cmbIsoType.itemObject[index] := isoType;
	endwhile;
	
	isoType := self.myTrackedItem.CM_Container.getISOTypeObject;
	if isoType &lt;&gt; null then
		self.cmbIsoType.listIndex := self.cmbIsoType.findObject( isoType );
	endif;

	if isoChgNotAllowed then
		self.cmbIsoType.enabled := false;
		self.txtContainerId.enabled := false;
	else
		//if _state = self.myHandHeldCheckerAgent.GateReceipt then	// 23 Mar 2010	NDL	Par 23285
		if _state = self.myMobileGenericAgent.GateReceipt or _state = self.myMobileGenericAgent.TruckUnload then//28 May 2010 NDL	Par 23698
			self.cmbIsoType.enabled := term.getConfig(GateCheckAllowsIsoChg).Boolean;
		else
			self.cmbIsoType.enabled := false;
		endif;
	endif;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_lastForm" type="Class"/>
    </JadeMethod>
    <JadeMethod name="tblCargoChecks_click" id="458e0d67-6d7a-413f-94d8-f4724a85bd8d">
