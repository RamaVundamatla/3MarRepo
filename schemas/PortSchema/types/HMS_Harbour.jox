    <JadeMethod name="addWharf" id="5cb3fa79-f936-4f32-b1d4-e4687576d1bb">
        <updating/>
        <source>addWharf(_wharf : HMS_Wharf; displayPos : Integer) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 17 December 2004
//
//********************************************************************
vars

begin

	if (not self.allWharves.includes(_wharf)) then
		self.allWharves.add(_wharf);
	endif;

	if self.allWharfDisplayOrderArray.includes(_wharf) then
		self.allWharfDisplayOrderArray.remove(_wharf);
	endif;
	
	if displayPos &lt;= 0 or displayPos &gt; self.allWharfDisplayOrderArray.size then
		self.allWharfDisplayOrderArray.add(_wharf);
	else
		self.allWharfDisplayOrderArray.atPut(displayPos, _wharf);
	endif;
	
end;</source>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <Parameter name="displayPos" type="Integer"/>
    </JadeMethod>
