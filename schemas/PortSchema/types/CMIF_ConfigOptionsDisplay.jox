    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="configCmif"/>
    <PrimAttribute name="appliesToTerm" id="0f1d92b1-b80a-43d8-b3ff-51edfda1f386">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="constantName" id="bec8af4a-0707-4c61-ac74-556497f9ea8e">
        <length>101</length>
