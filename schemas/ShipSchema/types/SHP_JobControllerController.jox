    <JadeMethod name="positionJobBubble" id="0c00de29-7e7f-4537-bc96-0c5e895c5eb5">
        <source>positionJobBubble(x : Real);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	newLeft, newTop: Real;	
	clientWidth : Real;
begin
	//if there is a hoirizontal scroll bar use the scroll bar width
	//else the frmScrollingMain width is fine (i.e. frm the jobs are draw on)
	if self.frmScrollableMain.hasHScroll then
		clientWidth := self.frmScrollableMain.getHScrollWidth;
	else
		clientWidth:=self.frmScrollingMain.width;
	endif;

	if x + 60 + frmJobBubble.width &gt; clientWidth then
		newLeft:= x - frmJobBubble.width -60 ;
	else
		newLeft:= x + 60;
	endif;
	
	newTop:=frmJobBubble.top;
	if newTop + self.frmJobBubble.height &gt; self.frmScrollingMain.height then
		newTop:=self.frmScrollingMain.height - self.frmJobBubble.height;
	else

	endif;
	
	self.frmJobBubble.move(newLeft, newTop,frmJobBubble.width,frmJobBubble.height);
	if not self.frmJobBubble.visible then
		self.frmJobBubble.visible:=true;
	endif;

epilog

end;</source>
        <Parameter name="x" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resizeScrollableMain" id="a517f600-0d0e-472c-b829-6d7844993d9f">
        <source>resizeScrollableMain();
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	voyageFrame : CMUI_Frame;
begin
	voyageFrame:=self.getVoyageOverviewLabelFrame;
	voyageFrame.top:=0;
	self.frmScrollableMain.setLeftLabelMargin(voyageFrame.width);
	self.frmScrollableMain.setVLabelDetails(voyageFrame.width,false);
	if self.frmScrollingMain.visible then
		self.frmScrollableMain.resizeScrollingFrame(self.getTimeLineLabelFrame.width, voyageFrame.height);
	endif;
	if self.getTimeLineLabelFrame.visible then
		self.frmScrollableMain.myTopLeftFillerFrame.top:=self.getTimeLineLabelFrame.top;
		self.frmScrollableMain.myTopLeftFillerFrame.height:=self.getTimeLineLabelFrame.height;
	else
		self.frmScrollableMain.myTopLeftFillerFrame.top:=0;
		self.frmScrollableMain.myTopLeftFillerFrame.height:=0;
	endif;
	if self.frmScrollableMain.hasHScroll then
		self.frmScrollableMain.myTopLeftFillerFrame.height:=self.frmScrollableMain.myTopLeftFillerFrame.height + app.getVerticalScrollbarWidth;
	endif;
	self.frmScrollableMain.myTopLeftFillerFrame.visible:=true;
	if self.myTimeLineDrawController.startTime &lt;&gt; null then
		self.frmScrollableMain.myTopLeftFillerFrame.caption:=
		"Start: " &amp; self.systemToLocalTime(self.myTimeLineDrawController.startTime).asStringJMT &amp;  ", Scale (mins): "  &amp;  self.myTimeLineDrawController.scaleMins.asStringJMT;	// 19/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
epilog

end;</source>
    </JadeMethod>
