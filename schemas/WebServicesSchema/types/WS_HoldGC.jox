        <source>setProxyFromObject(_hold : CM_GeneralCargoController) updating;
/*
Purpose:			
Date		Who		Reason
14 August 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_hold);

	self.code := _hold.hatch.padLeadingWith('0',2);
	self.description := _hold.getFullId();
	
epilog

end;</source>
