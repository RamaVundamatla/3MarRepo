<Class name="CM_Crane">
    <JadeMethod name="importPLXMLReference" id="42400359-8b1b-479f-8b60-b219fd5e0951">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Machine::myRoot.name then
		return app.myRoot;
	elseif _name = CM_Machine::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	elseif _name = CM_Crane::transferArea.name then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.allTerminalAreaMastersById[_theCode].CM_TerminalArea;
		endif;
//		return app.getMyTerminal.radioTelemetry.allRTDevices[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
