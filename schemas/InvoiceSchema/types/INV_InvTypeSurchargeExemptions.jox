    <JadeMethod name="btnACSDelete_click" id="50a08309-f420-4fc2-973c-fded9dc0ad28">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnACSDelete_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	obj : CM_Object;

begin

	if self.tblACS.row &gt; 0 then
		obj := self.tblACS.accessRow(self.tblACS.row).itemObject.CM_Object;
	endif;

