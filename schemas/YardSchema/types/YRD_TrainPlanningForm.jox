    <JadeMethod name="doMnuAttachGenSet" id="a6ec4925-0ec0-48b8-9154-abf076cba199">
        <updating/>
        <source>doMnuAttachGenSet( menuItem: MenuItem ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: CMUI_AttachGenSet;
	anObject: Object;
	theTI	: CM_TrackedItem;

begin

	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) and not anObject.isKindOf(CM_TILC) then
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theTI := anObject.CM_TrackedItem;
	create form;
	form.centreWindow;
	form.myTrackedItem := theTI;
	form.setMyTerminal(self.myTerminal);
	form.setFormParent( self );
	form.showModal;
	
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuConfirmOutClick" id="28123f18-b641-4684-a1f7-d0ec659a2f28">
        <updating/>
        <source>doMnuConfirmOutClick(_menuItem : MenuItem) protected, updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wagon		: CM_Wagon;
	theReturn			: Integer;
begin
	wagon := _menuItem.userObject.CM_Wagon;
	if wagon = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonConfirmOut(null, wagon, true, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Outward_wagon_CONFIRMmm), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

end;

</source>
