    <JadeMethod name="setForUpdate" id="d437189e-e370-4216-8374-c1437dd215db">
        <updating/>
        <source>setForUpdate(pxyReserveTI : CM_ReserveTI) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	inheritMethod(pxyReserveTI);
	
	self.raiseExceptionIfTransient(method);
	pxyReserveTI.raiseExceptionIfNotTransient(method);
	
	self.myBOLIn					:= pxyReserveTI.myBOLIn;
