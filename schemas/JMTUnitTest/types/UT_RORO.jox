    <JadeMethod name="x31258_OOTLSetupUnload5" id="9c2b9044-f11e-4333-8eac-677b36195425">
        <source>x31258_OOTLSetupUnload5(_voyage : CM_Voyage; _deck : CM_DeckVoyage);

/*

Purpose:		Create the OOTL's for #31258	

Date			Who		Reason
14/03/2013		cnwmh5	Initial creation

*/

vars
	
	roroStructure : CM_ROROVoyageStructure;
	locDefn  		: CM_ROROLocnDefn;
	
begin
	
	roroStructure := _voyage.myROROStructure;

	//roroStructure.createQuickCargoOOTL(null,false,79,-4,_deck, 5); // 1 X 20
	self.createQuickCargoOOTL(roroStructure, locDefn,false,79,-4,_deck, 5);
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(null,true,79,4,_deck, 5); // 1 X 40
	self.createQuickCargoOOTL(roroStructure, locDefn,true,79,4,_deck, 5);
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="xCheckExtractedDataCorrect" id="822ade8c-88b1-4731-b229-0949bd4a6ca4">
        <source>xCheckExtractedDataCorrect(_correctExtractedData, _extractedData : StringArray512);

/*

Purpose:		Check that the data extracted is the same as we are expecting	

Notes:			CorrectData is deleted in the calling method

Date			Who		Reason
25/01/2013		cnwmh5	Initial creation

*/

vars

	correctData					: StringArray512;

	idx, idx2					: Integer;
	ediText						: String;
	failingFound				: Boolean;
	
begin
	
	create correctData transient;
	_correctExtractedData.copy(correctData);
	
	foreach ediText in _extractedData do
		idx := idx + 1;
		idx2 := correctData.indexOf(ediText);
		if idx2 = 0 then
			failingFound := true;
			app.writeLog(idx.String &amp; Tab &amp; ediText, LogINFO);
		else
			correctData.removeAt(idx2);
		endif;
	endforeach;
	
	// display any errors
	if correctData.size &gt; 0 then
		failingFound := true;
		foreach ediText in correctData do
			app.writeLog(Tab &amp; ediText, LogINFO);
		endforeach;
	endif;
	self.assertEqual(failingFound, false);

epilog

	delete correctData;

end;</source>
        <Parameter name="_correctExtractedData" type="StringArray512"/>
        <Parameter name="_extractedData" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="xCreateCargoAtShipLocation" id="b1b901f7-c3a0-4d6d-b224-556687289e5c">
        <source>xCreateCargoAtShipLocation(_cargoId : String; _operator : CM_Operator; _isoTypeStr : String; _voyage : CM_Voyage; _dischargePort : String; _locnDefn : CM_ROROLocnDefn) : CM_TrackedItem;

/*

Purpose:		Add cargo to a specific location on a vessel	

Date			Who		Reason
15/01/2013		cnwmh5	Initial creation

*/

vars

	cargo								: CM_TrackedItem;

begin

	// add the cargo back to the locations
	self.deleteContainer(_cargoId);
			
	// add the cargo to the OOTL
	cargo := self.addContainerOnShip(_cargoId, _operator, _isoTypeStr, "GENL", null, _voyage, _dischargePort, _locnDefn.code);
	self.assertNoTrxErrorsOrWarnings();

	return cargo;
epilog

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoTypeStr" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefn"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="xCreateOOTLS" id="d7f8fd71-6c2f-4436-a962-1272fe07d57a">
        <source>xCreateOOTLS(_voyage : CM_Voyage);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14 January 2013	cnwmh5	Initial creation

*/

vars

	roroStructure 				: CM_ROROVoyageStructure;
	deck 						: CM_DeckVoyage;
	locnDefn					: CM_ROROLocnDefn;

begin

	// set up the details for the voyage, rotations, containers, etc.
	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	// get the deck
	deck := _voyage.myROROStructure.allDecksByCode["1"];
	self.assertNotNull(deck);
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, -1, 66, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, -4, 66, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, -6, 66, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, -9, 66, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, -11, 66, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xCreateOOTLSCargo" id="9eed3ef1-cc9c-4d0b-b224-6aad28cf1fe5">
        <source>xCreateOOTLSCargo(_voyage : CM_Voyage);

/*

Purpose:		Create OOTL's and Cargo

Date			Who		Reason
14 January 2013	cnwmh5	Initial creation

*/

constants
	CargoIdOOTL					: String = "OOTL23073";
	CargoIdNonOOTL				: String = "MDHA23073";
vars

	roroStructure 				: CM_ROROVoyageStructure;
	deck 						: CM_DeckVoyage;
	locnDefn					: CM_ROROLocnDefn;
	locnDefnTemp				: CM_ROROLocnDefn;
	tempTI						: CM_TrackedItem;
	cargo 						: CM_TrackedItem;
	operator					: CM_Operator;
	
	tiArray						: CM_TIArray;
	
	count						: Integer;
	isoTypeStr					: String;
	cargoId						: String;
	dischargePort				: String;

begin

	// set up the details for the voyage, rotations, containers, etc.
	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);

	/************************
		DECK 1
	************************/
	
	// get the deck
	deck := _voyage.myROROStructure.allDecksByCode["1"];
	self.assertNotNull(deck);
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 66.5, -1.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 72.5, -1.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 66.5, -3.6, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 72.5, -3.6, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 66.5, -6.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 72.5, -6.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 66.5, -8.5, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 72.5, -8.5, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 66.5, -11,  deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, false, 72.5, -11, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();

	create tiArray transient;
	
	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);
	
	count := 71;
	
	// read through the locations looking for OOTLs
	foreach locnDefn in deck.allROROLocnDefnByCode where locnDefn.isOOTLLocn do
	
		// delete the current ti at the location
		tiArray.clear();
		locnDefn.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;
		
		isoTypeStr := "2263";
		dischargePort := "NZPOE";
	
		if count &gt;= 78 then
			dischargePort := "DEBRV";
		endif;
		
		if count = 80 then
			isoTypeStr := "2200";
		endif;
		
		self.xCreateCargoAtShipLocation(CargoIdOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
		count := count + 1;
	
	endforeach;
	
	// rotated OOTL
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 77, -1.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	locnDefn := deck.allROROLocnDefnByCode["D1190O"].CM_ROROLocnDefnVoyage;
	self.assertNotNull(locnDefn);
	

	// delete the current ti at the location
	tiArray.clear();
	locnDefn.getAllTIs(REAL_MODE, tiArray, true);
	foreach tempTI in tiArray do
		self.deleteTrackedItem(tempTI, false);
	endforeach;
		
	app.myTrxUA.trxUpdateROROLocnDefnRotate(locnDefn, 1, 1, false, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
	isoTypeStr := "4262";
	count := 70;
	dischargePort := "NZPOE";
	
	self.xCreateCargoAtShipLocation(CargoIdOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
	count := count + 1;
	
	
	/************************
		DECK 2
	************************/
	
	// get the deck
	deck := _voyage.myROROStructure.allDecksByCode["2"];
	self.assertNotNull(deck);
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, locnDefn, true, 66.5, -1.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	count := 81;
	
	// read through the locations looking for OOTLs
	foreach locnDefn in deck.allROROLocnDefnByCode where locnDefn.isOOTLLocn do
	
		isoTypeStr := "2200";
		dischargePort := "NZPOE";
	
		// delete the current ti at the location
		tiArray.clear();
		locnDefn.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;
		
		self.xCreateCargoAtShipLocation(CargoIdOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
		count := count + 1;
		
		if locnDefn.myAdjacentSlotFwd = null then
			isoTypeStr := "4262";
			self.xCreateCargoAtShipLocation(CargoIdOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
			count := count + 1;
		endif;
		
	endforeach;

	// create standard 20' X 2 and 40' x 1
	locnDefn := deck.allROROLocnDefnByCode["D2037"].CM_ROROLocnDefnVoyage;
	self.assertNotNull(locnDefn);
	
	// add 20'
	isoTypeStr := "2200";
	self.xCreateCargoAtShipLocation(CargoIdNonOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
	count := count + 1;
	
	locnDefn := deck.allROROLocnDefnByCode["D2042"].CM_ROROLocnDefnVoyage;
	self.assertNotNull(locnDefn);
	
	self.xCreateCargoAtShipLocation(CargoIdNonOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
	count := count + 1;
	
	// add 40'
	isoTypeStr := "4262";
	self.xCreateCargoAtShipLocation(CargoIdNonOOTL &amp; count.padLeadingWith("0", 2), operator, isoTypeStr, _voyage, dischargePort, locnDefn);
	count := count + 1;
	
epilog

	delete tiArray;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xExtractLoadActual1_30863" id="821a8090-5860-4398-bfe1-b8e5d39e2745">
        <source>xExtractLoadActual1_30863(_voyage1, _voyage2 : CM_Voyage);

/*

Purpose:		Extract and load the actual to voyage 2	

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
constants

	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
	
vars
	theLines : HugeStringArray;
	ediFile 				: CM_EDIFile;
	voyage1Array			: StringArray512;
	correctExtractedData	: StringArray512;
	voyage1OriginalArray	: StringArray512;
	binaryMsg 				: Binary;	
	ediText 				: String;
	uncompressedStr			: String;
begin
	// extract out RORO EDI User Defined file
	ediFile := self.extractROROEDIUserDefined(UserDefinedROROBaplie, method.name, _voyage1, ACTUAL_BAYPLANS);					// 13/02/2013 cnwmh5
	
	// save the extracted details for voyage1
	create voyage1Array transient;
	create voyage1OriginalArray transient;
	ediText := null;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach uncompressedStr in theLines do
		voyage1OriginalArray.add(uncompressedStr);
		if uncompressedStr.cnContains(_voyage1.code) then
			uncompressedStr := uncompressedStr.replaceString(_voyage1.code, _voyage2.code);
		endif;
		if uncompressedStr.cnContains("NZPOE") then
			uncompressedStr := uncompressedStr.replaceString("NZPOE", "NZAKL");
		endif;
		if uncompressedStr.cnContains("RORO") then
			uncompressedStr := uncompressedStr.replaceString("RORO", "ROR0");
		endif;
		ediText := ediText &amp; uncompressedStr &amp; CrLf;
	endforeach;
		
	//  now load the extracted details into voyage2
	self.ediLoadVerifyDBLoadActualBasic(ediText, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);			// 13/02/2013 cnwmh5
	
	// check that the data extracted is the data that we are expecting to be extracted
	create correctExtractedData transient;
	self.xExtractedDataCorrectForVoyage(_voyage1, _voyage2, correctExtractedData);
	self.xCheckExtractedDataCorrect(correctExtractedData, voyage1OriginalArray);

epilog
	delete voyage1Array;
	delete correctExtractedData;
	delete voyage1OriginalArray;
	delete theLines;
end;</source>
        <Parameter name="_voyage1" type="CM_Voyage"/>
        <Parameter name="_voyage2" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xExtractLoadProposed1_30863" id="5234186e-cb97-435a-9478-5d4f7a2961f9">
        <source>xExtractLoadProposed1_30863(_voyage1, _voyage2 : CM_Voyage);

/*

Purpose:		Extract and load the proposed to voyage

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
constants

	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
	
vars
	theLines : HugeStringArray;
	ediFile 			: CM_EDIFile;
		
	voyage1Array		: StringArray512;
	voyage2Array		: StringArray512;
	copyVoyage1Array	: StringArray512;
	correctExtractedData	: StringArray512;
	voyage1OriginalArray	: StringArray512;
		
	binaryMsg 			: Binary;	
	ediText 			: String;
	uncompressedStr		: String;

begin

	// extract out RORO EDI User Defined file
	ediFile := self.extractROROEDIUserDefined(UserDefinedROROBaplie, method.name, _voyage1, PROPOSED_BAYPLANS);					// 13/02/2013 cnwmh5
	
	// save the extracted details for voyage1
	create voyage1Array transient;
	create voyage1OriginalArray transient;
	ediText := null;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach uncompressedStr in theLines do
		voyage1OriginalArray.add(uncompressedStr);
		if uncompressedStr.cnContains(_voyage1.code) then
			uncompressedStr := uncompressedStr.replaceString(_voyage1.code, _voyage2.code);
		endif;
		if uncompressedStr.cnContains("NZPOE") then
			uncompressedStr := uncompressedStr.replaceString("NZPOE", "NZAKL");
		endif;
		if uncompressedStr.cnContains("MDHUT2") then
			uncompressedStr := uncompressedStr.replaceString("MDHUT2", "MDHUT3");
		elseif uncompressedStr.cnContains("RORO") then
			uncompressedStr := uncompressedStr.replaceString("RORO", "ROR0");
		endif;
		
		voyage1Array.add(uncompressedStr);
		ediText := ediText &amp; uncompressedStr &amp; CrLf;
	endforeach;
	
	//  now load the extracted details into voyage3
	self.ediLoadVerifyDBLoadActualBasic(ediText, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);			// 13/02/2013 cnwmh5
	
	// check that the data extracted is the data that we are expecting to be extracted
	create correctExtractedData transient;
	self.xExtractedDataCorrectForVoyage(_voyage1, _voyage2, correctExtractedData);
	self.xCheckExtractedDataCorrect(correctExtractedData, voyage1OriginalArray);
epilog
	delete voyage1Array;
	delete voyage2Array;
	delete copyVoyage1Array;
	delete correctExtractedData;
	delete voyage1OriginalArray;
	delete theLines;
end;</source>
        <Parameter name="_voyage1" type="CM_Voyage"/>
        <Parameter name="_voyage2" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xExtractLoadProposed1_31119" id="3fa37a21-8e75-4601-adf9-e4b977882b2b">
        <source>xExtractLoadProposed1_31119(_voyage1, _voyage2 : CM_Voyage);

/*

Purpose:		Extract and load the proposed to voyage

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
constants

	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
	
vars
	theLines : HugeStringArray;
	ediFile 			: CM_EDIFile;
		
	voyage1Array		: StringArray512;
	voyage2Array		: StringArray512;
	copyVoyage1Array	: StringArray512;
	correctExtractedData	: StringArray512;
	voyage1OriginalArray	: StringArray512;
		
	binaryMsg 			: Binary;	
	ediText 			: String;
	uncompressedStr		: String;

begin

	// extract out RORO EDI User Defined file
	ediFile := self.extractROROEDIUserDefined(UserDefinedROROBaplie, method.name, _voyage1, PROPOSED_BAYPLANS);					// 13/02/2013 cnwmh5
	
	// save the extracted details for voyage1
	create voyage1Array transient;
	create voyage1OriginalArray transient;
	ediText := null;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach uncompressedStr in theLines do
		voyage1OriginalArray.add(uncompressedStr);
		if uncompressedStr.cnContains(_voyage1.code) then
			uncompressedStr := uncompressedStr.replaceString(_voyage1.code, _voyage2.code);
		endif;
		if uncompressedStr.cnContains("NZPOE") then
			uncompressedStr := uncompressedStr.replaceString("NZPOE", "NZAKL");
		endif;
		if uncompressedStr.cnContains("CANN111") then
			if _voyage2.code = "VOY31119PROPL" then
				uncompressedStr := uncompressedStr.replaceString("CANN111", "CANN112");
			elseif _voyage2.code = "VOY31119PROPLP" then
				uncompressedStr := uncompressedStr.replaceString("CANN111", "CANN113");
			elseif _voyage2.code = "VOY31119PROPLF" then
				uncompressedStr := uncompressedStr.replaceString("CANN111", "CANN114");
			endif;
		endif;
		if uncompressedStr.cnContains("UTMDHG0") then
			if _voyage2.code = "VOY31119PROPL" then
				uncompressedStr := uncompressedStr.replaceString("UTMDHG0", "UTMDHG1");
			elseif _voyage2.code = "VOY31119PROPLP" then
				uncompressedStr := uncompressedStr.replaceString("UTMDHG0", "UTMDHG2");
			elseif _voyage2.code = "VOY31119PROPLF" then
				uncompressedStr := uncompressedStr.replaceString("UTMDHG0", "UTMDHG3");
			endif;
		endif;
		voyage1Array.add(uncompressedStr);
		ediText := ediText &amp; uncompressedStr &amp; CrLf;
	endforeach;
	
	//  now load the extracted details into voyage3
	self.ediLoadVerifyDBLoadActualBasic(ediText, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);			// 13/02/2013 cnwmh5
	
	// check that the data extracted is the data that we are expecting to be extracted
	///create correctExtractedData transient;
	///self.xExtractedDataCorrectForVoyage(_voyage1, _voyage2, correctExtractedData);
	///self.xCheckExtractedDataCorrect(correctExtractedData, voyage1OriginalArray);
epilog
	delete voyage1Array;
	delete voyage2Array;
	delete copyVoyage1Array;
	delete correctExtractedData;
	delete voyage1OriginalArray;
	delete theLines;
end;</source>
        <Parameter name="_voyage1" type="CM_Voyage"/>
        <Parameter name="_voyage2" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xExtractLoad_30863" id="d7618249-4d88-47ea-a34e-d7bb3ad9f255">
        <source>xExtractLoad_30863(_voyage1, _voyage2 : CM_Voyage);

/*

Purpose:		Extract and load the actual to voyage 2	

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
constants

	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
	
vars

	fileTypeUser 		: CM_EDIFileTypeUser;
	pxyFileTypeUser 	: CM_EDIFileTypeUser;
	voyage 				: CM_Voyage;
	ediFile 			: CM_EDIFile;
	ediFile1			: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	ediDataParams 		: CMIF_EDIDataDetails;
	ediData 			: CM_EDIData;
	ediFileType 		: CM_EDIFileType;
		
	voyage1Array		: StringArray512;
	voyage2Array		: StringArray512;
	copyVoyage1Array	: StringArray512;
		
	binaryMsg 			: Binary;	
	ediText 			: String;
	idx					: Integer;
	idx2				: Integer;
	uncompressedStr		: String;
	failingFound		: Boolean;
	clientRef : String;
	clientRefNum : Integer;
	theLines : HugeStringArray;
	tempStr : String;
begin

	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedROROBaplie).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedROROBaplie &amp; ' is missing');

	// extract out roro actual for voyage
	create ediDataParams transient;
	ediFileType :=  app.myRoot.allEDIFileTypeUsersByName[UserDefinedROROBaplie];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		app.myTrxCA.trxCreateEDIDataFromDeckPlan(ediData, self.getTerminal().myEdiConfig, _voyage1,  ACTUAL_BAYPLANS,
			clientRef, _voyage1.myOperator, ediFileType, app.myPassport, _voyage1.myOperator.code, null, null );
		self.assertNoTrxErrorsOrWarnings();
		ediDataParams.operator := _voyage1.myOperator;
		ediFile1 := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile1, ediData.number, ediDataParams);
	endif;
	
	// save the extracted details for voyage1
	create voyage1Array transient;
	ediText := null;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach uncompressedStr in theLines do
		// ******************remove when fixed
		if uncompressedStr.cnContains('D3495') or uncompressedStr.cnContains('D3496') or
				uncompressedStr.cnContains("D3499") then
			continue;
		endif;
		if uncompressedStr.cnContains("VOYSHIP30863_1") then
			uncompressedStr := uncompressedStr.replaceString("VOYSHIP30863_1", "VOYSHIP30863_2");
		endif;
		if uncompressedStr.cnContains("NZPOE") then
			uncompressedStr := uncompressedStr.replaceString("NZPOE", "NZAKL");
		endif;
		voyage1Array.add(uncompressedStr);
		ediText := ediText &amp; uncompressedStr &amp; CrLf;
	endforeach;
	
	//  now load the extracted details into voyage2
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name);		
	self.assertNotNull(ediFile);
	
	// verify and load db load the file
	//self.expectTrxError(WarningPileWeightExceeded);
	//self.expectTrxError(WarningPileHeightExceed2);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// compare the 2 files to see that voyage2's extract is the same as voyage1's extract
	create copyVoyage1Array transient;
	voyage1Array.copy(copyVoyage1Array);
	
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
		
		idx2 := copyVoyage1Array.indexOf(ediText);
		if idx2 = 0 then
			failingFound := true;
			app.writeLog(idx.String &amp; Tab &amp; ediText, LogINFO);
		else
			copyVoyage1Array.removeAt(idx2);
		endif;
	endforeach;
	
	// display any errors
	if copyVoyage1Array.size &gt; 0 then
		failingFound := true;
		foreach ediText in copyVoyage1Array do
			app.writeLog(Tab &amp; ediText, LogINFO);
		endforeach;
	endif;
	self.assertEqual(failingFound, false);
	
epilog

	delete voyage1Array;
	delete voyage2Array;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete copyVoyage1Array;
	delete theLines;
end;</source>
        <Parameter name="_voyage1" type="CM_Voyage"/>
        <Parameter name="_voyage2" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xExtractedDataCorrectForVoyage" id="bdc57d5c-a9cf-415c-b978-2987a8efe286">
        <source>xExtractedDataCorrectForVoyage(_voyage1, _voyage2 : CM_Voyage; _correctExtractedData : StringArray512 io);

/*

Purpose:		Return the correct edi setup for the passed in voyage	

Date			Who		Reason
25/01/2013		cnwmh5	Initial creation

*/

vars

begin

	if _voyage1.code = "VOYSHIP30863_1" then
		self.xVOYSHIP30863_1Data(_correctExtractedData);
	elseif _voyage1.code = "VOYSHIP30863_4" and _voyage2.code = "VOYSHIP30863_5" then
		self.xVOYSHIP30863_4Data(_correctExtractedData);
	elseif _voyage1.code = "VOYSHIP30863_2" and _voyage2.code = "VOYSHIP30863_3" then
		self.xVOYSHIP30863_3Data(_correctExtractedData);
	elseif _voyage1.code = "VOYSHIP30863_4" and _voyage2.code = "VOYSHIP30863_6" then
		self.xVOYSHIP30863_4_AData(_correctExtractedData);
	endif;	
		
epilog

end;</source>
        <Parameter name="_voyage1" type="CM_Voyage"/>
        <Parameter name="_voyage2" type="CM_Voyage"/>
        <Parameter name="_correctExtractedData" type="StringArray512" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xLoadCCPlanOutbound" id="decf5015-490c-4ea6-9c2e-ef92752b12cc">
        <updating/>
        <source>xLoadCCPlanOutbound(_voyage : CM_Voyage io; _tisToPlan : CM_TIArray) updating;

/*

Purpose:			

Date			Who		Reason
11 February 2013	cnwmh5	Initial creation

*/

constants
	
vars
	
	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	location					: CM_ROROLocnDefn;
	locationGC					: CM_ROROGCDefn;
	location2					: CM_ROROSlotDefn;
	tempTI						: CM_TrackedItem;
	operator					: CM_Operator;
	realAlloc 					: CM_VoyageAllocation;
	voyageJob 					: CM_VoyageJob;
	bs							: CM_BlockStack;
	container					: CM_Container;
	moveController 				: CMIF_MoveController;
	lc							: CM_LocationsController;
	locnDefn					: CM_ROROLocnDefn;
	cargoType					: CM_CargoType;
	
	tiArray						: CM_TIArray;
	tisToPlanArray				: CM_TIArray;
	locationArray				: StringArray;
	roro20FTLCs 				: CM_LCArray;
	roro40FTLCs 				: CM_LCArray;
	roroLCs						: CM_LCArray;
	roroGCLCs					: CM_LCArray;
	altRoroLCs					: CM_LCArray;
	slotsToLoadCC				: StringArray;
	
	str							: String;
	count						: Integer;
	index						: Integer;

begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["2"];
	self.assertNotNull(deck);
	
	cargoType := self.getCargoType("CANNONBALL");
	self.assertNotNull(cargoType);
	
	// create a gc area
	roroStructure.createQuickCargoGC(null, cargoType, 64, -14, deck, 15);
	
	// create 20' and 40' OOTLs
	roroStructure.createQuickCargoOOTL(null, true, 64, 0.5, deck, 1);
	roroStructure.createQuickCargoOOTL(null, true, 64, 4.5, deck, 1);
	
	roroStructure.createQuickCargoOOTL(null, false, 83.5, .5, deck, 1);
	roroStructure.createQuickCargoOOTL(null, false, 83.5, 4.5, deck, 1);
	
	create tiArray transient;
	create locationArray transient;
		
	//locationArray.add("D2001G");
	locationArray.clear();
	locationArray.add("D2001G");
	locationArray.add("D2360O");
	locationArray.add("D2362O");
	locationArray.add("D2363O");
	locationArray.add("D2364O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		tiArray.clear();
		if location = null then
			locationGC := deck.allROROGCDefnByCode[str];
			locationGC.getAllTIs(REAL_MODE, tiArray, true);
		else
			location.getAllTIs(REAL_MODE, tiArray, true);
		endif;
		///app.writeLog(str &amp; Tab &amp; location.String, LogAlways);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
	endforeach;
	
	// setup load colour coding for 20' containers
	create altRoroLCs transient;
	altRoroLCs.clear();
	
	create roro20FTLCs transient;
	roro20FTLCs.clear();
	
	create slotsToLoadCC transient;
	slotsToLoadCC.add("D2363O1");
	slotsToLoadCC.add("D2364O1");
	slotsToLoadCC.add("D21201");
	slotsToLoadCC.add("D21202");
	slotsToLoadCC.add("D21211");
	
	
	foreach str in slotsToLoadCC do
		///app.writeLog(str, LogAlways);
		self.getJobROROControllerByID(_voyage.code, deck.code, null, str, roro20FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "GEN2", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro20FTLCs, altRoroLCs, 1);
	
	
	
	// setup load colour coding for 40' containers
	create roro40FTLCs transient;
	roro40FTLCs.clear();
	
	altRoroLCs.clear();
	
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D2360O1");
	slotsToLoadCC.add("D2362O1");
	slotsToLoadCC.add("D21081");
	slotsToLoadCC.add("D21091");
	
	foreach str in slotsToLoadCC do
		///app.writeLog(str, LogAlways);
		self.getJobROROControllerByID(_voyage.code, deck.code, null, str, roro40FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "GEN4", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro40FTLCs, altRoroLCs, 1);
	
	create roroGCLCs transient;
	altRoroLCs.clear();
	
	// setup load colour coding for GC area
	self.getJobROROGCController(_voyage.code, deck.code, roroGCLCs, true);
	
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", null, null, cargoType.id, false, false);
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roroGCLCs, altRoroLCs, 10);
	
	// setup the job
	create roroLCs transient;
	roro20FTLCs.copy(roroLCs);
	roro40FTLCs.copy(roroLCs);
	roroGCLCs.copy(roroLCs);
	
	voyageJob := self.addVoyageROROJob(_voyage, deck, "UT_30863Job1", roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	// plan the cargo to the respective slots
	locationArray.clear();
	locationArray.add("D2001G");

	roroLCs.clear();
	foreach str in locationArray do
		lc := _voyage.getLocationByID(str);
		roroLCs.add(lc);
	endforeach;
	
	realAlloc := roroLCs.first.getRequest(true).getVoyageAllocations().first.CM_VoyageAllocation;
	self.planTIsRORO(_tisToPlan, roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete roro20FTLCs;
	delete roro40FTLCs;
	delete roroLCs;
	delete altRoroLCs;
	delete slotsToLoadCC;
	delete locationArray;
	delete tiArray;
	delete tisToPlanArray;
	delete moveController;
	delete roroGCLCs;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_tisToPlan" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="xMoveTIsToVoyage_31119" id="bc70c1c6-e9b1-4f3f-bc4f-7564150b3b1b">
        <updating/>
        <source>xMoveTIsToVoyage_31119(_tisToMove : CM_TIArray) updating;

/*

Purpose:		Move the selected items to where they belong	

Date			Who		Reason
11/02/2013		cnwmh5	Initial creation

*/

vars
	
	tempTI						: CM_TrackedItem;
	plannedLocation				: CM_LocationsController;

begin

	foreach tempTI in _tisToMove do
		plannedLocation := tempTI.myPrimaryPlannedLocation;
		if plannedLocation = null then
			continue;
		endif;
		self.unplanTI(tempTI);
		self.assertNoTrxErrorsOrWarnings();
		self.deleteStops(tempTI);
		self.move(tempTI, plannedLocation);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_tisToMove" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="xPlanTranshipToMove_31119" id="5db97fa0-4bc0-4c7b-bab7-5037065ac34e">
        <source>xPlanTranshipToMove_31119(_voyage : CM_Voyage; _itemsToDischarge : CM_TIArray);

/*

Purpose:			

Date			Who		Reason
11 February 2013	cnwmh5	Initial creation

*/

constants

	BlockStackName				: String = "UTMHBS8";
	
vars
	
	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	operator					: CM_Operator;
	voyageJob 					: CM_VoyageJob;
	bs							: CM_BlockStack;
	lc							: CM_LocationsController;
	job							: CM_Job;
	req 						: CM_Request;
	wle 						: CM_WorkListEntry;
	tempTI						: CM_TrackedItem;
	
	roroLCs						: CM_LCArray;
	slotsToDiscCC				: StringArray;
	itemsToPlan					: StringArray;
	
	str							: String;

begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["2"];
	self.assertNotNull(deck);

	bs := self.addBlockStack(BlockStackName, 99, null);
	self.assertNotNull(bs);
	
	create slotsToDiscCC transient;
	slotsToDiscCC.add("D2001G");
	
	create roroLCs transient;
	beginTransaction;
	foreach str in slotsToDiscCC do
		app.writeLog(str, LogINFO);
		lc := _voyage.getLocationByID(str);
		if lc &lt;&gt; null then
			lc.CM_VoyageROROController.createDefaultDischargeCC(app.myPassport, true);
			roroLCs.add(lc);
		endif;
	endforeach;
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	// create a dishcarge job
	voyageJob := self.addVoyageROROJob(_voyage, deck, "UT_31119Job1", roroLCs, true);
	self.assertNotNull(voyageJob);
		
	lc := bs.allLocationsControllers.first;
	
	foreach job in _voyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null and _itemsToDischarge.includes(wle.myTrackedItem) then
					self.movePlannedWLE(wle.myTrackedItem, lc, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	// discharge the containers
	self.opts.purge;
	self.opts.addAssoc("Sleep", 5000);
	self.opts.addAssoc("WPOpHrs", 2);	//10 Apr 2012	NDL	Par 29369.
	self.expectedTrxErrors.clear();
	self.moveAllCargoOnVoyage(_voyage, REAL_MODE);
	
	
epilog

	delete roroLCs;
	delete slotsToDiscCC;
	delete itemsToPlan;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_itemsToDischarge" type="CM_TIArray"/>
    </JadeMethod>
