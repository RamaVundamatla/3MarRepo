	cmb.addItem(TODO_TYPE_GROUP_CARGOGROUP_STR);
	cmb.addItem(TODO_TYPE_GROUP_NONOPS_STR);
	
	if not _todotask then 						// ### TFS #56635[54261] 21NOV2022 NAVAB1
		cmb.addItem(TODO_TYPE_GROUP_ALL_STR);
	endif; 										// ### TFS #56635[54261] 21NOV2022 NAVAB1
	
	cmb.listIndex := cmb.findString(1,_type);
	self.cmbType_change(cmb);
