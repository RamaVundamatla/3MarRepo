    <JadeMethod name="isInUse" id="22e9729d-b9f3-47cb-a3f1-ebaff9bf425a">
        <source>isInUse(): Boolean;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
//				NOTE: Only checks grid controllers (lanes) not in use
//					  Does not check in transit in /out locations
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	controller	:CM_LocationsController;
begin
	foreach controller in self.allGridControllersByName do
		if controller.isYardLocation and
			controller.CM_YardController.hasVehicles then
			return false;
		endif;
	endforeach;

	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidAreaForRTMoveMethod" id="7d491d02-a928-4756-ac55-052c83d9cc05">
        <source>isValidAreaForRTMoveMethod(_rtMoveMethod: CM_RTMoveMethod; _isSource: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwer1	Initial creation

*/

vars
	machineTypeGrp : CM_MachineTypeGroup;
begin
	//ccms 1099 11/5/10  realised some of these don't make sense
	if _isSource then
		if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_LIFTER and
			 _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
			return false;
		endif;
		machineTypeGrp:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
		if _rtMoveMethod.allMachineTypeGroups.includes(machineTypeGrp) then
			return false;
		endif;
	else
		if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_LIFTER and
			 _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
			return false;
		endif;
			
		machineTypeGrp:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
		if _rtMoveMethod.allMachineTypeGroups.includes(machineTypeGrp) then
			return false;
		endif;
	endif;
	
	
	
	
	
	return true ;

epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyAddLaneController" id="e091ab56-c789-42e8-a478-20ab810f815c">
        <source>pxyAddLaneController(_row :CM_RoadRow; _col :CM_RoadColumn):CM_LaneController protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_LaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	_row.raiseExceptionIfNotTransient (method);
	_col.raiseExceptionIfNotTransient (method);
	
	create proxy as self.getLaneClass transient;
	
	proxy.setForProxy (PAD_AVAILABLE, NORMAL_USE, _row.row, _col.column, _row.row.String,
							2, false, false, null, self, false, null, false, null, false, null);
	
	proxy.setForProxyGridController(_row.row.String, _col, _row, 2);
	
	return proxy;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="CM_RoadRow"/>
        <Parameter name="_col" type="CM_RoadColumn"/>
        <ReturnType type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateDefaultLanes" id="4c219892-e4ee-4a2f-97ec-8cf442cd772c">
        <updating/>
        <source>pxyCreateDefaultLanes() abstract, updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
</source>
