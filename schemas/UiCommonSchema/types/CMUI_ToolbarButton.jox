    <JadeMethod name="mouseDown" id="28636564-474b-4890-aea5-54bed70fd2df">
        <updating/>
        <source>mouseDown(frame: CMUI_ToolbarButton input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	btn		: CMUI_ButtonForToolbar;

begin

	if button &lt;&gt; self.MouseButton_Left then
		return;
	endif;

	frame.drawButtonDown();
	if self.myButtonForToolbar &lt;&gt; null then
		self.myButtonForToolbar.mouseDown(self.myButtonForToolbar,button,shift,self.left + x,self.top + y);
	endif;
end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="283ac6ab-ff37-4684-a39b-a791ca90c22d">
        <updating/>
        <source>mouseEnter(frame: CMUI_ToolbarButton input) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.style &gt;= Button.Style_Auto2State and
	   self.myButtonForToolbar.value then
		// do nothing
	else
		frame.drawButtonUp();
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseLeave" id="ac215dbd-4ae3-4c14-a601-24eafd2ce2dc">
        <updating/>
        <source>mouseLeave(frame: CMUI_ToolbarButton input) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	btn		: CMUI_ButtonForToolbar;

begin
	btn := self.myButtonForToolbar;
	if self.style &gt;= Button.Style_Auto2State and
	   btn.value then
		// do not clear graphics
	else
		frame.clearGraphics();
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="3f1a4488-cb51-425d-a415-8a449d93e150">
        <updating/>
        <source>mouseUp(frame: CMUI_ToolbarButton input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	btn		: CMUI_ButtonForToolbar;

begin

	btn := self.myButtonForToolbar;

	if self.style &gt;= Button.Style_Auto2State and
	   btn.value then
		// do not clear graphics
	else
		frame.drawButtonUp();
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
