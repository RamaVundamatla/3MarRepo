    <JadeMethod name="getImportBOLNumbers" id="a3ff8943-978d-4ed0-acad-a99e262d07aa">
        <source>getImportBOLNumbers(_bols : StringArray input);
// 33880, 33881 populate the string array with all BOL numbers for on-site cargo
//  from both the explicit CM_BOLs and also the CM_TrackedItem.billOfLading text to get all bill of lading numbers
//		whether they have a BOL object or not.
vars
	bol	: CM_BOL;
	ti	: CM_TrackedItem;
	bolNumber	: String;
begin
	_bols.clear();
	foreach bol in self.allBOLInByTypeStatusNumDT do
		_bols.add(bol.number);
	endforeach;
	// 36613 also look at onship cargo
	foreach ti in self.allOnshipTIsByCargoTypeId do
		bolNumber := ti.billOfLading;
		if bolNumber &lt;&gt; null then
			if not _bols.includes(bolNumber) then
				_bols.add(bolNumber);
			endif;
		endif;
	endforeach;
	foreach ti in self.allOnsiteTIsByCargoTypeId do
		bolNumber := ti.billOfLading;
		if bolNumber &lt;&gt; null then
			if not _bols.includes(bolNumber) then
				_bols.add(bolNumber);
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_bols" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInPortStatusDescription" id="6fbfc483-6991-45ee-9203-99fde30ac664">
        <source>getInPortStatusDescription() : String;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	now : TimeStamp;
begin
	
	now := app.actualTimeServer;
	
	if self.arrivedDT.isValid() then
		if self.arrivedDT &lt;= now then
			// arrived
			if self.departedDT.isValid() then
				if self.departedDT &lt; now then
					return app.getErrorString(Sailed);
				else
					return app.getErrorString(In_Port);				
				endif;
			else
				// hasn't departed
				return app.getErrorString(In_Port);
			endif;
		else
			return app.getErrorString(To_Arrive);		
		endif;
	endif;
	
	// assume it hasn't arrived
	return app.getErrorString(To_Arrive);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
