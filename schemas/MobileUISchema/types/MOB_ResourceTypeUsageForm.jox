    <JadeMethod name="setupControls" id="78004f8a-6252-42ce-81ad-95436fb9ece3">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

begin

	
	
	self.setupTable();
	
	self.doResizeControls(true);
	
	self.btnUpdate.enabled := false;
	self.btnDelete.enabled := false;
	self.btnOne.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="460cfee5-fbf9-4d2f-b05c-83337f91f6e8">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	capString : String;
	desc : String;
	tmpTerminal	: CM_Terminal;
begin
	inheritMethod();
	
	self.setupCmdButtons(2, app.getErrorString(Save), app.getErrorString(Back), null,null,null);
	
	self.setupControls();
	
	capString := app.getErrorString(Resource_usage);
	
	tmpTerminal := self.myTerminal;
	if tmpTerminal &lt;&gt; null then
		capString := capString &amp; ' ' &amp; tmpTerminal.code;
		self.caption := capString; //_caption &amp; ' ' &amp; tmpTerminal.code;
	else
		self.caption := capString;// &amp; ' ' &amp; tmpTerminal.code;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="3bac2479-d240-47c6-86df-7ad1a7c86e3a">
        <source>setupTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	entTableDef		: EntTableDef;
	allEntTableRows : EntTableRowArray;
	entTableRow     : EntTableRow;
	colIndex 		: Integer;
begin
	
	self.tblResources.parentAspect:=Control.ParentAspect_StretchBoth;
	
	self.tblResources.fixedRows := 1;
	self.tblResources.rows := 1;
	self.tblResources.fixedColumns := 0;
	self.tblResources.userInputEnabled := false;
					 
	self.tblResources.fontName := "Tahoma";
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ToDoUsage];
	if entTableDef = null then
		return;
	endif;

	allEntTableRows := entTableDef.allEntTableRows;
	self.tblResources.columns := allEntTableRows.size;
	
	colIndex := self.tblResources.fixedColumns + 1;
	foreach entTableRow in allEntTableRows do
		if entTableRow.inputType &lt;&gt; Table.InputType_CheckBox then
			self.tblResources.accessColumn(colIndex).inputType := Table.InputType_None;
		else 
			self.tblResources.accessColumn(colIndex).inputType := entTableRow.inputType; 
		endif;
		 
		self.tblResources.accessColumn(colIndex).alignment := Table.Alignment_Center_Top;
		self.tblResources.accessCell(1,colIndex).text := entTableRow.getShortHeading(tblResources.myTerminologyCargoBOLType, tblResources.myTerminologyTerminal, app.myCurrentLocale);
		
		colIndex := colIndex + 1;
	endforeach;
	
	self.tblResources.selectMode := Table.SelectMode_WholeRows;
//	self.tblResources.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	
	self.tblResources.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
