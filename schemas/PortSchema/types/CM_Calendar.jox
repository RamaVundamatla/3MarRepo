    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="bda38191-26d6-4b40-9eba-bb9b503d49ae">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_CalendarCode then
		return self.code;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstCalendarDateForDay" id="e0683657-316c-4130-b643-e1c49bcf3e52">
        <source>getFirstCalendarDateForDay( _date : Date ):CM_CalendarDate;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation	Par 25530 / CCMS 1185

	to replace the direct lookup that used to exist when single key for holidays.

*/

vars

	calendarDate : CM_CalendarDate;
	
begin

	calendarDate := self.allCalendarDates.getAtKeyGeq( _date, null );
	if calendarDate &lt;&gt; null and calendarDate.date = _date then //cnwrd1 par 30567 10.10.12 sometimes its NOT a holiday!
		return calendarDate;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="CM_CalendarDate"/>
    </JadeMethod>
    <JadeMethod name="isCandidateCalendarDate" id="a37083e1-ee6e-4cd9-8d42-0180b50d4d85">
        <source>isCandidateCalendarDate(_dayNamesArray : StringArray; 
						_templateCalendarDate : CM_CalendarDate;
						_proposedDate : Date
						):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

	type : String;

begin

//	hookCodeConstant = HookType_CalendarDay;

	type := _templateCalendarDate.description;
	
	
	if _templateCalendarDate.dataSource = 0 then
		// Its a yearly type - we don't check anything on these
		return true;
		
	
		
	elseif _templateCalendarDate.dataSource = 1 then
		// Its a 'day of the week' type
		return _dayNamesArray[ _proposedDate.dayOfWeek ] = type;
		
	
		
	elseif _templateCalendarDate.dataSource = 2 then
		// Its a monthly type
		if type = app.getErrorString(First_day_of_month) then	// First Day of Month
			if _proposedDate.day &lt;&gt; 1 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_day_of_month) then	// Last Day of Month
			if ( ( _proposedDate + 1 ).Date.day ) &lt;&gt; 1 then
				return false;
			endif;
		elseif type = app.getErrorString(First_business_dom) then	// First Business Day of Month
			if _proposedDate &lt;&gt; _proposedDate.getFirstBusinessDayOfMonth then
				return false;
			endif;
		elseif type = app.getErrorString(Last_business_dom) then	// Last Business Day of Month
			if _proposedDate &lt;&gt; _proposedDate.getLastBusinessDayOfMonth then
				return false;
			endif;
		elseif type = app.getErrorString(First_monday_month) then	// First Monday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 1 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_monday_month) then	// Last Monday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 1 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_tuesday_month) then	// First Tuesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 2 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_tuesday_month) then	// Last Tuesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 2 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_wednesday_month) then	// First Wednesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 3 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_wednesday_month) then	// Last Wednesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 3 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_thursday_month) then	// First Thursday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 4 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_thursday_month) then	// Last Thursday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 4 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_friday_month) then	// First Friday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 5 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_friday_month) then	// Last Friday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 5 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_saturday_month) then	// First Saturday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 6 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_saturday_month) then	// Last Saturday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 6 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_sunday_month) then	// First Sunday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 7 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_sunday_month) then	// Last Sunday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 7 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		endif;
		
		return true;
	
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_dayNamesArray" type="StringArray"/>
        <Parameter name="_templateCalendarDate" type="CM_CalendarDate"/>
        <Parameter name="_proposedDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="cd5828bc-513c-4619-b0c9-d223040da891">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	prxCalendar		: CM_Calendar;
	year,			
	pxyYear			: CM_CalendarYear;
	pxyDate,			
	date			: CM_CalendarDate;
	completedOK		: Boolean;
	
begin
	prxCalendar := inheritMethod();
	
	prxCalendar.myDayType := self.myDayType;
	prxCalendar.myHookCode := self.myHookCode;
	
	foreach year in self.allCalendarYears do
		pxyYear := app.createUpdateProxy(year).CM_CalendarYear;
		pxyYear.setCalendar(prxCalendar);
	endforeach;
	
	prxCalendar.allTerminals.clear();
	self.allTerminals.copy( prxCalendar.allTerminals );

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return prxCalendar;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete prxCalendar;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="25306702-df12-4a62-8c33-3a523d8ec5cf">
        <updating/>
        <source>setForCreate(_pxyCalendar : CM_Calendar; _copyYearAndDates: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     create proxy with same calendar dates 
// ----------   ----------  --------------------------------------------------
vars
	pxyCalendar	: CM_Calendar;
	year,
	aYear		: CM_CalendarYear;
	aCalendarDate,
	date		: CM_CalendarDate;
begin

	pxyCalendar := _pxyCalendar;
	
	self.setForUpdate(pxyCalendar);

//	if is a copy being created then clone the dates from the copy (passed as proxy). 
	if _copyYearAndDates then 
		
		foreach year in pxyCalendar.allCalendarYears do 	
			aYear := year.cloneSelf(false);
			aYear.setCalendar(self);	
			foreach date in year.allCalendarDates do 	
				aCalendarDate := date.cloneSelf(false);
				aCalendarDate.setYear(aYear);
				aCalendarDate.setCalendar(self);
			endforeach;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_pxyCalendar" type="CM_Calendar"/>
        <Parameter name="_copyYearAndDates" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5618a5d3-3c92-47dd-af3b-fb9df16ad37c">
        <updating/>
        <source>setForUpdate(_pxyCalendar : CM_Calendar) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	term : CM_Terminal;
	pxyHookLink	: CM_HookLink;
	
begin

	self.code 					:= _pxyCalendar.code.trimBlanks;
	self.description 			:= _pxyCalendar.description.trimBlanks;
	
	//22 oct 2010	NDL	Par 25530
	self.hasEndTime := _pxyCalendar.hasEndTime;
	self.hasTime := _pxyCalendar.hasTime;
	self.myDayType := _pxyCalendar.myDayType;
	
	if _pxyCalendar.myHookCode &lt;&gt; null then
		pxyHookLink := _pxyCalendar.myHookLink;
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_pxyCalendar.myHookCode);
		endif;
	else
		if self.myHookCode &lt;&gt; null then
			self.myHookCode.logicallyDeleteMe();
		endif;
	endif;
	
	
	self.allTerminals.clear();
	_pxyCalendar.allTerminals.copy( self.allTerminals );
	
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="_pxyCalendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setMyHookCode" id="f7fe2c2c-28a8-47e7-aac6-ebecef2b9069">
