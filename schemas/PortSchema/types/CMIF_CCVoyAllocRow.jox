    <JadeMethod name="getTableRowDataDisplay" id="04c13588-e920-4473-9d4d-83d88614024d">
        <source>getTableRowDataDisplay( _nameCellColour : Integer output ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896
21 June 2013 	cnwdap1	PAR #31740 Changes to show actual Break-bulk numbers
*/

vars

	selected : String;		//ETRow_Selected
	name : String;			//ETRow_AllocName
	projected : String;		//ETRow_Projected
	varianceStr : String;	//ETRow_Variance
	tiExports : String;		//ETRow_MatchingTIsCollection
	tiRH : String;			// ETRow_NumRehandles
	tiSoB : String;			// ETRow_NumSoB
	tiTotal : String;		// ETRow_TotalActual
	ccExports : String;		// ETRow_ColourCodedExports
	ccRH : String;			// ETRow_ColourCodedRehandles
	ccSoB : String;			// ETRow_ColourCodedSobs
	ccTotals : String;		// ETRow_SlotRequests
	plannedTotals : String;// ETRow_SlotReqWithPlannedTIs
	returnString : String;
	size : Integer;
	subTotSize : Integer;
	variance : Integer;	
	ti: CM_TrackedItem;								// PAR #31740

begin

	selected := null;
	
	if self.myVoyageAllocation &lt;&gt; null then
		name := self.myVoyageAllocation.code;
		if self.myVoyageAllocation.projected20 = 0 then
			projected := null;
		else
			projected := self.myVoyageAllocation.projected20.zeroNotAllowed();
		endif;
		_nameCellColour := self.myVoyageAllocation.color;
	else
		name := null;
		projected := null;
	endif;
	
	//size := self.allActualCargoExports.size;						// PAR #31740
	foreach ti in self.allActualCargoExports do						// PAR #31740
		if ti.isBulkOrBreakBulkGeneric then							// PAR #31740
			size := size + ti.totalQuantity;						// PAR #31740
		else														// PAR #31740
			size := size + 1;										// PAR #31740
		endif;														// PAR #31740
	endforeach;														// PAR #31740
	subTotSize := size;
	tiExports := size.zeroNotAllowed();
	
	//size := self.allActualCargoRH.size;							// PAR #31740
	size := null;													// PAR #31740
	foreach ti in self.allActualCargoRH do							// PAR #31740
		if ti.isBulkOrBreakBulkGeneric then							// PAR #31740
			size := size + ti.totalQuantity;						// PAR #31740
		else														// PAR #31740
			size := size + 1;										// PAR #31740
		endif;														// PAR #31740
	endforeach;														// PAR #31740
	subTotSize := subTotSize + size;
	tiRH := size.zeroNotAllowed();
	
	//size := self.allActualCargoSoB.size;							// PAR #31740
	size := null;													// PAR #31740
	foreach ti in self.allActualCargoSoB do							// PAR #31740
		if ti.isBulkOrBreakBulkGeneric then							// PAR #31740
			size := size + ti.totalQuantity;						// PAR #31740
		else														// PAR #31740
			size := size + 1;										// PAR #31740
		endif;														// PAR #31740
	endforeach;														// PAR #31740
	subTotSize := subTotSize + size;
	tiSoB := size.zeroNotAllowed();
	
	variance := subTotSize - projected.Integer;
	if variance = 0 then
		varianceStr := null;
	else
		varianceStr := variance.zeroNotAllowed();
	endif;
	
	tiTotal := subTotSize.zeroNotAllowed();
	subTotSize := 0;
	
	size := self.getColourCodingExportSize();
	subTotSize := size;
	ccExports := size.zeroNotAllowed();
	
	size := self.getColourCodingRHSize();
	subTotSize := subTotSize + size;
	ccRH := size.zeroNotAllowed();
	
	size := self.getColourCodingSobSize();
	subTotSize := subTotSize + size;
	ccSoB := size.zeroNotAllowed();
	
	ccTotals := subTotSize.zeroNotAllowed();
	
	plannedTotals := allPlanned.size.zeroNotAllowed();
	
	returnString := selected  &amp; Tab &amp;		// ETRow_Selected
					name  &amp; Tab &amp;			// ETRow_AllocName
					projected  &amp; Tab &amp;		// ETRow_Projected
					varianceStr  &amp; Tab &amp;	// ETRow_Variance
					tiExports  &amp; Tab &amp;		// ETRow_MatchingTIsCollection
					tiRH  &amp; Tab &amp;			// ETRow_NumRehandles
					tiSoB  &amp; Tab &amp;			// ETRow_NumSoB
					tiTotal  &amp; Tab &amp;		// ETRow_TotalActual
					ccExports  &amp; Tab &amp;		// ETRow_ColourCodedExports
					ccRH  &amp; Tab &amp;			// ETRow_ColourCodedRehandles
					ccSoB  &amp; Tab &amp;			// ETRow_ColourCodedSobs
					ccTotals  &amp; Tab &amp;		// ETRow_SlotRequests
					plannedTotals;			// ETRow_SlotReqWithPlannedTIs
					
	return returnString;
	
epilog

end;</source>
        <Parameter name="_nameCellColour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleException1310" id="8cca1125-b7ea-40a8-99e0-1775bdc6748f">
        <source>handleException1310( _exc : Exception; _dupKey : Boolean output):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2012	cnwndl1	Initial creation	Par 30251

*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 1310 then
		if _exc.resumable then
			_dupKey := true;
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_dupKey" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="58dbd730-5e55-443b-aae6-827b1207e3ec">
        <updating/>
        <source>removeObject( _entTableRowName : String; _cmObject : CM_Object ) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	if _entTableRowName = ETRow_MatchingTIsCollection then
		self.allActualCargoExports.remove( _cmObject.CM_TrackedItem );
		
	elseif _entTableRowName = ETRow_NumRehandles then
		self.allActualCargoRH.remove( _cmObject.CM_TrackedItem );
		
	elseif _entTableRowName = ETRow_NumSoB then
		self.allActualCargoSoB.remove( _cmObject.CM_TrackedItem );
		
	elseif _entTableRowName = ETRow_SlotReqWithPlannedTIs then
		self.allPlanned.remove( _cmObject.CM_TrackedItem );
		
	elseif _entTableRowName = ETRow_ColourCodedExports then
		self.allColourCodingExports.remove( _cmObject.CM_Request );
		
	elseif _entTableRowName = ETRow_ColourCodedRehandles then
		self.allColourCodingRH.remove( _cmObject.CM_Request );
		
	elseif _entTableRowName = ETRow_ColourCodedSobs then
		self.allColourCodingSoB.remove( _cmObject.CM_Request );
		
	else
		return false;
		
	endif;
	
	self.setHasBeenUpdated( true );
	return true;

epilog

end;</source>
        <Parameter name="_entTableRowName" type="String"/>
        <Parameter name="_cmObject" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseDetails" id="277446ea-6804-4c29-9f56-de0f5f8a980e">
