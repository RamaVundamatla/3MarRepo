    <JadeMethod name="trxCreateEDIBOLIn" id="0303c816-7180-4fa5-9a9c-f063e88641f7">
        <updating/>
        <source>trxCreateEDIBOLIn(_intBOLIn:CMIF_BOLIn input; _ediData : CM_EDIData; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: cnwrs1 sept 2009
//--------------------------------------------------------------
// renamed ccms1845 cnwrs1 nov 2009
vars
	realBOL		: CM_BOLIn;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateBOLInFromCMIF(_intBOLIn, realBOL, _passport);
	
	if _passport.noErrors then //ccms1845
		app.myUtilityUA.utlSetEDIDataStatus(_ediData, CM_EDIFile.EDI_STATUS_DBLOADED, null);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <text>to be deleetd 
//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed</text>
        <Parameter name="_intBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIBOLInCusCar" id="c8312c94-57f6-492a-af1f-246a4d939a54">
        <updating/>
        <source>trxCreateEDIBOLInCusCar(_control : CMIF_TIUpdateController input; _ediData : CM_EDIData input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: dec 2005 cnwrs1
//--------------------------------------------------------------
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 2
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
constants
	NOBOLFOUND : Integer = 0; //no bol exists so create new
	FOUNDBOL : Integer = 1; // bol is being created so use it
	FOUNDOLDBOL : Integer = 2; // old bol found so ignore
vars
	intFaceBOLIn : CMIF_BOLIn;
	bolInArray: ObjectArray;
	ti : CM_TrackedItem;
	found : Integer;
	object : Object;
	obj : CM_Object;
	bolIn : CM_BOLIn;
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.myValCA.valEDIBayPlan(_control);
	app.myValCA.valTrackedItems(_control, _passport);
	
	endLoad;		// explicitly release any locks
	
	if _passport.noErrors then

		// Start the transaction
		beginTransaction;
	
	//  cmwrs1 June 2006 par 11961 ccms 1022
		app.myUtilityCA.utlCreateEDIBayPlanCusCar(_control, _ediData, _passport);	
	endif;
	create bolInArray transient;
//  cmwrs1 June 2006 par 11961 ccms 1022
	foreach ti in _control.myVoyage.allOnshipTIsByCargoTypeId do
		found := NOBOLFOUND;
		bolIn := _control.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, ti.billOfLading, null);
		if bolIn &lt;&gt; null and 
		   bolIn.number = ti.billOfLading then
			found := FOUNDOLDBOL;
			continue;
		endif;
		foreach object in bolInArray do
			intFaceBOLIn := object.CMIF_BOLIn;
			// check to see if the bol is already existing, if so give it a miss
			if intFaceBOLIn.bolNumber = ti.billOfLading then
				found := FOUNDBOL;
				break;
			endif;
		endforeach;
		if found = NOBOLFOUND then
			create intFaceBOLIn transient;
			intFaceBOLIn.bolNumber := ti.billOfLading;
			intFaceBOLIn.bolType := BOLType_GeneralBillOfLading;
			intFaceBOLIn.myTerminal := app.getMyTerminalDO_NOT_USE();
			intFaceBOLIn.myVoyage := _control.myVoyage;
			intFaceBOLIn.operatorCode := ti.operatorCode;
			intFaceBOLIn.myOperator := app.myRoot.allOperators[ti.operatorCode];
			intFaceBOLIn.transportMode := TI_TRANSMODE_SHIP;
			intFaceBOLIn.headerOnly := true;
			bolInArray.add(intFaceBOLIn);
		endif;
		if found &lt;&gt; FOUNDOLDBOL then			 
			intFaceBOLIn.allTrackedItems.add(ti);
		endif;
	endforeach;

	foreach object in bolInArray do
		intFaceBOLIn := object.CMIF_BOLIn;
		// Perform the operation
		app.myUtilityCA.utlCreateBOLInWithTIs(intFaceBOLIn, bolIn, _control, _passport);
		
		if not self.checkValidationWithPassport(_passport) then
			break;
		endif;
	endforeach;

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	delete bolInArray;
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIBayPlan" id="3936d298-f2af-4f61-8b19-02fa87fdc0b1">
        <updating/>
        <source>trxCreateEDIBayPlan(_ediData : CM_EDIData input; _ediTIs : CM_EDITIById; _control : CMIF_TIUpdateController input; _partialUpdate, _finalUpdate : Boolean; _passport : CM_Passport input) updating;
// cnwdvb1 25 February 2003 

// 04/09/2012	cnwcs5	par 30064 - use standard utl to set status.Changed CM_EDIData parameter to be real rather than proxy
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 2
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// 13 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
vars
	updateProgress	: Boolean;
	status 			: Integer;
	monitor : CMIF_Monitor;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _partialUpdate then
		// save off the monitor and put back in epilog
		monitor := _passport.myCMIFMonitor;
		_passport.setMyCMIFMonitor(null);
	endif;

	_passport.warningsAcknowledged := true;
	app.setContinueCMExceptions(true);
	_passport.setWarningsIgnored(true);

	updateProgress := (_passport.myCMIFMonitor &lt;&gt; null);
	
	app.myValCA.valEDIBayPlan(_control);
	app.myValCA.valTrackedItems(_control, _passport);
	
	endLoad;		// explicitly release any locks
	
	if _passport.noErrors then

		_passport.useTIDictDeferUpdate := true;
		_passport.useTITransactionDeferUpdate := true;
		
		// Long transaction so we want it to survive deadlock
		// Par 13004
		process.setPersistentDeadlockPriority(1);
	
		beginTransaction;
		app.myUtilityCA.utlCreateEDIBayPlan(_ediData, _ediTIs, _partialUpdate, _control, _finalUpdate, _passport);
	endif;
	
//	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
//		app.cmsAbortTransaction();
//		return;
//	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if not _partialUpdate and
			   _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad(false, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
//	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if not _partialUpdate and
	   _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad(false, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	_passport.setMyCMIFMonitor(monitor);
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediTIs" type="CM_EDITIById"/>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_partialUpdate" type="Boolean"/>
        <Parameter name="_finalUpdate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIBayPlanCusCar" id="04a9601e-afed-4c30-a052-7c2a3e019213">
        <updating/>
        <source>trxCreateEDIBayPlanCusCar(_control : CMIF_TIUpdateController input; _ediData : CM_EDIData input; _passport : CM_Passport input) updating;

//  cmwrs1 June 2006 par 11961 ccms 1022

vars
	updateProgress	: Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);

	updateProgress := (_passport.myCMIFMonitor &lt;&gt; null);
	
	app.myValCA.valEDIBayPlan(_control);
	app.myValCA.valTrackedItems(_control, _passport);
	
	endLoad;		// explicitly release any locks
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;
	app.myUtilityCA.utlCreateEDIBayPlanCusCar(_control, _ediData, _passport);	

	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);		
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIBayPlanPartial" id="735e11ee-88bc-4e99-8d02-07f200a14d6b">
        <updating/>
        <source>trxCreateEDIBayPlanPartial(_ediData : CM_EDIData; _passport : CM_Passport input) updating;
//
// 22 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
//
constants
	CommitDelay : Integer = 2000;	
vars
	planController : CM_VoyageEDIBayPlanController;
	updCntrl : CMIF_TIUpdateController;
	ediTI : CM_EDITrackedItem;
	lockedEDITI : CM_EDITrackedItem;
	poxyContainer : CM_TrackedItem;
	ediData : CM_EDIData;
	voyage : CM_Voyage;
	errorSet : CM_ErrorSet;
	status : Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	todoCount : Integer;
	done : Integer;
//	oldDone : Integer;
	planControllerIndex : Integer;
	gotLockException : Boolean;
	ediTISet : CM_EDITISet;
	error : CM_Error;
	invalidObject : Boolean;
	currentTIs : CM_TIByIdCargoTypeDict;
	futureMovePlanned : CM_FutureMovePlanned;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilLckExHandlerFlg(exception, 0, gotLockException, _passport);
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, gotLockException, _passport);
	on Exception do app.handleDeletedObject(exception, ediData.myBayPlanController, invalidObject);

	create errorSet transient;
	create ediTISet transient;
	create currentTIs transient;

	_passport.warningsAcknowledged := true;
	app.setContinueCMExceptions(true);
	_passport.setWarningsIgnored(true);
	app.setPassBackExceptions(false, false);

	ediData := _ediData;
	
	//	portHere := ediData.getMyTerminal().getConfig(PortDestCode).String;
	voyage := ediData.getMyTerminal().lookupVoyage(ediData.getVoyageCode, null, false);
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, ediData.getVoyageCode, null, null);
		return;
	endif;
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
	updCntrl.setMyUserObject(ediData);
	updCntrl.myVoyage := voyage;
	updCntrl.comment := ediData.getDescription();
	
	app.myValCA.valEDIBayPlan(updCntrl);
	if _passport.hasErrors() then
		// There is nothing in the set at this point... so why are we doing this?
		app.myPassport.addErrorsFromSet(errorSet);	//restore current errors back to
		return;
	endif;
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	// Long transaction so we want it to survive deadlock
	// Par 13004
	process.setPersistentDeadlockPriority(1);
	
	if ediData.myBayPlanController &lt;&gt; null  and
		ediData.myBayPlanController.getEDIStatus &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
		planController := ediData.myBayPlanController;
		foreach futureMovePlanned in planController.allPlannedFutureMoveEDIs do
			if futureMovePlanned.myTrackedItem &lt;&gt; null then
				currentTIs.add(futureMovePlanned.myTrackedItem);
			endif;
		endforeach;
	endif;
	
	beginTransaction;
	
	if planController = null then
		planController := updCntrl.myVoyage.createEDIBayPlan(updCntrl.comment[1:100], ediData);
		// in case we get a serious error straight up we need the plancontroller to be saved persistantly
		commitTransaction;
		beginTransaction;
	endif;
	
	planControllerIndex := planController.getMyEDIIndex();
	
	progressTS := app.actualTimeServer();			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	todoCount := ediData.allEDITrackedItems.size;
	done := null;
	ediData.updateProgress(progressTS, "Updating Bay Plan... "&amp;done.String&amp;'/'&amp;todoCount.String, todoCount, done, true, _passport);
	
	foreach ediTI in ediData.allEDITrackedItems do
		done := done + 1;
		ediData.updateProgress(progressTS, "Updating Bay Plan... "&amp;done.String&amp;'/'&amp;todoCount.String, todoCount, done, false, _passport);
		
		if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_DBLOADED then
			gotLockException := false;
			app.myPassport.hadDeadlock := false;
			
			poxyContainer := ediData.getMyTerminal().createTI(ediTI.myCargoType, true);
			ediTI.CM_EDIBayPlanTI.setProxy(poxyContainer, null, app.myPassport);
			
			app.myPassport.warningsAcknowledged := true;
			updCntrl.setMyUserObject(ediTI);
			ediTISet.add(ediTI);
			app.myUtilityCA.utlCreateEDIBayPlanPartial(poxyContainer, ediTI, updCntrl, planControllerIndex, currentTIs, _passport);
			
			foreach error in _passport.allErrorWarnings do
				if error.myUserObject = null then
					error.setMyUserObject(ediTI);
				endif;
			endforeach;
			
			app.myPassport.moveErrorsToSet(errorSet);
			poxyContainer.erase(NORMAL_ERASE);
			
			updCntrl.allTransientTIs.clear;
			updCntrl.allPersistentTIs.clear;
		endif;
		
		progressInt := app.actualTimeServer() - progressTS;					// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if ((progressInt.getMilliseconds &gt;= CommitDelay) or (todoCount = done)) then
			if not gotLockException then
				_passport.doDeferredUpdates();
			endif;
			
			if gotLockException then
				beginTransaction;
				foreach lockedEDITI in ediTISet do
					lockedEDITI.setStatus(CM_EDITrackedItem.EDI_STATUS_LOCKERROR);
					foreach error in _passport.allErrorWarnings do
						if error.myUserObject = null then
							error.setMyUserObject(lockedEDITI);
							break;
						endif;
					endforeach;
				endforeach;
				commitTransaction;
				_passport.clearDeferUpdatesCollections();
			else
				app.cmsCommitTransaction(_passport);
			endif;
			
			app.myPassport.warningsAcknowledged := true;
			progressTS := app.actualTimeServer();			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			ediTISet.clear();
			_passport.useTIDictDeferUpdate := true;
			_passport.useTITransactionDeferUpdate := true;
			beginTransaction;
		endif;
	endforeach;
	
	ediData.updateProgress(progressTS, "Updating Bay Plan... "&amp;done.String&amp;'/'&amp;todoCount.String, todoCount, done, true, _passport);
	
	app.myPassport.addErrorsFromSet(errorSet);	//restore current errors back to
	voyage.setRemarks(app.getErrorString(EDI) &amp; " #" &amp; planControllerIndex.String &amp; " " &amp; app.getErrorString(Message) &amp; " " &amp; app.getErrorString(Load) &amp; " " &amp; app.getErrorString(Completed), true);
	
	if app.myPassport.noErrors then
		planController.setEDIStatus(CM_EDIFile.EDI_STATUS_DBLOADED);
	else
		planController.setEDIStatus(CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	delete ediTISet;
	delete updCntrl;
	delete currentTIs;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDICompCon" id="e5a65334-85fd-4655-b4b5-979e03a2ed8b">
        <updating/>
        <source>trxCreateEDICompCon(_pxyObject : CM_EDIComparisonConfig; _realObject : CM_EDIComparisonConfig output; _passport : CM_Passport input) updating;
// ##### CR 64614 TASK 64643 NAVAB1 03JUL2024
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDICompCon(_pxyObject, _realObject, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyObject" type="CM_EDIComparisonConfig"/>
        <Parameter name="_realObject" type="CM_EDIComparisonConfig" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDICustomsStatusMessg" id="1fc47f12-65d3-478a-940f-b5484201961b">
        <updating/>
        <source>trxCreateEDICustomsStatusMessg(_proxyCustomsStatusMessage : CM_CustomsStatusMessage input; _newCustomsStatusMessage : CM_CustomsStatusMessage output; _ediData : CM_EDIData input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	26 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 2
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
vars
	iter : Iterator;
	ediAction : CM_EDIAction;
	ediActionName : String;
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Create the Customs Status Message
	app.myUtilityCA.utlCreateCustomsStatusMessage(_proxyCustomsStatusMessage, _newCustomsStatusMessage,  _passport); 

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				//cnwmc5 - 11 July 2014 - CCMS 2353 Penn
				app.myUtilityUA.utlCustomsStatusMessageAction(_newCustomsStatusMessage, _passport);
				if _passport.noErrors() then
					// use passport to get new status for EDI Data
					status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
					app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
				endif;
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
