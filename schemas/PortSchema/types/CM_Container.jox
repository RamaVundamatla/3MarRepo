//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	if set then
		app.raiseSetVirtualError(self.class.name, method.qualifiedName);
		
	else
		if self.myVGMDetails &lt;&gt; null then
			if self.myVGMDetails.myWeighAuthTerminal &lt;&gt; null then
