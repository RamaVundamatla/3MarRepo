    <JadeMethod name="isBlockStack" id="5bacbd18-fea8-4785-84f8-b1b7e98e7664">
        <methodInvocation>mapping</methodInvocation>
        <source>isBlockStack(set: Boolean; value: Boolean io) mapping;

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	value := false;
	
	if self.myTerminalArea = null then
		return;
	endif;
	if self.myTerminalArea.type &lt;&gt; TA_TYPE_STRADDLE_STACK
	and self.myTerminalArea.type &lt;&gt; TA_TYPE_FORK_LIFT_STACK 
	and self.myTerminalArea.type &lt;&gt; TA_TYPE_RTG then
		value := true;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
