// ---------------------------------------------------------------------------
// Created:     02 April 2008 by cnwrs2
//
// Purpose:     Used from Report Writer
// ---------------------------------------------------------------------------
/* 	Date		User	Reason
   ---------------------------------------------------------------------------
	19/05/2009	concms1	Par 19715 - Changed code to be compatible with changed collection keys
	06/06/2014	cnwdap1	PAR #34297 Cater for sites where no P-Gate Out exists
*/
vars
	detail	: CM_VehicleVisitRecordDetail;
begin
	detail := self.getLastGateOutVVRD;
	
	if detail &lt;&gt; null then
