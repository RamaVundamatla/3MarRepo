<Class name="DTO_User" id="a8c37fb3-7fdd-4be4-a7cd-14a80ec3b6d9">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="allTerminals" id="4c438688-a3d8-4350-a5ab-d8446cbdeddd">
        <memberTypeInverse/>
        <type name="DTO_TerminalArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="1e75160e-170a-44f0-b1ca-47d86474caa1">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allTerminals.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFromPersistent" id="a40b4090-a293-4fe3-bbff-9953d1402eca">
        <updating/>
        <source>setFromPersistent(_user: CM_User) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpUserTerminal	: CM_UserTerminal;
	dtoTerminal		: DTO_Terminal;
	
begin

	foreach tmpUserTerminal in _user.allUserTerminals do
		create dtoTerminal transient;
		self.allTerminals.add(dtoTerminal);
		dtoTerminal.setFromPersistent(tmpUserTerminal.getRealTerminal);
	endforeach;

	inheritMethod(_user);
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
</Class>
