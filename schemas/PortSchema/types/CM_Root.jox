    <JadeMethod name="getQryReport" id="65e2b2ec-db1f-44b8-858b-b938447a6e09">
        <source>getQryReport(_name: String): CM_QryReport;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	menuItemDict				: CM_MenuItemByTypeMenuIdDict;
	menuItem					: CM_MenuItem;
	qryReport					: CM_QryReport;
begin
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;
		
		if menuItem.CM_QryReport.reportName = _name then
			qryReport := menuItem.CM_QryReport;
			break;
		endif;
	endforeach;
	
	return qryReport;	
	

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="getQryReportsOfType" id="f042e10d-ed4e-4758-85e0-fb889ab079d6">
        <source>getQryReportsOfType(_dict : Collection input; _reportType : Integer);
// ---------------------------------------------------------------------------
// Created:     28 February 2003		cnwth2	
//
// Purpose:     Pass in null to retreive all user reports		 
// ----------   ----------  --------------------------------------------------
vars
	iter		: Iterator;
	menuItem	: CM_MenuItem;
begin

	_dict.clear;
	iter := self.myReportMenuRoot.allMenuItems.createIterator();
	self.myReportMenuRoot.allMenuItems.startKeyGeq(MenuType_DetailSystem, null, iter);
	
	while iter.next(menuItem) do
		if (not CM_QryReport.hasInstance(menuItem)) then //filters out menu headers (folder objects)
			continue;
		endif;
		
		if _reportType &lt;&gt; null then
			if menuItem.CM_QryReport.reportType &lt;&gt; _reportType then
				continue;
			endif; 
		else
			if (not CM_QryReportUser.hasInstance(menuItem)) then
				continue;
			endif;
		endif;
		
		_dict.add(menuItem);
	endwhile;

epilog
	delete iter;

end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
