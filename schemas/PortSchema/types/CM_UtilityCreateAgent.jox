    <JadeMethod name="utlCreateOperator" id="24d14ba5-5dca-4b56-8958-a5b56c9f19d7">
        <source>utlCreateOperator(pProxyOperator:CM_Operator; _cmifConfigOperator : CMIF_ConfigOperator input; 
			pNewOperator:CM_Operator output;
			_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valOperator(pProxyOperator);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewOperator as pProxyOperator.class persistent;
	pNewOperator.setForCreate(pProxyOperator, _passport);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewOperator);
	endif;
	
	if _cmifConfigOperator &lt;&gt; null then
		_cmifConfigOperator.updatePersistentObject(pNewOperator, _passport);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		pNewOperator.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
											 BGP_OpsViewWSRequest.OPS_TYPE_OPERATOR,
											 pNewOperator);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
        <Parameter name="pProxyOperator" type="CM_Operator"/>
        <Parameter name="_cmifConfigOperator" type="CMIF_ConfigOperator" usage="input"/>
        <Parameter name="pNewOperator" type="CM_Operator" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
