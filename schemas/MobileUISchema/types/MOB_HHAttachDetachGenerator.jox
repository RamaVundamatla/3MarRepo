    <JadeMethod name="populateTrackedItem" id="1c0f3198-a9fb-4837-80a4-53283ed74926">
        <updating/>
        <source>populateTrackedItem()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/
vars
	date :TimeStamp;
	time : Time;
	errorMsg		: String;
begin

	date 	:= self.systemToLocalTime(app.actualTimeServer());
	self.txtDate.setDate(date.date());
	self.txtTime.setTime(date.time());

	if self.myTrackedItem &lt;&gt; null then
		if  self.myTrackedItem.isKindOf(CM_Container) or self.myTrackedItem.isKindOf(CM_TILC) then
			
			if self.myTrackedItem.isKindOf(CM_Container) and not self.myTrackedItem.isReefer then
				errorMsg := app.getErrorString1(Container_not_reefer,self.myTrackedItem.id);
				if errorMsg &lt;&gt; null then
					app.msgBox(errorMsg, app.getErrorString(Error), 0);
					self.txtCargoId.setFocus();	
					return;
				endif;
			endif;
			self.txtCargoId.text := self.myTrackedItem.id;
			if self.myTrackedItem.getGeneratorId &lt;&gt; null then
				self.isAttach := false;
				self.txtGenerator.text := self.myTrackedItem.generatorId;			
				self.myGenerator := self.myTrackedItem.getGenerator;
				self.showHideControls(false,false);
			else
				self.isAttach := true;
				self.txtGenerator.text := self.lblGeneratorId.caption.toUpper;
				self.txtLocation.text := self.myTrackedItem.locationId;
	           self.showHideControls(false,true);
			endif;
		else
			errorMsg := app.getErrorString1(Cargo_not_reefer_trailer,self.myTrackedItem.id);
			if errorMsg &lt;&gt; null then
				app.msgBox(errorMsg, app.getErrorString(Error), 0);
				self.txtCargoId.setFocus();	
			endif;
		endif;
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.txtGenerator.text := self.lblGeneratorId.caption.toUpper;
	endif;
	
	if self.isAttach then
		self.btnOne.caption := app.getErrorString(Attach);
	else
		self.btnOne.caption := app.getErrorString(Detach);
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="604ff0ed-47ee-43bc-bc53-dd6a8cd74b8c">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/
	vars	
cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	
		app.myMobileCargoFindAgent.setPreventSiteChange(true); 
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyGenerator" id="214a31b5-a666-4613-bef0-eaf3830fa42c">
        <updating/>
        <source>setMyGenerator(_generator : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin

	self.myGenerator := _generator;
