    <JadeMethod name="hasWharfLockout" id="3532c838-05e1-46a9-b9e6-f408ad485f52">
        <source>hasWharfLockout(_fromDate, _toDate : TimeStamp; _lockedTo : TimeStamp output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     31 March 2008 by cnwrs2
//
// Purpose:     Checks if this berth has a wharf lockout that covers the passed in date
//				range.  If so then returns true and the date/time the wharf lockout ends
//				(i.e. the time the berth is then available
// ---------------------------------------------------------------------------
vars
	tmpLockout	: HMS_WharfLockout;
	tmpWharf	: HMS_Wharf;
	rtnValue	: Boolean;
begin

	_lockedTo := null;

	tmpWharf := self.myWharf;
	if tmpWharf = null then
		return false;
	endif;

	foreach tmpLockout in tmpWharf.allWLockoutsByBothDT 
	where tmpLockout.startOfLockoutDT &lt; _toDate
	and tmpLockout.endOfLockoutDT &gt; _fromDate do
		
		if (tmpLockout.startMarkOnWharf &lt; self.getBerthEndPosition()) and
		   (tmpLockout.endMarkOnWharf &gt; self.startPosition) then
			// this lockout covers this berth
			rtnValue := true;
			
			if tmpLockout.endOfLockoutDT &gt; _lockedTo then
				_lockedTo := tmpLockout.endOfLockoutDT;
			endif;
		endif;

	endforeach;	
	
	return rtnValue;
	
end;</source>
        <Parameter name="_fromDate" type="TimeStamp"/>
        <Parameter name="_toDate" type="TimeStamp"/>
        <Parameter name="_lockedTo" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="b9a1a340-4f68-4155-a399-fda9bd825e5e">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4ArgoQuay	:	CMIF_ArgoQuay;
	terminal	: 	CM_Terminal;
begin
	if _opsViewTable.isKindOf(CMIF_ArgoQuay) then
		if self.getHarbour() &lt;&gt; null then
			terminal := self.getHarbour().getMyTerminal();
		endif;	
		n4ArgoQuay					:=	_opsViewTable.CMIF_ArgoQuay;
		n4ArgoQuay.gkey				:= n4ArgoQuay.generateFullGKey(self, "");
		n4ArgoQuay.id 				:= self.code[1:12];
		n4ArgoQuay.facility_gkey	:= n4ArgoQuay.generateFullGKey(terminal, "");
		n4ArgoQuay.name           	:= self.description[1:35];
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isBerthOccupied" id="0e31b727-1158-4597-a47e-dd4926c8a515">
        <source>isBerthOccupied(_checkTime : TimeStamp; _departureTime : TimeStamp output;_movement : HMS_Movement) : HMS_Movement;
//-----------------------------------------------------------------------
//	Returns true if there is a vessel at the berth for the passed in timestamp
//	and movement &lt;&gt; _movement passed in
//	Assumption is only one vessel on a berth at a time
//	_departureTime is the time that the current vessel will leave the berth
//-----------------------------------------------------------------------
vars
	movement	: HMS_Movement;
	moveDict	: HMS_MovementByDateDict;
	iter 		: Iterator;
	movementFound : Boolean;
begin
// getAllVoyageMovements is keyed by myBerth because most departures berth is only a logical berth we really won't see many departures
	moveDict := self.getAllVoyageMovements();
	iter 		:=moveDict.createIterator;
	moveDict.startKeyLeq(_checkTime,iter);
	while iter.back(movement) do
		if movement = _movement then
			continue;
		endif;
		movementFound:=true;
		break;
	endwhile;
	
	// get most recent movement associated with the berth
	//movement := moveDict.getAtKeyLeq(_checkTime);
	
	if not movementFound then
		// no movement found so must be unoccupied
		return null;
	endif;
	
	_departureTime:=movement.getDepartureTimeFromBerth(self);
	if _departureTime &lt; _checkTime then
		return null;
	endif;
	
	return movement;
epilog
	delete iter;
end;</source>
        <Parameter name="_checkTime" type="TimeStamp"/>
        <Parameter name="_departureTime" type="TimeStamp" usage="output"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
