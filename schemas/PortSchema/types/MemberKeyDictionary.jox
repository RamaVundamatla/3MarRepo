<CollClass name="MemberKeyDictionary">
    <JadeMethod name="includesObject" id="49e8975a-27ff-4976-adc9-c5d7ce1e072a">
        <source>includesObject(_obj : MemberType) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="fc73dba9-374c-4e29-9efb-053477439d6b">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     Removes _obj from the dict.  Finds it by iteration as
//				if the keys have changed the normal remove will not
//				find the object.
// ---------------------------------------------------------------------------
vars

begin
	// need to reimplement on each sub-class as the only way to remove the
	// object is to iterate through the dict, find the keys, and remove the
	// object using these keys.
	// refer to JADE PAR/NFS 34120 - if this par is implemented than may not need this
	app.raiseUnexpectedProgramError(class.name, method.name, 'You need to reimplement this method on the class');
	return false;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateObject" id="90ddadba-fee1-433a-b158-e338f28eb18e">
        <lockReceiver/>
        <updating/>
        <source>updateObject(_obj: MemberType): Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     If _obj is in the dict it removes and re-adds it (to force and
//				update of the keys
// ---------------------------------------------------------------------------
vars

begin
	if self.removeObject(_obj) then
		self.add(_obj);
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
