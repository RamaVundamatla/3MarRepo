    <JadeMethod name="attributesMatchForX12" id="f06740b9-a623-47e9-89b5-47d998e4acc0">
        <source>attributesMatchForX12(_code, _name, _description,_actionType, _stopHeading, _keyFileSegment :String): Boolean;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 February 2009
//
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
// Method to check whether a CM_EDIAction object matches the values that have 
// been passed in from a CSV file.  
// We can have duplicate edi actions but we don't want to create them automatically.
//----------------------------------------------------------------------
vars

begin
	return self.keyword = _code and
		   self.description	= _description and
		   self.actionType = _actionType and
		   self.keyFileSegment = _keyFileSegment and	//26 Sep 2018	NDL	TFS 40940
		   self.getDataDisplay() = _stopHeading;
epilog
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_actionType" type="String"/>
        <Parameter name="_stopHeading" type="String"/>
        <Parameter name="_keyFileSegment" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
