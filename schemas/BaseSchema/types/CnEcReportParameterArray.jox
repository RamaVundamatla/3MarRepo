    <DbClassMap file="baserep"/>
    <JadeMethod name="addParameter" id="d95b7d9e-7b72-45a3-b473-7fc2b6f08017">
        <lockReceiver/>
        <updating/>
        <source>addParameter(	pReportDefinition:CnEcReportDefinition;
				pParameterName:String;
				pDisplayValue:String;
				pSequence:Integer;
				pParameterType:String;
				pHasValueList:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		07 August 2000 by cnwdad1
//
// Purpose:		Creates a report parameter object and adds it to the receiver.
//
// Parameters:	pReportDefinition - The owning report definition object.
//				pParameterName - The report parameter name.
//				pDisplayValue - The para,eter display value.
//				pSequence - The parameter sequence number.
//				pParameterType - The parameter value type.
//				pHasValueList - True if the parameter has a value list.
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportParameter	: CnEcReportParameter;
	
begin
	create reportParameter transient;
	reportParameter.initializeMe(pReportDefinition, pParameterName, pDisplayValue, pSequence, pParameterType, pHasValueList);
	self.add(reportParameter);
end;</source>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pDisplayValue" type="String"/>
        <Parameter name="pSequence" type="Integer"/>
        <Parameter name="pParameterType" type="String"/>
        <Parameter name="pHasValueList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d513dcaf-a463-4500-b5da-25648083a7ac">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Purpose:		Purges the receiver's member report parameter objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
</CollClass>
