    <JadeMethod name="erase" id="10844f95-1e1f-4310-958d-519f69d7ef00">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	subQueue : CM_RadioTelemetryQueue;
begin
	foreach subQueue in self.allSubQueues do
		subQueue.erase(_eraseLevel);
	endforeach;
	foreach subQueue in self.allSubRTQueues do
		subQueue.erase(_eraseLevel);
	endforeach;
	
	self.allRTGBaysByAreaColumn.purge();
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllRTGColumnsInLane" id="8f753fe7-fb0a-464c-b205-008f40a5882a">
        <source>getAllRTGColumnsInLane( _allRTGColumns :  CM_RTGColumnByAreaIdColDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
	rtgArea : CM_RTGArea;
begin
	
	foreach ta in self.allTAsByTypeId discreteLock do
		rtgArea:=ta.CM_RTGArea;
		
		rtgArea.allGridColumns.copy( _allRTGColumns);
	
	endforeach;
epilog

end;</source>
        <Parameter name="_allRTGColumns" type="CM_RTGColumnByAreaIdColDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColumnsBetweenCols" id="ec0a6e48-1b8e-44c2-951f-897e96ea9c5c">
        <source>getColumnsBetweenCols(_startCol, _endCol : CM_GridColumn input; _allRTGColumns :  ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2013	cnwer1	Initial creation Par 31523

*/

vars

	ta : CM_TerminalArea;
	startTAIndx , endTAIndx ,idx: Integer; 
	iter : Iterator;
	gridCol, firstCol , lastCol: CM_GridColumn;
	firstTA : CM_GridArea;
	lastTA : CM_GridArea;
begin

	
	if _startCol= _endCol then
		return;
	endif;
	
	if  _startCol.myGridArea = _endCol.myGridArea then
		return;
	endif;
		
	startTAIndx:= self.allTAsByTypeId.indexOf(_startCol.myGridArea);
	endTAIndx:=self.allTAsByTypeId.indexOf(_endCol.myGridArea);

	if startTAIndx &lt; endTAIndx then
		firstTA:=_startCol.myGridArea;
		firstCol:=_startCol;
		lastTA:=_endCol.myGridArea;
		lastCol:=_endCol;
	else
		firstTA:=_endCol.myGridArea;
		firstCol:=_endCol;
		lastTA:=_startCol.myGridArea;
		lastCol:=_startCol;
	endif;
	
	iter:=self.allTAsByTypeId.createIterator;
	iter.startAtObject(firstTA);
	idx := 1;
	while iter.next(ta) do
		if ta =  firstTA then
			ta.CM_GridArea.getColumnsBetweenCols(firstCol,ta.CM_GridArea.allGridColumns.last,_allRTGColumns);
		elseif ta = lastTA then
			ta.CM_GridArea.getColumnsBetweenCols(ta.CM_GridArea.allGridColumns.first,lastCol,_allRTGColumns);
		else
			ta.CM_GridArea.allGridColumns.copy(_allRTGColumns);
		endif;
		if idx = startTAIndx.max(endTAIndx) then
			break;
		endif;
			
		idx:=idx+1;
	endwhile;
	
	
epilog
	delete iter;
end;</source>
        <Parameter name="_startCol" type="CM_GridColumn" usage="input"/>
        <Parameter name="_endCol" type="CM_GridColumn" usage="input"/>
        <Parameter name="_allRTGColumns" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d2aa1cbe-74cd-41f0-8ab7-b52fefdf198c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwer1	Initial creation

*/

vars

	rtQueue : CM_SubQueue;
begin
	if _attrName = ETRow_TaAreas then
		return self.allTAsByTypeId.listString(',',CM_TerminalArea::id.name);
	elseif _attrName = ETRow_HasMap then // ### TFS CR 58499 TASK 61458 03JAN2024 NAVAB1
		return "";
	elseif _attrName = ETRow_FileName then // ### TFS CR 58499 TASK 61458 03JAN2024 NAVAB1
		return "";
	elseif _attrName = ETRow_AutoCreateRTQueues then
		return null;//(self.getLaneRTQueue &lt;&gt; null).asStringJMT;
	elseif _attrName = ETRow_QueueName then
		rtQueue:=self.getLaneRTQueue;
		if rtQueue &lt;&gt; null then
			return rtQueue.id;
		endif;
	elseif _attrName = ETRow_Rows then
		if self.allTAsByTypeId.size = 0 then
			return "";
		else
			return self.allTAsByTypeId.first.CM_RTGArea.numberOfRows.asStringJMT;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeightOfStack" id="20fa4db3-2255-4e44-924c-98d37e54fb9e">
        <source>getHeightOfStack() : Integer;
// ---------------------------------------------------------------------------
// Created:		15 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//epr 11/8/09 ccms 1076 rtg lanes won'y have bays anymore
	if self.allTAsByTypeId.size = 0 then
		return 1;
	else
		return self.allTAsByTypeId.first.CM_RTGArea.heightOfStack;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLaneRTQueue" id="9a108734-3a90-4628-8c76-892782d81e8e">
        <source>getLaneRTQueue(): CM_SubQueue;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwer1	Initial creation

*/

vars
	rtQueue : CM_RadioTelemetryQueue;
	queueColl : CM_RTQueueSet;
	realRTGLane : CM_RTGLane;
begin

	if self.isTransient then
		realRTGLane:=app.myProxyManager.getRealObject(self).CM_RTGLane;
		if realRTGLane = null then
			return null;
		endif;
		queueColl:=	realRTGLane.allSubRTQueues;
	else
		queueColl:=	self.allSubRTQueues;
	endif;
		
	foreach rtQueue in queueColl do
		if not rtQueue.isKindOf(CM_SubQueue) then
			continue;
		endif;
		if not rtQueue.queueType = QTYPE_RTG then
			continue;
		endif;
		return rtQueue.CM_SubQueue;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
