    <JadeMethod name="convertBaseToTarget" id="ef643f7b-6642-40b7-b724-f9bb380ec5d7">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;

begin
	if pUnitTo = self.GRAINS_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure * 70157;
	
	elseif pUnitTo = self.GRAINS_PER_GALLON_US then
		convertedMeasure	:=	pMeasure * 58418;
	
	elseif pUnitTo = self.GRAMS_PER_CUBIC_CENTIMETRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.GRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.GRAMS_PER_MILLILITRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.KILOGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.KILOGRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.MEGAGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure * 1000000;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_MILLILITRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.OUNCES_PER_CUBIC_INCH then
		convertedMeasure	:=	pMeasure / 1.729994044;
	
	elseif pUnitTo = self.OUNCES_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure / 0.006236023;
	
	elseif pUnitTo = self.OUNCES_PER_GALLON_US then
		convertedMeasure	:=	pMeasure / 0.007489152;
	
	elseif pUnitTo = self.POUNDS_PER_CUBIC_FOOT then
		convertedMeasure	:=	pMeasure / 0.016018463;
	
	elseif pUnitTo = self.POUNDS_PER_CUBIC_INCH then
		convertedMeasure	:=	pMeasure / 27.679905;
	
	elseif pUnitTo = self.POUNDS_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure / 0.099776373;
	
	elseif pUnitTo = self.POUNDS_PER_GALLON_US then
		convertedMeasure	:=	pMeasure / 0.119826427;
	
	elseif pUnitTo = self.TONNES_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.TONS_UK_PER_CUBIC_YARD then
		convertedMeasure	:=	pMeasure / 1.328939184;
	
	elseif pUnitTo = self.TONS_US_PER_CUBIC_YARD then
		convertedMeasure	:=	pMeasure / 1.186552843;
	
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Density to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="0934e4af-1629-4e8b-bf58-a1ec6719bbe7">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;

begin
	if pUnitFrom = self.GRAINS_PER_GALLON_UK then
		convertedMeasure	:=	self.measure / 70157;
	
	elseif pUnitFrom = self.GRAINS_PER_GALLON_US then
		convertedMeasure	:=	self.measure / 58418;
	
	elseif pUnitFrom = self.GRAMS_PER_CUBIC_CENTIMETRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.GRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.GRAMS_PER_MILLILITRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.MEGAGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure / 1000000;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_MILLILITRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.OUNCES_PER_CUBIC_INCH then
		convertedMeasure	:=	self.measure * 1.729994044;
	
	elseif pUnitFrom = self.OUNCES_PER_GALLON_UK then
		convertedMeasure	:=	self.measure * 0.006236023;
	
	elseif pUnitFrom = self.OUNCES_PER_GALLON_US then
		convertedMeasure	:=	self.measure * 0.007489152;
	
	elseif pUnitFrom = self.POUNDS_PER_CUBIC_FOOT then
		convertedMeasure	:=	self.measure * 0.016018463;
	
	elseif pUnitFrom = self.POUNDS_PER_CUBIC_INCH then
		convertedMeasure	:=	self.measure * 27.679905;
	
	elseif pUnitFrom = self.POUNDS_PER_GALLON_UK then
		convertedMeasure	:=	self.measure * 0.099776373;
	
	elseif pUnitFrom = self.POUNDS_PER_GALLON_US then
		convertedMeasure	:=	self.measure * 0.119826427;
	
	elseif pUnitFrom = self.TONNES_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.TONS_UK_PER_CUBIC_YARD then
		convertedMeasure	:=	self.measure * 1.328939184;
	
	elseif pUnitFrom = self.TONS_US_PER_CUBIC_YARD then
		convertedMeasure	:=	self.measure * 1.186552843;
	
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Density to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
