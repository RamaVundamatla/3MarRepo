        <source>showVBSEnhancedAssociateForm(_form : CM_BaseForm; _vvr : CM_VehicleVisitRecord; _bulkRelease : CM_BulkRelease) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS - On Schedule

*/

vars
	vbsEnhancedAssociateForm : CMUI_VBSEnhancedAssociateForm;
begin
	
	create vbsEnhancedAssociateForm transient;
	
	if vbsEnhancedAssociateForm &lt;&gt; null then
		vbsEnhancedAssociateForm.setParentForm( _form );
		vbsEnhancedAssociateForm.setMyVehicleVisitRecord(_vvr);
		vbsEnhancedAssociateForm.setMyReleaseRequest(_bulkRelease);
		vbsEnhancedAssociateForm.showModal();
	endif;
	
	return vbsEnhancedAssociateForm.modalResult;
				
epilog
	delete vbsEnhancedAssociateForm;
end;</source>
