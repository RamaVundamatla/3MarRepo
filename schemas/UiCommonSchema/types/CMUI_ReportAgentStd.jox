    <JadeMethod name="doCmbCompanyClick" id="0f729f07-aa7a-4eb6-bd8e-dd94cea1fcfe">
        <source>doCmbCompanyClick(_company : CM_Bank; 
				  _cmbInvoiceTypes : CMUI_ComboBox input);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		26 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
//----------------------------------------------------------------------
vars

begin
	self.doLoadInvoiceType(_cmbInvoiceTypes, null, _company); //Reset the invoice type combo.
	
	if self.myCmbServiceGroup &lt;&gt; null then //cnwrd1 par 23583 11.8.2010
		self.doLoadServiceGroup( self.myCmbServiceGroup, _company,null);
	endif;
	
	if self.myCmbService &lt;&gt; null then
		self.doLoadServices( self.myCmbService , _company , null,null);
	endif;
	
	if self.myCmbInvoiceStatus &lt;&gt; null then  // TFS 39618 PATCH 1 
		self.doLoadInvoiceStatus(self.myCmbInvoiceStatus,null,_company);  // TFS 39618 PATCH 1 
	endif;
	
	if self.myCmbInvoiceLineType &lt;&gt; null then // 20/04/2023	navkc1	CR 55654 Task 55670
		self.doLoadInvoiceLineType(self.myCmbInvoiceLineType, null, _company);
	endif;
	
epilog
end;</source>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_cmbInvoiceTypes" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
