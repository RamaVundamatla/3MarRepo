/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wod : CM_WorkOrderToDoDtl;
begin
	
	wod := self.myWorkOrderDtlToDo;
	
	if wod &lt;&gt; null and wod.allToDoTasksDescs.isNotEmpty() then
