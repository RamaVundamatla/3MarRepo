        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars

begin
	self.frmROROTB.showCaptions := _showCaptions;
	self.frmTBDeckItems.showCaptions := _showCaptions;
	
	inheritMethod(_showCaptions);

	self.tblDeckItems.top:=self.frmTBDeckItems.top + self.frmTBDeckItems.clientHeight;
	self.tblDeckItems.height:=self.shtDeckItems.clientHeight - self.tblDeckItems.top;
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="63e10db8-4760-4f52-9381-ae58d7309a93">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015313, locale);
	btnCopyDeck.translateBubbleHelp(Xlat_0015314, locale);
	btnCopyDeck.translateCaption(Xlat_0015315, locale);
	btnDelDeckItem.translateBubbleHelp(Xlat_0016563, locale);
