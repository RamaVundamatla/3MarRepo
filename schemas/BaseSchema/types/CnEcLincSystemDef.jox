    <JadeMethod name="getCurrentConnectionState" id="9adfa542-35d8-4cea-addf-322dd1dc6e0f">
        <source>getCurrentConnectionState();
/*******************************************************
*
* Description : cause an event that the connection can respond to
* 
* Parameters :	
*
* Return :		None
*
* History :		pjs	29/01/97	Initial version
*
*******************************************************/

begin
	// all we need to do here is cause an event that the transient connection
	// instance has subscribed to

	causeEvent(HCS_Get_Connection_State, true, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="initDiagnosticOptions" id="2e8f0d60-ed0c-4577-85fa-b7ce49623276">
        <updating/>
        <source>initDiagnosticOptions() updating;

vars
    count : Integer;
    
begin
	count := 0;

	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	while count &lt; Diagnostic_option_count do
		count := count + 1;

		diagnosticLogOptions[count] := false;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDiagnosticOptions" id="5693d721-4975-4a9d-b190-301d45fade67">
        <updating/>
        <source>setDiagnosticOptions(filename: String; 
					logOptions: BooleanArray;
					logFull :Boolean;
					logSize: Integer;
					logOld : Boolean)updating;
/*******************************************************
*
* Description : Set options for diagnostics
*
* Parameters :	log file name 
*				indicaticators as to when diagnostics should be logged
* Return :		None
*
* History :		pjs	23/01/97	Initial version
*
*******************************************************/
vars
	intIndex	:Integer;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// could do checking for the log file name and see if its acceptable
	// but for now just assume that its okay

	logFilename := filename;

	// now the diagnostic options

	while intIndex &lt; Diagnostic_option_count do
		intIndex := intIndex + 1;

		diagnosticLogOptions[intIndex] := logOptions[intIndex];
	endwhile;

	// now the rest

	logFileSize := logSize;
	logFullMessages := logFull;

	if logOld then 
		logRollOverDateTime := false;
	else
		logRollOverDateTime := true;
	endif;
end;</source>
        <Parameter name="filename" type="String"/>
        <Parameter name="logOptions" type="BooleanArray"/>
        <Parameter name="logFull" type="Boolean"/>
        <Parameter name="logSize" type="Integer"/>
        <Parameter name="logOld" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLincDefRoot" id="89ee2cc4-e058-4d2a-8f44-e41ba30f0cdd">
        <updating/>
        <source>setLincDefRoot( root : CnEcLincDefRoot ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	myLincDefRoot	:= root;
end;</source>
        <Parameter name="root" type="CnEcLincDefRoot"/>
    </JadeMethod>
    <JadeMethod name="setLincSystemName" id="2116e3a6-2b48-48cf-9759-9006d3b1115b">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Linc System name
*
* Parameters :	name
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
setLincSystemName( newName : String ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	name := newName;
end;</source>
        <Parameter name="newName" type="String"/>
    </JadeMethod>
