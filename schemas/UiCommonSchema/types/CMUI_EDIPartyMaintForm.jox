    <JadeMethod name="setupActionsTableIFCSUM" id="61322601-c01a-4d53-a5ad-5ca79d63c5f9">
        <source>setupActionsTableIFCSUM(_table :CM_DataTable input; _updates :Boolean; _heading, _comboList :String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM
//
vars
	cargoType : CM_CargoType;
	consignee : CM_ConsigneeConsignor;
	make : CM_VehicleMake;
	idx : Integer;

begin
	_table.rows 		:= _table.fixedRows;
	_table.columns 		:= 3;
	_table.selectMode	:= Table.SelectMode_WholeRows;
	
	self.cmbConsignees.addItem(" ");
	self.cmbCargoType.addItem(" ");
	self.cmbMakes.addItem(" ");
	foreach consignee in app.myRoot.allConsigneeConsignors discreteLock where consignee.isConsignee and not consignee.isNotAvailableForEntry do
		idx := self.cmbConsignees.addItem(consignee.code &amp; " - " &amp; consignee.description);
		self.cmbConsignees.itemObject[idx] := consignee;
	endforeach;
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock where cargoType.allTerminals.includes(self.myTerminal) 
	and not cargoType.isNotAvailableForEntry do
		idx := self.cmbCargoType.addItem(cargoType.description);
		self.cmbCargoType.itemObject[idx] := cargoType;
	endforeach;
	foreach make in app.myDutyDocRoot.allVehicleMakes discreteLock do
		idx := self.cmbMakes.addItem(make.make);
		self.cmbMakes.itemObject[idx] := make;
	endforeach;
	
	if _updates then
		_table.tabStop		:= true;
		_table.showFocus	:= false;

		// set combo values - we will need to make this more flexible when we have more options
		_table.accessColumn(1).cellControl	:= self.cmbConsignees;
		_table.accessColumn(2).cellControl	:= self.cmbCargoType;
		_table.accessColumn(3).cellControl 	:= self.cmbMakes;
		_table.autoSize := _table.AutoSize_Column;
	endif;
	
	_table.setCellText (1, 1, _heading);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_updates" type="Boolean"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_comboList" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupActionsTableIFCSUMHS" id="817510d0-c51a-4141-8133-ba94abc819f8">
        <source>setupActionsTableIFCSUMHS(_table :CM_DataTable input; _updates :Boolean; _heading, _comboList :String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/
vars

begin
	_table.rows 		:= _table.fixedRows;
	_table.columns 		:= 3;
	_table.selectMode	:= Table.SelectMode_WholeRows;
	_table.multiSelect	:= _table.MultiSelect_Simple;	//MTN-33228
	self.cmbHSCodes.addItem(" ");
	self.cmbCargoTypeHS.addItem(" ");
	self.cmbCargoSubtype.addItem(" ");
	
	self.myAssistant.comboBoxHSCodes(self.cmbHSCodes, null);
	self.myAssistant.comboBoxCargoBolType(self.cmbCargoTypeHS,null, true, false, true, true);
	
	if _updates then
		_table.tabStop		:= true;
		_table.showFocus	:= false;

		// set combo values - we will need to make this more flexible when we have more options
		_table.accessColumn(1).cellControl	:= self.cmbHSCodes;
		_table.accessColumn(2).cellControl	:= self.cmbCargoTypeHS;
		_table.accessColumn(3).cellControl 	:= self.cmbCargoSubtype;
		_table.autoSize := _table.AutoSize_Column;
	endif;
	
	_table.setCellText (1, 1, _heading);

epilog

end;</source>
