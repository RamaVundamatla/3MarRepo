    <JadeMethod name="remarks" id="d3f48cf2-e9e5-4b33-b393-30d530ba09e4">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>remarks(set: Boolean; value: String io)updating, mapping;

vars
	aStr : String;
	request	:	CM_Request;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	foreach	request in self.allRequests do
		aStr := aStr &amp; request.getRemarks();
	endforeach;
	value := aStr;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeRequest" id="c457bd2a-eca0-48a9-b1ad-c02d8f0e4874">
        <updating/>
        <source>removeRequest(request : CM_Request io)updating;
/*
Author:			steve
Date:        	2 dec 99
Description:	Jadeised the method
Raises: 		ERR_JOB_NOT_FOUND

30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

begin
	exclusiveLock(self);
	
	if not self.allRequests.includes(request) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_JOB_NOT_FOUND, null, null);
		return;	
	endif;

	request.erase(NORMAL_ERASE);
	
	self.updateObjectEdition (self);	// par 30292

end;</source>
        <Parameter name="request" type="CM_Request" usage="io"/>
    </JadeMethod>
