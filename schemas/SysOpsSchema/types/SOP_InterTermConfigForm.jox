    <JadeMethod name="btnDeleteDest_click" id="3bf1d489-12a3-4edd-ac58-a93ce538b69d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteDest_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars

begin
	if lstDestination.listIndex &gt; 0 and lstDestination.listIndex &lt;= lstDestination.listCount then
		self.allInterTermTargetTermInfo.remove(lstDestination.itemObject[lstDestination.listIndex].CM_InterTermTargetTermInfo);
		self.myEditTerminal := null;
		self.lstDestination.removeItem(lstDestination.listIndex);
		vUpdated := true;
	else
		self.myEditTerminal := null;
		app.raiseCMException1(Input_Required_For_TA, null, null, null);
		self.lstDestination.setFocus;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
