    <JadeMethod name="doCompleteTruck" id="e3d5a49c-464d-4664-acca-878be7871075">
        <source>doCompleteTruck():Boolean;
/*
	Created on 05 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	theVehicle : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	jobNumber  : String;
	alertCreated : Boolean;
begin
	if self.myMobileDataAgent.allCMIFs.size() &gt; 0 then
		app.msgBox('Please set down or clear this load before completing the truck',"", MsgBox_OK_Only);
		return false;
	endif;

	if self.myMobileDataAgent.deviceIsLastOnJob(self.myMobileDataAgent.myRoadJob, app.myMobileGUIAgent.strDevice) then
		self.myMobileDataAgent.gateOutTruck();
	
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorWarningDialog('Road Exit Process', app.myPassport, ErrWarnMode_Update);
			return false;
		endif;
	else
		app.msgBox(app.getErrorString(Truck_cannot_exit),"",MsgBox_OK_Only);
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTIForCMIF" id="42a1c28f-ef7e-4b39-bfc7-8820b03aef17">
        <source>findTIForCMIF(_id : String; _action : Integer output): CM_TrackedItem;
/*
/*
	Created on 07 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	ti : CM_TrackedItem;
	
begin
	ti := self.myMobileDataAgent.findCargoOnRoadJob(_id);
	
	if ti &lt;&gt; null then	
		_action := CMIF_TIGenCargo.Action_Move;
	else
		ti := self.myMobileDataAgent.findPrenoteByID(_id);
		if ti &lt;&gt; null then
			_action := CMIF_TIGenCargo.Action_ReceivePrenote;
		endif;
	endif;
	
	return ti;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_action" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getItemDisplay" id="b707259b-eabc-42e1-a1a9-fa6cf959b64a">
        <source>getItemDisplay(_cmifItem: CMIF_TIGenCargo): String;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	item 			: CM_TrackedItem;
	cmifRec 		: CMIF_Receival;
	id, 
	booking,
	location 		: String;
begin
	item := _cmifItem.getTrackedItem;
	cmifRec := _cmifItem.myCMIFReceival;

	if item &lt;&gt; null then
		id := item.id;
		
		if item.myBookingRef &lt;&gt; null then
			booking := item.myBookingRef.bookingReference;
		else
			booking := item.bookingReference;
		endif;
		
	elseif cmifRec &lt;&gt; null then
		id := cmifRec.id;
		booking := cmifRec.bookingReference;
	endif;
	
	if _cmifItem.myNewLocation &lt;&gt; null then
		location := _cmifItem.myNewLocation.getFullId;
	endif;
	
	return id &amp; Tab &amp; location &amp; Tab &amp; booking &amp; Tab &amp; _cmifItem.intLoadCount.asStringJMT;
end;</source>
        <Parameter name="_cmifItem" type="CMIF_TIGenCargo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOrderCountDisplay" id="56604ab4-f6c8-478e-9ac2-d550ad11935a">
        <updating/>
        <source>getOrderCountDisplay(): String updating;

// 12 Jun 2013	cnwcs5	par 31670 - used getReceivedCount instead of numOnsiteTIs

vars
	count, received, scanned, total 	: Integer;
	ti 		: CM_TrackedItem;
	cmif	: CMIF_Object;
begin
	self.setMyBookingRef();
	
	if self.myBookingRef &lt;&gt; null then
		received := self.myBookingRef.getRecievedCount;	// cnwcs5 par 31670
		
		foreach cmif in self.myMobileDataAgent.allCMIFs do
			ti := cmif.CMIF_TIGenCargo.getTrackedItem; 
			
			if ti &lt;&gt; null and ti.isOnSite and not self.myBookingRef.allTIs.includes(ti) then
				received := received + 1;
			endif;
		endforeach;
		
		return received.String &amp; '/' &amp; self.myBookingRef.getTotalQuantity.String;
	else
		return "n/a"; 
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="3aea0d46-be87-4154-ab67-f18d9e8d6073">
        <source>getTableSettings(_columns: Integer output; _header: String output);
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	_columns := 4;
	_header := app.getErrorString(Cargo_ID) &amp; Tab &amp; app.getErrorString(NewLocation) &amp; Tab &amp; app.getErrorString(Order)&amp; ' #' &amp; Tab &amp; app.getErrorString(Truck_count);
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleF10Key" id="2084cad0-5e2c-4134-9d3a-2a85c72a6010">
        <source>handleF10Key();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/04/2013	cnwdap1	Initial creation PAR #31378 CCMS PNL 2247 Use F10 key as shortcut to Order Enquiry screen
*/
vars
	bookingRef		: CM_BookingRef;
	ti				: CM_TrackedItem;
	form			: MOB_CEBookingRefForm;
	newTI			: Boolean;
	invalidObject	: Boolean;
	desc			: String;

begin
	on Exception do app.handleDeletedObject(exception, bookingRef, invalidObject);
	
	ti := self.getTrackedItemForRow(newTI);
	if ti = null then
		return;
	endif;
	if ti.myBookingRef &lt;&gt; null then
		bookingRef := ti.myBookingRef;
	endif;
	if bookingRef = null then
		app.msgBox(app.getErrorString(Cargo_Item_No_Order_Number), "", MsgBox_OK_Only);
		return;
	endif;
	
	// check booking hasn't beeen deleted
	desc := bookingRef.description;
	if invalidObject then
		return;
	endif;
	
	create form transient;
	form.setBookingRef(bookingRef);
	form.btn_Details.enabled := false;
	form.show();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="834a0aa6-fa2f-4bd8-8168-50f507a30eb3">
        <updating/>
        <source>loadTable(tbl: CM_MobTable io) updating;

vars

begin
	inheritMethod(tbl);	
	self.txt_OrderCount.text := self.getOrderCountDisplay;
end;
</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processForCloseForm" id="f071a3f2-932b-414d-892f-4233422cae06">
        <updating/>
        <source>processForCloseForm(): Boolean updating;
/*
	Created on 05 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	thisDevice	: String;
	term : CM_Terminal;
begin
	if not inheritMethod() then
		return false;
	endif;
	term := self.myMobileDataAgent.myTerminal;
	thisDevice := app.myMobileGUIAgent.strDevice;
	if not forceClose and self.myRoadJob &lt;&gt; null then
		if self.myMobileDataAgent.deviceIsLastOnJob(myRoadJob, app.myMobileGUIAgent.strDevice) 
//		and app.myCurrentUserCan(term, PmGteRoadExitUpdate)  // dh 17/7/2008 advice from RS 
		and term.getConfig(AllowMobileRoadExit).Boolean	then
			if app.msgBox(app.getErrorString(TruckCompleted), "", MsgBox_Yes_No) = MsgBox_Return_Yes then
				return self.doCompleteTruck();
			endif;
		endif;
		app.myTrxUA.trxUpdateRoadJobDevices(self.myRoadJob, thisDevice, self.myRoadJob. CM_RoadJob.Remove_Device, app.myPassport);
		self.myRoadJob	:=	null;
		self.myBookingRef := null;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyBookingRef" id="c114d9a4-cdce-4709-af7b-594dc06e142f">
        <updating/>
        <source>setMyBookingRef()updating;

vars
	ti : CM_TrackedItem;
	br : CM_BookingRef;
begin
	myBookingRef := self.myMobileDataAgent.getSingleBookingRefForJob(self.myRoadJob);
end;
</source>
    </JadeMethod>
    <JadeMethod name="setMyRoadJob" id="c098a41a-585d-40bf-b6cb-09aee419d193">
        <updating/>
        <source>setMyRoadJob(_roadJob : CM_RoadJob) updating;
/*
	Created on 09 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.myRoadJob := _roadJob;
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="39ddbd36-c41f-421b-a846-9e8872df8178">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
// adm 270509 Par 19483 myTerminal
vars
	dev : String;
begin
	inheritMethod();
	
	self.lbl_Truck.caption		:=	app.getErrorString(Unload_truck) &amp;': ';
	self.lbl_TruckNo.caption	:=	self.myRoadJob.regNumber;
	dev := app.myMobileGUIAgent.strDevice;
	self.myMobileDataAgent.setupRoadJob(self.myRoadJob, dev);
	self.txt_OrderCount.text := self.getOrderCountDisplay;
	if self.myTerminal().getConfig(AllowMobileRoadExit).Boolean then
		self.btn_TruckDone.visible := true;
	else
		self.btn_TruckDone.visible := false;
	endif;
	beginNotification(self.myRoadJob, Object_Delete_Event, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupItemTable" id="5982193e-0795-47a0-ab7a-4952f43eeed5">
        <source>setupItemTable(tbl: CM_MobTable input);
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	col : JadeTableColumn;
begin
	inheritMethod(tbl);
	col := tbl.accessColumn(2);
	col.enabled := true;
	col.inputType := tbl.InputType_TextBox;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="f52907bd-a173-496f-a9a3-4c86bf921457">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
	Created on 08 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	app.mousePointer	:=	Busy;
	
	if theObject = myRoadJob and eventType = Object_Delete_Event then
		app.msgBox(app.getErrorString(RoadJobDeleted),"Truck Done", MsgBox_OK_Only);
		self.forceClose := true;
		self.doCloseForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="939ceadc-4f74-4560-86a7-102faa307feb">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018475, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
