    <JadeMethod name="cmbReaderContext_click" id="a9907f32-6be1-4964-b8ba-25f26044c50a">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbReaderContext_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	windowsPCName		: String;
begin
	if combobox.listIndex &gt; 0 then
		self.myCurrentTableItem.SOPTM_RFIDTagReader.setViewForContext(combobox.itemData[combobox.listIndex]);
		//auto populate the app.computerName if
		windowsPCName := self.tblInput1.getValueByName(ETRow_WindowsMachineName).String.trimBlanks;
		if windowsPCName = null then
			self.tblInput1.setValueByName(ETRow_WindowsMachineName, app.computerName);
		endif;
		
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
