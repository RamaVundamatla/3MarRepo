// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.');
	// IF NOT LINKED
	if not self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCLinkPaletteAttributes then
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2.');
		self.myCCPalette := null;
		self.myCCPaletteLoad := null;	//24 Jan 2012	NDL	Par 28896
		return;
	endif;
	
	if not _show and self.myCCScreen &lt;&gt; null then 
		self.myCCScreen.unloadForm();
		self.myCCScreen := null;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 3.');
	endif;

epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
