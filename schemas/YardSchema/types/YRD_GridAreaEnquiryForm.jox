    <JadeMethod name="setMoveControllerSource" id="e59d63e6-ffba-4710-8c90-7f36546d3710">
        <updating/>
        <source>setMoveControllerSource(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	moveMode : Integer;
begin

	create moveController transient;
	
	moveController.setMyTrackedItem(_ti);
	delete app.myMoveController;
	app.myMoveController := moveController;
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		moveMode := REAL_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		moveMode := PLANNING_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		moveMode := QUEUE_MODE;
	endif;

	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(moveMode));
//	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(self.moveModeForm));	//REAL_MODE));
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := _ti.isRehandle;
	moveController.myOriginatingForm := self;
//	moveController.isOverstowMove := _ti.isOverStowed(REAL_MODE);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerTarget" id="f0359554-abab-43d8-94fb-f4e11e5f3fc8">
        <updating/>
        <source>setMoveControllerTarget(_theLocation : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		April  2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	
	delete app.myMoveController;
	app.myMoveController := moveController;
	moveController.setMyToPrimaryLocation(_theLocation);

	moveController.setMoveMode(self.moveModeForm);	
epilog

end;</source>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="a9b939df-bc74-4851-81f2-e71441e39c26">
        <updating/>
        <source>setMoveMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cdc : YRD_ContainerDrawingController;
	anObj : Object;

begin
	inheritMethod(_mode);

	cdc := self.myCurrentDrawingController;
	if cdc = null then
		return;
	endif;
	cdc.moveMode := _mode;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentDrawingController" id="313f4dee-0682-443d-b2ab-cf71fa358c2b">
        <updating/>
        <source>setMyCurrentDrawingController(_newController : CMUI_GridDrawingController input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	db			: YRD_ContainerGridAreaDockBar;
	anObject	: Object;
	gridArea	: CM_GridArea;
begin
	
	self.myPreviousDrawingController := self.myCurrentDrawingController;
	self.myCurrentDrawingController := _newController.YRD_ContainerDrawingController;

	if myCurrentDrawingController &lt;&gt; null then
		self.btnReverseStack.enabled := false;
		gridArea := self.myCurrentDrawingController.myTerminalArea.CM_GridArea;
		if gridArea &lt;&gt; null
		and (gridArea.type = TA_TYPE_STRADDLE_STACK or gridArea.type = TA_TYPE_RTG) then
			self.btnReverseStack.enabled := true;
			self.btnReverseStack.bubbleHelp := "Reverse Decking Direction For All Rows Of " &amp; self.myCurrentDrawingController.myTerminalArea.id;
		else
			self.btnReverseStack.bubbleHelp := "Reverse Decking Direction";
		endif;
	endif;
	
	if _redraw then
			
		foreach anObject in self.allDockBars do
			db := anObject.YRD_ContainerGridAreaDockBar;
			db.myDrawingFrame.changeBackColor(self.defYardBackColUnselected);
		endforeach;
		self.myCurrentDrawingController.changeBackColor(self.defYardBackColSelected);
	
	endif;
end;</source>
        <Parameter name="_newController" type="CMUI_GridDrawingController" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjFromTblPreferSpecial" id="b2304941-b073-4a2a-abe0-dba1b023a62b">
        <source>setObjFromTblPreferSpecial(_attrName, _value : String; _obj : Object input; _tbl : CM_EntryTable input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocLegend" id="8d55ba1b-2572-40aa-9884-a4e8142c187f">
        <updating/>
        <source>setYardAllocLegend() updating;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObj,yalloc : Object;
	cdc : YRD_ContainerDrawingController;
	objSet : ObjectSet;
	vMode : Integer;
begin
	create objSet transient;
	cdc := self.myCurrentDrawingController;
	vMode := cdc.viewMode;
	foreach yalloc in cdc.myDrawingAttrController.allYardAllocations do
		if yalloc.CM_YardAllocation.isDisabled then
			continue;
		endif;
		objSet.addNoDuplicates(yalloc,false);
	endforeach;
		
	cdc := self.myCurrentDrawingController;
	cdc.myDrawingAttrController.allYardAllocations.clear;
	objSet.copy(cdc.myDrawingAttrController.allYardAllocations);
		
	self.doNotesForLegendStartStop(vMode,cdc);

epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="01d1a1f5-7c45-4814-8623-1414d68fd70c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.configAutoPlanUseAllocations := true;					//SFW1030 30/10/2008


//	self.initSelectAreasGroupBox();
//	self.initSelectAreasCollection();		
	
	self.doInitInfoTable();
	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	self.chkSideOption.value := self.xmlDrawSideOn; // PAR 26858
	
	//28 Jul 2011	NDL	Par 27890
	if self.xmlSelector then
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_HIDE;
	else
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
	endif;
	self.mnuHideSelectorPanel_click(self.mnuHideSelectorPanel);
	
	if self.xmlLegend then
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
		self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_HIDE;
	else
		self.dkbColorLegend.visible := false;
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
		self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_SHOW;
	endif;
	self.mnuGridHideLegend_click(self.mnuGridHideLegend); // this reverses the lines above and sets things correctly
	// must set the width AFTER the click call above
	self.dkbColorLegend.width := 100;

	if self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly


	self.frmStatusLine.initFrame();
	inheritMethod();
	
	self.frmSelectorPane.populateListBox( self.myTerminal );	//27 June 2011	NDL	Par 27890
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormFromAreaSelector" id="5a124154-3831-4ebe-a108-13caf6e98759">
        <updating/>
        <source>setupFormFromAreaSelector() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aTA : Object;
	aTerminalArea : CM_GridArea;
	anObject : Object;
	idx,numDB : Integer;
	theCaption : String;
	aDB : YRD_ContainerGridAreaDockBar;
begin
	if self.allTerminalAreas.isEmpty then
		app.msgBox(app.getErrorString(Please_Select_Areas), app.getErrorString(Select_Area_Error), MsgBox_OK_Only);
		app.mousePointer := Window.MousePointer_Default;
		return false;
	endif;

	self.doNotesForLegend(false);
	self.frmColLegendTIs.myLegendTable.rows := 0;
	idx := 1;
	
	self.myAssistant.allGridAreasByLabel.purge;
	self.frmModalDialog.visible := false;
	self.frmModalDialog.height := 100;

	foreach aTA in self.allTerminalAreas reversed    do
		aTerminalArea := aTA.CM_GridArea;
		idx := idx + 1;
//		self.showArea(aTerminalArea,idx,VIEW_VOYAGE);
	endforeach;


	numDB := self.allDockBars.size;
	foreach aTA in self.allDockBars do
		aDB := aTA.YRD_ContainerGridAreaDockBar;
		aDB.width := (self.dkcGridArea.clientWidth / numDB);
		aDB.myDrawingController.showDrawingFrame(true);
	endforeach;
	self.doSetCaption();
	self.doResize();
	
/*
		self.doBuildMnuZoom(self.mnuWorkDisplayZoom);
		self.doBuildMnuZoom(self.mnuZoomSub);
		self.doMnuWorkDisplayViewVisible(true);
		self.mnuGridAreaContext.visible := false;
		self.doNotesForLegend(true);

*/	
	return true;

epilog
	self.setCaption(theCaption);
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="df468d27-46cf-410e-9b7d-16f8c84a2eeb">
        <source>showAreaSelector();
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);
	self.msgSelectAreas.width := 327;

	self.msgSelectAreas.setSelected(self.allTerminalAreas);
	self.showAreaSelectorEnable(true);
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="c9b8e5f6-7581-4ff8-9e3a-72662407f8af">
        <source>showAreaSelectorEnable(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmColLegendTIs.enabled := not _enable;
	self.frmToolbar.enabled := not _enable;
	self.tblGridAreaInfo.enabled := not _enable;

	self.frmSelectAreas.visible := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="a8cd3207-dde2-4e89-b6d0-07744fba3ff9">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
 		return null;
 	endif;

	thePicture := _theTI.getPicture;
	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showDeckingFrame" id="e099761f-94c5-4efc-b1f5-141fd1986bd4">
        <updating/>
        <source>showDeckingFrame(_yPos1 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     CNWAB1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame 	: Frame;
	theTable 	: CM_EntryTable;
	tblHeight, theTop : Integer;
	deckPos		: Integer;
begin
	theFrame := self.frmDeckingOrder;

	deckPos := self.myCurrentDrawingController.currentDeckingPosition;
	
	if deckPos = null then
		//before displaying check that the current decking is valid
		return;
	endif;

	self.deckingPosition := deckPos;

	if not theFrame.visible then
		theFrame.left := 150;
		theFrame.top := 250;
	endif;
	if self.myCurrentDrawingController.myCurrentDeckingRow &lt;&gt; null then
		self.lblDecking.caption := "Row:" &amp; self.myCurrentDrawingController.myCurrentDeckingRow.label &amp; " " &amp; deckPos.String;
	else
		self.lblDecking.caption := "Row:" &amp; " - ";
	endif;
	theFrame.zOrder(1);
	theFrame.visible := true;
end;</source>
        <Parameter name="_yPos1" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributesDisplay" id="134e5420-321b-47ba-91b9-81afde9cdced">
        <updating/>
        <source>showExtraAttributesDisplay(_theTIIndex : Integer;_theAttributeArray : CMUI_GridAttributesArray input;
		_dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------
vars
	theAttibuteString : String;
	aDrawingAttribute : CM_DrawingAttribute;
	aGridAttribute : CMIF_GridAttributes;
	block : CM_DataContainerBlock;
	
begin
	if _theTIIndex &lt; 1 then // see AKB. If you click on a point that is part of a TI that covers more than 1 point, the right hand points have no attributes
		return;
	endif;
	
	if _theAttributeArray = null then
		return;
	endif;
	
	if _theTIIndex &gt; _theAttributeArray.size then
		return;
	endif;
	aGridAttribute := _theAttributeArray[_theTIIndex];
	foreach theAttibuteString in aGridAttribute.allDisplayIcons do
		if theAttibuteString = null then
			continue;
		endif;
		aDrawingAttribute := app.myRoot.allDrawingAttributes[theAttibuteString];

		if aDrawingAttribute = null then
			continue;
		endif;
		if block = null then	
			block := _dataContainer.addNewBlock();
		endif;

		//block.addNewItem(aDrawingAttribute.getLabel(), DC_IconLabel, 1, null);  //17.10.2017	cnwma1  TFS #7431
		block.addNewItem(aDrawingAttribute.label, DC_IconLabel, 1, null);         //17.10.2017	cnwma1  TFS #7431
		block.addNewIcon(aDrawingAttribute.fontCharacter.Character, 1, null,
						aDrawingAttribute.fontName, aDrawingAttribute.colour);
	endforeach;

end;</source>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_theAttributeArray" type="CMUI_GridAttributesArray" usage="input"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfo" id="e18c48ab-6e33-4618-8dd6-c1df2bde9f82">
        <updating/>
        <source>showExtraInfo(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use transient CM_DataContainer instead of arrays
//							to pass data around.
// ---------------------------------------------------------------------------

vars
	dataContainer : CM_DataContainer;
	numberOfColumns,idx,theIndex,lDisplayMode,theWidth : Integer;
	theLine,theAttibuteString : String;
	theSingle : Boolean;
	anObject : Object;
	theAttributeArray : ObjectArray;
	aLeftDrawingAttribute,aRightDrawingAttribute : CM_DrawingAttribute;
	theObject : Object;
	
begin
	self.tblGridAreaInfo.rows := 0;
	numberOfColumns := self.getNumberOfColumns();
	
	if not global.isValidObject(_obj) then
		return;
	endif;

	if self.myCurrentInfoNoteObject &lt;&gt; null then
		self.endNotification(self.myCurrentInfoNoteObject,Object_Update_Event);
	endif;
	self.myCurrentInfoNoteObject := _obj;
	self.beginNotification(self.myCurrentInfoNoteObject,Object_Update_Event,Response_Continuous,null);
	
	self.tblGridAreaInfo.alignment := Table.Alignment_Left_Top;
	
	//######################
	// DISPLAY INFO
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	dataContainer.displayMode := self.myCurrentDrawingController.displayMode;
	self.getExtraInfoForObject(_obj, dataContainer);
	self.tblGridAreaInfo.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
			self.mnuGridBigFont.checked, numberOfColumns, self.getNumberOfColsForData,
			self.getNumberOfColsForHeader, self.getNumberOfColsForIcon,
			self.getNumberOfColsForLabel);

	self.doResizeColumnWidths(self.tblGridAreaInfo, true);

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfoForObject" id="f24d2eae-a71a-4ac8-9c68-913c987064aa">
        <updating/>
        <source>showExtraInfoForObject(_theObject : Object input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is used to update the macro info if a note comes thru for the object being displayed there
// ---------------------------------------------------------------------------
vars

begin
	self.tblGridAreaInfo.rows := 0;
	if _theObject &lt;&gt; null then
		self.showExtraInfo(_theObject);
	endif;
epilog
end;</source>
        <Parameter name="_theObject" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideLayout" id="8ed45bc3-fc33-4fb9-b7c9-a94b7368fd9b">
        <updating/>
        <source>showHideLayout(_show : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDkbPos	: CMUI_JadeDockBar;
begin

	tmpDkbPos := self.dkbPosition;
	
	if _show then
		self.mnuGridLayout.caption := app.getErrorString(HideLayoutOverview);
		self.mnuWorkDisplayLayout.caption := app.getErrorString(HideLayoutOverview);

		self.layoutRedraw(true);

		if (not tmpDkbPos.isFloating) then
			// some problem here where float event seems to get height
			// screwed up - RJS
			tmpDkbPos.height := tmpDkbPos.height + 25;
			tmpDkbPos.centreWindow();
			tmpDkbPos.float(layoutFramePosition.x, layoutFramePosition.y, tmpDkbPos.width.Integer, tmpDkbPos.height.Integer);
		endif;

		tmpDkbPos.visible := true;
		
	else
		tmpDkbPos.visible := false;
		
		// if the dockbar was closed by clicking its close button then
		// the left and right are no longer valid - refer PAR-34941 where
		// have asked if can tell what position was
		layoutFramePosition.set(tmpDkbPos.left.Integer, tmpDkbPos.top.Integer);

		self.mnuGridLayout.caption := app.getErrorString(ShowLayoutOverview);
		self.mnuWorkDisplayLayout.caption := app.getErrorString(ShowLayoutOverview);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
