    <JadeMethod name="getDisplay" id="66b24bec-9b0d-4d89-8c1b-a4b0f78be11a">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Returns a string to use for the GUI interface to display the receiver's
//				details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myComponent.getDisplay();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6296e251-c1a1-45fb-bb97-d1e26260c46e">
        <updating/>
        <source>updateMe(pTheComponent:JSSLKComponent; pTheUsedProduct:JSSLKUsedProduct) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pTheComponent - The Component that is being mapped to a Customer.
//				pTheUsedProduct - The Used Product which maps the Component's
//				Product to a Customer.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateMe(pTheComponent, pTheUsedProduct) then
		// Update any key properties and references.
		
		if self.myComponent &lt;&gt; pTheComponent then
			self.myComponent	:=	pTheComponent;
		endif;
		
		// Update inverse references.
		
		if self.myUsedProduct &lt;&gt; pTheUsedProduct then
			self.myUsedProduct	:=	pTheUsedProduct;
		endif;
	endif;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent"/>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="799abeee-db1b-4917-80e1-93b74cdc6222">
        <source>validateMe(pTheComponent:JSSLKComponent; pTheUsedProduct:JSSLKUsedProduct):Boolean;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Validates the receiver's properties.
//
// Parameters:	pTheComponent - The Component that is being mapped to a Customer.
//				pTheUsedProduct - The Used Product which maps the Component's
//				Product to a Customer.
//
// Returns:		True if the data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent"/>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
