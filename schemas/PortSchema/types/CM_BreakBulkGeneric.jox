    <JadeMethod name="setMoveControllerAmount" id="8aa5263e-1a0e-436c-91a8-7cd040cbb776">
        <updating/>
        <source>setMoveControllerAmount(_control: CMIF_MoveController input) updating, protected;
/*
Purpose: Ensure that a 	the controller is set with the quantity to move so that trns are created with correct quantity. 
         The move controller can just have 0, which implies move all the cargo
		 Also need to ensure there is a value for the weight being moved
		 PAR 35945
29/11/2017	jlgdap1		TFS 8123 QNS Also set controller volume if we have a volume
7/12/2017	jlger1		TFS 8220 using set methods
*/
vars

begin
	if _control.moveMode = REAL_MODE and self.canMergeBreakBulk then
		if _control.quantity = 0 then  
			//epr par 36908 22/9/15
			if _control.myWorkListEntry = null or _control.myWorkListEntry.quantity = 0 then
				_control.setQuantity( self.totalQuantity);
			else
				if _control.myWorkListEntry.quantity &lt; self.totalQuantity then
					_control.setQuantity( _control.myWorkListEntry.quantity);
				else
					_control.setQuantity( self.totalQuantity);
				endif;
			endif;
		endif;
		if _control.weight = 0 then  
			_control.setWeight(  self.totalWeight * (_control.quantity / self.totalQuantity));
		endif;
		if _control.volume = 0 and self.totalVolume &lt;&gt; 0 then									// TFS 8123
			
			_control.setVolume(self.totalVolume * (_control.quantity / self.totalQuantity));		// TFS 8123
		endif;																					// TFS 8123
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyLocations" id="63ac7ecf-db51-471d-8712-4771b6689509">
        <updating/>
        <source>setMyLocations(control: CMIF_MoveController input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwer1	Initial creation CCMS DPH 2274
24 Nov 2015	cnwma1  PAR #36930 Release Train is missing when releasing break-bulk (rebar)
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
17 May 2022 navds20 TFS 53504 EUP - Cargo Uniqueness - PortSchema
02 May 2023	jlizm1	TFS 55453 Cargo uniqueness by subtype
25 Mar 2024 navma1	Bug 62928: EUP - Demo - Pack Load By Request Froze During Cargo Display for User Selection
06 Aug 2025 navlw1	JIRA:35087: POB - Receive and Release Stevedore not coming through to the cargo from Voyage stevedore for non-container cargo
*/

vars
	targetBulkCargo : CM_BreakBulkGeneric;
	lc 				: CM_LocationsController;
	childTI 		: CM_TrackedItem;
	wle 			: CM_WorkListEntry;
	matches 		: Integer;
	dirRelLocn 		: CM_LocationsController;
	myToPrimaryLoc  : CM_LocationsController;
	stevedore 		: CM_Stevedore;
begin
	
	if control.moveMode = REAL_MODE and self.canMergeBreakBulk then
		//if going to same place return do nothing
		if self.allLocations.isSameArrayContents(control.allToLocations) 
		and not control.isForcedMove then // PAR 18682
			return;
		endif;
				
		if control.quantity &lt;&gt; 0 and control.quantity &gt; self.totalQuantity then
			//raise exception 
			app.raiseCMException2(Move_quantity_gtr_cargo,control.quantity.asStringJMT,self.totalQuantity.asStringJMT , null,null);
			return;
		endif;
		
		//06/08/2025 navlw1 JIRA:35087
		if control.isCreateCargoOnVoyage then
			//apparently when creating cargo on a voyage, we have to automagicly select and populate 'the' receive stevedore.
			if self.stevedoreCodeRecieve = null then
				stevedore := self.getStevedore;
				if stevedore &lt;&gt; null then
					self.setStevedoreCodeRecieve( stevedore.code );
				endif;
			endif;
		elseif control.isRealMoveToVoyagePosition then
			//and when moving existing cargo to a voyage location, we have to automagicly select and populate 'the' release stevedore.
			if self.stevedoreCodeRelease = null then
				stevedore := self.getStevedore;
				if stevedore &lt;&gt; null then
					self.setStevedoreCodeRelease( stevedore.code );
				endif;
			endif;
		endif;
		
		// figure out what to do if moved offsite  if control.isWagonMovingOffSite then	
		
		//same as to setMyLocations just display stuff for now
		foreach lc in self.allLocations do
			//-------------------
			// Update the last move date/time on the from lc
			//-------------------
			lc.setLastMoveOutDateTime(app.serverTimestampAtTrxStart);
			//-------------------
			// Call any specific cleanup methods on the source location if needed
			//-------------------
			lc.executePreMoveFromLocation(control);
			
			// do this here so all previous locations receive event
			control.doUpdateDisplayEvent(lc);
		endforeach;
					
		//determine if this is a split/merge 
		
		//first check if there is cargo in target location with same id and cargo type
		myToPrimaryLoc := control.myToPrimaryLocation;									//25.03.2024 navma1 #62928
		
		if myToPrimaryLoc &lt;&gt; null then
			//epr 14/3/17 this method makes sure we don't find cargo that is merged which if there was a bug in past could cause potential problems
			targetBulkCargo := myToPrimaryLoc.searchForOnsiteTI(self.id,matches,self.myCargoType.id,self.getMyCargoGroupId(),self.getCargoSubTypeCode(), self.operatorCode).CM_BreakBulkGeneric; //navds20 17/05/2022 TFS 53504 //03.Nov.2023 navsp TFS 61067
		else
			if control.myPackToTI &lt;&gt; null then
				foreach childTI in control.myPackToTI.allChildren discreteLock do 
					if childTI.id = self.id and childTI.myCargoType = self.myCargoType then
						targetBulkCargo:=childTI.CM_BreakBulkGeneric;
						break;
					endif;
				endforeach;
			endif;
			
		endif;
		
		if targetBulkCargo = null  then
			// figure out what to do if moved offsite  if control.isWagonMovingOffSite then	      // 24/11/2015 cnwma1 PAR #36930
			if control.isWagonMovingOffSite then												  // 24/11/2015 cnwma1 PAR #36930
				//This is a tracked item on a wagon moving off-site
				// Retain the location controller of the wagon.	
				self.setLocationId(null);
				return;
			endif;
			//if control.quantity = 0 or self.totalQuantity = control.quantity then												// TFS 51935
			if (control.quantity = 0 or self.totalQuantity = control.quantity) and control.directExcessQuantity = null then		// TFS 51935
			
				//20 May 2015	NDL	Par 36127
				wle := control.myWorkListEntry;
				if wle &lt;&gt; null and wle.quantity &gt; 1 and self.totalQuantity = 1 then
					// we have a pile of one (i.e. no split required but the wle is for multiples,
					// need to create a new wle for this one and complete it and lower the requrired
					//count on the existing one)
					self.splitWleCreateNewWLE( control, wle );
				elseif wle &lt;&gt; null then // TFS 3190 
					// TFS 3190 - Assign release to a hold. Now it is complete, unplan the TBA so it can be deleted.
					if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isTBAorIsRRP then
						if wle.myRequest.isHoldRequest() and wle.myRequest.CM_HoldRequest.myBulkReleaseReserveDetail &lt;&gt; null then 
							wle.setMyTrackedItem(self);
						endif;
					endif;
				endif;
				
				//move the entire TI 
				self.allLocations.clear();
		
				//Always update the primary location property
				self.refreshMyFutureLocations(control.moveMode,null);

				self.setLocationString(control);
				
				//07 Jun 2018	NDL:	TFS 38897
				if control.myDirectReleaseArea &lt;&gt; null then
					dirRelLocn := control.myDirectReleaseArea.CM_BlockStack.myLocationsController;
					if control.allToLocations.includes( dirRelLocn ) then
						control.allToLocations.remove( dirRelLocn );
					endif;
				endif;
				
				if control.allToLocations &lt;&gt; null and not  control.allToLocations.isEmpty then				//25.03.2024 navma1 #62928
					control.allToLocations.copy(self.allLocations);
				
					self.refreshMyFutureLocations(control.moveMode,null);
					
					self.setLocationString(control);
				endif;
				
				self.directDeliveryAdjustPreNoteWLE(control, control.myWorkListEntry, control.myDDWorkListEntry);	// TFS 51935
				
			elseif control.directExcessQuantity &lt;&gt; null then														// TFS 51935
				// need to split TI and WLE, move both TIs, complete both WLEs, and adjust prenote planning			// TFS 51935
				self.splitBulkOrBreakBulkAndWLE(control);															// TFS 51935
			else
				//need to split - 
				self.splitBreakBulkGeneric(control,null);
						
			endif;
			
		else
			if control.directExcessQuantity &lt;&gt; null then															// TFS 51935
				// need to split TI and WLE, move both TIs, complete both WLEs, and adjust prenote planning			// TFS 51935
				self.splitBulkOrBreakBulkAndWLE(control);															// TFS 51935
			else																									// TFS 51935
				self.mergeBreakBulkGeneric(control,targetBulkCargo);
			endif;																									// TFS 51935
		endif;
		
	else
		
		inheritMethod(control);

	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyPalletTiDetails" id="a8d8ff1c-8aab-4bb2-a694-c29a2dfe5b2e">
        <updating/>
        <source>setMyPalletTiDetails(	_heatTreated : Boolean;
						_storeOnPallets : Boolean;
						_myPalletType :	CM_PalletType
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2020	jlgndl1	Initial creation	TFS 48248

*/

vars

begin
	if not self.isPalletByDefault then
		return;
	endif;

	if self.myPalletDetailsTI = null then
		create self.myPalletDetailsTI;
		self.myPalletDetailsTI.setMyTrackedItem(self);
	endif;
	
	self.myPalletDetailsTI.setBaseDetails(	_heatTreated,	//_heatTreated : Boolean;
											_storeOnPallets,	//_storeOnPallets : Boolean;
											_myPalletType	//_myPalletType :	CM_PalletType
											);

epilog

end;</source>
        <Parameter name="_heatTreated" type="Boolean"/>
        <Parameter name="_storeOnPallets" type="Boolean"/>
        <Parameter name="_myPalletType" type="CM_PalletType"/>
    </JadeMethod>
