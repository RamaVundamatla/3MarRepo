    <JadeMethod name="tRTAmendTarget3" id="84688fc1-01a8-455e-8495-16a7c044202b">
        <source>tRTAmendTarget3();
// cnwer1
/*

Purpose:			Amending an umworked task	using strad -&gt; IMV -&gt; Fork rule		

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/

constants
	Container = "UT1001";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	InterchangeSource = "UT_IC1";
	InterchangeTarget = "UT_IC2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	
	Straddle1 = "UTS1";
	ForkLift1 = "UTF1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st1, st2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	straddle1,
	straddle2,
	fork	: CM_Machine;
	task	: CM_RTQueueTask;
	icSource,
	icTarget : CM_YardInterchangeArea;
	allTasForIC  : CM_TerminalAreaSet;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork, stradTargICFork,
	stradSourceICFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteTerminalArea(InterchangeSource);
	self.deleteTerminalArea(InterchangeTarget);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(ForkLift1);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForStraddleStack1, StraddleStack1,null,false);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForStraddleStack2, StraddleStack2,null,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);
	
	
	create allTasForIC transient;
	allTasForIC.add(st1);
	allTasForIC.add(fk1);
	icSource:= self.addInterchangeArea(InterchangeSource,allTasForIC);
	
	
	allTasForIC.clear;
	allTasForIC.add(st2);
	
	icTarget:= self.addInterchangeArea(InterchangeTarget,allTasForIC);
	q3:= self.addQueue(QueueForForkLift,icSource,icTarget,false);
	assertNotNull(q3);
	
	self.addTAAreaToQueue(q3,fk1,null);
	

	
	
	//move method straddle-&gt;source ic -&gt; forklift -&gt; target ic -&gt; straddle
	self.addMachineRule(st1,st2,RTMoveMethod_33);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(StraddleStack1); 
	tas.add(InterchangeSource);
	straddle1:=self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	self.assertNotNull(straddle1);
	
	tas.clear;
	tas.add(StraddleStack2);
	tas.add(InterchangeTarget);
	straddle2:=self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	self.assertNotNull(straddle2);
	
	tas.clear;
	tas.add(InterchangeSource);
	tas.add(InterchangeTarget);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	//amend target to fork lift area
	newLocation:=fk1.allLocationsControllers.first;
	task:=wle.allRTQueueEntries.first.allTasks.first;
	create allPossibleMoveMethodRules transient;
	wle.getMoveMethodRulesForNewTarget(newLocation,allPossibleMoveMethodRules);
	
	
	self.assertEqualMsg(allPossibleMoveMethodRules.size, 3, "possible move method rules mismatch");
	
	//should include 
	//straddle - &gt; Target IC -&gt; forklift move method
	stradTargICFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_16];
	//straddle - &gt; Source IC -&gt; forklift move method
	stradSourceICFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_31];
	//straddle - &gt; IMV  -&gt; forklift move method
	stradIMVFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_19];
	
	foreach moveMethodRule in allPossibleMoveMethodRules do
		if moveMethodRule.myRTMoveMethod = stradTargICFork then
			stradTargICForkRule:=moveMethodRule;
		elseif moveMethodRule.myRTMoveMethod = stradSourceICFork then
			stradSourceICForkRule:=moveMethodRule;
		elseif  moveMethodRule.myRTMoveMethod = stradIMVFork then
			stradIMVForkRule:=moveMethodRule;
		endif;
	
	endforeach;
	
	self.assertNotNullMsg(stradTargICForkRule,"Possible move method rule - Stad-TargetIC-Fork not found");
	self.assertNotNullMsg(stradSourceICForkRule,"Possible move method rule - Stad-SourceIC-Fork not found");
	self.assertNotNullMsg(stradIMVForkRule,"Possible move method rule - Stad-IMV-Fork not found");
	
		app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	//change to new target using strad -&gt; Target IC -&gt; Fork rule
	app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, task,null,null,stradIMVForkRule,app.myPassport);
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"New Target should have 3 rt queue entries");
	firstRTQueueEntry:=wle.allRTQueueEntries.first;
	
	self.assertNotNull(firstRTQueueEntry);
	self.assertEqualMsg(firstRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "Move method rule has changed");
	self.assertEqualMsg(firstRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Task Pickup Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_IMV, "Task Setdown machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.targetLocationId, "IMV", "Task Setdown target location");
	self.assertNotNull(firstRTQueueEntry.myNextRelatedEntry);
	self.assertNull(firstRTQueueEntry.myPreviousRelatedEntry);
	
	secondRTQueueEntry:=firstRTQueueEntry.myNextRelatedEntry;
	self.assertNotNull(secondRTQueueEntry);
	self.assertEqualMsg(secondRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "2nd Move method rule has changed");
	self.assertEqualMsg(secondRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Task Pickup Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.sourceLocation, st1.allGridControllersByRowColumn[1, 1], "2nd Task Setdown target location");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.targetLocation, newLocation, "2nd Task Setdown target location");
	
	self.assertNotNull(secondRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(secondRTQueueEntry.myPreviousRelatedEntry);

	thirdRTQueueEntry:=secondRTQueueEntry.myNextRelatedEntry;
	self.assertEqualMsg(thirdRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "3rd Move method rule has changed");
	self.assertEqualMsg(thirdRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "3rd Task Pickup Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Task Setdown machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.sourceLocationId, "IMV", "3rd Task Pickup  target location");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.targetLocation, newLocation, "3rd Task Pickup  target location");
	self.assertNull(thirdRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(thirdRTQueueEntry.myPreviousRelatedEntry);
	
	
epilog
	delete allPossibleMoveMethodRules;
	delete tas;
	delete allTasForIC;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTAmendTarget4" id="42151f9e-0742-4522-8cd9-5ad5ce01852e">
        <source>tRTAmendTarget4();
// cnwer1
/*

Purpose:	Amending a worked task first straddle machine has picked it up	change to new target using strad -&gt; Target IC -&gt; Fork rule	

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/

constants
	Container = "UT1001";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	InterchangeSource = "UT_IC1";
	InterchangeTarget = "UT_IC2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	
	Straddle1 = "UTS1";
	ForkLift1 = "UTF1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st1, st2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	straddle1,
	straddle2,
	fork	: CM_Machine;
	task	: CM_RTQueueTask;
	icSource,
	icTarget : CM_YardInterchangeArea;
	allTasForIC  : CM_TerminalAreaSet;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork, stradTargICFork,
	stradSourceICFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry: CM_RTQueueEntry;
begin
	/*self.deleteContainer(Container);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteTerminalArea(InterchangeSource);
	self.deleteTerminalArea(InterchangeTarget);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(ForkLift1);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForStraddleStack1, StraddleStack1,null,false);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForStraddleStack2, StraddleStack2,null,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);
	
	
	create allTasForIC transient;
	allTasForIC.add(st1);
	icSource:= self.addInterchangeArea(InterchangeSource,allTasForIC);
	
	
	allTasForIC.clear;
	allTasForIC.add(st2);
	allTasForIC.add(fk1);
	icTarget:= self.addInterchangeArea(InterchangeTarget,allTasForIC);
	q3:= self.addQueue(QueueForForkLift,icSource,icTarget,false);
	assertNotNull(q3);
	
	self.addTAAreaToQueue(q3,fk1,null);
	

	
	
	//move method straddle-&gt;source ic -&gt; forklift -&gt; target ic -&gt; straddle
	self.addMachineRule(st1,st2,RTMoveMethod_33);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(StraddleStack1); 
	tas.add(InterchangeSource);
	straddle1:=self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	self.assertNotNull(straddle1);
	
	tas.clear;
	tas.add(StraddleStack2);
	tas.add(InterchangeTarget);
	straddle2:=self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	self.assertNotNull(straddle2);
	
	tas.clear;
	tas.add(InterchangeSource);
	tas.add(InterchangeTarget);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift,null);
	self.assertNotNull(fork);
	
	
	self.machineLogon(straddle1);
	task := self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle1, task);
	self.machinePickup(straddle1);*/
	
	self.uRTAmendTarget4();
	
	
	fk1:=self.getTerminalArea(ForkLiftArea1).CM_GridArea;
	ti:=self.getTrackedItem(Container);
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	wle:=fmq.myWorkListEntry;
	straddle1:=self.getMachine(Straddle1);
	
	//amend target to fork lift area
	newLocation:=fk1.allLocationsControllers.first;
	task:=wle.allRTQueueEntries.first.allTasks.first;
	create allPossibleMoveMethodRules transient;
	wle.getMoveMethodRulesForNewTarget(newLocation,allPossibleMoveMethodRules);
	
	
	self.assertEqualMsg(allPossibleMoveMethodRules.size, 3, "possible move method rules mismatch");
	
	//should include 
	//straddle - &gt; Target IC -&gt; forklift move method
	stradTargICFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_16];
	//straddle - &gt; Source IC -&gt; forklift move method
	stradSourceICFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_31];
	//straddle - &gt; IMV  -&gt; forklift move method
	stradIMVFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_19];
	
	foreach moveMethodRule in allPossibleMoveMethodRules do
		if moveMethodRule.myRTMoveMethod = stradTargICFork then
			stradTargICForkRule:=moveMethodRule;
		elseif moveMethodRule.myRTMoveMethod = stradSourceICFork then
			stradSourceICForkRule:=moveMethodRule;
		elseif  moveMethodRule.myRTMoveMethod = stradIMVFork then
			stradIMVForkRule:=moveMethodRule;
		endif;
	
	endforeach;
	
	self.assertNotNullMsg(stradTargICForkRule,"Possible move method rule - Stad-TargetIC-Fork not found");
	self.assertNotNullMsg(stradSourceICForkRule,"Possible move method rule - Stad-SourceIC-Fork not found");
	self.assertNotNullMsg(stradIMVForkRule,"Possible move method rule - Stad-IMV-Fork not found");
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	//change to new target using strad -&gt; Target IC -&gt; Fork rule
	app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, task,null,null,stradTargICForkRule,app.myPassport);
	
	
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	

	
	
	//get wle check only 2 entries and source target etc
	
	self.assertEqualMsg(wle.allRTQueueEntries.size,2,"New Target should have 2 rt queue entries");
	firstRTQueueEntry:=wle.allRTQueueEntries.first;
	
	self.assertNotNull(firstRTQueueEntry);
	self.assertEqualMsg(firstRTQueueEntry.myRTMoveMethodRule , stradTargICForkRule, "Move method rule has changed");
	self.assertEqualMsg(firstRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Task Pickup Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_TARGETIC, "Task Setdown machine type group");
	self.assertNotNull(firstRTQueueEntry.myNextRelatedEntry);
	self.assertNull(firstRTQueueEntry.myPreviousRelatedEntry);
	
	secondRTQueueEntry:=firstRTQueueEntry.myNextRelatedEntry;
	self.assertNotNull(secondRTQueueEntry);
	self.assertEqualMsg(secondRTQueueEntry.myRTMoveMethodRule , stradTargICForkRule, "Move method rule has changed");
	self.assertEqualMsg(secondRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_LIFTER, "Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_TARGETIC, "Task Pickup Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_LIFTER, "Task Setdown machine type group");
	self.assertNull(secondRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(secondRTQueueEntry.myPreviousRelatedEntry);
	
	// should be the same wle as before the straddles task should not of been deleted
	self.assertEqualMsg(fmq,ti.allQueuedFutureMoves.first,"Not same fmq");
	self.assertEqualMsg(wle,ti.allQueuedFutureMoves.first.myWorkListEntry,"Not same wle");
	self.assertEqualMsg(task,firstRTQueueEntry.allTasks.first, " not same pickup task");
	self.assertEqualMsg(straddle1.allCurrentQueueTasks.last, firstRTQueueEntry.allTasks.last, " straddle still working same task");
	
epilog
	delete tas;
	delete allTasForIC;
	delete allPossibleMoveMethodRules;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTAmendTarget5" id="7abef853-0bed-45c8-be50-305273a4c8f2">
        <source>tRTAmendTarget5();
// cnwer1
/*

Purpose:		Amending a worked task originally straddle1-&gt;IMV-&gt; straddle2 and straddle1 has set container
				on IMV. changing target to an forklift stack. New rule will be  straddle1-&gt;IMV-&gt; fork.

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/

constants
Container = "UT1001";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	InterchangeSource = "UT_IC1";
	InterchangeTarget = "UT_IC2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	Straddle1 = "UTS1";
	ForkLift1 = "UTF1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st1, st2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	straddle1,
	straddle2,
	fork, imv	: CM_Machine;
	task	: CM_RTQueueTask;
	icSource,
	icTarget : CM_YardInterchangeArea;
	allTasForIC  : CM_TerminalAreaSet;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin

	self.uRTAmendTarget5();
	
	
	fk1:=self.getTerminalArea(ForkLiftArea1).CM_GridArea;
	st1:=self.getTerminalArea(StraddleStack1).CM_GridArea;
	ti:=self.getTrackedItem(Container);
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	wle:=fmq.myWorkListEntry;
	straddle1:=self.getMachine(Straddle1);
	imv 	:= self.getMachine(IMV);
	
	
	
	//amend target to fork lift area
	newLocation:=fk1.allLocationsControllers.first;
	task:=wle.allRTQueueEntries.first.allTasks.first;
	create allPossibleMoveMethodRules transient;
	wle.getMoveMethodRulesForNewTarget(newLocation,allPossibleMoveMethodRules);
	
	
	self.assertEqualMsg(allPossibleMoveMethodRules.size, 1, "possible move method rules mismatch");
	
	//should only include 
	//straddle - &gt; IMV  -&gt; forklift move method
	stradIMVFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_19];
	

	self.assertEqualMsg( allPossibleMoveMethodRules.first.myRTMoveMethod ,stradIMVFork,  "Possible move method rule - Stad-IMV-Fork not found");
	 
	stradIMVForkRule:=allPossibleMoveMethodRules.first;
	
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	//change to new target using strad -&gt; Target IC -&gt; Fork rule
	app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, task,null,null,stradIMVForkRule,app.myPassport);
	
	
	
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"New Target should have 3 rt queue entries");
	//get wle check only 2 entries and source target etc
	firstRTQueueEntry:=wle.allRTQueueEntries.first;
	
	self.assertNotNull(firstRTQueueEntry);
	self.assertEqualMsg(firstRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "Move method rule has changed");
	self.assertEqualMsg(firstRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_STRADDLE, "Task Pickup Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_IMV, "Task Setdown machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.targetLocation, imv.myMachineController, "Task Setdown target location");
	self.assertNotNull(firstRTQueueEntry.myNextRelatedEntry);
	self.assertNull(firstRTQueueEntry.myPreviousRelatedEntry);
	
	secondRTQueueEntry:=firstRTQueueEntry.myNextRelatedEntry;
	self.assertNotNull(secondRTQueueEntry);
	self.assertEqualMsg(secondRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "2nd Move method rule has changed");
	self.assertEqualMsg(secondRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Task Pickup Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.sourceLocation, st1.allGridControllersByRowColumn[1, 1], "2nd Task Setdown target location");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.targetLocation, newLocation, "2nd Task Setdown target location");
	
	self.assertNotNull(secondRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(secondRTQueueEntry.myPreviousRelatedEntry);

	thirdRTQueueEntry:=secondRTQueueEntry.myNextRelatedEntry;
	self.assertEqualMsg(thirdRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "3rd Move method rule has changed");
	self.assertEqualMsg(thirdRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "3rd Task Pickup Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Task Setdown machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.sourceLocationId, imv.myMachineController.id, "3rd Task Pickup  target location");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.last.targetLocation, newLocation, "3rd Task Setdown  target location");
	self.assertNull(thirdRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(thirdRTQueueEntry.myPreviousRelatedEntry);
	
	// should be the same wle as before the straddles task should not of been deleted
	self.assertEqualMsg(fmq,ti.allQueuedFutureMoves.first,"Not same fmq");
	self.assertEqualMsg(wle,ti.allQueuedFutureMoves.first.myWorkListEntry,"Not same wle");
	self.assertEqualMsg(task,firstRTQueueEntry.allTasks.first, " not same pickup task");
	self.assertEqualMsg(imv.allCurrentQueueTasks.first, secondRTQueueEntry.allTasks.first, " straddle still working same task");

epilog
	delete allPossibleMoveMethodRules;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTAmendTarget6" id="6da0910e-3c33-4d81-a9c8-ec9c728d376f">
        <source>tRTAmendTarget6();
// cnwer1
/*

Purpose:	Amending a worked task originally rtg1-&gt;IMV-&gt; rtg2 and rtg1 has set container
				on IMV then rtg2 has picked it up off the IMV. changing target to an forklift stack. New rule will be  RTG-&gt;IMV-&gt; fork.
				
		

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/
constants
	Container = "UT1001";
	RTGStack1 = "UT_R1";
	QueueForRTGStack1 = "UT_R1_Q";
	RTGStack2 = "UT_R2";
	QueueForRTGStack2 = "UT_R2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	RTG1 = "UTR1";
	ForkLift1 = "UTF1";
	RTG2 = "UTR2";
vars
	ti: CM_TrackedItem;
	rtgStack1, rtgStack2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	rtg1,
	rtg2,
	fork, imv	: CM_Machine;
	task	: CM_RTQueueTask;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForRTGStack1);
	self.deleteTerminalArea(RTGStack1);
	self.deleteQueue(QueueForRTGStack2);
	self.deleteTerminalArea(RTGStack2);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteQueue(QueueForForkLift);
	self.deleteMachine(RTG1);
	self.deleteMachine(RTG2);
	self.deleteMachine(ForkLift1);
	self.deleteMachine(IMV);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	self.deleteRTDevice("94");
	
	rtgStack1 := self.addRTGArea(RTGStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForRTGStack1,null ,rtgStack1,false);
	assertNotNull(q1);
	
	rtgStack2 := self.addRTGArea(RTGStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForRTGStack2, null,rtgStack2,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);

	q3:= self.addQueue(QueueForForkLift,fk1,null,false);
	assertNotNull(q3);

	self.addTAAreaToQueue(q3,rtgStack1.allAssociatedInterchangeAreas.first,null);
	self.addTAAreaToQueue(q3,rtgStack2.allAssociatedInterchangeAreas.first,null);
	//move method RTG -&gt; IMV -&gt; RTG
	self.addMachineRule(rtgStack1,rtgStack2,RTMoveMethod_14);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, rtgStack1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, rtgStack1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, rtgStack2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(RTGStack1); 
	rtg1:=self.addMachine(MACHINETYPE_RTG, RTG1, 91, tas, QueueForRTGStack1);
	self.assertNotNull(rtg1);
	
	tas.clear;
	tas.add(RTGStack2);
	rtg2:=self.addMachine(MACHINETYPE_RTG, RTG2, 92, tas, QueueForRTGStack2);
	self.assertNotNull(rtg2);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	imv:=self.addIMV(IMV,94,tas,QueueForForkLift);
	self.assertNotNull(imv);
	

	
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	self.machineLogon(rtg1);
	task := self.machineTaskRequest(rtg1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(rtg1, task);
	self.machinePickup(rtg1);
	
	self.machineLogon(imv);
	task := self.machineTaskRequest(imv);
	assertEqual(task.taskType, TASK_MOVE);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(imv, task);
	
	//setdown on the imv
	self.machineSetdown(rtg1,ti,imv.myMachineController.id);
	
	//second rtg pickup container off imv
	self.machineLogon(rtg2);
	task := self.machineTaskRequest(rtg2);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(rtg2, task);
	self.machinePickup(rtg2);
	
	
	//move method RTG -&gt; IMV -&gt; forklift
	self.addMachineRule(rtgStack2,fk1,RTMoveMethod_13);
	//start of test
	
	//amend target to fork lift area
	newLocation:=fk1.allLocationsControllers.first;
	task:=wle.allRTQueueEntries.first.allTasks.first;
	create allPossibleMoveMethodRules transient;
	wle.getMoveMethodRulesForNewTarget(newLocation,allPossibleMoveMethodRules);
	
	
	self.assertEqualMsg(allPossibleMoveMethodRules.size, 1, "possible move method rules mismatch");
	
	//should only include 
	//RTG - &gt; IMV  -&gt; forklift move method
	stradIMVFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_13];
	

	self.assertEqualMsg( allPossibleMoveMethodRules.first.myRTMoveMethod ,stradIMVFork,  "Possible move method rule - Stad-IMV-Fork not found");
	 
	stradIMVForkRule:=allPossibleMoveMethodRules.first;
	
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	//change to new target using strad -&gt; Target IC -&gt; Fork rule
	app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, task,null,null,stradIMVForkRule,app.myPassport);
	
	
	
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"New Target should have 3 rt queue entries");
	//get wle check only 2 entries and source target etc
	firstRTQueueEntry:=wle.allRTQueueEntries.first;
	
	self.assertNotNull(firstRTQueueEntry);
	self.assertEqualMsg(firstRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "Move method rule has changed");
	self.assertEqualMsg(firstRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_RTG, "Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "Task Pickup Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_IMV, "Task Setdown machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.targetLocationId, "IMV", "Task Setdown target location");
	self.assertNotNull(firstRTQueueEntry.myNextRelatedEntry);
	self.assertNull(firstRTQueueEntry.myPreviousRelatedEntry);
	
	secondRTQueueEntry:=firstRTQueueEntry.myNextRelatedEntry;
	self.assertNotNull(secondRTQueueEntry);
	self.assertEqualMsg(secondRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "2nd Move method rule has changed");
	self.assertEqualMsg(secondRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "2nd Task Pickup Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.sourceLocation, rtgStack2.allAssociatedInterchangeAreas.first.allGridControllersByRowColumn[1,1], "2nd Task Setdown target location");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.targetLocation, newLocation, "2nd Task Setdown target location");
	
	self.assertNotNull(secondRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(secondRTQueueEntry.myPreviousRelatedEntry);

	thirdRTQueueEntry:=secondRTQueueEntry.myNextRelatedEntry;
	self.assertEqualMsg(thirdRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "3rd Move method rule has changed");
	self.assertEqualMsg(thirdRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "3rd Task Pickup Move machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_LIFTER, "3rd Task Setdown machine type group");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.first.sourceLocationId,"IMV", "3rd Task Pickup  target location");
	self.assertEqualMsg(thirdRTQueueEntry.allTasks.last.targetLocation, newLocation, "3rd Task Setdown  target location");
	self.assertNull(thirdRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(thirdRTQueueEntry.myPreviousRelatedEntry);
	
	// should be the same wle as before the straddles task should not of been deleted
	self.assertEqualMsg(fmq,ti.allQueuedFutureMoves.first,"Not same fmq");
	self.assertEqualMsg(wle,ti.allQueuedFutureMoves.first.myWorkListEntry,"Not same wle");
	self.assertEqualMsg(rtg2.allCurrentQueueTasks.first, firstRTQueueEntry.allTasks.last, " rtg still working same task");


epilog
	delete allPossibleMoveMethodRules;
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTAmendTarget7" id="2dd84dee-a113-4746-b34b-4677b7e2b06f">
        <source>tRTAmendTarget7();
// cnwer1
/*

Purpose:			Amending a worked task originally rtg1-&gt;IMV-&gt; rtg2 and rtg1 has set container
				on IMV then rtg2 has picked it up off the IMV. changing target to an forklift stack. New rule will be  RTG-&gt;Source IC  -&gt; forklift .

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/

constants
	Container = "UT1001";
	RTGStack1 = "UT_R1";
	QueueForRTGStack1 = "UT_R1_Q";
	RTGStack2 = "UT_R2";
	QueueForRTGStack2 = "UT_R2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	RTG1 = "UTR1";
	ForkLift1 = "UTF1";
	RTG2 = "UTR2";
vars
	ti: CM_TrackedItem;
	rtgStack1, rtgStack2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	rtg1,
	rtg2,
	fork, imv	: CM_Machine;
	task	: CM_RTQueueTask;

	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin

	self.uRTAmendTarget7();
	
	fk1:=self.getTerminalArea(ForkLiftArea1).CM_GridArea;
	rtgStack2:=self.getTerminalArea(RTGStack2).CM_GridArea;
	ti:=self.getTrackedItem(Container);
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	wle:=fmq.myWorkListEntry;
	imv 	:= self.getMachine(IMV);
	rtg2:= self.getMachine(RTG2);

	
	//amend target to fork lift area
	newLocation:=fk1.allLocationsControllers.first;
	task:=wle.allRTQueueEntries.first.allTasks.first;
	create allPossibleMoveMethodRules transient;
	wle.getMoveMethodRulesForNewTarget(newLocation,allPossibleMoveMethodRules);
	
	
	self.assertEqualMsg(allPossibleMoveMethodRules.size, 1, "possible move method rules mismatch");
	
	//should only include 
	//RTG - &gt; Source IC  -&gt; forklift move method
	stradIMVFork:=app.myRoot.allRTMoveMethods[RTMoveMethod_10];
	

	self.assertEqualMsg( allPossibleMoveMethodRules.first.myRTMoveMethod ,stradIMVFork,  "Possible move method rule - RTG-Source IC-Fork not found");
	 
	stradIMVForkRule:=allPossibleMoveMethodRules.first;
	
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	//change to new target using strad -&gt; Target IC -&gt; Fork rule
	app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, task,null,null,stradIMVForkRule,app.myPassport);
	
	self.assertNoTrxErrors();
	
	self.assertEqualMsg(wle.allRTQueueEntries.size,2,"New Target should have 2 rt queue entries");
	//get wle check only 2 entries and source target etc
	firstRTQueueEntry:=wle.allRTQueueEntries.first;
	
	self.assertNotNull(firstRTQueueEntry);
	self.assertEqualMsg(firstRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "Move method rule has changed");
	self.assertEqualMsg(firstRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_RTG, "Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_IMV, "Task Pickup Move machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_SOURCEIC, "Task Setdown machine type group");
	self.assertEqualMsg(firstRTQueueEntry.allTasks.last.targetLocation, rtgStack2.allGridControllersByRowColumn[1, 1].getMyLaneController, "Task Setdown target location");
	self.assertNotNull(firstRTQueueEntry.myNextRelatedEntry);
	self.assertNull(firstRTQueueEntry.myPreviousRelatedEntry);
	
	secondRTQueueEntry:=firstRTQueueEntry.myNextRelatedEntry;

	self.assertEqualMsg(secondRTQueueEntry.myRTMoveMethodRule , stradIMVForkRule, "2nd Move method rule has changed");
	self.assertEqualMsg(secondRTQueueEntry.machineTypeGroup, MACHINETYPEGRP_LIFTER, "2nd Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_SOURCEIC, "2nd Task Pickup Move machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_LIFTER, "2nd Task Setdown machine type group");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.first.sourceLocation,rtgStack2.allGridControllersByRowColumn[1, 1].getMyLaneController, "2nd Task Pickup  target location");
	self.assertEqualMsg(secondRTQueueEntry.allTasks.last.targetLocation, newLocation, "2nd Task Setdown  target location");
	self.assertNull(secondRTQueueEntry.myNextRelatedEntry);
	self.assertNotNull(secondRTQueueEntry.myPreviousRelatedEntry);
	
	// should be the same wle as before the straddles task should not of been deleted
	self.assertEqualMsg(fmq,ti.allQueuedFutureMoves.first,"Not same fmq");
	self.assertEqualMsg(wle,ti.allQueuedFutureMoves.first.myWorkListEntry,"Not same wle");
	self.assertEqualMsg(rtg2.allCurrentQueueTasks.first, firstRTQueueEntry.allTasks.last, " straddle still working same task");
epilog
	delete allPossibleMoveMethodRules;
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTCompleteTask" id="65226a61-e42e-4c6b-9023-aedc019a559e">
        <source>tRTCompleteTask();
// cnwer1
/*

Purpose:	Tasks involving an IMV		

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwer1	Initial creation

*/

constants
	Container = "UT1001";
	RTGStack1 = "UT_R1";
	QueueForRTGStack1 = "UT_R1_Q";
	RTGStack2 = "UT_R2";
	QueueForRTGStack2 = "UT_R2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	RTG1 = "UTR1";
	ForkLift1 = "UTF1";
	RTG2 = "UTR2";
vars
	ti: CM_TrackedItem;
	rtgStack1, rtgStack2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	rtg1,
	rtg2,
	fork, imv,taskMachine	: CM_Machine;
	task,theTask	: CM_RTQueueTask;

	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
	
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForRTGStack1);
	self.deleteTerminalArea(RTGStack1);
	self.deleteQueue(QueueForRTGStack2);
	self.deleteTerminalArea(RTGStack2);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteQueue(QueueForForkLift);
	self.deleteMachine(RTG1);
	self.deleteMachine(RTG2);
	self.deleteMachine(ForkLift1);
	self.deleteMachine(IMV);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	self.deleteRTDevice("94");
	
	rtgStack1 := self.addRTGArea(RTGStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForRTGStack1,null ,rtgStack1,false);
	assertNotNull(q1);
	
	rtgStack2 := self.addRTGArea(RTGStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForRTGStack2, null,rtgStack2,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);


	q3:= self.addQueue(QueueForForkLift,fk1,null,false);
	assertNotNull(q3);
	self.addTAAreaToQueue(q3,rtgStack1.allAssociatedInterchangeAreas.first,null);
	self.addTAAreaToQueue(q3,rtgStack2.allAssociatedInterchangeAreas.first,null);
	//move method RTG -&gt; IMV -&gt; RTG
	self.addMachineRule(rtgStack1,rtgStack2,RTMoveMethod_14);
	
	self.addMachineRule(rtgStack2,fk1,	RTMoveMethod_10);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, rtgStack1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, rtgStack1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, rtgStack2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(RTGStack1); 
	rtg1:=self.addMachine(MACHINETYPE_RTG, RTG1, 91, tas, QueueForRTGStack1);
	self.assertNotNull(rtg1);
	
	tas.clear;
	tas.add(RTGStack2);
	rtg2:=self.addMachine(MACHINETYPE_RTG, RTG2, 92, tas, QueueForRTGStack2);
	self.assertNotNull(rtg2);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	imv:=self.addIMV(IMV,94,tas,QueueForForkLift);
	self.assertNotNull(imv);
	

	
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	// complete the pickup task for the first task of the first entry
	
	theTask:=wle.allRTQueueEntries.first.allTasks.first;
	taskMachine:=rtg1;
	app.myTrxUA.trxCompleteRTQueueEntry(theTask,false,false,taskMachine,null,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(theTask.status, TASK_COMPLETE,"task status &lt;&gt; complete");
	self.assertEqualMsg(theTask.myMachine, rtg1, "task machine &lt;&gt; rtg1");
	// rtg current queue task should be the setdown task of first entry
	self.assertEqualMsg(rtg1.allCurrentQueueTasks.first,wle.allRTQueueEntries.first.allTasks.last,"rtg1 working on setdown task");
	
	//setdown task
	theTask:=rtg1.allCurrentQueueTasks.first;
	//setdown to an imv so the imv is needed
	app.myTrxUA.trxCompleteRTQueueEntry(theTask,false,false,taskMachine,imv, null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(theTask.status, TASK_COMPLETE,"task status &lt;&gt; complete");
	self.assertEqualMsg(theTask.myMachine, rtg1, "task machine &lt;&gt; rtg1");
	// rtg current queue task should be the setdown task of first entry
	self.assertEqualMsg(rtg1.allCurrentQueueTasks.first,null,"rtg1 finished working on tasks");
	self.assertEqualMsg(wle.allRTQueueEntries[1].status, ENTRY_COMPLETE,"rtg 1  entry is complete");
	
	//imv should be working the move task
	self.assertEqualMsg(imv.allCurrentQueueTasks.first,theTask.myEntry.myNextRelatedEntry.allTasks.first,"rtg1 finished working on tasks");
	
	
	theTask:=wle.allRTQueueEntries.last.allTasks.first;
	taskMachine:=rtg2;
	//complete pickup of rtg2 - from the imv to the rtg
	app.myTrxUA.trxCompleteRTQueueEntry(theTask,false,false,taskMachine,null,null, null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(theTask.status, TASK_COMPLETE,"task status &lt;&gt; complete");
	self.assertEqualMsg(theTask.myMachine, rtg2, "task machine &lt;&gt; rtg2");
	// rtg current queue task should be the setdown task of first entry
	self.assertEqualMsg(rtg2.allCurrentQueueTasks.first,wle.allRTQueueEntries.last.allTasks.last,"rtg1 finished working on tasks");
	
	//check the imv task is finished
	self.assertEqualMsg(imv.allCurrentQueueTasks.size, 0, "IMV has finsihed tasks");
	self.assertEqualMsg(wle.allRTQueueEntries[2].status, ENTRY_COMPLETE,"imv move entry is complete");
epilog
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRTAmendTarget4" id="8d76aa0f-eaf3-4d5b-9fda-e385685fb4fb">
        <source>uRTAmendTarget4();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2011	cnwer1	Initial creation

*/
constants
	Container = "UT1001";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	InterchangeSource = "UT_IC1";
	InterchangeTarget = "UT_IC2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	
	Straddle1 = "UTS1";
	ForkLift1 = "UTF1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st1, st2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	straddle1,
	straddle2,
	fork	: CM_Machine;
	task	: CM_RTQueueTask;
	icSource,
	icTarget : CM_YardInterchangeArea;
	allTasForIC  : CM_TerminalAreaSet;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork, stradTargICFork,
	stradSourceICFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry: CM_RTQueueEntry;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteTerminalArea(InterchangeSource);
	self.deleteTerminalArea(InterchangeTarget);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(ForkLift1);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForStraddleStack1, StraddleStack1,null,false);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForStraddleStack2, StraddleStack2,null,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);
	
	
	create allTasForIC transient;
	allTasForIC.add(st1);
	icSource:= self.addInterchangeArea(InterchangeSource,allTasForIC);
	
	
	allTasForIC.clear;
	allTasForIC.add(st2);
	allTasForIC.add(fk1);
	icTarget:= self.addInterchangeArea(InterchangeTarget,allTasForIC);
	q3:= self.addQueue(QueueForForkLift,icSource,icTarget,false);
	assertNotNull(q3);
	
	self.addTAAreaToQueue(q3,fk1,null);
	

	
	
	//move method straddle-&gt;source ic -&gt; forklift -&gt; target ic -&gt; straddle
	self.addMachineRule(st1,st2,RTMoveMethod_33);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(StraddleStack1); 
	tas.add(InterchangeSource);
	straddle1:=self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	self.assertNotNull(straddle1);
	
	tas.clear;
	tas.add(StraddleStack2);
	tas.add(InterchangeTarget);
	straddle2:=self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	self.assertNotNull(straddle2);
	
	tas.clear;
	tas.add(InterchangeSource);
	tas.add(InterchangeTarget);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	
	self.machineLogon(straddle1);
	task := self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle1, task);
	self.machinePickup(straddle1);

epilog
	delete tas;
	delete allTasForIC;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRTAmendTarget5" id="5430152f-ed56-4f4e-b22a-4e92b2f8c150">
        <source>uRTAmendTarget5();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2011	cnwer1	Initial creation

*/

constants
Container = "UT1001";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	InterchangeSource = "UT_IC1";
	InterchangeTarget = "UT_IC2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	Straddle1 = "UTS1";
	ForkLift1 = "UTF1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st1, st2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	straddle1,
	straddle2,
	fork, imv	: CM_Machine;
	task	: CM_RTQueueTask;
	icSource,
	icTarget : CM_YardInterchangeArea;
	allTasForIC  : CM_TerminalAreaSet;
	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteTerminalArea(InterchangeSource);
	self.deleteTerminalArea(InterchangeTarget);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(ForkLift1);
	self.deleteMachine(IMV);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	self.deleteRTDevice("94");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForStraddleStack1, StraddleStack1,null,false);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForStraddleStack2, StraddleStack2,null,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);
	
	
	create allTasForIC transient;
	allTasForIC.add(st1);
	icSource:= self.addInterchangeArea(InterchangeSource,allTasForIC);
	
	
	allTasForIC.clear;
	allTasForIC.add(st2);
	allTasForIC.add(fk1);
	icTarget:= self.addInterchangeArea(InterchangeTarget,allTasForIC);
	q3:= self.addQueue(QueueForForkLift,icSource,icTarget,false);
	assertNotNull(q3);
	
	self.addTAAreaToQueue(q3,fk1,null);
	
	
	
	
	//move method straddle-&gt;IMV-&gt; straddle
	self.addMachineRule(st1,st2,RTMoveMethod_21);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(StraddleStack1); 
	tas.add(InterchangeTarget);
	straddle1:=self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	self.assertNotNull(straddle1);
	
	tas.clear;
	tas.add(StraddleStack2);
	tas.add(InterchangeTarget);
	straddle2:=self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	self.assertNotNull(straddle2);
	
	tas.clear;
	tas.add(InterchangeSource);
	tas.add(InterchangeTarget);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	tas.clear;
	tas.add(StraddleStack1);
	tas.add(StraddleStack2);
	tas.add(ForkLiftArea1);
	
	imv:=self.addIMV(IMV,94,tas,QueueForStraddleStack1);
	self.assertNotNull(imv);
	
	
	
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	self.machineLogon(straddle1);
	task := self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle1, task);
	self.machinePickup(straddle1);
	
	self.machineLogon(imv);
	task := self.machineTaskRequest(imv);
	assertEqual(task.taskType, TASK_MOVE);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(imv, task);
	
	
	self.machineSetdown(straddle1,ti,imv.myMachineController.id);

epilog
	delete tas;
	delete allTasForIC;
end;</source>
    </JadeMethod>
    <JadeMethod name="uRTAmendTarget7" id="438b4c7d-3666-41f8-8536-7b3d72fa52e9">
        <source>uRTAmendTarget7();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2011	cnwer1	Initial creation

*/

constants
	Container = "UT1001";
	RTGStack1 = "UT_R1";
	QueueForRTGStack1 = "UT_R1_Q";
	RTGStack2 = "UT_R2";
	QueueForRTGStack2 = "UT_R2_Q";
	QueueForForkLift = "UT_FK_Q";
	ForkLiftArea1 = "UT_FL1";
	IMV 	 = "UIMV";
	RTG1 = "UTR1";
	ForkLift1 = "UTF1";
	RTG2 = "UTR2";
vars
	ti: CM_TrackedItem;
	rtgStack1, rtgStack2, fk1: CM_GridArea;
	q1, q2, q3: CM_SubQueue;
	tas: StringArray;
	rtg1,
	rtg2,
	fork, imv	: CM_Machine;
	task	: CM_RTQueueTask;

	fmq 		: CM_FutureMoveQueued;
	wle 		: CM_WorkListEntry;
	newLocation	 : CM_LocationsController;
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule,	
	stradTargICForkRule,
	stradIMVForkRule,
	stradSourceICForkRule
	: CM_RTMoveMethodRule;
	stradIMVFork  : CM_RTMoveMethod;
	firstRTQueueEntry,
	secondRTQueueEntry,
	thirdRTQueueEntry: CM_RTQueueEntry;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForRTGStack1);
	self.deleteTerminalArea(RTGStack1);
	self.deleteQueue(QueueForRTGStack2);
	self.deleteTerminalArea(RTGStack2);
	self.deleteTerminalArea(ForkLiftArea1);
	self.deleteQueue(QueueForForkLift);
	self.deleteMachine(RTG1);
	self.deleteMachine(RTG2);
	self.deleteMachine(ForkLift1);
	self.deleteMachine(IMV);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	self.deleteRTDevice("94");
	
	rtgStack1 := self.addRTGArea(RTGStack1, 2, 2, 2);
	q1 := self.addQueue(QueueForRTGStack1,null ,rtgStack1,false);
	assertNotNull(q1);
	
	rtgStack2 := self.addRTGArea(RTGStack2, 2, 2, 2);
	q2 := self.addQueue(QueueForRTGStack2, null,rtgStack2,false);
	assertNotNull(q2);
	
	
	fk1:=self.addForkLiftStack(ForkLiftArea1,2,2,2);


	q3:= self.addQueue(QueueForForkLift,fk1,null,false);
	assertNotNull(q3);
	self.addTAAreaToQueue(q3,rtgStack1.allAssociatedInterchangeAreas.first,null);
	self.addTAAreaToQueue(q3,rtgStack2.allAssociatedInterchangeAreas.first,null);
	//move method RTG -&gt; IMV -&gt; RTG
	self.addMachineRule(rtgStack1,rtgStack2,RTMoveMethod_14);
	
	self.addMachineRule(rtgStack2,fk1,	RTMoveMethod_10);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, rtgStack1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, rtgStack1.allGridControllersByRowColumn[1, 1]);
	
	
	self.moveQueued(ti, rtgStack2.allGridControllersByRowColumn[1, 1]);
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	//self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(RTGStack1); 
	rtg1:=self.addMachine(MACHINETYPE_RTG, RTG1, 91, tas, QueueForRTGStack1);
	self.assertNotNull(rtg1);
	
	tas.clear;
	tas.add(RTGStack2);
	rtg2:=self.addMachine(MACHINETYPE_RTG, RTG2, 92, tas, QueueForRTGStack2);
	self.assertNotNull(rtg2);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	fork:=self.addForkLift(ForkLift1,93, tas,QueueForForkLift);
	self.assertNotNull(fork);
	
	tas.clear;
	tas.add(rtgStack1.allAssociatedInterchangeAreas.first.getID);
	tas.add(rtgStack2.allAssociatedInterchangeAreas.first.getID);
	tas.add(ForkLiftArea1);
	imv:=self.addIMV(IMV,94,tas,QueueForForkLift);
	self.assertNotNull(imv);
	

	
	
	fmq:=ti.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	self.assertNotNullMsg(fmq,"Queue failed - future queued move is null");
	wle:=fmq.myWorkListEntry;
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	self.machineLogon(rtg1);
	task := self.machineTaskRequest(rtg1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(rtg1, task);
	self.machinePickup(rtg1);
	
	self.machineLogon(imv);
	task := self.machineTaskRequest(imv);
	assertEqual(task.taskType, TASK_MOVE);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(imv, task);
	
	
	self.machineSetdown(rtg1,ti,imv.myMachineController.id);
	
	self.machineLogon(rtg2);
	task := self.machineTaskRequest(rtg2);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(rtg2, task);
	self.machinePickup(rtg2);

epilog
	delete tas;
end;</source>
    </JadeMethod>
</Class>
