        <source>utlUpdatePilotExemptCert(_proxy :HMS_PilotExemptionCertificate; _passport :CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars
	real			: HMS_PilotExemptionCertificate;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	
	_proxy.raiseExceptionIfNotProxy(method);
	
	_proxy.pxyGetRealObjectAndEdition(real, expectedEdition);
		
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, HMS_PilotExemptionCertificate.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valCM_Object(_proxy, _passport); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(real);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; real.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, CM_Gate.name, null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	
	if _passport.noErrors then
		real.setForUpdate(_proxy, _passport);
