    <JadeMethod name="buildComboAreas" id="aa543929-e6dc-413a-b436-50423e9f6ee1">
        <source>buildComboAreas();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwndl1	Initial creation

*/

vars

	idx : Integer;
	lRail : CM_TerminalArea;
	termAreaDict : CM_TAByIdDict;
	
begin

	self.cmbReturnAreas.clear;
	termAreaDict := self.myTerminal.getAllTAsOfType(TA_TYPE_RAILWAY_TRACK);

	foreach lRail in termAreaDict do // RR1 RR2
		idx := self.cmbReturnAreas.addItem(lRail.id);
		self.cmbReturnAreas.itemObject[idx] := lRail;
	endforeach;
	
	if self.cmbReturnAreas.listCount &gt; 0 then
		self.cmbReturnAreas.listIndex := 1;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboPosition" id="524dccdf-841e-4787-b63a-2d18baa52dde">
        <source>buildComboPosition(pRail : CM_Rail);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	lRow, lCol,idx, firstMT	: Integer;
	lID				: String;
	lRailLine	: CM_RailLine;
begin
	self.cmbReturnPos.clear;
	
	foreach lRow in 1 to  pRail.allRailLinesByIndex.size do
		lRailLine := pRail.allRailLinesByIndex[lRow];
		foreach lCol in 1 to lRailLine.maximumWagons do
			lID := lRailLine.getIdString.trimBlanks &amp; ' ' &amp; lCol.String.padLeadingZeros(2);
			idx := self.cmbReturnPos.addItem(lID);
			self.cmbReturnPos.itemObject[idx] := lRailLine;
			self.cmbReturnPos.itemData[idx] := lCol;
			
		endforeach;
	endforeach;
	if self.cmbReturnPos.listCount &gt; 0 and firstMT &gt; 0 then
		self.cmbReturnPos.listIndex := firstMT;
	endif;
end;</source>
        <Parameter name="pRail" type="CM_Rail"/>
    </JadeMethod>
