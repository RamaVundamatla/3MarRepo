    <JadeMethod name="btnRunAdhoc_click" id="3d750b46-30cb-4e9e-9a48-4ee37379ca5d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRunAdhoc_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 17/07/2012	cnwcs5	par 29601 - log excluded transactions (removed some redundant code)
vars
	startDate, endDate		: TimeStamp;
	item					: SOP_TableMaintItem;	// par 29601 July 2012
	obj						: Object;				// par 29601 July 2012
	
begin
	item := self.myCurrentTableItem;
	
	if item &lt;&gt; null and item.isKindOf(SOPTM_CamProtocol) then
		// Start Date/Time
		startDate.setDate(self.txtDateStart.getDate());		
		startDate.setTime(self.txtTimeStart.getTime());
		
		// End Date/Time
		endDate.setDate(self.txtDateEnd.getDate());
		endDate.setTime(self.txtTimeEnd.getTime());

		obj := self.myCurrentObject;
		
		if obj &lt;&gt; null and obj.isKindOf(CM_CamProtocol) then
			item.SOPTM_CamProtocol.doRunAdhoc(obj.CM_CamProtocol, startDate, endDate, self.chkLogExcluded.value);	// par 29601 July 2012
		endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
