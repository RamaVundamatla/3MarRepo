    <JadeMethod name="loadDataForFirstTime" id="034d7f33-d92c-481a-98a7-f1596afb8c6a">
        <updating/>
        <source>loadDataForFirstTime() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	jrwManager : JadeReportWriterManager;
	folders : HugeStringArray;
	names : StringArray;
	reportName : String;
	transientRep : JadeReportWriterReport;
	viewName : String;
	strStr : CM_StringWithString;

begin

	inheritMethod();
	
	if not self.allReportNamesByView.isEmpty then
		self.allReportNamesByView.purge();
	endif;
	
	create folders transient;
	create names transient;
	create jrwManager transient;
	
	jrwManager.getAllReportNames(folders, names);
	
	foreach reportName in names do		
		transientRep := jrwManager.getReport(reportName);
		viewName := transientRep.getReportingViewName();		
		delete transientRep;
		create strStr transient;
		strStr.set( viewName , reportName );
		allReportNamesByView.add( strStr );
	endforeach;

epilog

	delete jrwManager;
	delete names;
	delete folders;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateReportCmb" id="3d045ad3-1a64-4cc9-bd7a-52e84009e29e">
        <source>populateReportCmb(	_combo : ComboBox input; _view : String; _value : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	reportName : String;
	viewName : String;

	str : CM_String;
	strStr : CM_StringWithString;

begin

	_combo.clear();
	_combo.addItem( null );

	foreach str in self.allReportNamesByView do
		viewName := str.string; 
		if viewName = _view then
			reportName := str.CM_StringWithString.strString;
			_combo.addItem( reportName );
		endif;
	endforeach;
	
	if _value &lt;&gt; null then
		_combo.listIndex := _combo.findStringExact( 1, _value );
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_view" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="2d49e314-464c-4f34-8986-aa54e83f4f8b">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.tblInput1.userInputEnabled := true;
	
	// add is not available, so we only need to worry about edit
	self.showThumbnail(form.myProxyObject.CM_VoyageProcess);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="70e863c9-a368-4654-a09f-ff87df688c95">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars
	form : SOP_TableMaintForm;

begin
	inheritMethod();
	
	form := self.myForm;
	form.tblInput1.userInputEnabled := false;
	form.tblInput1.setValueByName(ETRow_ProcessHarbour, app.getErrorString( Dbl_Click_Edit_View ));
	form.tblInput1.setValueByName(ETRow_ProcessTerminal, app.getErrorString( Dbl_Click_Edit_View ));	//11 Jun 2018	NDL	TFS 39140
	form.tblInput1.setValueByName(ETRow_AddReportsForm, app.getErrorString( Dbl_Click_Edit_View ));//08 Feb 2019	NDL	TFS 43240
epilog

end;</source>
    </JadeMethod>
