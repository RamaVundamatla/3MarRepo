    <JadeMethod name="tblData_mouseDown" id="4aac00fc-41d5-4290-93e0-523463bc3784">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;


</source>
