    <JadeMethod name="addLCbyOID" id="30e23e78-8730-4a03-b851-b2cbc1e2812d">
        <source>addLCbyOID(_obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions
vars
	lcHolder 	: CMIF_LocationControllersByOid;
	oidStr 		: String;
begin

	if _obj = null then
		return;
	endif;
	
	// This is so that we can clear up when a restriction is deleted
	oidStr := self.getOidStringForObject(_obj);
	
	if  self.allOIDSbyOIDString.getAtKey(oidStr) = null then
		create lcHolder transient;
		
		lcHolder.objectString := oidStr;
		
		if _obj.isKindOf(CM_LabourRestriction) then
			_obj.CM_LabourRestriction.allLocationControllers.copy(lcHolder.allLocationControllers);
		
		elseif _obj.isKindOf(CM_SubBlockStack) then
			_obj.CM_SubBlockStack.allByPassedControllers.copy(lcHolder.allLocationControllers);
		endif;
		
		self.allOIDSbyOIDString.add(lcHolder);
	endif;

/*
	// This is so that we can clear up when a restriction is deleted
	oidStr := self.getOidStringForObject(_obj);
	if  self.allLCsByOID.getAtKey(oidStr,self.myLocationsController) = null then
		create lcHolder transient;
		lcHolder.objectString := oidStr;
		lcHolder.myLocationController := self.myLocationsController;
		self.allLCsByOID.add(lcHolder);
	endif;
	
*/

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addRest2Dict" id="ebbfb115-927b-4c2f-9fbc-78a001880ac1">
        <source>addRest2Dict() : Boolean;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="adjustEndX" id="171d55ad-2671-4a37-92d2-bb088389bf7e">
        <updating/>
        <source>adjustEndX(_theTI: CM_TrackedItem; _startX: Real io): Integer updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------

vars

	lcMultiplier, endX : Real;
begin

	endX := self.x2;	
	
	if _theTI = null then
		lcMultiplier := 1; // PAR 19082
	else
		 // PAR 16415 CCMS 1029
		lcMultiplier := _theTI.getMultiplierForDrawing();
	endif;

	if lcMultiplier &gt; 0 then

		if self.flipHorizontal then
			if lcMultiplier = 1 then
				if _theTI = null then
					endX := self.x1;
				else
					endX := _startX - (lcMultiplier * self.columnWidth);
				endif;
			else
				endX := _startX - (lcMultiplier * self.columnWidth) - self.columnSpacing; // PAR 19082
			endif;
		else
			if lcMultiplier = 1 then
				if _theTI = null then
					endX := self.x2;
				else
					endX := _startX + (lcMultiplier * self.columnWidth);
				endif;
				
			else
				endX := _startX + (lcMultiplier * self.columnWidth) + self.columnSpacing;
			endif;
			
		endif;

	/*	epr par 37386 20/1/16 not needed already done in setIconPositions
		if lcMultiplier = 1 then
			// Only 2 icons on a 20'
			self.attrMaxNum := 2;
		elseif lcMultiplier &gt; 1.5 then// PAR 16415
			// 5 icons on a 40'
			self.attrMaxNum := 5;
		else
			self.attrMaxNum := 4;// PAR 16415
		endif;*/
	endif;

	return endX.Integer;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_startX" type="Real" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustStartX" id="fbf27b3d-b66d-48c9-a828-dfd120620da3">
        <source>adjustStartX(_osTI : CM_TrackedItem; _lc : CM_LocationsController; _height : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 28/06/2018		jlgmd1			TFS #37853 - Fix drawing spaces around containers whos length doesn't fit the standard 20ft grid
//
// ---------------------------------------------------------------------------

vars
	key1, key2 : Point;
	offsetX, returnX : Real;
	isSwappedXY, found, hasItem : Boolean;
	fm : CM_FutureMove;
	tmpObj : Object;
	swapOffset, theFillColour, startY, osOffSet, backendOverHang, overhangOffset : Integer;
	fillSpace : Boolean;
	ti, stackTi : CM_TrackedItem;
begin
	
	returnX := self.x1;
	offsetX := self.x1;
	
	// Work out the drawing X for the offset on the LC
	if self.myLocationsController.offsetFlexi &gt; 0 and self.hasGotItemAtHeight(_height, true) then
		osOffSet := self.myLocationsController.offsetFlexi;	// PAR 18682
	endif;
	if  osOffSet &gt; 0 then
		hasItem := true;
		if self.flipHorizontal then
			offsetX := self.x2 - ((osOffSet/20) * self.columnWidth); 
		else
			offsetX := self.x1 + ((osOffSet/20) * self.columnWidth); 
		endif;
	endif;
	
	// Work out the drawing X for the Over hanging backend
	if  _osTI &lt;&gt; null then //and not self.drawFromNote then
		swapOffset := self.getSwapAdjustment(); // PAR 19604
		isSwappedXY := self.isSwapXY(); // PAR 19604
		fm :=_osTI.getFutureMoveForLC(QUEUE_MODE, _lc); // PAR 18682
		if fm = null then
			fm :=_osTI.getFutureMoveForLC(PLANNING_MODE, _lc); // PAR 18682
		endif;
		
		if fm &lt;&gt; null then
			if self.allGridObjects.findObjectInDictGetXY(fm, key1, key2)  then
				found := true;
				if isSwappedXY then // PAR 19604
					returnX := key2.y + swapOffset; // PAR 19604
				else
					returnX := key2.x + 1 ;
				endif;
			else
				if self.flipHorizontal then
					if not hasItem then
						osOffSet := _lc.offsetFlexi;	// PAR 18682
						if  osOffSet &gt; 0 then
							if self.flipHorizontal then
	//							offsetX := self.x2 - ((osOffSet/20) * self.columnWidth); 
								//returnX := self.x1 + ((osOffSet/20) * self.columnWidth); 
								returnX := self.x2 - ((osOffSet/20) * self.columnWidth);
							else
								offsetX := self.x1 + ((osOffSet/20) * self.columnWidth); 
							endif;
							found := true;
						endif;
					else
						returnX := offsetX;
						found := true;
					endif;
				endif;
			endif;
		endif;
		if not found then
			tmpObj := _osTI;
			if self.allGridObjects.findObjectInDictGetXY(tmpObj, key1, key2)  then
				found := true;
				if self.flipHorizontal then
					if isSwappedXY then // PAR 19604
						returnX := key1.y  - swapOffset ; // PAR 19604
					else
						returnX := key1.x - 1 ; // this only happens when we are flipped. If drawing the whole area  and flipped the lookup above is null
					endif;
				else
					if isSwappedXY then // PAR 19604 - rotated 90 degrees
						returnX := key2.y  + swapOffset ; // PAR 19604
					else
						returnX := key2.x + 1 ;
					endif;
				endif;
				
			else
				if self.flipHorizontal then
					osOffSet := _lc.offsetFlexi;	// PAR 18682
					if  osOffSet &gt; 0 then
						returnX := self.x2 - ((osOffSet/20) * self.columnWidth); 
						found := true;
					endif;					
				else
					returnX := offsetX;
				endif;
			endif;
		endif;
	else // use the X from the LC offset
		if self.flipHorizontal then
			if self.isForSatelliteView then // PAR 19283
				if hasItem then // PAR 19283
					returnX := offsetX; // PAR 19283
				else
					returnX := self.x2; // PAR 19283
				endif;
			else // PAR 19283
				returnX := (offsetX +  self.columnWidth); 
				if hasItem or self.isForOverview then //or self.isForSatelliteView then // PAR 19283
					returnX := offsetX;
				endif;
				if _lc &lt;&gt; null and _lc.isGap then
					returnX := offsetX + (self.x2 - self.x1);
				endif;
			endif;
		else
			returnX := offsetX;
		endif;
	endif;
	
	// vvv TFS 37853 Begin vvv
	// We might not be at the beginning or the end of our locations, so fill in the missing sections	
	if not self.flipHorizontal then
		//### Extra space to the left		
		if (returnX &gt; self.x1) then			
			if (_lc.allTrackedItems.size + _lc.allPlannedFutureMoves.size + _lc.allQueuedFutureMoves.size) &lt;&gt; 0 then
				fillSpace := true;
			endif;
			
			if fillSpace then
				if self.myLocationsController.hasPower() then 
					theFillColour := self.POWER_FILL_COLOUR;
				else
					if self.isForSatelliteView then // PAR 19283
						theFillColour := self.satelliteViewCellColour; // PAR 19283
					else
						theFillColour := Gray;
					endif;
				endif;
				startY := (self.y2 - (self.cellHeight.Integer * _height )).Integer;
				if self.isOSTiBeside(_lc, _height) then
					self.drawBlankSpace(self.myDrawingFrame, theFillColour, _height, returnX, startY, offsetX, (startY + 1 +  self.cellHeight.Integer), false);
				else
					self.drawBlankSpace(self.myDrawingFrame, theFillColour, _height, self.x1, startY, offsetX, (startY + 1 +  self.cellHeight.Integer), false);
				endif;
			endif;
			
			if offsetX &gt; returnX then
				returnX := offsetX;
			endif;
		else
			// If we're drawing a planned/queued TI and its not on screen yet, fix the returnX loc
			returnX := self.x1 + ((osOffSet/20) * self.columnWidth);
		endif;
		
	else
		//### Extra space to the right
		if hasItem then			
			if (returnX &lt; self.x2) and not self.isOSTiBeside(_lc, _height) then
				returnX := self.x2 - ((osOffSet/20) * self.columnWidth);
			
				if self.myLocationsController.hasPower() then 
					theFillColour := self.POWER_FILL_COLOUR;
				else
					if self.isForSatelliteView then // PAR 19283
						theFillColour := self.satelliteViewCellColour; // PAR 19283
					else
						theFillColour := Gray;
					endif;
				endif;
				startY := (self.y2 - (self.cellHeight.Integer * _height )).Integer;
				self.drawBlankSpace(self.myDrawingFrame, theFillColour, _height, self.x2, startY, returnX, (startY + 1 +  self.cellHeight.Integer),  false);				
			endif;
		endif;
	endif;
	// ^^^ TFS 37853 End ^^^
		
	return returnX;
end;</source>
        <Parameter name="_osTI" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
