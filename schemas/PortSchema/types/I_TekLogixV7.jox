	_p2 := fieldName;


	_jadeActiveXInvokeio('GetFieldAttributes', 1, '0.24,1.8,1.8,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395,3.16395', _p1, _p2, styleIsEntry, styleFixed, styleNoEcho, styleIsNumeric, styleIsRight, styleAutoXmit, flagAutoTab, flagIsBarcode, flagBlink, flagIsBold, flagFieldOff, flagReversed, flagSerialIO);

end;
</source>
