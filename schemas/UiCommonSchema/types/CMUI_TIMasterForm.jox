    <JadeMethod name="getCargoType" id="620aead1-bcbe-402b-80cd-1048309cce61">
        <updating/>
        <source>getCargoType(): Integer protected, updating;
/* ---------------------------------------------------------------------------
Created:	15 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
15/05/2025		navcs2	MTN-34843  Development - Fleet file Form implementation
------------------------------------------------------------------------------*/
vars

begin

	if self.modeStr.Integer = CargoType_Trailer then
		return CargoType_Trailer;
	
	elseif self.modeStr.Integer = CargoType_Generator then
		return CargoType_Generator;

	elseif self.modeStr.Integer = CargoType_Container then
		return CargoType_Container;
		
	elseif self.modeStr.Integer = CargoType_Wagon then	// 03 Jul 2009	NDL	CCMS 1067
		return CargoType_Wagon;
	
	elseif self.modeStr.Integer = CargoType_Mafi then	// 15/05/2025	navcs2	MTN-34843
		return CargoType_Mafi;							// 15/05/2025	navcs2	MTN-34843

	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'Unknown cargo type' );
		return null;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeIDKey" id="d0d6157a-8acc-4800-bd75-7640e599feb8">
        <source>getCargoTypeIDKey() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2008	cnwrd1	Initial creation

*/

vars

begin

if self.modeStr.Integer = CargoType_Trailer then // crap have a few....
		return 10000;
	
	elseif self.modeStr.Integer = CargoType_Generator then
		return 4;

	elseif self.modeStr.Integer = CargoType_Container then
		return 1;

	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'Unknown cargo type' );
		return null;
	endif;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="2d1a7af5-b2ff-4ca2-b8df-285990492595">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//30 Apr 2018	NDL	TFS 38313
//--------------------------------------------------
vars
	trailerXML, generatorXML, containerXML, wagonMasterXML : String;
	typeTag, typeXML: String;
	rtnStr, str		: String;
	
begin

// position is relative to type constants so need to update if the order is changed - especialy typeXML string.

	rtnStr := inheritMethod();

	str := self.tblData.getXmlStrForColumns(true);
	
//	if xmlStrTblDataArray.size &gt;= 1 then
//		generatorXML:= global.formatAsXMLPrefix( /*"MasterGenerator"*/self.CargoType_Generator.String )	&amp; self.xmlStrTblDataArray[1]	&amp; global.formatAsXMLSuffix(/*"MasterGenerator"*/self.CargoType_Generator.String );
//	endif;
//	if xmlStrTblDataArray.size &gt;= 2 then
//		containerXML:= global.formatAsXMLPrefix( /*"MasterContainer"*/self.CargoType_Container.String )	&amp; self.xmlStrTblDataArray[2]	&amp; global.formatAsXMLSuffix(/*"MasterContainer"*/self.CargoType_Container.String );
//	endif;
//	if xmlStrTblDataArray.size &gt;= 3 then
//		trailerXML	:= global.formatAsXMLPrefix( /*"MasterTrailer"*/self.CargoType_Trailer.String )	&amp; self.xmlStrTblDataArray[3]	&amp; global.formatAsXMLSuffix(/*"MasterTrailer"*/self.CargoType_Trailer.String) ;
//	endif;
//	if xmlStrTblDataArray.size &gt;= 4 then	// 06 Jul 2009	NDL	CCMS 1067
//		wagonMasterXML	:= global.formatAsXMLPrefix( self.CargoType_Wagon.String )	&amp; self.xmlStrTblDataArray[4]	&amp; global.formatAsXMLSuffix(self.CargoType_Wagon.String) ;
//	endif; 
	
	if self.xmlStrTblDataGen.trimBlanks &lt;&gt; null then
		generatorXML:= global.formatAsXMLPrefix( /*"MasterGenerator"*/self.CargoType_Generator.String )	&amp; self.xmlStrTblDataGen.trimBlanks &amp; global.formatAsXMLSuffix(/*"MasterGenerator"*/self.CargoType_Generator.String );
	endif;
	if self.xmlStrTblDataCont.trimBlanks &lt;&gt; null then
		containerXML:= global.formatAsXMLPrefix( /*"MasterContainer"*/self.CargoType_Container.String )	&amp; self.xmlStrTblDataCont.trimBlanks &amp; global.formatAsXMLSuffix(/*"MasterContainer"*/self.CargoType_Container.String );
	endif;
	if self.xmlStrTblDataTrailer.trimBlanks &lt;&gt; null then
		trailerXML	:= global.formatAsXMLPrefix( /*"MasterTrailer"*/self.CargoType_Trailer.String )	&amp; self.xmlStrTblDataTrailer.trimBlanks &amp; global.formatAsXMLSuffix(/*"MasterTrailer"*/self.CargoType_Trailer.String) ;
	endif;
	if self.xmlStrTblDataWagon.trimBlanks &lt;&gt; null then	// 06 Jul 2009	NDL	CCMS 1067
		wagonMasterXML	:= global.formatAsXMLPrefix( self.CargoType_Wagon.String )	&amp; self.xmlStrTblDataWagon.trimBlanks &amp; global.formatAsXMLSuffix(self.CargoType_Wagon.String) ;
	endif;
	
	
	typeTag := self.modeStr;

	
	if self.modeStr = self.CargoType_Trailer.String then
		typeXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag) &amp; generatorXML &amp; containerXML &amp; trailerXML &amp; wagonMasterXML;
	elseif self.modeStr = self.CargoType_Generator.String then
		typeXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag) &amp; generatorXML &amp; containerXML &amp; trailerXML &amp; wagonMasterXML;
	elseif self.modeStr = self.CargoType_Wagon.String then	// 06 Jul 2009	NDL	CCMS 1067
		typeXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag) &amp; generatorXML &amp; containerXML &amp; trailerXML &amp; wagonMasterXML;
	else
		typeXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag) &amp; generatorXML &amp; containerXML &amp; trailerXML &amp; wagonMasterXML;
	endif;

	str := str &amp;  typeXML;

	return rtnStr &amp; str;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
