    <JadeMethod name="loadLogErrors" id="210fbf22-ff18-4611-b42f-7a2687937fe8">
        <source>loadLogErrors(_checked : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	errorSet		: CM_LogLoadErrorByIdDict;
	logError		: CM_LogLoadError;
	obj				: Object;
	bolOut			: CM_BOLOut;
	bolExt			: CM_BOLExtLogOut;
begin
	//set controls
//	self.btnSelectAll.visible := true;
//	self.btnDeselectAll.visible := false;
	
	//reset log Table and logDynaDict
	self.myLogErrorDynaDict.clear();
	tblLogError.rows := tblLogError.fixedRows;
	
	bolExt := self.myCurrentBOLExt;
	if bolExt = null then
		return 0;
	endif;
	
	errorSet := bolExt.allLogLoadErrors;
	errorSet.copy(self.myLogErrorDynaDict);
	//eventually we will only want to display the logs that have errors here
	foreach obj in self.myLogErrorDynaDict do
		if obj.isKindOf(CM_LogLoadError) then
			self.addTblLogErrorRow(obj.CM_LogLoadError, _checked);
		endif;
	endforeach;
	tblLogError.colourRows(self.colorRow1, self.colorRow2);
	
	self.setStatusCaption();
	
	return self.myLogErrorDynaDict.size;	
end;</source>
        <Parameter name="_checked" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
