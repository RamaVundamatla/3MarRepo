    <JadeMethod name="showSwapTaskMenuOption" id="24e827ef-57fa-4ceb-b458-1856409cd7cc">
        <source>showSwapTaskMenuOption() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2013	cnwrd1	Initial creation
//nds TFS 2867 17/01/17 PKT - Bulk Process
*/

vars
	wleArray	: CM_WLEArray;	
	wleTable 	: CM_DataTable;
	wle1,
	wle2		: CM_WorkListEntry;
begin
	create wleArray transient;
	
	// cnwjk3 PAR 17951 - 31 October 2008 - current table now associated with last mouse click
	wleTable := self.myCurrentTable;
	if wleTable = null then
		if self.mnuTableContext.userObject.CM_DataTable = null then
			return false;
		else
			wleTable:=self.mnuTableContext.userObject.CM_DataTable;
		endif;
	endif;

	self.getAllWLEsInTableSelected(wleArray,wleTable,false);	//nds TFS 2867 17/01/17 PKT - Bulk Process

	if wleArray.size &lt;&gt; 2 then
		return false;
	endif;
	
	//ok we have 2 wle's now check to see if theya re suitable.
	
	wle1 := wleArray[1];
	wle2 := wleArray[2];
	
	// ok we need to check some stuff.
	// are then both releases?
	// are they for different trucks
	// same bulk release?
	// is one a director?
	
	
	if wle1.isReceipt or wle2.isReceipt then
		// at least one is a receipt so we wont swap
		return false;
	endif;
	
	if wle1.job.CM_RoadJob.myVehicleVisit = wle2.job.CM_RoadJob.myVehicleVisit then
		return false;
	endif;
	
	if wle1.isCompleteForJob or wle2.isCompleteForJob then
		return false;
	endif;
	
	// not sure we want this as a restriction but check if they are on the same bulk release.
	/*if wle1.myRequest.getBulkRelease &lt;&gt; wle2.myRequest.getBulkRelease then
		return false;
	endif;*/
	
	//are we bothered about directors?
	
	return true;
	
epilog
	delete wleArray;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblStageChange" id="69f9925e-7002-4a5a-b8b5-faf2d5a3d7c2">
        <updating/>
        <source>tblStageChange(	_obj :CM_Object input;	_wleTable : CM_DataTable input) updating, protected;
//--------------------------------------------------------------
//22/11/2017 cnwma1 TFS #7692 QNS - System buffering
//--------------------------------------------------------------
vars
	obj 			: CM_Object;
	roadJob 		: CM_RoadJob;
	itemIndex 		: Integer;
	oldArea			: CM_TerminalArea;
	invalidObject	: Boolean;
	roadOpObject	: CMIF_RoadOpObject;
begin
	// reset all form properties that relate to the currently selected item
	self.myCurrentWLE 			:= null;		
	self.myCurrentTrackedItem 	:= null;	
	self.myCurrentVehicle		:= null;
	self.myCurrentRoadJob		:= null;

	btnMoveIt.enabled 		:= false;	// cnwcs5 14/09/2009
	btnProcessRoad.enabled	:= false;	// cnwcs5 14/09/2009

	on Exception do app.handleDeletedObject (exception, _obj, invalidObject);
		
	if _obj.isKindOf(CM_WorkListEntry) then
		self.myCurrentWLE := _obj.CM_WorkListEntry;
		if self.myCurrentWLE.CM_WorkListEntry.job &lt;&gt; null and  
			self.myCurrentWLE.CM_WorkListEntry.job.isKindOf(CM_RoadJob) then
			self.myCurrentRoadJob := self.myCurrentWLE.CM_WorkListEntry.job.CM_RoadJob;
		endif;
	elseif _obj.isKindOf(CM_Vehicle) then
		self.myCurrentVehicle :=_obj.CM_Vehicle;	
		if self.myCurrentVehicle.allRoadJobs.size = 1 then
			self.myCurrentRoadJob := self.myCurrentVehicle.allRoadJobs.first.CM_RoadJob;
		endif;
	elseif _obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem:=_obj.CM_TrackedItem;
		if self.myCurrentTrackedItem.jobRoadReceive &lt;&gt; null then
			roadJob := self.myCurrentTrackedItem.jobRoadReceive;
		elseif self.myCurrentTrackedItem.jobRoadRelease &lt;&gt; null then
			roadJob := self.myCurrentTrackedItem.jobRoadRelease;
		endif;
		if roadJob &lt;&gt; null then
			self.myCurrentRoadJob := roadJob;
			self.myCurrentVehicle := roadJob.myVehicle;
		endif;
	endif;
	
	if self.myCurrentWLE &lt;&gt; null then
		self.myCurrentTrackedItem 	:= self.myCurrentWLE.myTrackedItem;
		self.myCurrentVehicle 		:= self.myCurrentWLE.getJobVehicle;
		
		if self.myCurrentVehicle &lt;&gt; null then
			if self.dkcVehicles.visible then           //22/11/2017 cnwma1 TFS #7828
				// clear ahything selected in the vehicles listbox
				self.lstJobs.clearAllSelected();
				// select the entry for the vehicle in the list
				itemIndex := self.lstJobs.findObject(self.myCurrentVehicle);
				if itemIndex &lt;&gt; -1 then
					self.lstJobs.itemSelected[itemIndex] := true;
				endif;
			endif;
		endif;
	endif;
	
	if not invalidObject then	// _obj is valid
		if dkbMacro.visible then				//22/11/2017 cnwma1 TFS #7828
			self.displayExtraInfoForObj(_obj);
		endif;
		//self.setNavigator(_obj);
		self.selectWLEforObject(_obj,_wleTable);	
		
		roadOpObject := self.myRoadOpController.findCMIF_RoadOpObjWithTable (_wleTable);// cnwcs5 14/09/2009
	
		if roadOpObject &lt;&gt; null then												// cnwcs5 14/09/2009
			btnMoveIt.enabled		:= roadOpObject.canMoveIt;						// cnwcs5 14/09/2009
			btnProcessRoad.enabled 	:= roadOpObject.canDoRoadExit;					// cnwcs5 14/09/2009
		else																		// cnwcs5 14/09/2009
			btnMoveIt.enabled 		:= false;										// cnwcs5 14/09/2009
			btnProcessRoad.enabled	:= false;										// cnwcs5 14/09/2009
		endif;																		// cnwcs5 14/09/2009
	else						// _obj was invalid
		if self.dkbMacro.visible then				//22/11/2017 cnwma1 TFS #7828
			self.displayExtraInfoForObj(null);
		endif;
		//self.setNavigator(null);
		self.selectWLEforObject(null,_wleTable);
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnProcessRoad.enabled:= false;
		self.btnMoveIt.enabled:= false;

	endif;

	self.setStatusBarCaption();
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStageDragDropEvent" id="c6ee78d9-27ef-46ae-a0d3-3e4b69b9f19e">
        <updating/>
        <source>tblStageDragDropEvent(table: Table input; win: Window ) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if win.isKindOf(CMUI_GridAreaForm) or
		win.isKindOf(CMUI_GridAreaDrawingFrame) or
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CM_DataTable) then
		self.tblStageReceiveDrop(table.CM_DataTable);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window"/>
    </JadeMethod>
    <JadeMethod name="tblStageMouseMoveEvent" id="3d1c407c-d8ce-4222-ba58-51e8732f7230">
        <updating/>
        <source>tblStageMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theTI : CM_TrackedItem;
begin
	if self.myCurrentWLE = null and self.myCurrentTrackedItem = null then
		return;
	endif;

	// check drag/drop detected
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then 
	   return;
	endif;

	self.origXPos := 0;
	self.origYPos := 0;	
	
	// check there is a trackedItem to move
	if self.myCurrentWLE &lt;&gt; null then
		theTI := self.myCurrentWLE.myTrackedItem;
	endif;
	
	if theTI = null then
		theTI := self.myCurrentTrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;

	if self.moveModeForm = REAL_MODE and
		not self.myRoadOpController.allCMIFRoadOpObjects[RoadOpsForm_Yard].allWLEs.includes(self.myCurrentWLE) then
		return;
	endif;
	
	
	app.myDraggedTrackedItem := theTI;
	
	self.dragTrackedItem(theTI, self.myCurrentWLE, table.CM_DataTable);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblStageReceiveDrop" id="dbe5ae7d-455b-48bd-8ca5-76e6830fd80c">
        <updating/>
        <source>tblStageReceiveDrop(_table : CM_DataTable input) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 Sep 2006	cnwer1	Initial creation - PAR#xxxx
14 Mar 2013 cnwer1 	Par 30903 can assign cargo to release requests that are queued - now convert director tasks to real tasks 
*/
vars
	ti : CM_TrackedItem;
	tiStr : String;
begin 
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),app.getErrorString (Make_selection), MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	if (not global.isValidObject(self.myCurrentWLE)) then
		self.tblStageChange(null,_table);
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),app.getErrorString (Make_selection), MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;	
	
	//epr more consistent make sure we can only do and instant move when vehicle is in the yard
	if app.myMoveController &lt;&gt; null and app.myMoveController.moveMode = REAL_MODE and not
		self.myRoadOpController.allCMIFRoadOpObjects[RoadOpsForm_Yard].allWLEs.includes(self.myCurrentWLE) then
		ti:=app.myMoveController.myTrackedItem;
		if ti &lt;&gt; null then
			tiStr :=ti.id;
		endif;
		app.msgBox(app.getErrorString1(Move_until_vehicle_yard,tiStr),app.getErrorString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
		if app.myMoveController &lt;&gt; null then
			delete app.myMoveController;
		endif;	
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
				
	
	if self.myCurrentWLE.isReceipt then
		//selected wle is a receipt, they could be sending it back to the vehicle
		self.moveTrackedItem(self.myCurrentWLE.getRoadReleaseLC(), self.myCurrentWLE,_table);
	else //selected wle is a release
	
		//06 Aug 2019	NDL	TFS 42876
		if app.myMoveController.myTrackedItem &lt;&gt; null then
			if app.myMoveController.myTrackedItem.canMergeBreakBulk then
				if not self.myAssistant.showMoveAmountForm( app.myMoveController ) then 
					return;
				endif;
			endif;
		endif;
		
		//epr par 34107 19/5/14
		self.assignTIToReleaseRequest(null,null);
	endif;
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStage_click" id="87f2c426-700d-4989-845a-53282111d104">
        <controlMethod name="CM_GroupingTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_click(_table: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwmh5	Initial creation  PAR 23634

*/

vars
	theRow		: Integer;
begin
	// don't select if is a grouping row
	if _table.CM_GroupingTable.isGroupingRow(_table.row) then
		_table.CM_GroupingTable.deselectRow(_table.row);
	endif;

	// PAR 33761 
	// ### table.fromRowColumnChanged is set to true in CM_DataTable if the rowColumnChg event fires.
	// ### it is reset to false at the end of this method
	// ### if it is still false then the rowColumnChg event has not fired.
	if not _table.fromRowColumnChanged then
		theRow := _table.row;
	
		if theRow &gt; _table.fixedRows then
			if _table.selectionType = CM_DataTable.SelectionType_Row then 
				_table.selectTheCurrentRow(theRow);
			endif;
		endif;
	endif;
	_table.fromRowColumnChanged := false; // PAR 33761 RESET
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStage_contextMenu" id="2666cb23-c2e9-4603-9caa-8f165cac11b0">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_contextMenu(_table: Table input; conwin: Window input; mouse: Boolean; _x: Integer; _y: Integer):Boolean updating;
// 24/06/2010	cnwcs5	par 24292 - make vehicle move menu for table same as for list
// 25/06/2010	cnwcs5	par 24292 - permission for Set Interchange Areas menu
// 24/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 New Disconnect menu item for containers on power during transit
// 17/01/2017 	cnwnds 	TFS 2867 PKT - Bulk Process
// 15/12/2022	navmp20	ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// 07/03/2023	navdap1	TFS 56996 FR | 53667 - EUP - Inspection App checks - Manual updates on Vehicle visit and Road exit screens
// 06/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
// 27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI
// 13/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy
// 08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
// 16 Sep 2025 	navhl20 Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars
	x 					: Real;
	y					: Real;
	obj	 				: CM_Object;
	visibleBeforeSep 	: Boolean;
	visibleAfterSep 	: Boolean;
	cmifRoadOp			: CMIF_RoadOpObject;
	menu				: Object;
	tiId 				: String;
	moveMenu			: MenuItem;			// par 24292
	ti					: CM_TrackedItem;	// par 24292
	i					: Integer;			// par 24292
	wle					: CM_WorkListEntry;	// par 24292
	gate 				: CM_Gate;
	user				: CM_User;
	invalidObj 			: Boolean;
	edition 			: Integer;
	truck 				: CM_Vehicle;
	recReqInfo 			: CM_ReceivalRequestInfo;
	isBulkGateVisit		: Boolean;//nds TFS 2867 17/01/17 PKT - Bulk Process
	vvr                 : CM_VehicleVisitRecord;  //15.12.2022 navmp20 TFS 55580
begin


	x 	:= _x;
	y 	:= _y;
	//Start 15.12.2022 navmp20 TFS 55580
	if self.myCurrentVehicle &lt;&gt; null then
		vvr := self.myCurrentVehicle.getCurrentVisit();  
	endif;
	//End 15.12.2022 navmp20 TFS 55580

	conwin.windowToScreen(x, y);
	self.screenToWindow(x, y);   // convert x, y relative to form
	
	// hide everything on the context menu
	self.doBuildMnuNullObj();
	
	
	// find out what we have selected in the table
	obj := _table.accessRow(_table.row).itemObject.CM_Object;
	
	
//	if obj.isKindOf(CM_WorkListEntry) then							//nds TFS 2867 17/01/17 PKT - Bulk Process
//		isBulkGateVisit := obj.CM_WorkListEntry.isBulkGateVisit();	//nds TFS 2867 17/01/17 PKT - Bulk Process
//	endif;															//nds TFS 2867 17/01/17 PKT - Bulk Process
	
	//09 Mar 2011	NDL	Par 19414
	if obj &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, obj, invalidObj);
		edition := obj.edition;
		if invalidObj then
			obj := null;
		endif;
		on Exception do null;
	endif;
	
	//22 Nov 2017	NDL - Moved from above do the exception handling first...
	if obj.isKindOf(CM_WorkListEntry) then							
		isBulkGateVisit := obj.CM_WorkListEntry.isBulkGateVisit();	
	endif;	
	
	// reset the dynamically create menuitems so they are not visible
	self.myRoadOpController.hideAllDynamicMenuItems();
	// make those which are relevent to this table visible 
	if _table.parent.isKindOf(CMUI_JadeDockBar) then
		cmifRoadOp := _table.parent.userObject.CMIF_RoadOpObject;
	endif;
	
	//if something other than a terminal area is selected
	if cmifRoadOp &lt;&gt; null and obj &lt;&gt; null and 
		not obj.isKindOf (CM_TerminalArea) and
		not obj.isKindOf (CM_LaneController) then
		
		foreach menu in cmifRoadOp.allMenuItems do
			if menu.MenuItem.name = self.mnuProceed.name then
				menu.MenuItem.visible := cmifRoadOp.canProceed(self.myCurrentVehicle, menu.MenuItem);
			else
				menu.MenuItem.visible := true;
			endif;
		endforeach;
		if not isBulkGateVisit then 										//nds TFS 2867 17/01/17 PKT - Bulk Process
			self.mnuMoveIt.visible 				:= cmifRoadOp.canMoveIt;
			self.mnuProcessRoadExit2.visible 	:= cmifRoadOp.canDoRoadExit; 
			self.mnuProcessRoadExit2.userObject	:= obj;
		else																//nds TFS 2867 17/01/17 PKT - Bulk Process
			self.mnuMoveIt.visible 				:= false;					//nds TFS 2867 17/01/17 PKT - Bulk Process
			self.mnuProcessRoadExit2.visible 	:=false; 					//nds TFS 2867 17/01/17 PKT - Bulk Process
		endif;																//nds TFS 2867 17/01/17 PKT - Bulk Process
		
		if self.myCurrentRoadJob  &lt;&gt; null then
			self.mnuRFIDTag.visible := self.myTerminal.hasRFIDTags;
			
			if self.myCurrentRoadJob.status = JOB_COMPLETE and self.myCurrentRoadJob.myVehicleVisit &lt;&gt; null then
				self.mnuCheckSeals.visible 			:= true;
				self.mnuCheckSeals.userObject 		:= self.myCurrentRoadJob.myVehicleVisit;
				self.mnuMaintainSeals.visible 		:= true;
				self.mnuMaintainSeals.userObject 	:= self.myCurrentRoadJob.myVehicleVisit;
			endif;
		endif;
		
		if self.myCurrentVehicle &lt;&gt; null then
			self.mnuEditRegistation.visible := true;
		endif;
		if self.myCurrentTrackedItem &lt;&gt; null then
			tiId := self.myCurrentTrackedItem.id;
			
			self.mnuEnquire.visible 	:= true;
			self.mnuEnquire.caption 	:= "Enquire on " &amp; tiId &amp; '...';
			self.mnuRemarks.visible 	:= true;
			self.mnuRemarks.caption 	:= "Edit remarks for " &amp; tiId &amp; '...';
			self.mnuRemarks.userObject 	:= self.myCurrentTrackedItem;
			if app.getMyUser.canDo(self.myTerminal, PmAdmCargoEnquiryMaint) and not isBulkGateVisit then //cwnrd1 par 29415 23.5.2012//nds TFS 2867 17/01/17 PKT - Bulk Process
				self.mnuUpdateDamage.visible		:= true; 
				self.mnuUpdateDamage.userObject 	:= self.myCurrentTrackedItem;
				self.mnuUpdateDamage.caption := app.getErrorString1(Update_Damage, tiId);				
			endif;
			// PAR #31018 add a disconnect menu item for receival reefers on power during transit					// PAR #31018
			if self.myCurrentTrackedItem.getOnPower and self.myCurrentTrackedItem.getOnPowerDuringTransit then		// PAR #31018
				if obj &lt;&gt; null and CM_WorkListEntry.hasInstance(obj) and not obj.CM_WorkListEntry.isReceipt then	// PAR #31018
				else																								// PAR #31018
					self.mnuDisconnect.visible		:= true;														// PAR #31018
					self.mnuDisconnect.caption		:= "Disconnect " &amp; tiId ;								// PAR #31018
					self.mnuDisconnect.userObject	:= self.myCurrentTrackedItem;									// PAR #31018
				endif;																								// PAR #31018
			endif;																									// PAR #31018
			
			if self.myCurrentTrackedItem.myMatchedTBA &lt;&gt; null and  // PAR 35574
				self.myCurrentTrackedItem.myPrimaryQueuedLocation = null then
				self.mnuAssignToTBA.visible := true; 
			endif;
		endif;
		// could be vehicle or wle
		if  CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;
			
			// pretty sure you can only move the vehicle while it is in the yard
			moveMenu := self.mnuMoveVehicle;
				
			if cmifRoadOp.canMoveVehicle then
				self.resetAllSubMenus (moveMenu);
				
				moveMenu.visible	:= true;
				moveMenu.userObject	:= obj;
				
				ti 	:= wle.myTrackedItem;
				i	:= 1;
				
				if wle.isReceipt then
					self.lstJobMoveVehicleContextMenu(moveMenu, i, ti , wle.getJobVehicle, true);
				else
					self.lstJobMoveVehicleContextMenu(moveMenu, i, ti , wle.getJobVehicle, false);
				endif;
				
				self.setupMoveSubMenus (moveMenu, null, i);
			else
				moveMenu.visible 	:= false;
				moveMenu.userObject	:= null;
			endif;
			
			//30 Sep 2011	NDL	Par 28285 - Assign ids to a 'receive by type' turning it into cargo items...
			if wle.isReceipt and wle.myTrackedItem = null then
				if wle.myRequest.isKindOf(CM_ReceivalRequest) and not wle.myRequest.CM_ReceivalRequest.allReceivalInfo.isEmpty then
					truck := wle.getJobVehicle;
					if truck &lt;&gt; null and truck.isOnsite and truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
						foreach recReqInfo in wle.myRequest.CM_ReceivalRequest.allReceivalInfo do
							if recReqInfo.myBooking &lt;&gt; null
							and recReqInfo.allTrackedItems.isEmpty then
								self.mnuAssignCargoIDs.visible := true;
								self.mnuAssignCargoIDs.userObject := recReqInfo.myReceivalRequest;
								break;
							endif;
						endforeach;
					endif;
				endif;
			endif;
			
			//epr par 33718 18/3/14
			if  wle.isReleaseByType then
				//epr par 34107 20/5/14
				self.mnuUndo.visible:=wle.myTrackedItem &lt;&gt; null;
				self.mnuAssignCargo.visible:= wle.myTrackedItem = null;	
			endif;
			
			//epr par 34174 21/5/14
			if not wle.isReceipt and wle.myRequest.isKindOf(CM_TIRequest) then		
				self.mnuSwapCargo.visible:= wle.status = WLE_UNACTIONED;			
			endif;
			
			//27/09/2023	navkc1	CR 60428 Task 60702
			if cmifRoadOp.isKindOf(CMIF_RoadOpPreGate) or cmifRoadOp.isKindOf(CMIF_RoadOpYard) then
				self.mnuCargoReview.visible := true;
				self.mnuCargoReview.userObject := _table;
			endif;
			
			self.mnuSendReport.visible := false;					//08.08.2025 navhl20 #35650
			if self.myCurrentRoadJob &lt;&gt; null then					//08.08.2025 navhl20 #35650
				self.mnuSendReport.visible := true;					
			endif;
			
			self.doBuildMnuTblObj(obj.CM_WorkListEntry, _table.CM_DataTable);	
		endif;
		
	endif;
	

	if obj &lt;&gt; null and cmifRoadOp &lt;&gt; null then						
		cmifRoadOp.setupGateLaneOption(obj, self.mnuGateLane);		
	else															
		self.mnuGateLane.visible := false;						
	endif;													

	self.mnuSetICAreas.visible	:= app.getMyUser.canDo(self.myTerminal, PmAdmMaintainICAreas);	// par 24292
	self.mnuInspect.visible 	:= app.isAllowedToInspect();	
	
	if obj &lt;&gt; null and 
		obj.isKindOf (CM_TerminalArea) or
		obj.isKindOf (CM_LocationsController) then
		self.mnuInspect.userObject := obj;
	else
		self.mnuInspect.userObject := null;
	endif;
	
	// only display separator if there are visible items before and after it
	visibleBeforeSep := mnuEnquire.visible or  mnuQueue.visible or mnuMoveIt.visible;
	visibleAfterSep := mnuRemarks.visible or mnuSetTargetLocn.visible or mnuComplete.visible or
			mnuAdditional.visible or mnuAssignToTBA.visible or mnuAddDeliveryRequest.visible or mnuDeleteCurrentEntry.visible or
			mnuReturnWorkEntry.visible or mnuProcessRoadExit2.visible or mnuSource.visible or
			mnuTurnAround.visible or  mnuRebuildWLEStatus.visible;
			
	self.mnuTableSep1.visible := visibleBeforeSep and visibleAfterSep;
	
	visibleBeforeSep := visibleBeforeSep or visibleAfterSep;
	visibleAfterSep := mnuColourLegend.visible or mnuColumnOrganiser.visible or mnuToggleMultiSelect.visible;

	self.mnuTableSep2.visible := visibleBeforeSep and visibleAfterSep;
	
	// separators for autoplan submenu
	visibleAfterSep := mnuUnplanAll.visible or mnuUnplanSelected.visible;
	
	// separators for queue submenu
	visibleBeforeSep := mnuQueueAll.visible or mnuQueueSelected.visible;
	visibleAfterSep := mnuUnqueueSelected.visible or mnuUnqueueAll.visible;
	
	self.mnuQueueSep.visible := visibleBeforeSep and visibleAfterSep;	
	
	user := app.getMyUser;
	
	if user.canDo(self.myTerminal, PmSealCheckType) then
		self.mnuRecSealCheck.visible := true;
		self.mnuRelSealCheck.visible := true;
		//+cnwml2 PAR25874 DCT CCMS 1131
		self.mnuRecSealCheck.caption := app.getString(Receiva_seal_check_type);
		self.mnuRelSealCheck.caption := app.getString(Release_seal_check_type);
		
		//+cnwml2 PAR23715 SFW CCMS1131
		if self.myCurrentRoadJob &lt;&gt; null then
			gate := self.myCurrentRoadJob.myGate;
			//+cnwml2 PAR25874 DCT CCMS 1131
			if gate &lt;&gt; null then
				self.mnuRecSealCheck.caption := self.mnuRecSealCheck.caption &amp; " (" &amp; gate.name &amp; ")";
				self.mnuRelSealCheck.caption := self.mnuRelSealCheck.caption &amp; " (" &amp; gate.name &amp; ")";
				self.mnuRecSCDefault.checked := gate.sealCheckReceival = SEAL_CHECK_DEFAULT;
				self.mnuRecSCFull.checked := gate.sealCheckReceival = SEAL_CHECK_FULL;
				self.mnuRecSCStrict.checked := gate.sealCheckReceival = SEAL_CHECK_STRICT;
				self.mnuRecSCView.checked :=  gate.sealCheckReceival = SEAL_CHECK_VIEW;
				self.mnuRecSCNone.checked :=  gate.sealCheckReceival = SEAL_CHECK_NONE;				
				self.mnuRelSCDefault.checked := gate.sealCheckRelease = SEAL_CHECK_DEFAULT ;
				self.mnuRelSCFull.checked := gate.sealCheckRelease = SEAL_CHECK_FULL;
				self.mnuRelSCStrict.checked := gate.sealCheckRelease = SEAL_CHECK_STRICT;
				self.mnuRelSCView.checked := gate.sealCheckReceival = SEAL_CHECK_VIEW;
				self.mnuRelSCNone.checked := gate.sealCheckReceival = SEAL_CHECK_NONE;
				
			else
				self.mnuRelSealCheck.visible := false;
				self.mnuRecSealCheck.visible := false;
			endif;
		else
			self.mnuRelSealCheck.visible := false;
			self.mnuRecSealCheck.visible := false;
		endif;
	else
		self.mnuRelSealCheck.visible := false;
		self.mnuRecSealCheck.visible := false;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuQueue.visible:= false;
		foreach menu in cmifRoadOp.allMenuItems do
			menu.MenuItem.visible := false;
		endforeach;
		
		self.mnuEditRegistation.visible:= false;
		self.mnuRebuildJobStatus.visible:= false;
		self.mnuRebuildWLEStatus.visible:= false;
		self.mnuCheckSeals.visible := false;
		self.mnuDoorsForward.visible:= false;
		self.mnuRFIDTag.visible:= false;
		self.mnuDeleteCurrentEntry.visible:= false;
		self.mnuTurnAround.visible:= false;
		self.mnuRemarks.visible:= false;
		self.mnuMoveIt.visible:= false;
		self.mnuProcessRoadExit.visible:= false;
		self.mnuMaintainSeals.visible := false;
		self.mnuMoveVehicle.visible:= false;
		self.mnuProcessRoadExit2.visible := false;
		self.btnProcessRoad.enabled:= false;
		self.btnMoveIt.enabled:= false;
		self.mnuWeigh.visible:= false;
		self.mnuGateLane.visible:= false;
		self.mnuRecSealCheck.visible:= false;
		self.mnuRelSealCheck.visible:= false;
		self.mnuSwapBRItem.visible := false;
		self.mnuSwapCargo.visible := false;
		self.mnuSwapTasks.visible := false;
		self.mnuUnassignTI.visible := false;
	endif;
	
	//Start 15.12.2022  navmp20 TFS 55580			// TFS 56996 moved up to before popupMenu
	self.mnuChangeStatus.visible := false;			// TFS 56996
	self.mnuSendInspection.visible := false;		// TFS 56996
	if app.myCurrentUserCan(self.myTerminal, PmGteInspectionStatusChange) and vvr &lt;&gt; null then		// 13/02/2024	navcs2	Bug 62454
		self.mnuChangeStatus.visible := true;
	endif;
	
	self.mnuStatusInCompleted.enabled := true;
	self.mnuStatusInNA.enabled := true;
	self.mnuStatusInPending.enabled := true;
	self.mnuStatusInFailed.enabled := true;
	self.mnuStatusOutCompleted.enabled := true;
	self.mnuStatusOutNA.enabled := true;
	self.mnuStatusOutPending.enabled := true;
	self.mnuStatusOutFailed.enabled := true;
	
	if vvr &lt;&gt; null then
		if vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then
			self.mnuStatusInCompleted.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionNA then 
			self.mnuStatusInNA.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionPending then
			self.mnuStatusInPending.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionFailed then
			self.mnuStatusInFailed.enabled := false;
		endif;		
			
		if vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then
			self.mnuStatusOutCompleted.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionNA then
			self.mnuStatusOutNA.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionPending then
			self.mnuStatusOutPending.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionFailed then
			self.mnuStatusOutFailed.enabled := false;
		endif;
	
		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionManualMsgSend) then
			self.mnuSendInspection.visible := true;
		endif;
	endif;
	//End 15.12.2022  navmp20 TFS 55580
	
	self.popupMenu(mnuTableContext, x.Integer, y.Integer);
	self.mnuColumnOrganiser.userObject := _table;

	return false;


end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblStage_dblClick" id="1ca2dc7d-9dbc-4e41-8c2e-18b851cbbb5b">
        <controlMethod name="CM_GroupingTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_dblClick(_table: CM_GroupingTable input) updating;

vars
	obj	 		: CM_Object;
	recRequest	: CM_ReceivalRequest;																							// cnwjk3 ccms 1071 19/02/10
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if _table.row &gt; _table.fixedRows then
		if _table.isDetailRow (_table.row) then
			obj := _table.accessRow(_table.row).itemObject.CM_Object;
			if obj.isKindOf(CM_YardWLE) and obj.CM_YardWLE.myRequest.isKindOf(CM_ReceivalRequest) then							// cnwjk3 ccms 1071 19/02/10
				recRequest := obj.CM_YardWLE.myRequest.CM_ReceivalRequest;														// cnwjk3 ccms 1071 19/02/10
				self.myAssistant.showCargoEnquiryFormForRcvlReq(recRequest, self.myMasterMenuAction);							// cnwjk3 ccms 1071 19/02/10
			else
				//epr par 34296 13/6/14
				if self.myCurrentTrackedItem = null then
					if obj.isKindOf(CM_WorkListEntry) then
						self.doRemarksUpdate(obj.CM_WorkListEntry.myRequest);
					endif;
				else		
					self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, false);
				endif;
			endif;
		endif;
	else
		self.resortTblWorkEntries(_table);	
	endif;
epilog
	
end;</source>
        <Parameter name="_table" type="CM_GroupingTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStage_dragDrop" id="a9be2fed-0918-4dfa-85bf-b601588aae58">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table.row &lt;= table.fixedRows then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	if (win = table) then	// dont allow drop from same table	PAR 7234
		return;
	endif;
	self.tblStageDragDropEvent(table, win);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblStage_groupHeadingDisplay" id="6fc4abb2-161c-4369-b0ae-0a97132eb44b">
        <controlMethod name="CM_GroupingTable::groupHeadingDisplay"/>
        <methodInvocation>event</methodInvocation>
        <source>tblStage_groupHeadingDisplay(_table: CM_GroupingTable; _any: Any):String;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin 

	//25 Mar 2011	NDL	Par 21775 - was being passed a String in the '_any' parameter as opposed to the CM_TerminalArea it was expecting. 

	if _any.isKindOf( CM_TerminalArea ) then
		return self.myRoadOpController.getAreaCaption_NameAndTotal (_table, _any.CM_TerminalArea);
	elseif _any.isKindOf( String ) then
		return _any.String;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_GroupingTable"/>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblStage_keyPress" id="d2b431a9-f75f-4946-93d4-a5a8e65f6fb6">
        <controlMethod name="Table::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_keyPress(table: Table input; keyCharCode: Integer io) updating;

vars

begin
	if keyCharCode = J_key_R then
		self.doRefresh();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblStage_mouseDown" id="0c630077-802a-4ae8-a135-9196f879cf99">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_mouseDown(table: CM_GroupingTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx
14/09/2009			cnwcs5	ccms1061 - only allow move/road exit for vehicle in yard
*/
vars
	obj 			: CM_Object;
	invalidObject	: Boolean;
begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
	// cnwjk3 PAR 17951 - 31 October 2008 - current table now associated with last mouse click
	self.myCurrentTable := table;
		
	on Exception do app.handleDeletedObject (exception, obj, invalidObject);
	
	obj := table.accessRow(table.row).itemObject.CM_Object;
	
	// if obj is invalid the exception will be trapped in the method below
	self.tblStageChange(obj, table);
epilog

end;</source>
        <Parameter name="table" type="CM_GroupingTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblStage_mouseMove" id="d0d8297e-e380-43fc-89c9-613bec25d310">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStage_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	tmpHeight : Real;	
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if table.row &gt; table.fixedRows then	
		self.tblStageMouseMoveEvent(table, button, shift, x, y);
	endif;


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="21e78e2c-f554-4003-b0db-92b381f5e12b">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//--------------------------------------------------
// Copied from CM_RoadOpsForm 3/8/06 by cnwer1
//--------------------------------------------------
vars

begin
	
	inheritMethod(eventTag); //27/03/2025	navkc1 JIRA Story MTN-34156
	
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.myRoadOpController.updateElapsedTimes();
	endif;
	
	self.beginTimerForRefresh();
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="919547f0-86fc-476b-ab2f-e1e3708f7b07">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2025 10:16:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017742, locale);
	btnCancel.translateCaption(Xlat_0016350, locale);
	btnClearFind.translateBubbleHelp(Xlat_0008866, locale);
	btnClearFind.translateCaption(Xlat_0008867, locale);
	btnClose.translateCaption(Xlat_0024558, locale);
	btnClosePref.translateBubbleHelp(Xlat_0004974, locale);
	btnClosePref.translateCaption(Xlat_0004975, locale);
	btnCloseSelect.translateBubbleHelp(Xlat_0012424, locale);
	btnCloseSelect.translateCaption(Xlat_0012425, locale);
	btnConfigAttr.translateBubbleHelp(Xlat_0021627, locale);
	btnConfigAttr.translateCaption(Xlat_0021628, locale);
	btnEdit.translateBubbleHelp(Xlat_0004652, locale);
	btnEdit.translateCaption(Xlat_0004654, locale);
	btnEventTrans.translateBubbleHelp(Xlat_0020196, locale);
	btnEventTrans.translateCaption(Xlat_0020197, locale);
	btnFindNext.translateBubbleHelp(Xlat_0008868, locale);
	btnFindNext.translateCaption(Xlat_0008869, locale);
	btnGate_Add.translateCaption(Xlat_0012426, locale);
	btnGate_AddAll.translateCaption(Xlat_0024559, locale);
	btnGate_Remove.translateCaption(Xlat_0012427, locale);
	btnGate_RemoveAll.translateCaption(Xlat_0024560, locale);
	btnHandheldOnly.translateCaption(Xlat_0004976, locale);
	btnHideCompleted.translateBubbleHelp(Xlat_0019007, locale);
	btnHideCompleted.translateCaption(Xlat_0019008, locale);
	btnHideFind.translateBubbleHelp(Xlat_0008870, locale);
	btnHideFind.translateCaption(Xlat_0008871, locale);
	btnHideSearcher.translateBubbleHelp(Xlat_0008872, locale);
	btnHideSearcher.translateCaption(Xlat_0008873, locale);
	btnICArea_Add.translateCaption(Xlat_0012428, locale);
	btnICArea_AddAll.translateCaption(Xlat_0024561, locale);
	btnICArea_Remove.translateCaption(Xlat_0012429, locale);
	btnICArea_RemoveAll.translateCaption(Xlat_0024562, locale);
	btnMoveIt.translateBubbleHelp(Xlat_0004646, locale);
	btnMoveIt.translateCaption(Xlat_0014666, locale);
	btnOK.translateCaption(Xlat_0016351, locale);
	btnOKPref.translateCaption(Xlat_0024563, locale);
	btnOperator_Add.translateCaption(Xlat_0024564, locale);
	btnOperator_AddAll.translateCaption(Xlat_0024565, locale);
	btnOperator_Remove.translateCaption(Xlat_0024566, locale);
	btnOperator_RemoveAll.translateCaption(Xlat_0024567, locale);
	btnPrint.translateBubbleHelp(Xlat_0004653, locale);
	btnPrint.translateCaption(Xlat_0004655, locale);
	btnProcessRoad.translateBubbleHelp(Xlat_0004638, locale);
	btnProcessRoad.translateCaption(Xlat_0004642, locale);
	btnResetFind.translateBubbleHelp(Xlat_0008874, locale);
	btnResetFind.translateCaption(Xlat_0008875, locale);
	btnShowFind.translateCaption(Xlat_0008876, locale);
	btnShowProblem.translateCaption(Xlat_0004977, locale);
	btnShowSearch.translateCaption(Xlat_0004644, locale);
	btnVAMoveDownGate.translateCaption(Xlat_0024568, locale);
	btnVAMoveDownICAreas.translateCaption(Xlat_0024569, locale);
	btnVAMoveDownOperator.translateCaption(Xlat_0024570, locale);
	btnVAMoveUpGate.translateCaption(Xlat_0024571, locale);
	btnVAMoveUpICAreas.translateCaption(Xlat_0024572, locale);
	btnVaMoveUpOperator.translateCaption(Xlat_0024573, locale);
	btnVehicleBook.translateCaption(Xlat_0019009, locale);
	chkCargoAttr.translateCaption(Xlat_0021629, locale);
	chkIncludeGateInLabel.translateCaption(Xlat_0024574, locale);
	chkPrefIn.translateCaption(Xlat_0004978, locale);
	chkPrefMacro.translateCaption(Xlat_0004979, locale);
