    <JadeMethod name="shiftQueueEntry" id="0a67d7f5-9e05-44dc-b6dc-086420bcf334">
        <source>shiftQueueEntry(pEntry : CM_RTQueueEntry input; pShiftBefore : CM_RTQueueEntry input);
//Shifts entry before shiftBefore.
/*

Date		Who		Reason
29 Jul 2013	cnwkpd1	PAR #32107 - change to prevent upgrade deadlocks on allEntries

*/

vars
	index		: Integer;
	terminal	: CM_Terminal;
begin
	//Check our status, can we accept entries?
	if status &lt;&gt; QSTATUS_RUNNING then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_Q_DISABLED, id, null, null);
		return;
	endif;

	// PAR #32107 - change check to the other end for performance and no shared lock
	if pEntry.myQueue &lt;&gt; self then
//	if (not self.allEntries.includes(pEntry)) then
		//-----------
	  	//Not here!!!
	  	//-----------
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ENTRY_NOTINQ, pEntry.id, id, null, null);
		return;
 	endif;
	
 	// PAR #32107 - change check to the other end for performance and no shared lock
	if pShiftBefore.myQueue &lt;&gt; self then
//	if (not self.allEntries.includes(pShiftBefore)) then
	  	//-----------
	  	//Target Not here!!!
	  	//-----------
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ENTRY_NOTINQ, pShiftBefore.id, id, null, null);
		return;
 	endif;
 	if pEntry = pShiftBefore then
		//Nothing to do! Already in correct spot.
		return;
 	endif;
	//---------------
	//Do the shift
	//---------------
	self.allEntries.remove(pEntry);
	index := self.allEntries.indexOf(pShiftBefore);
	self.allEntries.insert(index, pEntry);
	
	terminal := self.getMyTerminal();
  
	if terminal &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self,terminal.getTerminalEvent(Event_New_Queue_Entry),pEntry);
		app.myEventManager.createSingleObjInfoNoteEvt(self , terminal.getTerminalEvent(Event_Update_Queue_Entry), pEntry );
	endif;
end;</source>
        <Parameter name="pEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="pShiftBefore" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateMachineCoverage" id="29ce9e7d-16cb-4ba5-9a47-db48eee45a15">
        <source>updateMachineCoverage();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars
	entry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	iter,
	qIter : Iterator;
	entryHasMachineCoverage : Boolean;
	subQueue : CM_RadioTelemetryQueue;
begin
	
	iter:=self.allEntries.createIterator;
	while iter.next(entry) do
	
		task:=entry.allTasks.first;
		if task = null then
			continue;
		endif;

		entryHasMachineCoverage:=task.queryMachineCoverage(null);
		entry.setHasMachineCoverage(entryHasMachineCoverage);
	endwhile;
	
	
	qIter:=self.allSubQueuesByOrder.createIterator;
	while qIter.next(subQueue) do
		subQueue.updateMachineCoverage();
	endwhile;
	
epilog
	delete iter;
	delete qIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMachineCoverageForLocs" id="bfac02d6-f332-491e-a897-6413b18eba3a">
        <source>updateMachineCoverageForLocs(_allChangedRTGColumns : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2013	cnwer1	Initial creation PAR 31523

*/

vars
entry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	iter,
	qIter : Iterator;
	entryHasMachineCoverage,checkMachCoverage : Boolean;
	subQueue : CM_RadioTelemetryQueue;
begin
	
	if _allChangedRTGColumns = null then
		return;
	endif;
	
	iter:=self.allEntries.createIterator;
	while iter.next(entry) do
	
		task:=entry.allTasks.first;
		if task = null then
			continue;
		endif;
		checkMachCoverage:=false;
		if task.sourceLocation &lt;&gt; null and task.sourceLocation.isKindOf(CM_GridController) then
			checkMachCoverage:= _allChangedRTGColumns.includes(task.sourceLocation.CM_GridController.myGridColumn);
		endif;
		
		if not checkMachCoverage and task.targetLocation &lt;&gt; null and  task.targetLocation.isKindOf(CM_GridController) then
			checkMachCoverage:=_allChangedRTGColumns.includes( task.targetLocation.CM_GridController.myGridColumn);
			
		endif;
		
		if checkMachCoverage then
			
			entryHasMachineCoverage:=task.queryMachineCoverage(null);
			entry.setHasMachineCoverage(entryHasMachineCoverage);
			
			app.myEventManager.createSingleObjInfoNoteEvt(entry,entry.getMyTerminal.getTerminalEvent(RTQueueEntry_Update_Event),null);
			entry.sendNotesForRelatedEntry();
		endif;
	endwhile;
	
	
	qIter:=self.allSubQueuesByOrder.createIterator;
	while qIter.next(subQueue) do
		subQueue.updateMachineCoverageForLocs(_allChangedRTGColumns);
	endwhile;
	
epilog
	delete iter;
	delete qIter;

end;</source>
        <Parameter name="_allChangedRTGColumns" type="ObjectSet" usage="input"/>
    </JadeMethod>
