    <JadeMethod name="applySurcharges" id="117a8f47-59a6-4f09-a3c1-c2d556e5a8e7">
        <updating/>
        <source>applySurcharges() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018		jlgndl1	Initial creation	tfs 37818
17 Nov   2019       cnwma1	Bug 47208: JMT - Min Charges - Surcharge and Exemptions
19 Sep 2022			navpw1	TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges
02 Nov 2022			navpw1	TFS: 55285 - Fixed surcharge rate to be greater than/equal to
06 March 2023		navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
JIRA 35766 15AUG2025 NAVAB1 added 'SURG' to logging and changed logging levels and added more information.
*/

vars
	surChgExempt					: CM_InvoiceTypeSurchargeExempt;
	minChg							: Real;
	minChgInvLineType				: CM_InvoiceLineDesc;
	diff							: Real;
	
	newLine							: CM_InvoiceLine;
	seqNum							: Integer;
	charge							: CM_Charge;
	ctSurchargeRate, 
	invTotal						: Decimal [23,6];
	ctSurchgInvLineType				: CM_InvoiceLineDesc;
	addFees							: CM_InvTypeAdditionalCharges;
	addFeeInvType					: CM_InvoiceLineDesc;
	remark							: String; // TFS 38168
	vessel							: CM_Vessel;
	vessMinCharge					: CM_InvTypeVesselMinCharge;
	drMinCharge						: CM_InvTypeDebtorMinCharge;
	defaultDebtor					: CM_Debtor;
	defaultVessel					: CM_Vessel;
	typeString						: String;
	invoiceLine						: CM_InvoiceLine;
	invLineTotal					: Decimal [23,6]; 
	effectiveDT						: TimeStamp;
	conversionRate					: CM_CurrencyRate;
	rawDiff							: Real;
	createTaxableInvoice			: Boolean;
	invoiceForAddFees				: CM_Invoice;
	didCreateTaxInvoice				: Boolean;
	surchargeMultiSet				: CM_InvTypeCargoMultSchByFromDT;	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	ctSurChgMultiRate				: CM_InvTypeCargoMultiSurcharge;	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	ctSurchargeAmount,
	ctSurchargeGreaterThanEqualTo	: Decimal[23,3];					// ### TFS 54565 (54385) 21Sep2022 NAVPW1
	ctSurchargeGreaterThanLineTotal : Boolean;							// ### TFS 54565 (54385) 21Sep2022 NAVPW1
	invLineQuantity					: Real;								// ### TFS 54565 (54385) 21Sep2022 NAVPW1
	canLogExtra						: Boolean;							//26.02.2025 navah1	#34141
	theController					: CMIF_InvoiceLineManual;			//29/09/2025	navkc1 JIRA 35917
begin
	canLogExtra	:= app.canLogExtraDetail();								//26.02.2025 navah1	#34141
	//10 May 2019	NDL	TFS 44651
	if self.myOriginalAddFeesInvoice &lt;&gt; null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("SURG - Seperate Surcharge Invoice - Skipping Surcharge Checks", LogINFO.String);
		endif;
		return;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("SURG - Checking for Surcharges for invoice type '" &amp; self.invoiceType.description &amp; "'"    , LogINFO.String);
	endif;
	if self.invoiceType &lt;&gt; null then
		surChgExempt := self.invoiceType.mySurchargeAndExemptions;
	endif;
	if surChgExempt = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("SURG - No Surcharges found for invoice type '" &amp; self.invoiceType.description &amp; "'"    , LogTRACE.String);
		endif;
		return;
	endif;
	
	//01 Nov 2018	NDL	TFS 41684
	if surChgExempt.myCurrencyType &lt;&gt; null then
		effectiveDT := self.getRateDateForCurrencyCode();
		conversionRate := surChgExempt.myCurrencyType.getRate( effectiveDT );
	endif;
	
	defaultDebtor := CM_VoidDebtor.firstInstance;
	defaultVessel := CM_NullVessel.firstInstance;
	
	//Minimum charge code
	//05 Jun 2018	NDL	TFS 38914
	// Only do the first one found in order.  Vessel,  Debtor,  or Invoice.
	if self.myVoyage &lt;&gt; null then
		vessel := self.myVoyage.myVessel;
		if vessel &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Get minimum vessel charge from apply Surcharges", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
			endif;
			vessMinCharge := surChgExempt.getMinVessCharge( vessel, defaultVessel );
			if vessMinCharge &lt;&gt; null then
				minChgInvLineType := vessMinCharge.myMinimumChargeInvoiceLineType;
				minChg := vessMinCharge.minimumChargeAmount;
			endif;
		endif;
		if minChgInvLineType = null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - No related Vessel based minimum charge found", LogTRACE.String);
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141	
				app.invLog("SURG - Vessel based minimum charge found - line type '" &amp; minChgInvLineType.narration &amp; "'", LogTRACE.String);
			endif;
			typeString := "SURG - Vessel Based";
		endif;
		
		//10 May 2019	NDL	TFS 44651
		if surChgExempt.myInvoiceDescForSeperateTax &lt;&gt; null then
			if self.myVoyage.isTaxExempt( self.invoiceLines.first ) then
				createTaxableInvoice := true;
			endif;
		endif;
	endif;
	
	if minChgInvLineType = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("SURG - Get minimum debtor charges from apply Surcharges", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
		endif;
		drMinCharge := surChgExempt.getMinDebtorCharges( self.debtor, defaultDebtor );
		if drMinCharge &lt;&gt; null then
			minChgInvLineType := drMinCharge.myMinimumChargeInvoiceLineType;
			minChg := drMinCharge.minimumChargeAmount;
		endif;
		if minChgInvLineType = null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - No related Debtor based minimum charge found", LogTRACE.String);
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Debtor based minimum charge found - line type '" &amp; minChgInvLineType.narration &amp; "'", LogTRACE.String);
			endif;
			typeString := "SURG - Debtor Based";
		endif;
	endif;
	
	if minChgInvLineType = null then
		minChgInvLineType := surChgExempt.getMinChargeInvoiceLineType;
		minChg := surChgExempt.minimumChargeAmount;
		if minChgInvLineType = null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - No Invoice minimum charge found", LogTRACE.String);
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Invoice minimum charge found - line type '" &amp; minChgInvLineType.narration &amp; "'", LogTRACE.String);
			endif;
			typeString := "SURG - Invoice Based";
		endif;
	endif;
	
		
	if minChg &gt; 0 and minChgInvLineType &lt;&gt; null then
		//There is a minimum charge associated with this Invoice Type
		//invTotal := self.getTotalAmount(); // TFS 38168 
		invTotal := self.getTotalAmountConverted( conversionRate, null );	//01 Nov 2018	NDL	TFS 41684
		if invTotal &lt;= 0 then	//18 Dec 2018	NDL	TFS 42608
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - No Invoice Minimum Charge Applied, ignored, Invoice total = " &amp; invTotal.String, LogINFO.String);
			endif;
		elseif minChg &gt; invTotal then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG -  Invoice Minimum Charge Applied,Creating Invoice line to meet Invoice Minimum Charge " &amp; "(" &amp; typeString &amp; ")", LogINFO.String);
			endif;
			diff := minChg - invTotal;
			remark := "Invoice Total = " &amp; invTotal.String &amp; " " &amp; CM_Invoice.MinCharge &amp;" " &amp; minChg.String &amp; " Difference = " &amp; diff.String &amp; "(" &amp; typeString &amp; ")"; // TFS 38168
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG -  " &amp; remark, LogINFO.String); // TFS 38168
			endif;
			//01 Nov 2018	NDL	TFS 41684
			if minChgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
				// all good, generate the line as is
			else
				// convert diff to other currency
				rawDiff := diff;
				//diff := rawDiff / conversionRate.rate;
				diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	//28 Nov 2018	NDL	TFS 42218
				remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(remark, LogINFO.String);
				endif;
			endif;
			
			/*//29/09/2025	navkc1 JIRA 35917 Changed to use standard CMIF_InvoiceLineManual
			create newLine persistent;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			newLine.setForCreate(	seqNum,
									true,
									remark,
									minChgInvLineType,
									self,
									self.debtor,
									self.bank,
									1,
									app.actualTimeServer()
									);
			newLine.createCharges;
			foreach charge in newLine.charges do
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("SURG - " &amp; method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogWARN.String); // TFS 42084
				endif;
				charge.evaluateRate();
				charge.total := diff;
				// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
				charge.setOverriden();
				//charge.setRateForMinMax(charge.total);          //14.11.2019 cnwma1 # 47208
				charge.setRateForMinMax(diff);                    //14.11.2019 cnwma1 # 47208
			endforeach;
			*/
			
			//29/09/2025	navkc1 JIRA 35917
			create theController transient;
			theController.remarks := remark;
			theController.myInvoice := self;
			theController.quantity := 1;
			theController.chargeTime := app.actualTimeServer();
			theController.isOverridden := true;
			theController.totalAmount := diff;
			theController.rate := diff;
			
			newLine := minChgInvLineType.createManualInvoiceLine(theController, null, false);
			
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Invoice Minimum Charge already exceeded", LogINFO.String);
			endif;
		endif;
	endif;
	
	
	//Cargo Surcharge code
 // ### TFS 51219 03JUN2021 NAVAB1	voyage := self.myVoyage;
 // ### TFS 51219 03JUN2021 NAVAB1	if voyage &lt;&gt; null then
		//if not surChgExempt.allInvTypeCargoSurcharges.isEmpty() then
		if not surChgExempt.allInvTypeCargoMultiSurcharges.isEmpty() then									// ### TFS 54565 (54385) 20Sep2022 NAVPW1
			//New way	- 20 Jun 2018	NDL	TFS 39305
			//create surchargeSet transient;
			create surchargeMultiSet transient;																// ### TFS 54565 (54385) 19Sep2022 NAVPW1
 // ### TFS 51219 03JUN2021 NAVAB1			surChgExempt.getCargoTypeSurchargesForVoy( voyage, surchargeSet );
			//surChgExempt.getCargoTypeSurchargesForInv( self, surchargeSet );								// ### TFS 51219 03JUN2021 NAVAB1 use the invoice to get all the TIs, use the TI's cargotype to get all surcharges
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Surcharge exempt not empty for allInvTypeCargoMultiSurcharges to get Cargo Type Surcharges For Invoice", LogINFO.String);	// 1.3.2023 navmk20 TFS 56140
			endif;
			surChgExempt.getCargoTypeSurchargesForInv( self, surchargeMultiSet );							// ### TFS 54565 (54385) 19Sep2022 NAVPW1
			//if not surchargeSet.isEmpty then
			if not surchargeMultiSet.isEmpty then															// ### TFS 54565 (54385) 19Sep2022 NAVPW1
				foreach invoiceLine in self.invoiceLines discreteLock do
					if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
						continue;
					endif;
					//ctSurChgRate := surchargeSet.findFirstUsing( invoiceLine.invoiceLineDesc );
					//Should this check for myCargoSurchargeInvLineType was part of the original system design in WMAST????? Andrew Question
					ctSurChgMultiRate := surchargeMultiSet.findFirstUsing( invoiceLine.invoiceLineDesc );	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
					//if ctSurChgRate = null then
					if ctSurChgMultiRate = null then														// ### TFS 54565 (54385) 19Sep2022 NAVPW1
						//no surcharge to apply
						continue;
					endif;
					
					//ctSurchargeRate := ctSurChgRate.surchargeRate;
					//ctSurchgInvLineType := ctSurChgRate.getCargoSurchargeInvLineType();
					
					// ### TFS 54565 (54385) 19Sep2022 NAVPW1
					ctSurchargeRate					:= ctSurChgMultiRate.surchargeRate;
					ctSurchargeAmount				:= ctSurChgMultiRate.surchargeAmount;
					ctSurchargeGreaterThanEqualTo	:= ctSurChgMultiRate.applyGreaterThanAmount;
					ctSurchargeGreaterThanLineTotal	:= ctSurChgMultiRate.applyGreaterThanLineTotal;
					ctSurchgInvLineType				:= ctSurChgMultiRate.getCargoSurchargeInvLineType();
					// ### TFS 54565 (54385) 19Sep2022 NAVPW1
					
					//if ctSurchargeRate &gt; 0 and ctSurchgInvLineType &lt;&gt; null then
					if ctSurchargeRate &gt; 0 or ctSurchargeAmount &gt; 0 and ctSurchgInvLineType &lt;&gt; null then	// ### TFS 54565 (54385) 21Sep2022 NAVPW1
						//There is a surcharge associated with this Invoice Type for this cargo type
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("SURG - Creating Invoice line for 'cargo type surcharge' - line type " &amp; ctSurchgInvLineType.narration, LogTRACE.String);
						endif;
						//invLineTotal := invoiceLine.lineTotal;
						invLineTotal := invoiceLine.getLineTotalConverted( conversionRate );				//01 Nov 2018	NDL	TFS 41684
						invLineQuantity := invoiceLine.quantity;											// ### TFS 54565 (54385) 21Sep2022 NAVPW1
						//diff := invLineTotal * ( ctSurchargeRate / 100 );
						
						// ### TFS 54565 (54385) 21Sep2022 NAVPW1 - Replaces above line with new logic
						if ctSurchargeAmount &gt; 0 then //If we have a surcharge amount greater than 0 then apply a fixed rate
							if ctSurchargeGreaterThanLineTotal and invLineTotal &gt;= ctSurchargeGreaterThanEqualTo then				//If we are surcharging based on line total and the line total is greater than or equal to our surcharge greater than
																																	//(Was changed as Saurabh ased for greater than/equal to).
								diff := ctSurchargeAmount;																			//Then calculate the surcharge based off the fixed surcharge amount
							elseif not ctSurchargeGreaterThanLineTotal and invLineQuantity &gt;= ctSurchargeGreaterThanEqualTo then	//If we are surcharging based on quantity and the quantity for the line is greater than our surcharge greater than.
								diff := ctSurchargeAmount;																			//(Was changed as Saurabh ased for greater than/equal to).
																																	//Then calculate the surcharge based off the fixed surcharge amount
							else
								continue;
							endif;
						else //Calculate off a percentage
							if ctSurchargeGreaterThanLineTotal and invLineTotal &gt;= ctSurchargeGreaterThanEqualTo then 				//If we are surcharging based on line total and the line total is greater than our surcharge greater than.
								diff := invLineTotal * ( ctSurchargeRate / 100 );													//(Was changed as Saurabh ased for greater than/equal to).
																																	//Then calculate the surcharge based off the percentage
							elseif not ctSurchargeGreaterThanLineTotal and invLineQuantity &gt;= ctSurchargeGreaterThanEqualTo then 	//If we are surcharging based on quantity and the quantity for the line is greater than our surcharge greater than.
								diff := invLineTotal * ( ctSurchargeRate / 100 );													//(Was changed as Saurabh ased for greater than/equal to).
																																	//Then calculate the surcharge based off the percentage
							else
								continue;
							endif;
						endif;
						// ### TFS 54565 (54385) 21Sep2022 NAVPW1
						
						//remark := "Invoice Line Total = " &amp; invLineTotal.String &amp; " " &amp; CM_Invoice.CargoSurchargeRate &amp;" " &amp; ctSurchargeRate.String &amp; " Surcharge = " &amp; diff.String; 
						// ### TFS 54565 (54385) 21Sep2022 NAVPW1
						if ctSurchargeAmount &gt; 0 then
							remark := "Invoice Line Total = " &amp; invLineTotal.truncatedTo(2).asStringJMT() &amp; " " &amp; CM_Invoice.CargoSurchargeAmount &amp;" " &amp; ctSurchargeAmount.truncatedTo(2).asStringJMT() &amp; " Surcharge = " &amp; diff.asStringJMT(); 
							
						elseif ctSurchargeRate &gt; 0 then
							remark := "Invoice Line Total = " &amp; invLineTotal.truncatedTo(2).asStringJMT() &amp; " " &amp; CM_Invoice.CargoSurchargeRate &amp;" " &amp; ctSurchargeRate.truncatedTo(2).asStringJMT() &amp; " Surcharge = " &amp; diff.asStringJMT(); 
							
						endif;
						// ### TFS 54565 (54385) 21Sep2022 NAVPW1
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("SURG - " &amp; remark, LogINFO.String);
						endif;
						//01 Nov 2018	NDL	TFS 41684
						if ctSurchgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
							// all good, generate the line as is
						else
							// convert diff to other currency
							rawDiff := diff;
							//diff := rawDiff / conversionRate.rate;
							diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	//28 Nov 2018	NDL	TFS 42218
							remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
							if canLogExtra then	//26.02.2025 navah1	#34141
								app.invLog("SURG - " &amp; remark, LogINFO.String);
							endif;
						endif;
						
						/*//29/09/2025	navkc1 JIRA 35917 Changed to use standard CMIF_InvoiceLineManual
						create newLine persistent;
						seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
						newLine.setForCreate(	seqNum,
												true,
												remark,
												ctSurchgInvLineType,
												self,
												self.debtor,
												self.bank,
												1,
												app.actualTimeServer()
												);
						newLine.createCharges;
						foreach charge in newLine.charges do
							if canLogExtra then	//26.02.2025 navah1	#34141
								app.invLog("SURG - " &amp; method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
							endif;
							charge.evaluateRate();
							charge.total := diff;
							// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
							charge.setOverriden();
							//charge.setRateForMinMax(charge.total);          //14.11.2019 cnwma1 # 47208
							charge.setRateForMinMax(diff);                    //14.11.2019 cnwma1 # 47208
						endforeach;
						*/
						
						//29/09/2025	navkc1 JIRA 35917
						delete theController;
						create theController transient;
						theController.remarks := remark;
						theController.myInvoice := self;
						theController.quantity := 1;
						theController.chargeTime := app.actualTimeServer();
						theController.isOverridden := true;
						theController.totalAmount := diff;
						theController.rate := diff;
						
						newLine := ctSurchgInvLineType.createManualInvoiceLine(theController, null, false);
						
						newLine.setTotalAndTaxForResync();  // ### JIRA 35790 01SEP2025 NAVAB1
					endif;
					
				endforeach;
			endif;
			
		else
			if canLogExtra then	
				app.invLog("SURG - No Related Cargo Surcharges Found", LogTRACE.String);
			endif;
		endif;	
	 // ### TFS 51219 03JUN2021 NAVAB1 endif;
	
	//Additional Fees	TFS 37819
//	invTotal := self.getTotalAmount();  // TFS 38168 Re get all charges because we have to include them in this next calculation
	invTotal := self.getTotalAmountConverted( conversionRate, null );	//01 Nov 2018	NDL	TFS 41687
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("SURG - Apply charges for debtor/invTotal/defaultDebtor to get Invoice Type Add Fees For Invoice Total", LogINFO.String);	// 1.3.2023 navmk20 TFS 56140
	endif;
	addFees := surChgExempt.getInvTypeAddFeesForInvTotal( self.debtor, invTotal, defaultDebtor );
	if addFees &lt;&gt; null then
		
		//10 May 2019	NDL	TFS 44651
	//	invoiceForAddFees := self; //default value
		
		foreach addFeeInvType in addFees.allAdditionChargeInvTypes do
			
			if not addFeeInvType.taxAlwaysCharged or not createTaxableInvoice then	//10 Jun 2019	NDL	TFS 45017
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("SURG - Using 'Original Invoice' for this 'Additional fee'", LogINFO.String);
				endif;
				invoiceForAddFees := self;
				
			elseif createTaxableInvoice and addFeeInvType.taxAlwaysCharged then	//10 May 2019	NDL	TFS 44651
				if self.myAdditionalFeesInvoice = null then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("SURG - Creating Seperate Tax Invoice for 'Additional fee'", LogINFO.String);
					endif;
					didCreateTaxInvoice := true;
					create invoiceForAddFees persistent;
					invoiceForAddFees.initialise(	self.bank,									//theBusinessUnit	: CM_Bank;
													surChgExempt.myInvoiceDescForSeperateTax,	//theInvoiceType	: CM_InvoiceDesc;
													self.debtor,								//theDebtor			: CM_Debtor;
													null,										//tran				: CM_TITransaction;
													false,										//_forcedStatusOpen	: Boolean;
													self.paymentType							//_paymentType		: Integer
													);
					
					invoiceForAddFees.setVoyage( self.myVoyage );			//23 May 2019	NDL	TFS 44651
					invoiceForAddFees.setVesselName( self.myVoyage );		//23 May 2019	NDL	TFS 44651
					invoiceForAddFees.setMyWorkOrder( self.myWorkOrder );	//23 May 2019	NDL	TFS 44651
					
					self.myAdditionalFeesInvoice := invoiceForAddFees;
					
				else
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("SURG - Using Seperate Tax Invoice for this 'Additional fee'", LogINFO.String);
					endif;
					invoiceForAddFees := self.myAdditionalFeesInvoice;
					
				endif;
				
			endif;
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - Creating Invoice line for debtor additional fees", LogINFO.String);
			endif;	
				remark := "Debtor = " &amp; addFees.getNiceName(); // TFS 38168
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - " &amp; remark, LogINFO.String); // TFS 38168
			endif;
			
			/*//29/09/2025	navkc1 JIRA 35917 Changed to use standard CMIF_InvoiceLineManual
			create newLine persistent;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			newLine.setForCreate(	seqNum,
									true,
									remark,
									addFeeInvType,
									invoiceForAddFees,
									self.debtor,
									self.bank,
									1,
									app.actualTimeServer()
									);
			newLine.createCharges;
			
			foreach charge in newLine.charges do
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("SURG - " &amp; method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
				endif;
				charge.evaluateRate();
				charge.setOverriden(); // TFS 42084
 // TFS 38168				charge.isTotalSetExplicitly := true;
 // TFS 38168				charge.setRateForMinMax(charge.total);
			endforeach;
			newLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well
			*/
			
			//29/09/2025	navkc1 JIRA 35917
			delete theController; 
			create theController transient;
			theController.remarks := remark;
			theController.myInvoice := invoiceForAddFees;
			theController.quantity := 1;
			theController.chargeTime := app.actualTimeServer();
			theController.isOverridden := true;
			
			newLine := addFeeInvType.createManualInvoiceLine(theController, null, false);
			
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("SURG - " &amp; method.qualifiedName &amp; " New Invoice Line Created For Surcharge - " &amp; newLine.sequenceNum.String &amp; " total =  " &amp; newLine.lineTotal.String, LogINFO.String); // TFS 42084
			endif;
		endforeach;
		
		//10 May 2019	NDL	TFS 44651
		if didCreateTaxInvoice then
			invoiceForAddFees := self.myAdditionalFeesInvoice;	//14 Jun 2019	TFS 45177
			invoiceForAddFees.setStatus( self.status );
			if app.myPassport.noErrors then
				app.myAA.auditCreateTrx(invoiceForAddFees, invoiceForAddFees.getAuditText(), null);
				self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(Event_InvoiceCreate), false, invoiceForAddFees);
			endif;
		endif;
		
	else
		if canLogExtra then	
			app.invLog("SURG - No Related Invoice Type Add Fees Found", LogTRACE.String);
		endif;
	endif;
	
epilog
	//delete surchargeSet;
	delete theController; //29/09/2025	navkc1 JIRA 35917
	delete surchargeMultiSet; // ### TFS 54565 (54385) 19Sep2022 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="auditClass" id="c03f8612-e387-4d37-8237-42e26d9aeb78">
        <options>4</options>
        <source>auditClass(): Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin
	return CM_Invoice;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditDisplayString" id="f42759c7-3f96-431f-8531-34270c85827f">
        <source>auditDisplayString(): String;

vars

begin

	return "Audit Information for Invoice " &amp; sequenceNum.String;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="4247ea55-3d8a-44d6-bbcb-0d727ba0e3cc">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin
	return self.sequenceNum.String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="698fc1c7-e589-4aab-9ed0-626ea44263da">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS 37718
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	auditIdStr : String;
begin
	
	auditIdStr := self.auditId();			//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(Invoice) &amp; Space &amp; Hyphen &amp; Space &amp; auditIdStr;
	else
		return app.getErrorString(Invoice);
	endif;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="canBeApproved" id="5ccc20ad-f8c4-42fe-aaa4-2dab8fea75b8">
        <source>canBeApproved() : Boolean;
/*
Purpose:	

Date		Who		Reason
31 July 2025	navab1	JIRA 35468
*/

vars

begin
	if self.status &lt;&gt; CM_Invoice.INVOICE_POSTED_DRAFT 
	and self.status &lt;&gt; CM_Invoice.INVOICE_PENDING_APPROVAL then																			
		return false;
	endif;
	
	if not app.myCurrentUserCan(self.bank.terminal, PmInvoiceAdmin) then			
		return false;																													
	endif;																																
	
	if self.invoiceLines.isEmpty() then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeClosed" id="cdb487d8-eed1-4f48-a4f7-9c8b54c5d982">
        <source>canBeClosed() : Boolean;
/*

Date		Who		Reason
25/09/2015	cnwer1	Initial creation PAR 36958
03/04/2018	jlgdap1	TFS 37560 Prepend Invoice Status
*/

vars

begin
	return self.isOpen or self.isVoided
			or self.isPrepend or self.isDisputed;			// TFS 37560
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeExported" id="36090237-a786-48ca-b1fa-96c1a09b3738">
        <source>canBeExported() : Boolean;
/*

Date		Who		Reason
25 Sept2015	cnwer1	Initial creation PAR 36958
04 Mar 2020 cnwma1  ChangeRequest 48497: CPL - Credit invoice details for GreenTree Financial export files
01 Apr 2022	jlier1	TFS 53286
*/

vars
	finIO:   CM_ExtFinanceIO;
begin

	
	if self.isPosted then
		return true;
	endif;
	
	if self.isReverseCredit then
		return true;
	endif;
	
	
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO &lt;&gt; null and finIO.isKindOf(CM_SALInterface) then
		if self.isPostedReturned then
			return true;
		endif;
	else
		if self.isOpen and app.isSpecial then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePostDraft" id="fe263ddf-5d8e-44f8-942d-78b3f313365c">
        <source>canBePostDraft() : Boolean;
/*
Purpose:	

Date		Who		Reason
31 July 2025	navab1	JIRA 35468
*/

vars

begin
	if self.status &lt;&gt; CM_Invoice.INVOICE_PENDING_APPROVAL then																			
		return false;
	endif;
	
	if not app.myCurrentUserCan(self.bank.terminal, PmInvoiceAdmin) then			
		return false;																													
	endif;																																
	
	if self.invoiceLines.isEmpty() then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePosted" id="d5c067e5-ff7c-4abe-8603-cfc409ef810e">
        <source>canBePosted() : Boolean;
/* ---------------------------------------------------------------------------
Created:	12 November 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
	if self.status &lt;&gt; CM_Invoice.INVOICE_PENDING and
		self.status &lt;&gt; CM_Invoice.INVOICE_APPROVED and  // ### JIRA 35468 31JUL2025 NAVAB1 LINX status
		self.status &lt;&gt; CM_Invoice.INVOICE_POSTED_ERROR and 																				//navra1 - BUG 62652 - 1st March 2024
		self.status &lt;&gt; CM_Invoice.INVOICE_POSTED_PENDING then																			//navra1 - BUG 62652 - 1st March 2024
		return false;
	endif;
	
	if self.status = CM_Invoice.INVOICE_POSTED_PENDING and not app.myCurrentUserCan(self.bank.terminal, PmInvoiceAdmin) then			//navra1 - BUG 62652 - 1st March 2024
		return false;																													//navra1 - BUG 62652 - 1st March 2024
	endif;																																//navra1 - BUG 62652 - 1st March 2024
	
	 // ### JIRA 35465 31JUL2025 NAVAB8
	if self.status = CM_Invoice.INVOICE_PENDING
	and self.myInvoiceProcess.isLinxProcess() then
		return false;
	endif;
	
	// TFS 37904 jlgmd1 10/04/2018
	if self.invoiceLines.isEmpty() then
		return false;	// Don't post empty invoices
	endif;
	
	if self.unqualifiedAudits.isEmpty() then
		return true;
	else
		return self.myTerminal.getInvPostWithoutAuditQualify();	//ccms1773. Allows posting without audit qualify
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReevaluated" id="8d06c98f-8383-45c0-8685-3057bf1675c6">
        <source>canBeReevaluated() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	return not ( self.isPosted or self.isVoided);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReturned" id="cc7bc7a3-0538-4efd-9135-9b42782d47a5">
        <source>canBeReturned():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin

	if self.isCashInvoice then
		return false;
	endif;

	return self.isPosted;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeSuspended" id="c7564786-616c-4962-a03d-a57ab99c86e6">
        <source>canBeSuspended() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	if not self.isVoided then
		return false;
	endif;
	
	if self.invoiceType = null then
		return false;
	endif;
	
	return self.invoiceType.isTriggerOnRelease;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeVoided" id="2de8d369-769c-47af-8f28-82fde169bf7a">
        <source>canBeVoided() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/

vars

begin
	if self.paymentType = PaymentType_PrePay then                  //23.01.2019 cnwma1 TFS #42942
		return self.isOpen or self.isPrepend or self.isSuspended;  //23.01.2019 cnwma1 TFS #42942
	else
		return self.isOpen or self.isPending or self.isSuspended;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
