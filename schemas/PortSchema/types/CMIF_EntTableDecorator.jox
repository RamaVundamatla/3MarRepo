    <JadeMethod name="initDecorator" id="9792d188-e067-4ce1-8728-5fbdf9e862fa">
        <updating/>
        <source>initDecorator(	_terminal : CM_Terminal;
				_table : Table;
				_entTableDef : EntTableDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTerminal:=_terminal;
	self.myTable:=_table;
	self.myEntTableDef:=_entTableDef;
