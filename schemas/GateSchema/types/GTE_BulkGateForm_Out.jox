    <JadeMethod name="searchTable" id="1b238a22-d6f6-4b40-973b-a78eb387bb98">
        <source>searchTable(_table :CM_DataTable;_searchValue : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwns1	Initial creation

*/

vars
	searchValue : String;
	row 		: Integer;
	coll 		: Integer;	
	matchingRows : IntegerArray;
	cellText 	: String;
	table		: CM_DataTable;
begin
	searchValue := _searchValue;
	table := _table;
	
	if searchValue.isBlank() or table.rows = table.fixedRows then
		return;
	endif;
	
	create matchingRows transient;
	
	row := table.fixedRows + 1;
		
	while row &lt;= table.rows do
		coll := 1;
		while coll &lt;= table.columns   do
			cellText := tblItems.getCellText(row,coll);
			if cellText.toUpper().cnContains(searchValue) then
				if not matchingRows.includes(row) then
					matchingRows.add(row);
				endif;
			endif;
			coll := coll + 1;	
		endwhile;
		row := row + 1;
	endwhile;
	
	if matchingRows.size = 0 then
		return;
	endif;
	
	table.clearAllSelected;
	table.selectRow(matchingRows.first(),true);
	
epilog
	delete matchingRows;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_searchValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultGate" id="5fd73c71-38c1-49ab-aeb8-a9d789797331">
        <source>setDefaultGate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason


*/

vars
	gate : CM_Gate;
	
begin
	if not self.myBulkGateAgent.gateAndLaneSet then
		self.getXMLSettingsForSetup();									
	endif;
	
	gate := self.myBulkGateAgent.myGate;
	
	if gate = null then	 
		gate := self.myTerminal.getDefaultGate_OUT;	
	endif;
		
	if gate &lt;&gt; null and self.cmbGate.findObject(gate) &lt;&gt; -1 then	
		self.doChangeGate(gate);									
	else															
		self.cmbGate.setIndex(1);									
		self.doChangeGate(self.cmbGate.listObject.CM_Gate);			
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
