    <JadeMethod name="loadEnquiryCargo" id="e3964cd1-e800-4717-bdc9-fe763fb0d37c">
        <updating/>
        <source>loadEnquiryCargo( _table : Table input;_allFoundNonRTTIs: CM_TIArray input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	ti		: CM_TrackedItem;
begin

	app.myVMAgent.setupTableHeadings( _table);
	
	if _allFoundNonRTTIs &lt;&gt; null then
		iter:=_allFoundNonRTTIs.createIterator;
		while iter.next(ti) do
			app.myVMAgent.loadRTTableFromDTORTEntry(_table,ti);
		
		endwhile;
	endif;
	
	
	self.hideGFXFrames();
	self.resizeForNoGraphics();

		
	if self.isEnquiryMode and not app.myVMAgent.getMyRTVehicleConfig.allowNonRTMoves then
		self.btnAccept.visible:=false;
		self.btnReject.visible:=false;
	endif;
	self.btnAccept.caption:=app.getErrorString(Accept);
	self.btnReject.enabled:=true;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_allFoundNonRTTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadFrmMove2ndFields" id="98133b62-a279-40bd-9216-caffbe0daa1f">
        <source>loadFrmMove2ndFields(	_secondEntry : DTO_RTQueueEntry input;
						_cargoIDEntRow,
						_sourceEntRow,
						_accessEntRow,//22/06/2011 cnwdz2	27732
						_targetEntRow : String;
						_showSource,
						_showAccess, //22/06/2011 cnwdz2	27732
						_showTarget : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation

*/

vars
	rejectCell : JadeTableCell;
	dataColumn,targetRow : Integer;
	cargoIDEntRow,
	sourceEntRow,
	accessEntRow,
	targetEntRow : String;
	moveState	: Integer;
begin
	
	if _secondEntry = null then
		return;
	endif;
	dataColumn:=self.DataColumn;
	cargoIDEntRow :=_cargoIDEntRow;
	sourceEntRow :=_sourceEntRow;
	accessEntRow := _accessEntRow;
	targetEntRow := _targetEntRow;
	
	if  app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
		dataColumn:=5;
		cargoIDEntRow:=ETRow_CargoID;
		sourceEntRow:=ETRow_SourceID;
		accessEntRow:=ETRow_Access;
		targetEntRow:=ETRow_TargetID;
	endif;
	
	self.loadFrmMoveFields(_secondEntry,	
							cargoIDEntRow,
							sourceEntRow,
							accessEntRow,
							targetEntRow,
							_showSource,
							_showAccess, //22/06/2011 cnwdz2	27732
							_showTarget,
							dataColumn);
	
	moveState:=app.myVMAgent.getNextMoveState;
	
	if _showSource and moveState   =  VehicleMountedGenericAgent.PICKUP_TASK then
		self.btnRejectTask.visible:=true;
		self.myMoveTableDetails.setDataColumn(3);
		targetRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
		if targetRow &gt; 0 then
			rejectCell:=self.tblMoveEntry.accessCell(targetRow,dataColumn).cloneSelf(true);
			self.btnRejectTask.top:=self.tblMoveEntry.top + self.tblMoveEntry.accessRow(rejectCell.row).height ;
			//epr par 34682 4/8/14
			if 	(not self.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource) then
				self.btnRejectTask.top:=self.btnRejectTask.top  +  rejectCell.positionTop ;
			else
				self.btnRejectTask.top:=self.btnRejectTask.top  + 10;
			endif;
			self.btnRejectTask.left:=rejectCell.positionLeft;
			delete rejectCell;
		endif;
		
		if not  app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
			targetRow:=self.myMoveTableDetails.findRowWithEntRowName(targetEntRow);
		endif;
	
		if targetRow &gt; 0 then
			rejectCell:= self.tblMoveEntry.accessCell(targetRow,dataColumn).cloneSelf(true);
			if self.tblMoveEntry.top +  rejectCell.positionTop &gt; 0  then
				self.btnRejectTwin.visible:=true;
				//epr par 34682 4/8/14
				if self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
					self.btnRejectTwin.top:=self.btnRejectTask.top;
				else
					self.btnRejectTwin.top:=self.tblMoveEntry.top+ rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ;
				endif;
				self.btnRejectTwin.left:=rejectCell.positionLeft;	
			endif;
			delete rejectCell;
		endif;
	endif;
		
	if _showTarget and  moveState   =  VehicleMountedGenericAgent.SETDOWN_TASK then
		self.setBtnSwapVisible(targetEntRow);
	endif;
	//self.myMoveTableDetails.myTable.fitColumnWidth(3,0);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_secondEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_cargoIDEntRow" type="String"/>
        <Parameter name="_sourceEntRow" type="String"/>
        <Parameter name="_accessEntRow" type="String"/>
        <Parameter name="_targetEntRow" type="String"/>
        <Parameter name="_showSource" type="Boolean"/>
        <Parameter name="_showAccess" type="Boolean"/>
        <Parameter name="_showTarget" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFrmMoveFields" id="a0dd7a6b-561b-471d-b8b8-3916c6edc8d0">
        <source>loadFrmMoveFields(	_entry : DTO_RTQueueEntry input;
					_cargoIDEntRow,
					_sourceEntRow,
					_accessEntRow, //22/06/2011 cnwdz2	27732
					_targetEntRow : String;
					_showSource,
					_showAccess,  //22/06/2011 cnwdz2	27732
					_showTarget : Boolean;
					_dataColumn : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation
10 March 2015   cnwma1  PAR # 35797 Mulitple Containers on IMV does not work for VMT configured for PENN
*/

vars

	moveState,
	targetRow : Integer;
	rejectCell,targetCell : JadeTableCell;
	 cargoID ,  targetLocation : String;
	targetIsMachine : Boolean;
	access     : String;
	screenMode : CM_RTScreenConfig;
	cell	: JadeTableCell;
	useIMVlist : Boolean;
begin
	if _entry = null then
		return;
	endif;
	moveState:=app.myVMAgent.getNextMoveState;
	targetIsMachine:= _entry.myRealQueueEntry.CM_RTQueueEntry.isTargetAMachine;
	
	cargoID :=null;
	if  _entry.isForDirectorTask then
		cargoID :=null;
	else
		cargoID :=_entry.containerID;
	endif;
	self.myMoveTableDetails.setDataColumn(_dataColumn);
	self.myMoveTableDetails.addDataForEntRowName(_cargoIDEntRow,cargoID);
	
	self.myMoveTableDetails.setEntRowVisible(_sourceEntRow,_showSource);
	if _showSource then
		self.myMoveTableDetails.changeEntRowColInputType(_sourceEntRow,_dataColumn,Table.InputType_None);
		self.myMoveTableDetails.addDataForEntRowName(_sourceEntRow,_entry.currentLocationID);
	endif;
	
	//22/06/2011 cnwdz2 27732 start
	self.myMoveTableDetails.setEntRowVisible(_accessEntRow, false);
	if _showAccess then
		access := self.shouldShowAccessForkLiftStack(_entry);
		if access &lt;&gt; null then
			self.myMoveTableDetails.setEntRowVisible(_accessEntRow, true);
			self.myMoveTableDetails.changeEntRowColInputType(_accessEntRow,_dataColumn,Table.InputType_None);
			self.myMoveTableDetails.addDataForEntRowName(_accessEntRow,access);
		endif;
	endif;
	//22/06/2011 cnwdz2 27732 end
	
	self.myMoveTableDetails.setEntRowVisible(_targetEntRow,true);
	//epr par 25923 6/10/10
	self.setExtraDetails(_entry);	
	
	self.myMoveTableDetails.myTable.fitTableHeight();

	targetLocation:=_entry.getLocationTargetExtra; //epr par 30007 24/10/12
	if _showTarget then
		
	//	targetLocation:=_entry.queuedLocationID; //epr par 30007 24/10/12
		if (app.myVMAgent.canChangeTargetLocation() or targetIsMachine) and moveState &lt;&gt; VehicleMountedGenericAgent.ACCEPT_TASK then
			targetLocation:=_entry.getLocationTargetString;
			//09 April 2014	NDL	Par 33663
			if targetIsMachine then
				useIMVlist := self.getIMVListIsRequired();
			endif;
			if useIMVlist then
				if self.myTerminal.machines[targetLocation] = null then
					targetLocation:=null;
				endif;
				self.myMoveTableDetails.changeEntRowColInputType(_targetEntRow,_dataColumn,Table.InputType_ComboBox);
				targetRow:=self.myMoveTableDetails.findRowWithEntRowName(_targetEntRow);
				cell:=self.myMoveTableDetails.myTable.accessCell(targetRow,_dataColumn); 
				//cell.comboList:=app.myVMAgent.getIMVComboListStringForPenn;     		 // 10/03/2015  cnwma1 PAR #35797
				cell.comboList := app.myVMAgent.getIMVComboListStringForPenn(_entry);	 // 10/03/2015  cnwma1 PAR #35797
				
				if self.btnGraphic.visible and _targetEntRow = ETRow_TargetID  then
					rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(_targetEntRow),_dataColumn ).cloneSelf(true);
					delete rejectCell;
					self.btnTargetSearch.visible:=false;
				endif; 
				
			else
				self.myMoveTableDetails.changeEntRowColInputType(_targetEntRow,_dataColumn,Table.InputType_TextBox);
				
				if self.btnGraphic.visible and _targetEntRow = ETRow_TargetID  then
					rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(_targetEntRow),_dataColumn ).cloneSelf(true);
					self.btnTargetSearch.left:= self.tblMoveEntry.width - 	self.btnTargetSearch.clientWidth - 5; 
					self.btnTargetSearch.top:= self.tblMoveEntry.top +  rejectCell.positionTop;// -  self.tblMoveEntry.top;
					self.btnTargetSearch.visible:=true;
					self.btnTargetSearch.zOrder(1);
					delete rejectCell;
				endif; 
	
			endif;
			
			
		else
			self.myMoveTableDetails.changeEntRowColInputType(_targetEntRow,_dataColumn,Table.InputType_None);
		endif;
	else
		self.myMoveTableDetails.changeEntRowColInputType(_targetEntRow,_dataColumn,Table.InputType_None);
	endif;	
	
	if not useIMVlist or useIMVlist and targetLocation &lt;&gt; null then
		self.myMoveTableDetails.addDataForEntRowName(_targetEntRow,targetLocation);
	endif;

	targetRow:=self.myMoveTableDetails.findRowWithEntRowName(_targetEntRow);
	if targetRow  &gt; 0 then
		if targetIsMachine and
			_entry.moveVehicleID = null		then
			self.tblMoveEntry.accessCell(targetRow,_dataColumn).foreColor:=self.tblMoveEntry.getSystemColor(Control.Color_3DShadow);
		else
			
			if self.tblMoveEntry.accessCell(targetRow,_dataColumn).foreColor = self.tblMoveEntry.getSystemColor(Control.Color_3DShadow) or
				self.lastMoveState &lt;&gt; moveState then
			
				self.tblMoveEntry.accessCell(targetRow,_dataColumn).foreColor:=app.myVMAgent.getMyScreenMode.screenForeColour;
				self.tblMoveEntry.accessCell(targetRow,_dataColumn-1 ).foreColor:=app.myVMAgent.getMyScreenMode.screenForeColour;
			endif;
		endif;
		
		
		
	endif;
	

	
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_entry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_cargoIDEntRow" type="String"/>
        <Parameter name="_sourceEntRow" type="String"/>
        <Parameter name="_accessEntRow" type="String"/>
        <Parameter name="_targetEntRow" type="String"/>
        <Parameter name="_showSource" type="Boolean"/>
        <Parameter name="_showAccess" type="Boolean"/>
        <Parameter name="_showTarget" type="Boolean"/>
        <Parameter name="_dataColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadICCombo" id="73d4a612-7b6f-44a5-84e2-1ab4a9b032d4">
        <source>loadICCombo(_isSource : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwer1	Initial creation

*/

vars
	row,foundHeight : Integer;
	cell	: JadeTableCell;
	icArea : CM_InterchangeArea;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	ti : CM_TrackedItem;
	locID		: String;
	theLocation,
	lc,
	defaultLC: CM_LocationsController;
	allLCs 		: CM_LCArray;
begin
	row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_IcArea);
	if row &lt;&gt; null then
		cell:=self.myMoveTableDetails.myTable.accessCell(row,3); 
	endif;
	
	dtoRTQueueEntry:=self.getWorkingDTOEntry;
	ti:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry.getTrackedItem;

	if _isSource then
		// container will be on the vehicle get the tis prior location
		locID:=ti.priorLocation;
	else
		locID:=dtoRTQueueEntry.queuedLocationID;
	endif;
	
	app.myVMAgent.myTerminal.findLocationFromString(locID,true,theLocation,foundHeight);	
	
	create allLCs transient;
	theLocation.getAllInterchangeLocations(allLCs);
	cell.comboList:=null;
	foreach lc in allLCs do
		cell.comboList:=cell.comboList &amp; Tab &amp; lc.getFullId;
	endforeach;
	defaultLC:=theLocation.getDefaultInterchangeLocation();
	
	if defaultLC &lt;&gt; null then
		self.myMoveTableDetails.addDataForEntRowName(ETRow_IcArea, defaultLC.getFullId);
	endif;
epilog
	delete allLCs;
end;</source>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="f85e0f67-6444-463c-be3d-145fe58677c9">
        <updating/>
        <source>loadTable(_table : Table input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation
*/

vars
	row : Integer;
	
begin
	
	self.clearTableData(_table);
	app.myVMAgent.loadRTTaskTable(_table,null);
	
	//epr par 29849 20/6/12
	if _table = self.tblGetNext then
		//been offered twin tasks 
		if _table.columns &gt; 2  and self.myVMAgent.isIMV then
			self.btnRejectTask.left:=_table.columnWidth[1] + _table.columnWidth[2] - self.btnRejectTask.clientWidth - 10;
			self.btnRejectTask.top := self.frmGetTask.clientHeight - self.btnRejectTask.clientHeight - 10;
			self.btnRejectTask.visible:=true;
			self.btnRejectTask.parent:=self;
			self.btnRejectTask.zOrder(1);
			self.btnRejectTwin.left:=_table.columnWidth[1] + _table.columnWidth[2] + _table.columnWidth[3] - self.btnRejectTwin.clientWidth - 10;
			self.btnRejectTwin.top := self.frmGetTask.clientHeight - self.btnRejectTwin.clientHeight - 10;
			self.btnRejectTwin.visible:=true;
			self.btnRejectTwin.parent:=self;
			self.btnRejectTwin.zOrder(1);
		else
			self.btnRejectTask.visible:=false;
			self.btnRejectTwin.visible:=false;
		endif;
		
		//epr par 33401 18/2/14
		self.doTableHighlightTarget(_table);
		
		
	endif;
	
	
	if _table &lt;&gt; self.tblTasks then
		return;
	endif;
	//18/01/2011 cnwdz2 26647
	row := 2;
	if row &lt;= self.tblTasks.rows then
		self.tblTasks.row := row;
		self.tblTasks.click(self.tblTasks);	
		self.tblTasks.setFocus();				
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
