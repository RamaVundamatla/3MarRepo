/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2018	jlgab1	Initial creation

*/

vars

begin
	self.allDocuments.purge();
	self.allHMSResourcesUsed.purge();
	self.allCargoRequests.purge();
epilog

end;</source>
    </JadeMethod>
