        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="drawColour" id="f2bc2593-6389-49d7-8b9e-0f8d27e99be6">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
