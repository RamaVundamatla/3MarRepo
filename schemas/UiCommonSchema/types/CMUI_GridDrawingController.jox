        <source>getHazardClass(_ti : CM_TrackedItem) : CM_HazardClass;
/*
Purpose:			
Date		Who		Reason
17 March 2016	cnwab1	Initial creation
*/

vars
	hazardClass : CM_HazardClass;
begin
		
	if _ti &lt;&gt; null and not _ti.allTIHazards.isEmpty then
