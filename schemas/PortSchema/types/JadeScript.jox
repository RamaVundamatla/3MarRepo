    <JadeMethod name="rel841_par35232" id="cca1e01b-383e-4359-8945-59e21d1812e7">
        <source>rel841_par35232();
/*
Purpose:			
Date				Who			Reason
3/12/2014			cnwjre1		Add Cash Payment status to selector, fix up cash payment invoice reference
*/

vars
	cashPayment	: CM_CashPayment;
	invoice		: CM_Invoice;
	cashSel		: CM_QDefCashPayment;
	queryProp	: CM_QueryProperty;
begin
	
	app.initialize();
	
	beginTransaction;
	foreach cashPayment in CM_CashPayment.instances do
		if cashPayment.myInvoice = null and
		   cashPayment.myInvoiceLine &lt;&gt; null then
			if global.isValidObject(cashPayment.myInvoiceLine) then
				invoice := cashPayment.myInvoiceLine.invoice;
				if global.isValidObject(invoice) then
					cashPayment.pxySetInvoice(invoice);
				endif;
			endif;
		endif;
	endforeach;
	cashSel := CM_QDefCashPayment.firstInstance;
	queryProp := cashSel.allQueryProperties[CM_CashPayment::voided.name];
	if queryProp = null then
		create queryProp as CM_QBooleanProperty persistent;
		queryProp.set('Payment Voided', CM_CashPayment::voided.name, cashSel.className);
		cashSel.allQueryProperties.add(queryProp);
	endif;
	
	commitTransaction;
end;</source>
    </JadeMethod>
