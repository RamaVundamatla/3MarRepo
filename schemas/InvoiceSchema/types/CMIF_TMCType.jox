    </JadeMethod>
    <JadeMethod name="isTranMapCargo" id="197815a0-0839-4774-97e3-32ef666f73dd">
        <source>isTranMapCargo() : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return (self.type = self.TYPE_TRACKEDITEM);
epilog

end;</source>
        <ReturnType type="Boolean"/>
