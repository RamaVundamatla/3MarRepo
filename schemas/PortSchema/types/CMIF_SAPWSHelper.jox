    <JadeMethod name="getExternalWebServiceCMIF" id="a5509d4a-7324-4b7e-9f56-8c46b8866ab6">
        <updating/>
        <source>getExternalWebServiceCMIF(_message : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlger1	Initial creation
01 Oct 2019	NDL	TFS 46758
*/

vars
	
	xmlParser : JadeXMLDocumentParser;
	xmlDoc : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	nameSpace : String;
begin	
	
	if _message = null then
		return;
	endif;
	
	create xmlParser transient;
	create xmlDoc transient;
	xmlParser.parseDocumentString(xmlDoc,_message);
	xmlElement:=xmlDoc.getElementByTagName("soap:Body");
	if xmlElement = null then
		xmlElement:=xmlDoc.getElementByTagName("SOAP:BODY");
	endif;
	if xmlElement = null then
		xmlElement:=xmlDoc.getElementByTagName("SOAP:Body");
	endif;
	if xmlElement &lt;&gt; null then
		xmlElement:=xmlElement.childNodes.first.JadeXMLElement;
		nameSpace:=xmlElement.localName;
	endif;
	
	//couldn't work out a way to get this from the meta data
	if nameSpace &lt;&gt; null then
	
		//Requests
		if nameSpace = "AutocollEstimationRequest" then //1.1
			create mySAPRequest as CMIF_SAPAutoEstReq transient;
		elseif nameSpace = "AutocollPreInvoiceNewRequest" then //1.2
			create mySAPRequest as CMIF_SAPAutoPreInvReq transient;	
		elseif nameSpace = "AutocollInvoiceRequest" then //1.3
			create mySAPRequest as CMIF_SAPAutoInvReq transient;
		elseif nameSpace = "PreBillCheckLimitRequest" then //1.4
			create mySAPRequest as CMIF_SAPPreBillCheckLimitReq transient;
		elseif nameSpace = "PreBillPaidInvoiceRequest" then //1.5
			create mySAPRequest as CMIF_SAPPreBillPaidInvReq transient;
		elseif nameSpace = "PostBillEstimationRequest" then //1.6
			create mySAPRequest as CMIF_SAPPostBillEstReq transient;
		elseif nameSpace = "PostBillInvoiceRequest" then //1.7
			create mySAPRequest as CMIF_SAPPostBillInvReq transient;
		elseif nameSpace = "DataKinerja_OB_MT" then //1.9  or  Kinerja
			create mySAPRequest as CMIF_SAPDataKinerjaReq transient;
		elseif nameSpace = "AutocollCancellationRequest" then  //1.10
			create mySAPRequest as CMIF_SAPAutoCancelReq transient;
		elseif nameSpace = "PreBillCancellationRequest" then //1.11
			create mySAPRequest as CMIF_SAPPreBillCancelReq transient;
		elseif nameSpace = "PreBillProdDataRequest" then //1.12
			create mySAPRequest as CMIF_SAPPreBillProdDataReq transient;
		
		//Responses
		elseif nameSpace = "AutocollEstimationReturn" then  //1.1
			create mySAPResponse transient;
		elseif nameSpace = "AutocollPreInvoiceNewReturn" then  //1.2
			create mySAPResponse  transient;
		elseif nameSpace = "AutocollInvoiceReturn" then //1.3
			create mySAPResponse transient;
		elseif nameSpace = "PreBillCheckLimitReturn" then //1.4
			create mySAPResponse transient;
		elseif nameSpace = "PreBillPaidInvoiceReturn" then //1.5
			create mySAPResponse transient;
		elseif nameSpace = "PostBillEstimationReturn" then //1.6
			create mySAPResponse transient;
		elseif nameSpace = "PostBillInvoiceReturn" then //1.7
			create mySAPResponse transient;
		elseif nameSpace = "DataKinerja_IB_MT" then //1.9  or  Kinerja
			create mySAPResponse transient;	
		elseif nameSpace = "AutocollCancellationResponse" then//1.10
			create mySAPResponse transient;
		elseif nameSpace = "PreBillCancellationResponse" then //1.11
			create mySAPResponse transient;
		elseif nameSpace = "PreBillProdDataResponse" then //1.12	
			create mySAPResponse transient;
		endif;
			
	endif;
	
	if self.mySAPRequest &lt;&gt; null then
		self.mySAPRequest.setFromXML(xmlElement);
	endif;
	if self.mySAPResponse &lt;&gt; null then
		self.mySAPResponse.setFromXML(xmlElement);
	endif;
epilog
	delete xmlDoc;
	delete xmlParser;
end;</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSAPResponseReprocess" id="1c200a27-6c3e-4f3f-9f8f-5978557c1163">
        <source>handleSAPResponseReprocess(	_activityHistory : CM_ActivityHistoryExtInterface input; _errorString : String output ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	newActivityHistory : CM_ActivityHistoryExtInterface;
	returnValue : Boolean;
	error : String;

begin

	if _activityHistory = null then
		_errorString := app.getErrorString(Activity_history_selected);
		return false;
	endif;
	
	if self.mySAPRequest = null then
		_errorString := app.getErrorString(Unabl_repro_origi_reque_not_fo);
		return false;
	endif;
	
	if self.mySAPResponse = null then
		_errorString := app.getErrorString(Unabl_repro_origi_respo_not_fo);
		return false;
	endif;

	//set reprocessDT on old activity and create new activity history, to represent the input to and output from SAP.
	app.myTrxUA.trxUpdActivityHistExtReproc( _activityHistory, newActivityHistory, app.myPassport );
	
	if newActivityHistory = null or app.myPassport.hasErrors then
		_errorString := app.getErrorString(Create_activit_history_failed) &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString;
		return false;
	endif;
	
	//All good so far, try re-processing from the original response
	returnValue := self.mySAPRequest.handleSAPResponse(	self.mySAPResponse,	//_response : CMIF_SAPWSResponse;
														newActivityHistory.myCashReceipt,	//_cashReceipt : CM_CashReceipt input;
														newActivityHistory.myInvoice,	//_invoice : CM_Invoice input;
														newActivityHistory.allInvoiceLines,	//_invoiceLines : CM_InvoiceLineSet input;
														newActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
														);
												
	return returnValue;

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
