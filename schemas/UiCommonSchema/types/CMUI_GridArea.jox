    <JadeMethod name="selectPointsWithinXYs" id="4c83570a-f266-4e4e-8149-b507f6a3e57d">
        <source>selectPointsWithinXYs(_x1,_y1,_x2,_y2 : Integer);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	DIR_L2RT2B = 1;
	DIR_L2RB2T = 2;
	DIR_R2LT2B = 3;
	DIR_R2LB2T = 4;
vars

	x1, x2, y1, y2, tmpX, tmpY	: Integer;
	aPoint			: CMUI_GridPoint;
	aRow : CMUI_GridRow;
	aCol : CMUI_GridColumn;
	direction : Integer;
begin
	
	x1 := _x1;
	x2 := _x2;
	y1 := _y1;
	y2 := _y2;
	
	if x2 &gt; x1 then
		
		if y2 &gt; y1 then
			direction := DIR_L2RT2B;
		else
			tmpY := y1;
			y1 := y2;
			y2 := tmpY;
			direction := DIR_L2RB2T;
		
		endif;
	else
		tmpX := x1;
		x1 := x2;
		x2 := tmpX;
		if y2 &gt; y1 then
			direction := DIR_R2LT2B;
		else
			tmpY := y1;
			y1 := y2;
			y2 := tmpY;
			direction := DIR_R2LB2T;
		
		endif;
	
	endif;
	
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; direction.String);
	self.clearAllSelectedItems();
	
	foreach aRow in self.allGridRows do
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. ROW " &amp; aRow.label &amp; " " &amp; aRow.y1.String &amp; " " &amp; aRow.y2.String &amp; " &lt;&gt; " &amp; y1.String &amp; " " &amp; y2.String);		

		if y1 &lt;=  aRow.y1 and y2 &gt;= aRow.y1 
		or y1 &lt;=  aRow.y2 and y2 &gt;= aRow.y2 then
			
			foreach aPoint in aRow.allGridPointsByColumn do
			
				if x1 &lt;=  aPoint.x1 and x2 &gt;= aPoint.x1 
				or x1 &lt;=  aPoint.x2 and x2 &gt;= aPoint.x2 then
					aPoint.selectTIsWithinXYs(x1,y1,x2,y2);
					aPoint.drawSelf(self.myGridAreaFrame);
					self.addPointToSelected(aPoint);
//	app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; aPoint.myGridRow.label &amp; "/" &amp; aPoint.myGridColumn.label);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. ROW " &amp; aRow.label );		
				endif;
			endforeach;
		endif;
	endforeach;


	
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="bd22c956-ded9-4769-8a63-d61ed4dac7f1">
        <updating/>
        <source>selectSinglePoint( x, y : Real) : CMUI_GridPoint updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	returnPoint, gridPoint, origPoint 	: CMUI_GridPoint;
	x1, y1					: Real;
	aTI : CM_TrackedItem;
	column40, moveMode,lRow,lCol : Integer;
	primaryLocn : CM_LocationsController;
begin

	
	gridPoint := self.convertPositionToGridPoint(x, y);
	if gridPoint &lt;&gt; null then
		if gridPoint.locked then
			return gridPoint;
		endif;
		// if the user clicks on a block stack or a light etc, DO NOT redraw it
		if gridPoint.letter = GridPointType_Building or 
		   gridPoint.letter = GridPointType_RestLoc or 
		   gridPoint.letter = GridPointType_Light or 
		   gridPoint.letter = GridPointType_ReeferGantry or 
		   gridPoint.letter[1:4]= GridPointType_SubBlock or 
		   gridPoint.locked then

			return gridPoint;
		endif;

		aTI := gridPoint.getTI(x,y);
		// PAR 7406 AKB2004JAN - added from here
		if aTI &lt;&gt; null then
			if self.mySDF.displayMode = DISPLAY_MODE_ACTUAL then
				moveMode := REAL_MODE;
			elseif self.mySDF.displayMode = DISPLAY_MODE_QUEUE then
				moveMode := QUEUE_MODE;
			elseif self.mySDF.displayMode = DISPLAY_MODE_PLAN then
				moveMode := PLANNING_MODE;
			endif;
			primaryLocn := aTI.getPrimaryLocation(moveMode);
			
			if primaryLocn &lt;&gt; gridPoint.myLocationsController and
			primaryLocn &lt;&gt; null then
				primaryLocn.getRowColumn(lRow,lCol,self.flipHorizontal,self.flipVertical);	//PAR 19710
				gridPoint := self.allGridPoints[lRow,lCol];
				aTI := gridPoint.getTI(x,y);
			endif;
		endif;
		// PAR 7406 AKB2004JAN - added to here
		
		if aTI &lt;&gt; null then
			self.addRemoveTIToFromSelected(aTI);
		endif;

		if gridPoint &lt;&gt; null then
			if not self.allSelectedPoints.includes(gridPoint) then
				self.allSelectedPoints.add(gridPoint);
				returnPoint := gridPoint;
			else
				self.allSelectedPoints.remove(gridPoint);
				returnPoint := null;
			endif;
			gridPoint.drawSelf(self.myGridAreaFrame);
		
		endif;

		return returnPoint;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePointAlt" id="cfdcbb63-943e-4a22-99cb-7b2165ac1abb">
        <updating/>
        <source>selectSinglePointAlt( x, y : Real) : CMUI_GridPoint updating;

vars
	returnPoint, gridPoint	: CMUI_GridPoint;
	x1, y1					: Real;
	aTI : CM_TrackedItem;
begin

	gridPoint := self.convertPositionToGridPoint(x, y);
	if gridPoint &lt;&gt; null then
		if gridPoint.locked then
			return gridPoint;
		endif;
		// if the user clicks on a block stack or a light etc, DO NOT redraw it
		if gridPoint.letter = GridPointType_Building or 
		   gridPoint.letter = GridPointType_RestLoc or 
		   gridPoint.letter = GridPointType_Light or 
		   gridPoint.letter = GridPointType_ReeferGantry or 
		   gridPoint.letter[1:4]= GridPointType_SubBlock or 
		   gridPoint.locked then

			return gridPoint;
		endif;


		if not self.allSelectedPointsAlt.includes(gridPoint) then
			self.allSelectedPointsAlt.add(gridPoint);
			returnPoint := gridPoint;
		else
			self.allSelectedPointsAlt.remove(gridPoint);
			returnPoint := null;
		endif;

		aTI := gridPoint.getTI(x,y);
		if aTI &lt;&gt; null then
			self.addRemoveTIToFromSelected(aTI);
//			if not self.allSelectedTrackedItems.includes(aTI) then
//				self.allSelectedTrackedItems.add(aTI);
//			else
//				self.allSelectedTrackedItems.remove(aTI);
//			endif;
		endif;

		gridPoint.drawSelf(self.myGridAreaFrame);
		
		return returnPoint;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
