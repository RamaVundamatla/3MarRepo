    <JadeMethod name="getCustomDocHSCodeDescForSel" id="547dc45f-e880-4d44-a7c8-7ab1f58ad7df">
        <source>getCustomDocHSCodeDescForSel(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	hsCode	: CM_HarmonizedSystem;
begin
	
	hsCode := app.myRoot.allHSCodesActive[self.custDocHSCode];
	
	if hsCode &lt;&gt; null then
		return hsCode.getDisplayString();
	endif;

epilog

end;</source>
