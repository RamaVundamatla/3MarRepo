<Class name="WS_SAPResponse" id="0acca4ce-a5da-421e-8bb5-0a805cf18df3">
    <superclass name="WS_ExternalResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allMessages" id="d6f3e067-04b6-42bc-aa33-3c4a595724f0">
        <memberTypeInverse/>
        <type name="WS_SAPMessageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="status" id="41efd9b3-338f-41aa-bccb-ff4c0f3ffbe5">
        <type name="String"/>
        <text>Success Flag (Success = X)</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="6e3f4b88-fd83-4a81-a19c-a2eb26ca8577">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.allMessages.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setErrorsFromPassport" id="7f5ad357-74cf-42fd-bd7a-bb9c4078d582">
        <updating/>
        <source>setErrorsFromPassport() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2018	jlgkpd1	TFS - Pelindo 1 INAPORTNET Integration


*/

vars
	passport		: CM_Passport;
	error			: CM_Error;
	sapMessage		: WS_SAPMessage;
	
begin
	inheritMethod();

	passport := app.myPassport;

	if passport.noErrors()then
		self.status := "X";
	else
		self.status := null;
	endif;

	foreach error in passport.allWarnings do
		create sapMessage transient;
		sapMessage.type := 'W';
		sapMessage.message := error.getDetailsAsString();
		self.allMessages.add(sapMessage);
	endforeach;
	
	foreach error in passport.allErrors do
		create sapMessage transient;
		sapMessage.type := 'E';
		sapMessage.message := error.getDetailsAsString();
		self.allMessages.add(sapMessage);
	endforeach;
	
	// KPD - added this to ensure errors are not copied twice for nested webService
	// method calls
	passport.clearErrorsWarnings();
	
epilog

end;</source>
    </JadeMethod>
</Class>
