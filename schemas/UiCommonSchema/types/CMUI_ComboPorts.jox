    <JadeMethod name="setObjectAndVoyage" id="8c019c70-62e5-44d4-b2a1-f627b3ad044d">
        <updating/>
        <source>setObjectAndVoyage(_port : CM_Port; _voyage : CM_Voyage)updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------

vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
	needInit	: Boolean;
begin

	needInit := false;
	
	if self.myVoyage &lt;&gt; _voyage then 
		self.myVoyage := _voyage;
		needInit := true;
	endif;

	if _port &lt;&gt; null and (self.myObject &lt;&gt; _port) then
		needInit := true;
	endif;
	
	if needInit then
		// will cause a reset on next gotFocus
		self.amInitialised := false;
		self.setObject(_port);
	endif;

end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndVoyageDischPort" id="4a11368a-9cd7-44e9-b3d7-77f600277933">
        <updating/>
        <source>setObjectAndVoyageDischPort(_dischargePort : CM_Port; _voyage : CM_Voyage) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwas3	Initial creation

*/

vars
	
	idx			: Integer;
	saveText	: String;
	needInit	: Boolean;
begin

	needInit := false;
	
	if _voyage &lt;&gt; null and self.myVoyage &lt;&gt; _voyage then 
		self.myVoyage := _voyage;		
	endif;
	
	self.initTranshipsVoyageDischPort(_dischargePort);

end;</source>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromCode" id="53ce3a49-aa3b-4d6d-b670-95f4fd2e1d24">
        <updating/>
        <source>setObjectFromCode(_portCode : String) updating;

// Created by cnwdvb1 on 10 April 2006

vars

	port	: CM_Port;

begin

	if _portCode &lt;&gt; null then
		port := self.myAssistant.allPortDisplayCodesGetObject(_portCode);
	endif;
	self.setObject(port);

end;</source>
        <Parameter name="_portCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromCodeAndVoyage" id="7bba9dea-e28c-431e-aec5-2365c713a514">
        <updating/>
        <source>setObjectFromCodeAndVoyage(_portCode : String; _voyage : CM_Voyage) updating;

// Created by cnwdvb1 on 11 April 2006
// 18/12/2014 cnwma1 PAR 35416 impossible to edit some containers
vars
	invalidVoyage : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception,_voyage,invalidVoyage); 	// 18/12/2014 cnwma1 PAR #35416

	if self.myVoyage &lt;&gt; _voyage then 
		self.myVoyage := _voyage;
	endif;
		
	if invalidVoyage then 
		return; 
	endif;

	// 12/03/2010 cnwmh5 #22235 - Start
	if _portCode &lt;&gt; null and _voyage &lt;&gt; null and not _voyage.allPorts.includes(app.myRoot.allPorts[_portCode]) then
		self.myObject := app.myRoot.allPorts[_portCode];
	endif;
	// 12/03/2010 cnwmh5 #22235 - End
	
	// will cause a reset on next gotFocus
	self.amInitialised := false;
	init();
	
	/*if _voyage &lt;&gt; null and (self.myVoyage.allPorts.includes(app.myRoot.allActivePorts[_portCode]) or _voyage.isNullVoyage) then
		self.setObjectFromCode(_portCode);
	else
		self.setObjectFromCode(null);
	endif;*/
	// 23/06/2008 cnwar2 #17159 - should still populate if _voyage is null
	if _voyage &lt;&gt; null and not _voyage.isNullVoyage then
		if self.myVoyage.allPorts.includes(app.myRoot.allActivePorts[_portCode]) or self.myObject &lt;&gt; null then	// 12/03/2010 cnwmh5 #22235
			self.setObjectFromCode(_portCode);
		else
			self.setObjectFromCode(null);
		endif;
	else
		self.setObjectFromCode(_portCode);
	endif;
	
end;</source>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setVoyageAndTranships" id="c871948d-08cc-41cd-a556-0b928f182251">
