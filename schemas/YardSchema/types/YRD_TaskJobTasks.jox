    <JadeMethod name="tblOOWConfirm_rowColumnChg" id="56d38b8a-582b-4f98-b430-4ceef55cb4c2">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblOOWConfirm_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlger1	Initial creation

*/

vars

colIndex : Integer;
	rowIndex : Integer;
	
	wodCargoRequest : CM_VoyageHoldJob;
	
	gangs : Integer;
	trsfrTypeStr : String;
	trsfrTypeInt : Integer;
	firstTi : CM_TrackedItem;
	
	newTrsfrType : CM_VoyageJobTransferType;
	workPoint : CM_WorkPoint;
	wpRate : CM_WorkPointCargoRates;
	daysToComplete : Decimal[6,2];
	newAmount,
	newRate : String;
begin

	rowIndex := table.accessedCell.row;
	colIndex := table.accessedCell.column;
	
	if rowIndex &gt; table.fixedRows then
		//epr TFS 41645 3/11/18 refinement of contine
		if colIndex = TransferTypeCol or colIndex = GangsCol or colIndex = WPCol or colIndex = AmountCol then
			wodCargoRequest := table.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
			if wodCargoRequest &lt;&gt; null then
				gangs := table.accessCell( rowIndex, GangsCol ).text.Integer;
				newAmount := table.accessCell(rowIndex,AmountCol).text;
				trsfrTypeStr := table.accessCell( rowIndex, TransferTypeCol ).text;
				trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
				newTrsfrType := app.myRoot.allVoyageJobTransferTypes.getAtKey( trsfrTypeInt );
				
				workPoint :=  self.myTerminal.allWorkPointsByCode[table.accessCell( rowIndex, WPCol ).text].CM_WorkPoint; //  wodCargoRequest.getWorkPointObject.CM_WorkPoint;
				if workPoint &lt;&gt; null then
					daysToComplete:=self.getWorkPointDaysToComplete(workPoint,wodCargoRequest,newTrsfrType,gangs,newAmount,newRate);
					 table.accessCell( rowIndex,  DaysToCompleteCol-1 ).text :=newRate;
				endif;	
				
				table.accessCell( rowIndex, DaysToCompleteCol ).text := daysToComplete.asStringJMT;
				
				self.setPermitTotalDays(true);
				
			endif;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResourcesCR_queryRowColChg" id="c6f4cc3e-95cf-49f3-98bf-456f0df698b9">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResourcesCR_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	row : Integer;
	fdColIndex : Integer;
	tdColIndex : Integer;
	dateText : String;
	
begin

	fdColIndex := self.tblResourcesCR.getColumnByRowName( ETRow_FromDate );
	tdColIndex := self.tblResourcesCR.getColumnByRowName( ETRow_ToDate );

	row := self.tblResourcesCR.row;
	if row &gt; self.tblResourcesCR.fixedRows then
		if self.tblResourcesCR.column = fdColIndex then
			if self.tblResourcesCR.accessCell( row, fdColIndex ).cellControl &lt;&gt; null then
				dateText := self.tblResourcesCR.accessCell( row, fdColIndex ).cellControl.CMUI_DateMask.text;
				self.tblResourcesCR.accessCell( row, fdColIndex ).text := dateText;
			endif;
		elseif self.tblResourcesCR.column = tdColIndex then
			if self.tblResourcesCR.accessCell( row, tdColIndex ).cellControl &lt;&gt; null then
				dateText := self.tblResourcesCR.accessCell( row, tdColIndex ).cellControl.CMUI_DateMask.text;
				self.tblResourcesCR.accessCell( row, tdColIndex ).text := dateText;
			endif;
		endif;
	endif;
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
