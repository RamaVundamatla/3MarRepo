    <JadeMethod name="trxUpdateMediatorResponseValue" id="bccba792-1532-4914-9f51-95504339b1a1">
        <updating/>
        <source>trxUpdateMediatorResponseValue(_mediator : CM_RadioTelemetryMediator input;
							   _index : Integer;
							   _response : String;
							   _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateMediatorResponseValue(_mediator,
												   _index,
												   _response,
												   _passport);

	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.setLastUpdateTs(app.actualTimeServer);
	endif;

	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
