    <JadeMethod name="tAddMultiItemBooking" id="d846bda2-db4a-4106-add4-3178be68d67e">
        <updating/>
        <source>tAddMultiItemBooking()updating;
// jlgmp6
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking: CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
begin
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "GENL");
	booking := self.addBookingItemForContainer(booking, "4400", "MT", 1);
	assertNotNull(booking);
	
	assertEqual(booking.allBookingRefItems.size, 2);
	

end;</source>
