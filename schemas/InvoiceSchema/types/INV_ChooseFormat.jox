    <JadeMethod name="getExportFileNameBase" id="90d22b69-c9b5-4786-878b-1c5154abff1d">
        <source>getExportFileNameBase(_exportPath : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if _exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Invoicecontracts) &amp; "\";
	else
		target := _exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Invoicecontracts) &amp; "\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	

	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_exportPath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileExtension" id="3b95b336-7ad6-4a85-bd62-b97bb05cba85">
        <source>getFileExtension() : String;
/*

