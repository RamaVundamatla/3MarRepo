vars

begin
	return self.fromDate;

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="65f9b1e0-9c11-4fc0-b6c0-df1c815755ac">
        <source>getSearchValueRange(_prop : CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	dateArray : DateArray;
begin
	create dateArray transient;
	dateArray.add(fromDate);
	dateArray.add(toDate);

	return dateArray;
epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
