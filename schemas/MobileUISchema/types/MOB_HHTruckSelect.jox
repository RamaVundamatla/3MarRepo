    <JadeMethod name="doResizeControls" id="3cf0bfea-2c25-4431-8726-f0ea8ac6828e">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	stdWidth : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtTruck.visible := true;
	endif;
	self.txtTruck.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	
	top := self.resizedMargin + self.txtTruck.height + self.txtTruck.top;
	if _initialSetup then
		self.txtState.visible := self.myMobileGenericAgent.showState;
	endif;
	self.txtState.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	
	
	if self.txtState.visible then
		top := self.resizedMargin + self.txtState.height + self.txtState.top;
	endif;

	self.txtBatNo.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	self.txtBatNo.text := self.lblBatNo.caption.toUpper;
		

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="0910f689-b749-4afd-b9d7-3fe15957cfbf">
        <source>findTruck( errMsg : String output ) : CM_Vehicle;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	batNum,
	truckString : String;
	truck : CM_Vehicle;
	state : String;
	iter : Iterator;
	allTrucks : ObjectArray;
begin
	
	if self.txtState.text.trimBlanks = null or self.txtState.text = self.lblState.caption.toUpper then
		state := null;
	else
		state := self.txtState.text.trimBlanks;
	endif;
	
	if self.txtTruck.text.trimBlanks = null or self.txtTruck.text = lblTruck.caption.toUpper then
		truckString:=null;
	else
		truckString := self.txtTruck.text;
	endif;
	
	if self.txtBatNo.text.trimBlanks = null or txtBatNo.text = lblBatNo.caption.toUpper then
		batNum:=null;
	else
		batNum := self.txtBatNo.text;
	endif;
	
	//epr par 37162 refactored code shifted to terminal so could be reused by webservices
	truck:=self.myMobileDataAgent.myTerminal.findTruck(truckString,state,batNum);
	
	
	
	if truck = null and truckString &lt;&gt; null then
		truck := findTruckFromReleaseNumber( truckString.toUpper, errMsg );
		if errMsg &lt;&gt; null then
			return null;
		endif;
	endif;
	
	//epr TFS 2257
	if truck = null and truckString &lt;&gt; null and state = null and batNum = null then
		create allTrucks transient;
		self.myMobileDataAgent.myTerminal.findTrucksWithRegInYard(truckString,allTrucks);
		if allTrucks.size = 1 then
			truck:=allTrucks.first.CM_Vehicle;
		endif;
	endif;
	
	
	if truck = null then
		if truckString = null and batNum &lt;&gt; null  then
			errMsg := app.getErrorString(Number_no_current_truck);
		else
			if self.txtState.visible then
				errMsg := app.getErrorString2( Err_Unknown_Truck_Rego_State, truckString, state );
			else
				errMsg := app.getErrorString2( ERR_Truck_Unknown, truckString, null );
			endif;
		endif;
	endif;
	
	if truck &lt;&gt; null then
		self.isValidTruckForAction( truck,  errMsg);
	endif;
	
	return truck;
	
epilog
	delete allTrucks;
end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="findTruckFromReleaseNumber" id="fb79e513-bf66-4b98-aa0d-22e8f590a93d">
        <source>findTruckFromReleaseNumber( _text : String; _errMsg : String io ):CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation	Par 34717

*/

vars

	selectedBulkRelease : CM_BulkRelease;
	truckArray : CM_VehicleArray;

begin
	
	selectedBulkRelease := self.getActiveBulkRelease( self.myTerminal, BR_TYPE_ROAD, true, _text );
	
	create truckArray transient;
	self.getTrucksFromBulkRelease( selectedBulkRelease, truckArray );
	
	if truckArray.size = 1 then
		return truckArray.first;
	elseif truckArray.size &gt; 1 then
		_errMsg := app.getErrorString( Multi_truck_working_release );
	endif;
	
	return null;

epilog

	delete truckArray;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_errMsg" type="String" usage="io"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="52a07613-cd7a-4889-8104-1310f71cafa1">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	errMsg : String;
begin

	self.myMobileGenericAgent.setTruck( self.findTruck( errMsg ) );
	if errMsg &lt;&gt; null then
		self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="594f3398-6456-4337-bca3-ccd913f7a18a">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myMobileGenericAgent.clearAll();
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isValidTruckForAction" id="ad7d3da1-5852-46bb-89cd-6403c9181d45">
        <source>isValidTruckForAction( _truck : CM_Vehicle io;  errMsg : String output);

/*

Purpose:			
	
Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if _truck &lt;&gt; null then
		if not _truck.isOnsite or not _truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
			// can't load/unload  it if its not in the yard eh!
			errMsg := app.getErrorString(Truck_Not_In_Yard);
			_truck := null;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="4154415e-a8ab-4ca1-b63c-d76e8f386526">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	glc : CM_GateAreaLaneController;
	truck : CM_Vehicle;
	term : CM_Terminal;
	
begin

	truck := self.myMobileGenericAgent.myTruck;

	term := self.myMobileDataAgent.myTerminal;
	self.txtBatNo.visible := term.getConfig(SiteHasSecurityGate).Boolean;
		
	if truck &lt;&gt; null then
		self.txtTruck.text := truck.regNumber;
		if truck.state = null then
			self.txtState.text := lblState.caption.toUpper;
		else
			self.txtState.text := truck.state;
		endif;
	else
		self.txtTruck.text := lblTruck.caption.toUpper;
		self.txtState.text := lblState.caption.toUpper;
	endif;
	
	self.doResizeControls(true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="053b57cc-dfa4-46f9-8393-8b89645545cc">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myMobileGenericAgent.clearAll(); // to reset 'terminal' on the agent..

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="238540d9-9ce6-4f06-991b-1a9735dfdcee">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013993, locale);
	lblBatNo.translateCaption(Xlat_0019499, locale);
	lblState.translateCaption(Xlat_0014248, locale);
	lblTruck.translateCaption(Xlat_0013994, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtBatNo_gotFocus" id="812c8b01-4c5f-4412-8ef8-28f96d91e4c9">
