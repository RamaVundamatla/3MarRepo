    <JadeMethod name="getCapacityPC" id="95ad34d9-1c99-41df-ac5d-f95c3ad45cca">
        <source>getCapacityPC(_mode: Integer): Integer;

/*

Purpose:			TFS 49959

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	capacity, capacityPC, totQty : Integer;
	array : CM_TIArray; 
	ti : CM_TrackedItem;
begin

	capacity := self.getCurrentCapacity();
	if capacity = 0 then
		return 0;
	endif;
	
	create array transient;
	self.getTIs(array, _mode, true);
	foreach ti in array discreteLock do
		totQty := totQty + ti.totalQuantity;
	endforeach;
	
	capacityPC := ((totQty / capacity) * 100).Integer;

	return capacityPC;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentCapacity" id="8460db9d-5384-41f0-931d-553a510dd1ee">
        <source>getCurrentCapacity(): Integer;

/*

Purpose:			TFS 49959

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	minMax : CM_TerminalAreaProductMinMax;
	
begin

	minMax := self.getMinMaxForFirstTI();
	if minMax &lt;&gt; null and minMax.maxQuantity &gt; 0 then
			return minMax.maxQuantity;
	endif;

	return self.myTerminalArea.getMaxCapacity();
	
	
	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="40fe773e-ac4c-4717-a28b-61361922de50">
        <source>getFullId(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	str : String;
	first, last : CM_GeneralCargoAllocController;

begin
	str := self.rangeLabel;  // ### JIRA 35403 10JUL2025 NAVAB1
	
	if str = null then
		str   := self.myRowArea.id;
		first := self.allLocations.first.CM_GeneralCargoAllocController;
		
		if first &lt;&gt; null then
			last  := self.allLocations.last.CM_GeneralCargoAllocController;
			str   := str &amp; Space &amp; first.id;
			if last &lt;&gt; null and last &lt;&gt; first then
				str := str &amp; Hyphen &amp; last.id;
			endif;
		endif;
	endif;
	
	return str.trimBlanks;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdForTI" id="9a7bf02f-756e-4788-9a69-d24cf67dc8d9">
