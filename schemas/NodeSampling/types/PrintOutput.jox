    <JadeMethod name="create" id="b64e99f6-0852-4184-b25c-b80e1b50e173">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

vars
	column    : JadeTableColumn;
begin

	tbl_1_1.columnWidth [ 1 ] := 300;
	tbl_1_1.columnWidth [ 2 ] := 100;
	tbl_1_1.columnWidth [ 3 ] := 100;
	tbl_1_1.columnWidth [ 4 ] := 100;
	tbl_Details.columnWidth [ 1 ] := 300;
	tbl_Details.columnWidth [ 2 ] := 100;
	tbl_Details.columnWidth [ 3 ] := 100;
	tbl_Details.columnWidth [ 4 ] := 100;
	column := tbl_Details.accessColumn(2);
	column.alignment := Table.Alignment_Right_Middle;
	column := tbl_1_1.accessColumn(2);
	column.alignment := Table.Alignment_Right_Middle;
	column := tbl_Details.accessColumn(3);
	column.alignment := Table.Alignment_Right_Middle;
