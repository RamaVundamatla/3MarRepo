    <JadeMethod name="cmbCarrier_mouseDown" id="0cb60c4f-ada8-4e28-bf9b-61c6b572dfdc">
        <controlMethod name="CMUI_ComboBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCarrier_mouseDown(comboBox: ComboBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation

*/

vars

	form : CMUI_ComboFilterSelectionForm;
	tbl : CM_EntryTable;
	maxRows,
	idx	: Integer;
	entRowTrans : EntTableRowTransient;
	row1Text : String;
	pControlName : String;

begin

	if self.myTerminal.getConfig(CarrierCmbFilter).Boolean then
	
		tbl := comboBox.parent.CM_EntryTable;
		if not CM_EntryTable.hasInstance(comboBox.parent) then
			return;
		endif;
		
		pControlName := comboBox.name;
		
		maxRows := tbl.allEntRowTransients.size;
		foreach idx in 1 to maxRows do
			entRowTrans := tbl.allEntRowTransients[idx].EntTableRowTransient;
			if entRowTrans.controlName = pControlName then
				row1Text := tbl.accessCell(idx,1).text;
				break;
			endif;
		endforeach;
	
		create form transient;
		form.setMyRelatedCombo( self, comboBox.CMUI_ComboBox, row1Text );
		form.showModal();
		
		self.cmbCarrier_lostFocus(self.cmbCarrier);
		
	endif;

epilog

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
