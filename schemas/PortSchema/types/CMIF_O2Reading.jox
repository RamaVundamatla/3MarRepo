<Class name="CMIF_O2Reading" id="9253ab43-218e-4503-a4b3-34c7a586054c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="dateTime" id="7e7c7dc3-8efb-448d-8614-502fa7ea4f6e">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="8605d2ac-257c-491c-a5d2-f3c593cc884f">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="e39502d5-e39a-4e75-af7a-e00d292cbf7f">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="noCharge" id="aae9b4d3-cc3b-46c8-9828-520716fc7e0a">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="o2" id="8f14a3de-e4f3-41c9-8d1c-4f1efe6ed4da">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="d82ae52f-75d1-44fe-a1fb-a4ab992a82b4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="initialise" id="96bf2ba9-e166-4b37-b6da-3178cec4a417">
        <updating/>
        <source>initialise(	_ti : CM_TrackedItem;
			_terminal : CM_Terminal;
			_readingTime : TimeStamp;
			_reading : Decimal;
			_noCharge : Boolean;
			_user : String	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.o2 := _reading;
	self.dateTime := _readingTime;
	self.noCharge := _noCharge;
	self.userId := _user;
	
	self.myTerminal := _terminal;
	self.myTrackedItem := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_readingTime" type="TimeStamp"/>
        <Parameter name="_reading" type="Decimal"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTITransController" id="9ba9c28c-94a8-4371-be2a-c2c3d658128c">
        <source>setTITransController(_tiTransController: CMIF_TITransactionController input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	_tiTransController.userGenerated 	:= false;
	_tiTransController.userId 			:= self.userId;
	_tiTransController.noCharge 		:= self.noCharge;
	_tiTransController.myTrackedItem 	:= self.myTrackedItem;
	_tiTransController.type 			:= TRANS_TYPE_O2READING;
	_tiTransController.dateTime 		:= self.dateTime;
epilog

end;</source>
        <Parameter name="_tiTransController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
</Class>
