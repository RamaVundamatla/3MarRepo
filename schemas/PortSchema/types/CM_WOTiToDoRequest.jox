    <JadeMethod name="createWLE" id="d182e017-87df-4f6d-803a-a8f260f63fe2">
        <source>createWLE():CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
19 Apr 2023 navma1  ChangeRequest 57326:[57327] EUP - VAS Task linked with Pack or Unpack Work Order
*/

vars

	wle	: CM_WOToDoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);				  	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="70a4b17d-3053-4ca4-98a9-d7312f55855d">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
19 Apr 2023 navma1  ChangeRequest 57326:[57327] EUP - VAS Task linked with Pack or Unpack Work Order
23 May 2023 navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
18 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
22 May 2024	navpw1	TFS: 64096 (64098) - Added support for Work Order To Do Tasks on Release Cargo Work Orders.
20 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
*/

vars
	aWLE			: CM_WorkListEntry;
	theTI			: CM_TrackedItem;
	iter			: Iterator;
	releaseRequest	: CM_BulkRelease;
	reserve			: CM_ReserveDetail;
	cargoType		: CM_CargoType;
	count			: Integer;
	requestedCount,
	remaining		: Integer;
	toDoDesc        : CM_ToDoTaskDesc; //23/05/2023 navmv20 CR 57925 Task 57921
	trxType         : CM_TransactionType; //23/05/2023 navmv20 CR 57925 Task 57921
begin

	reserve := self.myReserveDetail;
	
	if reserve &lt;&gt; null then
		releaseRequest := reserve.myReserveHeader;
	endif;
	
	toDoDesc := self.myJob.CM_WOToDoTaskJob.myToDoTaskDesc;
	
	if releaseRequest &lt;&gt; null and  releaseRequest.releaseByType then							//17.04.2023 navma1 #57326:[57327]
		
		/*
		UnKnown cargo Items
		*/
		cargoType 		:= reserve.CM_ReserveSelection.myCargoType;
		requestedCount	:= reserve.CM_ReserveSelection.totalRequested;
		if cargoType.isAllowDuplicates then
			remaining := requestedCount - self.getWLEQuantity();								//20.09.2024 navhl20 #62456[66078]
			if remaining &gt; 0 then																//20.09.2024 navhl20 #62456[66078]
				aWLE := self.createWLE();
				//aWLE.setQuantity(requestedCount);												//20.09.2024 navhl20 #62456[66078]
				aWLE.setQuantity(remaining);													//20.09.2024 navhl20 #62456[66078]
				aWLE.setWeight(self.myReserveDetail.CM_ReserveSelection.weightRequested);
			endif;
		else
			while count &lt; requestedCount do
				aWLE := self.createWLE();
				aWLE.setQuantity(1);
				aWLE.setWeight(reserve.weightRequested);
				
				count := count +1;
			endwhile;
		endif;
		
		trxType := toDoDesc.myTransactionType; //This is the trxTypeOnCompletion.
		if trxType &lt;&gt; null and trxType.isForWorkOrder() and aWLE &lt;&gt; null then					//24.09.2024 navhl20 #62456[66078]
			aWLE.CM_WOToDoWLE.createWOToDoTask();
		endif;
	else
		
		/*
		Known cargo Items
		*/
		
		iter := self.myJob.CM_WOToDoTaskJob.allTrackedItems.createIterator;
		//23/05/2023 navmv20 CR 57925 Task 57921 - START
		//trxType := app.myRoot.allTransactionTypes[toDoDesc.trxTypeOnCompletion];
		trxType := toDoDesc.myTransactionType; //This is the trxTypeOnCompletion.
		if trxType &lt;&gt; null and trxType.isForWorkOrder() then
			aWLE := self.createWLE();
			aWLE.CM_WOToDoWLE.createWOToDoTask();
		else
		//23/05/2023 navmv20 CR 57925 Task 57921 - END
			while iter.next(theTI) do
				// create WLE , create todotask on ti link that to the wle			
				aWLE := self.createWLE();
				aWLE.setMyTrackedItem( theTI);
			  	aWLE.setQuantity(theTI.totalQuantity);							//18.01.2023 navhl20 #58760[61583]
			endwhile;
		endif; //23/05/2023 navmv20 CR 57925 Task 57921
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoSubType" id="a403d9df-4c23-4bbf-a6dc-621c8e4cb3f4">
        <source>getCargoSubType(): CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues

*/

vars

begin
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.getMyProduct();
	endif;

epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="5c5b6e34-0fcd-49dd-b37d-5efd91b38d56">
        <source>getCargoType(): CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2

*/

vars

begin
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.getCargoType();
	endif;
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="isReleaseType" id="805410bd-e943-4831-93bf-c823ea649b24">
        <source>isReleaseType(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2

*/

vars
	wod : CM_WorkOrderTIDtl;
	job : CM_Job;
begin
	if not app.myPassport.isVASEnabled then
		return false;
	endif;
	job := self.myJob;
	if job &lt;&gt; null then
		wod := job.myWODtl;
	endif;
	if wod.isKindOf(CM_WodToDo) then
		wod := wod.CM_WodToDo.myWorkOrderDetail;
	endif;
	if wod &lt;&gt; null and wod.isKindOf(CM_WodRelease) then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processDeleteForWO" id="10f1a2cd-1aba-4877-b7bc-e6abb87944c4">
        <source>processDeleteForWO();
/*

Purpose:	to update the work order (if exists ) and its request on delete of the request		

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars
	isRBT 	: Boolean;
	wle 	: CM_WorkListEntry;
	incompleteCount : Integer;
	incompleteTISet : CM_TISet;
	ti			: CM_TrackedItem;
begin

	create incompleteTISet transient;
	// here we need to see if we are a Work order job
	if self.myJob.myWODtl &lt;&gt; null then
	
	// figure out if we are from a RBT
	isRBT := ( self.myWORequestType &lt;&gt; null);
	
		foreach wle in self.allWorkListEntries do
			// if wle not complete then we need to update some work order detail stats &amp; cargo id's
			if wle.status &lt;&gt; WLE_COMPLETED then
				incompleteCount := incompleteCount +1;
				if wle.myTrackedItem &lt;&gt; null then
					incompleteTISet.add(wle.myTrackedItem );
				endif;
			endif;	
		endforeach;
		
		if incompleteCount &gt; 0 then
		// now have work to do on the wod/requets		
			if isRBT then
			// TI's are not assigned to the WOD untill the WLE is compelte so we can ignore the incompleteTISet
			// incompleteCount needs to update the request
			self.myWORequestType.setTotalActioned( self.myWORequestType.totalActioned - incompleteCount  );
			else
			//we need to update the WOD allocated count 			
			self.myJob.myWODtl.setTotalActioned( self.myJob.myWODtl.totalActioned - incompleteCount);
			self.myJob.myWODtl.setTotalUnactioned( self.myJob.myWODtl.totalUnactioned + incompleteCount);
			// and unaction the cargo on the WOD
				foreach ti in incompleteTISet do
					self.myJob.myWODtl.setTIUnactioned( ti, false);
				endforeach;
			endif;
		
		endif;
	endif;	

epilog
	delete incompleteTISet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="55b7f671-f925-4fa1-a12b-3c6e8fce61be">
        <updating/>
        <source>setForCreate(_proxyRequest: CM_WOToDoRequest) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin

	self.totalRequested := _proxyRequest.CM_WOTiToDoRequest.totalRequested;
	inheritMethod(_proxyRequest);

epilog

end;</source>
        <Parameter name="_proxyRequest" type="CM_WOToDoRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="47049d67-1f5d-4051-97b7-b088ee9abf55">
        <updating/>
        <source>setProxy(_ti : CM_TrackedItem; _requestType : CM_ToDoRequestType; _userCode : String; _job : CM_Job) updating;
// ---------------------------------------------------------------------------
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date			Who		Reason
// 10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 06 Jun 2023  navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
// ---------------------------------------------------------------------------
vars

begin
	self.setProxyForToDoRequest(_requestType, _userCode, _job);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_requestType" type="CM_ToDoRequestType"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
