    <JadeMethod name="cloneMySelf" id="b9dc13c7-26e4-4ff1-860e-0a95934d66a9">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	25 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	newVesselData : HMS_VesselData;
	tmpData : HMS_VesselDataHarbour;
begin
	
	newVesselData := self.cloneSelf(_transient);
	
	foreach tmpData in self.allVesselDataForHarbour do
		newVesselData.allVesselDataForHarbour.add(tmpData.cloneMySelf(_transient));
	endforeach;	
	
	newVesselData.myDefaultShippingLine := self.myDefaultShippingLine;
	newVesselData.myVesselType := self.myVesselType;
	newVesselData.myRoot := self.myRoot;
	
	return newVesselData;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="02a3d44a-e3e4-40b7-a24b-f4b3c461c287">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input) : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin

	if _property = HMS_VesselData::myVesselType then	
		return HMS_VesselType::code;
	elseif _property = HMS_VesselData::myDefaultShippingLine then
		return CM_ShippingLine::code;
	endif;
		
	return inheritMethod(_property);
	
epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="4ddfc0a2-ef16-4359-a148-712fb0403159">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin

	if _property = HMS_VesselData::myDefaultShippingLine then
		return ExportAsChild;
	elseif _property = HMS_VesselData::myVesselType then
		return ExportAsChild;
	elseif _property = HMS_VesselData::myRoot then
		return NoExport;
	elseif _property = HMS_VesselData::allVesselDataForHarbour then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultBerthForHarbour" id="b1b8ccf1-8f1c-4a2c-8180-cc28730c0118">
        <source>getDefaultBerthForHarbour(_harbour : HMS_Harbour) : HMS_Berth;
//--------------------------------------------------
// Created:	01 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpData : HMS_VesselDataHarbour;
begin
	if _harbour = null then
		return null;
	endif;
	
	tmpData := self.allVesselDataForHarbour.getAtKey(_harbour);
	
	if tmpData = null then
		return _harbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
	endif;
	
	return tmpData.getDefaultBerth();
	
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getDefaultResourcesForCMIFMove" id="bdcb371f-b784-44ea-9080-b438da61821d">
        <source>getDefaultResourcesForCMIFMove(_cmifMovement : CMIF_HMS_WorkingMovement );
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	resourceUsed,
	newResourceUsed		: CMIF_HMS_ResourceUsed;
	resource			: HMS_Resource;
	hmsVDHarbour		: HMS_VesselDataHarbour;
	tmpMoveResource		: HMS_ResourceTypeForMovement;
	tmpResourceType		: HMS_ResourceType;	
	lastVoyage 			: CM_Voyage;
	lastVoyageData		: HMS_VoyageData;
	lastMovement		: HMS_VoyageMovement;			
begin

	if _cmifMovement = null then
		return;
	endif;

	hmsVDHarbour := self.allVesselDataForHarbour[_cmifMovement.myHarbour];

	if hmsVDHarbour = null then
		return;
	endif;  		

	tmpMoveResource := hmsVDHarbour.allMovementResourcesByMovement[_cmifMovement.moveType];

	if tmpMoveResource &lt;&gt; null then

		// where possible set default resource to that of last voyage
		lastVoyage := hmsVDHarbour.myHarbour.getVesselsLastVoyage(self.myVessel.code);
		if lastVoyage &lt;&gt; null then
			lastVoyageData := lastVoyage.myHMSVoyageData;
		endif;				
		if lastVoyageData &lt;&gt; null then
			lastMovement := lastVoyageData.getMovementForMoveType(_cmifMovement.moveType);
		endif;		
			
		foreach tmpResourceType in tmpMoveResource.allResourceTypes do
			create newResourceUsed transient;
			newResourceUsed.notYetSaved := true;
			newResourceUsed.myViewController := _cmifMovement.myViewController;
			newResourceUsed.myWorkingMovement := _cmifMovement;
			newResourceUsed.myResourceType := tmpResourceType;
			
			// Lorcan PAR 11920 When creating a shift from the graphical view the default is that it is InContract
			newResourceUsed.isPartOfContract := true;

			if lastMovement &lt;&gt; null then
				newResourceUsed.myResource := lastMovement.getDefaultResourceForType(tmpResourceType);
			endif;
						
		endforeach;
	endif;

end;</source>
        <Parameter name="_cmifMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="33981280-65a2-4d41-bc0a-533b286fc57c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpCountry : CM_Country;
begin
	if _attrName = ETRow_MyTidalClassArrival
	or _attrName = ETRow_MyTidalClass 
	or _attrName = ETRow_MyTidalClassDept 
	or _attrName = ETRow_MyDefaultLineCompany 
	or _attrName = ETRow_MyShippingAgentDefault 
	or _attrName = ETRow_MyVesselCategoryIn 
	or _attrName = ETRow_MyVesselCategoryOut then
		if self.allVesselDataForHarbour.size &gt; 0 then	
			return self.allVesselDataForHarbour.first.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyDefaultShippingLine then
		if self.myDefaultShippingLine &lt;&gt; null then
			return self.myDefaultShippingLine.description;
		else
			return null;
		endif;						
																
	elseif _attrName = ETRow_MyVesselType then
		if self.myVesselType &lt;&gt; null then
			return self.myVesselType.description;
		else
			return null;
		endif;												
	elseif _attrName = ETRow_CountryCode then
		tmpCountry := self.getMyCountry();	
		if tmpCountry &lt;&gt; null then
			return tmpCountry.description;
		else
			return null;
		endif;	
	elseif _attrName = ETRow_LengthOverall then
		return self.dim_LengthOverall.asStringJMT();
	elseif _attrName = ETRow_GrossRegTonnes then
		return self.dim_GrossRegTonnes.asStringJMT();
	elseif _attrName = ETRow_NetRegTonnes then
		return self.dim_NetRegTonnes.asStringJMT();	// 30680 CCMS QNS 2178
	elseif _attrName = ETRow_DeadWeight then
		return self.dim_DeadWeight.asStringJMT();
	elseif _attrName = ETRow_Beam then
		return self.dim_Beam.asStringJMT();
	elseif _attrName = ETRow_DraftFore then
		return self.dim_DraftFore.asStringJMT();
	elseif _attrName = ETRow_DraftAft then
		return self.dim_DraftAft.asStringJMT();
	elseif _attrName = ETRow_BridgeToBow then
		return self.dist_BridgeToBow.asStringJMT();
	elseif  _attrName = ETRow_BridgeToStern then
		return self.dist_BridgeToStern.asStringJMT();
	elseif _attrName = ETRow_BowToFwdBay then
		return self.dist_BowToFwdContainer.asStringJMT();
	elseif _attrName = ETRow_SternToAftBay then
		return self.dist_SternToAftContainer.asStringJMT();
	elseif _attrName = ETRow_SternToBunker then
		return self.dist_SternToBunker.asStringJMT();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="7a7d9210-ad62-4636-b5af-aaafef26ed1b">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	block : CM_DataContainerBlock;
	passport : CM_Passport;
begin
	inheritMethod(_dataContainer);

	passport := app.myPassport;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel General Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarksGeneral, DC_Data, 1, null);	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel Previous Names', DC_Label, 1, null);
	block.addNewItem(self.remarksPreviousNames, DC_Data, 1, null);	

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getHarboursString" id="f7003979-152c-4f24-8b53-1a63aa903db4">
        <source>getHarboursString(_separator : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2018 cnwma1  Bug 42058: PEL1 - Workorder Voyage Missing port

*/

vars
	vslHarbour : HMS_VesselDataHarbour;
	str,
	sep		   : String;
begin

	if _separator  = null then
		sep := ",";
	elseif _separator = "CrLf" then
		sep := CrLf;
	else
		sep := _separator ;
	endif;
	
	foreach vslHarbour in self.allVesselDataForHarbour	discreteLock do
		if str = null then
			if vslHarbour.myHarbour.description &lt;&gt; null then
				str := vslHarbour.myHarbour.description;
			endif;
		else
			if vslHarbour.myHarbour.description &lt;&gt; null then
				str := str &amp; sep &amp; vslHarbour.myHarbour.description;
			endif;
		endif;
		
	endforeach;
	
	return str;
epilog

end;</source>
        <Parameter name="_separator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCountry" id="0bf97472-1c9c-449c-b2f3-dd4edeb8a5b5">
        <source>getMyCountry() : CM_Country;
//--------------------------------------------------
// Created:	23 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myRoot.allCountries[self.countryCode];
end;</source>
        <ReturnType type="CM_Country"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="02f3da44-0304-4a6a-9796-7663848e5aba">
        <source>getRemarks(_all : Boolean) : String;
//--------------------------------------------------
// Created:	26 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpData : HMS_VesselDataHarbour;
	tmpStr : String;
begin
	if _all
	and (not self.allVesselDataForHarbour.isEmpty) then
		tmpStr := 'General: '&amp; self.remarksGeneral;
		foreach tmpData in self.allVesselDataForHarbour do
			if tmpData.remarksPilotOnly &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ' &amp; tmpData.getRemarks();
			endif;
		endforeach;
	else
		return self.remarksGeneral;
	endif;
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselDataHarbour" id="8fa4361e-f350-4a3f-908c-96e330701f7a">
        <source>getVesselDataHarbour(_harbourObj:HMS_Harbour):HMS_VesselDataHarbour;
// --------------------------------------------------------------------------------
// Created:		01 June 2007 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Vessel Data Harbour object.
//
// Parameters:	_harbourObj - A reference to the Harbour for which the data is required.
//
// Returns:		A reference to a Vessel Data Harbour, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dataObj	: HMS_VesselDataHarbour;
	
begin
	dataObj	:=	self.allVesselDataForHarbour[_harbourObj];
	
	return dataObj;
end;</source>
        <Parameter name="_harbourObj" type="HMS_Harbour"/>
        <ReturnType type="HMS_VesselDataHarbour"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="f9de689a-8b6c-42ca-a6f1-32c3dc27aba2">
        <source>getXMLDefinitionString() : String;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	shipline,
	shipType,
	xml : String;
	tmpVDH : HMS_VesselDataHarbour;
begin
	if self.myDefaultShippingLine &lt;&gt; null then
		shipline := self.myDefaultShippingLine.code;
	endif;
	if self.myVesselType &lt;&gt; null then
		shipType := self.myVesselType.code;
	endif;
	
	xml := "&lt;csv&gt;" &amp; self.coastalServiceVessel.Integer.String &amp;
			 "&lt;/csv&gt;&lt;ccd&gt;" &amp;  self.countryCode.trimBlanks &amp; "&lt;/ccd&gt;&lt;db&gt;" &amp; self.dim_Beam.String &amp;
			 "&lt;/db&gt;&lt;dw&gt;" &amp; self.dim_DeadWeight.String &amp; "&lt;/dw&gt;&lt;da&gt;" &amp; self.dim_DraftAft.String &amp;
			 "&lt;/da&gt;&lt;df&gt;" &amp; self.dim_DraftFore.String &amp; "&lt;/df&gt;&lt;dg&gt;" &amp; self.dim_GrossRegTonnes.String &amp;
			 "&lt;/dg&gt;&lt;dn&gt;" &amp; self.dim_NetRegTonnes.String &amp;
			 "&lt;/dn&gt;&lt;dl&gt;" &amp; self.dim_LengthOverall.String &amp; "&lt;/dl&gt;&lt;bf&gt;" &amp; self.dist_BowToFwdContainer.String &amp;
			 "&lt;/bf&gt;&lt;bb&gt;" &amp; self.dist_BridgeToBow.String &amp; "&lt;/bb&gt;&lt;bs&gt;" &amp; self.dist_BridgeToStern.String &amp;
			 "&lt;/bs&gt;&lt;sa&gt;" &amp; self.dist_SternToAftContainer.String &amp; "&lt;/sa&gt;&lt;sb&gt;" &amp; self.dist_SternToBunker.String &amp;
			 "&lt;/sb&gt;&lt;hb&gt;" &amp; self.hasBowThrust.Integer.String &amp; "&lt;/hb&gt;&lt;hf&gt;" &amp; self.hasFixedProp.Integer.String &amp;
			 "&lt;/hf&gt;&lt;ht&gt;" &amp; self.hasHoldTanks.Integer.String &amp; "&lt;/ht&gt;&lt;hr&gt;" &amp; self.hasRamp.Integer.String &amp;
			 "&lt;/hr&gt;&lt;hs&gt;" &amp; self.hasSternThrust.Integer.String &amp; "&lt;/hs&gt;&lt;rg&gt;" &amp; self.remarksGeneral &amp;
			 "&lt;/rg&gt;&lt;rt&gt;" &amp; self.requiresTow.Integer.String &amp;	//21 Aug 2018	NDL	TFS 40347
			 "&lt;/rt&gt;&lt;tr&gt;" &amp; self.isTramper.Integer.String &amp;	//11 Sep 2018	NDL	TFS 40778
			 "&lt;/tr&gt;&lt;sl&gt;" &amp; shipline &amp; "&lt;/sl&gt;&lt;st&gt;" &amp; shipType &amp; "&lt;/st&gt;";
			 
	foreach tmpVDH in self.allVesselDataForHarbour do
		xml := xml &amp; tmpVDH.getXMLDefinitionString();
	endforeach;
		 
	return xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasHarbourDetails" id="06b1fe78-0776-47c2-a7ed-ef9cd3c98e13">
        <source>hasHarbourDetails() : Boolean;
/*
Purpose:	PAR 36959. ALL vessels have an HMS_VesselData object whether they want to use HMS or not;
									This is because the HMS_VesselData object stores all the dimensions of the vessel
									The vessel is only really using HMS if it has harbour data.
Date		Who		Reason
16 November 2015	cnwab1	Initial creation
*/

vars

begin
	return not self.allVesselDataForHarbour.isEmpty();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="b5b26a24-67b0-437a-924a-9746d8afa30a">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement : JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	vesselDataHarbour : HMS_VesselDataHarbour;
begin
	if _property = HMS_VesselData::myDefaultShippingLine then
		childElement:=_xmlElement.getElementByTagName(CM_ShippingLine::code.name);	
		if childElement &lt;&gt; null then
			self.myDefaultShippingLine:=app.myRoot.allShippingLines[childElement.textData];
		endif;
	elseif _property = HMS_VesselData::myVesselType then
		childElement:=_xmlElement.getElementByTagName(HMS_VesselType::code.name);	
		if childElement &lt;&gt; null then
			self.myVesselType:=app.myRoot.allVesselTypes[childElement.textData];
		endif;
	elseif _property = HMS_VesselData::allVesselDataForHarbour then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(HMS_VesselDataHarbour.name,allChildElements);
		foreach childElement in allChildElements do
			create vesselDataHarbour transient;
			self.allVesselDataForHarbour.add(vesselDataHarbour);
			vesselDataHarbour.importFromXMLDoc(childElement);
		endforeach;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b5cb9d86-1f68-4b20-8a30-cff857b0cb67">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpVDHarbour : HMS_VesselDataHarbour;
	theProxy : SelfType;
	completedOK		: Boolean;
begin
	theProxy :=  inheritMethod();
	theProxy.myDefaultShippingLine := self.myDefaultShippingLine;
	theProxy.myVesselType := self.myVesselType;
	theProxy.myRoot := self.myRoot;
	
	foreach tmpVDHarbour in self.allVesselDataForHarbour do
		theProxy.allVesselDataForHarbour.add(tmpVDHarbour.pxyCreateUpdateProxy());
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9c17dd7a-56f9-4447-ae16-16a1e986b6f4">
        <updating/>
        <source>setForUpdate(_pxyVesselData : HMS_VesselData; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 22 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpToDeleteSet : HMS_VesselDataHarbourSet;
	realVDHarbour,
	pxyVDHarbour : HMS_VesselDataHarbour;
begin
	
	inheritMethod(_pxyVesselData, _passport);

	create tmpToDeleteSet transient;
	self.allVesselDataForHarbour.copy(tmpToDeleteSet);
	self.allVesselDataForHarbour.clear();
	
	foreach pxyVDHarbour in _pxyVesselData.allVesselDataForHarbour do
		realVDHarbour := pxyVDHarbour.pxyGetRealObject();
		if realVDHarbour &lt;&gt; null then
			realVDHarbour.setForUpdate(pxyVDHarbour, _passport);
			if tmpToDeleteSet.includes(realVDHarbour) then
				tmpToDeleteSet.remove(realVDHarbour);
			endif;			
		else
			create realVDHarbour;
			realVDHarbour.setForCreate(pxyVDHarbour, _passport);
		endif;
		self.allVesselDataForHarbour.add(realVDHarbour);		
	endforeach;
	
	tmpToDeleteSet.purge();											
	
	self.coastalServiceVessel := _pxyVesselData.coastalServiceVessel;
	self.countryCode := _pxyVesselData.countryCode;

	self.dim_Beam := _pxyVesselData.dim_Beam;
	self.dim_DeadWeight := _pxyVesselData.dim_DeadWeight;
	self.dim_DraftAft := _pxyVesselData.dim_DraftAft;
	self.dim_DraftFore := _pxyVesselData.dim_DraftFore;
	self.dim_GrossRegTonnes := _pxyVesselData.dim_GrossRegTonnes;
	self.dim_NetRegTonnes := _pxyVesselData.dim_NetRegTonnes;		// QNS 2178
	self.dim_LengthOverall := _pxyVesselData.dim_LengthOverall;

	self.dist_BowToFwdContainer := _pxyVesselData.dist_BowToFwdContainer;
	self.dist_BridgeToBow := _pxyVesselData.dist_BridgeToBow;
	self.dist_BridgeToStern := _pxyVesselData.dist_BridgeToStern;
	self.dist_SternToAftContainer := _pxyVesselData.dist_SternToAftContainer;
	self.dist_SternToBunker := _pxyVesselData.dist_SternToBunker;

	self.hasBowThrust := _pxyVesselData.hasBowThrust;
	self.hasFixedProp := _pxyVesselData.hasFixedProp;
	self.hasHoldTanks := _pxyVesselData.hasHoldTanks;
	self.hasRamp := _pxyVesselData.hasRamp;
	self.hasSternThrust := _pxyVesselData.hasSternThrust;

	self.remarksGeneral := _pxyVesselData.remarksGeneral;
	self.remarksPreviousNames := _pxyVesselData.remarksPreviousNames;	
	self.requiresTow := _pxyVesselData.requiresTow;	//21 Aug 2018	NDL	TFS 40347
	self.isTramper := 	_pxyVesselData.isTramper;		//11 Sep 2018	NDL	TFS 40778
	
	self.myDefaultShippingLine := _pxyVesselData.myDefaultShippingLine;	
	self.myVesselType := _pxyVesselData.myVesselType;
	self.myRoot := _pxyVesselData.myRoot;

epilog
	delete tmpToDeleteSet;	
end;</source>
        <Parameter name="_pxyVesselData" type="HMS_VesselData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6f466d4a-ccca-4b52-b35d-7e5a2543f61b">
        <updating/>
        <source>setProxy(	_root : CM_Root;
			_coastalServiceVessel : Boolean;
			_isTramper : Boolean;		//11 Sep 2018	NDL	TFS 40778
			_requiresTow : Boolean;		//21 Aug 2018	NDL	TFS 40347
			_hasBowThrust : Boolean;
			_hasFixedProp : Boolean;
			_hasHoldTanks : Boolean;
			_hasRamp : Boolean;
			_hasSternThrust : Boolean;
			_remarksGeneral : String;
			_remarksPreviousNames : String;
			_countryCode : String;
			_dim_Beam : Decimal;
			_dim_DraftAft : Decimal;
			_dim_DraftFore : Decimal;
			_dim_LengthOverall : Decimal;
			_dim_DeadWeight : Integer;
			_dim_GrossRegTonnes : Integer;
			_dim_NetRegTonnes : Integer;
			_dist_BowToFwdContainer : Integer;
			_dist_BridgeToBow : Integer;
			_dist_BridgeToStern : Integer;
			_dist_SternToAftContainer : Integer;
			_dist_SternToBunker : Integer;
			_shippingLine : CM_ShippingLine;
			_vesselType : HMS_VesselType)updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.coastalServiceVessel		:=	_coastalServiceVessel;
	self.countryCode				:=	_countryCode;

	self.dim_Beam					:=	_dim_Beam;
	self.dim_DeadWeight				:=	_dim_DeadWeight;
	self.dim_DraftAft				:=	_dim_DraftAft;
	self.dim_DraftFore				:=	_dim_DraftFore;
	self.dim_GrossRegTonnes			:=	_dim_GrossRegTonnes;
	self.dim_NetRegTonnes			:=	_dim_NetRegTonnes;
	self.dim_LengthOverall			:=	_dim_LengthOverall;

	self.dist_BowToFwdContainer		:=	_dist_BowToFwdContainer;
	self.dist_BridgeToBow			:=	_dist_BridgeToBow;
	self.dist_BridgeToStern			:=	_dist_BridgeToStern;
	self.dist_SternToAftContainer	:=	_dist_SternToAftContainer;
	self.dist_SternToBunker			:=	_dist_SternToBunker;

	self.hasBowThrust				:=	_hasBowThrust;
	self.hasFixedProp				:=	_hasFixedProp;
	self.hasHoldTanks				:=	_hasHoldTanks;
	self.hasRamp					:=	_hasRamp;
	self.hasSternThrust				:=	_hasSternThrust;

	self.remarksGeneral				:=	_remarksGeneral;
	self.remarksPreviousNames		:=	_remarksPreviousNames;
	self.requiresTow 				:= _requiresTow;	//21 Aug 2018	NDL:	TFS 40347
	self.isTramper	 				:= 	_isTramper;		//11 Sep 2018	NDL	TFS 40778
	
	self.myDefaultShippingLine		:=	_shippingLine;
	self.myVesselType				:=	_vesselType;
	self.myRoot						:=	_root;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_coastalServiceVessel" type="Boolean"/>
        <Parameter name="_isTramper" type="Boolean"/>
        <Parameter name="_requiresTow" type="Boolean"/>
        <Parameter name="_hasBowThrust" type="Boolean"/>
        <Parameter name="_hasFixedProp" type="Boolean"/>
        <Parameter name="_hasHoldTanks" type="Boolean"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_hasSternThrust" type="Boolean"/>
        <Parameter name="_remarksGeneral" type="String"/>
        <Parameter name="_remarksPreviousNames" type="String"/>
        <Parameter name="_countryCode" type="String"/>
        <Parameter name="_dim_Beam" type="Decimal"/>
        <Parameter name="_dim_DraftAft" type="Decimal"/>
        <Parameter name="_dim_DraftFore" type="Decimal"/>
        <Parameter name="_dim_LengthOverall" type="Decimal"/>
        <Parameter name="_dim_DeadWeight" type="Integer"/>
        <Parameter name="_dim_GrossRegTonnes" type="Integer"/>
        <Parameter name="_dim_NetRegTonnes" type="Integer"/>
        <Parameter name="_dist_BowToFwdContainer" type="Integer"/>
        <Parameter name="_dist_BridgeToBow" type="Integer"/>
        <Parameter name="_dist_BridgeToStern" type="Integer"/>
        <Parameter name="_dist_SternToAftContainer" type="Integer"/>
        <Parameter name="_dist_SternToBunker" type="Integer"/>
