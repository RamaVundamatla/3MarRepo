<Class name="CM_EDIFileTypeXMLSuzanoPrenote" id="582dbdba-1aaf-4ca9-8dc4-9d62dae2ec43">
    <superclass name="CM_EDIFileTypeXML"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="8839ea6d-6d26-4071-9d74-24d83abadd44">
        <updating/>
        <source>create() updating;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
vars

begin
	self.name := "Suzano EDI PackingList";
	self.type := EDIFileType_XMLSuzanoPrenotes;
end;
</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="43f1a456-49e7-4765-a675-eb61434bd03e">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//----------------------------------------------------------------
vars
	ediData : CM_EDIData;
begin
	_ediDataClass := CM_EDIDataPrenote;
	_dataType := EDIDataType_Prenote;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
