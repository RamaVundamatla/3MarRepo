    <JadeMethod name="showNumberOfItems" id="6152cc22-4ca6-48bf-850d-f6fa58037541">
        <source>showNumberOfItems(_table :CM_BaseTable);
// ---------------------------------------------------------------------------
// Created:     05 May 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/05/2010	cnwcs5		New methods to show number of items in the table
// ---------------------------------------------------------------------------
vars
	count	:Integer;
begin
	if self.staStatusBar.visible and _table.visible then
		count := _table.rows - _table.fixedRows;
		
		self.staStatusBar.caption := app.getErrorString1 (Num_Rows_Found, count.String);
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_BaseTable"/>
    </JadeMethod>
    <JadeMethod name="showSelectedCount" id="122c797f-177b-4d8e-b52a-625bfe42da64">
        <updating/>
        <source>showSelectedCount(selected, max : Integer) updating;
// added for Par 23340 show select count in status line, as &lt;n&gt; of &lt;max&gt;
//31/7/25 navsaa30 MTN-35213 MTN | Pagination - Invoice List
vars
	col: Collection;
begin
	col := self.tblData.getCollection();
	if self.staStatusBar.visible then
		if col &lt;&gt; null then
			self.staStatusBar.caption := " " &amp; app.getErrorString2(SelectedOf, selected.asStringJMT, col.size.asStringJMT);		//navsaa30 #35313
		else
			self.staStatusBar.caption := " " &amp; app.getErrorString2(SelectedOf, selected.asStringJMT, max.asStringJMT);
		endif;
	endif;
end;</source>
        <Parameter name="selected" type="Integer"/>
        <Parameter name="max" type="Integer"/>
    </JadeMethod>
