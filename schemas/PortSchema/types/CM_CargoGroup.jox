    <JadeMethod name="getCargoGroupGrammage" id="c440765d-8bcc-46f9-a220-010ae717f209">
        <source>getCargoGroupGrammage() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2023	navra1	Initial creation for TFS 60586 - EUP | FR - GoodsReceipt - Grammage Value Is Missing In File
28 May 2024  navrv30 CR 64323 Task 64327: Jade - Chnage Existing Get methods to use Details
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgd : CM_CargoGroupDetail;
	retStr, valueStr : String;
	ti	: CM_TrackedItem;	//24/03/2025	navkc1 JIRA Story MTN-34256
	tiGram : Decimal[23,2]; //24/03/2025	navkc1 JIRA Story MTN-34256
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			tiGram := ti.getGrammage();
			
			if tiGram &lt;&gt; null then
				retStr.addStringToList(tiGram.asStringJMT(), ", ");
			endif;
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			valueStr := cgd.grammage;
			/*
			if valueStr &lt;&gt; null then
				if retStr.pos(valueStr, 1) = 0 then
					if retStr = null then
						retStr := valueStr;
					else
						retStr := retStr &amp; ", " &amp; valueStr;
					endif;
				endif;
			endif;
			*/
			
			retStr.addStringToList(valueStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endforeach;
	endif;
	
	return retStr;
epilog
	
