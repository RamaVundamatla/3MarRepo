<CollClass name="PointArray">
    <JadeMethod name="asString" id="6ab53b4d-93a1-41c2-87a0-a40f980a2807">
        <source>asString() : String;
/*
Purpose: Convert to a string in format "x1,y1 x2,y2 x3,y3"

Date		Who		Reason
27 June 2011	cnwdw1	Initial creation
*/
vars
	tmpStr : String;
	aPoint : Point;
begin
	foreach aPoint in self do
		tmpStr := tmpStr &amp; aPoint.x.String &amp; "," &amp; aPoint.y.String &amp; " ";
	endforeach;
	return tmpStr.trimBlankCharacters();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="calculateArea" id="f27b6c55-9de0-4bb3-9959-7fb8e7c7e3d9">
        <source>calculateArea() : Decimal;
/*

Purpose:	Calculates the Area formulae used is Surveyors Formala	
			google it for more info or if you know your math formala in detail is at
			http://www.maa.org/pubs/Calc_articles/ma063.pdf
			
			also online calculator is available at 
				http://www.analyzemath.com/Geometry_calculators/irregular_polygon_area.html
				
			I used this to verify answers were correct
					
Return Value:	Area of a polygon	


Date		Who		Reason
21 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	k : Integer;
	xDiff, yDiff : Integer;
	numberOfPoints : Integer;
	area 		: Decimal[12,4];
begin

	numberOfPoints:=self.size;
	k:=1;
	while k &lt;=numberOfPoints do
		if k = numberOfPoints then
			xDiff:= 0- self[k].x;
			yDiff:= 0- self[k].y;
		else
			xDiff:= self[k+1].x - self[k].x;
			yDiff:= self[k+1].y - self[k].y;
		endif;
		area:= area + self[k].x * yDiff - self[k].y * xDiff;
		
		k:=k+1;
	endwhile;
	
	area:=(0.5 * area).abs;
	
	return area;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="drawFilledPolygon" id="2c618d1a-63d6-46aa-a740-db8c918f645a">
        <source>drawFilledPolygon(_frame : Frame; _colour : Integer; _scale : Decimal);
// ---------------------------------------------------------------------------
// Created:		30 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	rArray : RealArray;
begin
	if self.isEmpty then
		return;
	endif;
	
	create rArray transient;
	self.populateRealArray(rArray, _scale);	
	
	_frame.drawFilledPolygon(rArray,_colour);	
epilog
	delete rArray;
end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_scale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="edgeIntersection" id="e564b57c-3e9c-4bb7-8926-d621b0e19f62">
        <source>edgeIntersection( a , b, c, d : Point input ) : Boolean protected;
/*

Purpose:			

Parameters:		one edge is a &amp; b  the other edge is c &amp; d	determines if the lines intersect 
   
                as used in the Separating Axis Theorem - http://content.gpwiki.org/index.php/Polygon_Collision
				
Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation PAR 29079

*/

vars	

	n_a,
	n_b,
	ua,ub,
    det : Real;
begin
	
	det:= (d.y - c.y) * (b.x - a.x) - (d.x - c.x) * (b.y - a.y);
	
	n_a:=  (d.x - c.x) * (a.y - c.y) - (d.y - c.y) * (a.x - c.x);
	
	n_b:=(b.x - a.x)  * (a.y - c.y) -(b.y - a.y) * (a.x -  c.x);
	 // Make sure there is not a division by zero - this also indicates that
	 // the lines are parallel.  
	 // If n_a and n_b were both equal to zero the lines would be on top of each 
	 // other (coincidental).  This check is not done because it is not 
	 // necessary for this implementation (the parallel check accounts for this).
	if (det = 0 ) then
		return false;
	endif;
	
	ua := n_a/det;
	ub:= n_b/det;
	if (ua &gt;= 0 and ua &lt;= 1 and ub &gt;= 0 and ub &lt;= 1) then
       
           // ptIntersection.X = L1.X1 + (ua * (L1.X2 - L1.X1));
           // ptIntersection.Y = L1.Y1 + (ua * (L1.Y2 - L1.Y1));
        return true;
    else
         return false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="a" type="Point" usage="input"/>
        <Parameter name="b" type="Point" usage="input"/>
        <Parameter name="c" type="Point" usage="input"/>
        <Parameter name="d" type="Point" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="b610bd7c-2c88-4b85-a27d-2f262ba87360">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:		16 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
	pntX, pntY,idx : Integer;
	aPoint : Point;
begin
	foreach aPoint in self do
		tmpStr := tmpStr &amp; " X: " &amp; aPoint.x.String &amp; " Y: " &amp; aPoint.y.String &amp; "/ ";
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtremePoints" id="42e943ad-8ad2-4e79-accc-8f7467538af5">
        <source>getExtremePoints(_x1, _y1, _x2, _y2 : Integer io);
/*

Date		Who		Reason
25 July 2013	cnwer1	Initial creation PAR

*/

vars
	aPoint  ,firstPoint: Point;
begin
	firstPoint:=self.first;
	if firstPoint = null then
		return;
	endif;

	// passed in X1 and Y1 must be initialised to 99999999
	foreach aPoint in self discreteLock do

		_x1:=aPoint.x.min(_x1);

		_x2:=aPoint.x.max(_x2);
		
		_y1:=aPoint.y.min(_y1);

		_y2:=aPoint.y.max(_y2);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getExtremesForText" id="5e085882-5ae3-48d8-9348-67550802dc09">
        <source>getExtremesForText(_x1, _y1, _x2, _y2 : Integer output);

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/
constants
	CHKLIMIT			: Integer = 300;

vars
	bestPlace, polygon	: PointArray;
	frame 				: Frame;
	x1, y1, x2, y2		: Real;
	point, point2		: Point;
	wasOut				: Boolean;
	offset, origY, 
	maxX, maxY, height,
 	minX, minY, 
	diffX, diffY		: Integer;
	checkCount			: Integer;
	
	isAngled			: Boolean;
	x, a				: Integer;
	
	lPoint, lPoint2		: Point;
begin
	wasOut := false;
	isAngled := false;
	height := 10;
	checkCount := 0;
	
	create bestPlace transient;
	create polygon transient;
	
	// Starting points (inside poly)
	foreach point in self do
		if bestPlace.isEmpty() then
			bestPlace.add(point);
			origY := point.y;
		elseif point.x &lt; bestPlace[1].x then
			bestPlace[1] := point;
		elseif point.x = bestPlace[1].x and point.y &lt; bestPlace[1].y then
			bestPlace[1] := point;
		endif;
		
		//Find the smallest Y point
		if minY = null then
			minY := point.y;
		elseif minY &gt; point.y then
			minY := point.y;
		endif;
		
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
		
		//Find the smallest X point
		if minX = null then
			minX := point.x;
		elseif minX &gt; point.x then
			minX := point.x;
		endif;
	endforeach;
	
	diffX := (maxX - minX);
	//diffY := maxY - minY;
	
	// Calculate other points...
	point.set((((diffX/2).Integer) + minX), bestPlace[1].y + height);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
	point.set(bestPlace[1].x, bestPlace[2].y);
	bestPlace.add(point);
	point.set(bestPlace[2].x, bestPlace[1].y);
	bestPlace.add(point);
	
	//Swap points around..
	point := bestPlace[2];
	bestPlace[2] := bestPlace[3];
	bestPlace[3] := point;
	
	//write "points: " &amp; bestPlace[1].x.String &amp; "," &amp; bestPlace[1].y.String &amp; " " &amp; bestPlace[2].x.String &amp; "," &amp; bestPlace[2].y.String &amp; " " &amp; bestPlace[3].x.String &amp; "," &amp; bestPlace[3].y.String &amp; " " &amp; bestPlace[4].x.String &amp; "," &amp; bestPlace[4].y.String &amp; " ";
	//write "diffX: " &amp; diffX.String;
	//write "minX: " &amp; minX.String;
	//write "next point: " &amp; (((diffX/2).Integer) + minX).String;
	
	self.copy(polygon);
	
	polygon.add(polygon[1]);
	
	x := 1;
	a := 1;
	/*foreach point in self do
		foreach a in x to polygon.size do
			point2 := polygon[a];
			if point = point2 then
				continue;
			endif;
			if point.x &lt;&gt; point2.x then
				if point.y &lt;&gt; point2.y then
					if lPoint = null then
						lPoint := point;
						lPoint2 := point2;
					elseif point.x &lt; lPoint.x then
						lPoint := point;
						if a = polygon.size then
							lPoint2 := polygon[1];
						else
							lPoint2 := polygon[a+1];
						endif;
					endif;
					isAngled := true;
					//write "Is Angled: " &amp; isAngled.String &amp; Tab &amp; "Point x: " &amp; point.x.String &amp; Tab &amp; "Point y: " &amp; point.y.String &amp; Tab &amp; "Point2 x: " &amp; point2.x.String &amp; Tab &amp; "Point2 y: " &amp; point2.y.String;
				endif;
			endif;
			x := x + 1;
			break;
		endforeach;
	endforeach;*/

	foreach a in 1 to polygon.size do
		if a = polygon.size then
			break;
		endif;
		
		point := polygon[a];
		point2 := polygon[a+1];
		if point = point2 then
			continue;
		endif;
		
		if point.x &lt; point2.x and point.y &gt; point2.y or point.x &gt; point2.x and point.y &lt; point2.y then
			if lPoint = null then
				lPoint := point;
				lPoint2 := point2;
			elseif point.x &lt; lPoint.x or point2.x &lt; lPoint2.x then
				lPoint := point;
				lPoint2 := point2;
			endif;
			isAngled := true;
		endif;
	endforeach;
	
	if isAngled then
		point.setX(((lPoint.x + lPoint2.x) / 2).Integer);
		point.setY(((lPoint.y + lPoint2.y) / 2).Integer);
		foreach point2 in self do
			if point2.x &lt; point.x and point2.y &lt; point.y then
				isAngled := false;
				break;
			endif;
		endforeach;
	endif;
	
	// FOR TESTING
	//frame.drawLine(lPoint.x, lPoint.y, 0, 0, Red);
	//frame.drawLine(lPoint2.x, lPoint2.y, 0, 0, Red);
	//write "lPoint: " &amp; lPoint.x.String &amp; ", " &amp; lPoint.y.String &amp; Tab &amp; "lPoint2: " &amp; lPoint2.x.String &amp; ", " &amp; lPoint2.y.String;
	
	// Find the best place...
	if isAngled then
		bestPlace.clear();
		point.setX(((lPoint.x + lPoint2.x) / 2).Integer + 1);
		point.setY(((lPoint.y + lPoint2.y) / 2).Integer + 1);
		bestPlace.add(point);
		
		point.set(maxX, bestPlace[1].y);
		bestPlace.add(point);
		
		point.set(bestPlace[1].x, maxY);
		bestPlace.add(point);
		
		point.set(maxX, maxY);
		bestPlace.add(point);
		
		while (self.intersectsPolygon(bestPlace, true) = false) and (checkCount &lt; CHKLIMIT) do
			bestPlace[2].setX(bestPlace[2].x - 1);
			bestPlace[3].setY(bestPlace[3].y - 1);
			bestPlace[4].set((bestPlace[4].x - 1), (bestPlace[4].y - 1));
			
			checkCount := checkCount + 1;
		endwhile;

		bestPlace[2].set(bestPlace[4].x, bestPlace[4].y);
		
		offset := 1;
	else
		while (self.intersectsPolygon(bestPlace, true) = false) and (checkCount &lt; CHKLIMIT) do
			bestPlace[1].setY(bestPlace[1].y + 2);
			bestPlace[2].setY(bestPlace[2].y + 2);
			bestPlace[3].setY(bestPlace[3].y + 2);
			bestPlace[4].setY(bestPlace[4].y + 2);
			
			if bestPlace[2].y &gt; maxY then
				height := height - 2;
				bestPlace[1].setY(origY);
				bestPlace[2].setY(origY + height);
				bestPlace[3].setY(origY + height);
				bestPlace[4].setY(origY);
			endif;
			
			if not bestPlace[2].insidePolygon(self) or not bestPlace[1].insidePolygon(self) then
				//bestPlace[1].setX(bestPlace[1].x + ((lPoint2.x - lPoint.x) / 2).Integer);
				//bestPlace[2].setX(bestPlace[2].x + ((lPoint2.x - lPoint.x) / 2).Integer);
				bestPlace[1].setX(bestPlace[1].x + 2);
				bestPlace[2].setX(bestPlace[2].x + 2);
			endif;
			
			checkCount := checkCount + 1;
		endwhile;
		
		offset := 2;
	endif;
	
	// Put into param's for output
	if checkCount = CHKLIMIT then
		_x1 := minX + offset;
		_y1 := minY + offset;
		_x2 := minX + offset;
		_y2 := minY + offset;
	else
		_x1 := bestPlace[1].x + offset;
		_y1 := bestPlace[1].y + offset;
		_x2 := bestPlace[3].x + offset;
		_y2 := bestPlace[3].y + offset;
	endif;
	
epilog
	delete bestPlace;
	delete polygon;
end;


//getExtremesForText(_x1, _y1, _x2, _y2 : Integer output);

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

/*vars
	bestPlace 		: PointArray;
	frame 			: Frame;
	point			: Point;
	wasOut			: Boolean;
	offset, origY, 
	maxX, maxY, 
	height, minX 	: Integer;
	
begin
	wasOut := false;
	height := 100;
	create bestPlace transient;
	
	// Starting points (inside poly)
	foreach point in self do
		if bestPlace.isEmpty() then
			bestPlace.add(point);
			origY := point.y;
		elseif point.x &lt; bestPlace[1].x then
			bestPlace[1] := point;
		endif;
		
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
		
		//Find the smallest X point
		if minX = null then
			minX := point.x;
