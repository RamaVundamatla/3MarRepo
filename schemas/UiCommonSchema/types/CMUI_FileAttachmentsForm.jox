    <JadeMethod name="initTable" id="daa608b1-77fe-4aaf-ab75-c8107a7ad4b8">
        <source>initTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	entTableDef : EntTableDef;
	tmpTable : CM_DataTable;
	
begin

	tmpTable := self.tblFiles;
	entTableDef	:= app.myController.getEntTableDef(ETDef_FileDocument);
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.userInputEnabled := false;
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;
	self.displayFiles();
	
epilog

end;</source>
    </JadeMethod>
