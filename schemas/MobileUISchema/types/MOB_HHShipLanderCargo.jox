    <JadeMethod name="doComplete" id="afe307df-b3fd-496a-8ec1-20f210645f8a">
        <updating/>
        <source>doComplete():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	errMess : String;
	tmpFoundLC : CM_LocationsController;
	wle : CM_WorkListEntry;
	checksSubCargo : CM_TrackedItem;
	
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	//24 Mar 2010	NDL	Par 23316
	if self.myTrackedItem.myVoyage &lt;&gt; self.myMobileGenericAgent.myVoyage then
		errMess := app.getErrorString3(Contai_voyage_your_curren_voya,self.myTrackedItem.id, self.myTrackedItem.myVoyage.code, self.myMobileGenericAgent.myVoyage.code);
		self.myTrackedItem := null;
		self.msgBox(errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.txtId.setFocus();
		return false;
	endif;
	
	//29 Apr 2010	NDL	Par 23945
	if self.myMobileGenericAgent.myBOL &lt;&gt; null then
		if not self.myMobileGenericAgent.myBOL.allTrackedItems.includes( self.myTrackedItem ) then
			errMess := self.myTrackedItem.id &amp; " is not part of BOL " &amp; self.myMobileGenericAgent.myBOL.number;
			self.myTrackedItem := null;
			self.msgBox(errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
			self.txtId.setFocus();
			return false;
		endif;
	endif;
	
	//cnwas3 par 24172
//	if self.hasRequiredChecks(CARGO_CHECK_CONTEXT_YARD) then 
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_YARD, self.myTrackedItem, checksSubCargo)  &lt;&gt; null then	//28 May 2010	NDL	Par 23698
		errMess := app.getErrorString(Action_required_cargo_checks);
		self.msgBox(errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	//////////////////
	
	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;	
	
	if tmpFoundLC.isVoyageController then //cnwrd1 par 28868 9.1.2012
		errMess := app.getErrorString(Location_ship_discharge);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, self.txtLocation.text);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;	
	
	// we have a location, should be good to go.
	//08 Mar 2010	NDL	Par 22657
//	wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
	wle := self.myTrackedItem.getVoyageWLEForLCUnactioned( false, tmpFoundLC );	//23 Jun 2016	NDL	TFS 2172
	if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, 0, 0, null ) then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFindLocation" id="762df64a-a040-47e0-b0a3-34aa8b6f8096">
        <source>doFindLocation();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwndl1	Initial creation	Par 22962

*/

vars

	errMess : String;
	location : CM_LocationsController;
	
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return;
	endif;
	
	location := self.myMobileGenericAgent.findLocationFor( self.myTrackedItem, self.myTerminal );	//15 Dec 2010	NDL	Par 26578
		
	if location &lt;&gt; null then
		txtLocation.text := location.getFullId;
	else
		errMess := app.getErrorString(Auto_plan_locatio_for_criteria);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="2197de20-8d11-4334-a062-b5220a065f8b">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	localTop : Real;
	localHeight : Real;
	stdWidth : Real;
	halfWidth : Real;
	width : Real;
	stdHeight : Real;
	
	formToDisplay	: Class;
	context, state	: Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( self.clientWidth/2 ) - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	width := stdWidth - self.getSearchButtonSpace();
	localTop := self.resizedMargin;
	
	if _initialSetup then
		self.txtId.visible := true;
	endif;
	self.txtId.move( self.resizedMargin,
					 localTop,
					 width,
					 stdHeight );
					 
	width := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move( self.txtId.left + self.txtId.width + self.resizedMargin,
						 localTop,
						 width,
						 stdHeight );
						 
	localTop := localTop + self.txtId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 localTop,
							 halfWidth,
							 stdHeight );
							 
	localTop := self.lblCargoType.top;	
	if _initialSetup then
		self.btnAutoPlan.visible := true;
	endif;
	self.btnAutoPlan.move( btnOne.left ,
							 localTop,
							 btnOne.width,
							 btnOne.height );
						 
	localTop := localTop + self.btnAutoPlan.height + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move( self.resizedMargin,
							 localTop,
							 stdWidth,
							 stdHeight );

	localTop := localTop + self.txtLocation.height + self.resizedMargin;
//	localHeight := self.height - localTop +  self.getSessionAgent().deviceHeightOffset;
	localHeight := self.clientHeight - localTop;	 //26 Jun 2017	NDL	TFS 4647
	if _initialSetup then
		self.tblCargoChecks.visible := true;
	endif;
	self.tblCargoChecks.move( self.resizedMargin,
							 localTop,
							 stdWidth,
							 localHeight );
							 
	state := self.myMobileGenericAgent.checksState;
	if state = self.myMobileGenericAgent.ShipDischargeCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_DISC;
	elseif state = self.myMobileGenericAgent.ShipLoadCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_LOAD;
	elseif state = self.myMobileGenericAgent.Yard then
		context := CARGO_CHECK_CONTEXT_YARD;
	endif;
							 
	if self.myTerminal.hasNoCargoCheckItemsFor(context) then	//31 May 2012	NDL Par 29038
		self.tblCargoChecks.visible := false;
	else
		self.tblCargoChecks.visible := true;
		// PAR #22960 remember where the cargo check table is, as the setup below moves it
	//	tableTop := self.tblCargoChecks.top;
		self.myHandHeldCheckerAgent.setupContextChecksTable(	self.tblCargoChecks,
															context,
															self,
															self.btnTick, self.btnCross, self.btnTickDown, self.btnCrossDown, self.btnButton,
															formToDisplay,
															null );
		// PAR #22960 now put the table back where it was
		self.tblCargoChecks.top := localTop;
	endif;

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="3b388beb-ed50-4fe3-84a5-fcc08bba4ea2">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	voyage : CM_Voyage;
	strs : StringArray;
	
begin

	// Find the location we are moving to.
	dataString := txtLocation.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblLocation.caption.toUpper then
		errMess := app.getErrorString( No_Location_entered );
	else
		term := self.myMobileDataAgent.myTerminal;		
		self.myTerminal.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			voyage := self.myMobileGenericAgent.myVoyage;
			if voyage &lt;&gt; null then
				create strs transient;
				strs.add( dataString );
				voyage.findLocation(strs, true, tmpFoundLC, tmpFoundHeight);			
			endif;
		endif;
		
		if tmpFoundLC = null then
			errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		//endif;
		//if tmpFoundLC.isMachineController() or tmpFoundLC.isVehicle() then 	// PAR 26960
		elseif tmpFoundLC.isMachineController() or tmpFoundLC.isVehicle() then	// 14/03/2013 cnwar2 #30740 - changed to elseif
			errMess := app.getErrorString2(Canno_move_canno_move_machi_ve, self.txtId.text, "'" &amp; dataString &amp; "'" );
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtLocation.setFocus();
		return false;
	endif; 
	
	return true;
	
epilog

	delete strs;

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
