    <JadeMethod name="addCraneMoveTxn" id="0111968b-7890-48b0-be55-fbd92a77b6ff">
        <source>addCraneMoveTxn(_moveTxn: CMIF_KEAMove): CM_Move;

vars
	craneMoveTxn: CM_Move;
	history: CM_MachineMoveHistory;
	lc: CM_LocationsController;
	tmpFoundHeight: Integer;	
begin
	history := _moveTxn.moveTxn.allMachineMoveHistories.first.CM_MachineMoveHistory;
	if history &lt;&gt; null then
		_moveTxn.moveTxn.myTerminal.findLocationFromString(history.targetLocation, true, lc, tmpFoundHeight);
		if lc &lt;&gt; null and lc.isCraneLaneController then
			create craneMoveTxn transient;
			craneMoveTxn.setCraneMoveDetailsFrom(_moveTxn.moveTxn, lc.CM_CraneLaneController);
			return craneMoveTxn;
		endif;
	endif;
	return null;
epilog
end;</source>
        <Parameter name="_moveTxn" type="CMIF_KEAMove"/>
        <ReturnType type="CM_Move"/>
    </JadeMethod>
