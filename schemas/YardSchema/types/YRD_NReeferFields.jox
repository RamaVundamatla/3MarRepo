    <JadeMethod name="btnMoveDown_click" id="7a75ceab-ac1b-43ba-8d6f-4d5b097c900d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveDown_click(btn: Button input) updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars


	entRow : EntTableRow;
	idx : Integer;

begin
	idx :=  self.lstFieldsUsed.listIndex;
	
	if idx &lt; 1 
	or idx = self.lstFieldsUsed.listCount then
		return;
	endif;
	
	entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
	self.lstFieldsUsed.removeItem(idx);
	
	idx := idx + 1;
	if entRow.isGroupRow() then
		self.lstFieldsUsed.addItemAt(app.getErrorString(Etrow_newLine), idx);
		self.lstFieldsUsed.itemBackColor[idx] := DarkGray;
		self.lstFieldsUsed.itemForeColor[idx] := White;
	else

		self.lstFieldsUsed.addItemAt(self.getRowHeading(entRow), idx);
	endif;
	self.lstFieldsUsed.itemObject[idx] := entRow;
	self.lstFieldsUsed.itemSelected[idx] := true;
	self.lstFieldsUsed.listIndex := idx;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnMoveUp_click" id="83b80a66-5d75-4fc5-9736-466364eed90f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveUp_click(btn: Button input) updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	entRow : EntTableRow;
	idx : Integer;

begin
	idx :=  self.lstFieldsUsed.listIndex;
	
	if idx &lt; 2 then
		return;
	endif;
	
	entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
	self.lstFieldsUsed.removeItem(idx);
	
	idx := idx - 1;
	
	if entRow.isGroupRow() then
		self.lstFieldsUsed.addItemAt(app.getErrorString(Etrow_newLine), idx);
		self.lstFieldsUsed.itemBackColor[idx] := DarkGray;
		self.lstFieldsUsed.itemForeColor[idx] := White;
	else

		self.lstFieldsUsed.addItemAt(self.getRowHeading(entRow), idx);
	endif;
	self.lstFieldsUsed.itemObject[idx] := entRow;
	self.lstFieldsUsed.itemSelected[idx] := true;
	self.lstFieldsUsed.listIndex := idx;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNewLine_click" id="17fba41c-804f-4294-9d42-8bba9d1d1aae">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewLine_click(btn: Button input) updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	entDef : EntTableDef;
	entGrp : EntTableGroup;
	entRow : EntTableRow;
	idx, grpcount : Integer;
begin
	foreach idx in 1 to self.lstFieldsUsed.listCount do
		entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
		
		if entRow.isGroupRow then
			grpcount := grpcount + 1;
		endif;
	endforeach;
	
	if grpcount = 10 then
		return;
		global.beep;
	endif;
	
	entGrp := app.myController.getEntTableGroup(ETGrp_ReeferAPI);
	entRow := entGrp.getEntTableRow(ETRow_Div1);
	
	if entRow = null then
		
		return;
	endif;
	
	idx := self.lstFieldsUsed.addItem(app.getErrorString(Etrow_newLine));
	self.lstFieldsUsed.itemObject[idx] := entRow;

	self.lstFieldsUsed.itemBackColor[idx] := DarkGray;
	self.lstFieldsUsed.itemForeColor[idx] := White;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="97db770c-9132-47ce-bf02-2c14a99f06ad">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars

	entRow : EntTableRow;
	idx : Integer;

begin
	idx :=  self.lstFieldsUsed.listIndex;
	
	if idx &lt; 0 then
		return;
	endif;
	
	entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
	self.lstFieldsUsed.removeItem(idx);

	if not entRow.isGroupRow then
		idx := self.lstFieldsAvailable.addItem(self.getRowHeading(entRow));
		self.lstFieldsAvailable.itemObject[idx] := entRow;

		self.lstFieldsAvailable.sorted := true;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="49d80629-ba7c-463e-bbf3-18e8750f566c">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Date		Who		Reason
01JUL2021	NAVAB1	TFS 51361
*/


vars

begin

	self.permissionView  := PmAdmReeferLayoutView;
	self.permissionMaint := PmAdmReeferLayoutMaint;
