    <JadeMethod name="addMissingMapValues_getDefault" id="29349175-6cb1-4a23-bc7f-10feff98d617">
        <source>addMissingMapValues_getDefault(_defValues :StringArray; _numTabs, _numRows, _numCols, _numKeys:Integer)protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter				: Iterator;
	grouping			: CMIF_OutputGrouping;
	int	, grpNo			: Integer;
	mapping				: CM_XTABMapping;
	value				: String;
	parentIncludeAll	: Boolean;
begin
	iter := self.allXTABData.createIterator;
	
	iter.next (grouping);	// first grouping in our collection
	
	foreach int in 1 to _numKeys do
		if int = _numTabs + 1 then
			continue;	// level key - not a grouping value
		endif;
		
		if _numRows = 0 and int = _numTabs + 2 then
			// no rows so value will always be the same
			value := self.Dummy_Detail_Value;
		elseif _numCols = 0 and int = _numKeys then
			// no columns so value will always be the same
			value := self.Dummy_Detail_Value;
		else
			// get any mapping corresponding to this grouping
			grpNo	:= self.keyXTAB_to_indexGrouping(int);
			mapping := self.allGroupingMappings [grpNo].CM_XTABMapping;
			
			if mapping &lt;&gt; null and mapping.includeAllMappingValues then
				if mapping.otherValues = CM_XTABMapping.OTHER_GROUPED then
					// use 'other values' if we can
					if mapping.order = CM_XTABMapping.ORDER_MAPPING then
						value := self.Mapping_OtherValue;	// internal key value for other values
					else
						value := mapping.otherHeading;		// actual value
					endif;
				else
					// just use first mapping value - we know it will have to be included
					value := mapping.allMappingLines.first.getMappingLineValue;
				endif;
			else
				// the default value will be self.Empty_Property_KeyValue
				value := self.Empty_Property_Key_Value;
			endif;
		endif;
		
		if int &lt;= _numTabs then
			// tabl grouping
			_defValues[int] := value;
		else
			// row or column grouping (_defValues does not include level key)
			_defValues [int-1] := value;
		endif;
	endforeach; 
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_defValues" type="StringArray"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_numKeys" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMissingMappingValues" id="148fe482-281f-4e8a-9e27-eda06fd78c9a">
        <source> addMissingMappingValues() protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
//				Add entries for mapping values for which there is no real data
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numTabs, numRows, numCols, 
	numKeys, rowLevel, colLevel,	
	int, size, 	keyNo, level, 
	grpNo 						:Integer;
	keyValues, lastKeyValues,
	mapValues, missingMapValues, 
	defValues					:StringArray;
	array						:ObjectArray;
	mapping						:CM_XTABMapping;
	iter						:Iterator;
	grouping					:CMIF_OutputGrouping;
	first						:Boolean;
	thisValue, lastValue		:String;
begin
	numTabs		:= self.myOutputFormat_XTAB.allTabs.size;
	numRows		:= self.myOutputFormat_XTAB.allRows.size;
	numCols		:= self.myOutputFormat_XTAB.allColumns.size;
	numKeys 	:= self.getNumberOfKeys_XTAB (numTabs, numRows, numCols);
	rowLevel	:= self.getDetailRowLevel (numRows);	// CMIF_OutputGrouping::rowSummaryLevel for detail entry
	colLevel	:= self.getDetailColLevel (numCols);	// CMIF_OutputGrouping::colSummaryLevel for detail entry	
	array		:= self.allGroupingMappings;
	size		:= array.size;
	iter		:= self.allXTABData.createIterator;
	first		:= true;

	create keyValues transient;
	create lastKeyValues transient;
	create mapValues transient;
	create missingMapValues transient;
	create defValues transient;
	
	// build up array of default values to use for lower level keys
	// we do this once then use it if we have to add a grouping for a mapping value
	self.addMissingMapValues_getDefault (defValues, numTabs, numRows, numCols, numKeys);

	// starting with highest level key check that any grouping with mappings has all
	// mapping values included - if we need to create a new grouping it will use defValues for the lower order keys
	foreach int in 1 to numKeys do
		if int = numTabs + 1 then
			continue;	// not a grouping value (level key)
		endif;
		
		keyNo	:= 0;										// key # in XTAB dictiomary
		grpNo	:= self.keyXTAB_to_indexGrouping(int);		// tab/row/col # - does not include dummy row/col entries					
		
		if grpNo &lt;= 0 then
			continue;	// not a real grouping - may be dummy row/column or level key
		endif;
		// does this tab/row/col have a mapping
		mapping := array[grpNo].CM_XTABMapping;	
		
		if mapping = null or not mapping.includeAllMappingValues then
			// not a mapping that includes all values
			continue;
		endif;
		// get all mapping line values we may need to include for this mapping
		mapping.getAllMappingLineValues (mapValues);
		// copy to a temporary collection we will use to keep track of any missing mapping values
		missingMapValues.clear;
		mapValues.copy(missingMapValues);
		// reset the key number we are looking for		
		keyNo := int;
		first := true;
		// start at beginning of our xtab data and clear out local collections 
		iter.reset;
		keyValues.clear;
		lastKeyValues.clear;
		while iter.next (grouping) do
			// once we have read through main report skip past the row summaries
			// they will be updated if we add groupings
			if grouping.summaryLevel &gt; 0 then
				break;
			endif;
			// we can skip over tab/row/column subTotals/grand totals
			// we only need to add detail values - any sub-totals/summaries will be taken care of
			// when we add the detail grouping to the collection
			if grouping.tabSummaryLevel = 0 or			// grand total
				grouping.rowSummaryLevel &lt; numRows or	// sub-total or grand total
				grouping.colSummaryLevel &lt; numCols then	// sub-total or grand total
				continue;
			endif;
			// get all key values for this entry in our XTAB collection - does not include level key
			self.getAllKeyValues_XTAB (keyValues, iter, numTabs, numCols, numRows, numKeys, true);
			// if any of the higher level grouping values have changed we need to create entries
			// for any missing values at keyNo level
			if not first then
				level := self.getChangedGroupingLevel (keyValues, lastKeyValues);
				
				if level &gt; 0 and		// a value has changed
					level &lt; keyNo then	// higher level key has changed
					// higher level grouping value has changed - we need to create all missing mapping lines
					// we use the last full set of key values to do this.
					if missingMapValues.size &gt; 0 then
						// not all mapping values have been used
						self.addMissingMappingValuesForGrp (keyNo, numTabs, numCols, numKeys, rowLevel, colLevel, lastKeyValues, missingMapValues, defValues);
						// re-populate the collection of expected mapping values
						missingMapValues.clear;
					endif;
					mapValues.copy(missingMapValues);	// for next iteration
				endif;
			endif;
			// get value for our mapped property for this key entry 
			thisValue := keyValues [keyNo];
			// remove thisValue from list of mapping lines that need to be added
			if missingMapValues.includes (thisValue) then
				missingMapValues.remove (thisValue);
			endif;
			// save previous values for next time.
			self.saveLastValues (lastKeyValues, keyValues);
			
			lastValue		:= thisValue;
			first 			:= false;
		endwhile;
		// add in missing mapping line values 
		if keyNo &gt; 0 and missingMapValues.size &gt; 0
		and ( not self.allColPropertyNames.isEmpty or not self.allTabPropertyNames.isEmpty )	//11 Apr 2018 NDL TFS 37902
		then
			// there is something to add - copy all higher level key values
			self.addMissingMappingValuesForGrp (keyNo, numTabs, numCols, numKeys, rowLevel, colLevel, lastKeyValues, missingMapValues, defValues);
		endif;
	endforeach;
epilog
	delete iter;
	delete keyValues;
	delete lastKeyValues;
	delete mapValues;
	delete missingMapValues;
	delete defValues;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addMissingMappingValuesForGrp" id="71fa30a9-8141-4eda-8a83-eb6247d96bab">
        <source>addMissingMappingValuesForGrp(_keyNo, _numTabs, _numCols, _numKeys, _rowLevel, _colLevel :Integer; 
							_lastKeyValues, _missingMapValues, _defValues :StringArray) protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  _keyNo		- the key # for which we are adding missing mapping values
//				_numTabs, _numCols, _numKeys
//				_rowLevel	- value of rowSummaryLevel for row detail
//				_colLevel	- value of colSummaryLevel for column detail
//				_lastKeyValues
//				_missingMapValues
//				_defvalues
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	grpValues, hdgValues, fieldValues		:StringArray;
	int, grpIndex, firstColKey, hdgIndex	:Integer;
	str	, value								:String;
	iter									:Iterator;
	grouping								:CMIF_OutputGrouping;
begin
	// get our first set of column headings so we can us these as key values 
	// for HIGHER order keys
	iter := self.allXTABData_ColumnHeadings.createIterator;
	
	iter.next (grouping);
	
	create hdgValues transient;
	
	foreach int in 1 to _numTabs + _numCols do
		if int &lt;= _numTabs then
			hdgValues [int] := iter.getCurrentKey (int).String;
		else
			hdgValues [int + _rowLevel] := iter.getCurrentKey (int).String;
		endif;
	endforeach;
	
	// build up an array of values to use for grouping keys
	create grpValues transient;
	// first get higher level keys - these are the last set of values we had for those keys
	foreach int in 1 to _keyNo-1 do
		if int = _numTabs + 1 then
			continue;	// don't include level key
		endif;
		if _lastKeyValues.size &gt;= int then		// cnwcs5 17/12/2009
			grpValues.add(_lastKeyValues[int]);
		else									// cnwcs5 17/12/2009
			grpValues.add(null);	// cnwcs5 17/12/2009
		endif;									// cnwcs5 17/12/2009
	endforeach;

	if grpValues.size &lt; _numKeys-1 then
		// now work out values for subordinate key values
		foreach int in grpValues.size+1 to _numKeys-1 do :outerLoop
			value := _defValues[int];
			
			if value = self.Dummy_Detail_Value then
				grpValues[int] 	:= value;	
				continue;
			endif;
			
			if value &lt;&gt; self.Empty_Property_Key_Value then
				// we have a real mapping value to use - we know they get included anyway
				grpValues[int] 	:= value;	
				continue;
			endif;
			// if we are adding a mapping value for a row then we can use any value for the columns
			// so just use the first column values for the current tab.
			if int &gt;= (_numKeys-1 - _numCols) then	
				// looking for a value for a column heading
				if _numTabs = 0 then
					// simply take the corresponding value for the 1st column heading
					value := hdgValues [int];
				
					grpValues[int] := value;
					continue;
				else
					// position ourselves in the column headings collection for the current tab
					// if there is no entry for the current tab then we have no data so no headings
					grouping := self.allXTABData_ColumnHeadings.startKeyGTR_Headings (0, _lastKeyValues, iter);
					
					foreach hdgIndex in 1 to _numTabs + _numCols do
						if int &lt;= _numTabs then
							hdgValues [hdgIndex] := iter.getCurrentKey (hdgIndex).String;
							
							if hdgValues[hdgIndex] &lt;&gt; _lastKeyValues [hdgIndex] then
								// no match on tab values
								grpValues[int] := value;
								continue outerLoop;
							endif;
						else
							hdgValues [hdgIndex + _rowLevel] := iter.getCurrentKey (hdgIndex).String;
						endif;
					endforeach;
					value := hdgValues [int] ;
				endif;
			endif;
			
			// if we get to here we have to use an empty value
			grpValues[int] := value;
		endforeach;
	endif;

	create fieldValues transient;
	
	foreach str in _missingMapValues do
		if _keyNo &lt;= _numTabs then
			grpValues [_keyNo] := str; 
		else
			grpValues[_keyNo-1] := str;
		endif;
		
		self.updateXTABEntry (0, grpValues, fieldValues, _rowLevel, _colLevel, null);
	endforeach;
epilog
	delete grpValues;
	delete iter;
	delete hdgValues;
	delete fieldValues;
end;</source>
        <access>protected</access>
        <Parameter name="_keyNo" type="Integer"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_numKeys" type="Integer"/>
        <Parameter name="_rowLevel" type="Integer"/>
        <Parameter name="_colLevel" type="Integer"/>
        <Parameter name="_lastKeyValues" type="StringArray"/>
        <Parameter name="_missingMapValues" type="StringArray"/>
        <Parameter name="_defValues" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="checkSummaryLevel" id="93171ca5-073c-47bf-b5db-8c7fdb013e6a">
        <source>checkSummaryLevel(_table :Table input; _level, _numTabs :Integer io; _iter :Iterator)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	level	:Integer;
begin
	level := _iter.getCurrentKey(_numTabs + 1).Integer;
	
	if level &lt;&gt; _level then
		// change of summary level so insert a blank row and then
		// a row for the heading
		_table.rows := _table.rows + 2;
		_table.accessCell (_table.rows, 1).text := self.myOutputFormat_XTAB.allRows[level].getSummaryHeading;
		_table.accessedCell.mergeCells := Table.MergeCells_Merge;
		_level		:= level;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_level" type="Integer" usage="io"/>
        <Parameter name="_numTabs" type="Integer" usage="io"/>
        <Parameter name="_iter" type="Iterator"/>
    </JadeMethod>
    <JadeMethod name="clearColumnValues" id="f63dea41-d5cf-4226-ae82-91c68c1bbc8b">
        <source>clearColumnValues(_values :StringArray input; _level, _numTabs, _numRows, _numCols :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, intStart, intEnd, col,
	cols, rows		:Integer;
begin
	rows := _numRows;
	
	if rows = 0 then 
		rows := 1;		// dummy entry
	endif;
	
	cols := _numCols;
	
	if cols = 0 then
		cols := 1;		// dumy entry
	endif;
	
	intStart	:= _numTabs + rows + _level + 1;
	intEnd		:= _numTabs + rows + cols;
	
	foreach int in intStart to intEnd do	
		col := int - _numTabs - rows;
		
		if _level = self.Level_Grand_Total then 					
			_values[int] := self.Total_Heading_Acsending;	
		elseif _numCols &gt; 0 and self.isColumnDescending (col) then
			_values[int] := self.Total_Heading_Descending;
		else
			_values[int] := self.Total_Heading_Acsending;	
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_values" type="StringArray" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearRowValues" id="67d6cf48-dac1-4ec8-b441-d85edd778beb">
        <source>clearRowValues(_values :StringArray; _level, _numTabs, _numRows, _numCols :Integer);
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, intStart, intEnd	:Integer;
begin
	intStart	:= _numTabs + _level + 1;
	
	if _numRows = 0 then
		intEnd	:= _numTabs + 1;	// dummy row grouping
	else
		intEnd	:= _numTabs + _numRows;
	endif;
	
	foreach int in intStart to intEnd do
		if _level = self.Level_Grand_Total then								// grand total row - set all _values
			_values[int] := self.Total_Heading_Acsending;
		elseif _numRows &gt; 0 and self.isRowDescending (int - _numTabs) then
			_values[int] := self.Total_Heading_Descending;
		else
			_values[int] := self.Total_Heading_Acsending;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearTabValues" id="b7310fca-4054-4f8f-bfec-4b1e8f3b1dd9">
        <source>clearTabValues(_values :StringArray; _numTabs :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     12 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int	:Integer;
begin
	// clear all tab values 
	foreach int in 1 to _numTabs do
		_values [int] := self.Total_Heading_Acsending;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_numTabs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="0f6240b2-cfab-4730-a878-6ecce22f5b40">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.hideRepeatedRowValues	:= true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createXMLInfoForXTABEntry" id="37dc624d-b298-4c8e-a7fe-029b8f76fcc2">
        <source>createXMLInfoForXTABEntry(_values :StringArray; _format :CM_OutputFormat_XTAB):String protected;
// ---------------------------------------------------------------------------
// Created:     16 February 2010 by cnwcs5
// Purpose:     CCMS 1028 - Store property name/value combinations
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, size	:Integer;
	property	:Object;
	value, xml, allString	:String;
begin
	size 		:= _values.size;
	allString	:= app.getErrorString (CM_LIT_ALL);
	xml			:= global.formatAsXMLPrefix (self.XML_Values_Tag);
	
	foreach property in self.allTabQueryProperties do
		int 	:= int + 1;
		value	:=  _values[int];
		
		xml := xml &amp; self.formatXMLForGrouping (value, allString, property.CM_QueryProperty);
	endforeach;
	
	foreach property in self.allRowQueryProperties do
		int 	:= int + 1;
		value 	:= _values[int];
		
		xml := xml &amp; self.formatXMLForGrouping (value, allString, property.CM_QueryProperty);
	endforeach;
	
	foreach property in self.allColQueryProperties do
		int 	:= int + 1;
		value 	:= _values[int];
		
		while value = self.Dummy_Detail_Value and int &lt; size do
			// we had no rows and have picked up the dummy row value
			// we know its a dummy row and not dummy column as we wouldn't be in this 
			// loop otherwise
			int := int + 1;
			value := _values [int];
		endwhile;
		
		xml := xml &amp; self.formatXMLForGrouping (value, allString, property.CM_QueryProperty);
	endforeach;
		
	xml := xml &amp; global.formatAsXMLSuffix (self.XML_Values_Tag); 
	return xml;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createXTABData" id="9ab745f3-fad2-48e3-ad75-f01a7e9d3191">
        <source>createXTABData(_coll : Collection; _cmifMonitor : CMIF_Monitor input; _nextMonitorUpdateTime : Integer io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  
// Returns:     false if the user has pressed cancel
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/12/2009	cnwcs5	ccms 1023 - use seperate collections for grouping values and 
//						field values.  For snapshots out field values will be actual objects
// ---------------------------------------------------------------------------
vars
	int				: Integer;
	numRows			: Integer;
	numCols			: Integer;
	numTabs, numKeys	: Integer;
	rowLevel		: Integer;
	colLevel		: Integer;
	invalidObject	: Boolean;
	obj				: Object;
	format			: CM_OutputFormat_XTAB;
	any				: Any;
	grpValues		: StringArray;
	fieldValues		: Array;
	summaryValues	: StringArray;
	rtnValue		: Boolean;
	
begin
	rtnValue 	:= true;
	format 		:= self.myOutputFormat_XTAB;
	numTabs		:= format.allTabs.size;
	numRows		:= format.allRows.size;
	numCols		:= format.allColumns.size;
	numKeys		:= self.getNumberOfKeys_XTAB (numTabs, numRows, numCols);
	rowLevel	:= self.getDetailRowLevel (numRows);	// cnwcs5 08/12/2009
	colLevel	:= self.getDetailColLevel (numCols);	// cnwcs5 08/12/2009
	
	// now go through all the objects and update our collections
	create grpValues transient;
	if format.isSnapshotMode then
		create fieldValues as ObjectArray transient;
	else
		create fieldValues as StringArray transient;
	endif;
	
	create summaryValues transient;
	
	on Exception do app.handleDeletedObject (exception, obj, invalidObject);
	
	foreach any in _coll do
		if (not self.updateProgress(_cmifMonitor, _nextMonitorUpdateTime)) then
			rtnValue := false;
			break;
		endif;
		// the next line will not cause an exception if any contains an invalid object reference
		obj := any.Object;	
		// reset parameter that gets passed to the exception handler
		invalidObject := false;
		
		// build up array of key/field values
		self.getValuesForObject( obj, grpValues, fieldValues );
		
		if invalidObject then
			// we must have had an exception - just skip over those objects that have been deleted
			continue;
		endif;
		
		// update xtab values for this entry
		self.updateXTABEntry( 0, grpValues, fieldValues, rowLevel, colLevel, obj);
		
		// now create summary data for any rows that are being summarised 
		foreach int in self.allSummarisedRows do
			self.getValuesForSummary( int, grpValues, summaryValues );
			
			self.updateXTABEntry( int, summaryValues, fieldValues, rowLevel, colLevel, obj);
		endforeach;
	endforeach;
	
	return rtnValue;
	
epilog
	delete grpValues;
	delete fieldValues;
	delete summaryValues;
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_nextMonitorUpdateTime" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createXTABEntry" id="90e5ee34-f941-4458-8573-95db6a65123c">
        <source>createXTABEntry(
	_summaryLevel	: Integer;
	_values			: StringArray;
	_rowLevel		: Integer;
	_colLevel		: Integer;
	_tabLevel		: Integer ) : CMIF_OutputGrouping protected;
	
// ---------------------------------------------------------------------------
// Created:     24 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Create a new dynamic object and add to relevant collections
// Parameters:  _values	- values to be used as dictionary keys
//				_rowLevel
//				_colLevel
//				_tablevel - 0 = normal tab, 1 = summary tab
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/02/2010 	cnwcs5 		ccms 1028 - store property name/value combinations
// ---------------------------------------------------------------------------

constants
	ERROR_TEXT	=	CrLf &amp; 'Your summary could not be completed as an item in the summary has at least one value ' &amp;
					'that is longer than expected.' &amp; CrLf &amp; CrLf &amp; 'The values are: ' &amp; CrLf &amp; CrLf;
	
vars
	grouping		: CMIF_OutputGrouping;
	groupingCol		: CMIF_OutputGrouping;
	error1035		: Boolean;
	xmlInfo			: String;	// 16/02/2010 cnwcs5 ccms 1028
begin
	xmlInfo := self.createXMLInfoForXTABEntry (_values, self.myOutputFormat_XTAB);	// 16/02/2010 cnwcs5 ccms 1028 - store property name/value combinations
	
	create grouping transient;
	
	// If get an UE 1300 here then it is almost certainly because self.allFieldHeadings.size &lt;&gt; self.myOutputFormat_XTAB.allFields.size
	grouping.createSelf(	self.myOutputFormat_XTAB,
							xmlInfo,	// 16/02/2010 cnwcs5 ccms 1028 - store property name/value combinations
							self.allFieldHeadings,
							_rowLevel,
							_colLevel,
							_tabLevel,
							_summaryLevel );
	
	//	add to collection
	on Exception do self.handleException1035( exception, error1035 );

	self.allXTABData.addEntry_XTAB( _values, grouping );
	
	if error1035 then
		// we hope this never happens !!!
		// it means we don't have the correct key lengths set up 
		// see CM_QueryProperty.getKeyLengthForXTABDictionary
		delete grouping;
		app.raiseUnexpectedProgramError(	self.class.name,
											method.name,
											ERROR_TEXT &amp; _values.concatenate( ',' ) );
	endif;
	
	// now look for matching entry in collection for column headings
	if _summaryLevel = 0 and
	   ( not self.myOutputFormat_XTAB.allColumns.isEmpty or not self.myOutputFormat_XTAB.allTabs.isEmpty ) then
		groupingCol := self.allXTABData_ColumnHeadings.getEntry_Headings (_values);
		// if not there, add dynamic object we have just created into 
		// the column headings collection (1 object in 2 collections)
		if groupingCol = null then
			error1035 := false;	// 16/02/2010 cnwcs5
			
			self.allXTABData_ColumnHeadings.addEntry_Headings (_values, grouping);
			
			if error1035 then
				// we hope this never happens !!!
				delete grouping;
				app.raiseUnexpectedProgramError(	self.class.name,
													method.name,
													ERROR_TEXT &amp; _values.concatenate( ',' ) );
			endif;
		endif;
	endif;
	
	return grouping;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_summaryLevel" type="Integer"/>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_rowLevel" type="Integer"/>
        <Parameter name="_colLevel" type="Integer"/>
        <Parameter name="_tabLevel" type="Integer"/>
        <ReturnType type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="delete" id="dff82130-c947-4a8b-b199-05d32631556f">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allXTABData.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayColHeadingsForRows" id="e1ad3551-e726-4319-9f62-312e6ec1796f">
        <source>displayColHeadingsForRows(_table :Table input) protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, size 	:Integer;
	format		:CM_OutputFormat_XTAB;
begin
	format	:= self.myOutputFormat_XTAB;
	size 	:= format.allRows.size;
	
	foreach int in 1 to size do
		_table.setCellText (_table.rows, int, format.allRows[int].CM_XTABGrouping.getHeading);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayColumnHeadings" id="87d5de52-39c7-418f-a116-a21cbc636622">
        <source>displayColumnHeadings(
	_table		: Table input;
	_lastArray	: StringArray;
	_array		: StringArray;
	_numCols	: Integer;
	_grouping	: CMIF_OutputGrouping ) : Boolean protected;
	
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// 01/12/2009	cnwcs5		ccms 1028 - change to mappings - display in mapping order
// 15/02/2010	cnwcs5		ccms 1925 / par 22295 Release Summaries
// ---------------------------------------------------------------------------
vars
	int			: Integer;
	level		: Integer;
	value		: String;
	error14048	: Boolean;
	
begin
	on Exception do self.handleException14048( exception, error14048 );
	
	level := self.getChangedColumnLevel (_lastArray, _array, _numCols);
	
	// add column for new headings
	_table.columns := _table.columns + 1;
	if error14048 then
		// if attempt to create too many columns then the exception handle will fire.
		app.msgBox(	app.getErrorString( Warn_Summary_Too_Many_Columns ),
					app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return false;
	endif;
	_table.accessColumn (_table.columns).alignment := Table.Alignment_Center;
	
	// now display changed keys
	foreach int in level to _numCols do
		_table.accessCell (int, _table.columns);
		_table.accessedCell.mergeCells	:= Table.MergeCells_Merge;
		_table.accessedCell.alignment	:= Table.Alignment_Center;
		
		value := _array[int];
		
		if value = self.Total_Heading_Acsending or
			value = self.Total_Heading_Descending then	
			// this column is a sub-total/total
			if int = _grouping.colSummaryLevel + 1 then
				// only display heading for higest level sub-total/total
				value := self.getTotalColumnHeading (int-1);
			endif;
		elseif value.startsWith (self.True_Property_Key_Value) or
			value.startsWith (self.False_Property_Key_Value) then
			value := self.getDisplayBooleanFromKey_Long (value);	// 22/02/2010 cnwcs5
		else
			value := self.keyValue_to_DisplayValue (value);	// 18/02/2010 cnwcs5 - refactored code
		endif;
		
		if value = self.Total_Heading_Descending or
			value = self.Total_Heading_Acsending then
			// we have displayed higer level total
			_table.accessedCell.mergeCells := Table.MergeCells_NotAvailable;
		elseif value = self.Empty_Property_Key_Value then
			// make sure a cell with a blank property value does not get merged into
			_table.accessedCell.mergeCells := Table.MergeCells_NotAvailable;
		else
			_table.accessedCell.text := value;
		endif;
	endforeach;
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_lastArray" type="StringArray"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayFieldHeadings" id="5f36ecb6-28af-4c2c-bd08-63ce59b125e8">
        <source>displayFieldHeadings(
	_table		: Table input;
	_grouping	: CMIF_OutputGrouping ) : Boolean protected;

// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------

vars
	int			: Integer;
	obj			: Object;
	error14048	: Boolean;
	
begin
	on Exception do self.handleException14048( exception, error14048 );
	
	foreach obj in _grouping.allChildren do
		int := int + 1;
		
		if int &gt; 1 then
			// add column for our field
			_table.columns := _table.columns + 1;
			if error14048 then
				// if attempt to create too many columns then the exception handle will fire.
				app.msgBox(	app.getErrorString( Warn_Summary_Too_Many_Columns ),
							app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
				return false;
			endif;
			_table.accessColumn (_table.columns).alignment := Table.Alignment_Center;
		endif;
		
		_table.accessCell (_table.rows, _table.columns);
		
		_table.accessedCell.text 		:= obj.CMIF_OutputField.heading;
		_table.accessedCell.alignment	:= Table.Alignment_Center;
	endforeach;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayFieldHeadings_NoCols" id="ff197574-ac3f-4b3b-ab2c-0a0f0694ad69">
        <source>displayFieldHeadings_NoCols( _table : Table input ) : Boolean protected;

// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------

vars
	field		: CM_XTABField;
	first		: Boolean;
	error14048	: Boolean;
	
begin
	on Exception do self.handleException14048( exception, error14048 );
	
	foreach field in self.myOutputFormat_XTAB.allFields do
		// when there are no columns defined for the x-tab we effectively display one detail
		// column per field.  If the field is setup to not display the detail then 
		// don't include it
		if field.hideDetail then
			continue;
		endif;
		_table.columns := _table.columns + 1;
		if error14048 then
			// if attempt to create too many columns then the exception handle will fire.
			app.msgBox(	app.getErrorString( Warn_Summary_Too_Many_Columns ),
						app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			return false;
		endif;
		_table.accessColumn (_table.columns).alignment := Table.Alignment_Center;
		
		_table.accessCell (_table.rows, _table.columns);
		_table.accessedCell.text 		:= field.getHeading;
		_table.accessedCell.alignment	:= Table.Alignment_Center;
	endforeach;
	
	if not self.myOutputFormat_XTAB.displayTotalColumn then
		return true;
	endif;
	
	first := true;
	
	foreach field in self.myOutputFormat_XTAB.allFields do
		// when there are no columns defined for the x-tab we effectively display one detail
		// column per field.  If the field is setup to not display the detail then 
		// don't include it
		if field.hideGrandTotals then
			continue;
		endif;
		
		_table.columns := _table.columns + 1;
		if error14048 then
			// if attempt to create too many columns then the exception handle will fire.
			app.msgBox(	app.getErrorString( Warn_Summary_Too_Many_Columns ),
						app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			return false;
		endif;
		_table.accessColumn (_table.columns).alignment := Table.Alignment_Center;
		
		if first then
			// display grand total heading
			_table.addItemAt (null, 1);
			_table.accessCell (1, _table.columns).text := self.getTotalColumnHeading (0);
			_table.accessedCell.mergeCells := Table.MergeCells_Merge;
			first := false;
		endif;		
		// display field headings
		_table.accessCell (_table.rows, _table.columns);
		_table.accessedCell.text 		:= field.getHeading;
		_table.accessedCell.alignment	:= Table.Alignment_Center;
	endforeach;
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayFieldValues" id="09fbad3a-04f7-48e6-9103-5be05bbe6e1a">
        <source>displayFieldValues(
	_table		: Table input;
	_array		: StringArray;
	_grouping	: CMIF_OutputGrouping;
	_numRows	: Integer;
	_numCols	: Integer;
	_col		: Integer io ) : Boolean protected;
	
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int			: Integer;
	size		: Integer;
	field		: CMIF_OutputField;
	error14050	: Boolean;
	
begin
	on Exception do self.handleException14050( exception, error14050 );
	
	// find the matching column headings	
	if _numCols &gt; 0 then
		self.findMatchingColumnHeadings( _table, _array, _grouping, _numRows, _numCols, _col );
	endif;
	
	// display values
	size	:= _grouping.allChildren.size;
	foreach int in 1 to size do
		field	:= _grouping.allChildren[ int ].CMIF_OutputField;
		_table.accessCell( _table.rows, _col );
		
		if error14050 then
			// Attempt to access an invalid column for this table.
			// A possible reason for this is have no column field and "Hide Details and Hide Grand Total" checked.
			app.msgBox(	app.getErrorString( Warn_Summary_Invalid_Column ),
						app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			return false;
		endif;
		
		_table.accessedCell.text		:= field.getValue;
		_table.accessedCell.itemObject	:= field;
		_col							:= _col + 1;	// next available column
	endforeach;
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_col" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayRowHeadings" id="2759dedd-d6aa-44af-b430-151276f45e80">
        <source>displayRowHeadings(_table :Table input; _array :StringArray; _grouping :CMIF_OutputGrouping; _level, _numRows :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/02/2010	cnwcs5		ccms 1925 / par 22295 Release Summaries
// 26/07/2010	cnwcs5		ccms 1156 / par 23706 Allow for hide/show repeated row values
// ---------------------------------------------------------------------------
vars
	int, start	:Integer;						// par 23706 cnwcs5 26/07/2010
	value		:String;	
begin
	_table.rows := _table.rows + 1;
	
	if self.hideRepeatedRowValues then				// par 23706 cnwcs5 26/07/2010
		// display row headings from changed row onwards
		start := _level;						// par 23706 cnwcs5 26/07/2010
	else										// par 23706 cnwcs5 26/07/2010
		// display all row heading values
		start := 1;								// par 23706 cnwcs5 26/07/2010
	endif;										// par 23706 cnwcs5 26/07/2010
	
	// now display changed row headings
	foreach int in start to _numRows do			// par 23706 cnwcs5 26/07/2010
		if int &lt; _grouping.summaryLevel then
			continue;
		endif;
		
		_table.accessCell (_table.rows, int);
		
		value := _array[int];
		
		if value = self.Total_Heading_Acsending or
			value = self.Total_Heading_Descending then	
			// it is a sub-total or total row
			if int = _grouping.rowSummaryLevel + 1 then
				value := self.getTotalRowHeading (_grouping.rowSummaryLevel);
				
				_table.accessedCell.text := value;
				break;	// only display highest level total
			endif;			
		elseif value = self.Empty_Property_Key_Value and
			_grouping.summaryLevel &lt;&gt; 0 then
			value := null;
		else
			value := self.keyValue_to_DisplayValue (value);		// 18/02/2010 - refactored code
		endif;
		_table.accessedCell.text := value;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayTabHeadings" id="aee50911-6a2b-46d4-9cdd-d3ab3c8e44a2">
        <source>displayTabHeadings(_table :Table input; _array :StringArray;_grouping :CMIF_OutputGrouping)protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/02/2010	cnwcs5		ccms 1925 / par 22295 Release Summaries
// ---------------------------------------------------------------------------
vars
	heading	:String;
	array	:StringArray;	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	str		:String;		// 15/02/2010 cnwcs5 ccms 1925 / par 22295
begin 
	if _grouping.tabSummaryLevel = self.Level_Grand_Total then
		heading := self.myOutputFormat_XTAB.allTabs.first.getSummaryHeading;
		
		if heading = null then
			heading := self.Default_Total_Heading;
		endif;
	else
		// array contains the key values - convert to mapped value if necessary
		// we will need to if tab value is mapped and order is mapped order
		// check to see if any key values are date keys and convert them
		create array transient;								// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		foreach str in _array do							// 15/02/2010 cnwcs5 ccms 1925 / par 22295
			if str.startsWith (self.True_Property_Key_Value) or str.startsWith (self.False_Property_Key_Value) then
				str := self.getDisplayBooleanFromKey_Long (str);	// 22/02/2010 cnwcs5
			else
				str := self.keyValue_to_DisplayValue (str);		// 18/02/2010 cnwcs5 - refactored code
			endif;
			array.add (str);								// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		endforeach;											// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		heading := array.concatenate ('/');					// 15/02/2010 cnwcs5 ccms 1925 / par 22295		
	endif;
	
	_table.sheetCaption := heading;
epilog
	delete array;	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="displayXTAB" id="8905aeae-d6b7-458e-a5f6-cd45734f3f45">
        <source>displayXTAB(_table : Table input; _cmifMonitor : CMIF_Monitor input; _nextMonitorUpdateTime : Integer io) : Boolean protected;

// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  
//				
// Returns:     false - if user has clicked cancel button on the progress form
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/01/2009	cnwrl1		Added error checking for UE 14045 (CCMS SFW 1047 - Totals Only Lists)
// 03/12/2009	cnwcs5		ccms 1028 - allow for mappings in order of mapping lines
// 21/10/2010	cnwcs5		par 25616 - fix exception due to not initialising column heading collection after change of tab
// ---------------------------------------------------------------------------

vars
	format				: CM_OutputFormat_XTAB;
	iter				: Iterator;
	first				: Boolean;
	grouping			: CMIF_OutputGrouping;
	grpKeyValues, lastGrpKeyValues,
	grpHdgValues, lastGrpHdgValues	: StringArray;
	tabKeyValues, lastTabKeyValues	: StringArray;
	tabHeadingValues	: StringArray;
	level				: Integer;
	numTabs				: Integer;
	numRows				: Integer;
	numCols				: Integer;
	error14045			: Boolean;
	
begin
	on Exception do self.handleException14045( exception, error14045 );
	
	format				:= self.myOutputFormat_XTAB;
	numTabs				:= format.allTabs.size;
	numRows				:= format.allRows.size;
	numCols				:= format.allColumns.size;
	
	if numTabs = 0 and numCols = 0 then
		_table.rows 		:= 1;	// one for field headings
		_table.fixedRows	:= 1;
		_table.columns		:= numRows;
		_table.fixedColumns	:= numRows;
		_table.fixed3D		:= false;

		self.displayColHeadingsForRows (_table);
		if not self.displayFieldHeadings_NoCols( _table ) then
			return true;
		endif;
		return self.displayXTABData( _table, null, _cmifMonitor, _nextMonitorUpdateTime );
	endif;
	
	// create collections we need to keep a track of changes to grouping (key) values.
	create grpKeyValues transient;
	create lastGrpKeyValues transient;
	create grpHdgValues transient;
	create lastGrpHdgValues transient;
	create tabKeyValues transient;
	create lastTabKeyValues transient;
	create tabHeadingValues transient;	// cnwcs5 02/12/09
	
	if not self.updateProgress( _cmifMonitor, _nextMonitorUpdateTime ) then
		return false;
	endif;
	
	iter 	:= self.allXTABData_ColumnHeadings.createIterator;
	first 	:= true;
	
	// we are iterating through the headings collection displaying headings for a single
	// tab value (sheet).  when the tab values change we displayed the data for the tab (sheet)
	while iter.next (grouping) do 
		
		if not self.updateProgress( _cmifMonitor, _nextMonitorUpdateTime ) then
			return false;
		endif;
		
		if grouping.allChildren.isEmpty then
			// there are no fields to be displayed so don't 
			// bother with column headings
			// can happen with hideDetail, hideSub-totals etc
			continue;
		endif;
		
		// get values for tab grouping properties - actual key values and associated
		// headings (which could be different)
		self.getTabValues_Headings (tabKeyValues, tabHeadingValues, numTabs, iter, true);
		
		if not first then
			// if tab values have changed then we need to display the XTAB values
			// for the previous tab groupings.  use key values to detect change
			level := self.getChangedTabLevel (lastTabKeyValues, tabKeyValues, numTabs);
			
			if level &gt; 0 then 
				// tab key values have changed
				if not self.displayXTABData( _table, lastTabKeyValues, _cmifMonitor, _nextMonitorUpdateTime ) then
					return false;
				endif;
			endif;
		endif;
		
		if first or 		// first time in
			level &gt; 0 then	// we have just displayed data for last set of tab values
			// create sheet for new set of tab values
			if first then
				_table.sheet	:= 1;
			else
				_table.sheets	:= _table.sheets + 1;
				if error14045 then
					// if attempt to create too many sheets then the exception handle will fire.
					app.msgBox(	app.getErrorString( Warn_Summary_Too_Many_Sheets ),
								app.getErrorString1( WARN_GENERIC, app.getErrorString( Failed_Produce_Full_Report ) ),
								MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
					return true;
				endif;
				_table.sheet	:= _table.sheets;
			endif;
			_table.rows			:= 0;			// in-case we had something displayed in table
			_table.rows 		:= numCols + 1;	// one for each column plus one for field headings
			_table.fixedRows	:= numCols + 1;
			_table.columns		:= numRows;
			_table.fixedColumns	:= numRows;
			_table.fixed3D		:= false;
			
			// display caption for sheet using heading values
			if format.hasTabs then
				self.displayTabHeadings (_table, tabHeadingValues, grouping);	// cnwcs5 02/12/09
			endif;
			
			// we need to display headings for the current row groupings
			self.displayColHeadingsForRows (_table);
			
			// if there are no column groupings defined then we just display groupings for our fields values 
			if numCols = 0 then
				self.displayFieldHeadings_NoCols (_table); 
			endif;
			
			// save new set of tab values for next time
			self.saveLastValues (lastTabKeyValues, tabKeyValues);		
			
			// clear out the saved column values as we want to display all column headings
			// on the new tab
			lastGrpKeyValues.clear;
			lastGrpHdgValues.clear;	// 21/10/2010 cnwcs5 par 25616
			
			first := false;
		endif;
		
		if numCols &gt; 0 then
			// copy all column headings to a string array so we can compare 
			// them with what we had last time
			self.getColumnHeadings_Headings (grpKeyValues, grpHdgValues, numTabs, numRows, numCols, iter, true);
			
			// now add a column(s) for our headings and disply changes headings
			if not self.displayColumnHeadings( _table, lastGrpHdgValues, grpHdgValues, numCols, grouping ) then
				return true;
			endif;
			
			// now display headings for our fields we may have to add extra columns for this
			if not self.displayFieldHeadings( _table, grouping ) then
				return true;
			endif;
		endif;
		
		// save off curent values so we can compare  next time round
		self.saveLastValues (lastGrpKeyValues, grpKeyValues);
		self.saveLastValues (lastGrpHdgValues, grpHdgValues);
	endwhile;
	
	// now display the XTAB data for the last set of tab groupings
	if not self.displayXTABData( _table, lastTabKeyValues, _cmifMonitor, _nextMonitorUpdateTime ) then
		return false;
	endif;
	
	// if the table has only one sheet then jade does not display the sheet caption
	if format.hasTabs and _table.sheets = 1 then
		// this is not ideal but better than not displaying the property value
		_table.sheets := 2;
	endif;
	
	return true;
	
epilog
	delete grpKeyValues;
	delete lastGrpKeyValues;
	delete grpHdgValues;
	delete lastGrpHdgValues;
	delete iter;
	delete tabKeyValues;		// 07/01/2009 cnwrl1 - delete transient
	delete lastTabKeyValues;	// 07/01/2009 cnwrl1 - delete transient
	delete tabHeadingValues;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_nextMonitorUpdateTime" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayXTABData" id="d718bf0e-9949-4b3f-9d5b-058bdc8d0bfb">
        <source>displayXTABData(
	_table					: Table input;
	_tabKeys				: StringArray input;
	_cmifMonitor			: CMIF_Monitor input;
	_nextMonitorUpdateTime	: Integer io ) : Boolean protected;

// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     false if user has pressed cancel
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/12/2009	cnwcs5		ccms 1028 - handle mapping line order
// ---------------------------------------------------------------------------

vars
	format				: CM_OutputFormat_XTAB;
	iter				: Iterator;
	first				: Boolean;
	headingValues		: StringArray;
	lastHeadingValues	: StringArray;
	grouping			: CMIF_OutputGrouping;
	int					: Integer;
	column				: Integer;
	level				: Integer;
	numTabs				: Integer;
	numRows				: Integer;
	numCols				: Integer;
	summLevel			: Integer;
	
begin 
	format		:= self.myOutputFormat_XTAB;
	numTabs		:= format.allTabs.size;
	numRows 	:= format.allRows.size;
	numCols		:= format.allColumns.size;
	
	create headingValues transient;
	create lastHeadingValues transient;
	
	iter := self.allXTABData.createIterator;
	
	if format.hasTabs then
		self.positionIterator( iter, _tabKeys, numTabs, numRows, numCols );
	endif;
	
	first := true;
	
	while iter.next( grouping ) do
	
		if not self.updateProgress( _cmifMonitor, _nextMonitorUpdateTime ) then
			return false;
		endif;

		if format.hasTabs then
			// if any of the tab grouping values have changed then that's it for us
			// this method just displays data for one TAB
			foreach int in 1 to numTabs do
				if _tabKeys[int] &lt;&gt; iter.getCurrentKey(int).String then
					return true;
				endif;
			endforeach;
		endif;
		
		// check for change of summary level
		self.checkSummaryLevel (_table, summLevel, numTabs, iter);
		
		if grouping.allChildren.isEmpty then
			continue;
		endif;
		
		// copy all row/column headings for this item to a string array so we can compare 
		// them with what we had last time
		self.getRowColumnHeadings_XTAB (headingValues, numTabs, numRows, numCols, iter, true); 
		
		// have any of the row heading values changed - if they have we will
		// need to add a new row.
		if first then
			level	:= 1;		// starting displaying row headings at column 1
			first	:= false;
		else
			level := self.getChangedRowLevel (lastHeadingValues, headingValues, numRows);
		endif;
		
		if level &gt; 0 then
			self.displayRowHeadings (_table, headingValues, grouping, level, numRows);			
			column := numRows + 1; // first column to have a column heading displayed in it
		endif;

		// column should have the column at which I can start adding my summary values
		if not self.displayFieldValues (_table, headingValues, grouping, numRows, numCols, column) then
			return false;
		endif;
		
		// save off curent values so we can compare  next time round
		self.saveLastValues (lastHeadingValues, headingValues);
	endwhile;
	
	return true;
	
epilog
	delete iter;
	delete headingValues;
	delete lastHeadingValues;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_tabKeys" type="StringArray" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_nextMonitorUpdateTime" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findMatchingColumnHeadings" id="14ebf7f8-618d-438f-828b-2c0e5d31169a">
        <source>findMatchingColumnHeadings(_table :Table input; _array :StringArray; _grouping :CMIF_OutputGrouping; _numRows, _numCols :Integer; _col :Integer io) protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _array	- all row, column, field values
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwcs5		ccms 1028 - changes to mappings
// 26/07/2010 	cnwcs5 		ccms 1156 / par 23706 - new date/time property
// ---------------------------------------------------------------------------
vars
	int, row, col,
	colFirst, colLast	:Integer;
	str					:String;
begin
	// now we need to output the summary _array - first find the matching column headings		
	row 		:= 0;
	col			:= _col;
	col 		:= _numRows + 1; // first column to have a column heading displayed in it
	
	if _numRows = 0 then
		colFirst := 2;	// dummy row and then first column
	else
		colFirst := _numRows + 1;
	endif;
	
	colLast		:= colFirst + _numCols - 1;
	
	// now we are going through the column heading _array and matching with headings already in the 
	// table to determine which column to start adding our summary value at
	foreach int in colFirst to colLast do :outerLoop
		row := row + 1;		// row we are searching in
		str := _array[int];	// key value we are searching for
		
		if str = self.Total_Heading_Acsending or
			str = self.Total_Heading_Descending then	
			str := self.getTotalColumnHeading(row - 1);
		elseif str = self.Empty_Property_Key_Value then
			str := self.Empty_Property_Text;
		elseif str.startsWith (self.Date_Key_Prefix) then		// 15/02/2010 cnwcs5 ccms 1925 / par 22295
			str := self.getDisplayDateFromKeyValue (str);		// 15/02/2010 cnwcs5 ccms 1925 / par 22295			
		elseif str.startsWith (self.DateTime_Key_Prefix) then	// 26/07/2010 cnwcs5 ccms 1156 / par 23706
			str := self.getDisplayDateTimeFromKeyValue (str);	// 26/07/2010 cnwcs5 ccms 1156 / par 23706
		elseif str.startsWith(self.True_Property_Key_Value) or			// 22/02/2010 cnwcs5
				str.startsWith (self.False_Property_Key_Value) then		// 22/02/2010 cnwcs5
			str := self.getDisplayBooleanFromKey_Long (str);			// 22/02/2010 cnwcs5
		endif;
		// find column with matching value
		foreach col in col to _table.columns do :innerLoop
			if _table.accessCell (row, col).text = str then
				if _grouping.colSummaryLevel + 1 = row then
					// no need to look for lower level match if we have a sub-total/grandTotal
					_col := col; 
					return;
				endif;
				// match at this level - go to next level column heading
				// if we are at lowest level column we will drop out of outerloop
				// and col will have a valid value
				continue outerLoop;	
			endif;
		endforeach; 
		// if i get to here i have not found a match (help!!! - i am a bad programmer)
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to find column for XTAB entry');
	endforeach;
	
	_col := col;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_grouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_col" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="formatValueOutPFormtAgentSSCSV" id="b384279b-3a49-4641-bf5b-8c1bf78933da">
        <source>formatValueOutPFormtAgentSSCSV(_value : String) : String;

/*

Purpose:		Format the value for the csv where required	

Date			Who		Reason
03/04/2012		cnwmh5	Initial creation

*/

vars

begin
	return self.keyValue_to_DisplayValue(_value);
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatXMLForGrouping" id="e056dfe5-53f9-4672-8071-405f1ffc9268">
        <source>formatXMLForGrouping(_value, _allString :String; _property :CM_QueryProperty):String protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/05/2010	cnwcs5		par 23818 - fix exception if property invalid
// ---------------------------------------------------------------------------
constants	
	
vars
	xml				:String;
	gotException	:Boolean;	// par 23818
begin
	on Exception do app.handleDeletedObject (exception, _property, gotException);	// par 23818
	
	xml := global.formatAsXMLPrefix (self.XML_Grouping_Tag);
	
	if _property &lt;&gt; null and _property.edition &gt;= 0 then	// par 23818
		xml := xml &amp; global.formatAsXML (self.XML_PropertyName_Tag, _property.niceName);
		xml := xml &amp; global.formatAsXML (self.XML_JadePropertyName_Tag, _property.propertyName);
	endif;	// par 23818
// par 23818 - start	
	if _property = null or gotException then
		xml := xml &amp; global.formatAsXML (self.XML_PropertyName_Tag, CMIF_OutputFormatAgent_XTAB.XML_Invalid_Property);
		xml := xml &amp; global.formatAsXML (self.XML_JadePropertyName_Tag, CMIF_OutputFormatAgent_XTAB.XML_Invalid_Property);
	endif;
// par 23818 - end	
	if _value = self.Total_Heading_Acsending or
		_value = self.Total_Heading_Descending then
		xml := xml &amp; global.formatAsXML (self.XML_PropertyValue_Tag, _allString);
	elseif _value.startsWith (self.True_Property_Key_Value) then
		xml := xml &amp; global.formatAsXML (self.XML_PropertyValue_Tag, true.String);
	elseif _value.startsWith (self.False_Property_Key_Value) then
		xml := xml &amp; global.formatAsXML (self.XML_PropertyValue_Tag, false.String);
	else
		xml := xml &amp; global.formatAsXML (self.XML_PropertyValue_Tag, self.keyValue_to_DisplayValue (_value));
	endif;
	
	xml := xml &amp; global.formatAsXMLSuffix (self.XML_Grouping_Tag);
	
	return xml;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <Parameter name="_allString" type="String"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateXTAB" id="127a2ac0-64f2-4fc9-8935-74a5b833e084">
        <updating/>
        <source>generateXTAB( _format : CM_OutputFormat_XTAB; _coll : Collection; _table : Table input;
		_cmifMonitor : CMIF_Monitor input) : Boolean updating;

// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     false if the user has pressed cancel
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/01/2009	cnwrl1		Handle UE causing errors (CCMS SFW 1047 - Totals Only Lists)
// 07/12/2009	cnwcs5		ccms 1028 - include all mapping values
// 15/02/2010	cnwcs5		ccms 1925 / par 22295 Release Summaries
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	bError		: Boolean;
	nextMonitorUpdateTime	: Integer;
	coll		: Collection;	// 15/02/2010 cnwcs5 Release Summaries
begin
//	process.profiler.reset;
//	process.profiler.start;

	if _cmifMonitor &lt;&gt; null then
	   	_cmifMonitor.partsDone := 0;
	   	_cmifMonitor.partsInJob := _coll.size * 2;		// need to adjust this for display but to what???

		nextMonitorUpdateTime := app.clock + 1000;		// do first update after 1 sec
	endif;

	
	beginLoad;
	bError	:= not self.setup( _format );
	endLoad;
	
	if bError then
		return true;
	endif;
	
	// if mode is for children of objects in collection then use collection of children
	// rather than the collection we were passed.
	coll := self.getCollectionForMode (_coll);	// 15/02/2010 cnwcs5 ccms 1925 / par 22295	
	
	// get all property values needed to build the XTAB
	if coll &lt;&gt; null then																// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		if (not self.createXTABData(coll, _cmifMonitor, nextMonitorUpdateTime)) then	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
			return false;																// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		endif;																			// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	else																				// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		if (not self.createXTABData(_coll, _cmifMonitor, nextMonitorUpdateTime)) then
			return false;
		endif;
	endif;																				// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	
	// add any missing mapping values
	self.addMissingMappingValues();
	
	// now format the XTAB
	return self.displayXTAB(_table, _cmifMonitor, nextMonitorUpdateTime);
	
//	process.profiler.stop;
//	process.profiler.fileName := 'xtab_profiler';
//	process.profiler.report ();
epilog
	endLoad;		// 08/04/2011 cnwmh5 #27347
	delete coll;	
end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="generateXTABForSS" id="bee93bde-3649-4002-9c3e-354e26303fe1">
        <updating/>
        <source>generateXTABForSS( _format : CM_OutputFormat_XTAB; _coll : Collection) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
07 December 2009	cnwndl1	Initial creation	CCMS 1023
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/
vars
	bError		: Boolean;
	nextMonitorUpdateTime	: Integer;
	cmifMonitor : CMIF_Monitor;
	
begin

	beginLoad;
	bError	:= not self.setup( _format );
	endLoad;
	
	if bError then
		return false;
	endif;
	
	// get all property values needed to build the XTAB
	if (not self.createXTABData(_coll, cmifMonitor, nextMonitorUpdateTime)) then
		return false;
	endif;
	
	// add any missing mapping values
	self.addMissingMappingValues();
	
	return true;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_coll" type="Collection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
