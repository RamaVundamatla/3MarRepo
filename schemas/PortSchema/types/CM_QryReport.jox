    <JadeMethod name="getTypeFromDescription" id="aa0fc1ee-7354-4c19-81d0-9d936320b48d">
        <source>getTypeFromDescription(_descr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 01/11/2010	cnwcs5	par 23714/ccms 1132 - new report type (machine history)
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars
	qryReport			: CM_QryReport;
begin
	if _descr = null then
		return null;
	endif;
	
	qryReport := self;
	
	if _descr = qryReport.ReportTypeDescr_SystemDefined then
		return qryReport.ReportType_SystemDefined;
		
	elseif _descr = qryReport.ReportTypeDescr_Selector then
		return qryReport.ReportType_Selector;
		
	elseif _descr = qryReport.ReportTypeDescr_VehicleDetails then
		return qryReport.ReportType_VehicleDetails;
	
	elseif _descr = qryReport.ReportTypeDescr_External then
		return qryReport.ReportType_External;

	elseif _descr = qryReport.ReportTypeDescr_BookingRef then	// Par 17601. July 2008
		return qryReport.ReportType_BookingRef;
	
	//elseif _descr = qryReport.ReportTypeDescr_DiscrepancyTxn then //CCMS1765 cnwsh3 19/11/2008 PAR18515
	//	return qryReport.ReportType_Discrepancy;
	
	elseif _descr = qryReport.ReportTypeDescr_BR_Discrepancy then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		return qryReport.ReportType_BR_Discrepancy;
	
	elseif _descr = qryReport.ReportTypeDescr_CargoChgs then	// 28 Feb 2012	NDL	Par 29118
		return qryReport.ReportType_CargoChgs;
		
	elseif _descr = qryReport.ReportTypeDescr_CargoReport then
		return qryReport.ReportType_CargoReport;

	elseif _descr = qryReport.ReportTypeDescr_Train then	// Par 19913
		return qryReport.ReportType_Train;

	elseif _descr = qryReport.ReportTypeDescr_DateSorter then  //CCMS 1869 cnwjo3
		return qryReport.ReportType_DateSorter;
	
	elseif _descr = qryReport.ReportTypeDescr_LogCheckScale then
		return qryReport.ReportType_LogCheckScaling;
	
	elseif _descr = qryReport.ReportTypeDescr_LogDocket then
		return qryReport.ReportType_LogDocket;
	
	elseif _descr = qryReport.ReportTypeDescr_LogLocation then
		return qryReport.ReportType_LogLocation;
	
	elseif _descr = qryReport.ReportTypeDescr_LogProductLoc then
		return qryReport.ReportType_LogProductLocation;
		
	elseif _descr = qryReport.ReportTypeDescr_TrackedItem then
		return qryReport.ReportType_TrackedItem;
		
	elseif _descr = qryReport.ReportTypeDescr_LogTransaction then
		return qryReport.ReportType_LogTransaction;
	
	elseif _descr = qryReport.ReportTypeDescr_LogSummary then //20 January 2010	#cnwdz2	 CCMS 1108 par22177 
		return qryReport.ReportType_LogSummary;
		
	elseif _descr = qryReport.ReportTypeDescr_LogVoyRowSum then
		return qryReport.ReportType_LogVoyageRowSummary ;
	
	elseif _descr = qryReport.ReportTypeDescr_TransReport then
		return qryReport.ReportType_TransactionReport;
		
	elseif _descr = qryReport.ReportTypeDescr_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		return qryReport.ReportType_TrxResource;
		
	elseif _descr = qryReport.ReportTypeDescr_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		return qryReport.ReportType_TrxSealChecks;
		
	elseif _descr = qryReport.ReportTypeDescr_Invoice then		// SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		return qryReport.ReportType_Invoice;

	elseif _descr = qryReport.ReportTypeDescr_InvoiceRate  then	// cnwrd1 par 23583 11.8.2010
		return qryReport.ReportType_InvoiceRate ;
		
	elseif _descr = qryReport.ReportTypeDescr_HMSVoyage then
		return qryReport.ReportType_HMSVoyage;
	elseif _descr = qryReport.ReportTypeDescr_HMSMasters then	//	01May 2012	NDL	Par 29496
		return qryReport.ReportType_HMSMasters;
	elseif _descr = qryReport.ReportTypeDescr_HMSMovements then
		return qryReport.ReportType_HMSMovements;
	elseif _descr = qryReport.ReportTypeDescr_HMSGlobalVoy then
		return qryReport.ReportType_HMSGlobalVoyage;
	elseif _descr = qryReport.ReportTypeDescr_Events then
		return qryReport.ReportType_Events;
	elseif _descr = qryReport.ReportTypeDescr_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		return qryReport.ReportType_MachineHistory;					// 01/11/2010 cnwcs5 par 23714/ccms 1132
	elseif _descr = qryReport.ReportTypeDescr_CraneKPI then			// Dec 2010 CCMS 1134
		return qryReport.ReportType_CraneKPI;
		
	elseif _descr = qryReport.ReportTypeDescr_Vessels then	//	01May 2012	NDL	Par 29496
		return qryReport.ReportType_Vessels;
		
	elseif _descr = qryReport.ReportTypeDescr_CashTrx then	//	14 Aug 2012	NDL	Par 29968
		return qryReport.ReportType_CashTrx;
	elseif _descr = qryReport.ReportTypeDescr_OrgAccess then	//	12 Feb 2013 cnwjre1 CCMS HAT 2205
		return qryReport.ReportType_OrgAccess;
		
	elseif _descr = qryReport.ReportTypeDescr_VehicleBooking then	// 16 Apr 2013	NDl	Par 31393
		return qryReport.ReportType_VehicleBooking;
	elseif _descr = qryReport.ReportTypeDescr_InvoiceLine then
		return qryReport.ReportType_InvoiceLine;					// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
	elseif _descr = qryReport.ReportTypeDescr_CashReceipt then
		return qryReport.ReportType_CashReceipt;					// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
	elseif _descr = CM_QryReport.ReportTypeDescr_InvoiceProform then //epr par 36778 18/8/15 CCMS 2368
		return CM_QryReport.ReportType_InvoiceProforma;
	elseif _descr = qryReport.ReportTypeDescr_CashCredit then
		return qryReport.ReportType_CashCredit;					// 3/02/2016 cnwjre1	TFS 985 cash credits
	elseif _descr = qryReport.ReportTypeDescr_BOLTransaction then
		return qryReport.ReportType_BOLTransaction;					// 2/05/2016 cnwjre1	TFS 1904
	elseif _descr = qryReport.ReportTypeDescr_Audit then
		return qryReport.ReportType_Audit;					// 5/6/18 MAP TFS37718
		
	elseif _descr = qryReport.ReportTypeDescr_SAPActivity then		// TFS 44298
		return qryReport.ReportType_SAPActivity;					// TFS 44298
		
	elseif _descr = qryReport.ReportTypeDescr_SpecialVoySumm then	//14 Aug 2019	NDL	TFS 46131
		return qryReport.ReportType_SpecialVoySumm ;
		
	elseif _descr = qryReport.ReportTypeDescr_EvtTrans then	//06 Jan 2020	NDL	TFS 47780
		return qryReport.ReportType_EventTransaction;
		
	elseif _descr = qryReport.ReportTypeDescr_WOTrans then	//16.3.2023 navhl20	#54350[54269]
		return qryReport.ReportType_WOTransaction;
	
	elseif _descr = qryReport.ReportTypeDescr_LocActivity then	//01 Jun 2021 NDL	TFS 51245
		return qryReport.ReportType_LocActivity;
	
	elseif _descr = qryReport.ReportTypeDescr_LocInventory then	//01 Jun 2021 NDL	TFS 51245
		return qryReport.ReportType_LocInventory;
		
	elseif _descr = qryReport.ReportTypeDescr_GateReceipt then	// 03/08/2022	navkc1	#54342
		return qryReport.ReportType_GateReceipt;				// 03/08/2022	navkc1	#54342
	
	// 20/04/2023	navkc1	CR 55654 Task 55670
	elseif _descr = qryReport.ReportTypeDescr_InvoiceContrct then
		return qryReport.ReportType_InvoiceContract;
	
	elseif _descr = qryReport.ReportTypeDescr_WorkOrder then		//16.8.2023 navhl20 #58568
		return qryReport.ReportType_WorkOrder;
	
	endif;	
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled user report category');
end;</source>
        <Parameter name="_descr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getViewNameOfFirstDesign" id="b598fe81-cebd-43c8-b315-9014540f79fb">
        <source>getViewNameOfFirstDesign() : String;
// ---------------------------------------------------------------------------
// Created:     30 July 2004	cnwth2
//
// Purpose:     
//			 
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 16 Mar 2010	consw1		PAR #22886 - Leaking report transients

vars
	transientRep 		: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	viewName			: String;
	
begin
	create reportManager transient;
	
	transientRep := reportManager.getReport(self.jrwReportName.first);

	if transientRep = null then //it's a form based report
		return null;
	endif;

	viewName := transientRep.getReportingViewName();
	
	return viewName;
	
epilog
	delete transientRep;
	delete reportManager;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
