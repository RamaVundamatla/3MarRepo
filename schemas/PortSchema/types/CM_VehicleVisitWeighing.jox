	self.myTrackedItem := _myTrackedItem;
	self.myTrailer := _myTrailer;
	self.myChassisType := _myChassisType;
	self.myVehicle := _myVehicle;
	self.myWeighBridge := _myWeighBridge;
	self.tiId := _tiId;
	self.vehicleName := _vehicleName;
	self.weighBridgeName := _weighBridgeName;
	self.weighFromWeightBridge := _weighFromWeightBridge;
	self.weightAdjustment := _weightAdjustment;
