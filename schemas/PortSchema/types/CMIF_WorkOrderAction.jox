    <JadeMethod name="getMyAssociatedTerminal" id="fc944d73-80d1-4c98-aaf6-1d6254273249">
        <source>getMyAssociatedTerminal():CM_Terminal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2012	cnwndl1	Initial creation	Par 29404

*/

vars

begin

	if self.myWorkOrderDtl &lt;&gt; null then
		return self.myWorkOrderDtl.getMyTerminal;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
</Class>
