    <JadeMethod name="hasRailJobs" id="b05ff78f-e1ae-4bda-98d3-b12a33848f85">
        <source>hasRailJobs(_inward : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	job : CM_Job;
begin
	foreach job in self.allRailJobs discreteLock do
		if _inward then
			if not job.isRelease then
				return true;
			endif;
		else
			if job.isRelease then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRemarks" id="f2de25ab-cb88-448d-a9b1-8568201d5bb5">
        <methodInvocation>mapping</methodInvocation>
        <source>hasRemarks(_set: Boolean; _value: Boolean io) mapping;

vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := ( self.remarks.trimRight &lt;&gt; null);
end;</source>
