<Class name="CM_WOReleaseCargoRequest" id="a55dcf45-8f01-445b-b710-1cff682b960a">
    <superclass name="CM_WORequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createSplittedWle" id="382ac232-07cd-4503-8954-effe2d8af0a9">
        <source>createSplittedWle(_qty : Integer;
				  _wt  : Decimal):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	aWLE			: CM_WorkListEntry;
	theTI			: CM_TrackedItem;
	iter			: Iterator;
	relByType		: Boolean;
	wod				: CM_WodRelease;
	releaseRequest	: CM_BulkRelease;
	reserve			: CM_ReserveDetail;
	cargoType		: CM_CargoType;
	requestedCount  : Integer;
	count			: Integer;
begin
	wod := self.myJob.myWODtl.CM_WodRelease;
	
	if wod &lt;&gt; null then
		releaseRequest := wod.myReleaseRequest;
	endif;
	
	if releaseRequest &lt;&gt; null then
		relByType := releaseRequest.releaseByType; 	
	endif;
	
	if relByType then
		reserve := wod.myReserveDetail;
		if reserve &lt;&gt; null then
			cargoType 		:= reserve.CM_ReserveSelection.myCargoType;
			requestedCount	:= reserve.CM_ReserveSelection.totalRequested;
			if cargoType.isAllowDuplicates then

				aWLE := self.createWLE();
				aWLE.setQuantity(_qty);
				aWLE.setWeight(_wt);
			endif;
		endif;
	endif;
	
	return aWLE;
epilog

end;</source>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_wt" type="Decimal"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLE" id="5dd9ad94-efbb-4e8a-a381-6d01ad4d2bbe">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	wle	: CM_WOReleaseCargoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="a928e18c-3ba9-4e1c-a22c-19377d436cfb">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
07 Feb 2023	navcs2	ChangeRequest 55440:[54990] EUP - Cargo Work Order Enhancements
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order

*/

vars
	aWLE			: CM_WorkListEntry;
	theTI			: CM_TrackedItem;
	iter			: Iterator;
	relByType		: Boolean;
	wod				: CM_WodRelease;
	releaseRequest	: CM_BulkRelease;
	reserve			: CM_ReserveDetail;
	cargoType		: CM_CargoType;
	requestedCount  : Integer;
	count			: Integer;
begin
	
	wod := self.myJob.myWODtl.CM_WodRelease;
	
	if wod &lt;&gt; null then
		releaseRequest := wod.myReleaseRequest;
	endif;
	
	if releaseRequest &lt;&gt; null then
		relByType := releaseRequest.releaseByType; 	
	endif;

	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	iter := self.myJob.CM_WOReleaseCargoJob.allTrackedItems.createIterator;
	
	// step through all real ti's on the job 
	// then continue until we have all we need
	
	if not relByType then
		while iter.next(theTI) do
		
			aWLE := self.createWLE();
			aWLE.setMyTrackedItem( theTI); 
			aWLE.setQuantity(theTI.totalQuantity);
			aWLE.setWeight(theTI.totalWeight);
		endwhile;
		
	else
		reserve := wod.myReserveDetail;
		if reserve &lt;&gt; null then
			cargoType 		:= reserve.CM_ReserveSelection.myCargoType;
			requestedCount	:= reserve.CM_ReserveSelection.totalRequested;
			if cargoType.isAllowDuplicates then
				/*
				17.04.2023 navma1 #57324:[57325]
				only one Wle with Total QTY/WT
				*/
				aWLE := self.createWLE();
				aWLE.setQuantity(self.myReserveDetail.CM_ReserveSelection.totalRequested);
				aWLE.setWeight(self.myReserveDetail.CM_ReserveSelection.weightRequested);
			else
				/*
				17.04.2023 navma1 #57324:[57325]
				More than Wle based on total requested
				*/
				
				while count &lt; requestedCount do
					aWLE := self.createWLE();
					aWLE.setQuantity(1);
					aWLE.setWeight(reserve.weightRequested);
					
					count := count +1;
				endwhile;
			endif;
		endif;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoSubType" id="76eb02a2-9c39-46c3-bf6a-0970096d2091">
        <source>getCargoSubType(): CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars

begin
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.getMyProduct();
	endif;

epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
