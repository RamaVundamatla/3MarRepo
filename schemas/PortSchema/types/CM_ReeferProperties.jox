    <JadeMethod name="getCarbonDioxide" id="d0ea3d65-a358-49e5-ad6f-fd23c6c157c7">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="8981be62-6147-4d2a-a3a1-ae872fd787f3">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			TFS 45590

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgab1	Initial creation

*/

vars
	str : String;
begin

	str := str &amp; app.getErrorString(Temperature) &amp; ": " &amp;  self.getTemperature().asStringJMT() ;
	
	if self.getHumidity &lt;&gt; NULL_HUMIDITY then
		str := str &amp; " "  &amp; app.getErrorString(HumidityStr) &amp; ": " &amp;  self.getHumidity.asStringJMT();
	endif;
	
	if self.getOxygen &lt;&gt; NULL_OXYGEN then
		str := str &amp; " "  &amp; app.getErrorString(Oxygen_str) &amp; ": " &amp; self.getOxygen.asStringJMT();
	endif;

	return str;
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
