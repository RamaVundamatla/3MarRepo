    <JadeMethod name="trxUpdateReceivalTemp" id="8e580fd3-53c8-400d-833c-cb818428431e">
        <updating/>
        <source>trxUpdateReceivalTemp(_temperature : Real; _gteReceival : CMGTE_Receival input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	app.myUtilityUA.utlUpdateReceivalTemp(_temperature, _gteReceival, _passport);

epilog
