    <JadeMethod name="tblSpecialLifts_displayRow" id="eed18ba8-8fea-447b-8197-07290b3c4ea1">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSpecialLifts_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	selected	: Boolean;
	specialLift : CM_SpecialLift;
	str : String;
	
begin

	specialLift := obj.CM_SpecialLift;
	if specialLift = null then
		return null;
	endif;
	selected := self.tblSpecialLifts.allSelectedObjects.includes(obj);
	
	
	str := specialLift.description;
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; str;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; str;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d9d9987f-5a44-49e6-89f1-96acf0bbb470">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 11:14:04.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019692, locale);
	btnBack.translateCaption(Xlat_0019694, locale);
	btnCheck.translateCaption(Xlat_0026655, locale);
	btnCheckDown.translateCaption(Xlat_0026656, locale);
	btnCheckNA.translateCaption(Xlat_0026862, locale);
	btnCheckParent.translateCaption(Xlat_0026657, locale);
	btnComplete.translateCaption(Xlat_0019693, locale);
	btnCross.translateCaption(Xlat_0026658, locale);
	btnCrossDown.translateCaption(Xlat_0026659, locale);
	btnSave.translateCaption(Xlat_0019695, locale);
	btnTick.translateCaption(Xlat_0026660, locale);
	btnTickDown.translateCaption(Xlat_0026661, locale);
	chkIsCertified.translateCaption(Xlat_0019716, locale);
	chkToDo.translateCaption(Xlat_0019698, locale);
	lblBack.translateCaption(Xlat_0019717, locale);
	lblCargoId.translateCaption(Xlat_0019700, locale);
	lblChildToCheck.translateCaption(Xlat_0026662, locale);
	lblConfirmLocation.translateCaption(Xlat_0026690, locale);
	lblDesc1.translateCaption(Xlat_0019701, locale);
	lblDesc2.translateCaption(Xlat_0019702, locale);
	lblDesc3.translateCaption(Xlat_0026663, locale);
	lblFront.translateCaption(Xlat_0019718, locale);
	lblHeight.translateCaption(Xlat_0019719, locale);
	lblLeft.translateCaption(Xlat_0019720, locale);
	lblLength.translateCaption(Xlat_0019721, locale);
	lblNoChecks.translateCaption(Xlat_0019703, locale);
	lblParentCargoId.translateCaption(Xlat_0026664, locale);
