    <JadeMethod name="weightTonnes" id="5a7cd3f5-e451-4107-9a06-77d59eb67775">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>weightTonnes(set: Boolean; _value: Decimal io) mapping, updating;
//--------------------------------------------------------------
//Created: 03 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if set then
		self.weightTonnes := (_value * 1000).rounded;
	else
		_value := (self.weight / 1000).roundedTo(3);					
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
</Class>
