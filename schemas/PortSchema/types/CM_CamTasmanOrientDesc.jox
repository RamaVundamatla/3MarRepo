    <JadeMethod name="availableTransactions" id="f8fb5c9d-7213-4bf2-8141-ed165686f412">
        <source>availableTransactions(_classColl: ClassColl input);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReleaseRail);
	_classColl.add(CM_ReleaseRoad);
	_classColl.add(CM_ReceiveShip);
	_classColl.add(CM_ReleaseShip);
	_classColl.add(CM_DairyBoard);
	_classColl.add(CM_Damage);
	_classColl.add(CM_Edit);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkEditTransaction" id="cf68070f-92d3-41be-b923-8e08e64d7d2e">
        <source>checkEditTransaction(_transaction: CM_TITransaction):Integer  protected;

vars
	field,
	oldValue,
	newValue	: String;
	i			: Integer;
	status		: Integer;
	theTI		: CM_TrackedItem;
begin
	if not _transaction.isCamsEditType() then
		return 0;
	endif;
	
	theTI := _transaction.CM_Edit.myTrackedItem;
				
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i,field,oldValue,newValue);
		//see if it includes a voyage change
		if field = CM_TrackedItem::isTranshipItem.name then
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue = "No" and newValue = "Yes" then
				status := TRFF;
			endif;
		elseif field = CM_TrackedItem::customExportEntryNumber.name then
			if oldValue &lt;&gt; newValue then
				//had a CEDO changed
				if theTI &lt;&gt; null then
					status := RCVF;
				endif;
			endif;
		endif;
		
	endforeach;
	
	return status;
end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
