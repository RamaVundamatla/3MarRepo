    <JadeMethod name="unPlanTi" id="86c9de26-dbaa-41a1-913b-70499882b55a">
        <source>unPlanTi( _trackedItem : CM_TrackedItem ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation

*/

vars
	wle : CM_WorkListEntry;
	wlesWithWarnings,	
	wleArray : CM_WLEArray;
	result	: Integer;
begin

	
	create wleArray transient;
	create wlesWithWarnings transient;
	
	if _trackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		foreach wle in _trackedItem.allWorklistEntries where wle.myFutureMove &lt;&gt; null do	//30 Mar 2010	NDL	Par 23486
			wleArray.add(wle);
		endforeach;
		if wleArray.isEmpty then
			return result;
		endif;
		
		
		while true do
			app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
			if app.myPassport.trxCompletedOK then
				result := IDOK;
				break;
			else
				//epr TFS 2732 21/11/16
				if self.doNotShowMsgBox then	
					return result;
				endif;
				
				result := app.showErrorWarningDialog(app.getErrorString(MOVE_TYPE_Unqueue), app.myPassport, 36);	//ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					
					// only reprocess the wles that had warnings.
					wleArray.clear;
					wlesWithWarnings.copy(wleArray);
					wlesWithWarnings.clear;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
	
	return result;
	
epilog

	delete wlesWithWarnings;
	delete wleArray;
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateAvailabilityGrade" id="2a8345f9-63fc-4576-82d3-e2704a50ebd6">
        <updating/>
        <source>updateAvailabilityGrade(_ti : CM_TrackedItem; _grade : CM_MTGrade): Boolean  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2016	cnwma1	Initial creation

*/

vars
	result		: Integer;
	tmpGrade	: Integer;
	ti : CM_TrackedItem;
begin
	ti := _ti;
	if _ti = null or not _ti.canSetAvailabilityGrade then
		app.raiseCMException(NO_Container_selected,null,null);
		return false;
	endif;
	
	if _grade = null then
		app.raiseCMException(No_Grade_selected,null,null);
		return false;
	endif;
	
	if _grade.code = _ti.getAvailabilityGrade then
		// already set.

		app.raiseCMException(Grade_already_selected,null,null);
		return true; 
	endif;
	tmpGrade := _ti.getAvailabilityGrade;
	app.myPassport.clearErrorsWarnings();
	while true do
		//Do the Update
		app.myTrxUA.trxUpdateTIAvailabilityGrade(ti, _grade.code, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := IDOK;// app.showErrorWarningDialog('Reading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateDimensionOnProxy" id="58874a09-8f5c-4e63-ad76-f3a42f878544">
        <source>updateDimensionOnProxy(	_pxyTi : CM_TrackedItem input; _isOD : Boolean):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	
	
begin
	
	
	// if some update is required for this/these attribute/(s) then
	//	do the update here against the proxy and return true.
	//	The update against the real ti will happen via the "doRealTrackedItemUpdate" method...
	if _pxyTi.isOverDimensions &lt;&gt; _isOD then
		_pxyTi.setIsOverDimensions(_isOD);
		return true;
	endif;
	
	// if no update is required
	return false;

epilog

end;</source>
        <Parameter name="_pxyTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isOD" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateEquipmentCheckSettings" id="9f28a578-c104-436c-8a8a-e1b661131b62">
        <source>updateEquipmentCheckSettings(_obj : CM_Object; _cargoCheckItem : CM_CargoCheckItem; _selection : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	setting : CM_TICargoChecks;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;

begin

	if _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;
		setting := self.allCargoCheckItemSelections[ti, _cargoCheckItem];
		if setting = null then
			create setting transient;
			setting.setForUpdateCreate(ti, null, null,_cargoCheckItem, null);
			self.allCargoCheckItemSelections.add(setting);
		endif;
		
	elseif _obj.isKindOf(CM_Wagon) then
		wagon := _obj.CM_Wagon;
		setting := self.allNonCargoCheckItemSelections[wagon, _cargoCheckItem];
		if setting = null then
			create setting transient;
			setting.setForUpdateCreate(null, null, wagon, _cargoCheckItem, null);
			self.allNonCargoCheckItemSelections.add(setting);
		endif;
		
	endif;
	
	setting.setSelection(_selection);
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
        <Parameter name="_selection" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLanderCargo" id="86f5192c-f1b1-44a1-bd8f-b487824c36c4">
        <source>validateLanderCargo(_ti : CM_TrackedItem input);
/*

Date		Who		Reason
22 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

begin
	if _ti = null then
		return;
	endif;
	
	if self.checksState = self.ShipDischargeCargo then 
		if _ti.isExport then
			app.raiseCMWarning(Cargo_marked_export_discharge, null,null,null);
		endif;
	elseif self.checksState = self.ShipLoadCargo then
		if _ti.isImport and not _ti.isPlannedToVoyage(self.myVoyage) then  
			app.raiseCMWarning(Cargo_marked_import_not_loaded, null,null,null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateLanderDischarge" id="e50d34b8-79d8-43ca-a301-6bb133626675">
        <updating/>
        <source>validateLanderDischarge(_ti: CM_TrackedItem; _target: CM_LocationsController input ) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2016	cnwndl1	Initial creation
21 Nov 2016 cnwer1	TFS 2732 - validation exception handler that is armed will decide whether to show msgbox or stick with exception
*/

vars
	wle: CM_WorkListEntry;
	otherDDWle: CM_WorkListEntry;
begin
		
//	wle := _ti.getVoyageWLEUnactioned(false);
	wle := _ti.getVoyageWLEForLCUnactioned( false, _target );	//23 Jun 2016	NDL	TFS 2172
	
	//epr par  32868 30/10/13
	if wle = null and _target.isVehicle then
		//find road wle 
		wle := _ti.getIncompleteRoadWleForJob(_target.CM_VehicleController.vehicle, false);
	endif;
	
	//05 Feb 2013	NDL	Par 31102 - Make sure the DD wles that are VoyageWles are loaded to operations.
	if _ti.directDelivery then
		//epr TFS 2732 refactored so can return error and not a msgbox
		return self.validateLanderDischargeDD(_ti, wle, otherDDWle,_target);
			
	else
		if _ti.myPrimaryActualLocation.requiresJob then // 34464
			
			return validateLanderDischargeLOLO(wle);		
		endif;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_target" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderDischargeDD" id="28cec1c0-68c5-4501-bbbb-086ae379c891">
        <source>validateLanderDischargeDD(_ti: CM_TrackedItem; 
							wle : CM_WorkListEntry; 
							otherDDWle : CM_WorkListEntry output;
							_dischargeLocation : CM_LocationsController) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2016	cnwndl1	Initial creation	Par 1593
21 Nov 2016 cnwer1	TFS 2732 - validation exception handler that is armed will decide whether to show msgbox or stick with exception
*/

vars
begin
	
	// must be Road Rail or Ship
	if _dischargeLocation &lt;&gt; null then
		if not _dischargeLocation.isVehicle and ( _dischargeLocation.isYardLocation or _dischargeLocation.isMachineController ) then
			
			//epr TFS 2732 21/11/16 validation exception handler that is armed will decide whether to show msgbox or stick with exception
			app.raiseCMException(Invalid_direct_delivery_loc,null,null);
			return false;
		endif;
	endif;

	if wle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
		return false;
	endif;
	
	otherDDWle := _ti.getDirectDeliveryTargetWle( wle );
	if otherDDWle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
		return false;
	endif;
	
	if wle.job = null then
		app.raiseCMException1(Not_found_worklis_entry, wle.id,null,null);
		return false;
	endif;
	
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	//09 Jan 2014	NDL	Par 33277
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c,  wle.job.jobId,null,null);
		return false;
	endif;
	
	if otherDDWle.isKindOf(CM_VoyageWLE)then
		if otherDDWle.job = null then
			app.raiseCMException1(Not_found_worklis_entry,  otherDDWle.id ,null,null);
			return false;
		endif;
		if not otherDDWle.CM_VoyageWLE.isLoadedToOperations() then
			app.raiseCMException1(Voyag_been_loade_voyag_opera_c,   otherDDWle.job.jobId ,null,null);
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <Parameter name="otherDDWle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderDischargeLOLO" id="9c32ab34-edf2-46c2-a734-f1a48779d52b">
        <source>validateLanderDischargeLOLO(wle : CM_WorkListEntry ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2016	cnwndl1	Initial creation	TFS 1593
21 Nov 2016 cnwer1	TFS 2732 - validation exception handler that is armed will decide whether to show msgbox or stick with exception
*/

vars

	errMess : String;

begin
	
	// must be Road Rail or Ship
	if wle = null or wle.job = null then
		app.raiseCMException1(Not_found_worklis_entry,null,null,null);
		return false;//app.getErrorString1(Not_found_worklis_entry, null);
	endif;
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c, wle.job.jobId,null,null);
		return false;// app.getErrorString1(Voyag_been_loade_voyag_opera_c, wle.job.jobId );
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderLoadDD" id="5c580d96-f86b-4f72-a427-302b78d7b7ff">
        <source>validateLanderLoadDD(	_ti : CM_TrackedItem input;
						_wle : CM_WorkListEntry;
						_otherDDWle : CM_WorkListEntry output ) : Boolean protected;
/*

Date		Who		Reason
16 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

begin
	if _wle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);	
		return false;
	endif;
	_otherDDWle := _ti.getDirectDeliveryTargetWle( _wle );
	if _otherDDWle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
		return false;
	endif;
	if _wle.job = null then
		 app.raiseCMException1(Not_found_worklis_entry, _wle.id ,null,null);
		return false;
	endif;

	if _wle.isKindOf(CM_VoyageWLE) and not _wle.CM_VoyageWLE.isLoadedToOperations() then	//09 Jan 2014	NDL	Par 33277
		 app.raiseCMException1(Voyag_been_loade_voyag_opera_c, _wle.job.jobId,null,null );
		return false;
	endif;
	if _otherDDWle.isKindOf(CM_VoyageWLE)then
		if _otherDDWle.job = null then
			app.raiseCMException1(Not_found_worklis_entry, _otherDDWle.id,null,null );
			return false;
		endif;
		if not _otherDDWle.CM_VoyageWLE.isLoadedToOperations() then
			 app.raiseCMException1(Voyag_been_loade_voyag_opera_c, _otherDDWle.job.jobId ,null,null);
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_otherDDWle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderLoadDPH" id="915ff279-e652-48b2-bbfb-00c285ee236b">
        <source>validateLanderLoadDPH(	_ti : CM_TrackedItem input;
						_loadLocation : CM_LocationsController ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

	plannedLoc : CM_LocationsController;

begin
	
	if not app.myRoot.isClientDPH then
		//NOT DPH, and this is 'DPH only' validfation
		return true;
	endif;
	
	//Doing a load to voyage for DPH - Make sure that it is planned, and is going to the same voyage.
	
	plannedLoc := _ti.myPrimaryPlannedLocation;
	if plannedLoc = null or not plannedLoc.isVoyageController then
		// not planned to a voyage at all
		app.raiseCMException1(Not_Planned_To_Voyage, _ti.id,null,null) ;
		return false;
	endif;
	
	if not _loadLocation.isVoyageController then
		app.raiseCMException(Cannot_load_voyage_locatio,null,null);
		return false;
	endif;
	
	if plannedLoc.CM_VoyageController.myVoyage &lt;&gt; _loadLocation.CM_VoyageController.myVoyage then
		//wrong voyage
		app.raiseCMException2( Not_Planned_To_Voyage, _ti.id, _loadLocation.CM_VoyageController.myVoyage.code,null,null) ;
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_loadLocation" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderLoadLocation" id="3d58ddca-cd8c-4760-ad21-7a00b39ac7a2">
        <source>validateLanderLoadLocation(_loadLocation : CM_LocationsController input; _ti : CM_TrackedItem input; _selectedWle : CM_WorkListEntry input) : Boolean protected;
/*

Date				Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732
11 July 2022		jlizm1	TFS 53690 change to less confusing error message

*/

vars
	vjob 				   : CM_VoyageJob;
	allowOutOfOrderLoading : Boolean;
	plannedLoc			   : CM_LocationsController;
begin
	if _selectedWle &lt;&gt; null and _selectedWle.job &lt;&gt; null and _selectedWle.job.isVoyageTypeJob() then // TFS 4561 TFS 4859
		vjob 					:= _selectedWle.job.CM_VoyageJob;									 // TFS 4561
		allowOutOfOrderLoading  := vjob.allowOutOfOrderLoading;										 // TFS 4561
	endif; 																							 // TFS 4561

	if allowOutOfOrderLoading then // TFS 4561
		return true;
	endif;
	
    if not _loadLocation.isKindOf(CM_VoyageController) then
		app.raiseCMException(Location_must_be_Onship,null,null);
		return false;		
	else
		if self.myVoyage &lt;&gt; _loadLocation.CM_VoyageController.myVoyage then
			 app.raiseCMException1(Location_must_voyage,self.myVoyage.code,null,null);
			 return false;	
		endif;
		
		
		if  _ti.myPrimaryQueuedLocation = null and _loadLocation.mustBePlannedForHHLanderLoad() then // PAR 34610 
			
			plannedLoc := _ti.myPrimaryPlannedLocation;
			
			if plannedLoc = null then
				if _selectedWle = null or not _selectedWle.isTiAssignedToResDet(_ti) then	// 09 May 2017	NDL	TFS 3045
					app.raiseCMException( Move_not_permi_cargo_must_prep,null,null );
					return false;
				endif;
			elseif plannedLoc &lt;&gt; _loadLocation then
				app.raiseCMException(Cargo_planned_diff_slot,null,null);
				return false;
			endif;
		endif;
		
	endif;
	
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_loadLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_selectedWle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderSOBDetails" id="9717be12-e546-4bce-b38e-2f689b6f570e">
        <source>validateLanderSOBDetails(	_ti : CM_TrackedItem input;
					_wle : CM_VoyageWLE;
					_locationTarget : String;
					_isCargoLander: Boolean //26/10/2022 navmv20 TFS 51643
					) : Boolean protected;
/*
Purpose:			
Date				Who			Reason
15 November 2016	cnwer1	Initial creation TFS 2732
26 October 2022     navmv20 Bug 51643: MTN - Cargo Lander Shift on board gives error about not having a job
*/

vars

	sourceLocation : CM_LocationsController;
	targetLocation : CM_LocationsController;
	locationStr : String;
	nullLocationStr : String;
	primarySOBWle : CM_VoyageWLE;
	linkedWle : CM_VoyageWLE;
		
begin

	primarySOBWle := _wle;
	
	//26/10/2022 navmv20 TFS 51643 - START
	if _isCargoLander then
		return true;
	endif;
	//26/10/2022 navmv20 TFS 51643 - END
	if primarySOBWle &lt;&gt; null then
		sourceLocation := primarySOBWle.getSourceLocation();
	endif;
	locationStr := app.getErrorString(CM_Source_Location);
	
	// no wle
	if sourceLocation = null then
		nullLocationStr := _ti.getPrimaryLocationId(REAL_MODE);
		app.raiseCMException2(Location_Not_CC_SOB_In_Job, locationStr, nullLocationStr,null,null);
		return false;
	endif;

	// wle not marked as SOB
	if not primarySOBWle.isSOB() then
		app.raiseCMException2(Location_Not_Marked_SOB, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;
	
	// controller not colour coded
	if sourceLocation.mustBePlannedForHHLanderLoad
	and sourceLocation.CM_VoyageController.getColourCoding(false) = null then
		app.raiseCMException2(Location_Not_Colour_Coded, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;

	// wle not in a job
	if primarySOBWle.job = null then
		app.raiseCMException2(Location_Not_In_Job, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;
	
	///////////////////////////////////
	
	linkedWle := primarySOBWle.getLinkedWLE().CM_VoyageWLE;
	if linkedWle &lt;&gt; null then
		targetLocation := linkedWle.getTargetLocation();
	elseif not sourceLocation.mustBePlannedForHHLanderLoad then
		targetLocation := primarySOBWle.getTargetLocation();
	endif;
	locationStr := app.getErrorString(CM_Target_Location);
	
	// no wle
	if targetLocation = null then
		nullLocationStr :=  _locationTarget; 
		app.raiseCMException2(Location_Not_CCSOBJobLinkd, locationStr, nullLocationStr,null,null);
		return false;
	endif;

	// wle not marked as SOB
	if linkedWle &lt;&gt; null and not linkedWle.isSOB() then
	app.raiseCMException2(Location_Not_Marked_SOB, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;
	
	// controller not colour coded
	if targetLocation.mustBePlannedForHHLanderLoad
	and targetLocation.CM_VoyageController.getColourCoding(true) = null then
	app.raiseCMException2(Location_Not_Colour_Coded, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;

	// wle not in a job
	if linkedWle &lt;&gt; null and linkedWle.job = null then
		app.raiseCMException2(Location_Not_In_Job, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
        <Parameter name="_locationTarget" type="String"/>
        <Parameter name="_isCargoLander" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePackForReserveDetails" id="de24a3c7-5064-431d-9147-18bd082f3aad">
        <source>validatePackForReserveDetails(	_reserveDetail : CM_ReserveDetail;
								_ti : CM_TrackedItem;
								_quantity : Integer;
								_weight : Decimal;
								_reason : String output
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation	TFS 1593
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	count : Integer;
	weight : Decimal[16,4];
	ti : CM_TrackedItem;
	desc : String;
	allTis	: CM_TISet; 
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	count := 0;
	weight := 0;
	
	if _reserveDetail.isPackingChild then
		count := _reserveDetail.getTotalPacked;
		weight := _reserveDetail.getWeightPacked;
		
	else
		_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in _reserveDetail.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isVehicle then
				count := count + ti.totalQuantity.max(1);
				weight := weight + ti.totalWeight;
			endif;
		endforeach;
	
		foreach ti in _reserveDetail.allTrackedItemsReleased do
			count := count + ti.totalQuantity.max(1);
			weight := weight + ti.totalWeight;
		endforeach;
	endif;
	
	desc := _reserveDetail.CM_ReserveSelection.getTotalRequestedDisplay() &amp; ' x ' &amp; _reserveDetail.CM_ReserveSelection.getProductISOTypeDescr();
	if _reserveDetail.CM_ReserveSelection.myCargoType = null then
		desc := desc &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
	endif;
			
	if count = _reserveDetail.totalRequested  and _reserveDetail.totalRequested &gt; 0 then
		_reason := app.getErrorString2(Already_have_count_for, count.String, desc);
		return;
	endif;
	if weight = _reserveDetail.weightRequested  and _reserveDetail.weightRequested &gt; 0 then
		_reason := app.getErrorString1(Already_have_weight_request, desc);
		return;
	endif;

	count := count + _quantity;
	weight := weight + _weight;

	if ( count &gt; _reserveDetail.totalRequested and _reserveDetail.totalRequested &gt; 0 )
	or ( weight &gt; _reserveDetail.weightRequested and _reserveDetail.weightRequested &gt; 0 )
	then
		_reason := app.getErrorString1(Quant_weigh_relea_will_excee_r, desc);
		return;
	endif;
	
	_reason := null;

epilog
	delete allTis; 
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_reason" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="validateReleaseLoad" id="ceac8a99-e64a-4898-8ca0-f7a3752a6f57">
        <source>validateReleaseLoad(_reserveDetail : CM_ReserveDetail; 
					_roadJob 	: CM_RoadJob;
					_quantity : Integer; _weight: Decimal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879

*/

vars
	quantityLoading: Integer;
	weightLoading : Decimal[16,4];
	quantityLoaded : Integer;
	weightLoaded : Decimal[16,4];
	maxQuantityToLoad : Integer;
	maxWeightToLoad : Decimal[16,4];
	allWles : CM_WLESet;
	wle : CM_WorkListEntry;
	reserveDetail : CM_ReserveDetail;
	reason : String;
	tiSet  : CM_TISet;
	wc : CM_WagonController;
	wagon 	: CM_Wagon;
begin
	if self.myLocationsController = null then
		return;
	endif;
	if self.myLocationsController.isKindOf(CM_WagonController) then
		wagon:=self.myLocationsController.CM_WagonController.myWagon;
	endif;
	
	weightLoading := _weight;	
	quantityLoading := _quantity;
		
	create tiSet transient;
	create allWles transient;
	if wagon &lt;&gt; null then
		foreach wc in wagon.allLocationsControllersArray discreteLock do
				quantityLoaded := quantityLoaded + wc.getWeightQuantityForRelease(self.myBulkRelease,tiSet, weightLoaded );
				foreach wle in wc.CM_WagonController.allRailWLELoad discreteLock where wle.myRequest &lt;&gt; null  do
						if wle.myRequest.bulkRelease = self.myBulkRelease then
							allWles.addNoDuplicates(wle,false);
						endif;
				endforeach;
		endforeach;
	else
		quantityLoaded := self.myLocationsController.getWeightQuantityForRelease(self.myBulkRelease,tiSet, weightLoaded );	//already on the truck
		if _roadJob &lt;&gt; null then
			foreach wle in _roadJob.workListEntries discreteLock where wle.myRequest &lt;&gt; null do			
				if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
					allWles.add(wle);
				endif;
			endforeach;
		endif;
	endif;
	
	//20 May 2015	NDL	Par 36127
	foreach wle in allWles discreteLock do
		maxQuantityToLoad :=maxQuantityToLoad  + wle.quantity.max(1);
		maxWeightToLoad:=maxWeightToLoad  + wle.weight;
	endforeach;
	
		
	//09 Dec 2015	NDL	TFS752-12
	if _reserveDetail &lt;&gt; null then
		_reserveDetail.validateWeightQuantityAdd(	quantityLoading, weightLoading, true );
		if app.myPassport.hasErrors then
			return ;
		endif;
	endif;
	
	
	//Relative to the WLE where potentailly multiple trucks are working one bulk release,
	// should be able to load more than the amount on the WLE on the basis that the checks above
	// will have determined that there was enough left on the reserve details of the bulk release.
	if quantityLoading &gt; 0 and maxQuantityToLoad &gt; 0 then
		if quantityLoaded &gt;= maxQuantityToLoad then
			//Already on the truck
			 app.raiseCMWarning(Fully_loaded,null,null,null);
		elseif (quantityLoaded + quantityLoading) &gt; maxQuantityToLoad then
			if quantityLoading &gt; 0 then
				 app.raiseCMWarning3(Addin_truck_will_excee_totla_w, quantityLoading.String, quantityLoaded.String, maxQuantityToLoad.String,null,null,null );
			else
				 app.raiseCMWarning2(Addin_will_excee_total_work_li, quantityLoading.String, maxQuantityToLoad.String,null,null,null );
			endif;
			
		endif;
		
	elseif weightLoading &gt; 0 and  maxWeightToLoad &gt; 0 then
		if weightLoaded &gt;= maxWeightToLoad then
			//Already on the truck
			app.raiseCMWarning(Fully_loaded,null,null,null);
		elseif (weightLoaded + weightLoading) &gt; maxWeightToLoad then
			if weightLoading &gt; 0 then
				app.raiseCMWarning3(Addin_truck_will_excee_totla_w, weightLoading.String, weightLoaded.String, maxWeightToLoad.String ,null,null,null );
			else
				 app.raiseCMWarning2(Addin_will_excee_total_work_li, weightLoading.String, maxWeightToLoad.String ,null,null,null );
			endif;	
		endif;
	
	endif;
	
	
epilog
	delete allWles;
	delete tiSet;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateReserveTI" id="ae526bfd-ca77-4a16-a93d-3e517ddc9d1a">
        <source>validateReserveTI( _bulkRelease 	 : CM_BulkRelease input; 
				  _trackedItem 	     : CM_TrackedItem; 
				  _raiseErrorWarning : Boolean;
				  _quantity 		 : Integer;
				  _weight 			 : Decimal) : Boolean;
/*

Purpose:			

Parameters:			Web based should raise an error, old thin client based hand helds should just call a msgBox

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
18 Jun 2019	jlgndl1	TFS 45162	Initial creation
27 Jun 2019	jlgka1	TFS 45162	STWO - Call the new method to validate Loaded TrackedItems as we need to include those items
								that are currently in the Agent as part of the Released Quantity.
26 Jul 2019 jlgka1 	TFS 45830	STWO - Partial Release for Break Bulk.								
============================================================================*/

vars
	mess 		 : String200Array;
	errorCodes 	 : IntegerArray;
	cmifGrouping : CMIF_ReserveTIGrouping;
	tmpMess 	 : String;
	pos 		 : Integer;
	errorInt 	 : Integer;
	isError 	 : Boolean;
	exObj 		 : CM_Exception;
	msgBoxStr 	 : String;
	resumable 	 : Boolean;
	
	wasAlreadyAcknowledged : Boolean;
begin
	if _bulkRelease = null or _bulkRelease.myTerminal = null then
		return true;
	endif;
	
	if not _bulkRelease.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		return true;
	endif;
	
	if _raiseErrorWarning then
		//check passport to see if warnings acknowledged
		wasAlreadyAcknowledged := app.myPassport.warningsAcknowledged;
	endif;

	create mess transient;
	create errorCodes transient;

	create cmifGrouping transient;
	cmifGrouping.setCMIFFromLoaderAndRelease( _bulkRelease, cmifGrouping, self, _quantity, _weight, _trackedItem);
	cmifGrouping.validateReserveTIs( errorCodes, mess, _trackedItem );
	
	resumable := true;
	if not mess.isEmpty then
		foreach pos in 1 to mess.size do
			tmpMess := mess[pos];
			errorInt := errorCodes[pos];
			isError := tmpMess[1:6].pos("Error",1) &gt; 0;
			
			if isError then
				//we have had a real error
				resumable := false;
			endif;
				
			if _raiseErrorWarning then
				if wasAlreadyAcknowledged and resumable then
					continue;
				endif;
				//raise each error / warning individually
				create exObj transient;
				exObj.set(errorInt, tmpMess, not isError, null, null, null);
				raise exObj;
			else
				//collect up a string of erros and warnings.
				msgBoxStr := msgBoxStr &amp; errorInt.String &amp; " " &amp; tmpMess &amp; CrLf;
			endif;			
		endforeach;
		
		if _raiseErrorWarning then //(Web based using exceptions, we are NOT in a transaction here)
			//if passport warnings were already acknowledged and no errors raised, so still resumable,
			//reset the acknowledged (so we don't override the folowing trxs) and let it go
			//otherwise force the (web) user to look now, by returning false.
			if wasAlreadyAcknowledged then
				app.myPassport.warningsAcknowledged := false;
				app.myPassport.initialiseTransaction;
				return true;
			else
				return false;
			endif;
				
		else // Old style thin client Hand Held using msg box pre transaction
			if resumable then
				//Only warnings, let the user decide.
				msgBoxStr := msgBoxStr &amp; app.getErrorString( DoYouWantToContinue );
				return app.msgBox( msgBoxStr, app.getErrorString( Continue ), MsgBox_Yes_No ) = MsgBox_Return_Yes;
			else
				//at least one is an error.
				app.msgBox( msgBoxStr, app.getErrorString( Error ), MsgBox_OK_Only );
				return false;
			endif;
			
		endif;
	endif;
	
	return true;

epilog

	delete cmifGrouping;
	delete mess;
	delete errorCodes;

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_raiseErrorWarning" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validationExHandler" id="34f13900-19e5-47ae-9c88-513e4049c9bf">
        <source>validationExHandler(exObj : CM_Exception; _passport : CM_Passport input) : Integer;
/*

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732 

*/

vars

begin
	
	if self.doNotShowMsgBox then
		// 19/4/17 this is set from webservices
		// pass back to the WS_WebServiceProvider handleCMException this adds the warnings and errors to pasport and aborts if not continable

		return Ex_Pass_Back;
		
	else
		self.msgBox(  exObj.extendedErrorText, app.getErrorString(Error), MsgBox_OK_Only,true);
	
		return Ex_Abort_Action; //epr TFS 3987 6/4/17
	endif;
	
	
epilog

end;</source>
        <Parameter name="exObj" type="CM_Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
