epilog

end;</source>
        <Parameter name="_type" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="a2094244-466b-45ae-8fb3-498a72fb0ed9">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
*/

vars
	isShowDataMenusP,
	isShowDataMenusC	: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	self.mnuInspect.visible :=  false;
	self.mnuColOrganiser.visible := true;
	self.mnuColOrganiser.userObject := table;
	
	if table = self.tblAvailCargo then
		isShowDataMenusP	:=	(table = self.tblAvailCargo);
	elseif table = self.tblCompletedCargo then
		isShowDataMenusC	:=	(table = self.tblCompletedCargo);
	// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
	elseif table = self.tblResources then
		self.mnuInspect.visible := app.isSpecial();
		self.mnuColOrganiser.visible := false;
		self.mnuColOrganiser.userObject := null;
	endif;
	

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuCompleteJob, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="04a81f48-d90d-4976-bbc4-0efdbadc5223">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars

begin
	if self.btnOk.caption = app.getErrorString(Pack_Complete) then				//19.03.2024 navhl20 #62863
		self.doPackComplete();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOperations" id="1efe62cd-4bad-4939-98b9-6b644258a294">
        <updating/>
        <source>doOperations() updating;
/*
Purpose:			

Date		Who		Reason
30 May 2024	navab1	CR 64297 TASK 64359
*/

vars
	job	: CM_Job;
	
begin
	job := self.myJob;
	if job.isRoadJob then											//11.03.2024 navhl20 #60097
		if job.isRelease then										//13.02.2024 navhl20 #62418
			self.doTruckLoad();
		else
			self.doTruckUnload();
		endif;
	elseif job.isRail then
		if job.isRelease then
			self.doRailLoad();
		else
			self.doRailDischarge();
		endif;
	else
		//Ship operations
		if job.isRelease then										//12.03.2024 navhl20 #62734
			// ### TFS CR 64297 TASK 64359 06JUNE2024 NAVAB1 - self.doShipLoadBulk();									//07.05.2024 navhl20 #64031
			self.doShipLoadBulkDLRT(); // ### TFS CR 64297 TASK 64359 06JUNE2024 NAVAB1
		else
			if app.isSpecial then									//23405.2024 navhl20 #64271
				self.doShipDischargeBulkSU();
			else
				// ### TFS CR 64297 TASK 64359 30MAY2024 NAVAB1 - self.doShipDischargeBulk();							//07.05.2024 navhl20 #64031	
				self.doShipDischargeBulkDLRT(); // ### TFS CR 64297 TASK 64359 30MAY2024 NAVAB1
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPack" id="8795a134-1db5-4efb-b8a2-0365e4f1f6b6">
        <source>doPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
16 Apr 2024 navhl20 Bug 63707: EUP - 1090 Exception when clicking on the Pack button for the retrospective Pack jobs
13 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form
17 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
09 Aug 2024 navhl20	Bug 65573: Pack work order issues - Unable to perform Pack Complete
20 Aug 2024 navbs1	Defect 65687: 75764 exception when clicking on the Pack Complete button on the Complete Job form
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
29 Oct 2024 navhl20 MTN - Performance issues and locks when completing the Retrospective Pack jobs
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/


vars
	effectiveDate			: TimeStamp;
	packCargo,
	parentCargo				: CM_TrackedItem;
	quantity,
	result					: Integer;
	bulkRelease				: CM_BulkRelease;
	reserveDetail			: CM_ReserveDetail;
	setParentFromChild 		: Boolean;
	packQuantity			: Integer;
	weight					: Decimal[12,4];
begin
	effectiveDate := self.getEffectiveDate();											//27.03.2025 navhl20 #34493
	
	if not self.validate(null,null,true) then											//27.03.2025 navhl20 #34493
		return;
	endif;
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	parentCargo := self.tblParent.allSelectedObjects.first.CM_TrackedItem;
	
	self.getQuantitytoPack(quantity,weight);											//27.03.2025 navhl20 #34493
	
	setParentFromChild :=  parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
						   and parentCargo.isStorage;
			
	bulkRelease := self.getBulkReleaseFromJob();										//27.03.2025 navhl20 #34493

	app.myPassport.clearErrorsWarnings();												//20.8.2024 navbs1 #65687
		
	foreach packCargo in self.tblChild.allSelectedObjects as CM_TrackedItem do			//17.06.2024 navhl20 #64602
		packQuantity := packCargo.totalQuantity;										//03.10.2024 navbs1 #19303
		
		self.validateCargoToPack(parentCargo,packCargo,bulkRelease,reserveDetail,setParentFromChild);	//27.03.2025 navhl20 #34493
		
		if app.myPassport.noErrors and self.tblChild.allSelectedObjects.size = 1 then
			packQuantity := quantity;
			if not self.completeChecks(packCargo,CARGO_CHECK_CONTEXT_PACK,effectiveDate) then	//01.04.2025 navhl20 #34493
				return;
			endif;
		endif;
		
		while true do
			if app.myPassport.noErrors then														//25.04.2024 navhl20 #63707
				app.myTrxUA.trxUpdatePackCargo(parentCargo, packCargo, packQuantity, null, setParentFromChild,bulkRelease, reserveDetail,true,effectiveDate, app.myPassport);		//09.08.2024 navhl20 #65573		//03.10.2024 navbs1 #19303
			endif;
			
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Pack), app.myPassport, 20);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					return;
				endif;
			endif;
		endwhile;
	endforeach;
	
	if app.myPassport.trxCompletedOK then				//29.10.2024 navhl20 #23340
		self.reloadTablesForPack();						//27.03.2025 navhl20 #34493
	endif;
epilog
	app.myPassport.clearErrorsWarnings();
end;</source>
    </JadeMethod>
    <JadeMethod name="doPackComplete" id="22d1ddf2-a3ed-4dad-9222-17df073e72ca">
        <updating/>
        <source>doPackComplete()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
12 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
11 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
08 Aug 2024 navhl20	Bug 65572: FR | 54177 - Retrospective Operations - Pack Process issue
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	result			: Integer;
	bulkRelease		: CM_BulkRelease;
	parentCargo,
	pxyTI			: CM_TrackedItem;
	effectiveDate	: TimeStamp;
begin
	effectiveDate := self.getEffectiveDate();											//27.03.2025 navhl20 #34493
	parentCargo := self.tblParent.allSelectedObjects.first.CM_TrackedItem;
	bulkRelease := self.getBulkReleaseFromJob();										//27.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	if parentCargo = null then					//12.06.2024 navhl20 #64602
		if app.msgBox(app.getErrorString(Pleas_selec_paren_cargo_pack_c), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	if parentCargo.allChildren.isEmpty then
		return;
	endif;
	
	pxyTI :=  app.createUpdateProxy(parentCargo).CM_TrackedItem;																					//28.08.2024 navhl20 #65572
		
	while true do
		if self.completeChecks(parentCargo,CONT_CHECK_CONTEXT_PACK,effectiveDate) then			//08.08.2024 navhl20 #65572							//01.04.2025 navhl20 #34493
			app.myTrxUA.trxUpdateTIPackComplete(pxyTI, bulkRelease, effectiveDate, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			if not parentCargo.hasJobTransactions(self.myJob) then		//17.10.2024 navhl20 #12389
				self.doSaveStartStop();
			endif;
			if self.myJob.status = JOB_COMPLETE then					//08.08.2024 navhl20 #65572
				self.unloadForm();										//11.07.2024 navhl20 #61368
				break;
			endif;
			self.reloadTablesForPack();									//27.03.2025 navhl20 #34493
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Pack), app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				return;
			endif;
		endif;
	endwhile;
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="1acde680-af86-418a-a244-b0daecfc9125">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDoOperation.enabled := false;
		self.btnOk.enabled := false;
		self.btnPack.enabled := false;
		self.btnResUpdate.enabled := false;
		self.btnResComplete.enabled := false;
		self.btnResDelete.enabled := false;
		self.btnStartStop.enabled := false;
		self.btnUnpack.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRailDischarge" id="0b6ef22c-58b6-4963-8322-0223ca9d45f9">
        <source>doRailDischarge() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2024	navpw1	Initial creation TFS 63304 (63313)
13 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	mobileAgent 			: CMIF_MobileGenericAgent;
	ti						: CM_TrackedItem;
	ta						: CM_TerminalArea;
	terminal				: CM_Terminal;
	targetLocation			: CM_LocationsController;
	quantity				: Integer;
	effectiveDate			: TimeStamp;
	railJob					: CM_RailJob;
	result					: Integer;
	weight					: Decimal[12,4];
	tiSet					: CM_TISet;
	multi					: Boolean;
begin
	ta			:= self.cmbTerminalArea.listObject.CM_TerminalArea;
	terminal	:= self.getMyTerminal();
	effectiveDate := self.getEffectiveDate();
	
	targetLocation := self.getTragetLocation();
	
	if not self.validate(ta,targetLocation,false) then		//13.06.2024 navhl20 #64602	//27.03.2025 navhl20 #34493
		return;
	endif;
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	railJob := self.myJob.CM_RailJob;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipDischargeCargo); //Check if needed
	mobileAgent.setMyJob(railJob);
	
	ti := self.tblAvailCargo.allSelectedObjects.first.CM_TrackedItem;
	
	if railJob.allWagons.isEmpty then
		if app.msgBox(app.getErrorString(Input_required_field_WgnId), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	mobileAgent.setMyCurrentWagon(railJob.allWagons.first);
	
	if self.tblAvailCargo.allSelectedObjects.size = 1 then															//13.06.2024 navhl20 #64602
		quantity := ti.totalQuantity;
		
		if quantity &gt; 1 or (ti.isBulkByWeight and ti.totalWeight &gt; 1) then											//10.12.2024 navhl20 #33643
			self.showMoveAmountForm(ti,quantity,weight);															//27.03.2025 navhl20 #34493
		endif;
	endif;
	
	create tiSet transient;
	
	if self.tblAvailCargo.allSelectedObjects.size &gt; 1 then
		multi := true;
	endif;
	
	while true do
		if not multi then																								//13.06.2024 navhl20 #64602
			if self.completeChecks(ti, CARGO_CHECK_CONTEXT_SHIP_DISC, effectiveDate) then								//01.04.2025 navhl20 #34493
				mobileAgent.doLanderDischargeToRail(ti, targetLocation, quantity, weight,effectiveDate);				//13.06.2024 navhl20 #64602	//09.12.2024 navhl20 #33643
			endif;
		else
			foreach ti in self.tblAvailCargo.allSelectedObjects as CM_TrackedItem do
				mobileAgent.setDoNotShowMsgBox(true);																	//20.06.2024 navhl20 #64602
				if not mobileAgent.doLanderDischargeToRail(ti, targetLocation, ti.totalQuantity, ti.weight,effectiveDate) then		//13.06.2024 navhl20 #64602
					break;
				endif;
				tiSet.tryAdd(ti);
			endforeach;
		endif;
		
		if app.myPassport.trxCompletedOK then

			self.loadTblAvail();		//Notifications should handle this??
			self.loadTblCompleted();	//Notifications should handle this??
			
			if self.tblAvailCargo.rows = 1 then
				self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66108
				self.btnDoOperation.enabled := false;
			endif;
			
			self.setTblDataCount();
			break;
		else
			foreach ti in tiSet do
				self.tblAvailCargo.allSelectedObjects.tryRemove(ti);
			endforeach;
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return; //Bail as we cannot save if theres errors
		
	endwhile;
	
epilog
	delete mobileAgent;
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRailLoad" id="d4577853-1372-4679-8098-9e425cd27147">
        <updating/>
        <source>doRailLoad() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2024	navpw1	Initial creation TFS 62859 (62860)
13 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
30 Oct 2024	navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
13 Dec 2024	navbs1 Bug MTN-33190: MTN - Error when loading the rail job on the complete job form
26 Dec 2024	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
11 Jun 2025	navhl20 Bug MTN-34584: MTN - Work Order Operations - Rail Load Behaviour when choosing multiple items to load
24 Jun 2025	navbs1  Bug MTN-35184: MTN - 1090 exception on the complete job form when loading the cargo item for the release road job
*/

vars
	ta				: CM_TerminalArea;
	failedDAC		: CM_DataAccessController;
	railJob			: CM_RailJob;
	ti				: CM_TrackedItem;
	wagon			: CM_Wagon;
	wle				: CM_WorkListEntry;
	targetLocation	: CM_LocationsController;
	allRequests		: CM_DeliveryRequestSet;
	quantity,
	row				: Integer;
	weight			: Decimal[14,4];
	effectiveDate	: TimeStamp;
	tblString		: String;
	tiSet			: CM_ObjectSet;
begin
	ta := self.cmbTerminalArea.listObject.CM_TerminalArea;
	effectiveDate := self.getEffectiveDate();											//27.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	//Job should be a rail job. Gets checked before entering method
	railJob := self.myJob.CM_RailJob;
	
	//Get Ti
	ti := self.tblAvailCargo.allSelectedObjects.first.CM_TrackedItem;
	
	wagon := self.getWagonForJob(railJob);												//27.03.2025 navhl20 #34493
	
	//Check wagon is not null
	if wagon = null then
		if app.msgBox(app.getErrorString1(Wagon_not_found_expect_wagons, "for job '" &amp; railJob.id &amp; "'"), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;

	self.getReleaseDetailsForRail(ti,wle,wagon);										//24.06.2025 navbs1 #35184
	
	
	//Check to make sure we have a wle from the code above
	if wle = null then
		if app.msgBox(app.getErrorString(Work_list_entry_found), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	//Check that jobs match
	if railJob &lt;&gt; wle.job then
		if app.msgBox(app.getErrorString2(Does_not_match_work_list_entry, railJob.id, wle.job.id), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	targetLocation := wagon.getNextFreeWagonContForWLE(ti, wle);
	
	if targetLocation = null then
		if app.msgBox(app.getErrorString2(ERR_NO_SPACE, ti.id, wagon.id), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;	
	
	if not self.validate(ta,targetLocation,false) then					//27.03.2025 navhl20 #34493
		return;
	endif;
	
	if ti.myPrimaryActualLocation = targetLocation then
		if app.msgBox(app.getErrorString2(Cargo_already_located, ti.id, targetLocation.getID), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	//Checks user can access the location
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		if app.msgBox(app.getErrorString3(ERR_USER_NO_ACCESS, app.getMyUser.userName, targetLocation.auditId, null), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	//Check Ti Cargo type to get weight/quantity info for break bulk
	if ti.myCargoType &lt;&gt; null and ti.myCargoType.allowDuplicates then
		if ti.isBulkByQuantity then
			quantity := ti.totalQuantity;					//13.12.2024 navbs1 #33190
		else
			weight := ti.weight;							//13.12.2024 navbs1 #33190
			if  ti.myCargoType.isTrackByVolume then			
				weight := weight * ti.getDensity;		
			endif;
		endif;
	endif;
	
	if wle = null then																							//13.06.2024 navhl20 #64602
		wle := railJob.getFirstWle();
	endif;
	
	if not app.myPassport.warningsAcknowledged and self.tblAvailCargo.allSelectedObjects.size = 1 then			//11.06.2025 navhl20 #34584
		ti := self.tblAvailCargo.allSelectedObjects.first.CM_TrackedItem;
		if ti.totalQuantity &gt; 1 or
		ti.isBulkByWeight then
			self.showMoveAmountForm(ti,quantity,weight);
		endif;
	endif;

	if self.tblAvailCargo.allSelectedObjects.size = 1 then														//11.06.2025 navhl20 #34584
		self.doSaveRailLoad(ti, quantity, weight, wle, railJob, targetLocation, effectiveDate);
	else
		foreach ti in self.tblAvailCargo.allSelectedObjects as CM_TrackedItem do
			wle := self.myJob.getFirstWle();
			quantity := ti.totalQuantity;
			if wle.weight &gt; 0 then
				weight := ti.totalWeight;	
			endif;
			self.doSaveRailLoad(ti, quantity, weight, wle, railJob, targetLocation, effectiveDate);
		endforeach;
	endif;
	
	if app.myPassport.trxCompletedOK then																		//16.06.2025 navhl20 #34584
		create tiSet transient;
		self.tblAvailCargo.allSelectedObjects.tryCopy(tiSet);
		foreach ti in tiSet as CM_TrackedItem do
			if self.myJob.CM_RailJob.allReleaseTrackedItems.includes(ti) then
				self.tblAvailCargo.removeItemObject(ti);
				tblString := ti.getAttributeStringForDefArray(self.tblCompletedCargo.allTblDataEntRows);
				row := self.tblCompletedCargo.addItemObject(ti,tblString);
				self.tblCompletedCargo.accessRow(row).backColor := Grey;
				self.tblCompletedCargo.accessRow(row).foreColor := White;
			endif;
		endforeach;
	endif;
epilog
	delete allRequests;
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReloadTables" id="93891bd1-813b-4e73-ac5d-ab4311c84d0e">
        <source>doReloadTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	if self.myJob.isJobComplete then
		self.btnDoOperation.enabled := false;
	endif;
	
	self.loadTblAvail();		//Notifications should handle this??
		
	if not self.chkHideCompleted.value then
		self.loadTblCompleted();	//Notifications should handle this??
	endif;
	
	if self.tblAvailCargo.rows = 1 then
		self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
		self.btnDoOperation.enabled := false;
	endif;
	
	self.setTblDataCount();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="ace8bc28-fa0f-4949-8486-6124b765aec6">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
25 Apr 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
*/

vars

begin
	inheritMethod();
	if self.chkHideCompleted.value and self.shtJob.visible then
		self.grpLocation.top := self.grpAvail.top + self.grpAvail.height + 5;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceComplete" id="5f4be61c-e2f6-40e7-a0e0-b600b9da3073">
        <updating/>
        <source>doResourceComplete() updating;
/*
Purpose:			

Date		Who		Reason
15 March 2024	navab1	CR 62818 TASK 62821
17 Jul 2024 navlc30 ChangeRequest 64690 Task 64691: EUP - FR | 54177 - Retrospective Operations - 1
28 Aug 2024 navhl20	Bug 65538: EUP | Retrospective date/time is not recorded on the cargo for the VAS work orders
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	toDoTask, task	: CM_ToDoTask;
	toDoTaskDesc 	: CM_ToDoTaskDesc;
	theReturn		: Integer;
	effectiveDate	: TimeStamp;
begin
	if self.myWLE = null then
		return;
	endif;
	
	effectiveDate := self.getEffectiveDate();											//27.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	app.myPassport.setRetrospectiveDT(effectiveDate);
	
	toDoTask := self.myWLE.CM_WOToDoWLE.myToDoTask;

	if toDoTask = null then
		if self.myWLE.job &lt;&gt; null then
			toDoTaskDesc := self.myWLE.job.CM_WOToDoTaskJob.myToDoTaskDesc;
			if toDoTaskDesc &lt;&gt; null then
				foreach task in self.myWLE.myTrackedItem.allToDoTasksToDo where task.toDoTaskDesc = toDoTaskDesc do
					toDoTask := task;
					break;
				endforeach;
			endif;
		endif;
	else
		toDoTaskDesc :=toDoTask.toDoTaskDesc;
	endif;
	
	if toDoTaskDesc &lt;&gt; null then
		toDoTaskDesc.validateResourceUsage(self.allProxyResTypeUsages);
	endif;
	
	if self.myWLE.isForToDoWOTransaction() then
		while true do
			app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(self.myWLE.CM_WOToDoWLE,toDoTask.CM_TiToDoTask,self.allProxyResTypeUsages,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
		endwhile;
		
		return;
	endif;
		
	self.doResourceCompleteTI(toDoTaskDesc);				//27.03.2025 navhl20 #34493
	return;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceCompleteTI" id="88fd2d1f-2674-4b0b-a137-46ca25bd6d60">
        <updating/>
        <source>doResourceCompleteTI(_toDoTaskDesc : CM_ToDoTaskDesc)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	tiSet 		: CM_TISet;
	wle			: CM_WorkListEntry;
	ti			: CM_TrackedItem;
	hasToDoTask : Boolean;
	theResult 	: Integer;
begin
	create tiSet transient;
	foreach wle in self.myWLE.job.CM_WOToDoTaskJob.workListEntries do
		ti := wle.CM_WOToDoWLE.myTrackedItem;
		if ti &lt;&gt; null then
			hasToDoTask := ti.allToDoTasksToDo.includesToDoDesc(_toDoTaskDesc.code);
			
			if not hasToDoTask then
				continue;
			endif;
			
			tiSet.addNoDuplicates(ti,false);
		endif;
	endforeach;

	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(_toDoTaskDesc, tiSet, self.allProxyResTypeUsages, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doResourceCompleteVAS" id="60a353b0-7e6e-4f54-86b4-dd99f4fb11a1">
        <updating/>
        <source>doResourceCompleteVAS() updating;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
12 Nov 2024	navbs1	Initial creation Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/
 
vars
 
	task			: CM_ToDoTask;
	toDoTaskDesc 	: CM_ToDoTaskDesc;
	wle				: CM_WorkListEntry;
	theResult 		: Integer;
	effectiveDate,
	retroDate		: TimeStamp;
	object			: CM_Object;
	wodl 			:CM_WorkOrderToDoDtl;
begin
	if self.myWLE = null then
		return;
	endif;
	
	wle:= self.myWLE;
 
	effectiveDate := self.getEffectiveDate();				//27.03.2025 navhl20 #34493
 
	
	if not self.validateDateTime(effectiveDate) then
		return;
	endif;
	
	app.myPassport.setRetrospectiveDT(effectiveDate);
	
	task := wle.CM_WOToDoWLE.myToDoTask;
	toDoTaskDesc :=task.toDoTaskDesc;
	
	if toDoTaskDesc &lt;&gt; null then
		toDoTaskDesc.validateResourceUsage(self.allProxyResTypeUsages);
	endif;
	
	wodl := wle.job.myWorkOrderDtlToDo;
	
	if task.isKindOf(CM_TrainToDoTask) then
		object := task.CM_TrainToDoTask.myTrainToDo;
	elseif task.isKindOf(CM_WagonToDoTask) then
		object := task.CM_WagonToDoTask.myWagonToDo;
	elseif task.isKindOf(CM_VBSToDoTask) then
		object := task.CM_VBSToDoTask.myVBSToDo;
	elseif task.isKindOf(CM_NonOpsToDoTask) then
		object := task.CM_NonOpsToDoTask.myDebtorToDo;
	elseif task.isKindOf(CM_VoyageToDoTask) then
		object := task.CM_VoyageToDoTask.myVoyageToDo;	
	elseif task.isKindOf(CM_VehicleVisitRecordToDoTask) then
		object := task.CM_VehicleVisitRecordToDoTask.myVVRToDo;
	endif;	
	
	while true do																										
		app.myTrxUA.trxUpdateVasToDoTaskComplete(object, task.toDoTaskDesc.code, app.myPassport, self.allProxyResTypeUsages, wodl);
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
epilog
 
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceDelete" id="1314e1f5-461d-4cec-994b-d983506a5fd6">
        <updating/>
        <source>doResourceDelete() updating;
/*
Purpose:			

Date		Who		Reason
14 March 2024	navab1	CR 62818 TASK 62821 
*/

vars
	resType : CM_ResourceType;
begin
	if self.myCurrentProxyUsage = null then
		return;
	endif;
	
	resType :=  self.myCurrentProxyUsage .myResourceType;
	
	self.allProxyResTypeUsages.removeIfPresent(self.myCurrentProxyUsage);
	delete self.myCurrentProxyUsage;
	self.clearResourceDetails();
	self.tblResources.accessCell(self.tblResources.row,4).text := "";
	self.tblResources.accessRow(self.tblResources.row).itemObject := resType;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceUpdate" id="ee71fcf5-7ae2-4397-a260-2f613f6c6cc9">
        <updating/>
        <source>doResourceUpdate() updating;
/*
Purpose:			

Date		Who		Reason
14 Mar 2024	navab1	CR 62818 TASK 62821 
27 Aug 2024 navhl20	Bug 65788: EUP | VAS - Job complete discrepancies between Todo mobile app and Thin client
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	proxy 		  			: CM_ResourceTypeUsage;
	realUsage 	  			: CM_ResourceTypeUsage;
	lResourceType 			: CM_ResourceType;
	lNoCharge 	  			: Boolean;
	lQuantity 	  			: Decimal [23,4];
	lRemarks 	  			: String;
	lStatus 	  			: Integer;
	lFromDateTime,
	lToDateTime	  			: TimeStamp;
	result		  			: Integer;
	palletType    			: CM_PalletType;
	isHeatTreated   		: Boolean;
	isStoreOnPallet 		: Boolean;
	autoApplyResourceType 	: CM_ResourceType;
	proxyAutoApply 		  	: CM_ResourceTypeUsage;
	theReturn 				: Integer;
	toDoTask, task 			: CM_ToDoTask;
	toDoTaskDesc 			: CM_ToDoTaskDesc;
begin
	// populate local variables with the data.
	lResourceType := self.mySelectedResType;

	lQuantity := txtUnits.text.asDecimalJMT();
	lNoCharge := self.chkNoCharge.value;
	lRemarks := self.txtRemarks.text;
	if not self.chkVoid.value then
		lStatus := CM_InvoiceLine.STATUS_NORMAL;
	else
		lStatus := CM_InvoiceLine.STATUS_VOIDED;
	endif;
	
	lFromDateTime.setDate(self.txtFromDate.text.asDateJMT);
	lFromDateTime.setTime(self.txtFromTime.text.asTimeJMT);
	lToDateTime.setDate(self.txtToDate.text.asDateJMT);
	lToDateTime.setTime(self.txtToTime.text.asTimeJMT);
	
	if self.frmPallet.visible then
		palletType := self.cmbPalletType.listObject.CM_PalletType;
		isHeatTreated := self.chkHeatTreated.value;
		isStoreOnPallet := self.chkStoreOnP.value;
	endif;
	
	if lResourceType = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A) &amp;  " " &amp; app.getErrorString(Resource_usage), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	// if no current proxy to update, create new proxy.
	if self.myCurrentProxyUsage = null then
		create proxy transient;
		self.myCurrentProxyUsage := proxy;
	else
		proxy := self.myCurrentProxyUsage;
	endif;
	
	proxy.setProxy(	lResourceType,
					null, 
					lNoCharge,	
					lQuantity,	
					lRemarks,	
					lStatus,	
					lFromDateTime,		
					lToDateTime,		
					palletType,	
					isHeatTreated,	
					isStoreOnPallet	
					);
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);	//27.08.2024 navhl20 #65788
	app.setContinueCMExceptions(true);										//27.08.2024 navhl20 #65788
	app.myPassport.clearErrorsWarnings();									//27.08.2024 navhl20 #65788
	
	proxy.validateForCreate();												//27.08.2024 navhl20 #65788
	
	if app.myPassport.hasErrorsOrWarnings then								//27.08.2024 navhl20 #65788
		result	:= app.showErrorWarningDialog(	app.getErrorString( ToDoTaskResources ),
												app.myPassport,
												ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
		if app.myPassport.hasErrors or result &lt;&gt; IDOK then
			return;
		endif;
	endif;
					
	self.allProxyResTypeUsages.addNoDuplicates(proxy, false);
	self.tblResources.accessRow(self.tblResources.row).itemObject := proxy;
	self.tblResources.accessCell(self.tblResources.row,4).text := "Yes";
	self.btnResDelete.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66108

	if self.myCurrentProxyUsage &lt;&gt; null then
		realUsage := self.myCurrentProxyUsage.pxyGetRealObject().CM_ResourceTypeUsage;
		if realUsage &lt;&gt; null then
			if not realUsage.allInvoiceLines.isEmpty then
				app.msgBox( app.getErrorString(Changing_Invoiced_Resource), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			endif;
		endif;
	endif;

epilog

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveRailLoad" id="5ab7e87b-c408-44c9-abbc-12cd1c9d7255">
        <source>doSaveRailLoad(_ti 			   : CM_TrackedItem;
			   _quantity 	   : Integer io; 
			   _weight 		   : Decimal io; 
			   _wle 		   : CM_WorkListEntry;
			   _railJob 	   : CM_RailJob;
			   _targetLocation : CM_LocationsController;
			   _effectiveDate  : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
11 Jun 2025	navhl20 Bug MTN-34584: MTN - Work Order Operations - Rail Load Behaviour when choosing multiple items to load
*/

vars
	moveController	: CMIF_MoveController;
	mobileAgent		: CMIF_MobileGenericAgent;
	obj             : CM_Association;
	wle				: CM_WorkListEntry;
	result			: Integer;
	isMulti,
	loop,
	useMoveControl	: Boolean;
begin
	if _effectiveDate &lt;&gt; null then
		create obj transient;
		obj.setValue(_effectiveDate);
	endif;
	
	wle := _wle;
	isMulti := self.tblAvailCargo.allSelectedObjects.size &gt; 1;
	loop := true;
	useMoveControl := wle &lt;&gt; null and ( wle.myTrackedItem = null or wle.myTrackedItem.isTBAorIsRRP );
	
	if useMoveControl then
		create moveController transient;
		moveController.setMyWorkListEntry(wle);
		moveController.setMyToPrimaryLocation(_targetLocation);
		moveController.setMyTrackedItem(_ti);
		moveController.setQuantity(_quantity);
		moveController.setWeight(_weight);
		moveController.retrospectiveDT := _effectiveDate;
	endif;
	
	while true do
		if useMoveControl then
			if not isMulti then
				if self.completeChecks(_ti, CARGO_CHECK_CONTEXT_RAIL_REL, _effectiveDate) then
					app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
				endif;
			else
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
			endif;
		else
			create mobileAgent transient;
			if not isMulti then
				if self.completeChecks(_ti, CARGO_CHECK_CONTEXT_RAIL_REL, _effectiveDate) then
					mobileAgent.moveTI(_ti, null, _targetLocation, _wle, true, _quantity, _weight, obj);
				endif;
			else
				mobileAgent.moveTI(_ti, null, _targetLocation, _wle, true, _quantity, _weight, obj);
			endif;
		endif;
		
		if app.myPassport.trxCompletedOK then
			loop := false;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				loop := false;
			endif;
		endif;
		
		return; //Bail as we cannot save if theres errors
	endwhile;
epilog
	if moveController &lt;&gt; null then
		delete moveController;
	endif;
	delete obj;
	if mobileAgent &lt;&gt; null then
		delete mobileAgent;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_railJob" type="CM_RailJob"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doSaveStartStop" id="97dc059b-532c-4ed1-b6dd-15ab0fd8b812">
        <source>doSaveStartStop();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops

*/

vars
	form	: CMUI_StartStopJobActivity;
	job		: CM_Job;
	ti		: CM_TrackedItem;
begin
	job := self.myJob;
	
	if job = null then
		return;
	endif;
	
	create form transient;
	
	if form = null then
		return;
	endif;
	
	form.setMyJob(job);
	ti := self.tblParent.allSelectedObjects.first.CM_TrackedItem;
	form.setMyTrackedItem(ti);
	form.doSave();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShipDischargeBulk" id="99d846ed-03a0-4501-87d2-db6a66c0d2f9">
        <updating/>
        <source>doShipDischargeBulk()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
02 Apr 2024 navhl20	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
25 Apr 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
07 May 2024 navhl20 ChangeRequest 64031: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective)
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024 navlc30 Bug 65501: Performance Issue - The progress bar never goes away when discharging the cargo group using the complete job form
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
20 Feb 2025	navbs1 	Bug MTN-34096: Cargo Items are not Refreshed/Removed from the Complete Job form after loading
*/

vars
	targetLocation	: CM_LocationsController;
	effectiveDate	: TimeStamp;
	ta				: CM_TerminalArea;
	tiset,
	movedTiSet		: CM_TISet;
	woJob			: CM_Job;
	moveController  : CMIF_MoveController;
	prof    	    : JadeProfiler;
	folder   	    : String;
	clock			: String;
	time,
	count 			: Integer;
	isCargoGrp		: Boolean;
	ti				: CM_TrackedItem;
	trackByWeight	: Boolean;
	startTM			: Decimal[19,0];
begin
	if process.isMohamed then
		app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	endif;
	ta 			   := self.cmbTerminalArea.listObject.CM_TerminalArea;
	targetLocation := self.getTragetLocation();
	time 		   := self.txtOpTime.text.Integer * 1000;
	count		   := self.txtCount.text.Integer;
	isCargoGrp 	   := self.chkCargoGroup.value;
	
	effectiveDate := self.getEffectiveDate();																//28.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then														//26.09.2024 navhl20 #14712
		return;
	endif;
	
	if not self.validate(ta,targetLocation,false) then														//07.05.2024 navhl20 #64031	//27.03.2025 navhl20 #34493
		return;
	endif;
	
	if self.myJob.isVoyageWorkpointJob then																	//04.04.2025 navhl20 #34493
		woJob := self.myJob.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
	endif;
	
	create tiset transient;
	create movedTiSet transient;	
	
	//03.12.2024  navbs1  #33570 START
	self.getSelectedObjects(self.tblAvailCargo, tiset);
	//03.12.2024  navbs1  #33570 END
	
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(targetLocation);
	moveController.setMoveMode(REAL_MODE); 
	moveController.setIsFromWeb(false); 
	moveController.myVoyageWPJob   := self.myJob.CM_VoyageWorkPointJob;
	moveController.transferType    := self.myJob.CM_VoyageWorkPointJob.transferType;
	moveController.retrospectiveDT := effectiveDate;														//07.05.2024 navhl20 #64031
	moveController.setMoveContext(moveController.CONTEXT_BULK_REAL_DISCHARGE);
	
	ti := tiset.first;																						//20.02.2024 navbs1 #34096
	trackByWeight := ti.isBulkByWeight;																		//20.02.2024 navbs1 #34096
	
	if tiset.size = 1 and not self.isBulkMode then															//29.05.2024 navhl20 #64345
		if ti.totalQuantity &gt; 1 or (trackByWeight and ti.totalWeight &gt; 1) then								//09.12.2024 navhl20 #33643
			if app.myMoveController = null or not app.isValidObject(app.myMoveController) then
				app.myMoveController := moveController;
			endif;
			moveController.setMyTrackedItem(ti);
			self.myAssistant.showMoveAmountForm(moveController);
		endif;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	
	self.displayMonitorForBulkMove();
	
	self.doCompleteShip(tiset,moveController,time,count,isCargoGrp,ti,trackByWeight,false,null);					//28.03.2025 navhl20 #34493
epilog
	delete tiset;
	delete movedTiSet;																						//12.08.2024 navlc30 #65501
	if app.myMoveController &lt;&gt; moveController then
		delete moveController;
	endif;
	delete app.myPassport.myCMIFMonitor;

	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;
	app.myRoot.stopJadeProfiler(prof,startTM);
end;</source>
    </JadeMethod>
    <JadeMethod name="doShipDischargeBulkDLRT" id="6aef6eac-1bde-443f-8684-0297601b7498">
        <updating/>
        <source>doShipDischargeBulkDLRT() updating;
/*
Purpose:			DLRT = DEAD LOCK RE-TRY. If get a dead lock the transaction will be aborted and this method will pause, loop round and retry the TRX. It will do this 10 times

Date		Who		Reason
30 May 2024	navab1	CR 64297 TASK 64359
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
*/

vars
	localCaption : String;
begin

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		
		//call the code that was originally in this method
		self.doShipDischargeBulk();	// original code 
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.hadDeadlock = false then
			return;
		endif;
		
		self.caption := localCaption &amp; " DLRT " &amp; app.myPassport.silentDeadlockRetryCount.String;
		
		//OK so we had a deadlock, log it, and get ready to retry if appropriate
		if app.myPassport.silentDeadlockRetryCount &lt; app.myPassport.silentDeadlockLimit then
			// give the other guy a chance to do his processing and release the locks we want.
			process.sleep(app.myPassport.silentDeadlockSleepTime);
		
			//reset the boolean ready to try again.
			app.myPassport.hadDeadlock := false;
		else
			//We did deadlock, and we returned from 'doSave' before we had a chance to pop up a message to the user, so tell'em now.
			app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			return;
		endif;
		
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818

	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doShipDischargeBulkSU" id="415bb0d5-2d3a-478d-8c12-e798a6cc1abc">
        <updating/>
        <source>doShipDischargeBulkSU() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024 navhl20 ChangeRequest 64271: EUP - Improve Bulk Discharge - Retrospective Screen
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024 navlc30 Bug 65501: Performance Issue - The progress bar never goes away when discharging the cargo group using the complete job form
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
*/

vars
	targetLocation	: CM_LocationsController;
	effectiveDate	: TimeStamp;
	ta				: CM_TerminalArea;
	tiset,
	movedTiSet		: CM_TISet;
	woJob			: CM_Job;
	moveController  : CMIF_MoveController;
	prof    	    : JadeProfiler;
	folder   	    : String;
	clock			: String;
	time,
	count,
	idx				: Integer;
	isCargoGrp		: Boolean;
	ti				: CM_TrackedItem;
	tiSetPart       : CM_TISet;
	cnt				: Integer;
	colSize         : Integer;
	lastTi			: CM_TrackedItem;
	cmifMonitor		: CMIF_Monitor;
	trackByWeight	: Boolean;
begin
	if process.isMohamed then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 50;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - Bulk Retro new - " &amp; clock &amp;".txt";
		prof.clearMethodCache();
		prof.start;
	endif;
	
	ta 			   := self.cmbTerminalArea.listObject.CM_TerminalArea;
	targetLocation := self.getTragetLocation();
	time 		   := self.txtOpTime.text.Integer * 1000;
	count		   := self.txtCount.text.Integer;
	isCargoGrp 	   := self.chkCargoGroup.value;
	
	effectiveDate := self.getEffectiveDate();											//28.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	if not self.validate(ta,targetLocation,false) then									//27.03.2025 navhl20 #34493
		return;
	endif;
	
	if self.myJob.isVoyageWorkpointJob then												//04.04.2025 navhl20 #34493
		woJob := self.myJob.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
	endif;
	
	create tiset transient;
	create movedTiSet transient;
	
	//03.12.2024  navbs1  #33570 START
	self.getSelectedObjects(self.tblAvailCargo, tiset);
	//03.12.2024  navbs1  #33570 END
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(targetLocation);
	moveController.setMoveMode(REAL_MODE); 
	moveController.setIsFromWeb(false); 
	moveController.myVoyageWPJob   := self.myJob.CM_VoyageWorkPointJob;
	moveController.transferType    := self.myJob.CM_VoyageWorkPointJob.transferType;
	moveController.retrospectiveDT := effectiveDate;
	moveController.setMoveContext(moveController.CONTEXT_BULK_REAL_DISCHARGE);
	
	if tiset.size = 1 and not self.isBulkMode then															//29.05.2024 navhl20 #64345
		ti := tiset.first;
		trackByWeight := ti.isBulkByWeight;
		if ti.totalQuantity &gt; 1 or (trackByWeight and ti.totalWeight &gt; 1) then								//09.12.2024 navhl20 #33643
			if app.myMoveController = null or not app.isValidObject(app.myMoveController) then
				app.myMoveController := moveController;
			endif;
			moveController.setMyTrackedItem(ti);
			self.myAssistant.showMoveAmountForm(moveController);
		endif;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	
	self.displayMonitorForBulkMove();
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	colSize := tiset.size;
	lastTi  := tiset.last;
	
	create tiSetPart transient;
	foreach ti in tiset do
		if cnt = 0 then
			tiSetPart.clear();
		endif;
		cnt := cnt + 1;
		idx := idx + 1;
		
		tiSetPart.tryAdd(ti);
		
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.partsDone := idx;
			cmifMonitor.updateProgress('Bulk Cargo Move', cmifMonitor.partsInJob, cmifMonitor.partsDone);
			if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				break;
			endif;
		endif;
		
		if cnt = 100 or lastTi = ti then
			self.doCompleteShip(tiset,moveController,time,count,isCargoGrp,ti,trackByWeight,false,null);			//28.03.2025 navhl20 #34493
			cnt := 0;
		endif;
		
	endforeach;
epilog
	delete tiset;
	delete movedTiSet;																														//12.08.2024 navlc30 #65501
	if app.myMoveController &lt;&gt; moveController then
		delete moveController;
	endif;
	delete app.myPassport.myCMIFMonitor;

	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;
	
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShipLoadBulk" id="d6c55a99-50da-424b-a93a-25ca76aa6580">
        <updating/>
        <source>doShipLoadBulk()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Apr 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
07 May 2024 navhl20 ChangeRequest 64031: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective)
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024 navlc30 Bug 65501: Performance Issue - The progress bar never goes away when discharging the cargo group using the complete job form
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
31 Jan 2025	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
20 Feb 2025	navbs1 	Bug MTN-34096: Cargo Items are not Refreshed/Removed from the Complete Job form after loading
28 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	targetLocation	: CM_LocationsController;
	effectiveDate	: TimeStamp;
	tiset			: CM_TISet;
	woJob			: CM_Job;
	moveController  : CMIF_MoveController;
	prof    	    : JadeProfiler;
	folder   	    : String;
	clock			: String;
	time,
	count,
	quantity		: Integer;
	isCargoGrp		: Boolean;
	ti				: CM_TrackedItem;
	release			: CM_BulkRelease;
	resSel			: CM_ReserveDetail;
	weight			: Decimal[12,4];
	trackByWeight	: Boolean;
begin
	
	if process.isMohamed or process.isHari then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 50;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - Bulk Retro - " &amp; clock &amp;".txt";
		prof.clearMethodCache();
		prof.start;
	endif;
	
	targetLocation 	:= self.cmbVoyLocation.listObject.CM_LocationsController;
	time 		   := self.txtOpTime.text.Integer * 1000;
	count		   := self.txtCount.text.Integer;
	isCargoGrp 	   := self.chkCargoGroup.value;
	
	effectiveDate := self.getEffectiveDate();											//31.03.2025 navhl20 #34493
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	if not self.validate(null,targetLocation,false) then			//07.05.2024 navhl20 #64031	//27.03.2025 navhl20 #34493
		return;
	endif;
	
	self.getReleaseFromJobShipRel(resSel,release);										//31.03.2025 navhl20 #34493
	
	if self.myJob.isVoyageWorkpointJob then												//04.04.2025 navhl20 #34493
		woJob := self.myJob.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
	endif;
	
	create tiset transient;											//12.08.2024 navlc30 #65501
	
	//03.12.2024  navbs1  #33570 START=
	self.getSelectedObjects(self.tblAvailCargo, tiset);
	//03.12.2024  navbs1  #33570 END
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(targetLocation);
	moveController.setMoveMode(REAL_MODE); 
	moveController.setIsFromWeb(false); 
	moveController.myVoyageWPJob   := self.myJob.CM_VoyageWorkPointJob;
	moveController.transferType    := self.myJob.CM_VoyageWorkPointJob.transferType;
	moveController.retrospectiveDT := effectiveDate;								//07.05.2024 navhl20 #64031
	
	ti := tiset.first;																//20.02.2024 navbs1 #34096
	trackByWeight := ti.isBulkByWeight;												//20.02.2024 navbs1 #34096
	
	self.getAmountToLoadShip(tiset,moveController,weight,quantity,trackByWeight,ti);//31.03.2025 navhl20 #34493
	
	if release &lt;&gt; null and release.releaseByType then
		resSel.validateWeightQuantityAdd(	quantity, weight, true );																	//09.12.2024 navhl20 #33643
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	
	self.displayMonitorForBulkMove();
	
	self.doCompleteShip(tiset,moveController,time,count,isCargoGrp,ti,trackByWeight,true,woJob);												//31.03.2025 navhl20 #34493
epilog
	delete tiset;
	if app.myMoveController &lt;&gt; moveController then
		delete moveController;
	endif;
	delete app.myPassport.myCMIFMonitor;

	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShipLoadBulkDLRT" id="de296b51-f2cd-4c57-a5aa-25ab33dd73f0">
        <updating/>
        <source>doShipLoadBulkDLRT() updating;
/*
Purpose:			DLRT = DEAD LOCK RE-TRY

Date		Who		Reason
06 June 2024	navab1	CR 64297 TASK 64359
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
*/

vars
	localCaption : String;
begin

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(200, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		
		//call the code that was originally in this method
		self.doShipLoadBulk();	// original code 
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.hadDeadlock = false then
			return;
		endif;
		
		self.caption := localCaption &amp; " DLRT " &amp; app.myPassport.silentDeadlockRetryCount.String;
		
		//OK so we had a deadlock, log it, and get ready to retry if appropriate
		if app.myPassport.silentDeadlockRetryCount &lt; app.myPassport.silentDeadlockLimit then
			// give the other guy a chance to do his processing and release the locks we want.
			process.sleep(app.myPassport.silentDeadlockSleepTime);
		
			//reset the boolean ready to try again.
			app.myPassport.hadDeadlock := false;
		else
			//We did deadlock, and we returned from 'doSave' before we had a chance to pop up a message to the user, so tell'em now.
			app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			return;
		endif;
		
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818

	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblResClick" id="c2009160-9b65-40a5-b459-c617dca544ee">
        <updating/>
        <source>doTblResClick() updating;
/*
Purpose:			

Date		Who		Reason
14 Mar 2024	navab1	CR 62818 TASK 62821 
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	type : CM_ResourceType;
	decPlaces : Integer;
	selectedObj : CM_Object;
begin
	selectedObj := self.tblResources.allSelectedObjects.first.CM_Object;
	if selectedObj = null then
		return;
	endif;
	
	self.grpResource.enabled := true;
	self.btnResDelete.enabled := false;
	
	if selectedObj.isKindOf(CM_ResourceTypeGroup) then
		self.grpResource.enabled := false;
		return; // ### JIRA 33435 10JAN2025 NAVAB1
	elseif selectedObj.isKindOf(CM_ResourceType) then
		type := selectedObj.CM_ResourceType;
		self.mySelectedResType := type;
		self.clearResourceDetails();
		
		//
		if type &lt;&gt; null then
			decPlaces := type.decimalPlaces;
			
			if type.isFromToDateTimeRequired then
				self.frmFromToDate.visible := true;
			else 
				self.frmFromToDate.visible := false;
			endif;
		endif;
		
		self.txtUnits.text := null;
		// clear before setting length, so it can never be too long
		self.txtUnits.decimals := 0;
		self.txtUnits.maxLength := decPlaces + 9;
		if decPlaces = null then						
			self.txtUnits.maxLength := decPlaces + 8;		
		endif;										
		self.txtUnits.decimals := decPlaces;
		
		if type &lt;&gt; null then
			self.lblUnits.caption := type.unitDescription &amp; ":";
		else
			self.lblUnits.caption := app.getErrorString(Units) &amp; ":";
		endif;
		
		self.doMakePalletStuffVisible( type );			
		//
	elseif selectedObj.isKindOf(CM_ResourceTypeUsage) then
		self.myCurrentProxyUsage := selectedObj.CM_ResourceTypeUsage;
		type := self.myCurrentProxyUsage.myResourceType;
		// ### JIRA 33435 13JAN2025 NAVAB1 notice this was crashing
		if type &lt;&gt; null then
			decPlaces := type.decimalPlaces;
			self.txtUnits.maxLength := decPlaces + 9;
			if decPlaces = null then						
				self.txtUnits.maxLength := decPlaces + 8;		
			endif;										
			self.txtUnits.decimals := decPlaces;
		endif;
		
		self.btnResDelete.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66108
		
		decPlaces := self.myCurrentProxyUsage.myResourceType.decimalPlaces;
		self.txtUnits.text := self.myCurrentProxyUsage.quantity.asStringJMTWithPrecision(decPlaces,false);
		self.txtFromDate.setDate(self.myCurrentProxyUsage.fromDateTime.date);
		self.txtFromTime.setTime(self.myCurrentProxyUsage.fromDateTime.time);
		self.txtToDate.setDate(self.myCurrentProxyUsage.toDateTime.date);
		self.txtToTime.setTime(self.myCurrentProxyUsage.toDateTime.time);
		self.chkNoCharge.value := self.myCurrentProxyUsage.noCharge;
		self.chkVoid.value := self.myCurrentProxyUsage.isVoid;
		self.txtRemarks.text := self.myCurrentProxyUsage.remarks;
	endif;

	self.lblResTypeName.caption := self.mySelectedResType.description;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTruckLoad" id="3d70d091-497d-40be-be98-eb73486088f6">
        <updating/>
        <source>doTruckLoad()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
19 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
13 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
27 Mar 2024 navhl20 Defect 63195: Null object reference error when multiselecting the items on the Complete Job form
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
25 Oct 2024 navah1	Defect 33187: After loading the cargo items on the complete job form the page is not refreshing properly
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
26 Dec 2024	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
20 Feb 2025	navbs1 	Bug MTN-34096: Cargo Items are not Refreshed/Removed from the Complete Job form after loading
20 Mar 2025	navah1	Defect 34418: 1090 exception when loading the cargo item for road job on the complete job form
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
24 Jun 2025	navbs1  Bug MTN-35184: MTN - 1090 exception on the complete job form when loading the cargo item for the release road job
*/

vars
	ti						: CM_TrackedItem;
	tiSet					: CM_TISet;
	effectiveDate			: TimeStamp;
	tblAvail,
	tblComplete				: CM_DataTable;
	myWle					: CM_WorkListEntry;
	resDetl					: CM_ReserveSelection;
	targetLocation			: CM_LocationsController;
	quantity				: Integer;
	idx						: Integer;
	totalQuantity			: Integer;
	weight,
	totalWeight				: Decimal[12,4];
	trackByWeight			: Boolean;
begin
	self.getReleaseDetailsFromWLE(myWle,resDetl);														//24.06.2025 navbs1 #35184	
	
	targetLocation := self.myJob.CM_RoadJob.myVehicle.locationsController;
	effectiveDate := self.getEffectiveDate();															//31.03.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then													//26.09.2024 navhl20 #14712
		return;
	endif;
	
	if not self.validate(null,null,false) then															//27.03.2025 navhl20 #34493
		return;
	endif;
		
	tblAvail	:= self.tblAvailCargo;
	tblComplete := self.tblCompletedCargo;
	
	ti := tblAvail.allSelectedObjects.first.CM_TrackedItem;												//20.02.2024 navbs1 #34096
	trackByWeight := ti.isBulkByWeight;																	//20.02.2024 navbs1 #34096
	
	self.getAmountToLoadTruck(trackByWeight,weight,quantity,ti);										//31.03.2025 navhl20 #34493
	
	if not self.validateTruckLoad(quantity,weight,resDetl) then											//31.03.2025 navhl20 #34493
		return;
	endif;
	
	create tiSet transient;
	
	if tblAvail.allSelectedObjects.size = 1 then														//13.03.2024 navhl20 #62734
		ti := tblAvail.allSelectedObjects.first.CM_TrackedItem;
		totalQuantity := ti.totalQuantity;																//28.10.2024 navah1 #33187
		totalWeight := ti.totalWeight;																	//03.03.2024 navbs1 #34096
		self.doTruckLoadSave(ti, myWle, targetLocation, effectiveDate, false, quantity, weight);		//09.10.2024 navbs1 #19303	//26.12.2024 navhl20 #33648
		
		if app.myPassport.trxCompletedOK then	
			//Add completed cargo to remove from available table
			if ( not trackByWeight and quantity &lt; totalQuantity ) or ( trackByWeight and weight &lt; totalWeight)  then															//28.10.2024 navah1 #33187				//03.03.2024 navbs1 #34096
				if tblAvail.findObjectInRow(ti,idx) then 
					tblAvail.setCellText(idx, 1, ti.getAttributeStringForDefArray(tblAvail.allTblDataEntRows));
				endif;
			else
				tiSet.addNoDuplicates(ti,false);
			endif;
		endif;
	else
		foreach ti in tblAvail.allSelectedObjects as CM_TrackedItem do
			myWle := self.myJob.getFirstWle();
			quantity := ti.totalQuantity;
			weight := ti.totalWeight;	
			self.doTruckLoadSave(ti, myWle, targetLocation, effectiveDate, true, quantity, weight);			//09.10.2024 navbs1 #19303	//26.12.2024 navhl20 #33648

			if app.myPassport.trxCompletedOK then
				//Add completed cargo to remove from available table
				tiSet.addNoDuplicates(ti,false);
			endif;
		endforeach;
	endif;
		
	if app.myPassport.trxCompletedOK then
		if self.myJob.isJobComplete then														//09.10.2024 navhl20 #12389
			self.btnDoOperation.enabled := false;
			self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66108
		endif;
		
		foreach ti in tiSet do 
			tblAvail.removeItemObject(ti);
		endforeach;
		
		if not self.chkHideCompleted.value then 												//20.02.2024 navbs1 #34096
			self.loadTblCompleted();
		endif;
		
		self.setTblDataCount();
	endif;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTruckLoadSave" id="6870caca-8976-48e7-ac04-3971c655b3a9">
        <source>doTruckLoadSave(_ti : CM_TrackedItem; _myWle : CM_WorkListEntry; _targetLocation : CM_LocationsController; _effectiveDate : TimeStamp; _multi : Boolean; _quantity : Integer; _weight : Decimal);		//09.10.2024 navbs1 #19303
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
27 Mar 2024 navhl20 Defect 63189: Unable to complete the job for release work orders in retrospective mode
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
26 Dec 2024	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
*/

vars
	moveController 	: CMIF_MoveController;
	weight 			: Decimal [16,4];
	loop			: Boolean;
	result			: Integer;
begin
	loop := true;
	create moveController transient;
	while loop do
		if app.myMoveController = null or not app.isValidObject(app.myMoveController) then
			app.myMoveController := moveController;
		endif;
		moveController.setMyWorkListEntry(_myWle);
		moveController.setMyToPrimaryLocation(_targetLocation);
		moveController.setMyTrackedItem(_ti);
		moveController.retrospectiveDT := _effectiveDate;
		
		if not _ti.isBulkByWeight then							//26.12.2024 navhl20 #33648	//01.04.2025 navhl20 #34493
			moveController.setQuantity(_quantity);
		else													//26.12.2024 navhl20 #33648
			moveController.setWeight(_weight);
		endif;
		
		if not _multi then
			if self.completeChecks(_ti,CARGO_CHECK_CONTEXT_TRUKLOAD,_effectiveDate) then	//01.04.2025 navhl20 #34493
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
			endif;
		else
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			loop := false;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				loop := false;
			endif;
		endif;
	endwhile;
epilog
	if app.myMoveController &lt;&gt; moveController then
		delete moveController;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_myWle" type="CM_WorkListEntry"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <Parameter name="_multi" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doTruckUnload" id="8dd6d7b2-f776-44f0-971f-c8c3f143ae01">
        <updating/>
        <source>doTruckUnload()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
19 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
20 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	ti						: CM_TrackedItem;
	ta						: CM_TerminalArea;
	targetLocation			: CM_LocationsController;
	tbl						: CM_DataTable;
	tiSet					: CM_TISet;
	effectiveDate			: TimeStamp;
	controller				: CMIF_MobileTruckLoaderUnloader;
	loop,
	multi					: Boolean;
	quantity,
	result					: Integer;
	weight					: Decimal[12,4];
begin
	create controller transient;
	controller.setMyTerminal(self.myTerminal);
	controller.setTruck(self.myJob.CM_RoadJob.myVehicle);
	
	ta 				:= self.cmbTerminalArea.listObject.CM_TerminalArea;
	effectiveDate	:= self.getEffectiveDate();											//01.04.2025 navhl20 #34493
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	targetLocation := self.getTragetLocation();											//01.04.2025 navhl20 #34493
	
	tbl := self.tblAvailCargo;
	
	if not self.validate(ta,targetLocation,false) then									//27.03.2025 navhl20 #34493
		return;
	endif;
	
	loop := true;
	
	create tiSet transient;
	
	if tbl.allSelectedObjects.size &gt; 1 then
		multi := true;
	endif;
	
	while loop do
		if not multi then																//01.03.2024 navhl20 #62705
			ti := tbl.allSelectedObjects.first.CM_TrackedItem;
			self.getAmountToUnloadTruck(ti,weight,quantity);							//01.04.2025 navhl20 #34493
			
			if self.completeChecks(ti,CARGO_CHECK_CONTEXT_TRUKUNLOAD,effectiveDate)then	//01.04.2025 navhl20 #34493
				controller.saveChangesUnload(ti,targetLocation,quantity,weight,effectiveDate);
			endif;
		else
			foreach ti in tbl.allSelectedObjects as CM_TrackedItem do
				controller.setDoNotShowMsgBox(true);									//20.06.2024 navhl20 #64602
				if not controller.saveChangesUnload(ti,targetLocation,ti.totalQuantity,ti.totalWeight,effectiveDate) then
					break;
				endif;
				tiSet.tryAdd(ti);
			endforeach;
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.doReloadTables();														//01.04.2025 navhl20 #34493										
			loop := false;
		else
			foreach ti in tiSet do
				tbl.allSelectedObjects.tryRemove(ti);
			endforeach;
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				loop := false;
			endif;
		endif;
	endwhile;
epilog
	delete controller;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnpack" id="8593ef1d-9b64-4f29-a9fa-733f4c729704">
        <source>doUnpack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
16 Apr 2024 navhl20 Bug 63704: EUP - 1090 exception when clicking on the Unpack button on the Complete Job form
04 Jul 2024 navhl20	Defect 64923: 1308 exception when completing the unpack work order
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
12 Dec 2024 navma1	MTN-33665 MTN - 1090 when trying to complete Unpack Work order
*/

vars
	wod						: CM_WorkOrderTIDtl;
	targetLocation			: CM_LocationsController;
	ti,
	parent,
	firstTI					: CM_TrackedItem;
	result					: Integer;
	effectiveDate			: TimeStamp;
	tiSet					: CM_TISet;
	unpackQuantity			: Integer;
	weight					: Decimal[12,4];
begin
	wod := self.myJob.myWODtl;

	if wod &lt;&gt; null and wod.isWorkOrderForUnpack then									//04.04.2025 navhl20 #34493
		targetLocation := wod.CM_WodUnpack.myUnpackToLocation;
	endif;
	
	effectiveDate := self.getEffectiveDate();											//01.04.2025 navhl20 #34493
	
	if not self.validateDateTime(effectiveDate) then									//26.09.2024 navhl20 #14712
		return;
	endif;
	
	ti := self.tblChild.allSelectedObjects.first.CM_TrackedItem;
	
	if not self.validate(null,targetLocation,true) then									//01.04.2025 navhl20 #34493
		return;
	endif;
	
	parent := ti.myParent;
	
	if self.tblChild.allSelectedObjects.size = 1 then												//17.06.2024 navhl20 #64602
		if not self.completeChecks(ti,CARGO_CHECK_CONTEXT_UNPACK,effectiveDate) then				//01.04.2025 navhl20 #34493
			return;
		endif;
	endif;
	
	create tiSet transient;
	self.tblChild.allSelectedObjects.copy(tiSet);
	
	if tiSet.size = 1 and ti.totalQuantity &gt; 1 then	                                                 //09.10.2024 navbs1 #19303
		self.showMoveAmountForm(ti, unpackQuantity,weight);											 //09.12.2024 navhl20 #33643
	endif;
	
	while true do
		app.myTrxUA.trxUpdateUnpackCargos(tiSet, targetLocation, unpackQuantity,null,true,effectiveDate, app.myPassport);	//05.07.2024 navhl20 #64923		//09.10.2024 navbs1 #19303
		
		if app.myPassport.trxCompletedOK then
			if not parent.hasJobTransactions(self.myJob) then										//17.10.2024 navhl20 #12389
				self.doSaveStartStop();
			endif;
			self.reloadTablesUnpack();																//01.04.2025 navhl20 #34493
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Unpack), app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				return;
			endif;
		endif;
	endwhile;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterTblAvailCargo" id="680c4a35-3505-4264-833e-b7cecb01b1fa">
        <source>filterTblAvailCargo();
