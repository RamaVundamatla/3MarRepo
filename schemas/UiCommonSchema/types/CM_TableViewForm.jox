    <JadeMethod name="doResize" id="098e61ce-0bdf-4ff8-b60d-a49ebe86b8b2">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/04/2017	cnwdap1		TFS 4038 Release Request Form Usability Issues
// ---------------------------------------------------------------------------
vars
	tmpLeftPos 	: Real;
	leftBtn		: Button;
	
begin

	inheritMethod();
	
	tblSearch.top 	:= self.frmSearchToolbar.height;

	self.positionSptMain();
	self.zPositionBottomControls();

	sptMain.cnEcResizeContents();

	if self.isSearcherFloating then
		frmSearch.height := self.frmSearchToolbar.height + self.tblSearch.height + 15;
		frmSearch.centreWindow;								// TFS 4038
	endif;

	if self.isSearcherVisible then
		if frmSearch.left + frmSearch.width &gt; self.clientWidth then
			frmSearch.left := (self.clientWidth - frmSearch.width).max(0);
		endif;
		if frmSearch.top + frmSearch.height &gt; self.clientHeight then
			frmSearch.top := (self.clientHeight - frmSearch.height).max(0);
		endif;
		self.zResetDataFilterRatio();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e3d5b2b0-b29f-423a-9d4e-c9717e5c704a">
