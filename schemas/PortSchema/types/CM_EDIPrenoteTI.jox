    <JadeMethod name="alternativeId" id="473f8f22-89e8-402e-a34d-8ea193177b98">
        <methodInvocation>mapping</methodInvocation>
        <source>alternativeId(set: Boolean; _value: String io) mapping;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, CM_EDIPrenoteTI::alternativeId.name, _value);
	else
		global.getExtraData(self.allExtraData, CM_EDIPrenoteTI::alternativeId.name, _value);
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="assignValueSpecial" id="02c951b9-473a-46f3-b6e2-883fa337de9d">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
Date		Who		Reason
18 Sep 2012	cnwcs5	Initial creation - par 30316
10 May 2013	cnwcs5	par 31626 - make method public so can be used for hook code
20 Oct 2015 cnwma1  PAR #36634 EDI userdefined prenote  doesnot always register null values. (see Par 36548)
17 Nov 2015	cnwma1	PAR #37167 Issue processing inbound cargo
03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
23 Jan 2018 jlgsl4	TFS 36722 Weight decimal places not stored on TI
13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
4 sept 2024 navsaa30 Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
17 Oct 2024	navcs2	MTN-33066 EUP - NTO-980 - "89636: Total Weight Should Not be Zero" Error when Uploading Transport Manifest with weights in kilograms only
07 Nov 2024	navdap1	MTN-33400 MTN - User Defined EDI is not longer loading Volume details
16 Jun 2025	naviv1	MTN-34550 : PEN - Upon update to version 24.12, paper prenotes switch from lbs to kg, remove cargo group ID from check in screens
02 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/
vars
	value					: String;
	contRange : CM_ContRange;
	isWeightZero,							// 17 Oct 2024		navcs2	MTN-33066
	isKg,									// 17 Oct 2024		navcs2	MTN-33066
	shouldChange		: Boolean;			// 17 Oct 2024		navcs2	MTN-33066
	str,									// 17 Oct 2024		navcs2	MTN-33066
	type				: String;			// 17 Oct 2024		navcs2	MTN-33066
	isoTypeObj			: CM_ISOType;			// MTN-36141
begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_propName&amp;' '&amp;_processedValue;
	if _propName = ETRow_CoolingType then
		value	:= _processedValue.toUpper;
		
		if value = 'AIR' or value = 'AC' or value = 'A' or value = ContainerAirCooledStr.toUpper then
			self.coolingType := ContainerAirCooled;
			
		elseif value = 'WATER' or value = 'WC' or value = 'W' or value = ContainerWaterCooledStr.toUpper then
			self.coolingType := ContainerWaterCooled;
			 
		else
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.coolingType := contRange.coolingType;
			else
				self.coolingType := ContainerCooledNull;
			endif;
		endif;
		
		return true;
	// 17/11/2015 cnwma1 PAR #37167	
	elseif _propName = ETRow_PackTempC then
		if _processedValue =  null then		
			self.packTempC := NULL_TEMPERATURE;
		else
			self.packTempC := _processedValue.Real;
		endif;
		return true;
		
	elseif _propName = ETRow_PackTempF then
		if _processedValue =  null then		
			self.packTempF := app.temperatureConversion(true, NULL_TEMPERATURE);   //NULL_TEMPERATURE;   // 16/09/2014 cnwmh5 #34914
		else
			self.packTempF := _processedValue.Real;
		endif;
		return true;
		
	elseif _propName = ETRow_PackTime then
		if _processedValue =  null then		
			self.packTime := NULL_TIME;
		else
			self.packTime := _processedValue.Time;
		endif;
		return true;
		
	elseif _propName = ETRow_TimeAllowedOffPower then // 20/10/2015 cnwma1 PAR #36634
		value	:= _processedValue.toUpper; 
		if _processedValue = null then
			self.setPropertyValue(ETRow_TimeAllowedOffPower, NULL_ALLOWABLE_TIME_OFF_POWER);
		else
			self.setPropertyValue(ETRow_TimeAllowedOffPower, _processedValue.Decimal);
		endif;
		return true;
	// 17/11/2015 cnwma1 PAR #37167	
	elseif _propName = CM_EDIPrenoteTI::temperature.name then
		if _processedValue &lt;&gt; null then
			self.temperature := self.extractNumber(_processedValue.String);
			
			if self.temperature &gt;= 0 then
				self.temperatureSign 		:= '+';
				self.temperatureAbsolute 	:= self.temperature;
			else
				self.temperatureSign 		:= '-';
				self.temperatureAbsolute 	:= self.temperature * (-1);
			endif;
		endif;
		
		return true;
		
	elseif _propName = ETRow_VoltageType then
		value	:= _processedValue.toUpper; 
		
		if value = 'DUAL' or value = 'DV' or value = 'D' or value = ContainerDualVoltStr.toUpper then 
			self.voltageType := ContainerDualVolt;
			
		elseif value = 'SINGLE' or value = 'SV' or value = 'S' or value = ContainerSingleVoltStr.toUpper then
			self.voltageType := ContainerSingleVolt;
			 
		else
			self.voltageType := ContainerVoltNull;
		endif;
		
		return true;
		
	elseif _propName = ETRow_CargoGroupId then	//17 Feb 2016	NDL	Par 37544
		if app.isCargoGroupEnabled then
			self.cargoGroupId := _processedValue.toUpper.trimBlanks; 
		else
			self.cargoGroupId := null;
		endif;
		
	elseif _propName = CM_EDIPrenoteTI::weight.name then
		self.weight := self.extractNumber(_processedValue.String); //.Integer; TFS 36722
		
		return true;
		
	elseif _propName = ETRow_TareWeight then	//15 Nov 2016	NDL	TFS 2959 / 2420
		self.tareWeight := _processedValue.asDecimalJMT;		//4/9/24  navsaa30  #63853
		return true;
		
	elseif _propName = ETRow_CargoWeight then	//15 Nov 2016	NDL	TFS 2959 / 2420
		self.cargoWeight := _processedValue.asDecimalJMT;				//4/9/24  navsaa30  #63853
		return true;
		
	elseif _propName = ETRow_IsCertifiedWeight then							// TFS #1699
		self.isWeightCertified := _processedValue.toUpper.asBooleanJMT;		// TFS #1699
		return true;														// TFS #1699
	
	// jlika1 TFS 53316 --&gt;
	elseif _propName = ETRow_Diameter then
		self.diameter := _processedValue.asDecimalJMT;				//4/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_RollingLength then
		self.rollingLength := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;	
	// jlika1 TFS 53316 &lt;--
	elseif _propName = ETRow_OperatorExportRelNumber then	
		//jlier1 TFS 53030 6/9/22
		self.operatorExportReleaseNumber:=_processedValue.String;
		return true;
	endif;
	
	if _propName.isMeasurementType then	
		_propName.getRowNameMeasureType(str, type);	
		
		//MTN-34550 - Eliminated redundant weight-handling logic and extended unified measurement processing to include dimensions like height, width, and length.
		if str.toLower().cnContains(ETRow_Weight) then 
			if str = ETRow_CargoWeight then
				isWeightZero 	:= self.getCargoWeight = 0;
			elseif str = ETRow_TareWeight then
				isWeightZero 	:= self.getTareWeight = 0;
			elseif str = ETRow_TotalWeight then
				str := ETRow_Weight;
				isWeightZero 	:= self.getTotalWeight = 0;
			endif;
			
			isKg				:= type = self.KGString;
			value 				:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
			shouldChange		:= (isWeightZero and not value = null) or (isKg and not value = null);
		
			if shouldChange then
				if value = null then
					self.setPropertyValue(str, NULL_WEIGHT);
				else
					self.setPropertyValue(str, value.asDecimalJMT); 
				endif;
			endif;
			
			return true;
		endif;
		
		if str.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width,ETRow_OverHeight, ETRow_OverLength, ETRow_OverLengthBack,ETRow_OverLengthFront,ETRow_OverWidth, ETRow_OverWidthLeft,ETRow_OverWidthRight, ETRow_Diameter, ETRow_RollingLength) then	//MTN-34550
			value 	:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT; //MTN-34550
			return inheritMethod(str, value, _xlationOperator);		//MTN-34550
		else																			// MTN-33400
			return self.assignValueSpecial(str, _processedValue, _xlationOperator);		// MTN-33400
		endif;
		
	// MTN-36141 Imex Status, weight and ISO type interactions
	elseif _propName = ETRow_IsoType then
		// Is the ISO Type Rotatable?
		if self.isISOTypeRotatable(isoTypeObj) then
			self.isoType := _processedValue;
			self.tareWeight := isoTypeObj.tareKilos;
			self.imexStatus := app.imexStatusEnumToString(TI_IMEX_STATUS_STORAGE);
			return true;
		endif;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="a0a3221f-d4e1-42b0-b6d0-8d39aea46163">
        <source>canUserSet(_propName: String): Boolean;
//----------------------------------------------------------------
//	Created:	15 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin

	if _propName = CM_EDIPrenoteTI::clean.name 
	or _propName = CM_EDIPrenoteTI::damaged.name
	or _propName = CM_EDIPrenoteTI::imCodes.name
	or _propName = CM_EDIPrenoteTI::preTripped.name then
		return false;
	elseif _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoType" id="4999bbbc-cb50-402b-9575-d1aac8dcf0b2">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoType(set : Boolean; _value : Integer io) mapping;
//
// par 21329 cnwrs1 11 Feb 2010
//
vars
	product 	: CM_Product;
begin
	if set then
	
	else

		if self.cargoType &lt;&gt; null then
			_value := self.cargoType;
		else
			
			if self.cargoType = null then		
				//epr TFS 6980 26/9/17
				product := self.getMyProduct(null, self.operatorCode);				
				if product &lt;&gt; null and  cargoType = 0 then 
					_value := product.myCargoType.id;
				endif;
			else
				_value := self.cargoType;
			endif;
		endif;
	endif;
epilog

end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkForMatchAndSiteLocation" id="769871c5-deac-4f8e-8362-4eba31e30484">
        <source>checkForMatchAndSiteLocation() : String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 July 2009
//
// Implemented version: 7.7.3
//----------------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	terminal 	: CM_Terminal;
	ti 			: CM_TrackedItem;
	siteLocation: String;
	voyageCodeStr	: String;
	
begin
	if app.getMyUserCode() = 'CNWSH3' then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1. ");
	endif;
	
	terminal := self.getMyTerminal();
	
	if terminal &lt;&gt; null then
		voyageCodeStr	:= self.getVoyageCode();	// cnwrl1 09/06/2010 PAR 24299
//		ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NOTIFIED, self.voyageCode, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NOTIFIED, voyageCodeStr, false);
		
		if ti = null then
//			ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NORMAL, self.voyageCode, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
			ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_NORMAL, voyageCodeStr, false);
			if ti = null then
//				ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_OFFSITE, self.voyageCode, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
				ti := terminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_OFFSITE, voyageCodeStr, false);
				if ti &lt;&gt; null then
					siteLocation := 'Offsite';
				else
					siteLocation := 'Unknown';
				endif;
			else
				siteLocation := ti.getPrimaryLocationId(REAL_MODE);
			endif;
		else
			siteLocation := 'Notified';
		endif;
	endif;
	return siteLocation;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkTemperatures" id="4dba60f5-06a9-482c-b5fd-f2c8d54e68bf">
        <updating/>
        <source>checkTemperatures() updating;
//----------------------------------------------------------------
//	Created:	04 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

begin

	if self.temperature = NULL_TEMPERATURE then
		if self.temperatureAbsolute &lt;&gt; NULL_TEMPERATURE.abs() then
			self.temperature := self.getTempFromAbsolute();
		endif;
	else
		if self.temperatureAbsolute = NULL_TEMPERATURE.abs() then
			//set tempAbs
			self.temperatureAbsolute := self.temperature.abs();
			if temperature &lt; 0 then
				self.temperatureSign := '-';
			else
				self.temperatureSign := '+';
			endif;
		endif;
	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="9e7fceb6-321b-4c1c-afaf-83e456f00b4a">
        <updating/>
        <source>create() updating;
//15 September 2008	cnwdw1	
//
// 18/09/2012	cnwcs5	par 30316 - new prenote properties
// 17 Nov 2015	cnwma1	PAR #37167 Issue processing inbound cargo
vars

begin
	self.messageMode 	:= CM_EDITrackedItem.EDI_ACTION_ADD;
	self.temperature 	:= NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY ); 			// par18451 nov 2008 cnwrs1
	self.vent 			:= NULL_VENTILATION; 		// par18451 nov 2008 cnwrs1
	self.transportMode 	:= TI_TRANSMODE_ROAD_STR; 	// cnwgb1 PAR 18666 16.12.2008
	self.packTempC		:= NULL_TEMPERATURE;		// par 30316 Sep 2012
	self.packTempF		:= app.temperatureConversion(true, NULL_TEMPERATURE);  //NULL_TEMPERATURE;		// par 30316 Sep 2012  // 16/09/2014 cnwmh5 #34914
	self.timeAllowedOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;					// 14/08/2014 cnwmh5
	self.packTime		:= NULL_TIME;     // 17/11/2015 cnwma1 PAR #37167
	//cnwmc5 - 10 March 2014 - PAR 33001
	self.overHeight := NULL_INTEGER;
	self.overLengthBack := NULL_INTEGER;
	self.overLengthFront := NULL_INTEGER;
	self.overWidthLeft := NULL_INTEGER;
	self.overWidthRight := NULL_INTEGER;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCMIF" id="314d1e45-4890-4dfe-abf3-a62988d04d75">
        <source>createCMIF(_cmifList : CMIF_PrenoteSet input; _realPrenote : CM_TrackedItem) : CMIF_PreNote;
// ---------------------------------------------------------------------------
// Created:	17 June 2010 By Graeme Black cnwgb1
// Purpose:	Create a CMIF_Prenote from the CM__EDIPrenoteTI. Then attach it to 
//			the cmifList provided. Any child cargo (parentCargoID &lt;&gt; null) is 
//			attached to its parent which is assumed to be in the list.
//			If a prenote already exists and has children, they will be added
//			 
// ---------------------------------------------------------------------------
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//16 Sep 2015   cnwgb1  Par 37172 Modify Action on Prenotes
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 27/04/2018 	JLGNS1	Bug 38204: POL - Fwd: ##RE-7661## : Pre-Note error for Niagara using RIA
vars
	cmifPrenote : CMIF_PreNote;
	proxyPrenote  : CM_TrackedItem;
	ediAction : String;
	cmifParent : CMIF_PreNote;
	doNotCreatePins : Boolean;
	transMode: String;
begin
	ediAction := self.normaliseAction(_realPrenote);
	if ediAction = null then
		return null;
	endif;

	if self.parentCargoID &lt;&gt; null then
		cmifParent := self.findCMIFCargo(_cmifList, self.parentCargoTypeCode, self.parentCargoID);
	endif;
	
	doNotCreatePins := self.doNotGeneratePins();
		
	if ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE or
	   ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE or 
       ediAction = CM_EDITrackedItem.EDI_ACTION_MODIFY then // PAR 37172/CR 1164 cnwgb1 Add Modify semantics to Prenote
		if _realPrenote &lt;&gt; null then						//Bug 38204
			//Proxy should have been already created, but the file comes from a user and might be inconsistent 
			proxyPrenote := _realPrenote.pxyGetProxyObject();
		endif;
		if proxyPrenote = null then
			proxyPrenote :=	app.createUpdateProxy(_realPrenote).CM_TrackedItem; // Also creates proxies for any children
		endif;
		create cmifPrenote transient;
        if ediAction = CM_EDITrackedItem.EDI_ACTION_MODIFY then // PAR 37172/CR 1164 cnwgb1 Add Modify semantics to Prenote
            cmifPrenote.setFromTI(_realPrenote, self.getMyTerminal() );
        endif;
		cmifPrenote.setMyOriginalProxyTI(proxyPrenote);
		//epr TFS 6980 26/9/17 products collection removed	it checks self.product if cargo type is null on the cargoType mapping method
		self.setPrenoteInterface(cmifPrenote, doNotCreatePins);	//18 Nov 2015	NDL	Par 37147
		// 7/8/19 MAP TFS45915	Even if this is an update rather than a modify, don't lose these non-null attributes
        if ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			transMode := _realPrenote.getReceiptTransportModeStr();
			if transMode &lt;&gt; TI_TRANSMODE_NULL_STR and not (transMode = TI_TRANSMODE_ROAD_STR and cmifPrenote.transportMode &lt;&gt; TI_TRANSMODE_ROAD_STR) then
				cmifPrenote.transportMode := transMode;
			endif;
			if _realPrenote.wagon &lt;&gt; null then
				cmifPrenote.wagon := _realPrenote.wagon;
			endif;
			if _realPrenote.getMyNotifiedWagonClass() &lt;&gt; null then
				cmifPrenote.myWagonClass := _realPrenote.getMyNotifiedWagonClass();
			endif;
		endif;
		cmifPrenote.setMyPersistentTrackedItem(_realPrenote);
		
	elseif ediAction = CM_EDITrackedItem.EDI_ACTION_ADD then
		//epr TFS 6980 26/9/17 products collection removed	it checks self.product if cargo type is null on the cargoType mapping method
		cmifPrenote	:= self.createPrenoteInterface(doNotCreatePins);	//18 Nov 2015	NDL	Par 37147	
	else
		// 21/02/2014 cnwar2 #33202 - create cmif to allow validation for invalid EDI action to occur later
		cmifPrenote	:= self.createPrenoteInterface(doNotCreatePins);	//18 Nov 2015	NDL	Par 37147
	endif;

	if cmifPrenote = null then
		return null;
	endif;
	
	cmifPrenote.myTerminal	:= self.getMyTerminal();
	cmifPrenote.action := ediAction;
	if cmifParent = null then
		_cmifList.add(cmifPrenote);
	else
		cmifPrenote.setMasterItem(cmifParent);
	endif;
	
	return cmifPrenote;

epilog
end;
</source>
        <Parameter name="_cmifList" type="CMIF_PrenoteSet" usage="input"/>
        <Parameter name="_realPrenote" type="CM_TrackedItem"/>
        <ReturnType type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="createPrenoteInterface" id="a026c3a9-2e8a-4b03-bc90-af2547a8b62d">
        <source>createPrenoteInterface(_doNotGeneratePin : Boolean) : CMIF_PreNote;
vars
	cmifPrenote			: CMIF_PreNote;
begin
	create cmifPrenote transient;
	//epr TFS 6980 26/9/17 products collection removed	it checks self.product if cargo type is null on the cargoType mapping method
	self.setPrenoteInterface(cmifPrenote, _doNotGeneratePin);
	return cmifPrenote;
end;
</source>
        <Parameter name="_doNotGeneratePin" type="Boolean"/>
        <ReturnType type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="createTIHazardsFromEdiHaz" id="cb5e6717-b626-4837-81dd-4c3d9925ba49">
        <source>createTIHazardsFromEdiHaz( _tmpHazards : ObjectArray input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2018	jlgndl1	Initial creation	TFS 36824

*/

vars

	retValue : Boolean;
	edi : CM_EDITrackedItem;
	tiHaz : CM_TIHazard;

begin

	if self.myAttachedItems.isEmpty then
		return false;
	endif;
	
	foreach edi in self.myAttachedItems where edi.isEDIHazDetails do
		create tiHaz transient;
		tiHaz.setPxyFromEDI( edi.CM_EDIHazDetailsTI );
		_tmpHazards.add( tiHaz );
		retValue := true;
	endforeach;
	
	return retValue;

epilog

end;</source>
        <Parameter name="_tmpHazards" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="customsSeal" id="b248ac3b-5a54-46c9-8a82-87cc59bc3562">
        <methodInvocation>mapping</methodInvocation>
        <source>customsSeal(set : Boolean; _value : String io) mapping;
//
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if set then
		self.setSealsAsObjects(_value, SealType_Customs);
	else
		_value := self.getSealsAsString(SealType_Customs);
		if _value = null then
			_value := self.customsSeal;
		endif;
	endif;	
end;

</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="76a9271a-3543-4108-b392-3ae327d9a39c">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
// 23 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
	
vars
	voyageCodeStr	: String;
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.myAttachedItems do
		if ediTI.isEDISealDetails then
			delete ediTI;
		endif;
	endforeach;
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getConsignorVoyage();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="a92a17c3-e0c9-4176-9cc7-0b73d169094e">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
