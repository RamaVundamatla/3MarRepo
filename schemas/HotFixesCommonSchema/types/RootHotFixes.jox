    <JadeMethod name="logFileOutput" id="45f6f393-bdc0-40e8-8422-cf28406dce8a">
        <source>logFileOutput( _fileName: String input;  _strOut: String ) : Boolean;
// created by cnwvu1 on 27/01/2007
// Parameters:
// _fileName - file name with full path

vars
	fLog	: File;
	ts		: TimeStamp;
	
begin

	if _fileName = null then
		return false;
	endif;
	
	create fLog	transient;

	fLog.fileName := _fileName;
	if not fLog.isAvailable then
		fLog.mode := File.Mode_Output;
	else
		fLog.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
		fLog.mode := File.Mode_Append;
	endif;

	ts := app.actualTimeServer();

	fLog.open;

	if ( _strOut[1:3] = '===' ) or ( _strOut[1:1] = '-' ) then
		fLog.writeLine( _strOut );
	else
		fLog.writeLine( 
			ts.date.format('yyyy/MM/dd') &amp; ' ' &amp;
			ts.time.format("HH:mm:ss") 
//			&amp; '.' &amp; ts.time.milliSecond.padTrailingZeros(3)
			&amp; ' ' &amp; _strOut ); 
	endif;

	fLog.commit;
	fLog.close;

	return true;

epilog
	delete fLog;
	
end;
</source>
        <Parameter name="_fileName" type="String" usage="input"/>
        <Parameter name="_strOut" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="08326aae-4b5c-4120-8d5b-d34960d3a677">
        <updating/>
        <source>set( _dirSetupHotFixes, _releaseVersionNo :String ) updating;

vars

begin

	//removing the last \
	if _dirSetupHotFixes[ _dirSetupHotFixes.length : 1 ] = "\" then
		self.dirSetupHotFixes		:= _dirSetupHotFixes[ 1 : _dirSetupHotFixes.length-1 ];
	else
		self.dirSetupHotFixes		:= _dirSetupHotFixes;
	endif;
	
	self.releaseVersionNo		:= _releaseVersionNo;

//	See constants section:
//	self.dirJadeName			:= 'JadeMaster';
//	self.dirSchemasName 		:= 'Schemas';
//	self.fileJMTInstallName		:= 'JMTInstall.txt';
//	self.fileReadmeName 		:= 'Readme.txt';
//		self.jmtInstallStrBegin 	:= 'SCM::';
//		self.jmtInstallStrBeginDDB	:= 'DDB';
//		self.jmtInstallStrEnd		:= '::REQ::NOERRORS';
//		self.jmtInstallStrFirst 	:= 'SET::SERVER::MULTIUSER';
//		self.jmtInstallStrLast 		:= 'REM::All Done';
//	self.readmeStrBegin			:= 'This hotfix addresses the following issues:';


end;
</source>
        <Parameter name="_dirSetupHotFixes" type="String"/>
        <Parameter name="_releaseVersionNo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHotfixVersionForJMTInstall" id="134c087e-56b1-4ead-9633-1c733f3bafba">
        <source>setHotfixVersionForJMTInstall( _hotFixName : String) : String;
//	26/02/2008	cnwvu1
// gives the string for JMTInstall file: JMTPATCH::7.5.3::22::NOERRORS
vars
	strOut	: String;
	
begin

	strOut	:= self.JMT_INSTALL_STR_HOTFIX_VERSION &amp; self.JMT_INSTALL_STR_SP;

	// adding JMT version no
	strOut := strOut &amp; self.getReleaseVersionForJAPInstall();
	
	strOut := strOut &amp; JMT_INSTALL_STR_SP &amp; self.getHotfixNoFromHotfixName(_hotFixName);
	
	strOut := strOut &amp; JMT_INSTALL_STR_SP &amp; JMT_INSTALL_STR_NOERRORS;
	
	return strOut;
	
end;
</source>
        <Parameter name="_hotFixName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validDirectories" id="91c9da50-0079-4353-8367-4d38816c0611">
        <source>validDirectories( _releaseNo : String ): Boolean;

vars
	dirPatch, dirHtFx : FileFolder;
	
begin

	create dirPatch transient;
	create dirHtFx transient;

	if self = null then
		app.writeLogMessage(' RootHotFixes.firstInstance = null...');
		return false;
	endif;
	
	if not dirHtFx.isValidPathName( self.getDirHotFixes() ) then
		app.writeLogMessage(' HotFixes directory is invalid - '&amp; self.getDirHotFixes());
		return false;
	endif;
	if not dirPatch.isValidPathName( self.getDirOfPatches() ) then
		app.writeLogMessage(' Patches directory is invalid - '&amp; self.getDirOfPatches());
		return false;
	endif;

	dirHtFx.fileName := self.getDirHotFixes();
	if not dirHtFx.isAvailable then
		app.writeLogMessage(' HotFixes directory not found... '&amp; dirHtFx.fileName);
		return false;
	endif;	
	dirPatch.fileName := self.getDirOfPatches();
	if not dirPatch.isAvailable then
		app.writeLogMessage(' Patch directory not found... '&amp; dirPatch.fileName);
		return false;
	endif;	

	return true;

epilog
	delete dirPatch;
	delete dirHtFx;

end;
</source>
        <Parameter name="_releaseNo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
