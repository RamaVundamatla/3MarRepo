    <JadeMethod name="getCurrentJob" id="3fd24555-9326-40a3-a17b-bf79e2078b29">
        <source>getCurrentJob() : CM_Job;
// -----------------------------------------------------------------------------
// Created:		23 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	job : CM_Job;
	invalidJob : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, job, invalidJob);

	if self.myCurrentJob &lt;&gt; null then
		job := self.myCurrentJob;
		job.getName();
		if invalidJob then
			job := null;
		endif;
	endif;
	
	return job;

epilog

