    <JadeMethod name="setProxy" id="cc1dc037-a6e6-4df4-b317-bd15299d98ed">
        <updating/>
        <source>setProxy(_code: String; _proxyYA : CM_YardAllocation; _terminal: CM_Terminal input; _status : Integer ) updating;
//17 July 2008	cnwdw1	
//
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code := _code;
	self.myYardAllocation := _proxyYA;
	self.myTerminal := _terminal;
	self.status := _status;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_proxyYA" type="CM_YardAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
