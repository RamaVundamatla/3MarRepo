<Class name="CM_VesselHold" id="10d5e942-8b8d-4d7f-8c83-d2c2f25ea70e">
    <superclass name="CM_Hold"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vessel"/>
    <ExplicitInverseRef name="myCellularVesselStructure" id="734dcfc4-87b7-4a59-8610-b1c6a0f212d7">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CellularVesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_CellularVesselStructure::allHolds"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="d03e332b-0ab1-4823-9bd3-daf53f095b20">
        <updating/>
        <source>cloneMySelf(_newVessel : CM_CellularVesselStructure) : CM_VesselHold updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newMe : SelfType;
	realBay, proxyBay : CM_Bay;
begin
	newMe := self.cloneSelf(false);
	newMe.myCellularVesselStructure := _newVessel;
	
	// set up my bays
	foreach realBay in self.allBays do
		proxyBay := _newVessel.allBaysByOrdinal[realBay.ordinalBay];
		if proxyBay &lt;&gt; null then
			proxyBay.setMyHold(newMe);
		endif;
	endforeach;	

	// set up my holds
	
	return newMe;

end;</source>
        <Parameter name="_newVessel" type="CM_CellularVesselStructure"/>
        <ReturnType type="CM_VesselHold"/>
    </JadeMethod>
