    <JadeMethod name="doResizeControls" id="3899c68b-36e1-4beb-8568-ae3452bd2d87">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - 10;
	if _initialSetup then
		self.lblStatusTitle.setAndIncrementTabIndex( tabIndex );
		self.lblStatusTitle.visible := true;
	endif;
	self.lblStatusTitle.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.lblStatusTitle.height + self.resizedMargin;
	if _initialSetup then
		self.lblStatus.setAndIncrementTabIndex( tabIndex );
		self.lblStatus.visible := true;
	endif;
	self.lblStatus.move(	self.resizedMargin + 10,
							cTop,
							cWidth,
							cHeight );

	cTop := cTop + self.lblStatus.height + self.resizedMargin;
	if _initialSetup then
		self.chkNoCharge.setAndIncrementTabIndex( tabIndex );
		self.chkNoCharge.visible := true;
	endif;
	self.chkNoCharge.move(	self.resizedMargin,
							cTop,
							stdWidth,
							cHeight );
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
