    <JadeMethod name="showTrainDepartureForm" id="5f377355-d726-4532-9faa-050727c0ea0f">
        <source>showTrainDepartureForm(_rail : CM_Rail; _train : CM_Train; _parent : CM_BaseForm; _menuAction : CMUI_MenuAction; _term : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	departureForm : YRD_TrainDeparture; //;
begin
	departureForm := app.loadForm(YRD_TrainDeparture, YRD_Assistant, false, false, true, _term, _menuAction).YRD_TrainDeparture;

	if departureForm = null then
		return true;
	endif;

	departureForm.setParentForm(_parent);
	departureForm.setMyTerminal(_term);	
	departureForm.myDefaultTrain := _train;
	departureForm.myDefaultRail := _rail;
	departureForm.showModal;
	if departureForm.modalResult &lt;&gt; IDOK then
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_rail" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
