    <JadeMethod name="getSplitLocsString" id="155f1e07-cabc-4f67-b7e2-b8b92fd68160">
        <source>getSplitLocsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

	obj : Object;
	moveCMIF : CMIF_MoveController;
	location : CM_LocationsController;
	str : String;

begin

	if not self.allMultiRangeCMIFs.isEmpty then
		foreach obj in self.allMultiRangeCMIFs do
			moveCMIF := obj.CMIF_MoveController;
			location := moveCMIF.myToPrimaryLocation;
			if location &lt;&gt; null then
				if str &lt;&gt; null then
					str := str &amp; ", ";
				endif;
				str := str &amp; location.getFullId();
			endif;
		endforeach;
	endif;

	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
