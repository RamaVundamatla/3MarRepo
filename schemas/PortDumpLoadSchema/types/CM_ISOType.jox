<Class name="CM_ISOType">
    <JadeMethod name="importPLXMLReference" id="2841179f-9586-41a5-a071-3918667984c8">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ISOType::myRoot.name then
		return app.myRoot;
	elseif _name = CM_ISOType::myISOTypeGroup.name then
		return app.myRoot.allISOTypeGroups[_theCode];
	elseif _name = CM_ISOType::myCargoType.name then
		return app.myRoot.allCargoTypesById[_theCode.Integer];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
