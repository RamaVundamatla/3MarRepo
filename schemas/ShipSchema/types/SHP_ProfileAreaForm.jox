    <JadeMethod name="setTableHeights" id="2aacde41-2017-498f-9d1a-3b09eb17f57e">
        <updating/>
        <source>setTableHeights() updating, protected;
// 30278 resize the tables when toolbar captions are enabled to retain their horizintal scroll 
vars

begin
	self.tblRORODecks.height := self.clientHeight - self.fldMain.top - self.shtRORODecks.top - 5;
	self.tblROROMoves.height := self.clientHeight - self.fldMain.top - self.shtROROMoves.top - 5;
	self.tblBays.height := self.clientHeight - self.fldMain.top - self.shtBays.top - 5;
	self.tblStats.height := self.clientHeight - self.fldMain.top - self.shtMoves.top - 5;
	self.tblDelays.height := self.clientHeight - self.fldMain.top - self.shtDelays.top - 5;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3ca6de85-ef1d-446e-b2e3-080591d7ef7e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/08/2011	cnwcs5		CCMS MES 1033 RORO KPI
// 08/11/2012	cnwcs5		par 30519  - handle delay notifications. 
//									   - Also move voyage related code to be in one place &amp; added a translation
// ---------------------------------------------------------------------------
vars
	idx 		: Integer;
	voyage 		: CM_Voyage;
	terminal	: CM_Terminal;
	user		: CM_User;
begin
	inheritMethod();
	
	self.frmColLegendLogs.visible 	:= false; // 28318
	self.frmGridArea.ignoreSkin 	:= true;
			
	self.doInitialiseSDF();
	//self.splMain.setLeftToRightRatioAndResize(15);
	
	// populate cmbArea ComboBox
	self.doCmbAreasBuild();	
	
	self.cmbArea.visible 			:= true;
	self.frmColLegendTIs.visible 	:= true;
	self.frmCargoPic.visible 		:= false;
	self.left 						:= 200;
	
	// Set the toolbar button that correspondes to the view mode
	self.sdf01.width 				:= self.clientWidth - self.frmColLegendTIs.clientWidth - 10;
	self.frmGridArea.borderStyle 	:= BorderStyle_None;

	//MoveMode get set in self.frmStatusLine.initFrame();

	self.frmColLegendTIs.doChangeViewMode(TI_ColourMode_DischargePort);	//There is only the one view mode by Disharge Port in the form. Par 18247 Mar 2009
	
	self.sptGridArea01.setLeftToRightRatioAndResize(80);
	//self.splMain.setLeftToRightRatioAndResize(15);
	// the default is Bay View ACTUAL so disable these controls
	self.doResize();

	// hide show the toolbar, legend and macro info table - these are set in the super class setup from XML savings
	self.mnuGridHideToolbar_click(self.mnuGridHideToolbar);
	
	voyage 		:= app.getMyCurrentVoyage();
	terminal	:= self.myTerminal;
	
	if voyage &lt;&gt; null then
		self.mnuGridHideLegend_click(self.mnuGridHideLegend);
		// select voyage in combo. if current voyage on app is for another terminal then it will
		// not be in the combo so can't be selected
		idx := self.cmbArea.findObject(voyage);
		
		if idx &gt; 0 then
			self.cmbArea.listIndex := idx;
		endif;
		
		// par 30519 - if we have a voyage doComboVoyageClick will be called in loadDataForFirstTime
		// because we have something selected in the voyage combo.  This will set our voyage references
		// and register for notifications etc.
	endif;


	self.frmStatusLine.visible := false;
	
	user 				:= app.myPassport.myUser;
//	self.hasKPILicense 	:= user.canDo(terminal, PmKPIModule);
	self.hasKPILicense 	:= user.canDo(terminal, Mod_BaseSystem);//07 Oct 2019	NDL	TFS 46169
	self.hasROROLicense	:= user.canDo(terminal, Mod_VesselRORO);
	
	if not self.hasKPILicense then
		self.shtDelays.visible 		:= false;
		self.shtMoves.visible 		:= false;
		self.shtTimings.visible 	:= false;
		self.shtBays.visible 		:= false;
	endif;
	
	if not self.isShowROROKPI  then
		self.shtRORODecks.visible	:= false;
		self.shtROROMoves.visible	:= false;
	endif;
	
	self.frmPrint.autoRedraw := true;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveWebCam.enabled:= false;
		self.btnTBKPIUpdate.enabled:= false;
		self.btnWPOpHrsEdit.enabled:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAverageColumns" id="b78d8551-3685-4524-aca0-84f6a6b2ee66">
        <source>showAverageColumns(_show : Boolean);

vars
	table : Table;
begin
	table := self.tblStats;
	
	table.accessColumn(COLUMN_PlusMinus_GrossRate).visible 	:= _show;
	table.accessColumn(COLUMN_PlusMinus_NetRate).visible 	:= _show;
	table.accessColumn(COLUMN_PlusMinus_MinPerHour).visible := _show;
	table.accessColumn(COLUMN_PlusMinus_MaxPerHour).visible := _show;
end;
</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showBayStats" id="a0f56778-569a-471d-bc49-d66105109c62">
        <updating/>
        <source>showBayStats() updating;
// ---------------------------------------------------------------------------
// Created:		September 2007 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 02/08/2011	cnwcs5	Tidy up when removing old KPI classes
vars
	newRow	: Integer;
	colStr 	: String;
	kpi 	: CM_KPI;
	kpiBay 	: CM_KPIVoyageBayCrane;
	allVoys : CM_VoyageByArrivalDTTerminal;
	aVoy 	: CM_Voyage;
	table	: CM_DataTable;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
//	if  not app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if  not app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;

	create allVoys transient;
	app.mousePointer := Window.MousePointer_HourGlass;

	table 		:= self.tblBays;
	table.rows 	:= table.fixedRows;

	allVoys.add(self.myCurrentVoyage);

	if not self.hideDetail and  self.myVesselVoyageController &lt;&gt; null then
		foreach aVoy in self.myVesselVoyageController.allVoyages do
			allVoys.addNoDuplicates(aVoy, false);
		endforeach;
	endif;
	
	foreach aVoy in allVoys do
		foreach kpi in aVoy.allVoyageKPIEntities discreteLock where kpi.type = KPI_Type_VoyageBayCrane do 
			kpiBay := kpi.CM_KPIVoyageBayCrane;
			colStr := kpiBay.getAttributeStringForDefArray(table.allTblDataEntRows);
			newRow := table.addItem(colStr);
			
			table.accessRow(newRow).itemObject := kpi;
		endforeach;
	endforeach;
	
epilog
	delete allVoys;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneMoves" id="1b21f01c-2443-4e80-a41f-61d46d19ab26">
        <updating/>
        <source>showCraneMoves() updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
vars
	idx,totalMoves : Integer;
	aJS : CM_JobSheet;
begin
	foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
		totalMoves := totalMoves.max(aJS.CM_VoyageJobSheet.completedWLEsByDateSize); // AKB2004OCT
	endforeach;
	
	foreach idx in MOVES_MAX to 5500 step MOVES_MAX do
		if idx &gt; totalMoves then
			break;
		endif;
	endforeach;
	self.craneMovesMax := idx;
	self.showCraneMovesInit();
	self.showCraneMovesYAxis();
	self.showCraneMovesXAxis();
	self.showCraneMovesLines();
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneMovesInit" id="716b4b45-1f0f-4b28-adc8-69f969149530">
        <source>showCraneMovesInit();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
begin
	
	theFrame := self.frmCraneMove;
	
	theFrame.height := 175;
	theFrame.width := 400;
	theFrame.drawWidth := 1;
	theFrame.autoRedraw := true;
	theFrame.clearGraphics();
	theFrame.drawFontName := "Microsoft Sans Serif";
	theFrame.drawFontSize := 8;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
	
	theFrame.visible := true;
	theFrame.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneMovesLines" id="32fb69d0-3a5c-4bf1-9cb8-ae1c07a05cee">
        <source>showCraneMovesLines();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		very similar code is used in CM_JobSheet::getWorkActualRateNoDelays
//
// ---------------------------------------------------------------------------

vars
	theFrame				: Frame;
	aJS						: CM_VoyageJobSheet;
	theX, theY, tmpX, tmpY	: Real;
	theColour, axisRate,
	idx	: Integer;
	tmpJobSheetStats	: CMIF_JobSheetStats;
	tmpPoint			: Point;
	workPointObj : CM_Object;
	theLabel : String;
begin

	theFrame := self.frmCraneMove;
	axisRate := (self.craneMovesMax / MOVES_MAX).Integer;

	theFrame.drawWidth := 2;
// PAR 36118	foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
// PAR 36118		if aJS.allJobsByOrder.isEmpty then // PAR 8436
// PAR 36118			continue;
// PAR 36118		endif;
	foreach tmpJobSheetStats in self.myVoyageStats.allJobSheetStats do //  PAR 36118
		idx := 0;
		tmpX := null;
		tmpY := null;
		
		aJS := tmpJobSheetStats.myJobSheet.CM_VoyageJobSheet;
		if aJS  = null then
			continue;
		endif;
		workPointObj:=aJS.getMyWorkPointObject;
		if workPointObj &lt;&gt; null then
			theColour:=workPointObj.IF_VoyageWorkPoint.getColour;
			theLabel:=workPointObj.IF_VoyageWorkPoint.getID;
		else // PAR 36118
			theColour:=Red;
			theLabel:=tmpJobSheetStats.description;
		endif;
		
// PAR 36118		tmpJobSheetStats := self.myVoyageStats.getJobSheetStatsForJobSheet(aJS);
		foreach tmpPoint in tmpJobSheetStats.allGraphPoints do
			theX := tmpPoint.x;
			theY := tmpPoint.y;

			theX := OFFSET_X + ((tmpPoint.x / axisRate) * 2);
			theY := OFFSET_Y - tmpPoint.y;

			if tmpX &lt;&gt; null then
				theFrame.drawLine(tmpX,tmpY,theX,theY,theColour);
			endif;
			
			tmpX := theX;
			tmpY := theY;
			
		endforeach;

		// draw a little box to terminate the line
		theFrame.drawFilledRectangle(tmpX - 2, tmpY - 2, tmpX + 2, tmpY + 2, theColour);
	endforeach; // each JS

	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneMovesXAxis" id="5a6e2d09-d0be-4b6d-a6c1-eaa6a78915dc">
        <source>showCraneMovesXAxis();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
vars
	theFrame : Frame;
	idx, rowIDX : Integer;
	label : String;
	aJS : CM_VoyageJobSheet;
	jobStat : CMIF_JobSheetStats;
	theColour,labelX,axisRate,labelY : Integer;
	theLabel : String;
	workPointObj : CM_Object;
begin
	theFrame := self.frmCraneMove;
	axisRate := (self.craneMovesMax / MOVES_MAX).Integer;
	labelY := OFFSET_Y + 15;
	idx := OFFSET_X + 9;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		if aJS.allJobsByOrder.isEmpty then // PAR 8436
			continue;
		endif;
		
		workPointObj:=aJS.getMyWorkPointObject;
		if workPointObj &lt;&gt; null then
			theColour:=workPointObj.IF_VoyageWorkPoint.getColour;
			theLabel:=workPointObj.IF_VoyageWorkPoint.getID;
		else
			continue;
		endif;
		
		theFrame.drawFillColor := theColour;
		theFrame.drawFilledRectangle(idx - 22,labelY,idx + 22 ,labelY + 15,Black); //  PAR 36118 widened the rectangle
		
		theFrame.drawTextAt(theLabel,idx,labelY,theColour.getInverseColour);
		idx := idx + 50; //  PAR 36118
	endforeach;	
	
	//  PAR 36118
	foreach jobStat in self.myVoyageStats.allJobSheetStats do
		if jobStat.allGraphPoints.isEmpty then
			continue;
		endif;
		
		if jobStat.myJobSheet = null then
			continue;
		endif;
		
		if not jobStat.myJobSheet.isTransient then // holds only
			continue;
		endif;
		
		theColour:=Red;
		theLabel:=jobStat.description;
		
		theFrame.drawFillColor := theColour;
		theFrame.drawFilledRectangle(idx - 22,labelY,idx + 22 ,labelY + 15,Black);
		
		theFrame.drawTextAt(theLabel,idx,labelY,theColour.getInverseColour);
		idx := idx + 50;
		
	endforeach;
	
	

	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	theFrame.drawTextAt("Number Of Moves",idx,labelY,Black);
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	foreach idx in 25 to 150 step 25 do
		label :=  (idx * axisRate).asStringJMT;
		rowIDX := OFFSET_X + (idx * 2);
		theFrame.drawTextAt(label,rowIDX, OFFSET_Y,Black);
		theFrame.drawLine(rowIDX,OFFSET_Y , rowIDX, OFFSET_Y + 3,Black);
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneMovesYAxis" id="28d1c4c8-39ac-4d85-b1f0-50093e89569d">
        <source>showCraneMovesYAxis();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
//	LABEL_X = 20;
	MAX_Y_VALUE = 140;
	
vars
	theFrame : Frame;
	idx, rowIDX,actualY : Integer;
	label : String;
	aJS : CM_VoyageJobSheet;
	theColour,labelX, depTargetRPH : Integer;
	craneRate,
	rateAllCranes		: Integer;
	workPointObj		: CM_Object;
begin


	theFrame := self.frmCraneMove;

	theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
	rowIDX := OFFSET_Y - 28;
	theFrame.drawTextRotation := 270;
	theFrame.drawTextAt("Rate   Per   Hour",25,10,Black);
	theFrame.drawTextRotation := 0;

	//foreach idx in 10 to 100 step 20 do
	foreach idx in 10 to MAX_Y_VALUE step 20 do
	
		actualY := ((MAX_Y_VALUE - idx) + 10);
		label := ((idx / 2) + 5).asStringJMT;
		labelX := OFFSET_X - 5;
		theFrame.drawTextAt(label,labelX,rowIDX,Black);
		theFrame.drawLine(OFFSET_X, OFFSET_Y - actualY, 350, OFFSET_Y - actualY, Gray);
		theFrame.drawLine(OFFSET_X - 3,OFFSET_Y - actualY,OFFSET_X,OFFSET_Y - actualY,Black);
		rowIDX := rowIDX - 20;
	endforeach;

	theFrame.drawLine(OFFSET_X,2,OFFSET_X,OFFSET_Y,Black);
	theFrame.drawLine(OFFSET_X,OFFSET_Y,350,OFFSET_Y,Black);
	
	idx := 0;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		//epr CCMS 1033 31/8/11 changed to use work point objects
		workPointObj:=aJS.getMyWorkPointObject;
		if workPointObj &lt;&gt; null then
			theColour := workPointObj.IF_VoyageWorkPoint.getColour;
			if workPointObj.isKindOf(CM_WorkPoint) and workPointObj.CM_WorkPoint.hasDefinedCargoRates then	//08 Mar 2017	NDL	TFS 37437
				craneRate := workPointObj.CM_WorkPoint.getDefinedTargetRateWeight( aJS );
			else
				craneRate := workPointObj.IF_VoyageWorkPoint.getTargetRatePH;
			endif;
		endif;
		
		rateAllCranes := rateAllCranes + craneRate;		
		idx := idx + 1;

		theFrame.drawLine(OFFSET_X, OFFSET_Y - (craneRate * 2), 350, OFFSET_Y - (craneRate * 2), theColour);
	
	endforeach;
	
	if idx &gt; 0 then
		rateAllCranes := (rateAllCranes/idx).Integer;
	endif;
	
	depTargetRPH := self.myVoyageStats.getWorkDepartureTargetRatePH();
	theFrame.drawStyle := Frame.DrawStyle_DashDot;
	theFrame.drawLine(OFFSET_X,OFFSET_Y - (rateAllCranes * 2),350,OFFSET_Y - (rateAllCranes * 2),Red);

	//Bish, is this the rate required to meet target departure?
	theFrame.drawLine(OFFSET_X,OFFSET_Y - (depTargetRPH * 2),350,OFFSET_Y - (depTargetRPH * 2),Blue);


	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showDelaysStats" id="fd22d66d-b768-4a10-bc99-5c9a2fe1bbf1">
        <source>showDelaysStats();
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 08/11/2012	cnwcs5	par 30519
// 16/03/2015	cnwmh5	Transient Leaks
vars
	voyage				: CM_Voyage;
	table				: Table;
	jobSheet 			: CM_VoyageJobSheet;
//	crane				: CM_Crane;
	craneOrWp 			: Object;		//24 Jan 2013	NDL	Par 31059
	shiftStartTS, shiftEndTS, delayEnd : TimeStamp;
	newRow				: Integer;
	colStr, minStr 		: String;
	delayMinutes, totDelays, grdDelays : Real;
	delay 				: CM_Delay;
	shift 			: CM_Shift;
	jobSheets : ObjectArray;
	label : String;

begin
	voyage := self.myCurrentVoyage;
	
	if voyage = null then
		return;
	endif;
	
//	if  not app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if  not app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
	
	// PAR 33847
	create jobSheets transient;
	foreach delay in voyage.allDelays discreteLock do
		craneOrWp := delay.myMachine;
		if craneOrWp = null then
			craneOrWp := delay.myWorkPoint;
		endif;
		
		if craneOrWp &lt;&gt; null then
			if not jobSheets.includes (craneOrWp) then
				jobSheets.add(craneOrWp);
			endif;
		endif;
		
	endforeach;
	
	table := self.tblDelays;
	
	if table.rows &lt;&gt; table.fixedRows then
		// this is the way we decide if it has already been loaded
		return;
	endif;
	
	if voyage.allDelays.isEmpty then
		// why bother goiing through the jobsheets and shifts of there are no delays to be found
		// small optimisation (par 30519)
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	table.rows := table.fixedRows;

/* PAR 33847
	foreach jobSheet in voyage.allJobSheets discreteLock do
		if (jobSheet.allShipReceivals.isEmpty and jobSheet.allShipReleases.isEmpty) then
			continue;
		endif;
		
		if jobSheet.allCompletedWLEsByDate.isEmpty then
			continue;
		endif;
		

		craneOrWp 		:= jobSheet.getMyWorkPointObject();	//24 Jan 2013	NDL	Par 31059
	*/	

	// ###################################################
	// ###
	// ###  CRANE and WORK POINT     D E L A Y S
	// ###
	// ###################################################
	
	foreach craneOrWp in jobSheets discreteLock do // PAR 33847
		label := craneOrWp.getNiceName;
		
		shiftStartTS 	:= null;
		
		// ### go through all the shifts over all the days and split up the transactions for this crane.
		foreach shift in self.myVoyageStats.allShifts discreteLock do
			shiftStartTS 	:= self.systemToLocalTime(shift.startDateTime);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
			shiftEndTS 		:= self.systemToLocalTime(shift.endDateTime);

			// ### GETS MOVES PER SHIFT
			//foreach delay in voyage.allDelays  discreteLock where delay.myMachine = crane  do
			foreach delay in voyage.allDelays  discreteLock where ( delay.myMachine = craneOrWp or delay.myWorkPoint = craneOrWp ) do	//24 Jan 2013	NDL	Par 31059		//24 Jan 2013	NDL	Par 31059
			
				// ### get delays per shift
				// PAR 33847 delayMinutes := jobSheet.getShiftMinutesForADelay(delay, shiftStartTS, shiftEndTS);
				delayMinutes := delay.getShiftMinutesForADelay(shiftStartTS, shiftEndTS); // PAR 33847
				
				if delayMinutes &gt; 0 then
					minStr 		:= (delayMinutes * 60).Integer.getHMS();
					delayEnd 	:= self.systemToLocalTime(delay.endDT);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
					
					if not delayEnd.isValid() then
						delayEnd := self.systemToLocalTime(delay.estEndDT);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
					endif;
					
					colStr := 	label &amp; Tab &amp; 
								shiftStartTS.shortCurrentLocaleFormat() &amp; Tab &amp; 
								shiftEndTS.shortCurrentLocaleFormat() &amp; Tab &amp; 
								shift.description &amp; Tab &amp; 
								minStr &amp; Tab &amp; 
								delay.myDelayType.description &amp; Tab &amp; 
								delay.remarks &amp; Tab &amp; 
								self.systemToLocalTime(delay.startDT).shortCurrentLocaleFormat() &amp; Tab &amp; 	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
								delayEnd.shortCurrentLocaleFormat() &amp; Tab &amp; 								
								delay.getDelayLengthDesc();
					
					// add row for shift/delay to table
					newRow 								:= table.addItem(colStr);
					table.accessRow(newRow).itemObject 	:= delay;
					totDelays 							:= totDelays + delayMinutes;
				endif;
			endforeach;
		endforeach;
		
		grdDelays := grdDelays + totDelays;
		
		// add row for jobsheet (crane)
		if totDelays &gt; 0 then
			minStr := (totDelays * 60).Integer.getHMS();
			colStr := label &amp; " " &amp; app.getErrorString (Total) &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; minStr;			
			newRow := table.addItem(colStr);
			
			table.accessRow(newRow).backColor 	:= self.ColourLightGrey01;
			table.accessedRow.foreColor 		:= Black;
		endif;
		
		totDelays := 0;
	endforeach;
// ###


	// ###################################################
	// ###
	// ###  V O Y A G E     D E L A Y S    (N O   M A C H I N E S)
	// ###
	// ###################################################
	foreach delay in voyage.allDelays  discreteLock where delay.myMachine = null and delay.myWorkPoint = null do // PAR 33847 this part is for non crane or work point delays.
// PAR 33847	foreach delay in voyage.allDelays  discreteLock where ( delay.myMachine = craneOrWp or delay.myWorkPoint = craneOrWp ) do	//24 Jan 2013	NDL	Par 31059
		// ### get delays per shift
		// ### get delays per shift
		delayMinutes := delay.startDT.getDifferenceInMinutes(delay.endDT); //jobSheet.getShiftMinutesForADelay(delay, shiftStartTS,shiftEndTS);
		
		if delayMinutes &gt; 0 then
			minStr 		:= (delayMinutes * 60).Integer.getHMS();
			delayEnd 	:= self.systemToLocalTime(delay.endDT);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
			
			if not delayEnd.isValid() then
				delayEnd := self.systemToLocalTime(delay.estEndDT);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
			endif;
			
			colStr := delay.getDelayTypeGroupDesc() &amp; Tab &amp; 
						shiftStartTS.shortCurrentLocaleFormat() &amp; Tab &amp; 
						shiftEndTS.shortCurrentLocaleFormat() &amp; Tab &amp; 
						"" &amp; Tab &amp; 
						minStr &amp; Tab &amp; 
						delay.myDelayType.description &amp; Tab &amp; 
						delay.remarks &amp; Tab &amp; 
						self.systemToLocalTime(delay.startDT).shortCurrentLocaleFormat() &amp; Tab &amp; 	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
						delayEnd.shortCurrentLocaleFormat() &amp; Tab &amp; 
						delay.getDelayLengthDesc();
						
			newRow 		:= table.addItem(colStr);		
			grdDelays 	:= grdDelays + delayMinutes;
		endif;
	endforeach;

	minStr := (grdDelays * 60).Integer.getHMS();
	colStr := app.getErrorString (Voyage_total) &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; minStr;						
	newRow := table.addItem(colStr);
	
	table.accessRow(newRow).backColor 	:= self.ColourLightGrey01;
	table.accessedRow.foreColor 		:= Black;
	
epilog	
	app.mousePointer := Window.MousePointer_Default;
	delete jobSheets;
end;</source>
    </JadeMethod>
    <JadeMethod name="showExtraInfo" id="e79e1d56-47b9-49b8-8707-afbfd47261e0">
        <updating/>
        <source>showExtraInfo(_theGridPoint: CMUI_GridPoint; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	// do nothing, override super class.
end;</source>
        <Parameter name="_theGridPoint" type="CMUI_GridPoint"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showGraphCrane" id="a7cf2c50-fffb-4fcb-9bb1-ed0d43943aff">
        <source>showGraphCrane(_theGraph : CMUI_PieGraph; _aJS : CM_JobSheet;_theFrame : CMUI_Frame input; _visible : Boolean);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	completed, unactioned,partCompleted : Integer;
	completedPC, unactionedPC,partCompletedPC : Integer;
	theGraph : CMUI_PieGraph;
	aJS : CM_JobSheet;
	theLabel : String;
begin
	if not _visible then
		return;
	endif;
	theGraph := _theGraph;
	
	aJS := _aJS;
	if aJS = null then
		_theFrame.visible := false;
		return;
	endif;
	aJS.getJobTotalsCrane(completed, unactioned, partCompleted);
	
	completedPC := completed;
	unactionedPC := unactioned;
	partCompletedPC := partCompleted;
	
	aJS.getJobTotalsCranePC(completedPC, unactionedPC,partCompletedPC);
	
	theGraph.move(0,0,_theFrame.clientWidth,_theFrame.clientHeight);
	theGraph.clearGraph();
	theGraph.isShowPieLegend := true;
//	theGraph.setLegendLabelFontSize(8);
	theLabel := aJS.CM_VoyageJobSheet.crane &amp; " Jobs";
	
	if completed &gt; 0 then
		theGraph.addValue(completed.String &amp; " - " &amp; app.jobStatusEnumToString(JOB_COMPLETE),completedPC,CM_Job.Colour_ReceiptComplete);
	endif;
	if unactioned &gt; 0 then
		theGraph.addValue(unactioned.String &amp; " - " &amp; app.jobStatusEnumToString(JOB_UNACTIONED),unactionedPC,CM_Job.Colour_ReceiptUnactioned);
	endif;
	if partCompleted &gt; 0 then
		theGraph.addValue(partCompleted.String &amp; " - " &amp; app.jobStatusEnumToString(JOB_PART_COMPLETE),partCompletedPC,CM_Job.Colour_ReceiptPartComplete);
	endif;
	theGraph.setTitle(theLabel);
	theGraph.drawGraph();
	_theFrame.visible := _visible;
end;</source>
        <Parameter name="_theGraph" type="CMUI_PieGraph"/>
        <Parameter name="_aJS" type="CM_JobSheet"/>
        <Parameter name="_theFrame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideDetail" id="e8a98d77-a006-4b00-929d-7c08abdffda5">
        <source>showHideDetail();
// ---------------------------------------------------------------------------
// Created:		10 September 2007 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
vars
	table				: CM_DataTable;
	stRow, endRow, idx 	: Integer;
	obj					: Object;
begin
	table 	:= self.tblStats;
	stRow 	:= table.fixedRows + 1;
	endRow 	:= table.rows;
	
	foreach idx in stRow to endRow do
		if self.kpiDetail = self.KPIDetail_ALL then
			table.accessRow(idx).visible := true;
			
		elseif self.kpiDetail = self.KPIDetail_Voyage then
			table.accessRow(idx);
			
			obj := table.accessedRow.itemObject;
			
			if obj.isKindOf(CM_KPIVoyageEntity) then
				if obj.CM_KPIVoyageEntity.myVoyage = self.myCurrentVoyage then
					table.accessRow(idx).visible := true;
				else
					table.accessRow(idx).visible := false;
				endif;
			else
				table.accessRow(idx).visible := true;
			endif;
			
		elseif self.kpiDetail = self.KPIDetail_Totals then
			table.accessRow(idx);
			
			obj := table.accessedRow.itemObject;
			
			if obj.isKindOf(CM_KPIVoyageEntity) then
				table.accessRow(idx).visible := false;
			else
				table.accessRow(idx).visible := true;
			endif;
		endif;
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="showMoveStatPlusMinus" id="c0d41c47-bff8-470c-a105-398bdbcb1ab0">
        <source>showMoveStatPlusMinus(_row, _col : Integer; _totAvGross : Real);

vars
	table		: Table;
	tmpAmt 		: Real;
	plusMinus 	: String;
begin
	table	:= self.tblStats;
	tmpAmt 	:= table.accessCell(_row, _col - 1).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	tmpAmt 	:= tmpAmt - _totAvGross;

	if tmpAmt &gt; 0 then
		plusMinus := "+";
	else
		plusMinus := null;
	endif;
	
	// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
	table.accessCell(_row, _col).text := plusMinus &amp; tmpAmt.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;
end;
</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_totAvGross" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showMoveStatsAverage" id="612ed60c-f21a-462e-a836-976e5beeed40">
        <source>showMoveStatsAverage(_startRow, _endRow : Integer; _label : String; _lineColour : Integer; _plusMinus : Boolean);
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 19/08/2011	cnwmh5	#28034 - Change test for Grand so that only does if _label length &gt; 0
vars
	table						: CM_DataTable;
	colStr						: String;
	totLIDS, totTEUS, totTIS	: Integer;
	idx, newRow, row 			: Integer;
	totMinC, totMaxC, totGrossHours, 
	totDownHours, totDelayHours, totNetHours, 
	totAvGross, totAvNet 		: Real;
	doGrd 						: Boolean;
	rowObj 						: Object;
	startPos					: Integer;			// 19/08/2011 cnwmh5 #28034
begin
	table := self.tblStats;
	
	// 19/08/2011 cnwmh5 #28034
	startPos := _label.length - 5;
	if startPos &gt; 0 then
		doGrd := (_label[startPos:end] = "Grand");
	endif;
	//doGrd := (_label[_label.length - 5:end] = "Grand");
	
	foreach row in _startRow to _endRow do
		rowObj := table.accessRow(row).itemObject;

		if doGrd then
			if rowObj &lt;&gt; self then
				continue;
			endif;
		else
			if rowObj &lt;&gt; null then // KPI detail - ignore
				continue;
			endif;
		endif;

		// MOVES
		totTIS := totTIS + table.accessCell(row, 7).text.Integer;
		totTEUS := totTEUS + table.accessCell(row, 8).text.Integer;
		totLIDS := totLIDS + table.accessCell(row, 9).text.Integer;
		// HOURS
		totGrossHours := totGrossHours  + table.accessCell(row, 11).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		totDownHours := totDownHours  + table.accessCell(row, 12).text.asDecimalJMT();// 04 Apr 2012	NDL	Par 29369
		totDelayHours := totDelayHours  + table.accessCell(row, 13).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		totNetHours := totNetHours  + table.accessCell(row, 14).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		// CONTAINER
		totAvGross := totAvGross  + table.accessCell(row, 16).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		totAvNet := totAvNet  + table.accessCell(row, 18).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		// LIFTS
		totMinC := totMinC  + table.accessCell(row, 21).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
		totMaxC := totMaxC  + table.accessCell(row, 23).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556

		idx := idx + 1;
		
	endforeach;
	
	if idx = 0 then
		return;
	endif;

	totAvGross := (totAvGross/ idx); // PAR 16592
	totAvNet := (totAvNet/ idx); // PAR 16592
	
	// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
	colStr := _label &amp; Tab &amp; " Total" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 1
						totTIS.String &amp; Tab &amp; 
						totTEUS.String &amp; Tab &amp; 
						totLIDS.String &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 2
						totGrossHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						totDownHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; //04 Apr 2012	NDL	Par 29369
						totDelayHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						totNetHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 3
						totAvGross.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
						totAvNet.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 4
						totMinC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp; 
						totMaxC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;

	newRow := table.addItem(colStr);
	
	table.accessRow(newRow).backColor := self.getTotalColour(_lineColour );
	table.accessedRow.foreColor := table.accessedRow.backColor.getInverseColour();// PAR 16592
	table.accessedRow.itemObject := self;
	
	totTIS 			:= (totTIS/ idx).Integer;
	totTEUS 		:= (totTEUS/ idx).Integer;
	totLIDS 		:= (totLIDS/ idx).Integer;
	totGrossHours 	:= (totGrossHours/ idx);
	totDownHours 	:= (totDownHours/ idx);	 //04 Apr 2012	NDL	Par 29369
	totDelayHours 	:= (totDelayHours/ idx);
	totNetHours 	:= (totNetHours/ idx);
	totMinC 		:= (totMinC/ idx);
	totMaxC 		:= (totMaxC/ idx);
	
	// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
 	colStr := _label &amp; Tab &amp; " Average" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 1
						totTIS.String &amp; Tab &amp; 
						totTEUS.String &amp; Tab &amp; 
						totLIDS.String &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 2
						totGrossHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						totDownHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 	 //04 Apr 2012	NDL	Par 29369
						totDelayHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						totNetHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
						"" &amp; Tab &amp; // GAP 3
						totAvGross.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
						totAvNet.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
						"" &amp; Tab &amp; // GAP 4
						totMinC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
						totMaxC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;


	newRow := table.addItem(colStr);

	table.accessRow(newRow).backColor 	:= self.getTotalColour(_lineColour + 1);
	table.accessedRow.foreColor 		:= Black;

	if _plusMinus then
		foreach row in _startRow to _endRow do
			self.showMoveStatPlusMinus(row, self.COLUMN_PlusMinus_GrossRate, totAvGross);
			self.showMoveStatPlusMinus(row, self.COLUMN_PlusMinus_NetRate, totAvNet);
			self.showMoveStatPlusMinus(row, self.COLUMN_PlusMinus_MinPerHour, totMinC);
			self.showMoveStatPlusMinus(row, self.COLUMN_PlusMinus_MaxPerHour, totMaxC);
		endforeach;
	endif;
end;</source>
        <Parameter name="_startRow" type="Integer"/>
        <Parameter name="_endRow" type="Integer"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_lineColour" type="Integer"/>
        <Parameter name="_plusMinus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMoveStatsByJS" id="57a66fdb-ba0c-46c7-ae23-7399883fde15">
        <source>showMoveStatsByJS();
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theMachines : CM_MachineSet;
	aMach : CM_Machine;
	aCrane : CM_Crane;
	allJSByCrane : CM_ObjectArray;
	anObj : Object;
	aVoy : CM_Voyage;
	aJS : CM_VoyageJobSheet;
	craneStr, tmpLbl : String;
	idx, startRow, endRow : Integer;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
//	if  not app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if  not app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
	create theMachines transient;
	create allJSByCrane transient;
	self.tblStats.rows := self.tblStats.fixedRows;
	
	// voyage comparision
	if self.myVesselVoyageController &lt;&gt; null then
		self.myTerminal.getAllMachines(theMachines,true);
		
		// use each crane to get a job sheet on each voyage
		foreach aMach in theMachines do
			aCrane := aMach.CM_Crane;

			aJS := self.myCurrentVoyage.allJobSheets[aCrane.id];
			
			if aJS &lt;&gt; null and not allJSByCrane.includes(aJS) then
				allJSByCrane.add(aJS);
			endif;
			
			foreach aVoy in self.myVesselVoyageController.allVoyages reversed do
				aJS := aVoy.allJobSheets[aCrane.code.trimBlanks];
				if aJS &lt;&gt; null and not allJSByCrane.includes(aJS) then
					allJSByCrane.add(aJS);
				endif;
			endforeach;
			
			aJS := self.myCurrentVoyage.allJobSheets[aCrane.code.trimBlanks];
			
			if aJS &lt;&gt; null and not allJSByCrane.includes(aJS) then
				allJSByCrane.add(aJS);
			endif;
		endforeach;
	else
		foreach aJS in self.myCurrentVoyage.allJobSheets do
			if not aJS.isVoyageLOLOJobSheet then
				continue;
			endif;
			
			allJSByCrane.add (aJS);
		endforeach;
	endif;
	
	startRow := self.tblStats.fixedRows + 1;
	// go through all the jobSheets and display the details
	foreach anObj in allJSByCrane do
		aJS := anObj.CM_VoyageJobSheet;
		if aJS.crane &lt;&gt; craneStr and craneStr &lt;&gt; null then
			if self.kpiDetail &lt;&gt; self.KPIDetail_Voyage then
				tmpLbl := self.myCurrentVoyage.vesselCode &amp; " " &amp; craneStr;
				self.showMoveStatsAverage(startRow, endRow, tmpLbl, idx, true);
				startRow := self.tblStats.rows + 1;
			endif;
			idx :=0;		
		endif;
		
		//if zNewStyleKPI then
			aJS.getKPIStringsForTableDetailNEW(self.tblStats, idx);
		/*
		else
			aJS.getKPIStringsForTableDetail(self.tblStats, idx);
		endif;
		*/
		
		self.tblStats.accessRow(self.tblStats.rows).backColor := self.getTotalColour(idx);
		endRow := self.tblStats.rows;
		craneStr := aJS.crane;
	endforeach;
	if self.kpiDetail &lt;&gt; self.KPIDetail_Voyage then
		tmpLbl := self.myCurrentVoyage.vesselCode &amp; " " &amp; craneStr;
		
		if startRow &lt; endRow then // PAR 20252
		self.showMoveStatsAverage(startRow, endRow, tmpLbl, idx, true);
		endif;
	endif;
	
	idx := idx + 1;
	startRow := self.tblStats.fixedRows + 1;
	endRow := self.tblStats.rows;
	tmpLbl := self.myCurrentVoyage.vesselCode &amp; " Grand";
	if startRow &lt; endRow then // PAR 20252
	self.showMoveStatsAverage(startRow, endRow, tmpLbl, idx, false);
	endif;
	
epilog
	delete allJSByCrane;
	delete theMachines;
end;</source>
    </JadeMethod>
    <JadeMethod name="showRORODecksStats" id="fd5c3a56-e0ed-4357-bc56-281c4ba6d11b">
        <source>showRORODecksStats() protected;
/*
Date		Who		Reason
09 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	table	:CM_DataTable;
	agent	:CMIF_OutputFormatAgent_ROROKPI;
begin
	if not self.isShowROROKPI then 
		return;
	endif;
	
	table := self.tblRORODecks;
	agent := self.myRORODecKOutputAgent;
	
	if table.rows &gt; table.fixedRows then 
		// already loaded
		return;
	endif;
	
	agent.displayDecksTable (self.myCurrentVoyage, table);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
