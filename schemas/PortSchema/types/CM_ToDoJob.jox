    <JadeMethod name="jobId" id="a9ec1490-6405-4734-83fc-027d8f3f8d64">
        <methodInvocation>mapping</methodInvocation>
        <source>jobId(set: Boolean; value: String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/

vars

	aStr : String;
	//maxLen : Integer;
	reqst : CM_Request;
	delReq : CM_YardDeliveryRequest;
	req	:	CM_YardMoveRequest;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.id.trimBlanks &lt;&gt; null then
		value := self.id;
		return;
	endif;
	reqst := self.allRequests.first;
	if reqst = null then
		value := "Unknown";
		return;
	endif;
	if reqst.isKindOf(CM_YardMoveRequest) then
		req := reqst.CM_YardMoveRequest;
		value := req.mySourceLocation.getFullId &amp; "-&gt;";
		if req.myTargetLocation &lt;&gt; null then
			value := value &amp; req.myTargetLocation.getFullId &amp; " " &amp; req.totalRequested.String;
		else
			value := value &amp; 'Unknown ' &amp; req.totalRequested.String;
		endif;
		return;
	elseif reqst.isKindOf(CM_YardDeliveryRequest) then
		delReq := reqst.CM_YardDeliveryRequest;
		if delReq.sourceLocation &lt;&gt; null then
			value := delReq.sourceLocation.getFullId;
		else
			value := "Unknown";
		endif;
		if delReq.targetLocation &lt;&gt; null then
			value := value &amp; " =&gt; "&amp; delReq.targetLocation &amp; " " &amp; delReq.totalRequested.String;
		else
			value := value &amp; " =&gt; "&amp; 'Unknown '  &amp; delReq.totalRequested.String;
		endif;
		return;	
	endif;

	if workListEntries.size &gt; 0 then
		if workListEntries.first.myTrackedItem &lt;&gt; null then
				aStr :=  workListEntries.first.myTrackedItem.id.trimBlanks &amp; "- Internal" ;
		endif;
	endif;

	if aStr = null then
		aStr := "Internal " &amp; getOidString();	
	endif;

	//maxLen := CM_Job.getProperty("jobId").getLength;
	if aStr.length &gt; JOBID_LEN -1 then
		aStr := aStr[1:JOBID_LEN -1];
	endif;
	value := aStr;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="85683752-482e-467a-8436-adade9ed1005">
        <updating/>
        <source>setForCreateInternal(_todoInternalJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwrd1	Initial creation

*/

vars
	req : CM_TiToDoRequest;
begin

	self.myTerminal := _terminal;
	self.id := _todoInternalJobParam.jobId;
	//self.type := _todoInternalJobParam.typeToCreate;

	self.allTrackedItems.clear();
	_todoInternalJobParam.allTIs.copy(self.allTrackedItems);
	
	self.myToDoTaskDesc := _todoInternalJobParam.myToDoTaskDesc;
	self.myWODtl := _todoInternalJobParam.myWorkOrderDtl.CM_WorkOrderTIDtl;

	
	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _todoInternalJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();

	self.addToJobSheet();
	

end;</source>
        <Parameter name="_todoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
