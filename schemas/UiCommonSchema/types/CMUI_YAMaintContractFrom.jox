    </JadeMethod>
    <JadeMethod name="setPriority" id="df9af52c-d9ac-478e-bf02-0c1dfdde7a41">
        <source>setPriority(criterias: CMIF_Array; _priority: Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2023 navnk30 Bug 59915: FR | EUP 54089 - Inv Contract - Auto Priority

*/

vars
	critPriority,
	allocPriority, 
	cnt 			: Integer;
	cmifObj		: CMIF_Object;
	criteriaObj	: CM_YACriteria;
	cmifCritObj	: CMIF_YACriteriaPriority;
begin
	cnt := -1;
	foreach cmifObj in criterias do
		if not cmifObj.isKindOf(CMIF_YACriteriaPriority) then
			continue;
		endif;
		
		cmifCritObj := cmifObj.CMIF_YACriteriaPriority;
		
		// ### TFS BUG 59915 20SEP2023 NAVAB1
		if cmifCritObj.isDeleted then
			continue;
		endif;
		
		criteriaObj := cmifCritObj.myProxy.CM_YACriteria;
		if criteriaObj = null then 
			continue;
		endif;
		
		cnt := cnt + 1;
		critPriority := (2 ^ cnt);
		criteriaObj.setPriorityValue(critPriority);
		allocPriority := allocPriority + critPriority;
	endforeach;
	_priority := allocPriority;
epilog

end;</source>
        <Parameter name="criterias" type="CMIF_Array"/>
        <Parameter name="_priority" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="953bf5be-810b-4f25-b5db-086ba7fede39">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria
08 Mar 2023 navtnr20	Bug 56765: EUP - Criteria Priority not being saved
28/11/2023	navkc1 		Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

begin
	inheritMethod();
	self.btnSave.caption := app.getErrorString(This_crieria); // 'Use This Crieria';	//navtnr20 08-03-2023 bug 56765
	self.openWithSavedSettings();
	
	self.lblYAColour.visible 	:= false;
	self.clrYAColour.visible 	:= false;

	self.grpTemplate.visible 	:= false;
	self.cmbIMEX.visible 		:= false;
	self.lblHeader.visible 		:= false;
	self.chkDisableYA.visible 	:= false;
	self.btnFindImex.visible 	:= false;
	self.shtLocation.visible 	:= false;
	self.shtOptions.visible 	:= false;
	self.txtGroupName.visible 	:= false;
	self.lblGroupName.visible 	:= false;
	self.txtImex.visible 		:= false;
	self.btnNext.visible 		:= false; 
	self.picCriteria.scrollBars := 0;
	self.picCriteria.height := 500;
	self.picCriteria.top := 10;
	self.picCriteria.parentAspect := Picture.ParentAspect_StretchBoth;
	self.resizeForContract();
	self.btnCancel.setCaptionForTranslation("&amp;Close");
	
	self.frmHeader.transparent 	:= true;
	// must set height before fldYardAlloc height
	self.height 				:= self.fldYardAlloc.top + self.clrYAColour.top + 60 + 80;
	self.fldYardAlloc.height 	:= self.clrYAColour.top + 60;
	self.shtRemarks.visible 	:= false;
	self.fldYardAlloc.top 		:= 25;
	
	self.mnuFile.visible 		:= false;
	self.mnuHelp.visible 		:= false;
	self.mnuOptions.visible 	:= false;
	self.mnuWindows.visible 	:= false;
	self.mnuTerminal.visible 	:= false;
	self.mnuView1.visible 		:= false;
	//self.fldYardAlloc.parentAspect := 0; // 28/11/2023	navkc1 Bug 60782
	self.fldYardAlloc.height := picCriteria.height + 90;
	self.setCaption("Invoice Contract Criteria -  ");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3e762384-bc93-4a19-b8c0-ba644c0081c8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:13:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025585, locale);
	btnMoreCriteria.translateCaption(Xlat_0025586, locale);
	btnRemove.translateCaption(Xlat_0025587, locale);
	lblDescription.translateCaption(Xlat_0025588, locale);
	lblPriority.translateCaption(Xlat_0025589, locale);
end;</source>
    </JadeMethod>
</GUIClass>
