    <JadeMethod name="getMyParent" id="78b904fb-bab0-4ec1-b347-39efcef4ed49">
        <source>getMyParent(): CM_HSCodeChapter;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.myHSChapter &lt;&gt; null and self.myHSChapter.isTransient and not self.myHSChapter.pxyIsProxy then
		return app.myRoot.allHSChapters[self.myHSChapter.id];
	endif;
	
	return self.myHSChapter;

epilog

end;</source>
        <ReturnType type="CM_HSCodeChapter"/>
    </JadeMethod>
