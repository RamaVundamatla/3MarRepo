    <JadeMethod name="delete" id="53a9683c-056b-4796-ac03-d2adc9b849c1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2014	cnwmc5	Initial creation

*/

vars

begin
	self.allTIHazards.purge();
	self.allSpecialLifts.purge;
	delete self.cargoType;
	delete self.commodity;
	delete self.isoGroup;
	delete self.isoType;
	delete self.product;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="86e0d9ce-89d9-4e14-be1d-4528be2c5f57">
        <updating/>
        <source>setProxyFromObject(_bookingItem: CM_BookingRefItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Nov 2014	cnwmc5	Initial creation
09 May 2018	cnwma1	ChangeRequest 38518: PEL1 - WP Cargo Receivals
17 Mar 2020	jlgdap1	TFS 47457 Web Portal Bookings
08 Jan 2026 navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/

vars
	hazard : CM_Hazard;
	wsHazard : WS_TIHazard;
	specialLift : CM_SpecialLift;
	wsSpecialLift : WS_SpecialLift;
	myReserveDetail : CM_ReserveDetail;
	avalGrade : CM_MTGrade;
	
begin
	inheritMethod(_bookingItem);
	
	self.carbonDioxide := _bookingItem.getCarbonDioxide();
	
	if _bookingItem.myCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(_bookingItem.myCargoType);
	endif;
	
	if _bookingItem.getCommodityObj() &lt;&gt; null then
		create self.commodity transient;
		self.commodity.setProxyFromObject(_bookingItem.getCommodityObj());
	endif;
	
	self.curtainsIn := _bookingItem.getCurtainsIn();
	self.density := _bookingItem.density;
	self.generatorType := _bookingItem.generatorType;
	self.height := _bookingItem.height;
	self.humidity := _bookingItem.getHumidity();	
	
	if _bookingItem.getISOTypeGroupObject() &lt;&gt; null then
		create self.isoGroup transient;
		self.isoGroup.setProxyFromObject(_bookingItem.getISOTypeGroupObject());
	endif;
	
	if _bookingItem.myISOType &lt;&gt; null then
		create self.isoType transient;
		self.isoType.setProxyFromObject(_bookingItem.myISOType);
		if _bookingItem.getISOTypeGroupObject = null and _bookingItem.myISOType.myISOTypeGroup &lt;&gt; null then		// TFS 47457
			create self.isoGroup transient;																		// TFS 47457
			self.isoGroup.setProxyFromObject(_bookingItem.myISOType.myISOTypeGroup);							// TFS 47457
		endif;																									// TFS 47457
	endif;
	
	self.length := _bookingItem.length;
	self.markNumber := _bookingItem.markNumber;
	self.marks := _bookingItem.shippingMarks;
	self.oxygen := _bookingItem.getOxygen();
	
	if _bookingItem.myProduct &lt;&gt; null then
		create self.product transient;
		self.product.setProxyFromObject(_bookingItem.myProduct);
	endif;
	
	self.productQuantity := _bookingItem.productQuantity;
	self.productVolume := _bookingItem.productVolume;
	self.productWeight := _bookingItem.productWeight;
	self.quantity := _bookingItem.quantity;
	self.remarks := _bookingItem.remarks;
	self.sequence := _bookingItem.sequence;
	self.temperature := _bookingItem.getTemperature();
	self.vent := _bookingItem.getVentilation();
	self.ventUnits := _bookingItem.getVentilationUnits();
	self.volume := _bookingItem.volume;
	self.weight := _bookingItem.weight;
	self.width := _bookingItem.width;
	//self.description := _bookingItem.getDisplayString();
	//22/2/18 epr webportal better to display the voyage code 
	self.description := _bookingItem.myBookingReference.voyageCode &amp; " " &amp; _bookingItem.getAmountDisplay() &amp; " x ";
	if _bookingItem.myCargoType.id = TI_CargoType_Container then
		if _bookingItem.myISOType &lt;&gt; null then
			self.description  := self.description  &amp; _bookingItem.myISOType.code;
		elseif _bookingItem.isoTypeGroup &lt;&gt; null then
			self.description  := self.description  &amp; _bookingItem.isoTypeGroup;
		endif;
	elseif _bookingItem.myCargoType.isTrailer then  //epr par 33302 15/1/14
		self.description  := self.description  &amp; _bookingItem.trailerType;
	else
		self.description := self.description &amp; _bookingItem.cargoTypeDescr;
		if _bookingItem.myProduct &lt;&gt; null then
			self.description  := self.description  &amp; " - " &amp; _bookingItem.myProduct.code;
		endif;
	endif;
	
	//epr webportal dev 20/2/18
	self.cargoID :=_bookingItem.id;
	if _bookingItem.mySpecialStow &lt;&gt; null then
		self.specialStow:=_bookingItem.mySpecialStow.code;
	endif;
	foreach specialLift in _bookingItem.allSpecialLifts discreteLock do
		create wsSpecialLift transient;
		wsSpecialLift.setProxyFromObject(specialLift);
		self.allSpecialLifts.add(wsSpecialLift);
	endforeach;
	
	foreach hazard in _bookingItem.allTIHazards where hazard.isKindOf(CM_TIHazard) do
		create wsHazard transient;
		wsHazard.setProxyFromObject(hazard);
		self.allTIHazards.add(wsHazard);
	endforeach;
	self.prenoteCount := _bookingItem.getPrenotedCount(); //  9.5.2018 cnwma1 TFs #38518 
	self.onsiteCount :=  _bookingItem.getRecievedCount(); //  9.5.2018 cnwma1 TFs #38518 
	
	self.purchaseOrder := _bookingItem.purchaseOrder;			// TFS 47457
	self.serviceOrder := _bookingItem.serviceOrder;				// TFS 47457
	
	self.matchMode := _bookingItem.matchMode;					//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.clean := _bookingItem.clean;							//navtr3 MTN-36695
	self.inspected := _bookingItem.inspected;
	
	myReserveDetail := _bookingItem.myReserveDetail;
		if myReserveDetail &lt;&gt; null then
			self.maxToRelease := myReserveDetail.maxToRelease;
			if myReserveDetail.isKindOf(CM_ReserveSelection) then
				if myReserveDetail.CM_ReserveSelection.allAvailabilityGrades.size() &gt; 0 then
					avalGrade := app.myRoot.allAvailableAvailabilityGrades[myReserveDetail.CM_ReserveSelection.allAvailabilityGrades.first];
					if avalGrade &lt;&gt;  null then
						self.grade := avalGrade.code;
					else
						self.grade := NULL_INTEGER;
					endif;
				endif;	
				
				self.heavyRated := myReserveDetail.CM_ReserveSelection.heavyRated;
			endif;
		endif;	//navtr3 MTN-36695
epilog
	
end;</source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
    </JadeMethod>
</Class>
