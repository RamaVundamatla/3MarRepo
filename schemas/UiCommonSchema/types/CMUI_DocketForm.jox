    <JadeMethod name="restrictEntryForLogDocket" id="0c43f5eb-8a4f-4b8c-84f1-f538bf54c45c">
        <updating/>
        <source>restrictEntryForLogDocket(_bol : CM_BOL) updating, protected;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	idx : Integer;
	theCell : JadeTableCell;
begin

	if (not _bol.isKindOf(CM_BOLIn)) then
		return;
	endif;
	
	if (not _bol.CM_BOLIn.isMatched) and
	   (not _bol.CM_BOLIn.isQueuedToMove) and
	   _bol.myPlannedLocation &lt;&gt; null then
	   	// Logs have not been queued or moved to the yard yet.
		// no restrictions can edit every field.
		self.hasLocationRestricted := false;		// it makes sense to set false at least in one place. cnwvu1

		// have to enable these fields incase they have been disabled by previous edit. 
		self.tblMain.enableRowByName(ETRow_JasScaled);
		self.tblMain.enableRowByName(ETRow_PercentScaled);
		self.tblMain.enableRowByName(ETRow_TicketedAll);		
		self.tblMain.enableRowByName(ETRow_Supplier);
		self.tblMain.enableRowByName(ETRow_LogSpeciesCode);
		self.tblMain.enableRowByName(ETRow_LogGradeCode);
		self.tblMain.enableRowByName(ETRow_LogTypeCode);
		self.tblMain.enableRowByName(ETRow_LogTreatmentCode);
		self.tblMain.enableRowByName(ETRow_LengthRandom);
		self.tblMain.enableRowByName(ETRow_LogLocation);
		self.tblMain.enableRowByName(ETRow_NumItems);
		self.tblMain.enableRowByName(ETRow_TicketSequence);
		return;	
	endif;

	//Log have been moved to the yard BUT docket may not be matched.
	if _bol.CM_BOLIn.isMatched then
		self.tblMain.disableRowByName(ETRow_JasScaled);
		self.tblMain.disableRowByName(ETRow_TicketedAll);
		self.tblMain.disableRowByName(ETRow_PercentScaled);
		

	endif;  
	

	//Allow docket number to be edited at anytime RJS NOV 02
	//self.tblMain.disableRowByName(ETRow_DocketNumber);
	
	// ccms 1089 - if docket has been matched today, we should be able to edit all these fields
	if _bol.CM_BOLIn.isMatched() and _bol.CM_BOLIn.isMatchedTodayForDocketCorrect() then
		// the rows are enabled allready
		self.pressedButtonEditDocketCorrect := self.systemToLocalTime(app.actualTimeServer()).Date;	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
	else
		self.tblMain.disableRowByName(ETRow_Supplier);
		self.tblMain.disableRowByName(ETRow_LogSpeciesCode);
		self.tblMain.disableRowByName(ETRow_LogGradeCode);
		self.tblMain.disableRowByName(ETRow_LogTypeCode);
		self.tblMain.disableRowByName(ETRow_LogTreatmentCode);
		self.tblMain.disableRowByName(ETRow_LengthRandom);
	endif;
		
	if _bol.myPlannedLocation = null then	// _bol has been matched, and we should disable Location
		// However, we can still edit the Location for the docket correction
		if _bol.CM_BOLIn.isMatchedTodayForDocketCorrect() then
			// Location is enabled and ready for changes for the docket correction
		else
		// Cannot change location as logs already moved to location
			self.tblMain.disableRowByName(ETRow_LogLocation);
		endif;
	endif;
	
	self.hasLocationRestricted := true;
	self.tblMain.disableRowByName(ETRow_NumItems);
	self.tblMain.disableRowByName(ETRow_TicketSequence);



end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="saveEntTblSpecial" id="c610ad4e-cb8f-4206-af4b-68e827e90068">
        <updating/>
        <source>saveEntTblSpecial(_attrName : String;
				_strValue : String;
				_obj : Object input;
				_tbl : CM_EntryTable input) : Boolean updating, protected;
/*

Date		Who		Reason
01 November 2016	cnwer1	Initial creation TFS 2889

*/

vars
	cmifBOLIn : CMIF_BOLIn;
	
begin
	if _obj = null then
		return false;
	endif;
	
	if not _obj.isKindOf(CMIF_BOLIn) then
		return false;
	endif;
	
	cmifBOLIn:= _obj.CMIF_BOLIn;
	
	//epr TFS 2889 1/11/16

	if cmifBOLIn.stripCarriageReturns(_attrName,_strValue) then
		return true;
	endif;
	
	if _attrName = ETRow_DocketNumber then
		cmifBOLIn.bolNumber := _strValue;
		return true;
	elseif _attrName = ETRow_Supplier then
		cmifBOLIn.operatorCode :=_strValue;
		return true;
	elseif _attrName = ETRow_LoggingContractor then
		cmifBOLIn.handlingContractor1 := _strValue;
		return true;
	elseif _attrName = ETRow_LoadingContractor then
		cmifBOLIn.handlingContractor2 := _strValue;
		return true;
	elseif _attrName = ETRow_LoggingGang then
		cmifBOLIn.gangNumber := _strValue;
		return true;
	
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
