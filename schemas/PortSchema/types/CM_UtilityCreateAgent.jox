    <JadeMethod name="utlCreateCargoCheckItem" id="3ef2d574-bb83-4458-ac2b-3af0d81d2c2f">
        <source>utlCreateCargoCheckItem(	_pxyCargoCheckItem : CM_CargoCheckItem input; 
							_allCriteria : CMIF_Array input;
							_cargoCheck : CM_CargoCheck input;
							_newCargoCheckItem : CM_CargoCheckItem output;
							_passport : CM_Passport input	);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCargoCheckItem(_pxyCargoCheckItem);
	
	self.raiseExceptionIfNull(_cargoCheck, 'Cargo Check');
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newCargoCheckItem persistent;

	_newCargoCheckItem.setForCreate(_pxyCargoCheckItem, _allCriteria, _cargoCheck);
	
	if _passport.noErrors then  //cnwrd1 par 25599 3.9.2010
		_newCargoCheckItem.persistCriteria(_allCriteria, _passport);
	endif;
end;</source>
        <Parameter name="_pxyCargoCheckItem" type="CM_CargoCheckItem" usage="input"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_cargoCheck" type="CM_CargoCheck" usage="input"/>
        <Parameter name="_newCargoCheckItem" type="CM_CargoCheckItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCargoForecast" id="a65dd998-eb4f-43d1-b7d1-7a4d942eecbf">
        <source>utlCreateCargoForecast(_pxyCargoForecast : CM_CargoForecast; _newCargoForecast : CM_CargoForecast output; _passport : CM_Passport input);
/*

Purpose:			Utility to create a new Cargo Forecast from Proxy object passed in and gives a new gate scan record out

Parameters:			_pxyCargoForecast	CM_CargoForecast	Proxy cargo forecast to create real object from (Input meaning it gets passed in as a constant)
					_newCargoForecast	CM_CargoForecast	Real cargo forecast created (Output meaning it is passed outwards)
					_passport			CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	expectedEdition : Integer;
	voyage : CM_Voyage;

begin
	self.initialiseActivity();
	
	_pxyCargoForecast.raiseExceptionIfNotTransient(method);
	
	app.setContinueCMExceptions(true);

	app.myValCA.valCargoForecast(_pxyCargoForecast);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newCargoForecast persistent;
	_newCargoForecast.setForCreate(_pxyCargoForecast);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newCargoForecast);
	endif;
	
	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		if _newCargoForecast.myParent &lt;&gt; null then
			self.updateObjectEdition(_newCargoForecast.myParent);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_pxyCargoForecast" type="CM_CargoForecast"/>
        <Parameter name="_newCargoForecast" type="CM_CargoForecast" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCargoGroupDetails" id="1100e723-ca20-4ca7-8768-6b0db0f8e9c7">
        <updating/>
        <source>utlCreateCargoGroupDetails(_controller : CMIF_CargoGroupDtlController; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2022	navam1	Initial creation
TFS 53390
*/

vars
	cargoGroup : CM_CargoGroup;

	term : CM_Terminal;
	voyage : CM_Voyage;
	payLoad : CM_Object;
	cmifEventCtrl	: CMIF_EventTransactionCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	_controller.getCargoGroups();
	
	if _controller.purgeExisting then
	 // ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
		foreach cargoGroup in _controller.allCargoGroups as CM_CargoGroup discreteLock do
			cargoGroup.allCargoGroupDetails.purge;
		endforeach;
	endif;
	
	_controller.recalculateForVoyage(); // ### TFS BUG 58853 06JUL2023 NAVAB1
	
	 // ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
	term := _controller.myTerminal;
	if _controller.myVoyage &lt;&gt; null then
		voyage := _controller.myVoyage;
		payLoad := voyage;
	endif;
	
	
	if _passport.noErrors then
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		// raise event notification
		app.createEvent(EVT_CargoGroupDetail, app.actualTimeServer, term, _passport.userCode, false, false, null);
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_CargoGroupDetail;
		cmifEventCtrl.dateTime := app.actualTimeServer();
		cmifEventCtrl.myTerminal := term;
		cmifEventCtrl.userCode := _passport.userCode;
		
		app.createEventUsingCMIF(cmifEventCtrl);
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		
		// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
		foreach cargoGroup in _controller.allCargoGroups as CM_CargoGroup discreteLock do
			cargoGroup.updateObjectEdition(cargoGroup);
		endforeach;
		// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1 - might have created new cargo group details for new cargo groups
		if voyage &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, _passport.myTerminal.getTerminalEvent(EVENT_VOYAGE_CARGOGROUP_DETAIL), payLoad);
		endif;
	endif;
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_controller" type="CMIF_CargoGroupDtlController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCargoPhoto" id="c96aa7b4-6694-43b8-85c7-7ffe7e98a2d3">
        <source>utlCreateCargoPhoto(_proxyPhoto:CM_Photo input; _newPhoto:CM_Photo output; _passport : CM_Passport input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2009	#cnwdz2	par21808
28/09/2010  cnwas3 	par 25243
15/06/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/
vars
	beforeValue, 
	afterValue, 
	tmpStr 			: String;
	tiParent 		: CM_TrackedItem;
	hazardParent	: CM_HazardClass;		
	taParent		: CM_TerminalArea;
	pxyParent		: CM_Object;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	pxyParent := _proxyPhoto.myParent;		//22.04.2025 navma1 #MTN-34387
	if   pxyParent &lt;&gt; null and pxyParent.isKindOf(CM_TrackedItem) then 
		tiParent := pxyParent.CM_TrackedItem;
	elseif pxyParent &lt;&gt; null and pxyParent.isKindOf(CM_TerminalArea) then // ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		taParent := pxyParent.CM_TerminalArea;
	elseif _proxyPhoto.CM_Symbol.myHazardClass &lt;&gt; null then				// PAR #36421
		hazardParent := _proxyPhoto.CM_Symbol.myHazardClass;			// PAR #36421
		_proxyPhoto.CM_Symbol.validateMe(app.myPassport);				// PAR #36421
	else
		return;
	endif;
	
	if tiParent &lt;&gt; null then											// PAR #36421
		beforeValue := tiParent.getAttachmentsAuditText(true);
	elseif taParent &lt;&gt; null then 										// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, true);
	elseif hazardParent &lt;&gt; null then									// PAR #36421
		beforeValue := hazardParent.getAttachmentsAuditText();			// PAR #36421
	endif;																// PAR #36421
	
	if tiParent &lt;&gt; null or taParent &lt;&gt; null then 						// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		create _newPhoto persistent;
	elseif hazardParent &lt;&gt; null then									// PAR #36421
		create _newPhoto as CM_Symbol persistent;						// PAR #36421
	endif;																// PAR #36421
	_newPhoto.setForCreate(_proxyPhoto);
	
	if tiParent &lt;&gt; null then											// PAR #36421
		afterValue := tiParent.getAttachmentsAuditText(true);	
	elseif taParent &lt;&gt; null then 										// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, false);
	elseif hazardParent &lt;&gt; null then									// PAR #36421
		afterValue := hazardParent.getAttachmentsAuditText();			// PAR #36421
	endif;																// PAR #36421
	
	if beforeValue = null then
		tmpStr := app.getErrorString(Attached_photo) &amp; afterValue;
	elseif beforeValue &lt;&gt; afterValue then
		tmpStr := app.formatForEditTransaction(app.getErrorString(Attached_photos_changed), beforeValue, afterValue);	
	endif;
	
	
	if _passport.noErrors and tmpStr &lt;&gt; null and tiParent &lt;&gt; null then	// PAR #36421									
		app.createEditTransaction(tiParent, tmpStr, null, _passport);	//20.02.2024 navhl20 #62525
	endif;
	
	
	/*
	31.03.2025 navma1 #MTN-34387
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newPhoto);
	endif;
	*/

epilog

end;</source>
        <Parameter name="_proxyPhoto" type="CM_Photo" usage="input"/>
        <Parameter name="_newPhoto" type="CM_Photo" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCargoType" id="99d895eb-225b-4d97-ab28-cd92b53238e6">
        <source>utlCreateCargoType(pProxyCargoType : CM_CargoType; 
				pNewCargoType : CM_CargoType output;
				_pxyDraw : CM_DrawingAttribute;
				_pxySystemProduct : CM_Product input;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave 	: Boolean;
	newDraw		: CM_DrawingAttribute;
	newProduct	: CM_Product;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCargoType(pProxyCargoType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewCargoType persistent;
	
	if _pxyDraw &lt;&gt; null then
		pNewCargoType.createDrawingAttribute();
		pNewCargoType.myDrawingAttribute.setForCreate(_pxyDraw); 
	endif;
	
	pNewCargoType.setForCreate(pProxyCargoType);
	
	// CCMS 1080, PAR 19704 MAy 2009
	//create new system dummy product for a user-defined cargo type which doesn't require subcargo types
	if _passport.noErrors and _pxySystemProduct &lt;&gt; null then	//_pxySystemProduct can be null, when reseting cargo types for new JMT release: root.resetCargoTypes()
		if not pNewCargoType.isSystemCargoBOLType and pNewCargoType.requiresSystemProductType() then
			self.utlCreateProduct(_pxySystemProduct, newProduct, _passport);
			if _passport.noErrors then
				pNewCargoType.setSystemProductType(newProduct);
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewCargoType);
	endif;
	
	//navsp1 31MAY2022 TFS#53104 - GC --&gt;&gt;
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			pNewCargoType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOTYPE, pNewCargoType);
		endif;
	endif;
	//&lt;&lt;--
end;</source>
        <Parameter name="pProxyCargoType" type="CM_CargoType"/>
        <Parameter name="pNewCargoType" type="CM_CargoType" usage="output"/>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute"/>
        <Parameter name="_pxySystemProduct" type="CM_Product" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCargoTypeAttribPlan" id="90807def-97c0-4832-b3e9-8b192766f1e1">
        <source>utlCreateCargoTypeAttribPlan(_proxyAP:CM_AttributePlan; _newAttributePlan:CM_AttributePlan output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
