    <JadeMethod name="doDataComparison" id="236f36c9-5b34-4f9d-b841-522ed91a2ae4">
        <source>doDataComparison(_yaData: SelfType): Boolean;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars
	valueArray : StringArray;
	priorityArray : StringArray;
	valueString,
	priorityString : String;
begin
	if self.value = null then
		return true;
	endif;
	
	//+cnwml2 PAR24472
	create valueArray transient;
	create priorityArray transient;
	
	self.value.getTokensForDelimiter(",", valueArray);
	_yaData.value.getTokensForDelimiter(",", priorityArray);
	
	foreach valueString in valueArray do
		foreach priorityString in priorityArray do
			if valueString = priorityString then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;
	
epilog
	delete valueArray;
	delete priorityArray;
end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataComparisonWithResolution" id="846d89ce-d31e-4c71-aa33-7205542ce645">
        <source>doDataComparisonWithResolution(_yaData: CM_YAData): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 August 2008	consw1	Initial creation

*/

vars

begin
	return self.doDataComparison(_yaData.CM_YADataString);

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesValueMatch" id="549e594f-2042-42c0-a97c-772ce84a7de7">
        <source>doesValueMatch(_stringValue : String) : Boolean;
vars
	pattern: CMIF_YAPattern;
	value: String;
begin
	value := _stringValue.toUpper();	// PAR 32190
	create pattern transient;
	if self.myCriteriaType &lt;&gt; null then
		pattern.setPattern(self.value, self.myCriteriaType.getPatternType);
	else
		pattern.setPattern(self.value, self.myYAParent.myYACriteriaType.getPatternType);
	endif;
	
	//if pattern.isPattern() or self.value.containsOneOf(",")then		//-cnwml2 PAR25298
//	if pattern.isPattern() or (self.value &lt;&gt; null and self.value.containsOneOf(","))then			//+cnwml2 PAR25298
	if pattern.isPattern() or pattern.hasWildcard() or ( self.value &lt;&gt; null and self.value.containsOneOf(",") )then //08 May 2020	NDL	TFS 49291
		if self.value.toUpper() =  value then	//07 Apr 2016	NDL	TFS 1799 - it might just be an item that has  a hyphen in its name.
			return true;
		else
			return pattern.match(value);
		endif;
	else
		if self.value.isDecimal then	//07 Apr 2016	NDL	TFS 1799
			return self.value.cnEcStripDecimalZeros.asStringJMT() = value.cnEcStripDecimalZeros.asStringJMT();
		else
			return self.value.toUpper() =  value;
		endif;
	endif;
epilog
	delete pattern;
end;</source>
        <Parameter name="_stringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
