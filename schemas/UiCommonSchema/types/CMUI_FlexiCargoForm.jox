    <JadeMethod name="initFromPreNoteForm" id="cfca6179-e3d6-4b80-b9b8-e38d7b7402ec">
        <updating/>
        <source>initFromPreNoteForm(_preNoteForm : CM_BaseForm; _trackedItem : CM_TrackedItem; _brItem : CM_BookingRefItem; _preNote : CMIF_PreNote; _transportMode : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2009	cnwdap1	Initial creation
17/12/2009	cnwdap1	PAR #21827 Allow attachment to be edited directly from this form - correct setting of proxies
12/03/2010	cnwdap1	PAR #23164 Correct re-displaying a CMIF_PreNote transient attachment object
*/
vars

begin
	self.isPreNoteForm			:= true;
	self.isFlexiGateForm		:= false;
	self.setParentForm(_preNoteForm);
	self.myMainForm 			:= _preNoteForm;
	self.myCurrentVehicleVisit 	:= null;
	self.currentTransNum 		:= null;
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= null;
	self.myBookingRefItem 		:= null;
	self.myCargoType			:= null;
	
	if _trackedItem &lt;&gt; null then
		// PAR #21827 Correct proxy/real ti handling for attachment editing
		if _trackedItem.isTransient then
			self.myTI				:= _trackedItem.pxyGetRealObject();
			self.myProxyTrackedItem	:= _trackedItem;
		else
			self.myTI			 	:= _trackedItem;
			self.myProxyTrackedItem := _trackedItem.pxyGetProxyObject();
			if self.myProxyTrackedItem = null then
				self.myProxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
			endif;
		endif;
		self.updateMode 		:= self.Mode_Update;
	elseif _preNote &lt;&gt; null then
		// PAR #23164 are we editing an existing prenote transient
		self.updateMode 		:= self.Mode_Update;
	else
		self.updateMode 		:= self.Mode_Add;
	endif;

	if _brItem &lt;&gt; null then 
		// setupForm() will pick this up and set the fileds accordingly, after initilisation of combos etc.
		self.myBookingRefItem 	:= _brItem;
	endif;
	
	if _preNote &lt;&gt; null then
		self.myIntFacePreNote 	:= _preNote;
	endif;
	
	if _transportMode &lt;&gt; null then
		self.transportMode 		:= _transportMode;
	endif;

epilog

end;</source>
        <Parameter name="_preNoteForm" type="CM_BaseForm"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_preNote" type="CMIF_PreNote"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromRailCargoForm" id="54e7cf79-52d2-40e9-83a6-01f62897e139">
        <updating/>
        <source>initFromRailCargoForm(_cargoForm : CM_BaseForm; _trackedItem : CM_TrackedItem; _cargoType : CM_CargoType) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2009	cnwdap1	Initial creation
21/09/2022 navhl20 ChangeRequest 54612: MTN - Create Cargo On Wagon
*/
vars

begin
	//self.isPreNoteForm			:= false;		//21/09/2022 navhl20 TFS 54612
	self.isPreNoteForm			:= true;		//21/09/2022 navhl20 TFS 54612
	self.isFlexiGateForm		:= false;
	//self.isRailPreNoteForm		:= true;		//21/09/2022 navhl20 TFS 54612
	self.isRailPreNoteForm		:= false;		//21/09/2022 navhl20 TFS 54612
	self.setParentForm(_cargoForm);
	self.myMainForm 			:= _cargoForm;
	self.myCurrentVehicleVisit 	:= null;
	self.currentTransNum 		:= null;
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= null;
	self.myBookingRefItem 		:= null;
	
	if _trackedItem &lt;&gt; null then
		self.myTI			 	:= _trackedItem;
		if _trackedItem.isTransient then
			self.myProxyTrackedItem := _trackedItem;
		else
			self.myProxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
		endif;
		self.updateMode 		:= self.Mode_Update;
	else
		self.updateMode 		:= self.Mode_Add;
	endif;
	
	if _cargoType &lt;&gt; null then
		self.myCargoType		:= _cargoType;
	else
		self.myCargoType		:= null;
	endif;

	// no Next button
	btnNext.visible := false;	
	self.transportMode := "Rail";	//21/09/2022 navhl20 TFS 54612
epilog

end;</source>
        <Parameter name="_cargoForm" type="CM_BaseForm"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
