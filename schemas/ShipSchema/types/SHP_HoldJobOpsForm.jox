// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	coll : ObjectSet;
	
begin
	app.mousePointer := Busy;
	create coll transient;
	
	// Get a collection of all the objects SELECTED to pass to the Summary Definition form.
	self.tblJobDetails.allSelectedObjects.copy(coll);
	self.myAssistant.showXTABSummaryDefinitionForm(coll, false, false, false, true);
	
epilog
	delete coll;
	app.mousePointer := Idle;
end;</source>
