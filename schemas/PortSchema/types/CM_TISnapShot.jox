    </JadeMethod>
    <JadeMethod name="getCandHOperatorCode" id="1e8de371-3054-476d-ad40-d87dea71761b">
        <source>getCandHOperatorCode(_useOriginal : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     10 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _useOriginal and
	   CM_UserTISnapShot.hasInstance(self) then
		return self.CM_UserTISnapShot.myTISnapShot.operatorCode;
	else
		return self.operatorCode;
	endif;

end;</source>
        <Parameter name="_useOriginal" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCandHShipPortGroup" id="7afdf928-3e69-47d8-aa83-b54b4ecdc8dd">
        <source>getCandHShipPortGroup() : CM_ShipPortGroup;
// ---------------------------------------------------------------------------
// Created:     10 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 26/10/2010	cnwdap1		PAR #26146 Correct tranship handling
// 03/11/2010	cnwdap1		PAR #26146 Resubmit
// 08/09/2016   cnwma1      TFS #2671:MSL - UE 1090 in app UiCommonSchema::BGP_GenericController of MESPJMT
vars
	tmpVoyage		: CM_Voyage;
	tmpShipPortGroup	: CM_ShipPortGroup;
	portCode	: String;
	port		: CM_Port;
	shipPort	: CM_ShipPort;
	
begin
	tmpVoyage := self.getVoyage();
	
	if self.imExStatus = TI_IMEX_STATUS_IMPORT or
	   self.imExStatus = TI_IMEX_STATUS_EXPORT or
	   self.imExStatus = TI_IMEX_STATUS_TRANSHIP or		// PAR #23645 CCMS 1116
	   self.imExStatus = TI_IMEX_STATUS_STORAGE then
	
		if tmpVoyage &lt;&gt; null then
			if self.imExStatus = TI_IMEX_STATUS_IMPORT then
				portCode := self.loadPort;
			elseif self.imExStatus = TI_IMEX_STATUS_EXPORT then//or self.imExStatus = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116	// PAR #26146
				portCode := self.dischargePort;
			// PAR #26146 split tranship processing out to separate tranship import and tranship export
			elseif self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
				if tmpVoyage = self.myTrackedItem.myImportVoyage then
					if self.myTrackedItem.myTranshipDetail &lt;&gt; null then
						portCode := self.myTrackedItem.myTranshipDetail.importOriginalLoadPort;
					endif;
					if portCode = null then
						portCode := self.loadPort;
					endif;
				elseif tmpVoyage = self.myTrackedItem.myExportVoyage then
					portCode := self.dischargePort;
				endif;
			// PAR #26146 end
			elseif self.imExStatus = TI_IMEX_STATUS_STORAGE then
				portCode := self.loadPort;
			endif;
			
			port := app.myRoot.allPorts[portCode];
			if port &lt;&gt; null then
				if tmpVoyage.myShippingLine &lt;&gt; null then //08/09/2016 cnwma1 TFS #2671
					shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
				endif;
				if shipPort &lt;&gt; null then
					tmpShipPortGroup := shipPort.shipPortGroup;
				endif;
			endif;
		endif;

	elseif self.transitStatus = TI_TransitStatusSOB or
	   self.transitStatus = TI_TransitStatusDLR then

		if tmpVoyage &lt;&gt; null and
		   tmpVoyage.myDefaultLineGroupDebtor &lt;&gt; null then //par 15408 cnwrs1 nov 2007
			tmpShipPortGroup := tmpVoyage.myDefaultLineGroupDebtor.shipPortGroup;
		endif;
		
	endif;
	
	return tmpShipPortGroup;

end;</source>
        <ReturnType type="CM_ShipPortGroup"/>
    </JadeMethod>
    <JadeMethod name="getCandHShippingLine" id="19a803bb-392f-4f26-a9c7-c03560b8a907">
        <source>getCandHShippingLine() : CM_ShippingLine;
// ---------------------------------------------------------------------------
// Created:     10 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	tmpVoyage		: CM_Voyage;
	tmpShippingLine	: CM_ShippingLine;
	lgd				: CM_LineGroupDebtor;
	
begin
	tmpVoyage := self.getVoyage();
	
	if self.imExStatus = TI_IMEX_STATUS_IMPORT
	or self.imExStatus = TI_IMEX_STATUS_EXPORT
	or self.imExStatus = TI_IMEX_STATUS_TRANSHIP	// PAR #23645 CCMS 116
	or self.imExStatus = TI_IMEX_STATUS_STORAGE
	then
		if tmpVoyage &lt;&gt; null then
			tmpShippingLine	:=	tmpVoyage.myShippingLine;
		endif;
		
	elseif self.transitStatus = TI_TransitStatusSOB
	or self.transitStatus = TI_TransitStatusDLR
	then
		if tmpVoyage &lt;&gt; null then
// cnwdad1 16/03/2009 - PAR #19151.
//			lgd := tmpVoyage.myDefaultLineGroupDebtor;
//			tmpShippingLine	:=	lgd.shipPortGroup.shippingLine;
			tmpShippingLine	:=	tmpVoyage.myShippingLine;
			
			if tmpShippingLine = null then
				lgd	:=	tmpVoyage.myDefaultLineGroupDebtor;
				
				if lgd &lt;&gt; null then
					if lgd.shipPortGroup = null then
						app.raiseUnexpectedProgramError(class.name,
														method.name,
														"Line Group Debtor is missing a reference to a Shipping Line (OID=" &amp; lgd.String &amp; ")");
					else
						tmpShippingLine	:=	lgd.shipPortGroup.shippingLine;
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	return tmpShippingLine;
end;</source>
        <ReturnType type="CM_ShippingLine"/>
    </JadeMethod>
