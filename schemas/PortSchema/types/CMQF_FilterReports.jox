    <JadeMethod name="setTemplateDateFields" id="65e55e43-4167-4776-af20-176aada441fe">
        <source>setTemplateDateFields(_tplDateStr : String; _tplType, _tplFactor : Integer output; _attrName : String);
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	isEndMonth,
	isStartMonth				: Boolean;
	runDateLength,
	runMonthStartLength,
	runMonthEndLength,
	spacePos			: Integer;
	numStr,
	tplWholeStr,
	tplValueStr,
	tplTypeStr			: String;
	
begin

	tplWholeStr	:= _tplDateStr.trimBlanks.toUpper;
	tplWholeStr.cnReplaceChar(' ', null);

	runDateLength := RTPL_RunDateText.length;
	runMonthStartLength := RTPL_RunMonthStartText.length;
	runMonthEndLength := RTPL_RunMonthEndText.length;
	
	tplTypeStr := tplWholeStr[1:runDateLength];
	if tplTypeStr &lt;&gt; RTPL_RunDateText.toUpper then
		//doesn't fit DateTextStr so try MonthStart
		tplTypeStr := tplWholeStr[1:runMonthStartLength];
		if tplTypeStr &lt;&gt; RTPL_RunMonthStartText.toUpper then
			//doesn't fit MonthStart so try MonthEnd
			tplTypeStr := tplWholeStr[1:runMonthEndLength];
			if tplTypeStr &lt;&gt; RTPL_RunMonthEndText.toUpper then
				//we have a problem - doesn't fit any date string prefix
				return;//this will raise an exception - see epilog
			else
				isEndMonth := true;
			endif;
		else
			isStartMonth := true;
		endif;
	endif;

	//at this point 'tplTypeStr' will equal either 'RUNDATE' or 'RUNMONTHSTART' or 'RUNMONTHEND' - if this is the
	//equal to the str passed in, then we have enough.
	
	if tplTypeStr = tplWholeStr then
		if isEndMonth then
			_tplType 	:=  RTPL_RunMonthEnd;
			_tplFactor	:= 0;		
		elseif isStartMonth then
			_tplType 	:=  RTPL_RunMonthStart;
			_tplFactor	:= 0;
		else
			_tplType 	:=  RTPL_RunDate;
			_tplFactor	:= 0;
		endif;
		
		return;
	endif;
	
	if tplWholeStr.length &lt;= tplTypeStr.length then
		//prevents the line below causing and array out of bounds exception - shouldn't really ever get in here
		return;
	endif;
	
	//now get whatever is further on in the string - this should leave something like '+12' or '-56'
	tplValueStr := tplWholeStr[tplTypeStr.length + 1 : end];
	
	if tplValueStr.length &lt; 2 then
		// no room for trailing +/- and a number
		return;//this will raise an exception - see epilog
	endif;
	
	if tplValueStr[1] = '+' then
		if isEndMonth then
			_tplType := RTPL_RunMonthEndPlus;		
		elseif isStartMonth then
			_tplType := RTPL_RunMonthStartPlus;
		else
			_tplType := RTPL_RunDatePlus;
		endif;
	elseif tplValueStr[1] = '-' then
		if isEndMonth then
			_tplType := RTPL_RunMonthEndMinus;
		elseif isStartMonth then
			_tplType := RTPL_RunMonthStartMinus;
		else
			_tplType := RTPL_RunDateMinus;
		endif;
	else
		return;//this will raise an exception - see epilog
	endif;

	numStr := tplValueStr[2:end];
	if numStr.isInteger then
		_tplFactor	:= numStr.Integer;
	else
		_tplType := 0;		// reset to invalid
	endif;

epilog
	if _tplDateStr &lt;&gt; null and _tplType = 0 then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr, _tplDateStr, _attrName, _attrName, null);
	endif;

end;</source>
        <Parameter name="_tplDateStr" type="String"/>
        <Parameter name="_tplType" type="Integer" usage="output"/>
        <Parameter name="_tplFactor" type="Integer" usage="output"/>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
</Class>
