    <JadeMethod name="cmbTransportMode_click" id="33ab567d-dbc4-43aa-ae81-e295d3c6cd3d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTransportMode_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type is no longer translatable, replaced with string constants
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	self.viewTransportMode := cmbTransportMode.text;
	self.setNavigatorHeading(self.viewTransportMode);

	//if self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_ROAD) then // cnwrd1 par 18519 6.3.09	// PAR #27972
	if self.viewTransportMode = BR_TYPE_ROAD_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
		self.lastTransportMode := TI_TRANSMODE_ROAD;
	//elseif self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_RAIL) then							// PAR #27972
	elseif self.viewTransportMode = BR_TYPE_RAIL_STR then													// PAR #27972
		self.lastTransportMode := TI_TRANSMODE_RAIL;
	endif;
	
	self.showHideWagonColumn();
	self.zTblDataSortAndShow(true);
	self.zTblDataSelectObject(null);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
