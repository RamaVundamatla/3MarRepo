		self.loadDataFromObject( listbox.itemObject[listbox.listIndex]);
		
		if process.isCallum() then
			listbox.itemObject[listbox.listIndex].inspect;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
