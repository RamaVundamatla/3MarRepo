    <JadeMethod name="cmbSearchItem_keyUp" id="df86c25f-e8fc-4bc5-80b2-36ca7ce5fd9d">
        <controlMethod name="ComboBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchItem_keyUp(combobox: ComboBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2013	cnwndl1	Initial creation

*/

vars

begin

	if keyCode = J_key_Enter then
		// if something is selected then close the combo if it is open, or open it if it is closed
		if cmbSearchItem.listIndex &gt; 0 then
			if cmbSearchItem.isDroppedDown then
				cmbSearchItem.closeDropDown;
			else
				cmbSearchItem.showDropDown;
			endif;
		else // perform the search
			btnSearch.click(btnSearch);
			if not cmbSearchItem.isDroppedDown then
				cmbSearchItem.showDropDown;
			endif;
		endif;
		keyCode := 0;
	endif;


epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cmbSearchItem_lostFocus" id="87eb9103-87cb-42a9-9824-2d53ad26b0c4">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchItem_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	rawSearchText : String;
	cmifID : CMIF_IDConversion;
	searchText : String;
	
	
begin
	
	if cmbSearchItem.listObject = null then
		rawSearchText := self.cmbSearchItem.text.toUpper.trimBlanks;
		create cmifID transient;
		cmifID.scannedValue := rawSearchText;
		cmifID.myTerminal := self.myTerminal;
		cmifID.callerName := self.class.name;	//18 Aug 2016	NDL	TFS 2567
		searchText := app.convertScannedCargoId( null, null, false, cmifID );
		self.cmbSearchItem.text := searchText;
	endif;

epilog

	delete cmifID;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNewTrackedItem" id="b839c75d-11d2-4ca2-91cb-c5784c2b8df8">
        <source>createNewTrackedItem():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2017	cnwndl1	Initial creation	TFS 2314 - new version of method

*/

vars

	id : String;
	wagon : CM_Wagon;
	firstLocationsController : CM_LocationsController;
	isoText : String;
	ti : CM_TrackedItem;
	mess : String;

begin

	id := self.cmbSearchItem.text.trimBlanks.toUpper;
	if id = null then
		mess := app.getErrorString( ERR_INVALID_TI_ID );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	wagon := self.myMobileGenericAgent.myCurrentWagon;
	if wagon = null then
		mess := app.getErrorString(Please_select_wagon_POP);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	firstLocationsController := self.myMobileGenericAgent.myLocationsController;
	if firstLocationsController = null then
		mess := app.getErrorString(Please_select_positionPOP);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	isoText := self.txtIsoType.text.trimBlanks.toUpper;
	
	ti := wagon.createNewTIFromHandHeld(	id,	//_id : String;
											firstLocationsController,	//_firstLocationsController : CM_LocationsController;
											isoText,	//_isoText : String;
											self.class,	//_callingClass : Class;
											mess	//_mess : String output
											);
	
	
	if mess &lt;&gt; null then
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	return ti;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="7676691d-c8cc-4daa-9a40-7cfefc8d6796">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	str : String;
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	left : Real;
	height : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	width := ( stdWidth / 3 ) - self.resizedMargin;
	if _initialSetup then
		self.lblId.setAndIncrementTabIndex( tabIndex );
		self.lblId.visible := true;
	endif;
	self.lblId.move(	stdLeft,
						top,
						width,
						stdHeight );
	
	left := self.lblId.left + self.lblId.width + self.resizedMargin;
	width := self.lblId.width * 2  - (self.resizedMargin + stdHeight );
	if _initialSetup then
		self.txtId.setAndIncrementTabIndex( tabIndex );
		self.txtId.enabled := false;
		self.txtId.visible := true;
	endif;
	self.txtId.move(	left,
						top,
						width,
						stdHeight );
						
	// put the combo searcher in the same place.
	if _initialSetup then
		self.cmbSearchItem.setAndIncrementTabIndex( tabIndex );
		self.cmbSearchItem.parent := self;
		self.cmbSearchItem.visible := true;
	endif;
	self.cmbSearchItem.move(	left,
								top + 3, // combos draw thinner than text boxes.
								width,
								stdHeight );
						
	left := self.txtId.left + self.txtId.width + self.resizedMargin;
	width := stdHeight;
	if _initialSetup then
		self.btnSearch.setAndIncrementTabIndex( tabIndex );
		self.btnSearch.visible := true;
	endif;
	self.btnSearch.move(	left,
							top,
							width,
							stdHeight );
	
	top := self.txtId.top + self.txtId.height + self.resizedMargin;
	width := self.lblId.width;
	if _initialSetup then
		self.lblIsoType.setAndIncrementTabIndex( tabIndex );
		self.lblIsoType.visible := true;
	endif;
	self.lblIsoType.move(	stdLeft,
							top,
							width,
							stdHeight );
							
	left := self.lblId.left + self.lblId.width + self.resizedMargin;
	width := self.txtId.width;
	if _initialSetup then
		self.txtIsoType.setAndIncrementTabIndex( tabIndex );
		self.txtIsoType.visible := true;
	endif;
	self.txtIsoType.move(	left,
							top,
							width,
							stdHeight );
							
	top := self.txtIsoType.top + self.txtIsoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblCargoType.top + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblLocation.setAndIncrementTabIndex( tabIndex );
		self.lblLocation.visible := true;
	endif;
	self.lblLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblLocation.top + self.lblLocation.height + self.resizedMargin + ( stdHeight /2 );
	width := self.btnOne.width;
	left := ( stdWidth - width ) / 2;	//i.e. centred
	if _initialSetup then
		self.btnChecks.setAndIncrementTabIndex( tabIndex );
		self.btnChecks.visible := true;
	endif;
	self.btnChecks.move(	left,
							top,
							width,
							stdHeight );
	if _initialSetup then
		self.btnChecks.enabled := ( self.getCargoChecks &lt;&gt; null);
	endif;
	
	top := self.btnChecks.top + self.btnChecks.height + ( stdHeight / 2 );
	if _initialSetup then
		self.btnRemove.setAndIncrementTabIndex( tabIndex );
		self.btnRemove.visible := self.myMobileGenericAgent.inward;	// not allowed to remove cargo from outward bounnd wagons.
	endif;
	self.btnRemove.move(	left,
							top,
							width,
							stdHeight );


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchTIs" id="3319490b-9b4b-4b4c-9074-3d17277180c2">
        <updating/>
        <source>doSearchTIs() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	rawSearchText : String;
	cmifID : CMIF_IDConversion;
	
	searchText : String;
	ti : CM_TrackedItem;
	searchTIs : CM_TISet;
	obj : Object;
	forwardTIDict : CM_TIByCargoTypeIdDict;
	reverseTIDict : CM_TIByCargoTypeIdDictRev;
	newSearchTIs : CM_TISet;
	train : CM_Train;
	allTis : CM_TIArray;
	
begin
	
	train := self.myMobileGenericAgent.myCurrentTrain;
	searchTIs := self.getSessionAgent().allFoundTIs;
	searchTIs.clear();
	
	//07 Jul 2016	NDL TFS 2275 / 2216
//	searchText := cmbSearchItem.text.toUpper.trimBlanks;
	rawSearchText := cmbSearchItem.text.toUpper.trimBlanks;
	create cmifID transient;
	cmifID.scannedValue := rawSearchText;
	cmifID.myTerminal := self.myTerminal;
	cmifID.callerName := self.class.name;	//18 Aug 2016	NDL	TFS 2567
	searchText := app.convertScannedCargoId( null, null, false, cmifID );
	
	cmbSearchItem.clear();

	if searchText &lt;&gt; null then
		create forwardTIDict transient;
		create reverseTIDict transient;
		create newSearchTIs transient;
		create allTis transient;
		train.getAllTrackedItems(true, allTis);
		allTis.copy(forwardTIDict);
		forwardTIDict.lookupAllTIsUsingIdCargoType(searchText,TI_CargoType_Container,newSearchTIs,null);
		if newSearchTIs.isEmpty then
			allTis.copy(reverseTIDict);
			reverseTIDict.lookupAllTIsUsingIdCargoType(searchText,TI_CargoType_Container,newSearchTIs,null);
		endif;
		newSearchTIs.copyNoDuplicates(searchTIs,false);
	endif;

	if searchTIs.size &lt;&gt; 0 then
		foreach ti in searchTIs do
			cmbSearchItem.addItem(ti.id);
			cmbSearchItem.itemObject[cmbSearchItem.newIndex] := ti;
		endforeach;
	endif;

	
	cmbSearchItem.text := searchText;
	if cmbSearchItem.listCount &gt; 1 then
		cmbSearchItem.showDropDown();
	elseif cmbSearchItem.listCount = 1 then
		cmbSearchItem.listIndex := 1;
		handleSelectSearchItem(); // if only one is found then display the data for it
	elseif cmbSearchItem.listCount = 0 then
		handleSelectSearchItem(); // if none are found then clear the data
	endif;
	
epilog

	delete forwardTIDict;
	delete reverseTIDict;
	delete newSearchTIs;
	delete allTis;
	delete cmifID;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCargoChecks" id="47c23b12-bf35-4677-b9f6-01b658a7120d">
        <source>getCargoChecks():CM_CargoCheck;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	cargoCheck : CM_CargoCheck;
	
begin

	if self.myMobileGenericAgent.inward then
		cargoCheck := self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_RAIL_REC];
	else
		cargoCheck := self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_RAIL_REL];
	endif;
	
	if cargoCheck = null then
		return null;
	elseif cargoCheck &lt;&gt; null then
		if cargoCheck.allCargoCheckItems.isEmpty then
			return null;
		endif;
	endif;
	
	return cargoCheck;
	
epilog

end;</source>
        <ReturnType type="CM_CargoCheck"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="56b16180-50d9-4cdc-8637-44a04a51abff">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

constants
	Bullet = 149;
vars

begin

	return app.getErrorString(RAILHHHELP_TI001) &amp; CrLf  &amp; CrLf &amp;
			//Enter and Confirm details for the cargo.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI002) &amp; CrLf  &amp;
			//ID. Choose a pre noted item, else enter a new ID to create new cargo.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI003) &amp; CrLf   &amp; CrLf &amp;
			//ISO Type. The Container&amp;apos;s type or GEN for a generator.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI004) &amp; CrLf  &amp;
			//Cargo Checks. Allow the user to record predefined rail checks. E.g. Seals Damage etc.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI010) &amp; CrLf &amp; CrLf &amp;
			//Remove cargo. Will remove the cargo from the wagon.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI008) &amp; CrLf  &amp;
			//Back. Takes you back to the wagon details.
			Bullet.Character &amp; " " &amp; app.getErrorString(RAILHHHELP_TI009);
			//Confirm. Will mark the cargo as having been checked.
			
				
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
