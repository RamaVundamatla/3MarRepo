	endif;

	/*if hostName = "cnwchcs4"
	or hostName = "cnwchcs25"
	or hostName = "cnwchcs55"
	//or hostName = "cnwchcs91"
	or hostName = "cnwchcs97"
	or hostName = "cnwchcs116"
	or hostName = "cnwchcs117"
	//or hostName = "cnwchcs119"  // disk too slow - causes timeouts
	or hostName = "cnwchcs121"
	//or hostName = "cnwchcs124"
	or hostName = "cnwchcs127"
	//or hostName = "cnwchcs131"
	or hostName = "cnwchcs148"
	or hostName = "cnwchcs149"
	or hostName = "cnwchcs155"
	or hostName = "cnwchcs157"
	or hostName = "wynchcs254"
	or hostName = "wynchcs255" then
		generics.add("plantphysical");
	endif;

	if hostName = "cnwchcs4"
	or hostName = "cnwchcs25"
	or hostName = "cnwchcs55"
	//or hostName = "cnwchcs86"
	//or hostName = "cnwchcs91"
	or hostName = "cnwchcs97"
	//or hostName = "cnwchcs111"
	//or hostName = "cnwchcs112"
	// or hostName = "cnwchcs113"
	or hostName = "cnwchcs116"
	or hostName = "cnwchcs117"
	or hostName = "cnwchcs119"
	or hostName = "cnwchcs121"
	or hostName = "cnwchcs123"
	or hostName = "cnwchcs124"
	//or hostName = "cnwchcs126"
	or hostName = "cnwchcs127"
	//or hostName = "cnwchcs131"
	or hostName = "cnwchcs148"
	or hostName = "cnwchcs149"
	or hostName = "cnwchcs155"
	or hostName = "cnwchcs157"
	or hostName = "wynchcs254"
	or hostName = "wynchcs255" then
		generics.add("plant");
	endif;/**/
	
	if hostName = "cnwchcs4"
	or hostName = "cnwchcs25"
	or hostName = "cnwchcs55"
	or hostName = "cnwchcs97"
	//or hostName = "cnwchcs111"
	//or hostName = "cnwchcs112"
	// or hostName = "cnwchcs113"
	or hostName = "cnwchcs116"
	or hostName = "cnwchcs117"
	or hostName = "cnwchcs119"
	or hostName = "cnwchcs121"
	or hostName = "cnwchcs124"
	or hostName = "cnwchcs127"
	or hostName = "cnwchcs148"
	or hostName = "cnwchcs149"
	or hostName = "cnwchcs155"
	or hostName = "cnwchcs157"
	or hostName = "wynchcs254"
	or hostName = "wynchcs255" then
		generics.add("contops");
	endif;
end;
</source>
        <Parameter name="generics" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getName" id="1de3158e-c1db-430e-b795-c906285e77fd">
