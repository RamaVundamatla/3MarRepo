    <JadeMethod name="convertToRelease" id="ce962a58-5804-49a0-a9b8-dd81728f06bc">
        <updating/>
        <source>convertToRelease() updating;

vars
	newRequest	: CM_TIRequest;
	wle			: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
	trans : CM_TITransaction;
	passport : CM_Passport;
begin

	if (not self.isReceipt) then
		app.raiseCMException1(ERR_TURNAROUND, self.getId, null, null);			
		return;
	endif;

	ti := self.trackedItem;		//PAR 2689 AJA 9/4/01: Avoid duplicated relationship ref
	self.trackedItem := null;	//by breaking tracked item link first
	
	if ti = null then
		app.raiseCMException1(ErrorOnStore_NullTIForRequest, self.getId, null, null);		
		return;
	endif;
	
	ti.breakTBAMatch;

	newRequest := self.cloneSelf(false);
	newRequest.trackedItem := ti;
	newRequest.myJob := self.myJob;
	
    if newRequest.myJob.isKindOf(CM_RoadJob) then
    	newRequest.myJob.CM_RoadJob.isTurnAroundJob := true;
    endif;
//	ti.releaseRequest := self; 	//GD self is a receipt here	Xpose 1561
	newRequest.isReceipt := false;
	newRequest.myJob := self.myJob;
	//GD set the ti release job once the new request has been updated Xpose 1561
	//ti.setReleaseRequest(newRequest);
	newRequest.setTrackedItem(ti);
	passport := app.myPassport;
    foreach wle in self.allWorkListEntries do
	    wle.unQueueWLE(passport);
    endforeach;
    
	wle := self.createYardWLE(newRequest, WLE_UNACTIONED,ti);
	
	// PAR5307 - AKB2003JULY if the job is turned around as a release we logically delete the receival transaction
	// can only turn round a receival for ROAD and RAIL receivals at present
	foreach trans in ti.allTransactions do
		if trans.type = TRANS_TYPE_REC_RAIL
		or trans.type = TRANS_TYPE_REC_ROAD
		
		// or trans.type = TRANS_TYPE_REC_ST_DEPOT_INT		// CCMS 1875 - not internal moves
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_DEPOT_ROAD		// CCMS 1875
		// or trans.type = TRANS_TYPE_REC_ST_MARINE_INT		// CCMS 1875 - not internal moves
		or trans.type = TRANS_TYPE_REC_ST_MARINE_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_MARINE_ROAD		// CCMS 1875
		//or trans.type = TRANS_TYPE_REC_ST_WHOUSE_INT		// CCMS 1875 - not internal moves
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL		// CCMS 1875
		or trans.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD		// CCMS 1875
		
		or trans.type = TRANS_TYPE_REC_RAIL_INTER_TERM
		or trans.type = TRANS_TYPE_REC_ROAD_INTER_TERM
		then
			trans.setForDelete(null);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="createBulkRelease" id="ff94c0bb-bcc4-467c-b5ab-217ad799cc8b">
        <updating/>
        <source>createBulkRelease(_passport: CM_Passport input) : CM_BulkRelease updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwdf1
//
// Purpose:     for ccms 1048: if the Request is directly created in Raod in
//              without previously enter a empty release request, then make it
//              up by creating the empty release request(bulkRelease) and right
//              after,delete the original ti request(not self but the one created
//              with the bulkRelease;

// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2004  cnwgd1		Par 8380
// 14/11/2019  cnwma1		Bug 47393: POL - [Fwd: ##RE-13305## : FW: Deliver Release Query]
// ---------------------------------------------------------------------------
vars
	newBulkRelease		: CM_BulkRelease;
	auditAgent          : CM_CreateTransactionAuditAgent;
begin
	
	inheritMethod(_passport);

	if self.trackedItem = null then
		// Hmmm what happened here??
		return null;
	endif;

	// par 15513 6/12/07 -this could of already been created in this transaction so we have to check this now
	newBulkRelease := self.myTerminal.getBulkReleaseFromCode(self.deliveryNumber.trimBlanks.toUpper);
	if newBulkRelease = null then
		//epr 11/9/17 TFS 6723 deleted reference to method that did nothing
		// Par 8380	- Now
		create newBulkRelease persistent;
		newBulkRelease.setFromTIRequest(self);
		
		if app.myPassport.noErrors and newBulkRelease &lt;&gt; null  then   //14.11.2019 cnwma1 #47393
			auditAgent := app.myUtilityCA.myCreateAuditAgent;
			auditAgent.audCreateGeneric(newBulkRelease);
		endif;
	endif;
	
	return newBulkRelease;	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d30d743d-a065-441a-aee0-6263b9f68c67">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	yjob : CM_YardJob;
	invalid 		: Boolean;
	ed				: Integer;
	ti				: CM_TrackedItem;
begin
	if self.isTransient() then
		inheritMethod(_eraseLevel);
		return;
	endif;

	exclusiveLock(self);		
	yjob := self.myJob.CM_YardJob;

	ti := self.trackedItem;
	if ti &lt;&gt; null then
//		and global.isValidObject(trackedItem) then
		on Exception do app.handleDeletedObject(exception, ti, invalid);
		// dereference TI to check it is valid
		ed := ti.edition();
		
		if not invalid then
			if yjob &lt;&gt; null then
				yjob.removeTI(ti, self);
			endif;
		endif;
		on Exception do null;
		//Does not do anything
		/*if self.trackedItem.releaseRequest = self then
			self.trackedItem.setReleaseRequest(null);
		endif;*/
	endif;
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
