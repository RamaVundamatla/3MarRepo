    <JadeMethod name="cloneReferences" id="32ff0758-3a19-4dd4-b9c0-01b91f35e292">
        <updating/>
        <source>cloneReferences(_obj: CMQF_OrganisationAccess; _transient: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2013	cnwjre1	Initial creation

*/

vars

begin
	inheritMethod(_obj, _transient);

	_obj.allUsers.copy(self.allUsers);
	self.setMyOrganisation( _obj.getMyOrganisation );
	self.setMyVoyage( _obj.getMyVoyage );

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_OrganisationAccess"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="e2e46a1a-eb05-456c-89cf-a79df305b7a4">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2013	cnwjre1	Initial creation

*/

vars
	useOnsiteCargo	: Boolean;
	cmif	: CMIF_OrganisationCargoItem;
	ti		: CM_TrackedItem;
	term	: CM_Terminal;
	allCargo		: CM_TIArray;
	tiSet	: CM_TISet;
	user	: CM_User;
	userDict	: CM_UserByCodeDict;
	failedDAC	: CM_DataAccessController;
	agent		: CM_OnsiteCargoAgent;
begin
	// selecting an organisation but no users means take all users for the organisation
	// selecting an organisation plus individual users means take the selected users only
	if self.allUsers.isEmpty and
	   self.getMyOrganisation &lt;&gt; null then
		userDict := self.getMyOrganisation.allUsers;
	else
		userDict := self.allUsers;
	endif;
	if userDict = null then
		return;
	endif;

	// only on-site or on-voyage can be selected and only one is used.  If only on-voyage is selected then use the associated voyage, 
	//   otherwise report on on-site cargo only.
	useOnsiteCargo := true;		// default
	if self.allQrySites.size = 1 and
	   self.allQrySites[1] = TI_SITE_ONSHIP then
		useOnsiteCargo := false;
	endif;
	
	create allCargo transient;
	if useOnsiteCargo then

		create agent transient;
		create tiSet transient;
		foreach term in self.allTerminals do

			agent.getOnsiteCargo(term, self.startDate, self.endDate, tiSet);
		endforeach;
		tiSet.copy(allCargo);
		// voyage cargo
	else
		if self.getMyVoyage &lt;&gt; null then
			self.getMyVoyage.allOnshipTIsByCargoTypeId.copy(allCargo);
		endif;
	endif;
	
	foreach ti in allCargo do

		foreach user in userDict do 
			if ti.canUserAccessSelf(user, failedDAC, app.myPassport) then
				self.numFound := self.numFound + 1;
				create cmif transient;
				cmif.myOrganisation := self.getMyOrganisation;
				cmif.myOrganisationUser := user;
				cmif.myTrackedItem := ti;
				_collection.add(cmif);
			endif;
		endforeach;
	endforeach;
	
epilog
	delete allCargo;
	delete tiSet;
	delete agent;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyOrganisation" id="7905ba2d-4896-405d-95e2-b1db7330f933">
        <source>getMyOrganisation():CM_Organisation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Organisation;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myOrganisation;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Organisation"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="e959f81e-3cd3-4a9f-b03b-2b51c7114738">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="d297accc-0c78-4d46-a758-ebf96adae3f1">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2013	cnwjre1	Initial creation
*/

vars

begin
		
	if _attrName = ETRow_SiteState then
		return self.getSiteOIDAndString(_oid);
		
	elseif _attrName = ETRow_Voyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); 
			return self.getMyVoyage.code;
		endif;

	elseif _attrName = ETRow_Organisation then
		if self.getMyOrganisation &lt;&gt; null then
			_oid := self.getMyOrganisation.getOidAsString(); 
			return self.getMyOrganisation.name;
		endif;
		
	elseif _attrName = ETRow_OrganisationUsers then
		return self.getUsersString(_oid);
		
	elseif _attrName = ETRow_DateTimeFrom then	
		return self.startDate.asStringJMT();

	elseif _attrName = ETRow_DateTimeTo then	
		return self.endDate.asStringJMT();
	
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSiteOIDAndString" id="0c7a7cab-473f-4f1b-babc-67a2913958b3">
        <source>getSiteOIDAndString(_oid : String output) : String protected;

vars
	siteString			: String;
	site				: Integer;
begin
	foreach site in self.allQrySites do
		_oid := _oid &amp; site.String &amp; ', ';
		siteString := siteString &amp; app.siteEnumToString(site) &amp; ', ';
	endforeach;
	
	if siteString &lt;&gt; null then
		_oid := _oid[1:_oid.length-2];
		siteString := siteString[1: siteString.length -2];
	endif;
	
	return siteString[1:50];
end;</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsersString" id="91e54984-360b-4bcb-ba9c-f65e83967ed8">
        <source>getUsersString(_oid : String output) : String protected;

vars
	user	: CM_User;
	str		: String;
begin
	foreach user in self.allUsers do
		_oid := _oid &amp; user.getOidAsString &amp; ', ';
		if str = null then
			str := user.code;
		else
			str := str &amp; ', ' &amp; user.code;
		endif;
	endforeach;
	if str = null then
		str := Any_String;
	endif;

	return str;
			
end;


</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="d7b059d4-58d5-44b1-8e50-a9ab41df1acf">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR 34813

*/

vars
	eventData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyOrganisation" id="446f8d92-af73-4535-9ad5-5a4508779d57">
