    <JadeMethod name="resizeBottomButtons" id="58ee7729-df8d-4c7a-a144-2844156fb841">
        <source>resizeBottomButtons() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2012	cnwer1	Initial creation SFW 1295

*/
constants
	Margin = 5;
	MinButtonWidth = 65;
	MinButtonHeight = 35;
vars
	theWidth, theHeight : Integer;	
begin
	
	theWidth:= self.btnMain.getTextExtent(self.btnMain.caption).max(theWidth);
	theWidth:= self.btnConfig.getTextExtent(self.btnConfig.caption).max(theWidth);
	theWidth:= self.btnLogoff.getTextExtent(self.btnLogoff.caption).max(theWidth);
	theWidth:=theWidth + (self.btnLogoff.getTextExtent("W") *2);
	theWidth:=theWidth.max(MinButtonWidth);
	
	self.btnMain.left:=5;
	self.btnMain.width:=theWidth;
	self.btnConfig.left:=self.btnMain.left + theWidth + Margin;
	self.btnConfig.width:=theWidth;
	self.btnLogoff.left:=self.btnConfig.left + theWidth + Margin;
	self.btnLogoff.width:=theWidth;
	
	
	theHeight:=self.btnMain.getTextHeight(self.btnMain.caption);
	theHeight:= theHeight + (Margin *2);
	theHeight:=theHeight.max(MinButtonHeight);
	self.btnMain.height:=theHeight;
	self.btnConfig.height:=theHeight;
	self.btnLogoff.height:=theHeight;
	
	self.frmMenuBtm.height:=theHeight + (Margin *2);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e6eb9a16-4d9e-4302-83b3-885701753c78">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwer1	Initial creation

*/

vars

begin
	
	self.btnDamage.visible:=false;
	self.btnEnquiry.visible:=false;
	self.btnGrading.visible:=false;
	self.btnReports.visible:=false;
//	self.btnSeals.visible:=false;
	self.btnStops.visible:=false;
	self.btnToDoTask.visible:=false;
	
	inheritMethod();
    if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;		

	self.setVehicleMountedScreenSize();

	self.organiseButtons();
	self.updateCaption();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74963b85-5956-464e-88ae-b558606059a3">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017621, locale);
	btnConfig.translateCaption(Xlat_0014847, locale);
	btnDamage.translateCaption(Xlat_0014848, locale);
	btnEnquiry.translateCaption(Xlat_0014849, locale);
	btnGrading.translateCaption(Xlat_0014850, locale);
	btnLogoff.translateCaption(Xlat_0014852, locale);
	btnMain.translateCaption(Xlat_0014853, locale);
	btnReports.translateCaption(Xlat_0014854, locale);
//	btnSeals.translateCaption(Xlat_0014855, locale);
	btnStops.translateCaption(Xlat_0014856, locale);
	btnToDoTask.translateCaption(Xlat_0014857, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
