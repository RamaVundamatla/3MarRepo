    <JadeMethod name="getNextFreeSlotController" id="e2f5c4b1-e3fc-44b0-b5bb-47b484a1be72">
        <source>getNextFreeSlotController() : CM_ROROSlotController;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
