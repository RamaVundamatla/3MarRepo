    <JadeMethod name="test_64296" id="2c360a0f-76d4-4ce0-b9e4-c0f2de0876e8">
        <source>test_64296();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2024	navnk30	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	weight	: Decimal[8, 0];
	dispStr	: String;
begin
	ti := "4949.4861919".asOid.CM_TrackedItem;
	write ti.id;
	weight := ti.totalWeight;
	
	dispStr := (weight * 2.204622).rounded().String;
	write "kg = " &amp; weight.String &amp; CrLf &amp; " lbs = "&amp; dispStr;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="woInst" id="822b2874-3586-4d23-8770-f3f5842aa382">
        <source>woInst();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2023		navma1	Initial creation

*/

vars
	wo 		: CM_WorkOrder;
	instset : CM_InstructionsIssuedSet;
//	term 	: CM_Terminal;
	obj : Object;
begin
	app.initialize();
	
	//term := app.myRoot.allTerminals['WO'];
	
	wo := "555.555".asOid.CM_WorkOrder;
	
	create instset transient;
	if wo &lt;&gt; null then
		
		wo.getInstructionsForContext(instset,null,null);
	endif;
	
	foreach obj  in instset do 
		
		write obj.CM_InstructionsIssued.getParentType ;
	endforeach;
epilog
	delete instset;
end;</source>
    </JadeMethod>
