						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_ROAD	//_transMode : Integer
						);
					
	self.addPreNotes(	"THRS1110116",	//_id : String;
						isoType,	//_isoType : String;
						_mTGrade,	//_mTGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_ROAD	//_transMode : Integer
						);
						
	//threshold priority 3 data
	//2 by rail and 2 by road
	
	isoType := "4200";
	grade := null;
	
	self.addPreNotes(	"THRS1110313",	//_id : String;
						isoType,	//_isoType : String;
						grade,	//_mTGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_RAIL	//_transMode : Integer
						);
					
	self.addPreNotes(	"THRS1110314",	//_id : String;
						isoType,	//_isoType : String;
						grade,	//_mTGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_RAIL	//_transMode : Integer
						);
						
	self.addPreNotes(	"THRS1110315",	//_id : String;
						isoType,	//_isoType : String;
						grade,	//_mTGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_ROAD	//_transMode : Integer
						);
					
	self.addPreNotes(	"THRS1110316",	//_id : String;
						isoType,	//_isoType : String;
