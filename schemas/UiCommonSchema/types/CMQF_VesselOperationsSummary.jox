<Class name="CMQF_VesselOperationsSummary">
    <JadeMethod name="setFromAgent" id="8e111695-018d-4320-8ca3-88816d43d551">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
// 27/05/2008	concms1	par 19768 - add voyage/shipping line parameters
vars

begin
	inheritMethod(_agent);
	// Arrival
	if _agent.isRowIncluded(ETRow_ArrivalsDateFrom) then
		self.arriveDateFrom := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsDateTo) then
		self.arriveDateTo := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsTimeFrom) then
		self.arriveTimeFrom  := _agent.getValueByNameIfVisible(ETRow_ArrivalsTimeFrom).Time;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsTimeTo) then
		self.arriveTimeTo  := _agent.getValueByNameIfVisible(ETRow_ArrivalsTimeTo).Time;
	endif;
	
	if _agent.isRowIncluded(ETRow_Vessel) then
		self.setMyVessel( _agent.getSelectedVessel );
	endif;
	
	// par 19768 - start
	if  _agent.isRowIncluded(ETRow_ShippingLine) then
		self.setMyShippingLine( _agent.getSelectedShippingLine );
	endif;
	if  _agent.isRowIncluded(ETRow_Voyage) then 
		self.setMyVoyage( _agent.getSelectedCellularVoyage );
	endif;
	// par 19767 - end
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
