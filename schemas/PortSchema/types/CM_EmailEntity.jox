    <JadeMethod name="userCanSeeMe" id="3303b46b-88c9-4720-83f5-7e3ba922d4ba">
        <source>userCanSeeMe(_user : CM_User) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return (_user.canDo(null, PmAdmEmailSystem)) or
			(_user.allEmailsICanSee.includes(self)) or
			(_user.myEmailEntity = self);
			

end;


</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="131083ad-00fc-4be7-a784-c2ef6cd9f641">
        <source>validate();
// -------------------------------------------
// Created 24 September 2003 by cnwdvb1

//	08/12/2014 cnwdb2	PAR 35364 
//	11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  

// -------------------------------------------
vars

	entity	: CM_EmailEntity;
	iter	: Iterator;
	theType	: Integer;
	theName	: String;
	realObj	: SelfType;
	index : Integer;
	str : String;

begin

	if self.name = null then
	// 	app.raiseCMException1(REQUIRED_FIELD, 'Email Title', null, null);
		app.raiseCMException(Input_required_field_emlTitle, null, null); // cnwdb2	PAR 35364
	endif;
	
	//13 Mar 2013	NDl	Par 30404
	foreach index in 1 to self.EmailSeperatorChars.length do
		str := self.EmailSeperatorChars[index];
		if self.name.pos(str,1) &gt; 0 then
			app.raiseCMException1(Email_name_not_includ_charac, str, null, null);
		endif;
	endforeach;
	
	realObj := self.pxyGetRealObject();
	iter := app.myRoot.allEmailEntities.createIterator();
	app.myRoot.allEmailEntities.startKeyGeq(Email_Address, self.name, iter);
	while iter.next(entity) do
		iter.getCurrentKeys(theType,theName); //MTN-35226
		if theName = self.name then
			if realObj = null or entity &lt;&gt; realObj then
			//	app.raiseCMException3(ERR_DUPLICATE_KEY, "Email Title " , self.name, null, null, null);
				app.raiseCMException1(Already_exists_email_title, self.name, null, null); /// cnwdb2 PAR 35364
				break;
			endif;
		endif;
	endwhile;
	
	if self.type &lt;&gt; Email_Address and self.type &lt;&gt; Email_Group then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Type', null, null);
		app.raiseCMException(Input_required_field_type, null, null); // cnwdb2	PAR 35364
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b7411537-6581-4d0c-b62a-a235d76a2b05">
        <source>validateForDelete();
// -------------------------------------------
// Created 24 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allCamProtocols.isEmpty = false then
		app.raiseCMException2(ObjectStillHasEntries, self.name &amp; ' email group', "CAM protocol", null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForWebPortal" id="1864a5fe-ec11-4e92-8baa-2975bfd4d7ad">
        <source>validateForWebPortal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2017	jlger1	Initial creation 7181

*/

vars

begin
	if not self.allUsers.isEmpty then
		app.raiseCMException(Email_in_use_another_user,null,null);
		return;
	endif;
	
	if not self.allCamProtocols.isEmpty then
		app.raiseCMException(Not_this_email_bcaus_used_cams,null,null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
