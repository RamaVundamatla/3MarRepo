    <JadeMethod name="validateUpdate" id="226354e4-6a89-467a-aa27-9b28612cf37b">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cga : CM_CargoGroupAssignment;
	real : CM_CargoGroupAssignment;

begin

	if self.isTransient then
		real := self.pxyGetRealObject();
	else
		real := self;
	endif;

	cga := self.myTerminal.allWorkTasksDict.getAtKey( self.type, self.id).CM_CargoGroupAssignment;	
	if cga &lt;&gt; null and cga &lt;&gt; real then
		app.raiseCMException1(Cargo_group_assign_alread_exis,self.id,null,null);
		return;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
