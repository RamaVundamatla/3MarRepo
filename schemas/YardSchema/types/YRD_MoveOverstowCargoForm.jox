	toolbar.addFrame(self.frmTBViewMode, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);


end;</source>
