    <JadeMethod name="columnTableResize" id="4c388eb9-ce85-4f4c-8d87-0eaea735ea83">
        <updating/>
        <source>columnTableResize() updating;

begin
	columnTable.height := columnTable.rowHeight[1] + columnTable.rowHeight[2] + 25;
