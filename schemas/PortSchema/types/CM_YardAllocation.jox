    <JadeMethod name="setFromSummaryResults" id="050677b7-75e2-48d1-84ed-9a619788041a">
        <updating/>
        <source>setFromSummaryResults(_cellResults : CMIF_OutputGrouping) updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	parser	:JadeXMLDocumentParser;
	xmlDoc	:JadeXMLDocument;
	element, nameElement, valueElement, jadePropertyElement	:JadeXMLElement;
	xmlNode	:JadeXMLNode;
	strProperty, strValue, prodCode	:String;
	includesCargoSubtype : Boolean;
	cargoTy : CM_CargoType;
	criteria : CM_YACriteria;
	prod : CM_Product;
	imex : CM_IMEXStatus;
	objSet : ObjectSet;
begin
	if _cellResults = null then
		return;
	endif;
	if _cellResults.xmlInfo.trimBlanks() = null then
		return;
	endif;
	
	create parser transient;
	create xmlDoc transient;
	create objSet transient;
	parser.parseDocumentString (xmlDoc, _cellResults.xmlInfo);
	
	element := xmlDoc.getElementByTagName (CMIF_OutputFormatAgent_XTAB.XML_Values_Tag);
	// MANDATORY IMEX STATUS = IMPORT
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	objSet.add(imex);
	criteria := self.createCriteria(objSet, YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;

	foreach xmlNode in element.childNodes do
		if xmlNode.JadeXMLElement.tagName = CMIF_OutputFormatAgent_XTAB.XML_Grouping_Tag then
			nameElement := xmlNode.JadeXMLElement.getElementByTagName (CMIF_OutputFormatAgent_XTAB.XML_PropertyName_Tag);
			valueElement := xmlNode.JadeXMLElement.getElementByTagName (CMIF_OutputFormatAgent_XTAB.XML_PropertyValue_Tag);
			jadePropertyElement := xmlNode.JadeXMLElement.getElementByTagName (CMIF_OutputFormatAgent_XTAB.XML_JadePropertyName_Tag);
			
			strProperty :=  jadePropertyElement.textData;			
			strValue	:=  valueElement.textData;

			self.createCriteriaFromXTABProperty(strProperty, strValue, TI_IMEX_STATUS_EXPORT);
			
			if (strProperty = CM_BookingRefItem::getProductCode.name) then
				prodCode := strValue;
				includesCargoSubtype := true;
			endif;

		endif;
	endforeach;
	
	if includesCargoSubtype then
		self.setCargoSubtypeForSummary(prodCode);
	endif;
epilog
	delete objSet;
	delete parser;
	delete xmlDoc;
end;</source>
        <Parameter name="_cellResults" type="CMIF_OutputGrouping"/>
    </JadeMethod>
