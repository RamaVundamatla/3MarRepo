    <JadeMethod name="populateDictAllXlatConstants" id="c93b17b9-43f0-4020-abfa-64ad05aa4845">
        <updating/>
        <source>populateDictAllXlatConstants( _formClass,_schemaName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	startTime 		: TimeStamp;
	xmlDoc			: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	textElement		: JadeXMLElement;
	xmlAttribute	: JadeXMLAttribute;
	constantObj		: Constant;
	lsConstant		: LSconstant;
	lsClass			: LSclass;
	
	lsSchema		: LSschema;
	controlProperty	: String;
	schemaName		: String;
	controlName		: String;
	constantName 	: String;
	constantNumber	: Integer;
	formClass		: String;
	text			: String;
	portSchema 		: Schema;
	constantCategory: ConstantCategory;
	myStep 			: Integer;
	conCount 		: Integer;
	stepCount 		: Integer;
	
	
begin

	mousePointer := Window.MousePointer_HourGlass;
	
	self.staMain.caption := "Loading in ...";
	self.doWindowEvents(0);
	
	startTime := app.actualTimeServer;
	
	create self.dictAllXlatConstants transient;
	
//	portSchema:=rootSchema.getSchema("PortSchema");
	portSchema := self.myPortSchema;	//11 Sep 2020	NDL
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
	myStep := (constantCategory.cnEcGetConstants.size / 5).Integer;
		
	foreach 	constantObj in constantCategory.getConstants do
	
	conCount := conCount + 1;
//11 Sep 2020	NDL - slows down	
//	if conCount mod myStep = 0 then
//		stepCount := stepCount + 1;
//		self.staMain.caption := self.staMain.caption &amp; (6 - stepCount).String &amp; "..."; 
		
//		self.doWindowEvents(0);
//	endif;
		
		schemaName := null;
		formClass  := null;
		controlName:= null;
		controlProperty := null;
		constantNumber := null;
		text := null;
	
		constantName := constantObj.name;
		// no xml then error as should have xml
		if constantObj.text = null then
			app.writeStatement("*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")");
			write "*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")";
			continue;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			schemaName := xmlAttribute.value;
			if _schemaName &lt;&gt; null and schemaName &lt;&gt; _schemaName then
				continue;
			endif;
		else
			continue;
		endif;
		
		
		
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			formClass := xmlAttribute.value;
			if	_formClass &lt;&gt; null and _formClass &lt;&gt; formClass then
				continue;
			endif;
		else
			continue;
		endif;
		
		// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			text := textElement.text;
		else
			continue;
		endif;
				
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute &lt;&gt; null then
			controlName := xmlAttribute.value;
		endif;
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlProperty);
		if xmlAttribute &lt;&gt; null then
			controlProperty := xmlAttribute.value;
		endif;
	
		if self.dictAllXlatConstants.includesKey(schemaName) then
			lsSchema := self.dictAllXlatConstants.getAtKey(schemaName);
		else
			create lsSchema transient;
			lsSchema.mySchema := rootSchema.getSchema(schemaName);
			lsSchema.name := lsSchema.mySchema.name;
			self.dictAllXlatConstants.add(lsSchema);			
		endif;
		
		if lsSchema.allClasses.includesKey(formClass) then
			lsClass := lsSchema.allClasses.getAtKey(formClass);
		else
			create lsClass transient;
			lsClass.myClass := lsSchema.mySchema.getClass(formClass);
			if lsClass.myClass = null then
				continue;
			endif;
			lsClass.name := lsClass.myClass.name;
			lsSchema.allClasses.add(lsClass);
		endif;
	
		if not lsClass.allConstants.includesKey(schemaName, formClass, controlName, controlProperty) then
			constantNumber := constantObj.getSource().Integer;
			
			create lsConstant transient;
			lsConstant.schemaName 	:= schemaName;
			lsConstant.formName 	:= formClass;
			lsConstant.controlName 	:= controlName;
			lsConstant.controlProperty := controlProperty;
			
			lsConstant.name 		:=  constantObj.name;
			lsConstant.number 		:= constantNumber;
			lsConstant.text 		:= text;	
			lsConstant.matchedToFormConstant := true;
			lsClass.allConstants.add(lsConstant);
		
		endif;
		
		
	//	if schemaName &lt;&gt; null and formClass &lt;&gt; null and controlName &lt;&gt; null and controlProperty &lt;&gt; null and constantObj.name &lt;&gt; null and constantNumber &lt;&gt; null and text &lt;&gt; null then
//	
//			create lsConstant transient;
//			lsConstant.schemaName 	:= schemaName;
//			lsConstant.formName 	:= formClass;
//			lsConstant.controlName 	:= controlName;
//			lsConstant.controlProperty := controlProperty;
//			lsConstant.name 		:=  constantObj.name;
//			lsConstant.number 		:= constantNumber;//
//			lsConstant.text 		:= text;/	
//			dictAllXlatConstants.add(lsConstant);
//		endif;
	
	endforeach;
	
//write	/*self.staMain.caption :=*/ "Loaded in " &amp;  app.actualTimeServer.getDifferenceInSeconds(startTime).String &amp; " Seconds";
	self.doWindowEvents(0);
	
epilog
	mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_formClass" type="String"/>
        <Parameter name="_schemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="processFormMethodDetails" id="60d64c98-a125-41d6-91b3-e4523610a2bb">
        <updating/>
        <source>processFormMethodDetails() updating;

/*

Purpose:	Get / Create the constants required to build the translateForm method

			The following rules cause an error / warning to occur.  I've included those that are checked but don't cause an error / warning to occur.
		
			No Warning / Error
			------------------
			* Constant doesn't exist and line is commented out
			
			Warning
			-------
			* Constant has no XML in its text (Needs to be addressed)
			* Form caption is still default
			* Constant exists with different text (Needs to be addressed)
			
			Error
			-----
			* Unable to find Xlat_FormCaption constant (Needs to be addressed)
			* Constant isn't a Xlat_FormCaption constant (Needs to be addressed)

Date			Who		Reason
16/01/2012		cnwmh5	Initial creation
12/04/2013		cnwmh5	Fix issue where bubbleHelp isn't getting found for at least ComboBox, Picture, TextBox, Table controls.
						These are the ones that were found so fix will do all controls.

*/
constants
	TranslateCaption		: String = "translateCaption";
	TranslateCaption2		: String = ".caption";
	TranslateBubbleHelp		: String = "translateBubbleHelp";
	TranslateBubbleHelp2	: String = ".bubbleHelp";
	AlphaCharacters			: String = "abcdefghijklmnopqrstuvwxyz";
vars

	meth					: Method;
	lsConstant				: LSconstant;
	form					: Form;
	cntrl					: Control;
	tmpMenu					: MenuItem;
	prop					: Property;
	
	methSource				: String;
	attribute				: String;
	constant				: String;
	sourceLine				: String;
	str						: String;
	controlName				: String;
	constantProperty		: String;
	commentedOutStartOfLine	: String;
	commentedOutEndOfLine	: String;
	
	posCrLf					: Integer;
	length					: Integer;
	pos1					: Integer;
	pos2					: Integer;
	isCommentedOut			: Boolean;
	numControls				: Integer;
	index					: Integer;
	numMenus				: Integer;
	multiCommentOut			: Boolean;
	conObj : Constant;
	conNum : Integer;
begin
	
	meth := self.myLSclass.myClass.getMethod("translateForm");
	if meth &lt;&gt; null then
		methSource := meth.getSource();
		length := methSource.length;
	endif;

	posCrLf := -1;
	
	// Read the source and see what is currently already defined
	// read through the file getting current constants
	while true do
	
		if methSource &lt;&gt; null then
			if posCrLf = -1 then
				posCrLf := 1;
			else
				posCrLf := posCrLf + 2;
			endif;
			if (posCrLf + 2) &gt; methSource.length then
				break;
			endif;
			methSource := methSource[posCrLf:end];
		endif;
	
		posCrLf := 1;
		posCrLf := methSource.pos(CrLf, posCrLf);
		if posCrLf = 0 or (posCrLf + 1) &gt; length then
			break;
		endif;
		sourceLine := methSource[1:posCrLf];		
		
		pos1 := 1;
		attribute := null;
		constant := null;
		isCommentedOut := multiCommentOut;
		commentedOutStartOfLine := null;
		commentedOutEndOfLine := null;
		
		// ok have translate need to get the details
		sourceLine.cnReplaceString(Tab, " ");
		sourceLine.cnReplaceString("( ", "(");
		sourceLine.cnReplaceString(" )", ")");
		
		// check to see if the following exist on the line and cause error message
		if sourceLine.cnContains(TranslateCaption2) or sourceLine.cnContains(TranslateBubbleHelp2) then
			pos1 := 1;
			str := sourceLine.scanUntil(AlphaCharacters, pos1);
			str.cnReplaceString(Tab, "");
			continue;
		endif;

		// if line doesn't have .translate then don't want to know about it
		pos1 := 1;
		pos1 := sourceLine.pos(".translate", pos1);
		if pos1 = 0 then
			continue;
		endif;
		
		// get the starting point of the text
		pos2 := sourceLine.reversePosIndex(" ", pos1);
		attribute := sourceLine[pos2+1:pos1-pos2-1];
		if pos2 &gt; 0 then
			commentedOutStartOfLine := sourceLine[1:pos2].trimBlanks();
			if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
				isCommentedOut := true;
			endif;
		endif;
		
		// get the attribute
		if attribute[1:2] = "//" then	
			pos2 := 1;
			commentedOutStartOfLine :=  sourceLine.scanUntil(AlphaCharacters, pos2);
			if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
				isCommentedOut := true;
			endif;
			attribute := sourceLine[pos2:pos1-pos2];
		endif;
		if attribute = "self" then
			if sourceLine[pos1:10] &lt;&gt; ".translate" then
				pos1 := pos1 + 1;
				attribute := sourceLine.scanUntil(".", pos1);
			endif;
		endif;
		sourceLine := sourceLine[pos1+1:end];
		
		// get what we are translation
		pos1 := 1;
		constantProperty := sourceLine.scanUntil("(", pos1);
		constantProperty := constantProperty[10:end].trimBlanks();
		constantProperty[1:1] := constantProperty[1:1].toLower();
		sourceLine := sourceLine[pos1+1:end];
		
		// get the constant
		pos1 := 1;
		constant := sourceLine.scanUntil(",", pos1);
		
		// if commented out see if there is a comment on the end of the line
		sourceLine.scanUntil(";", pos1);
		if pos1+1 &lt; sourceLine.length then
			commentedOutEndOfLine := sourceLine[pos1+1:end];
			commentedOutEndOfLine.cnReplaceString(Tab, "");
			commentedOutEndOfLine.cnReplaceString(Cr, "");
			commentedOutEndOfLine.cnReplaceString(Lf, "");
		endif;
		
		//conObj := rootSchema.getSchema(PortSchemaName).getConstant(constant);
		conObj := self.myPortSchema.getConstant(constant);	//11 Sep 2020	NDL
	
		if conObj &lt;&gt; null then
			conNum := conObj.getSource.Integer;
		endif;
		
		
		
		
		if not self.myLSclass.allConstants.includesKey(self.myLSclass.mySchema.name,self.myLSclass.name, attribute,constantProperty) then
			lsConstant :=	self.myLSclass.addConstant(constant, attribute, constantProperty,null, commentedOutStartOfLine,commentedOutEndOfLine,isCommentedOut,true,conNum);
			
			if lsConstant &lt;&gt; null and not self.dictLSconstantsToDisplay.includesKey(self.myLSclass.name, attribute, constantProperty) then
			//if _addToDisplayDict then
				self.dictLSconstantsToDisplay.putAtKey(self.myLSclass.name, attribute, constantProperty, lsConstant);
			endif;
			
		endif;
		
		//self.handleFormTranslation(constant, attribute, constantProperty, null, commentedOutStartOfLine, commentedOutEndOfLine, isCommentedOut, false, true);
		
	endwhile;

	// read through the form and see what is left to define
/*	foreach form in Form.instances do
		if form.name = self.myLSclass.name then
			break;
		endif;
	endforeach; */
	form := self.allAvailableForms.getAtKey( self.myLSclass.name ).Form;	//10 Jun 2021	NDL	TFS 51321
	
	lsConstant := self.myLSclass.allConstants[self.myLSschema.name, form.name, form.name, 'caption'];			
	if lsConstant = null then
		self.handleFormTranslation(null, "self", 'caption', form.getPropertyValue('caption').String, null, null, false, true, true);
	else 
		lsConstant.text := form.getPropertyValue('caption').String;
		lsConstant.matchedToFormConstant := true;
	endif;
	
	// read through the controls seeing who's there an who isn't
	numControls := form.controlCount;
	foreach index in 1 to numControls do
		cntrl := form.controls(index);
		
		controlName := cntrl.getPropertyValue('name').String;
		//write method.qualifiedName() &amp; Tab &amp; controlName;
		// check to see if the property has a caption
		prop := cntrl.class.getPropertyInHTree("caption");
		//write method.qualifiedName() &amp; Tab &amp; 'prop caption: ' &amp; prop.String;
		if prop &lt;&gt; null then
			lsConstant := self.myLSclass.allConstants[self.myLSschema.name, form.name, controlName, 'caption'];			
			if lsConstant = null then
				self.handleFormTranslation(null, cntrl.getPropertyValue('name').String, 'caption', 
					cntrl.getPropertyValue('caption').String, null, null, false, true, true);
			else
				lsConstant.text := cntrl.getPropertyValue('caption').String;
				lsConstant.matchedToFormConstant := true;
			endif;
		endif;
		
		// get bubbleHelp
		prop := cntrl.class.getPropertyInHTree("bubbleHelp");
		/*write method.qualifiedName() &amp; Tab &amp; "form.name: " &amp; form.name &amp; Tab &amp; 'prop bubbleHelp: ' &amp; prop.String &amp; Tab &amp; cntrl.getPropertyValue('name').String &amp; Tab &amp;
			cntrl.getPropertyValue('bubbleHelp').String;*/
		if controlName = "btnActivity" or controlName = "txtEmailAddress" then
			//write 'debugging';
		endif;
		if prop &lt;&gt; null then
			lsConstant := self.myLSclass.allConstants[self.myLSschema.name, form.name, controlName, 'bubbleHelp'];
			if lsConstant = null then
				self.handleFormTranslation(null, cntrl.getPropertyValue('name').String, 'bubbleHelp', 
					cntrl.getPropertyValue('bubbleHelp').String, null, null, false, true, true);
			else
				lsConstant.text := cntrl.getPropertyValue('bubbleHelp').String;
				lsConstant.matchedToFormConstant := true;
			endif;
		endif;
		
	endforeach;
	
	// read through the menu to see who isn't there
	numMenus := form.menuItemCount;
	foreach index in 1 to numMenus do
		tmpMenu := form.menuItems(index);
		
		if tmpMenu.isSeparatorJMT() then
			continue;
		endif;
		
		if tmpMenu.name = null then
			continue;
		endif;
		
		controlName := tmpMenu.getPropertyValue('name').String;
		
		lsConstant := self.myLSclass.allConstants[self.myLSschema.name, form.name, tmpMenu.name, 'caption'];
		if lsConstant = null then
			self.handleFormTranslation(null, tmpMenu.getPropertyValue('name').String, 'caption', 
				tmpMenu.getPropertyValue('caption').String, null, null, false, true, true);
		else
			lsConstant.text := tmpMenu.getPropertyValue('caption').String;
			lsConstant.matchedToFormConstant := true;
		endif;
	endforeach;
	
	
	
	
	
epilog
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="reloadNewSchemas" id="1d56f1b7-c497-4384-9e6d-2ad9c451274d">
        <executionLocation>server</executionLocation>
        <source>reloadNewSchemas(_fileFolder : FileFolder io) serverExecution;

/*

Purpose:			Relaod the partial PortSchema (Constants) and Schema for Form 

					Need have PortSchema as the first file to load so that any new constants that are created will be
					there when there relevent translateForm method is loaded so no compile errors occur.

Date				Who		Reason
27/01/2012			cnwmh5	Initial creation
16/03/0215			cnwmh5	Tranisent Leaks
*/

vars

	fileNodePortSchema				: FileNode;
	fileNodePortSchemaJadeScript	: FileNode;
	fileNodeOtherSchema				: FileNode;
	obj								: Object;
	
	allFiles						: FileNodeArray;
	
	args							: StringArray512;
	
	rtnStr							: String;
	result							: Integer;

begin

	app.writeLog(class.name &amp; '::' &amp; method.name, LogINFO);

	create allFiles transient;
	_fileFolder.mask := "*-FormCaptions-*.scm";
	allFiles := _fileFolder.files();
		
	// get the details of the Form Captions-partial scms
	foreach obj in allFiles do
	
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; obj.String &amp; Tab &amp; obj.FileNode.fileName, LogINFO);
	
		if obj.FileNode.fileName.cnContains("JadeScript") then
			fileNodePortSchemaJadeScript := obj.FileNode;
		elseif obj.FileNode.fileName.cnContains("PortSchema") then
			fileNodePortSchema := obj.FileNode;
		elseif obj.FileNode.fileName.cnContains(self.myLSschema.mySchema.getName()) then
			fileNodeOtherSchema := obj.FileNode;
		endif;
	
	endforeach;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; fileNodePortSchema.String &amp; Tab &amp; fileNodeOtherSchema.String &amp; Tab &amp; 
		fileNodePortSchemaJadeScript.String &amp; Tab &amp; "allFiles.size: " &amp; allFiles.size.String, LogINFO);
	
	// if either don't exist then can't load stuff in
	if fileNodePortSchema = null or fileNodeOtherSchema = null or fileNodePortSchemaJadeScript = null then
		// TODO: Error 
		return;
	endif;

	create args transient;
	
	result := -1;
		
	// load PortSchema global constants
	rtnStr := "Loading schema file: " &amp; fileNodePortSchema.fileName;
	self.staMain.caption := rtnStr;
	self.doWindowEvents(0);
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; fileNodePortSchema.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; fileNodePortSchema.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		if not self.fromUnitTestRun then										// 24/02/2015 cnwmh5
			app.msgBox("PortSchema scm failed to load (Constants).  Please check the scm file", "PortSchema load error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		else
			self.unitTestErrorArray.add(fileNodePortSchema.fileName &amp; " PortSchema scm failed to load (Constants).  Please check the scm file.");
		endif;
		return;
	endif;
	
	// load PortSchema create global constant object
	rtnStr := "Loading schema file: " &amp; fileNodePortSchemaJadeScript.fileName;
	self.staMain.caption := rtnStr;
	self.doWindowEvents(0);
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; fileNodePortSchemaJadeScript.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; fileNodePortSchemaJadeScript.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		if not self.fromUnitTestRun then										// 24/02/2015 cnwmh5
			app.msgBox("PortSchema scm failed to load (JadeScript).  Please check the scm file", "PortSchema load error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		else
			self.unitTestErrorArray.add(fileNodePortSchema.fileName &amp; " PortSchema scm failed to load (JadeScript).  Please check the scm file.");
		endif;
		return;
	endif;
	
	// load other schema
	rtnStr := "Loading schema file: " &amp; fileNodeOtherSchema.fileName;
	self.staMain.caption := rtnStr;
	self.doWindowEvents(0);
	args.clear();
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; fileNodeOtherSchema.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; fileNodeOtherSchema.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');	
		
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		if not self.fromUnitTestRun then										// 24/02/2015 cnwmh5
			app.msgBox(self.myLSschema.mySchema.getName() &amp; " scm failed to load.  Please check the scm file", self.myLSschema.mySchema.getName() &amp; " load error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		else
			self.unitTestErrorArray.add(self.myLSschema.mySchema.getName() &amp; " scm failed to load.  Please check the scm file.");
		endif;
		return;
	endif;
	
	// run the JadeScript loaded to load the translations
	self.updateConstantDetails();
	
epilog

	delete args;
end;
</source>
        <Parameter name="_fileFolder" type="FileFolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeConstants" id="cc8b5435-e6f8-4fd4-af02-6f538f07c331">
        <executionLocation>server</executionLocation>
        <source>removeConstants(_fileFolder : FileFolder io) serverExecution;

/*

Purpose:			Purge the Xlat Constants that are no longer used
*/

vars

	fileNodePortSchema	: FileNode;
	obj					: Object;	
	allFiles			: FileNodeArray;
	args				: StringArray512;
	rtnStr				: String;
	result				: Integer;

begin
	if self.fromUnitTestRun then
		return;
	endif;

	create allFiles transient;
	_fileFolder.mask := "*-DeleteGlobalConstants.jcf";
	allFiles := _fileFolder.files();
		
	// get the details of the Form Captions-partial scms
	foreach obj in allFiles do
		if obj.FileNode.fileName.cnContains("PortSchema") then
			fileNodePortSchema := obj.FileNode;
		endif;
	endforeach;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; fileNodePortSchema.String  &amp; Tab &amp; "allFiles.size: " &amp; allFiles.size.String, LogINFO);
	
	// if it don't exist then can't load stuff in
	if fileNodePortSchema = null  then
		// TODO: Error 
		return;
	endif;

	create args transient;
	
	result := -1;
		
	// load PortSchema global constants
	rtnStr := "Loading schema file: " &amp; fileNodePortSchema.fileName;
	self.staMain.caption := rtnStr;
	self.doWindowEvents(0);
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('commandFile="' &amp; fileNodePortSchema.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'commandFile="' &amp; fileNodePortSchema.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');
	
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; rtnStr, LogINFO);
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		if not self.fromUnitTestRun then									
			app.msgBox("PortSchema jcf failed to Ditch Constants.  Please check the JCF file", "PortSchema load error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		else
			self.unitTestErrorArray.add(fileNodePortSchema.fileName &amp; " PortSchema jcf failed to Ditch Constants.  Please check the JCF file");
		endif;
		return;
	endif;
		
epilog

	delete args;
end;
</source>
        <Parameter name="_fileFolder" type="FileFolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resize" id="7b8b74b0-8eaa-4535-98c3-fd0bc61513ca">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27/01/2012		cnwmh5	Initial creation

*/

vars

	colWidthNonText			: Real;
	colWidth 				: Real;
	minLegendWidth 			: Integer;
begin

	colWidthNonText := self.tblDetails.accessColumn(2).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(3).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(4).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(5).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(6).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(7).width;
	colWidthNonText := colWidthNonText + self.tblDetails.accessColumn(8).width;
	
	colWidth := (self.tblDetails.width - colWidthNonText) / 2;
	
	self.tblDetails.accessColumn(9).width := colWidth.Integer;
	self.tblDetails.accessColumn(10).width := colWidth.Integer;
		
	if self.lblNonDevSystem.visible then
		minLegendWidth := 1009;
	else
		minLegendWidth  := 900;
	endif;
	if self.width &gt; minLegendWidth then
		grpLegend.visible := true;
	else
		grpLegend.visible := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="26a0e4cf-150c-4f7c-bdf0-79d56ad71cd2">
        <updating/>
        <source>setFormCaption() updating;

/*

Purpose:		Set the forms caption with the correct details

Date			Who		Reason
31/05/2013		cnwmh5	Initial creation

*/

vars

begin

	self.noDetailsStr := null;
	
	if self.optNewOnly.value = true then
		if self.noDetailsStr &lt;&gt; null then
			self.noDetailsStr := self.noDetailsStr &amp; " ";
		endif;
		self.noDetailsStr := " No. to Add: " &amp; self.noToAdd.String;
	endif;
	
	if self.optDiffOnly.value = true then
		if self.noDetailsStr &lt;&gt; null then
			self.noDetailsStr := self.noDetailsStr &amp; " ";
		endif;
		self.noDetailsStr := " No. with Diffs: " &amp; self.noWithDiffs.String;
	endif;
	
	self.noDetailsStr := self.noDetailsStr &amp; "]";
	
	//self.caption := "Generate / Load translateForm Method [No. of Forms: " &amp; self.noForms.String &amp; noDetailsStr;
	self.caption := "Generate / Load translateForm Method for " &amp; app.myCnKarmaCntrl.environmentId.toUpper &amp; " [No. of Forms: " &amp; self.noForms.String &amp; noDetailsStr;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableColumnWidths" id="6d6d9b59-8cc4-4baa-a3a6-57e04cebee83">
        <source>setTableColumnWidths();

/*

Purpose:		Set the width for the table	

Date			Who		Reason
19/04/2012		cnwmh5	Initial creation

*/

vars
	tempWidth			: Integer;
	colWidth			: Integer;
begin
	self.tblDetails.accessColumn(1).width := 20;
	tempWidth := self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(2).width := 150;
	tempWidth := self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(3).width := 70;
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(4).width := 70;
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(5).width := 70; 
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(6).width := 45;
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(ColCommentOut).width := 60;
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	self.tblDetails.accessColumn(ColConstantName).width := 200; 
	tempWidth := tempWidth + self.tblDetails.accessedColumn.width;
	
	colWidth := ((self.tblDetails.width - tempWidth) / 2).Integer;
	self.tblDetails.accessColumn(ColFormText).width := colWidth;
	self.tblDetails.accessColumn(ColConstantText).width := colWidth;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectedFormDetails" id="a05da874-0556-484d-97a3-66d307cc30b9">
        <updating/>
        <source>showSelectedFormDetails(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2020	jlgndl1	Initial creation

*/

vars
	lsSchema			: LSschema;
begin

	
	if combobox.listIndex &lt;= 0 or combobox.text.trimBlanks = null then
		return;
	endif;
	
	delete self.myLSschema;
	create self.myLSschema transient;

	self.myFormAgent.allSchemas.purge();
	self.myFormAgent.allConstantsByName.purge();
	self.dictLSconstantsToDisplay.purge();
	
	create lsSchema transient;
	//lsSchema.mySchema := rootSchema.getSchema(PortSchema.name);
	lsSchema.mySchema := self.myPortSchema;	//11 Sep 2020	NDL
	lsSchema.name := lsSchema.mySchema.name;
	self.myFormAgent.allSchemas.add(lsSchema);	
	self.myFormAgent.allSchemas.add(self.myLSschema);
	
	self.lblNoCntrlCount.caption := null;
	self.lblNoCntrlXNew.caption := null;
	self.lblNoTxtXDiff.caption := null;
	self.lblNewCntrlXlats.fontBold := false;
	self.lblNoCntrlXNew.fontBold := false;
	
	// 19/09/2014 cnwmh5
	self.lblNoDontExist.caption := null;
	self.lblNoDontExistC.caption := null;
	self.lblNoCommentOut.caption := null;
	self.lblNoCommentOutC.caption := null;
	
	self.myLSschema.mySchema := combobox.itemObject[combobox.listIndex].Class.schema;
	self.myLSschema.name := self.myLSschema.mySchema.name;
	self.myLSschema.getLSclass(combobox.itemObject[combobox.listIndex].Class.name);
	self.lblSchema.caption := self.myLSschema.mySchema.getName().padBlanks(40);
	self.lblChanged.caption := "Changed: " &amp; rootSchema.findClassInSubschema(combobox.itemObject[combobox.listIndex].Class.name).getModifiedBy().asStringJMT() &amp; " " &amp; 
		rootSchema.findClassInSubschema(combobox.itemObject[combobox.listIndex].Class.name).getModifiedTimestamp().asStringJMT();
	self.lblNoCntrlXlats.caption := "No. Control Translations:";
	self.lblNewCntrlXlats.caption := "No. New Control Translations:";
	self.lblNoTxtXlatsDif.caption := "No. Text Translation Differs:";
	self.lblNoDontExist.caption := "No. No Longer Exist:";										// 19/09/2014 cnwmh5
	self.lblNoCommentOut.caption := "No. Commented Out:";										// 19/09/2014 cnwmh5
	self.myLSclass := self.myLSschema.allClasses.first;
	self.btnSave.enabled := self.myLSclass &lt;&gt; null and app.isDevelopmentSystemMain();
	self.staMain.caption := "Processing " &amp; self.myLSclass.name &amp; " for control/constant details.  Please wait.....";
	
	self.staMain.caption := null;
	
	self.tblDetails.accessColumn(7).enabled := true;
	
	self.processFormMethodDetails();
	
	if self.visible and self.dictAllXlatConstants = null then	//TFS 36423
		self.populateDictAllXlatConstants(null,null);			//TFS 36423
	endif;														//TFS 36423
	
	self.loadTable();

epilog

	app.mousePointer := MousePointer_Default;
	self.setTableColumnWidths();
	self.currentCmbAllFormsIndex := self.cmbAllForms.listIndex;

end;

</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
