    <JadeMethod name="displayInvoiceLine" id="48fb0a0d-3a84-437b-96bb-b77df2d45748">
        <source>displayInvoiceLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
20 January 2026	jlier1	Initial creation 36572

*/

vars
	invLine : CM_InvoiceLine;
	theTable : CM_EntryTable;
	canManualUpdateExtRef : Boolean;
	currentInvoice : CM_Invoice;
	ti : CM_TrackedItem;
	 theRemRow 	: Integer;
begin	

	if self.currentView =  ETView_InvListInvLinePropVoid then
		self.btnSearchCargo.visible:=false;
		return;
	endif;
	
	invLine := self.myCurrentInvoiceLine;
	if invLine = null then
		return;
	endif;
	theTable:=self.tblInvLineProps;
	currentInvoice:=self.myCurrentInvoiceLine.invoice;
	
	theRemRow := theTable.getRowByName(ETRow_Remarks300);
	theTable.accessCell(theRemRow,CM_EntryTable.ColumnValue).wordWrap := true;
	theTable.accessRow(theRemRow).height := 50; 

	
	theTable.setValueByName(ETRow_Remarks300, invLine.remarks); // ### JIRA 33007 03DEC2024 NAVAB1
	theTable.setValueByName(ETRow_InvoiceNumber,invLine.invoice.sequenceNum);	//18 May 2021	NDL	TFS 51194
	theTable.setValueByName(ETRow_InvoiceLineNumber,invLine.sequenceNum);	//18 May 2021	NDL	TFS 51194
	theTable.setValueByName(ETRow_Debtor,		invLine.debtor.name);
	theTable.disableRowByName(ETRow_InvoiceNumber);
	
	theTable.disableRowByName(ETRow_Debtor);
	theTable.hideRowByName(ETRow_Quantity,false);
	theTable.hideRowByName(ETRow_CargoType,false);
	theTable.hideRowByName(ETRow_CargoId,false);
	theTable.hideRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_CargoTA,false);		//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_QuantityTen, false); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34822

	theTable.setValueByName(ETRow_ExternalReference1, invLine.externalRef1); //08/12/2025	navkc1 JIRA 36262
	theTable.setValueByName(ETRow_ExternalReference2, invLine.externalRef2); //08/12/2025	navkc1 JIRA 36262
	theTable.setValueByName(ETRow_ExternalReference3, invLine.externalRef3); //08/12/2025	navkc1 JIRA 36262
	theTable.setValueByName(ETRow_ExternalReference4, invLine.externalRef4); //08/12/2025	navkc1 JIRA 36262
	
	canManualUpdateExtRef := currentInvoice.isManUpdeExtRefAllowedForUser(); //08/12/2025	navkc1 JIRA 36262
	
	//08/12/2025	navkc1 JIRA 36262
	if canManualUpdateExtRef then
		theTable.enableRowByName(ETRow_ExternalReference1);
		theTable.enableRowByName(ETRow_ExternalReference2);
		theTable.enableRowByName(ETRow_ExternalReference3);
		theTable.enableRowByName(ETRow_ExternalReference4);
	else
		theTable.disableRowByName(ETRow_ExternalReference1);
		theTable.disableRowByName(ETRow_ExternalReference2);
		theTable.disableRowByName(ETRow_ExternalReference3);
		theTable.disableRowByName(ETRow_ExternalReference4);
	endif;
	
	if invLine.manual then
		if app.myRoot.isClientGhana() then
			theTable.setValueByName(ETRow_QuantityTen,invLine.quantity);
			theTable.showRowByName(ETRow_QuantityTen,false);
		else
			theTable.setValueByName(ETRow_Quantity,invLine.quantity);
			theTable.showRowByName(ETRow_Quantity,false);
		endif;
		
		if invLine.trackedItem &lt;&gt; null then
			ti := invLine.trackedItem;
			
			self.cmbCargoTypeInvP.listObject := ti.myCargoType;
			theTable.setValueByName(ETRow_CargoType,     ti.myCargoType.description);
			theTable.setValueByName(ETRow_CargoId,       ti.id);
			theTable.setValueByName(ETRow_CargoOperator, ti.myOperator.code);								//12 Dec 2019	NDL	TFS 47954
			self.cmbCargoOper.listObject :=			     ti.myOperator;
			if ti.myPrimaryActualLocation &lt;&gt; null then
				if  ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
					theTable.setValueByName(ETRow_CargoTA, ti.myPrimaryActualLocation.getMyTerminalArea);	//12 Dec 2019	NDL	TFS 47954
					self.cmbCargoTA.listObject := 		   ti.myPrimaryActualLocation.getMyTerminalArea;
					self.cmbCargoTA.lostFocus(self.cmbCargoTA);
					
					theTable.setValueByName(ETRow_CargoLocation, ti.myPrimaryActualLocation);	  			//12 Dec 2019	NDL	TFS 47954
					self.cmbCargoLoc.listObject := 				 ti.myPrimaryActualLocation;
					self.cmbCargoLoc.lostFocus(self.cmbCargoLoc);
				endif;
			endif;
		endif;
		theTable.showRowByName(ETRow_CargoType,false);
		theTable.showRowByName(ETRow_CargoId,false);
		theTable.showRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
		theTable.showRowByName(ETRow_CargoTA,false);		//12 Dec 2019	NDL	TFS 47954
		theTable.showRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
		
		theTable.showRowByName(ETRow_StartDate, false);							// TFS 51154
		theTable.setValueByName(ETRow_StartDate, invLine.chargeTime.date);		// TFS 51154
	else																		// TFS 51154
		theTable.hideRowByName(ETRow_StartDate, false);							// TFS 51154
		theTable.setValueByName(ETRow_StartDate, invLine.chargeTime.date);		// TFS 51154
		self.btnSearchCargo.visible:=false;
	endif;

	self.btnSaveBase.enabled    := true; 

	theTable.goToRowByName(ETRow_Remarks300);	// 24035// ### JIRA 33007 03DEC2024 NAVAB1
	
	theTable.hideRowByName(ETRow_ExternalReference1, false); //23/01/2026	navkc1 JIRA MTN 37058
	theTable.hideRowByName(ETRow_ExternalReference2, false); //23/01/2026	navkc1 JIRA MTN 37058
	theTable.hideRowByName(ETRow_ExternalReference3, false); //23/01/2026	navkc1 JIRA MTN 37058
	theTable.hideRowByName(ETRow_ExternalReference4, false); //23/01/2026	navkc1 JIRA MTN 37058
	
	if currentInvoice.isManViewExtRefAllowedForUser() then
		theTable.showRowByName(ETRow_ExternalReference1, false); //23/01/2026	navkc1 JIRA MTN 37058
		theTable.showRowByName(ETRow_ExternalReference2, false); //23/01/2026	navkc1 JIRA MTN 37058
		theTable.showRowByName(ETRow_ExternalReference3, false); //23/01/2026	navkc1 JIRA MTN 37058
		theTable.showRowByName(ETRow_ExternalReference4, false); //23/01/2026	navkc1 JIRA MTN 37058
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="2f4aa068-61da-4b37-a5db-15d6b2b7ee86">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/*

Purpose:			

