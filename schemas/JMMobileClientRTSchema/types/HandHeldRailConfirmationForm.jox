    <JadeMethod name="doShowFrmDamage" id="0e5f4ce4-db82-4396-855e-5b451b1a60c4">
        <updating/>
        <source>doShowFrmDamage() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
begin
	
	self.doHideFrm(self.frmInward);
	self.doHideFrm(self.frmOutward);
	self.doShowFrm(self.frmDamage);
	self.doHideFrm(self.frmContInfo);
	
	self.btnDamageOK.default := true;
	self.btnDamageCancel.cancel := true;
	containerInfo := self.getCurrentContainerInfo();
	self.lblDamage.caption := 'Damage-' &amp; containerInfo.containerId;
	
	self.tblDamage.init;
	
	
	if containerInfo &lt;&gt; null then
		//self.tblDamage.setTableFromTI(containerInfo.myRealTrackedItem.allDamageInstances);
		// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//self.tblDamage.setTableFromTI(containerInfo.myPxyTrackedItem.allDamageInstances);
		self.tblDamage.setTableFromTI(containerInfo.myPxyTrackedItem.allDamageInstancesByPos);
		if  containerInfo.myRealTrackedItem &lt;&gt; null then
			self.txtDamage.text := containerInfo.myRealTrackedItem.remarks;
		endif;
	endif;
	
	//self.tblDamage.setTableFromTI(containerInfo.allDamageInstances);
	//self.txtDamage.text := containerInfo.damageRemarks;
	
	
	self.setLogicalFocus();
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowFrmInfo" id="d76c466c-44e9-4b84-a4e6-bade56638f0b">
        <updating/>
        <source>doShowFrmInfo(_idx : Integer) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
	dtoWagon				: MobileHandHeldThin::DTO_WagonPosition;
begin
	
	if self.showingForInwards then
		dtoWagon := self.myDTOWagonIn.allDTOWagonPositions[_idx,1];
		if dtoWagon.isBackEnd then
			return;
		endif;
		
		self.showingContainerNumIn 	:= _idx;
		self.showingContainerNumOut := null;
		self.cmbISOType.visible := true;
		self.lblISOType.visible := true;
		containerInfo := self.myDTOWagonIn.getDTOContainerInfo(_idx);
		self.frmContInfo.parent := self.shtInward;
		
	else
		dtoWagon := self.myDTOWagonOut.allDTOWagonPositions[_idx,1];
		if dtoWagon.isBackEnd then
			return;
		endif;
		
		self.showingContainerNumIn 	:= null;
		self.showingContainerNumOut := _idx;
		self.cmbISOType.visible := false;
		self.lblISOType.visible := false;
		containerInfo := self.myDTOWagonOut.getDTOContainerInfo(_idx);
		self.frmContInfo.parent := self.shtOutward;
		
	endif;
	
	
	if containerInfo = null then
		self.txtId.text 		:= null;
		self.cmbISOType.text 	:= null;
		self.txtSealCust.text	:= null;
		self.txtSealOp.text		:= null;
		self.txtSealShip.text	:= null;
		self.chkHaz.value		:= null;
		self.btnDamage.enabled 	:= false;
	else
		self.txtId.text 		:= containerInfo.containerId.toUpper.trimBlanks;
		self.cmbISOType.listIndex := self.cmbISOType.findString(1, containerInfo.isoTypeCode);
		self.txtSealCust.text	:= containerInfo.customsSeal.toUpper.trimBlanks;
		self.txtSealOp.text		:= containerInfo.operatorSeal.toUpper.trimBlanks;
		self.txtSealShip.text	:= containerInfo.shipperSeal.toUpper.trimBlanks;
		self.chkHaz.value		:= containerInfo.hazardousChecked;
	//	if self.showingForInwards then
		//	self.btnDamage.enabled  := containerInfo.confirmed;
	//	else
			self.btnDamage.enabled:=containerInfo.myPxyTrackedItem &lt;&gt; null;
	//	endif;
	endif;
	
	self.doHideFrm(self.frmInward);
	self.doHideFrm(self.frmOutward);
	self.doHideFrm(self.frmDamage);
	
	self.btnConfirm.default := true;
	self.btnBack.cancel := true;
	if containerInfo &lt;&gt; null and containerInfo.confirmed then
		self.lblInfoCaption.caption := 'CONTAINER ' &amp; _idx.String &amp; ' CONFIRMED';		
	else
		self.lblInfoCaption.caption := 'CONTAINER ' &amp; _idx.String;
	endif;
	
	self.doShowFrm(self.frmContInfo);
	self.setLogicalFocus();

			
end;


</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
