<Class name="CMIF_YAPattern" id="42de517d-8471-42b8-b545-2151e47d8d09">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A pattern is a comma separated list of tokens.
Each token can optionally be prefixed with "!" (NOT) 
and/or postfixed by a "*" (Wildcard match).

Ie  !DUG, HU*, JUK,!JI*
</text>
    <DbClassMap file="yardAllocations"/>
