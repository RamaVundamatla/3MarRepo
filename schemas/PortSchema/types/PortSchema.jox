    <JadeMethod name="getTemperatureDisplay" id="90c70581-a280-498d-bcea-57368adfea7c">
        <source>getTemperatureDisplay(pValue : Real; pTempIsFarenheit, pShowAsFarenheit : Boolean) : String;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin

	if pValue = NULL_TEMPERATURE then
		return null;
	endif;

	if pTempIsFarenheit and (not pShowAsFarenheit) then
		return app.temperatureDisplayString(app.temperatureConversion(false, pValue)); //.userNumberFormat($CM_Temperature);
	elseif (not pTempIsFarenheit) and pShowAsFarenheit then
		return app.temperatureDisplayString(app.temperatureConversion(true, pValue)); //.userNumberFormat($CM_Temperature);
	else
		return app.temperatureDisplayString(pValue); //.userNumberFormat($CM_Temperature);
	endif;
	
end;</source>
        <Parameter name="pValue" type="Real"/>
        <Parameter name="pTempIsFarenheit" type="Boolean"/>
        <Parameter name="pShowAsFarenheit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalByName" id="cbbcb0aa-8345-4836-bcae-c867bbe82e65">
        <source>getTerminalByName(_name: String) : CM_Terminal;
// -------------------------------------------
// Created Mar 2005 by cnwrs1
// -------------------------------------------

vars
	term: CM_Terminal;
begin
	foreach term in app.myRoot.allTerminals do
		if term.name = _name then
			return term;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTerminalDefCmdty" id="15b7561b-8bdf-4151-9ff7-5bab9ecef0a1">
        <source>getTerminalDefCmdty(_mtCmdty, _defCmdty, _refCmdty, _hazCmdty: String output);
//----------------------------------------------------------------
//	Created:	07 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	term : CM_Terminal;
begin
	term := self.getMyTerminalDO_NOT_USE;
	
	//01 Mar 2021	NDL	TFS 50740 - Don't default the commodity ever in EDI
	if term.getConfig(EdiNoDefaultComm).Boolean then
		return;
	endif;
	
	_mtCmdty	:= term.getDefaultEmptyCommodity();
	_defCmdty	:= term.getConfig(DefCommodity).String;
	_refCmdty	:= term.getConfig(DefReeferComdty).String;
	_hazCmdty	:= term.getConfig(DefHazCommodity).String;
end;</source>
        <Parameter name="_mtCmdty" type="String" usage="output"/>
        <Parameter name="_defCmdty" type="String" usage="output"/>
        <Parameter name="_refCmdty" type="String" usage="output"/>
        <Parameter name="_hazCmdty" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTerminologyAlternate" id="a6872b8c-49da-42e3-b2f6-b22e29b91148">
        <source>getTerminologyAlternate(_cargoBOLType : CM_CargoBOLType;
						_terminal 	: CM_Terminal;
						_termType 	: String;
						_expType 	: Integer;
						_term 		: String) : String;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     Finds the correct alternate for the _term passed in if there is one.
//				Note that either or both of _cargoBOLType and _terminal maybe validly be
//				null if they have specified a default terminology alternate for that 
//				cargoType of terminal or both.
//
//				If you don't know the expression type required (i.e. singular, plural etc.), pass in as null  
//				and it will search for a replacment through all expressions based on the term passed in.
//			 
// ----------   ----------  --------------------------------------------------
vars
	ctTerminal			: CM_TerminologyHdr;
	termType			: CM_TerminologyType;
	termHdr				: CM_TerminologyHdr;
	termExp				: CM_TerminologyExpression;
begin
	
	termType := self.myRoot.allTerminologyTypes[_termType];
	if termType = null then
		return _term ;
	endif;
	
	termHdr := self.myRoot.allTerminologyHdrs[termType, _cargoBOLType, _terminal];
	
	if termHdr = null then
		return _term ;
	endif;
	
	if _expType &lt;&gt; null then
		termExp := termHdr.myTerminologyDef.allTerminologyExpressions[termHdr.myTerminologyDef.name, _expType];
		if termExp &lt;&gt; null then
			return termExp.userExpression ;
		endif;
	else
		foreach termExp in termHdr.myTerminologyDef.allTerminologyExpressions do
			if termExp.systemExpression.toLower = _term.toLower then
				return termExp.userExpression ;
			endif;
		endforeach;
	endif;
	
	return _term ;

end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termType" type="String"/>
        <Parameter name="_expType" type="Integer"/>
        <Parameter name="_term" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeEditMaskShortFormat" id="46510a64-ba82-4933-8012-af5223fd3e0a">
        <source>getTimeEditMaskShortFormat(_includeSeconds : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     16 June 2008 by cnwrs2
//
// Purpose:     Need to allow for different seperators.
//
// NOTE:		It is critical that lower case "h" for the hours is used for
//				the JadeEditMask control, which always assumes a 24-hour clock.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 
// --------------------------------------------------------------------------------
vars
	tmpTimeInfo	: TimeFormat;
	sep			: String;
	str			: String;

begin
	/*
	//tmpTimeInfo := app.currentLocaleInfo.timeInfo;
	tmpTimeInfo := app.getMyLocaleInfoJMT.timeInfo;
	
	sep := tmpTimeInfo.separator;

	if _includeSeconds then
		str := 'hh' &amp; sep &amp; 'mm' &amp; sep &amp; 'ss';
	else
		str := 'hh' &amp; sep &amp; 'mm';
	endif;
	
	return str;
	*/
	//return "hh.mm";

	return "hh:mm";
end;</source>
        <Parameter name="_includeSeconds" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeShortFormat" id="229fe636-f29f-4bb2-9539-35fe601d4bff">
        <source>getTimeShortFormat(_includeSeconds : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     16 June 2008 by cnwrs2
//
// Purpose:     Need to allow for different seperators
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
vars
	tmpTimeInfo	: TimeFormat;
	sep			: String;
	str			: String;

begin
// cnwdad1 31/08/2010 - PAR #20064.
//	tmpTimeInfo := app.currentLocaleInfo.timeInfo;
	tmpTimeInfo := app.getMyLocaleInfoJMT().timeInfo;
	
	sep := tmpTimeInfo.separator;
	
	if _includeSeconds then
		str := 'HH' &amp; sep &amp; 'mm' &amp; sep &amp; 'ss';
	else
		str := 'HH' &amp; sep &amp; 'mm';
	endif;

	return str;
end;</source>
        <Parameter name="_includeSeconds" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskIntToString" id="55eadea6-f700-4130-a7d3-68da052fec78">
