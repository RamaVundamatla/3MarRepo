    <JadeMethod name="updateStatus" id="0e401281-2e0d-4900-8ff8-c504d6edc8bd">
        <updating/>
        <source>updateStatus(newTaskStatus : Integer) updating;
/*

This method is intended to do the work in respect of updating the status of an 
Entry in a queue.
when a task's status is updated, it calls this method to ensure the
entry's status is correct.
It checks all of the entry's tasks, if they are all complete, then it sets
its status to complete. The queue software will then purge it at a later time.
We also advise the Job of our status.
As this is called from the Task, we need to switch depending on the
status change to a task. If offline/error or held, then we have to
update the entry's status with the new situation
The Entry status can be either COMPLETE, UNACTIONED, HELD or WORKING.
*/
/*

Date		Who		Reason
20 Feb 2009	cnwkpd1	PAR #18796 - Need to treat partially completed overstow tasks
					differently, and allow the Entry to be unactioned in this situation
22 Sep 2009	cnwkpd1	PAR #20711 - remove global.isValidObject for performance
21 Nov 2012	cnwdap1	PAR #30762 CCMS QNS 2233 Use TASK_SYSTEM_HELD to denote a manually-held task  
22 Apr 2015	NDL		Par 36014
*/

vars
	term		: CM_Terminal;
	firstTask	: CM_RTQueueTask;
	
begin
	exclusiveLock(self);
	if status = TASK_ERROR or 
		 status = TASK_MACH_OFFLINE or
		 status = TASK_SYS_HELD then
		if newTaskStatus &lt;&gt; TASK_ERROR and 
			 newTaskStatus &lt;&gt; TASK_MACH_OFFLINE and
			 newTaskStatus &lt;&gt; TASK_SYS_HELD then
			//Status being set back to something other than bad...
			//Restore all statues back to what they were...
			self.restoreTaskStatuses;
		endif;
	endif;

	if newTaskStatus = TASK_UNACTIONED then
		//Check all are now unactioned...
		if areAllTasksEqualStatus(newTaskStatus) then
	  		self.setEntryStatusUnactioned();
		else
			// PAR #18796 - If the first task is a Director, or an overstow move,
			// the the entry can be unactioned and available even if this task is
			// marked as complete
			firstTask := self.allTasks.first;
			if firstTask.taskType = TASK_DIRECTOR or firstTask.isOverstowTask or firstTask.taskType = TASK_BREAKBULK then
		 	 	self.setEntryStatusUnactioned();
			else
				self.status := ENTRY_WORKING;
			endif;
		endif;
	elseif newTaskStatus = TASK_OFFERED then
 		self.status := ENTRY_WORKING;

 	elseif newTaskStatus = TASK_ACCEPTED then
 		self.status := ENTRY_WORKING;
		self.statusToRestoreTo := ENTRY_NULL;
 	elseif newTaskStatus = TASK_WORKING or newTaskStatus = TASK_PENDING then
 		self.status := ENTRY_WORKING;
		self.statusToRestoreTo := ENTRY_NULL;
 	elseif newTaskStatus = TASK_COMPLETE then
 		//Check all are now complete...
 		if areAllTasksEqualStatus(newTaskStatus) then
  			self.status := ENTRY_COMPLETE;
	   	endif;
	elseif newTaskStatus = TASK_ERROR then
 		//Tasks set all others to same state if this condition
 		status := ENTRY_ERROR;

	elseif newTaskStatus = TASK_USER_HELD then
 		//Tasks set all others to same state if this condition
 		status := ENTRY_USER_HELD;

 	elseif newTaskStatus = TASK_MACH_OFFLINE then
 		//Tasks set all others to same state if this condition
 		status := ENTRY_SYSTEM_HELD;

	elseif newTaskStatus = TASK_SYS_HELD then
		//Task is held, but entry is unconcerned at this point.
		//status := ENTRY_UNACTIONED;		// PAR #30762
		status := ENTRY_SYSTEM_HELD;		// PAR #30762

	elseif newTaskStatus = TASK_ALLOCATED then
		//A machine is GOING to do this task
		status := ENTRY_WORKING;
	endif;
	//------------
	//Call WLEs "updateStatus" method
	//------------
	// PAR #20711 - self.myWorkListEntry is inversed, and we have an exclusiveLock on self,
	// so can only be either null or a valid object.  Changed code to use "&lt;&gt; null" for performance
	if self.myWorkListEntry &lt;&gt; null then
		//exclusiveLock(self.myQueue); //??
		self.myWorkListEntry.rebuildStatus();//epr par 25573 6/2/2011 trying to not have so many status update methods was updateStatus();

	endif;
//	term := app.getMyTerminal();
	term := self.myQueue.getMyTerminal();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
		
		if newTaskStatus = TASK_OFFERED or newTaskStatus = TASK_USER_HELD then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue,term.getTerminalEvent(Event_Delete_Queue_Entry),self);
		elseif newTaskStatus = ENTRY_UNACTIONED then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue,term.getTerminalEvent(Event_New_Queue_Entry),self);
		
		endif;
		//Par 14363 2/8/07
		self.sendNotesForRelatedEntry();
	endif;

epilog
	unlock(self);
end;</source>
        <Parameter name="newTaskStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateQueueEntryFlags" id="468a8781-5f7c-442f-b89c-b6c40025b7b2">
        <source>validateQueueEntryFlags();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
