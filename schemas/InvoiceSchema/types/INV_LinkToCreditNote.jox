    <JadeMethod name="setCaption" id="67edd73d-eb87-431b-ae65-7431a1f7aa04">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation  TFS CR 55305 TASK 55536

*/

vars
	string 	: String;
	bank		: CM_Bank;
	creditNote	: CM_Invoice;
begin
	
	if self.myCaption = null then
		self.myCaption := self.caption;
	endif;
	
	string := self.myCaption;
	
	creditNote := self.tblCreditNotes.allSelectedObjects.first().CM_Invoice;
	
	if creditNote &lt;&gt; null then
		string := string &amp; " " &amp; creditNote.sequenceNum.String;
	endif;
	
	if self.myBank &lt;&gt; null then
		string := string &amp; " " &amp; self.myBank.code;
	endif;
	
	inheritMethod(string);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDef" id="c40e3394-cb90-41f4-b0ad-242bb4fc191d">
