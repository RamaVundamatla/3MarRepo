    <JadeMethod name="includeObject" id="a1404b97-5b00-46a3-9b98-f6e50ef2c53b">
        <updating/>
        <source>includeObject(_obj: Object; _passport : CM_Passport): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		01 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 18 Mar 2010	cnwcs5		par 23241 - fix UE 1090
//							Also noticed that Yes/No were hardcoded values - change to locale aware
// -----------------------------------------------------------------------------
vars
	docket : CM_BOL;
	str		: String;
begin
	// 27881 cnwjre1 Aug 2011 this method is now only called for CM_BOL not CM_BOLDtl
	///if self.btnShowBOLItems.value then
	///	docket := _obj.CM_BOLDtl.myBOL;
	///else
		docket := _obj.CM_BOL;
	///endif;

	//+cnwml2 MSL CCMS 1071
	if docket.reconciledDate &lt;&gt; null then
//		str := "Yes";
		str := app.getString(Yes);	// 18/03/2010 cnwcs5
	else
//		str := "No";
		str := app.getString(No);	// 18/03/2010 cnwcs5
	endif;

	if (self.filterDocketNumber &lt;&gt; null and (not docket.number.startsWith( self.filterDocketNumber))) or
		(self.filterOperatorCode &lt;&gt; null and docket.getOperatorCode.trimRight &lt;&gt; self.filterOperatorCode) or
		(self.filterDocketType &lt;&gt; TI_CargoType_Null and docket.bolType &lt;&gt; self.filterDocketType) or
//	or (self.filterVoyage &lt;&gt; null and docket.CM_BOLIn.myVoyage.code &lt;&gt; self.filterVoyage) 					//+cnwml2 MSL CCMS 1071
		(self.filterVoyage &lt;&gt; null and docket.CM_BOLIn.myVoyage &lt;&gt; null and docket.CM_BOLIn.myVoyage.code &lt;&gt; self.filterVoyage) or	// par 23241
		(self.filterStatus &lt;&gt; null and docket.statusDescription &lt;&gt; self.filterStatus) or 					//+cnwml2 MSL CCMS 1071
		(self.filterReconciled &lt;&gt; null and str &lt;&gt; self.filterReconciled) then								//+cnwml2 MSL CCMS 1071
	   	return false;
	endif;


	return true;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="3dd5c6d7-97d5-4ae0-8fcf-2c40829fa381">
        <updating/>
        <source>initDataTable() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	navObj	: CMUI_NavigatorObject;
	idx		: Integer;
	cell	: JadeTableCell;
		
begin

	self.allowMultiSelectEdit := true;
	self.allowMultiSelectDelete := true;
	
	//+cnwml2 PAR22842
	if self.myBOLType.id = BOLType_Log then
		self.setTblDataEntRows(ETDef_DocketTbl);
	else
		if self.btnShowBOLItems.value then
			self.setTblDataEntRows(ETDef_DocketTblItems);
		else
			self.setTblDataEntRows(ETDef_DocketTbl);
		endif;
	endif;
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Number, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="2b218e56-d7ab-482a-93cf-db76b44a88e6">
        <updating/>
        <source>initFilterTable() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	entTableView 	: EntTableView;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	theDocType 		: CM_BOLType;
begin

	theTable := tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_DocketFind);
	
	if entTableDef &lt;&gt; null then
		//theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		//+cnwml2 PAR22842
		if self.myBOLType.id = BOLType_Log then
			entTableView := entTableDef.allEntTableViews["Logs"];
		elseif self.myBOLType.id = BOLType_GeneralBillOfLading then
			entTableView := entTableDef.allEntTableViews["BOLs"];
		endif;
		theTable.setEntTableFromView(entTableDef, entTableView, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);

		//self.myAssistant.comboBoxDocketType(cmbDocketType, self.filterDocketType);
		self.setFilterDocketCmb();
		theDocType := app.myRoot.allBOLTypes[self.filterDocketType];
		theTable.setValueByName(ETRow_FilterDocketType, theDocType.description);
//		CCMS1235	
//		self.myAssistant.comboBoxOperator(cmbOperator, null, null);
		//self.myAssistant.comboBoxLogDocketError(self.cmbDocketError,null);   //ccms 1110
		self.myAssistant.comboBoxBOLStatus(self.cmbFiltStatus, null);				//+cnwml2 MSL CCMS 1071
		theTable.setValueByName(ETRow_FilterStatus, self.cmbFiltStatus.text);		//+cnwml2 PAR26136
		//self.myAssistant.comboBoxVoyageCode(self.cmbFiltVoyage, null, false);		//+cnwml2 MSL CCMS 1071
		self.setFilterVoyageCmb();													//+cnwml2 PAR26136	
		self.myAssistant.comboBoxYesNoCombo(self.cmbReconciled);					//+cnwml2 MSL CCMS 1071
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;

	self.sptDataFilter.setLeftToRightRatioAndResize(35);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="8620e16a-1269-480c-97cd-1856cbc0a20e">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	navObj	: CMUI_NavigatorObject;
	//canUpdate : Boolean;
	termBOLType		: CM_CargoBOLType;
begin

	//self.allowAdd 				:= false;
	//self.allowDelete 			:= false;			//-cnwml2 PAR23230
	self.allowPrint  	:= false;	//Buttons not implemented as of 15/6/01
	self.allowExportCSV	:= false;
	if self.filterDocketType = null then
		self.filterDocketType		:= BOLType_Log;
	else
		self.filterDocketType		:= self.cmbDocketType.listObject.CM_BOLType.id;
	endif;
	self.showFilterOnStartup 	:= true; 	// Show the filter frame
	self.showDataOnStartup 		:= false; 	// Do not populate the data table with data
	cmbDocketType.listObject 	:= null;
	
	termBOLType := app.myRoot.allBOLTypes[BOLType_Log];
	self.tblData.setTerminologyRelevant(termBOLType, self.myTerminal);
	self.tblMain.setTerminologyRelevant(termBOLType, self.myTerminal);
	self.tblSearch.setTerminologyRelevant(termBOLType, self.myTerminal);
	self.tblThumb.setTerminologyRelevant(termBOLType, self.myTerminal);

	/*if app.myCurrentUserCan(self.myTerminal, PmAdmDocketMaint) then
		self.userPermissionMode := PmAdmDocketMaint;
	else
		self.userPermissionMode := PmAdmDocketView;
	endif;

	canUpdate := (self.userPermissionMode &lt;&gt; PmAdmDocketView);
	self.allowUpdate := canUpdate;*/
	
	self.cmbSrcLocn.useDisplayCollection		:=	true;
	self.cmbSrcSubLocn.useDisplayCollection		:=	true;
	self.cmbSrcSubSubLocn.useDisplayCollection	:=	true;
	self.cmbSubTerminal.automaticCellControl	:=	true;
	
	self.initMainTable();
	self.initFilterTable();

//	PAR 10281 - playing up with the way the combo text displayed.
//	self.cmbLoggingOrg.automaticCellControl := true;
	
	//self.setNavigatorHeading('Dockets');					//-cnwml2 PAR22998
	
	self.beginClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLAdd), Response_Continuous, 0);
	self.beginClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="initMainTable" id="1c49cba3-9a82-467c-913b-c15b5dc1c2a3">
        <source>initMainTable();
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	subTermObj		: CM_SubTerminal;
	
begin

	theTable := tblMain;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
		
	entTableDef := app.myController.getEntTableDef(self.myMasterMenuAction.mainTableDef);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.adjustHeight(200);

	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
//	self.myAssistant.comboBoxSupplier(self.cmbSupplier, null);
	self.cmbSupplier.setObject(null);
//	HJG changed 13/12/04 re CCMS 1235
//	self.myAssistant.comboBoxConsignor(self.cmbConsignor, null);
	//self.cmbConsignor.setObject(null);
	self.myAssistant.comboBoxConsignor(self.cmbConsignor, null, CONSIGNOR);
	
//	self.myAssistant.comboBoxUser(self.cmbScaler, null);
	
	self.myAssistant.comboBoxLocationControllers(self.cmbLogLocation,  self.allLogLocations, true);
	self.myAssistant.comboBoxLogDocketError(self.cmbDocketError,null);   //ccms 1110
// cnwdad1 21/04/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.myCurrentObject &lt;&gt; null then	
			if self.myCurrentObject.isKindOf(CM_BOLDtl) then												//+cnwml2 SFW CCMS 1071
				subTermObj := self.myCurrentObject.CM_BOLDtl.myBOL.mySubTerminal;
			else
				subTermObj	:=	self.myCurrentObject.CM_BOL.mySubTerminal;
			endif;
		endif;
		
		self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, subTermObj, self.myTerminal);
	else
		theTable.hideRowByName(ETRow_MySubTerminal, false);
		tblThumb.hideRowFromHeading(ETRow_MySubTerminal);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadItemTable" id="6f437765-bbe6-4d31-a7ce-81e0659214e8">
        <source>loadItemTable(_bol : CM_BOL; _viewName : String);

vars

	idx		: Integer;
	bolItem : CM_BOLDtl;
begin
	if _bol = null then
		return;
	endif;
	
	self.tblBOLItems.clear;
	self.tblBOLItems.rows := 0;
	self.tblBOLItems.clearAllSelected;

	foreach bolItem in _bol.allBOLDtls do
		self.tblBOLItems.addObjectAndDisplay(bolItem, _viewName);
	endforeach;
	
end;
	</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
