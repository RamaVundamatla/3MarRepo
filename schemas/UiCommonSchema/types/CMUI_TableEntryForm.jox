    <JadeMethod name="setupForm" id="9f44b344-0dae-44df-8f36-22cf776ecae8">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
begin
	self.frmAll.borderStyle		:=	Frame.BorderStyle_None;
	self.frmItem.borderStyle	:=	Frame.BorderStyle_None;
	self.toolbarStyle			:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar			:=	true;
	self.tblItem.parentBottomMargin := self.tblItem.distanceFromBottom;
	self.lblItemCount.visible	:=	self.showNumberOfItems();
	
	inheritMethod();
end;</source>
    </JadeMethod>
