    <JadeMethod name="txtCargoId_keyPress" id="023e8355-d000-4632-a1aa-d5651ee5879b">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2013	cnwmc5	Initial creation	PAR 32517

*/

vars

begin
	if keyCharCode = J_key_Enter then
		app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
		self.doClickPartCargoIdSearch();
	endif;
epilog

end;</source>
