    <JadeMethod name="setFromSlotDefnVoyage" id="3852eacc-430e-48d8-bdeb-7c12b606b655">
        <updating/>
        <source>setFromSlotDefnVoyage(_slotDefnVoyage : CM_SlotDefnVoyage) updating;
/*
------------------------------------------------------------------------
Created:			30 January 2003 by cnwdwq1
Purpose:			Updates the properties from the passed in slotDefnVoyage. Called at
							create time. Can also be called at any time the slotDefn changes so
							values propagate across here.
Parameters:		A_slotDefnVoyage. The slotDefn we are using with this slotcontroller
Returns:			zilch
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if _slotDefnVoyage = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotDefnVoyage', null, null);	
	endif;
	self.ordinalCell := _slotDefnVoyage.ordinalCell;
	self.ordinalDeck := 	_slotDefnVoyage.ordinalDeck;
	self.ordinalTier := _slotDefnVoyage.ordinalTier;

	// PAR 18847
	self.is30ft := _slotDefnVoyage.is30;
	self.is45ft := _slotDefnVoyage.is45;
	self.is53ft := _slotDefnVoyage.is53;
	self.is40ft := _slotDefnVoyage.fortyFront;
	
//	self.ordinalSlot := 1;

	if app.isConverting then
		self.myBayVoyage := null;
		self.myVoyage := null;
		self.mySlotDefnVoyage := null;
	endif;

	//Inverse updates.
	self.myBayVoyage := _slotDefnVoyage.myBay.CM_BayVoyage;
	//------------------
	//CM_VoyageController stuff
	//------------------
	self.myVoyage := self.myBayVoyage.myCellularVoyageStructure.myVoyage;
	self.mySlotDefnVoyage := _slotDefnVoyage;
	//------------------
	//CM_LocationsController stuff
	//------------------
	self.setIdent(self.myBayVoyage.myCellularVoyageStructure.useBayCellTierNumbering);

end;</source>
        <Parameter name="_slotDefnVoyage" type="CM_SlotDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="setIdent" id="34b7e42c-93e3-473f-a0a9-e58536d8b45a">
        <updating/>
        <source>setIdent(_useBayCellTierNumbering : Boolean) updating;
/*
 ------------------------------------------------------------------------
Created:			13 November 2002 by cnwdwq1
Purpose:			This is a method because the ident can be altered by the users altering the
							definition of the vessel/voyage.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if _useBayCellTierNumbering then
		self.ident :=  self.cellId &amp; self.tierId;
	else
		self.ident := self.tierId &amp; self.cellId;
	endif;
end;</source>
        <Parameter name="_useBayCellTierNumbering" type="Boolean"/>
    </JadeMethod>
