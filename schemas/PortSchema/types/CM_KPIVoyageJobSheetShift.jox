    <JadeMethod name="getDescriptionString" id="6ea926be-5657-4585-9db9-897ac94f36f6">
        <source>getDescriptionString(_short: Boolean): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
02 August 2011	cnwcs5	Initial creation - Tidy up when removing old KPI classes
*/
vars

begin
	return self.shiftDescription &amp; ' (' &amp; self.shiftStartTS.date.asStringJMT &amp; ')';
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShiftEndTSLocalTZ" id="67e0bc60-595d-4a17-9c6f-a0f06890e20d">
        <source>getShiftEndTSLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
