    <JadeMethod name="convertBaseToTarget" id="e5dffe33-aafd-424e-895c-f80eb18adda4">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.GRAMS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	pMeasure / 10;

	elseif pUnitTo = self.GRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure / 2.54;
		
	elseif pUnitTo = self.KILOGRAMS_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10000;
		
	elseif pUnitTo = self.KILOGRAMS_PER_SQUARE_CM then
		convertedMeasure	:=	pMeasure / 10000;
		
	elseif pUnitTo = self.KILOGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.MILLIGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 0.305152;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 43.942;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure * 49.494;
		
	elseif pUnitTo = self.POUNDS_PER_ACRE then
		convertedMeasure	:=	pMeasure * 8921.791;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 4.882428;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 703.07;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure / 0.542492;
		
	elseif pUnitTo = self.TONNES_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10;
		
	elseif pUnitTo = self.TONS_UK_PER_ACRE then
		convertedMeasure	:=	pMeasure * 3.982942;
		
	elseif pUnitTo = self.TONS_US_PER_ACRE then
		convertedMeasure	:=	pMeasure * 4.460896;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Spread Rate (by mass) to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="ead1eb87-9925-4da7-8d0f-4d53c16de51f">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.GRAMS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	self.measure * 10;

	elseif pUnitFrom = self.GRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	self.measure * 2.54;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10000;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_SQUARE_CM then
		convertedMeasure	:=	self.measure * 10000;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.MILLIGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 0.305152;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 43.942;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure / 49.494;
		
	elseif pUnitFrom = self.POUNDS_PER_ACRE then
		convertedMeasure	:=	self.measure / 8921.791;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 4.882428;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 703.07;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure * 0.542492;
		
	elseif pUnitFrom = self.TONNES_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10;
		
	elseif pUnitFrom = self.TONS_UK_PER_ACRE then
		convertedMeasure	:=	self.measure / 3.982942;
		
	elseif pUnitFrom = self.TONS_US_PER_ACRE then
		convertedMeasure	:=	self.measure / 4.460896;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Spread Rate (by mass) to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="20a99df9-4092-4e8b-a9b5-9725584209d9">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.GRAMS_PER_SQUARE_CENTIMETRE);
	pAllUnits.add(self.GRAMS_PER_SQUARE_METRE);
	pAllUnits.add(self.INCHES_OF_RAINFALL);
	pAllUnits.add(self.KILOGRAMS_PER_HECTARE);
	pAllUnits.add(self.KILOGRAMS_PER_SQUARE_CM);
	pAllUnits.add(self.KILOGRAMS_PER_SQUARE_METRE);
	pAllUnits.add(self.MILLIGRAMS_PER_SQUARE_METRE);
	pAllUnits.add(self.MILLIMETRES_OF_RAINFALL);
	pAllUnits.add(self.OUNCES_PER_SQUARE_FOOT);
	pAllUnits.add(self.OUNCES_PER_SQUARE_INCH);
	pAllUnits.add(self.OUNCES_PER_SQUARE_YARD);
	pAllUnits.add(self.POUNDS_PER_ACRE);
	pAllUnits.add(self.POUNDS_PER_SQUARE_FOOT);
	pAllUnits.add(self.POUNDS_PER_SQUARE_INCH);
	pAllUnits.add(self.POUNDS_PER_SQUARE_YARD);
	pAllUnits.add(self.TONNES_PER_HECTARE);
	pAllUnits.add(self.TONS_UK_PER_ACRE);
	pAllUnits.add(self.TONS_US_PER_ACRE);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="0ac5a3aa-9bb8-44b4-a43c-fb8a6eb11172">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.GRAMS_PER_SQUARE_CENTIMETRE then
		return "Grams per Square Centimetre";
	elseif pUnit = self.GRAMS_PER_SQUARE_METRE then
		return "Grams per Square Metre";
	elseif pUnit = self.INCHES_OF_RAINFALL then
		return "Inches of Rainfall";
	elseif pUnit = self.KILOGRAMS_PER_HECTARE then
		return "Kilograms per Hectare";
	elseif pUnit = self.KILOGRAMS_PER_SQUARE_CM then
		return "Kilograms per Square Centimetre";
	elseif pUnit = self.KILOGRAMS_PER_SQUARE_METRE then
		return "Kilograms per Square Metre";
	elseif pUnit = self.MILLIGRAMS_PER_SQUARE_METRE then
		return "Milligrams per Square Metre";
	elseif pUnit = self.MILLIMETRES_OF_RAINFALL then
		return "Millimetres of Rainfall";
	elseif pUnit = self.OUNCES_PER_SQUARE_FOOT then
		return "Ounces per Square Foot";
	elseif pUnit = self.OUNCES_PER_SQUARE_INCH then
		return "Ounces per Square Inch";
	elseif pUnit = self.OUNCES_PER_SQUARE_YARD then
		return "Ounces per Square Yard";
	elseif pUnit = self.POUNDS_PER_ACRE then
		return "Pounds per Acre";
	elseif pUnit = self.POUNDS_PER_SQUARE_FOOT then
		return "Pounds per Square Foot";
	elseif pUnit = self.POUNDS_PER_SQUARE_INCH then
		return "Pounds per Square Inch";
	elseif pUnit = self.POUNDS_PER_SQUARE_YARD then
		return "Pounds per Square Yard";
	elseif pUnit = self.TONNES_PER_HECTARE then
		return "Tonnes per Hectare";
	elseif pUnit = self.TONS_UK_PER_ACRE then
		return "Tons (UK) per Acre";
	elseif pUnit = self.TONS_US_PER_ACRE then
		return "Tons (US) per Acre";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Spread Rate by Mass to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
