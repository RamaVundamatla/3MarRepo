    <JadeMethod name="displayDeliveryRequest" id="48a5ee2d-9e25-41b3-841e-c25aa3769a60">
        <updating/>
        <source>displayDeliveryRequest(_delReq: CM_YardDeliveryRequest) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	theOperator		: CM_Operator;
	theISOType		: CM_ISOType;
	theAvGrade		: CM_MTGrade;
	theTarget		: CM_TerminalArea;
	theSource		: CM_TerminalArea;
	subTerminalObj	: CM_SubTerminal;
	str				: String;
	aGO				: CM_GridObject;
	localTS			: TimeStamp;
begin
	if _delReq = null then
		return;
	endif;	
	

	//self.cmbTypeToCreate.setForText(Depot_Request_Str);
	self.cmbRequestType.cnEcSetTextIndex(Depot_Request_Str);
	
	
	theOperator := app.myRoot.allOperators[_delReq.operatorCode.trimBlanks()];
	
	
	self.myAssistant.setListTableMTGrade(self.lstMTGrade, _delReq.allAvailabilityGrades);
	str := self.lstMTGrade.getSelectedString(CM_MTGrade::description.name);
	str := self.truncateDisplayString(str, -1);
	self.txtMTGrades.text := str;
	/*
	if _delReq.allAvailabilityGrades.size() &gt;= 1 then
		// CCMs 1235
		theAvGrade := app.myRoot.allAvailabilityGrades[_delReq.allAvailabilityGrades[1]];
//		theAvGrade := app.myRoot.allAvailableAvailabilityGrades[_delReq.allAvailabilityGrades[1]];
		if theAvGrade &lt;&gt; null then
			self.cmbAVGradecmb.listIndex := self.cmbAVGradecmb.findObject(theAvGrade);
			self.cmbAVGradecmb.setObjectAndOperator(theAvGrade, theOperator, null);
		//	self.cmbAvGrade.setForObject(theAvGrade);
		endif;
	endif;
	
	*/
	if theOperator &lt;&gt; null then
		self.cmbOperator.setForObject( theOperator);

	endif;
	
	subTerminalObj	:=	_delReq.mySubTerminalSource;	
	self.cmbSubTerminal.setForObject(subTerminalObj);
	
	theISOType := app.myRoot.allISOTypes[_delReq.isoType.trimBlanks()];
	self.cmbISOType.setForObject( theISOType);
	
	theTarget := self.myTerminal.allTerminalAreas[_delReq.targetLocation.trimBlanks()];

	
	if theTarget &lt;&gt; null then
	//	self.cmbTargetArea.listIndex := self.cmbTargetArea.findObject(theTarget);
		//self.tblMain.setValueByControlName(self.cmbTargetArea.name, theTarget.id.trimBlanks());
		self.cmbTargetArea.setForObject( theTarget );
	else
		self.cmbTargetArea.setForText( _delReq.targetLocation.trimBlanks() );
		self.cmbTargetArea.getEmbeddedControl.ComboBox.lostFocus(self.cmbTargetArea.getEmbeddedControl.ComboBox);
	endif;
	
	
	_delReq.allTerminalAreas.copy ( self.allSelectedTAs);
	_delReq.allTerminalAreaGridObj.copy( self.allSelectedTAGridObjs);
	
	if self.allSelectedTAs.size = 1 then
		theSource := self.allSelectedTAs.first;
		if self.allSelectedTAGridObjs.size = 1 then
			aGO := self.allSelectedTAGridObjs.first;
		endif;
	endif;
	
	self.myCurrentSourceTA := null;
	/*
	// 23098 revise source processing
	if _delReq.sourceLocation = null then
		//theSource := _delReq.getNominatedTA();
		theSource := _delReq.allTerminalAreas.first;
	else
		theSource := _delReq.sourceLocation.myTerminalArea;
	endif;

		*/
	if theSource &lt;&gt; null then		//cnwrd1 par 28628 4.11.11		
		if theSource.isGridArea and aGO &lt;&gt; null then
			//need to find the grid object for this area
			self.cmbSourceArea.setForObject(  aGO ) ;
		else
			self.cmbSourceArea.setForObject( theSource ) ;			
		endif;
		self.cmbSourceArea.getEmbeddedControl.ComboBox.click(self.cmbSourceArea.getEmbeddedControl.ComboBox);
	endif;	

	self.txtYardSource.caption := self.getYardSourceText();
	//06/04/2009 cnwdz2 PAR 19338 - issue 1.
//	self.tblMain.enableRowByName(ETRow_IsClean);
//	self.tblMain.enableRowByName(ETRow_CheckISOGroup);
	
	self.txtNumRequested.setValue(_delReq.totalRequested);
	self.chkIsClean.setValue( _delReq.clean );
	self.txtRemarks.setValue( _delReq.remarks ) ;
	// self.chkISOGrp.setValue( _delReq.doISOGroupCheck ) ;	//cnwrd1 22.12.09 --
	self.cmbISOGroup.setForObject( app.myRoot.allISOTypeGroups[_delReq.isoGroup] ); //cnwrd1 22.12.09 ++
	//self.txtRequiredDate2.setValue(  _delReq.requiredBtDT.date ) ;
	
	//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	localTS := self.systemToLocalTime(_delReq.requiredByDT);
	self.dtRequired.setDate( localTS.date() ) ;
	self.txtRequiredTime.setValue( localTS.time() ) ;
	
	if self.myTerminal.isAutoPlanUseBestPickDirector then
		self.chkBestPick.visible := false;
	else
		self.chkBestPick.visible := true;
		self.chkBestPick.setValue(_delReq.isBestPick);			// 23098				
	endif;	
	
	
	if _delReq.myTargetSubTerminal &lt;&gt; null then
		self.cmbTargetSubTerm.setForObject(_delReq.myTargetSubTerminal );
	else
		self.cmbTargetSubTerm.setIndex(CNEC_NULL_INDEX);
	endif;

	if _delReq.myRelease &lt;&gt; null then
		self.cmbRelease.setForObject(_delReq.myRelease);
		self.myInitialisingRelease := _delReq.myRelease;  //cnwrd1	 par 22331 17.2.2010
		self.doBuildComboReleaseItem();		//cnwrd1	 par 22331 17.2.2010
		self.doReleaseChange();//cnwrd1 par 27754 28.6.2011
		self.doReleaseItemLostFocus();//cnwrd1 par 27754 28.6.2011
	else
		self.cmbRelease.setIndex(CNEC_NULL_INDEX);
	endif;
	


	if _delReq.myReleaseItem &lt;&gt; null then
		self.cmbReleaseItem.setForObject(_delReq.myReleaseItem);

	else
		self.cmbReleaseItem.setIndex(CNEC_NULL_INDEX);
		
	endif;
	
	if _delReq.mySelectedRTQueue &lt;&gt; null then
		self.cmbRTQueue.setForObject(_delReq.mySelectedRTQueue);
	else
		self.cmbRTQueue.setIndex(CNEC_NULL_INDEX);
	endif;

	
	self.cmbPriority.setForText( _delReq.myJob.priority.String );
	
	
	self.picSelector.visible := false;
end;</source>
        <Parameter name="_delReq" type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="displayJobQStatus" id="d1f56f3c-5a3f-4f4a-9137-8cc8884b2727">
        <source>displayJobQStatus(_theRealJob : CM_Job);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	theRequest : CM_Request;	
	numRTEntries : Integer;
begin


	theRequest := _theRealJob.allRequests.first;
	
	if theRequest = null then
		return;
	endif;
	
	
	
	self.lblStatusDisplay.caption := null;
	self.lblStatusDisplay.foreColor := Black;

	numRTEntries := _theRealJob.allEntries.size;
	if numRTEntries &lt; 1 then		
		self.lblStatusDisplay.caption := app.getErrorString(RTQ_Has_ZERO_Entries);
		self.lblStatusDisplay.foreColor := Red;
		
	else	
		self.lblStatusDisplay.caption := app.getErrorString1(RTQ_Has_X_Entries ,numRTEntries.String );
		self.lblStatusDisplay.foreColor := Blue;
	endif;	
	

epilog

end;</source>
        <Parameter name="_theRealJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="displayMoveRequest" id="d2104d83-f24a-4997-8989-54127762fe2d">
        <updating/>
        <source>displayMoveRequest(_moveRequest : CM_YardMoveRequest)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	theTarget,
	theSource : CM_TerminalArea;
	subTerminalObj	: CM_SubTerminal;
	localTS			: TimeStamp;
begin
	
	self.cmbRequestType.cnEcSetTextIndex(Controller_Strip_Str);
	
	
	if _moveRequest.myTargetTA &lt;&gt; null then
		theTarget := _moveRequest.myTargetTA;
	endif;
	
	if theTarget &lt;&gt; null then
		self.cmbTargetArea.setForObject(theTarget);
	else	
		self.cmbTargetArea.setForText(null );
		self.cmbTargetArea.getEmbeddedControl.ComboBox.lostFocus(self.cmbTargetArea.getEmbeddedControl.ComboBox);
	endif;	


	self.myCurrentSourceTA := null;

	
	if _moveRequest.mySourceLocation &lt;&gt; null then
		theSource := _moveRequest.mySourceLocation.myTerminalArea;
		
		if theSource &lt;&gt; null then
			self.cmbSourceArea.setForObject(theSource);
			self.cmbSourceArea.click(self.cmbSourceArea);
			self.txtSourceRestric.setValue( theSource.getTAEnqRestrictionLocString());
		endif;	
	endif;

	self.txtNumRequested.setValue(_moveRequest.totalRequested);
	self.txtRemarks.setValue( _moveRequest.remarks ) ;
	self.chkNoChecks.setValue(_moveRequest.overrideLocnRestrictions);

	//self.tblMain.disableRowByName(ETRow_IsClean);
//	self.tblMain.disableRowByName(ETRow_CheckISOGroup);
	//self.btnEditTV.enabled := false;

	self.picSelector.visible := true;
	
	//cant edit 'move' types
	//self.  enableAllControls(false);
	//self.btnSave.enabled := false;
	self.btnSave.visible := false;
	
	self.txtNumRequested.getEmbeddedControl.TextBox.readOnly := true;
	self.txtRemarks.getEmbeddedControl.TextBox.readOnly := true;
	self.txtJobID.readOnly := true;
	self.txtRequiredDate.enabled := false;
	self.txtRequiredTime.enabled := false;
	
	self.cmbSourceArea.enabled:= false; //getEmbeddedControl.ComboBox.enabled := false;
	self.cmbTargetArea.enabled:= false; //getEmbeddedControl.ComboBox.enabled := false;
	self.cmbSubTerminal.enabled:= false; //getEmbeddedControl.ComboBox.enabled := false;
	self.chkNoChecks.enabled:= false; //getEmbeddedControl.CheckBox.enabled := false;
	self.chkStatusHeld.enabled:= false; //getEmbeddedControl.CheckBox.enabled := false;
	self.cmbPriority.enabled:= false; //getEmbeddedControl.CheckBox.enabled := false;
	self.cmbShifts.enabled:= false; //getEmbeddedControl.CheckBox.enabled := false;
	self.chkBestPick.enabled := false;		// 23098
	
	self.txtNumRequested.enabled := false;  //cnwrd1 par 24963 14.7.2010
	self.txtJobID.enabled := false; //cnwrd1 par 24963 14.7.2010
	//self.lstSelectedTIs.enabled := false; // leave enabled
	//self.txtRemarks.enabled := false; //leave enabled
	
	//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	localTS := self.systemToLocalTime(_moveRequest.requiredByDT);
	self.dtRequired.setDate( localTS.date() ) ;
	self.txtRequiredTime.setValue( localTS.time() ) ;
	
	
epilog

end;</source>
        <Parameter name="_moveRequest" type="CM_YardMoveRequest"/>
    </JadeMethod>
    <JadeMethod name="displaySelectedTIs" id="00a675ed-2a72-4642-b9c3-ce4ce3f285a0">
        <source>displaySelectedTIs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	idx,
	tmpRow	: Integer;
	tmpTI	: CM_TrackedItem;
	newRow : Integer;
begin

	self.lstSelectedTIs.clear();
	idx := 0;
	foreach tmpTI in self.allSelectedTIs do		
		idx := idx + 1;
		newRow := self.lstSelectedTIs.addItem( tmpTI.id);
		self.lstSelectedTIs.itemObject[newRow] := tmpTI;
	endforeach;	
	
epilog

end;</source>
    </JadeMethod>
