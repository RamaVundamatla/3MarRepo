    <JadeMethod name="displayCriteriaForm" id="53d26911-b891-40c5-9abe-cb622223f3a2">
        <updating/>
        <source>displayCriteriaForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 April 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/
vars
	criteriaForm : CMUI_ObjectCriteriaLineForm;
	transitionProxy, transitionMatchCriteria : CM_IMEXTransitionCriteria;
	temp : CM_IMEXTransitionCriteria;
begin
	
	create criteriaForm transient;
	
	criteriaForm.setMyTerminal(self.myTerminal);
	transitionProxy := self.myProxyObject.CM_IMEXTransitionCriteria;
	if not transitionProxy.allCriteria.isEmpty then
		transitionMatchCriteria := transitionProxy; // prepopulate the criteria if update
	endif;
	criteriaForm.setBaseData(CM_ObjectMatchCriteria.ImexTransitionInt,
							transitionProxy,
							transitionMatchCriteria,
							null,
							self
							);
	self.isCancel := false; // isCancel is set true by criteria form if Cancel clicked
	criteriaForm.showModal();
	if not isCancel then
		self.setDescription(transitionProxy); // show criteria from criteria form
	endif;
	
epilog

end;</source>
    </JadeMethod>
