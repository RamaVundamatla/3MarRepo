        <source>utlUpdateTerminalSubArea(_prxTerminalSubArea : CM_TerminalSubArea input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
