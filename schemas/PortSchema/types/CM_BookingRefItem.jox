    <JadeMethod name="consignorDesc" id="8a08b947-0677-4c60-8342-579255bab827">
        <methodInvocation>mapping</methodInvocation>
        <source>consignorDesc(set: Boolean; _value: String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

begin
	if set then
		// set code here
	else
		// get code here
		if self.myBookingReference &lt;&gt; null then
			_value := self.myBookingReference.consignorDesc;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="containsPrenotedTI" id="a6583321-77af-41a6-a068-a82860e3dbc9">
        <source>containsPrenotedTI(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2014	cnwmc5	Initial creation	PAR 34468

*/

vars
	ti		: CM_TrackedItem;
	realTI	: CM_TrackedItem;
	
begin

	foreach ti in self.allTIs where (ti.state = TI_STATE_NOTIFIED) do
		if _ti.isTransient then
			realTI := _ti.pxyGetRealObject();
		else
			realTI := _ti;
		endif;
		if self.allTIs.includes(realTI) then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createReeferPropertiesIfReqd" id="e8ca3737-fc72-48a4-9216-fb64f1f9b908">
        <updating/>
        <source>createReeferPropertiesIfReqd() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.myReeferProperties = null then
		if self.isTransient then
			create self.myReeferProperties transient;
		else
			create self.myReeferProperties persistent;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cutoffTS" id="d00a3ad5-e7a2-4073-b039-195650a51337">
        <methodInvocation>mapping</methodInvocation>
        <source>cutoffTS(set : Boolean; _value : TimeStamp io) mapping;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

*/
vars
	recCutoff : CM_ReceivalCutoffVoyage;
	receivalCutoff : String ;
	earliest : TimeStamp;
	cutoff : TimeStamp;
	earliestPN : TimeStamp; //04/03/2025	navkc1 JIRA Story MTN-34227
	cutoffPN : TimeStamp; //04/03/2025	navkc1 JIRA Story MTN-34227
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		 //self.getReceivalCutoff(earliest,cutoff);
		 self.getReceivalCutoff(earliest,cutoff,earliestPN,cutoffPN);//04/03/2025	navkc1 JIRA Story MTN-34227
		_value := cutoff;
	
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="decreaseItemQuantity" id="ea65ee7c-6951-42fc-acd4-04082c9fe6de">
        <updating/>
        <source>decreaseItemQuantity(_quantity : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwmc5	Initial creation		PAR 32827

*/

vars
	toRemove,
	diff		: Integer;
begin
	toRemove := 0;
	diff := self.quantity - self.getRecievedCount();
	
	if diff &lt; 0 then
		toRemove := diff;
	endif;
	
	if _quantity = 0 then
		toRemove := toRemove + 1;
	else
		toRemove := toRemove + _quantity;
	endif;
	
	if toRemove &gt; 0 then
		//cnwmc5 - 20 Nov 2013 - PAR 33008 - so it can't get to negitive numbers...
		if (self.quantity - toRemove) &gt; 0 then
			self.quantity := self.quantity - toRemove;
		else
			self.quantity := 0;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_quantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d5448088-4afb-4e91-bb8a-2f9b74ccf24b">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwndl1	Initial creation To stop a transient leak in PAR26798_COPARN_Hazardous test.

*/

vars
	
	
begin

	self.allTIHazards.purge();
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doesCargoMatch" id="01a3dd39-ecce-49c8-928f-23e536605db2">
        <source>doesCargoMatch(	_cargo			: CM_CargoBOLType;
				_commodCode		: String;
				_isoType		: CM_ISOType; 
				_product		: String;
				_marks			: String;
				_markNumber		: String;
				_colour			: String;
				_purchaseOrder	: String;
				_serviceOrder	: String;
				_checkedAll 	: Boolean;
				_reason			: String io) : Boolean;
/*

Date		Who		Reason
28 August 2015	cnwer1	Initial creation PAR 36632 refactored out of CM_BookingRef::getMatchingItem
05 April 2023	navpw1	TFS: 56707 (56712) - Added extra critiera for a booking item to match against
22nd May 2024	navra1	//navra1 - CR 63764/Task 64217 - 22st May 2024
15 Jul 2024 navlc30 Bug 64966: Items Received is not showing up on the Booking Form
*/

vars
	isoGroup	: CM_ISOTypeGroup;
	product		: CM_Product;
	strictCheckingResult : Boolean;
begin
	if self.matchMode = CM_BookingRefItem.BASIC_MATCH then
		if _isoType &lt;&gt; null then
			//cnwmc5 - 21 March 2014 - PAR 33045 - split this if statement to do two seperate cheecks..
			//cnwmc5 - 17 April 2014 - PAR 33955 - corrected the order of the checks
			if  self.myISOType &lt;&gt; null and not _checkedAll then		//cnwmc5 - 17 April 2014 - PAR 33955 - only do this for the first check
				if self.myISOType &lt;&gt; _isoType then
					return false; // Supplied ISO type doesn't match with the ISO type of the booking item
				endif;
			endif;
			if self.isoTypeGroup &lt;&gt; null then
				isoGroup := _isoType.myISOTypeGroup;
				if isoGroup = null or isoGroup.code &lt;&gt; self.isoTypeGroup then
					return false; // Supplied ISO type doesn't match with the ISO group of the booking item
				endif;
			endif;
		endif;
		
		if _product &lt;&gt; null then
			product := self.myProduct;
		endif;
		
		if _cargo &lt;&gt; null and self.myCargoType &lt;&gt; _cargo then
			/* //04/04/2025	navkc1 JIRA Story MTN-33940
			if _reason.pos(app.getErrorString(CargoType), 1) = null then
				if _reason &lt;&gt; null then
					_reason &amp;= ", " &amp; app.getErrorString(CargoType);
				else
					_reason &amp;= app.getErrorString(CargoType);
				endif;
			endif;
			*/
			_reason.addStringToList(app.getErrorString(CargoType), ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		//elseif _commodCode &lt;&gt; null and self.commodity &lt;&gt; _commodCode then											//15.07.2024 navlc30 #64966
		elseif self.commodity &lt;&gt; null and _commodCode &lt;&gt; null and self.commodity &lt;&gt; _commodCode then				//15.07.2024 navlc30 #64966
			/* //04/04/2025	navkc1 JIRA Story MTN-33940
			if _reason.pos(app.getErrorString(Commodity), 1) = null then
				if _reason &lt;&gt; null then
					_reason &amp;= ", " &amp; app.getErrorString(Commodity);
				else
					_reason &amp;= app.getErrorString(Commodity);
				endif;
			endif;
			*/
			_reason.addStringToList(app.getErrorString(Commodity), ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		elseif _product &lt;&gt; null and product &lt;&gt; null and product.code &lt;&gt; _product then
			/* //04/04/2025	navkc1 JIRA Story MTN-33940
			if _reason.pos(app.getErrorString(Product), 1) = null then
				if _reason &lt;&gt; null then
					_reason &amp;= ", " &amp; app.getErrorString(Product);
				else
					_reason &amp;= app.getErrorString(Product);
				endif;
			endif;
			*/
			_reason.addStringToList(app.getErrorString(Product), ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		else
			if _checkedAll then
				return true;
			endif;
			if not self.isCompleteWithPrenotes then	//epr par 34935 29/9/14	
				return true;
			endif;
		endif;
			
		return false;

	elseif self.matchMode = CM_BookingRefItem.STRICT_MATCH then
		strictCheckingResult := true;	//assume everything matched
		
		//if the ref has a specific field filled, the compared TI SHOULD have the field filled exactly the same		
		
		//first check what the BASIC_MATCH does, ie. isogroup, iso, cargotype, cargosubtype as relevant and then go on to detailed checking
		
		if self.isoType &lt;&gt; null then		
			if self.myISOType &lt;&gt; _isoType then
				self.addToReason(_reason, app.getErrorString(ISOTypes));
				strictCheckingResult := false;				
			endif;			
		endif;
		if self.isoTypeGroup &lt;&gt; null then
			if _isoType &lt;&gt; null then		
				if self.isoTypeGroup &lt;&gt; _isoType.myISOTypeGroup.code then					
					self.addToReason(_reason, "ISO Type Group");
					strictCheckingResult := false;
				endif;
			else	//we cannot determine the isotype group, so return false
				self.addToReason(_reason, "ISO Type Group");
				strictCheckingResult := false;
			endif;
		endif;
		if self.myCargoType &lt;&gt; null then		
			if self.myCargoType &lt;&gt; _cargo then				
				self.addToReason(_reason, app.getErrorString(CargoType));
				strictCheckingResult := false;
			endif;			
		endif;
		if self.myProduct &lt;&gt; null then		
			if self.myProduct.code &lt;&gt; _product then				
				self.addToReason(_reason, app.getErrorString(Product));
				strictCheckingResult := false;
			endif;
		endif;
		
		//the TI matches what the basic match criteria does(except weight and count), lets check the other parameters before 
		//we check the weight and count		
		if self.commodity &lt;&gt; null then
			if _product = null then				//navra1 - BUG 64534 - 17th June 2024 - Since if the TI had a myProduct(subtype), the commodity would have been made empty in CM_BookingRef::getMatchingItemForTI
				if self.commodity &lt;&gt; _commodCode then				
					self.addToReason(_reason, app.getErrorString(Commodity));
					strictCheckingResult := false;
				endif;
			endif;								//navra1 - BUG 64534 - 17th June 2024 - Since if the TI had a myProduct(subtype), the commodity would have been made empty in CM_BookingRef::getMatchingItemForTI
		endif;
		if self.shippingMarks &lt;&gt; null then		
			if self.shippingMarks &lt;&gt; _marks then
				_reason &amp;= app.getErrorString(Marks);
				strictCheckingResult := false;
			endif;			
		endif;
		if self.markNumber &lt;&gt; null then		
			if self.markNumber &lt;&gt; _markNumber then
				self.addToReason(_reason, app.getErrorString(Mark_Number));				
				strictCheckingResult := false;
			endif;			
		endif;		
		if self.colour &lt;&gt; null then		
			if self.colour &lt;&gt; _colour then				
				self.addToReason(_reason, app.getErrorString(Colour));
				strictCheckingResult := false;
			endif;			
		endif;
		if self.purchaseOrder &lt;&gt; null then		
			if self.purchaseOrder &lt;&gt; _purchaseOrder then				
				self.addToReason(_reason, app.getErrorString(Purchase_order_number));
				strictCheckingResult := false;
			endif;			
		endif;
		if self.serviceOrder &lt;&gt; null then		
			if self.serviceOrder &lt;&gt; _serviceOrder then				
				self.addToReason(_reason, app.getErrorString(Services));
				strictCheckingResult := false;
			endif;			
		endif;
		
		if not strictCheckingResult then	//if something didnt match, we have the reson written out, just return as false
			return false;
		endif;
		
		//if it came upto here without returning, everything required matched, just check the weight and count and return as true if
		//the weight/count is ok, otherwise return false
		
		if not self.isCompleteWithPrenotes then	//epr par 34935 29/9/14	
			return true;
		endif;
		
		return false;	
	endif;	
	
epilog

end;</source>
        <Parameter name="_cargo" type="CM_CargoBOLType"/>
        <Parameter name="_commodCode" type="String"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_product" type="String"/>
        <Parameter name="_marks" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_checkedAll" type="Boolean"/>
        <Parameter name="_reason" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesTIMatchMe" id="9cddbfb1-c9cc-49ea-b2f5-4c2c47aede11">
        <source>doesTIMatchMe(_ti : CM_TrackedItem; _exact : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	blnCommodity : Boolean;
	realTemp : Real;
	tempMatches : Boolean;
begin

	if _ti = null then
		return true;
	endif;
	
	if _exact then
		return tempMatches
//		and _ti.bolType = self.bolType
		and ((_ti.cargoType = null) or (_ti.cargoType = self.cargoType)) // so do this instead
		and (_ti.commodity = self.commodity or self.isCommodityChanged)
		and _ti.height = self.height
		and _ti.getISOType() = self.isoType
		and _ti.length = self.length
		and _ti.width = self.width
		and _ti.getMyTotalVolume = self.volume
		//and _ti.weight = self.weight					//-cnwml2 MSL CCMS 1017
		and _ti.totalWeight = self.weight				//+cnwml2 MSL CCMS 1017
		and _ti.myProduct = self.myProduct;
	else  // if file has a null value but real item has data entered, this is ok
		return 
//and (self.bolType = null or _ti.bolType = self.bolType)
		 (self.cargoType = null or _ti.cargoType = self.cargoType)
		and (self.commodity = null or _ti.commodity = self.commodity or self.isCommodityChanged)
		and (self.height = null or _ti.height = self.height)
		and (self.isoType = null or _ti.getISOType() = self.isoType)
		and (self.length = null or _ti.length = self.length)
		and (self.width = null or _ti.width = self.width)
		and (self.volume = null or _ti.getMyTotalVolume = self.volume)
		//and (self.weight = null or _ti.weight = self.weight)				//-cnwml2 MSL CCMS 1017
		and (self.weight = null or _ti.totalWeight = self.weight)			//+cnwml2 MSL CCMS 1017
		and (self.myProduct = null or _ti.myProduct = self.myProduct);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_exact" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="earliestReceivalTS" id="0705a37f-8440-49e6-b22f-21a0d1185edf">
