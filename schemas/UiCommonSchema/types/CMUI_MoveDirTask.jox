    <JadeMethod name="tblMove_contextMenu" id="b6110767-280e-40b6-b288-fdbae3a98803">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMove_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	26 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin
	if self.myBaseObject = null then
		return false;
	endif;
	if app.isAllowedToInspect() then
		self.mnuInspectObject.visible := false;
	else
		self.mnuInspectObject.visible := true;			
	endif;	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	
	return false;
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="779bec1a-17a1-49a8-8fa6-795fc436a610">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019850, locale);
	btnMoveIt.translateBubbleHelp(Xlat_0019851, locale);
	btnMoveIt.translateCaption(Xlat_0019852, locale);
	mnuContext.translateCaption(Xlat_0019853, locale);
	mnuInspectObject.translateCaption(Xlat_0019854, locale);
	shtItems.translateCaption(Xlat_0019855, locale);
	shtMove.translateCaption(Xlat_0019856, locale);
end;</source>
    </JadeMethod>
</GUIClass>
