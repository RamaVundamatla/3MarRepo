        <Parameter name="_sealType" type="CM_SealType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnProductsFormClick" id="4de03a91-7d60-4d75-9bb6-d84ff099fc0d">
        <source>doBtnProductsFormClick();
// ---------------------------------------------------------------------------
// Created:     14 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------

//02/04/2009 cnwdz2 PAR19302 rewrite the method to correctly select the table row.
vars
	cargoType	: Object;
begin
	
	if self.tblData.allSelectedObjects.size &lt; 1 then
		//13/05/2009 cnwdz2 par19302
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	cargoType := self.tblData.accessRow(tblData.row).itemObject;
	
	if cargoType = null then
		return;
	endif;
	
	if not cargoType.CM_CargoType.isSubCargoTypeRequired then
		app.raiseCMException(Pleas_selec_cargo_type_whick_h, null, null);
		return;
	endif;
	
	if cargoType &lt;&gt; null then 
	//if self.tblData.accessedRow.itemObject &lt;&gt; null then 
		//cargoType := self.tblData.accessedRow.itemObject.CM_CargoType;
		self.myAssistant.showProductForm(cargoType.CM_CargoType, self.myMasterMenuAction);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="d9a16be0-8666-42e3-bc94-a931984fffe8">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 23 September 2003
//
//-----------------------------------------------------------------------

vars
	result : Integer;
begin
	if self.tblEntDetail.hasChanged 
	and not self.isCodesEdited	// when codes are edited, there is special talk - more complicated message
	then
		return self.confirmCancel('the current item');
	endif;
	
	if self.isCodesEdited then 
		
		result := app.msgBox(app.getErrorString(EditChangedAndClosing) &amp; CrLf &amp; CrLf &amp;'PLEASE NOTE: Changes made to codes will not be saved', self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result = MsgBox_Return_Yes then
			self.isCodesEdited := false;
			return true;	//close form
		else

			return false;
		endif;			

	else
	
		return inheritMethod();
		
	endif;
epilog
	delete self.pxySystemProductType;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClickAddRecipe" id="70626d57-385b-4db5-962e-8e28778562a8">
        <source>doClickAddRecipe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	form : CMUI_RecipeMaint;
	cargoType : CM_CargoType;
	newPxyRecipe : CM_Recipe;

begin

	cargoType := self.myProxyObject.CM_CargoType;
	
	if cargoType = null then
		return;
	endif;
	
	create form transient;
	form.setMyTerminal( self.myTerminal );
	form.setParentForm( self );
	form.setMyCargoType( cargoType, null );
	create newPxyRecipe transient;
	newPxyRecipe.setMyCargoType( cargoType );
	form.setMyPxyRecipe( newPxyRecipe );
	form.showModal();
	
	if newPxyRecipe.code = null then
		//it wasn't updated.
		delete newPxyRecipe;
	else
		self.setShtBlendingRecipes(true);
	endif;
	

epilog

	self.resetRecipeButtons();
	delete form;

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCmbProductType" id="27e230af-c514-4eea-bf0e-edd3d3febebd">
        <updating/>
        <source>doClickCmbProductType() updating, protected;
/* ---------------------------------------------------------------------------
Created:	10 July 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType	: CM_CargoType;
	
begin

	cargoType := self.myCurrentObject.CM_CargoType;
	
	self.displayProductDefaultsNew(cargoType, self.cmbProductType.listData);
	
	// reseting tblEntDetails values according to cargoType
	if cargoType &lt;&gt; null then
		self.tblEntDetail.setValueByName(ETRow_IsCommodityRequired, cargoType.isCommodityRequired);
		self.tblEntDetail.setValueByName(ETRow_IsSubCargoTypeRequired, cargoType.isSubCargoTypeRequired);
	else	// setting to default values
		self.tblEntDetail.setValueByName(ETRow_IsCommodityRequired, false);
		self.tblEntDetail.setValueByName(ETRow_IsSubCargoTypeRequired, false);
	endif;

	self.showHideControlsTblEntDetail(self.cmbProductType.listData);


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClickDelRecipe" id="41ff6fc1-3ff7-4468-ac57-aedb0efd1e27">
        <source>doClickDelRecipe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	rowIndex : Integer;
	recipe : CM_Recipe;

begin

	rowIndex := self.tblRecipes.row;
	if rowIndex &gt; self.tblRecipes.fixedRows and rowIndex &lt;= self.tblRecipes.rows then
		recipe := self.tblRecipes.accessRow( rowIndex ).itemObject.CM_Recipe;
	endif;
	
	if recipe &lt;&gt; null and recipe.isTransient then
		delete recipe;
		self.setShtBlendingRecipes(true);
	endif;
	
epilog

	self.resetRecipeButtons();

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickUpdRecipe" id="27d257dd-c96e-43ad-b1b5-a90b67115279">
        <source>doClickUpdRecipe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	rowIndex : Integer;
	recipe : CM_Recipe;
	form : CMUI_RecipeMaint;
	cargoType : CM_CargoType;

begin

	rowIndex := self.tblRecipes.row;
	if rowIndex &gt; self.tblRecipes.fixedRows and rowIndex &lt;= self.tblRecipes.rows then
		recipe := self.tblRecipes.accessRow( rowIndex ).itemObject.CM_Recipe;
	endif;
	
	if recipe &lt;&gt; null and recipe.isTransient then
		//This is in Update mode
		cargoType := self.myProxyObject.CM_CargoType;
	
		if cargoType = null then
			return;
		endif;
		
		create form transient;
		form.setMyTerminal( self.myTerminal );
		form.setParentForm( self );
		form.setMyCargoType( cargoType, null );
		form.setMyPxyRecipe( recipe );
		form.showModal();
		
		self.setShtBlendingRecipes(true);
	else
		//This is in View mode
		cargoType := self.myCurrentObject.CM_CargoType;
	
		if cargoType = null then
			return;
		endif;
		
		create form transient;
		form.setMyTerminal( self.myTerminal );
		form.setParentForm( self );
		form.setMyCargoType( cargoType, null );
		form.setMyPxyRecipe( recipe );
		form.setViewOnlyMode();
		form.showModal();
		
	endif;

epilog

	self.resetRecipeButtons();
	delete form;

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboCharClick" id="11ced26e-bcf0-4246-a71d-c807f5a103e0">
