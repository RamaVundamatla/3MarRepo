    <JadeMethod name="getJobTotals" id="798c5d4d-dd98-448b-a501-8a68a754c05c">
        <source>getJobTotals(_completed, _unactioned, _partCompleted, _exportCargo : Integer output);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport or tranships
vars
	aJob : CM_Job;
	total : Integer;
	ti : CM_TrackedItem;
begin
	foreach aJob in self.allVoyageJobs discreteLock do
		if aJob.status = JOB_COMPLETE then
			_completed := _completed + 1;
		elseif aJob.status = JOB_UNACTIONED then
			_unactioned := _unactioned + 1;
		elseif aJob.status = JOB_PART_COMPLETE then
			_partCompleted := _partCompleted + 1;
		endif;
	endforeach;
	foreach ti in self.allOnshipTIsByCargoTypeId do //par15488 cnwrs1 jan 2008
		//if ti.isExport then							// PAR #25021
		if ti.isExport or ti.isTranshipOutbound then	// PAR #25021
			_exportCargo := _exportCargo + 1;
		endif;
	endforeach;
end;</source>
        <Parameter name="_completed" type="Integer" usage="output"/>
        <Parameter name="_unactioned" type="Integer" usage="output"/>
        <Parameter name="_partCompleted" type="Integer" usage="output"/>
        <Parameter name="_exportCargo" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getJobTotalsPC" id="5bfe8043-569b-41d7-8f4b-cc2819fc514a">
        <source>getJobTotalsPC(_completed, _unactioned,_partCompleted : Integer io);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	total : Integer;
begin
	
	total := _completed +  _unactioned + _partCompleted;

	
	if total &gt; 0 then
		_completed := ((_completed / total) * 100).Integer;
		_unactioned := ((_unactioned / total) * 100).Integer;
		_partCompleted := ((_partCompleted / total) * 100).Integer;
		
		total := _completed +  _unactioned + _partCompleted;
		// rounding
		if total &lt; 100 then
			_completed := _completed + (100 - total);
		endif;
	endif;
end;</source>
        <Parameter name="_completed" type="Integer" usage="io"/>
        <Parameter name="_unactioned" type="Integer" usage="io"/>
        <Parameter name="_partCompleted" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getJobsForCrane" id="97508208-d426-4817-a24e-e0d842976906">
        <source>getJobsForCrane(_craneId : String; _jobs : CM_JobArray io) protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2001 by cnwdwq1 
//
// Purpose:     Returns all the jobs for a particular crane in order 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	jobSheet : CM_VoyageJobSheet;
begin
	_jobs.clear;
	jobSheet := self.allJobSheets[_craneId.trimBlanks.toUpper];
	if jobSheet = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_CRANE, null, null);
		return;		
	endif;

	jobSheet.allJobsByOrder.copy(_jobs);
	
end;</source>
        <access>protected</access>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_jobs" type="CM_JobArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getKPI" id="6ee1cb01-7d7f-485c-acfc-6f81fcfe4c12">
        <source>getKPI():CM_KPIVoyageEntity;
// ---------------------------------------------------------------------------
// Created:     15 March 2011 by cnwcs5
// Purpose:     Return KPI total for Voyage
//				*** Used in Report Writer - CM_VoyageView ***
// Parameters:  None
// Returns:     Single KPI totals object for voyage
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiTotals	:CM_KPIVoyageEntity;
begin
	kpiTotals := self.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageEntity;
	
	return kpiTotals;
epilog

end;</source>
        <ReturnType type="CM_KPIVoyageEntity"/>
    </JadeMethod>
    <JadeMethod name="getKPIAllCranesHoursDelay" id="1b3485a5-db97-4f8d-897c-e6cbdd258e4f">
        <source>getKPIAllCranesHoursDelay() : Real;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tot : Real;
	aKPI : CM_KPI;
begin

	foreach aKPI in self.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		tot := tot + aKPI.CM_KPIVoyageEntity.hoursDelay;
		
	endforeach;

	return tot;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getKPIAllCranesHoursGross" id="0c039eeb-1154-47c2-830d-4306c416f612">
        <source>getKPIAllCranesHoursGross() : Real;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tot : Real;
	aKPI : CM_KPI;
begin

	foreach aKPI in self.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		tot := tot + aKPI.CM_KPIVoyageEntity.hoursGross;
		
	endforeach;

	return tot;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getKPIAllCranesHoursNet" id="7a798449-e3bf-44fd-9acd-69183b12ed17">
        <source>getKPIAllCranesHoursNet() : Real;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tot : Real;
	aKPI : CM_KPI;
begin

	foreach aKPI in self.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		//tot := tot + aKPI.CM_KPIVoyageEntity.hoursNet;
		tot := tot + aKPI.CM_KPIVoyageEntity.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
		
	endforeach;

	return tot;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getKPIAllCranesNetRate" id="6cf3eec8-054c-42d3-849b-3c951aeca554">
        <source>getKPIAllCranesNetRate()  : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	hoursNet : Decimal[8,2];
	totalTIs : Real;
	aKPI : CM_KPI;
begin
	
	foreach aKPI in self.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		//hoursNet := hoursNet + aKPI.CM_KPIVoyageEntity.hoursNet;
		hoursNet := hoursNet + aKPI.CM_KPIVoyageEntity.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
		totalTIs:=totalTIs +  aKPI.CM_KPIVoyageEntity.movesTI;
	endforeach;
	
	if hoursNet = 0 then
		return 0;
	endif;
	
	return (totalTIs/hoursNet).Decimal.roundedTo(2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
