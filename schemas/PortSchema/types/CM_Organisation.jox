    <JadeMethod name="cnEcGetDuplicate" id="645540ac-5513-4f2b-b6ed-625b38327f3f">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	name : String;
	org : CM_Organisation;

begin

	name := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "name" ).String; 
	
	if name &lt;&gt; null then
		org := app.myRoot.allOrganisations.getAtKey( name );
	endif;

epilog

	return org;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
