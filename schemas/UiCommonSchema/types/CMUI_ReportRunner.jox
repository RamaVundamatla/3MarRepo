		self.setDateComboBoxsFromText(ETRow_RateFromEndDate, self.cmbRateFromEndDate);
		self.setDateComboBoxsFromText(ETRow_RateToEndDate, self.cmbRateToEndDate);
		// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
		
		self.switchDateBoxComboBox(true, ETRow_MovementDateFrom, self.cmbArriveDFrom);
		self.switchDateBoxComboBox(true, ETRow_MovementDateTo, self.cmbArriveDTo);	
		
		self.switchDateBoxComboBox(true, ETRow_LastConnectDT, self.cmbOnDate);	
		
		//12 Jul 2016	NDL	TFS 2234
		self.switchDateBoxComboBox(true, ETRow_FromDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_ToDate, self.cmbCloseDate);
		
		//28 Feb 2018	NDL	TFS 37304
		self.switchDateBoxComboBox(true, ETRow_FilterDateIn, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_FilterDateOut, self.cmbCloseDate);
		
		
		self.setDateComboBoxsFromText(ETRow_ExpectedArrivalDateFrom, self.cmbExpArrDFrom); 					//+TFS39313
		self.setDateComboBoxsFromText(ETRow_ExpectedArrivalDateTo, self.cmbExpArrDTo);
		self.setDateComboBoxsFromText(ETRow_ExpectedDepartDateFrom, self.cmbExpDepDFrom);
		self.setDateComboBoxsFromText(ETRow_ExpectedDepartDateTo, self.cmbExpDepDTo);
		
		self.switchDateBoxComboBox (true,ETRow_ExpectedArrivalDateFrom, self.cmbExpArrDFrom);					//+TFS39280
		self.switchDateBoxComboBox (true,ETRow_ExpectedArrivalDateTo, self.cmbExpArrDTo);
		self.switchDateBoxComboBox (true,ETRow_ExpectedDepartDateFrom, self.cmbExpDepDFrom);
		self.switchDateBoxComboBox (true,ETRow_ExpectedDepartDateTo, self.cmbExpDepDTo);
		
		self.switchDateBoxComboBox(true, ETRow_DateToRun, self.cmbOpenDate);	//14 Aug 2019	NDL	TFS 46131
		
		self.switchDateBoxComboBox(true, ETRow_EffectiveDate, self.cmbOnDate);	 //02 Jul 2021	NDL	TFS 54128
		self.switchDateBoxComboBox(true, ETRow_ExpiryDateFrom, self.cmbOpenDate);	//02 Jul 2021	NDL	TFS 54128	
		self.switchDateBoxComboBox(true, ETRow_ExpiryDateTo, self.cmbCloseDate);	//02 Jul 2021	NDL	TFS 54128	
		self.switchDateBoxComboBox(true, ETRow_FilterFromDate, self.cmbOpenDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_FilterToDate, self.cmbCloseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_DateFrom, self.cmbOpenDate);			// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_DateTo, self.cmbCloseDate);			// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActArrivedDateFrom, self.cmbProcDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActArrivedDateTo, self.cmbPackByDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActDepartedDateFrom, self.cmbBaseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActDepartedDateTo, self.cmbCloseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_SchedDepartedDateFrom, self.cmbDepartDFrom);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_SchedDepartedDateTo, self.cmbDepartDTo);		// TFS 52643

		// Switch dynamic query report parameter date fields to Combo Box
		self.switchQryParamsDateBoxToCmb(true);  // 27-oct-25 navec1 MTN-36160: switch all date fields in allQueryReportParams to combo box
		
	elseif _state = self.myReportAgent.STATE_TEMPLATE_VIEW then
		if self.myMenuEntity &lt;&gt; null and self.myMenuEntity.isKindOf(CM_MenuUserReport) then
			self.lblRepName.caption 		:= 'Template Report Type: ' &amp; self.myMenuEntity.CM_MenuUserReport.myQryReport.heading;
			self.btnPrint.enabled		 	:= true;								// TFS 51190
			self.btnEdit.enabled			:= true;								// TFS 51190
		else
			self.lblRepName.caption			:= 'Template Report Type: &lt;Invalid&gt;';	// TFS 51190
		endif;
		
		//self.btnPrint.enabled		 	:= true;									// TFS 51190
		self.lblRepName.visible 		:= true;	
		//self.btnEdit.enabled			:= true;									// TFS 51190
		self.tblParameter.visible 		:= true;
		self.tblPrintOptions.userInputEnabled := false;
		self.btnDeleteBGR.enabled 		:= true;
		
		self.switchDateBoxComboBox(true, ETRow_BaseDate, self.cmbBaseDate);
		self.switchDateBoxComboBox(true, ETRow_CloseDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(true, ETRow_PackByDate, self.cmbPackByDate);
		self.switchDateBoxComboBox(true, ETRow_MatchDateEnd, self.cmbMatchEnd);
		self.switchDateBoxComboBox(true, ETRow_MatchDateStart, self.cmbMatchStart);
		self.switchDateBoxComboBox(true, ETRow_OnDate, self.cmbOnDate);
		self.switchDateBoxComboBox(true, ETRow_OpenDate, self.cmbOpenDate);
		
		self.switchDateBoxComboBox(true, ETRow_StartDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_EndDate, self.cmbCloseDate);

		self.switchDateBoxComboBox(true, ETRow_LastConnectDT, self.cmbOnDate);
		self.switchDateBoxComboBox(false, ETRow_ProcessDate, self.cmbProcDate);	//16 Nov 2009	NDL	Par 21519
		self.switchDateBoxComboBox(true, ETRow_ReportDate, self.cmbBaseDate);	//14 Sep 2012	EPR PAR 30364
		
		self.switchDateBoxComboBox(true, ETRow_FromPackByDate, self.cmbOpenDate);		// cnwdad1 22/11/2010 - PAR #25218.
		self.switchDateBoxComboBox(true, ETRow_ToPackByDate, self.cmbCloseDate);		// cnwdad1 22/11/2010 - PAR #25218.
		
		//28 Feb 2018	NDL	TFS 37304
		self.switchDateBoxComboBox(true, ETRow_FromDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_ToDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(true, ETRow_FilterDateIn, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_FilterDateOut, self.cmbCloseDate);
