    <JadeMethod name="doMnuFormContextMenu" id="313d286a-4950-48ca-9327-d08f2dad317d">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
//********************************************************************
vars
	x1, y1		: Real;
	showListDataMenus :	Boolean;
	lstDataValidRow	: Boolean;
	tmpMenu : MenuItem;
begin
	showListDataMenus := (conwin = lstData);
	if showListDataMenus then
		lstDataValidRow := (lstData.listIndex &gt; -1);
	endif;

//	Par 9837	
	self.mnuLstDataInspect.visible := app.isAllowedToInspect();

/*	if app.isDevelopmentSystem then
		self.mnuLstDataInspect.visible := true;
	endif;
*/	
	self.mnuLstDataViewAudits.visible := false;
	if showListDataMenus and lstDataValidRow and 
	
	
		self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Object) and 
		self.myCurrentObject.CM_Object.hasAudits then
	  // app.myAA.isAnAuditedClass(self.myDataClass) then
		tmpMenu := self.mnuLstDataViewAudits;
		tmpMenu.caption := "View Audits for " &amp; self.myCurrentObject.CM_Object.auditIdDisplay;
		tmpMenu.enabled := true;
		tmpMenu.visible := true;
	endif;
	
	//No need to show the menu if there is nothing to see.  The separator will show otherwise.
	if self.mnuLstDataViewAudits.visible = false and self.mnuLstDataInspect.visible = false then
		return false;
	endif;
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(mnuLstDataContext, x1.Integer, y1.Integer);
	return false;
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
