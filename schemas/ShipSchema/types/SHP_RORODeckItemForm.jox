    <JadeMethod name="getChildTypeName" id="b572f182-ad66-4f59-910a-fd6348bb1abe">
        <source>getChildTypeName(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent.isKindOf(CM_DeckVessel) then
		return app.getErrorString(Vessel_deck_item);
	elseif self.myParent.isKindOf(CM_DeckVoyage) then
		return app.getErrorString(Voyage_deck_item);
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
