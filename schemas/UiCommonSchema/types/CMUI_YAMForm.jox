    <JadeMethod name="translateForm" id="1ae309c2-d9f3-4f19-85b7-072431db9f37">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2025 10:28:05.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010189, locale);
	btnAdd.translateBubbleHelp(Xlat_0010190, locale);
	btnAdd.translateCaption(Xlat_0010191, locale);
	btnAddYA.translateBubbleHelp(Xlat_0010192, locale);
	btnAddYA.translateCaption(Xlat_0010193, locale);
//	btnClear.translateCaption(Xlat_0001176, locale);
