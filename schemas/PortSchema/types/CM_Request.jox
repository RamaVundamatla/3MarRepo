    <JadeMethod name="getDisplayStringForAttribute" id="e9593d10-c539-42ee-9d73-a055ba10d409">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	28 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	bulkRelease : CM_BulkRelease;
	product		: CM_Product;
	dischargePort : CM_Port;
begin
	if _attrName = ETRow_OperatorCode
	or _attrName = ETRow_CargoTypeDescr then				
		if self.myOriginatingBulkRelease &lt;&gt; null then
			return self.myOriginatingBulkRelease.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_TransactionNum then
		return	self.myJob.getTransactionNumberByRequest(self);
	elseif	_attrName = ETRow_AvailabilityGradeCode then
		return null;
	elseif _attrName = ETRow_Consignee then
		bulkRelease:= self.getBulkRelease();
		if bulkRelease &lt;&gt; null then
			return bulkRelease.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return self.consigneeCode;
	elseif _attrName = ETRow_IsHazardous then
		return self.getAttrHazardous().getYesNo;
	elseif _attrName = ETRow_IsOverDimensions then
		return self.getAttrOverDimensioned().getYesNo;	
	elseif _attrName = ETRow_CargoSubType then
		product:=self.getCargoSubType;
		if product &lt;&gt; null then
			return product.code;
		endif;
		return null;
	elseif _attrName = ETRow_DischargePort then
		dischargePort:= self.getAttrDischargePort;		
		if dischargePort &lt;&gt; null then
			return dischargePort.code;
		endif;
		return null;
	elseif _attrName = ETRow_DestinationPort then
		return null;	
	elseif _attrName = ETRow_Commodity then
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
