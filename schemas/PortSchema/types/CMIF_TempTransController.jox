<Class name="CMIF_TempTransController" id="f54f1d88-609f-4538-bef6-d6f51b8aa505">
    <superclass name="CMIF_TITransactionController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myTempReading" id="5044102e-8a94-4df0-8449-13db26e414d7">
        <embedded/>
        <type name="CM_TempReading"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="027368ee-6b26-4c1d-9145-adb519057ab1">
        <updating/>
        <source>setFromTransaction(_txn: CM_TemperatureReading) updating;
// ---------------------------------------------------------------------------
// Created:		10 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_txn);
	self.myTempReading := _txn.myTempReading;
end;</source>
        <Parameter name="_txn" type="CM_TemperatureReading"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="44458957-34f3-447f-877a-8fc863c63a40">
        <updating/>
        <source>setTransactionDetails(_txn: CM_TemperatureReading input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		10 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_txn);
	_txn.setTempReading(self.myTempReading);
end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TemperatureReading" usage="input"/>
    </JadeMethod>
</Class>
