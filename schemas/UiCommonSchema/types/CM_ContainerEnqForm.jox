    <JadeMethod name="eraseChildCargoItems" id="3eb72034-3ecd-4267-a518-3191f57586b4">
        <updating/>
        <source>eraseChildCargoItems() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwmc5	Initial creation		PAR 34086

*/

vars
	obj 				: Object;
	ti					: CM_TrackedItem;
	
	result				: Integer;
	
	tiSet				: CM_TISet;
	tisWithWarnSet		: CM_TISet;
	
begin

	create tiSet transient;
	create tisWithWarnSet transient;

	foreach obj in self.tblData.allSelectedObjects where obj.isKindOf(CM_TrackedItem) do
		ti := obj.CM_TrackedItem;
		if not ti.isChild 
		or (not obj.CM_TrackedItem.isPreNote and not obj.CM_TrackedItem.isOnShip) then
			continue;
		endif;
		
		tiSet.add(ti);
	endforeach;
	
	while true do
		app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Delete Child Cargo', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			result := app.showErrorWarningDialog('Delete Child Cargo', app.myPassport, ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterTblInitWithLC" id="e828380b-25d4-4055-8e36-5f8edbf4aff8">
        <updating/>
        <source>filterTblInitWithLC() updating;
// ---------------------------------------------------------------------------
// Created:     30 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theLC			: CM_LocationsController;
	theRow			: Integer;
	tmpTI			: CM_TrackedItem;
	tmpCombo		: CMUI_ComboBox;
	tmpTypeId		: Integer;
	theType			: CM_CargoBOLType;
begin

	theLC := self.myCurrentObject.CM_LocationsController;
	
/*	tmpTI := theLC.allTrackedItems.first;
	if tmpTI = null then
		tmpTypeId := self.getDefaultTiType(self.myCurrentCargoBOLType);
	else
		self.myCurrentCargoBOLType := tmpTI.myCargoType;
		tmpTypeId := tmpTI.cargoType;
	endif;
	
	tmpCombo := cmbFiltTiType;
	self.myAssistant.comboBoxCargoBolType(tmpCombo, tmpTypeId, true, true, true, true);
	tmpCombo.lostFocus(tmpCombo);
	tblSearch.setValueByControlName(tmpCombo.name, tmpCombo.text);*/

//  CCMS1235 new combobox object. 
//	tmpCombo := cmbFiltISOType;
//	self.myAssistant.comboBoxISOType(tmpCombo, null);

	tmpCombo := self.cmbFiltVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											false,
											self.includeArchivedVoyages,
											self.includeSailedVoyages,
											true,
											true,
											true,
											true,
											false,
											false); //cnwrs1 par15258 nov 2007



	//Manually enter and set a default for the state combo
	self.loadSiteCombo();
			
	if theLC.myTerminalArea &lt;&gt; null then
		self.myAssistant.comboBoxTAType(cmbFiltTAType, theLC.myTerminalArea.myType, false);	
		self.myAssistant.comboBoxTerminalArea(self.cmbFiltTermArea, theLC.myTerminalArea.type, theLC.myTerminalArea);
		//epr CCMS 1366 25/3/14 before was defaulting the cargo type to the cargo type of first cargo in LC this was wrong
		//now - we have a lc just get all cargo in that lc .
		self.cmbFiltTermArea_click(self.cmbFiltTermArea);
		self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, theLC.displayEntry());
	//	self.cmbFiltYardLocn.listObject := theLC;
		self.cmbFiltYardLocn.listIndex := self.cmbFiltYardLocn.findObject(theLC);
		self.filterYardLocation := theLC;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="findAlphabetisedRow" id="b8b532b5-eb05-4e7d-9ea2-a18e5199f148">
        <source>findAlphabetisedRow(_tbl : CM_EntryTable io; _name : String) : Integer;
// ---------------------------------------------------------------------------
// Created:	06 May 2008 By Graeme Black cnwgb1 pas 16666
// If an entry table is sorted alphabetically, find the place the string 
// given should be added to maintain the alphabetic order
// ---------------------------------------------------------------------------
vars
	low : Integer;
	high: Integer;
	mid : Integer;
begin
	low := 1;
	high := _tbl.rows;
	mid := (high + low) div 2;
	if high = 0 then
		return 0;
	elseif isLessThanRow( _tbl, low, _name ) then
		return 1; //First Position
	elseif not isLessThanRow( _tbl, high, _name ) then
		return 0; //Append
	endif;
	while mid &lt;&gt; low do
		if isLessThanRow(_tbl, mid, _name ) then
			high := mid;
		else
			low := mid;
		endif;
		mid := (high+low )  div 2;
	endwhile;
	
	return mid+1;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
