Purpose:	Return the appropriate VoyageCode.

Date			Who		Reason
04 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	return self.importVoyageCode;
	
epilog
	
