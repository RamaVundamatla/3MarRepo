    <JadeMethod name="setupThumbnailDetails" id="762dfd54-9354-456e-889c-7995382978da">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm	: SOP_HMS_TableMaintForm;
	harbour : HMS_Harbour;
	fieldRoute	: CMUI_FieldComboBox;
begin
	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	harbour := theForm.myHarbour;

	theForm.cmbPathSegment.automaticCellControl := true;
	theForm.cmbPathSegment.listCollection(app.myRoot.allPathSegments, true, 0);
	
	theForm.tblRoute.accessColumn(1).cellControl := theForm.cmbPathSegment;
	theForm.tblRoute.tabKey := J_key_Tab;
	theForm.shtPathSegments.caption := 'Path Segments';
	
		

end;</source>
    </JadeMethod>
    <JadeMethod name="showRouteData" id="6121004f-79f2-4d3a-abcb-865b29945ed5">
        <updating/>
        <source>showRouteData(pObj: HMS_MovementPath) updating;
//-----------------------------------------------------------------------
//	Created:	24 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	theForm 		: SOP_HMS_TableMaintForm;
	fieldRoute 		: CMUI_FieldComboBox;
	pathSegment		: HMS_PathSegment;
	whereAreWe		: HMS_HarbourRegion;
	movementPath	: HMS_MovementPath;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	allRouteSegmentCtrls.purge;
	
	if pObj = null then // source may have changed
		movementPath := theForm.myProxyObject.HMS_MovementPath.pxyGetRealObject();
	elseif pObj.isTransient then  
		movementPath := pObj.pxyGetRealObject();
		theForm.frmPathSegments.enabled := true;
	else
		movementPath := pObj;
		theForm.frmPathSegments.enabled := false;
	endif;
	
	whereAreWe := movementPath.myRegionFrom;

	theForm.cmbRegionSource.top := 30;
	
	theForm.lblStartRoute.caption := "Start :";
	theForm.lblStartRoute.visible := true;
	theForm.lblStartRoute.top := 30;
	theForm.lblStartRoute.fontBold := true;
	
	foreach pathSegment in movementPath.allPathSegments do
		fieldRoute := doCloneARouteSeg (pathSegment, whereAreWe, theForm);
//		fieldRoute.caption := "Via " &amp; movementPath.allPathSegments.indexOf(pathSegment).String;
	endforeach;
	
	if movementPath.allPathSegments.size &gt; 0 then
		theForm.lblDestination.top := allRouteSegmentCtrls.size * 30 + 100;
		theForm.lblDestination.caption := "Finishing  Point : " &amp; movementPath.allPathSegments.last.myRegionTo.description;
		theForm.lblDestination.fontBold := true;
	else
		theForm.lblDestination.caption := "Finishing  Point :";
	endif;

epilog

end;</source>
        <Parameter name="pObj" type="HMS_MovementPath"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b4dbd078-813c-405b-95cd-dcf08ff98303">
        <updating/>
        <source>showThumbnail(pObj: HMS_MovementPath) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	theForm 		: SOP_HMS_TableMaintForm;
	assistantObj	: CMUI_Assistant;
	tmpCombo 		: CMUI_ComboBox;
	tmpPathSeg		: HMS_PathSegment;
	
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);
	
	assistantObj	:=	theForm.myAssistant;
	tmpCombo		:=	theForm.cmbRegionSource;		
	assistantObj.comboBoxHMSRegion(tmpCombo, null, pObj.myRegionFrom);				
	tmpCombo.lostFocus(tmpCombo);
	
	tableObj		:=	theForm.tblRoute;
	tableObj.rows	:=	tableObj.fixedRows;
		
	foreach tmpPathSeg in pObj.allPathSegments do
		tableObj.addItemObject(tmpPathSeg, theForm.myAssistant.displayEntryHMSPathSegment(tmpPathSeg));
	endforeach;

	//theForm.mulSelect1.setSelected(pObj.allPathSegments);	
	
	//lorcan
		
	//self.showRouteData (pObj);
end;</source>
        <Parameter name="pObj" type="HMS_MovementPath"/>
    </JadeMethod>
</Class>
