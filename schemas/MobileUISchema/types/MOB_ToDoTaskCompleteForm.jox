    <JadeMethod name="checkForUnsavedTransientChgs" id="5da47d5c-4d1c-4ecd-bed5-23f2ab0a5895">
        <updating/>
        <source>checkForUnsavedTransientChgs(_unsavedChange : Boolean output) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	resourceType : CM_ResourceType;
	
begin	
	if not self.frm_AddResource.enabled then
		// no entry possible, can't be any unsaved changes.
		_unsavedChange := false;
		return;
	endif;
	
	resourceType := self.cmb_ResourceType.listObject.CM_ResourceType;
	
	if self.myCurrentProxyUsage &lt;&gt; null then
		// in update mode
		if self.myCurrentProxyUsage.myResourceType &lt;&gt; resourceType
		or self.myCurrentProxyUsage.quantity &lt;&gt; self.txt_Units.text.asDecimalJMT()
		or	self.myCurrentProxyUsage.remarks &lt;&gt; self.txt_Remarks.text
		or	self.myCurrentProxyUsage.noCharge &lt;&gt; self.chk_NoCharge.value
		or	( self.myCurrentProxyUsage.status = CM_InvoiceLine.STATUS_VOIDED and self.chk_Void.value = false )
		or	( self.myCurrentProxyUsage.status = CM_InvoiceLine.STATUS_NORMAL and self.chk_Void.value = true )
		then
			_unsavedChange := true;
		endif;
	
	else
		// in add mode
		if resourceType &lt;&gt; null
		//or self.txt_Units.text.Decimal &lt;&gt; 0
		or self.txt_Units.text.asDecimalJMT &lt;&gt; 0	//23 Oct 2015	NDL	Par 36655
		or	self.txt_Remarks.text.trimBlanks &lt;&gt; null
		or	self.chk_NoCharge.value
		then
			_unsavedChange := true;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_unsavedChange" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="clearGrpResource" id="db4657de-0dc5-4390-81da-6e3c0a493ed1">
        <updating/>
        <source>clearGrpResource()protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars

begin
	self.txt_Units.text := null;

	if self.cmb_ResourceType.listCount = 1 then
		self.cmb_ResourceType.listIndex := 1;
		self.cmb_ResourceType_click(cmb_ResourceType);
	else
		self.cmb_ResourceType.listIndex := -1;
		self.setLblUnitsCaption(0);
	endif;

	self.txt_Remarks.text 	:= null;
	self.chk_NoCharge.value := false;
	self.chk_Void.value 	:= false;
	self.chk_Void.enabled 	:= false;
	
	self.frm_AddResource.enabled 	:= false;
	self.myCurrentProxyUsage 		:= null;
	
	self.btn_Delete.enabled := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmb_ResourceType_click" id="7fc1b196-c7da-4614-9351-a777dadfba1c">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmb_ResourceType_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	type : CM_ResourceType;
	decPlaces : Integer;

begin
	if self.cmb_ResourceType.listIndex &gt; 0 then
		type := self.cmb_ResourceType.itemObject[cmb_ResourceType.listIndex].CM_ResourceType;
	endif;
	if type &lt;&gt; null then
		decPlaces := type.decimalPlaces;
	endif;
	
	self.txt_Units.text := null;
	self.setLblUnitsCaption(decPlaces);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnAdd" id="4b63dc79-86bf-41dd-bd10-8327fa08fa11">
        <updating/>
        <source>doBtnAdd() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	unsavedChanges : Boolean;

begin
	self.checkForUnsavedTransientChgs( unsavedChanges );
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist2), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	self.clearGrpResource();
	self.frm_AddResource.enabled := true;
	self.cmb_ResourceType.setFocus();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCancel" id="d288562e-d589-45c7-bf8c-b756358d5cdc">
        <updating/>
        <source>doBtnCancel() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCM SPNL 2461
// 03/06/2015	cnwdap1		PAR #36231 Don't purge proxies, calling form uses them too
//
vars
	proxyResourceUsage : CM_ResourceTypeUsage;
	realResourceUsage : CM_ResourceTypeUsage;
	unsavedChanges : Boolean;
	
begin
	self.checkForUnsavedTransientChgs( unsavedChanges );
	
	if not unsavedChanges then
		//transients that have been added. (I.e. new ones)
		if self.allUpdProxyResourceTypeUsages &lt;&gt; null then
			unsavedChanges := not self.allUpdProxyResourceTypeUsages.isEmpty;
		endif;
	endif;
	
	if not unsavedChanges then
		if self.myToDoTask &lt;&gt; null then
			// an existing transaction, check if any of the existing resource usages which we built proxies for when we 
			// set up the form, have been changed
			foreach proxyResourceUsage in self.allProxyResourceTypeUsages do
				realResourceUsage := proxyResourceUsage.pxyGetRealObject;
				if realResourceUsage = null then
					// should never happen as these were all created from real ones.
					continue;
				endif;
				if realResourceUsage.differsFrom(proxyResourceUsage) then
					//difference between the persistant and its proxy.
					unsavedChanges := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if unsavedChanges then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	self.modalResult := IDCANCEL;

	//self.purgeProxies;					// PAR #36231
	self.unloadForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDelete" id="844f992b-4024-4f4d-8457-cffe08c45afe">
        <updating/>
        <source>doBtnDelete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	proxyUsage : CM_ResourceTypeUsage;
	realUsage : CM_ResourceTypeUsage;
	
begin
	if self.tbl_Resources.row &gt; self.tbl_Resources.fixedRows and self.tbl_Resources.row &lt;= self.tbl_Resources.rows then
		proxyUsage := self.tbl_Resources.accessRow(self.tbl_Resources.row).itemObject.CM_ResourceTypeUsage;
	endif;
	
	if proxyUsage = null then
		return;
	endif;
	
	realUsage := proxyUsage.pxyGetRealObject();
	if realUsage &lt;&gt; null then
		// should never get here...
		// not allowed to delete a real usage once created, it can only be voided.
		return;
	else
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, app.getErrorString( Resource_usage ) ), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.allNewProxyResourceTypeUsages.remove(proxyUsage);
			delete proxyUsage;						// PAR #36231
		endif;
	endif;
	
	//delete proxyUsage;							// PAR #36231
	
	self.clearGrpResource();
	self.loadTableData();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnOK" id="42356972-42bc-4b1a-9a0b-4a9532a66bab">
        <updating/>
        <source>doBtnOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 02/06/2015	cnwdap1		PAR #36231 Don't update container yet, as it's still MT and 
// 							To Do Tasks must be applied to full container for invoicing to be correct
//
vars
	doResources : Boolean;
	proxyResourceUsage : CM_ResourceTypeUsage;
	realResourceUsage : CM_ResourceTypeUsage;
	unsavedChanges : Boolean;
	row : Integer;
	obj : Object;
	sealTI : CM_SealTI;
	specialLifts : CM_SpecialLiftByCodeDict;
	sealValue : String;
	sealType : CM_SealType;
	transaction : CM_TITransaction;
	edition : Integer;
	pxyTISet : CM_TISet;
	result : Integer;
	realTI : CM_TrackedItem;
	newTrans : CM_TITransaction;					// PAR #36231

begin
	self.checkForUnsavedTransientChgs( unsavedChanges );
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;
	
	doResources := false;
	if self.frm_Resources.visible then
		foreach proxyResourceUsage in self.allProxyResourceTypeUsages do
			realResourceUsage := proxyResourceUsage.pxyGetRealObject;
			if realResourceUsage = null then
				// should never happen as these were all created from real ones.
				continue;
			endif;
			if realResourceUsage.differsFrom(proxyResourceUsage) then
				//something has changed on this one.  Put him in the updated collection.
				self.allUpdProxyResourceTypeUsages.add(proxyResourceUsage);
				self.allProxyResourceTypeUsages.remove(proxyResourceUsage);
			endif;
		endforeach;
		doResources := true;
	
	elseif self.frm_Dimensions.visible then
		if self.myTrackedItem &lt;&gt; null then
			self.myTrackedItem.CM_Container.setOverDimensions(self.txt_Height.text.Decimal, self.txt_Front.text.Decimal, self.txt_Rear.text.Decimal, self.txt_Left.text.Decimal, self.txt_Right.text.Decimal, null, null);
		endif;
		
	elseif self.frm_Seals.visible then
		if self.myTrackedItem &lt;&gt; null then
			row := 1;
			while row &lt; self.tbl_Seals.rows do
				row := row +1;
				obj := self.tbl_Seals.accessRow(row).itemObject;
				if obj = null then
					continue;
				endif;
				
				sealValue := self.tbl_Seals.accessCell(row,2).text;
				
				if obj.isKindOf(CM_SealTI) then
					sealTI := obj.CM_SealTI;
					
					if not sealTI.matchesValueFromUser(sealValue) then
						sealTI.setProxy(	sealValue.trimBlanks[1:62],		// _sealNum : String;
											null,							// _sealNumArray : StringArray;
											sealTI.getSealValueAsString(),	// _prevSeal : String;
											sealTI.sealType,				// _sealType : String;
											app.actualTimeServer(),			// _sealedDT : TimeStamp;
											sealTI.myTrackedItem	);		// _myTrackedItem : CM_TrackedItem
					endif;
					
				elseif obj.isKindOf(CM_SealType) then
					sealType := obj.CM_SealType;
					self.myTrackedItem.setSealNumberValueDirect(sealType, sealValue, null);					
				else
					//?
				endif;
			endwhile;
		endif;
		
	elseif self.frm_SpecialLift.visible then
		if self.myTrackedItem &lt;&gt; null then
			create specialLifts transient;
			
			foreach row in 1 to self.lst_SpecialLift.listCount do
				if self.lst_SpecialLift.itemSelected[row] then
					specialLifts.add(self.lst_SpecialLift.itemObject[row].CM_SpecialLift);
				endif;
			endforeach;
			self.myTrackedItem.zSetPxySpecialLifts(specialLifts);
		endif;
			
	elseif self.frm_Weight.visible then
		if self.myTrackedItem &lt;&gt; null then
			self.myTrackedItem.setTotalWeightAndCertified(self.txt_Weight.text.Decimal, self.myTrackedItem.weightCargo, self.myTrackedItem.weightTare, self.chk_Certified.value, null, app.myPassport);
		endif;
		
	endif;
	
	// Do the updates - PAR #36231 don't update the real TI just yet, as it's still an MT and invoicing won't be correct
	// So update the proxy, and pass the proxy back to the calling form. 
	// Pass any proxy resources back to the calling form as well.
	self.myToDoTask.setTaskComplete(app.myPassport, false, newTrans);								// PAR #36231
	self.myCallingForm.setMyTrackedItem(self.myTrackedItem);										// PAR #36231
	self.myCallingForm.clearToDoResources();														// PAR #36231
	self.allNewProxyResourceTypeUsages.copy(self.myCallingForm.allNewProxyResourceTypeUsages);		// PAR #36231
	self.allProxyResourceTypeUsages.copy(self.myCallingForm.allProxyResourceTypeUsages);			// PAR #36231
	self.allRealResourceTypeUsagesToDel.copy(self.myCallingForm.allRealResourceTypeUsagesToDel);	// PAR #36231
	self.allUpdProxyResourceTypeUsages.copy(self.myCallingForm.allUpdProxyResourceTypeUsages);		// PAR #36231
	if self.myCallingForm.tasksToAdd.includes(self.myToDoTask.toDoTaskDescCode) then				// PAR #36231
		self.myCallingForm.tasksToAdd.remove(self.myToDoTask.toDoTaskDescCode);						// PAR #36231
	endif;																							// PAR #36231
	self.myCallingForm.tablePopulate();																// PAR #36231
	
	/* PAR #36231
	create pxyTISet transient;
	pxyTISet.add(self.myTrackedItem);
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(self.myToDoTask.toDoTaskDesc, pxyTISet, self.allProxyResourceTypeUsages, app.myPassport);
		if app.myPassport.trxCompletedOK then
			if app.myPassport.myUser.getAcknowledgeTodoStop() then
				app.msgBox(app.getErrorString2(Completed_for, self.myToDoTask.toDoTaskDesc.description, pxyTISet.size.String), app.getString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		realTI := self.myTrackedItem.pxyGetRealObject().CM_TrackedItem;
		delete self.myTrackedItem;
		self.myTrackedItem := app.createUpdateProxy(realTI).CM_TrackedItem;
		self.myCallingForm.setMyTrackedItem(self.myTrackedItem);
		self.myCallingForm.tablePopulate();
		self.modalResult := IDOK;
		self.unloadForm();
	endif; PAR #36231 */
	self.modalResult := IDOK;
	self.unloadForm();

epilog
	delete specialLifts;
	delete pxyTISet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdate" id="765f838a-9780-4bf1-80be-07d8f688e4d8">
        <updating/>
        <source>doBtnUpdate() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 08 Mar 2019 cnwma1	Ticket 43624: ADP - TO Resource Quantity gets truncated.
//
vars
	proxyUsage		: CM_ResourceTypeUsage;
	realUsage 		: CM_ResourceTypeUsage;
	resourceType	: CM_ResourceType;
	noCharge 		: Boolean;
	quantity 		: Decimal [23,4];
	remarks 		: String;
	status 			: Integer;
	lFromDateTime,
	lToDateTime		: TimeStamp;
	
begin
	// populate local variables with the data.
	resourceType := self.cmb_ResourceType.listObject.CM_ResourceType;
	quantity := txt_Units.text.asDecimalJMT();
	noCharge := self.chk_NoCharge.value;
	remarks := self.txt_Remarks.text;
	if not self.chk_Void.value then
		status := CM_InvoiceLine.STATUS_NORMAL;
	else
		status := CM_InvoiceLine.STATUS_VOIDED;
	endif;
	
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	//lFromDateTime.setDate(self.txtFromDate.text.asDateJMT);
	//lFromDateTime.setTime(self.txtFromDate.text.asTimeJMT);
	//lToDateTime.setDate(self.txtToDate.text.asDateJMT);
	//lToDateTime.setTime(self.txtToDate.text.asTimeJMT);
	lFromDateTime := app.actualTimeServer();	// 8/6/16 cnwmp6 TFS 488 - Multi timezone support
	lToDateTime := lFromDateTime;
	
	if resourceType = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A) &amp;  " " &amp; app.getErrorString(Resource_usage), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.cmb_ResourceType.setFocus();
		return;
	endif;

	// if no current proxy to update, create new proxy.
	if self.myCurrentProxyUsage = null then
		create proxyUsage transient;
		self.allNewProxyResourceTypeUsages.add(proxyUsage);
	else
		proxyUsage := self.myCurrentProxyUsage;
	endif;
	
	//update / populate the proxy
	proxyUsage.setProxy(	resourceType,		//_resourceType : CM_ResourceType;
							null,				//_transaction : CM_Transaction;
							noCharge,			//_noCharge : Boolean;
							quantity,			//_quantity : Decimal;
							remarks,			//_remarks : String;
							status,				//_status : Integer
							lFromDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
							lToDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
							null,
							null,
							null
							);
	
	if self.myCurrentProxyUsage &lt;&gt; null then
		realUsage := self.myCurrentProxyUsage.pxyGetRealObject().CM_ResourceTypeUsage;
		if realUsage &lt;&gt; null then
			if not realUsage.allInvoiceLines.isEmpty then
				app.msgBox( app.getErrorString(Changing_Invoiced_Resource), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				warningIssued := true;
			endif;
		endif;
	endif;
	
	//refresh the form
	self.clearGrpResource();
	self.loadTableData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblResourcesClick" id="5deccfdb-b00e-4756-ad3c-cb525cddc1c2">
        <updating/>
        <source>doTblResourcesClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35892 CCMS PNL 2461
//
vars
	proxyUsage : CM_ResourceTypeUsage;
	decPlaces : Integer;
	realUsage : CM_ResourceTypeUsage;
	unsavedChanges : Boolean;

begin
	self.checkForUnsavedTransientChgs(unsavedChanges);
	if unsavedChanges then
		if app.msgBox(app.getErrorString(NonUpdated_Change_Exist3), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;	
	endif;

	self.clearGrpResource();

	if self.tbl_Resources.row &gt; self.tbl_Resources.fixedRows and self.tbl_Resources.row &lt;= self.tbl_Resources.rows then
		proxyUsage := self.tbl_Resources.accessRow(self.tbl_Resources.row).itemObject.CM_ResourceTypeUsage;
	endif;
	
	if proxyUsage = null then
		return;
	endif;
	
	self.myCurrentProxyUsage := proxyUsage;
	self.frm_AddResource.enabled := true;
	
	self.cmb_ResourceType.listIndex := self.cmb_ResourceType.findObject( self.myCurrentProxyUsage.myResourceType );
	decPlaces := self.myCurrentProxyUsage.myResourceType.decimalPlaces;
	self.setLblUnitsCaption(decPlaces);
	self.txt_Units.text := self.myCurrentProxyUsage.quantity.asStringJMTWithPrecision(decPlaces,false);
	self.txt_Remarks.text := self.myCurrentProxyUsage.remarks;
	self.chk_NoCharge.value := self.myCurrentProxyUsage.noCharge;
	
	if self.myCurrentProxyUsage.getStatusString = app.getErrorString(Normal) then
		self.chk_Void.value := false;
	else
		self.chk_Void.value := true;
	endif;
	
	realUsage := proxyUsage.pxyGetRealObject();
	if realUsage &lt;&gt; null then
		// no longer allowed to delete persistant usages.
		self.btn_Delete.enabled := false;
		self.chk_Void.enabled := true;
	else
		self.btn_Delete.enabled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTableData" id="d53acccd-b798-4df9-9153-75304fab7b36">
        <updating/>
        <source>loadTableData() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	usage : CM_ResourceTypeUsage;
	
begin

	self.tbl_Resources.rows := self.tbl_Resources.fixedRows;

	foreach usage in self.allProxyResourceTypeUsages do
		self.addUsageToTblResources(usage);
	endforeach;
	
	foreach usage in self.allNewProxyResourceTypeUsages do
		self.addUsageToTblResources(usage);
	endforeach;
	
	self.tbl_Resources.row := self.tbl_Resources.fixedRows;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lst_SpecialLift_displayRow" id="5332ce4f-11cd-45d8-b4de-a93083bba095">
        <controlMethod name="ListBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lst_SpecialLift_displayRow(listbox: ListBox input; obj: Object; lstIndex: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars

begin
	return obj.CM_SpecialLift.description;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="lstIndex" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="purgeProxies" id="835548f9-6a4a-4bbb-8d6d-e69fb12dc298">
        <updating/>
        <source>purgeProxies() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/0/32015	cnwdap1		Initial creation PAR #35895 CCMS PNL2461
//
vars

begin
	if not self.allNewProxyResourceTypeUsages.isEmpty then
		self.allNewProxyResourceTypeUsages.purge;
	endif;
	if not self.allProxyResourceTypeUsages.isEmpty then
		self.allProxyResourceTypeUsages.purge;
	endif;
	if not self.allUpdProxyResourceTypeUsages.isEmpty then
		self.allUpdProxyResourceTypeUsages.purge;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLblUnitsCaption" id="0d5eaa66-5863-40d0-b6fb-b8fe6b5c802e">
        <source>setLblUnitsCaption(_decimals : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 06/04/2020	jlgdap1		TFS 48977 STWO Unable to add enough digits for to do task resource
//
vars
	type : CM_ResourceType;

begin
	if self.cmb_ResourceType.listIndex &gt; 0 then
		type := self.cmb_ResourceType.itemObject[self.cmb_ResourceType.listIndex].CM_ResourceType;
	endif;
	
	// clear before setting length, so it can never be too long
	self.txt_Units.decimals		:= 0;
	//self.txt_Units.maxLength 	:= _decimals + 5;		// TFS 48977
	self.txt_Units.maxLength 	:= _decimals + 9;		// TFS 48977
	if _decimals = null then							// TFS 48977
		self.txt_Units.maxLength := _decimals + 8;		// TFS 48977
	endif;												// TFS 48977
	self.txt_Units.decimals 	:= _decimals;
	
	if type &lt;&gt; null then
		self.lbl_Units.caption := type.unitDescription &amp; ":";
	else
		self.lbl_Units.caption := app.getErrorString(Units) &amp; ":";
	endif;

epilog

end;</source>
        <Parameter name="_decimals" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setModeAndDisplay" id="dba4d628-4a67-4f33-8bd5-a30fc59b4849">
        <updating/>
        <source>setModeAndDisplay(_toDoTask : CM_ToDoTask; _ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #32895 CCMS PNL 2461
//
vars

begin
	self.myTrackedItem := _ti;
	self.myToDoTask := _toDoTask;
	if self.myToDoTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then
		self.mode := self.Mode_LiftCheck;
	elseif self.myToDoTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then
		self.mode := self.Mode_WeightCheck;
	elseif self.myToDoTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DIMENSION then
		self.mode := self.Mode_DimensionsCheck;
	elseif self.myToDoTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SEALS then
		self.mode := self.Mode_SealCheck;
	elseif self.myToDoTask.toDoTaskDesc.allResourceTypes.size &gt; 0 then
		self.mode := self.Mode_ResourcesCheck;
	else
		return;
	endif;
	
	self.frm_Weight.visible 		:= false;
	self.frm_Dimensions.visible 	:= false;
	self.frm_Seals.visible 			:= false;
	self.frm_SpecialLift.visible 	:= false;
	self.frm_Resources.visible 		:= false;
	
	if self.mode = self.Mode_WeightCheck then
		self.frm_Weight.visible := true;
		self.txt_Weight.text := self.myTrackedItem.getTotalWeightDisplay();
		self.chk_Certified.value := self.myTrackedItem.isWeightCertified;
		
	elseif self.mode = self.Mode_DimensionsCheck then
		self.frm_Dimensions.visible := true;
		self.txt_Front.text := self.myTrackedItem.CM_Container.overLengthFront.asStringJMTWithPrecision(0, false);
		self.txt_Rear.text := self.myTrackedItem.CM_Container.overLengthRear.asStringJMTWithPrecision(0, false);
		self.txt_Left.text := self.myTrackedItem.CM_Container.overWidthLeft.asStringJMTWithPrecision(0, false);
		self.txt_Right.text := self.myTrackedItem.CM_Container.overWidthRight.asStringJMTWithPrecision(0, false);
		self.txt_Height.text := self.myTrackedItem.CM_Container.overHeight.asStringJMTWithPrecision(0, false);
		
	elseif self.mode = self.Mode_SealCheck then
		self.frm_Seals.visible := true;
		self.setupSealsTable();
		
	elseif self.mode = self.Mode_LiftCheck then
		self.frm_SpecialLift.visible := true;
		self.setupSpecialLifts();
		
	elseif self.mode = self.Mode_ResourcesCheck then
		self.frm_Resources.visible := true;
		self.setupResourceDetails();
		
	endif;
	
	self.lbl_Resources.caption := "Enter Details for " &amp; self.myToDoTask.toDoTaskDescDesc;
epilog

end;</source>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="28c21de5-b083-4445-bfe5-871071a96619">
        <updating/>
        <source>setupForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #32895 CCMS PNL 2461
// 03/06/2015	cnwdap1		PAR #36231 Populate table with "yet to be added" tasks
//
vars

begin
	inheritMethod();
	
	self.myTrackedItem := self.myMainObject.CM_TrackedItem;
	self.frm_AddResource.enabled := false;
	self.loadTableData;										// PAR #36231
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupResourceDetails" id="77a74750-cad0-4446-aed4-da932a802adb">
        <source>setupResourceDetails();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35892 CCMS PNL 2461
//
vars
	entTableDef		: EntTableDef;
	taskDesc		: CM_ToDoTaskDesc;
	cmObj 			: CM_Object;
	type 			: CM_ResourceType;
	index			: Integer;
		
begin
	self.tbl_Resources.columns := 6;
	self.tbl_Resources.userInputEnabled := false;
	self.tbl_Resources.selectMode := CM_Table.SelectMode_CurrentRow;
	
	self.tbl_Resources.addItemAt(app.getErrorString(Resources) &amp; Tab &amp; app.getErrorString(Qty) &amp; Tab &amp; app.getErrorString(Units) &amp; Tab &amp; app.getErrorString(NoCharge) &amp; Tab &amp; app.getErrorString(Remarks) &amp; Tab &amp; app.getErrorString(Status), 1);
	self.tbl_Resources.rows := 1;
	self.tbl_Resources.cnEcResizeContents();
	
	self.cmb_ResourceType.clear;
	if self.myToDoTask &lt;&gt; null then	
		taskDesc := self.myToDoTask.toDoTaskDesc;
		foreach cmObj in taskDesc.allResourceTypes do
			if cmObj.isKindOf(CM_ResourceType) then
				type := cmObj.CM_ResourceType;
				if not type.isAvailable then
					continue;
				endif;
				index := self.cmb_ResourceType.addItem( type.description );
				self.cmb_ResourceType.itemObject[index] := type;
				if not type.isAvailable then
					self.cmb_ResourceType.itemEnabled[index] := false;
				endif;
			endif;
		endforeach;
	else
		foreach type in app.myRoot.allTaskResourceTypes
			where type.type = TODO_TYPE_GROUP_TI or type.type = TODO_TYPE_GROUP_ALL do // ### TFS #56635[54261] 22NOV2022 NAVAB1
		
			if not type.isAvailable then
				continue;
			endif;
			index := self.cmb_ResourceType.addItem( type.description );
			self.cmb_ResourceType.itemObject[index] := type;
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupSealsTable" id="6a395e0a-c7c9-4941-ac56-b9e9dee69879">
        <source>setupSealsTable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	ti				: CM_TrackedItem;
	cargoType		: CM_CargoType;
	allSealTypes	: CM_SealTypeSet;
	sealType		: CM_SealType;
	index			: Integer;
	sealTi			: CM_SealTI;
	
begin
	self.tbl_Seals.clear();
	
	ti := self.myTrackedItem;
	cargoType := ti.myCargoType;
	
	create allSealTypes transient;
	foreach sealType in cargoType.allSealTypes do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		allSealTypes.add(sealType);
	endforeach;
	
	if allSealTypes.isEmpty then
		return;
	endif;
	
	self.tbl_Seals.selectMode := Table.SelectMode_None;
	self.tbl_Seals.columns := 2;
	self.tbl_Seals.rows := 1;
	
	self.tbl_Seals.fixedRows := 1;
	self.tbl_Seals.fixedColumns := 1;
	
	self.tbl_Seals.accessRow(1).alignment := Table.Alignment_Left_Middle;
	self.tbl_Seals.accessRow(1).fontBold := true;
	self.tbl_Seals.setCellText(1, 1, app.getErrorString(CM_Type));
	self.tbl_Seals.setCellText(1, 2, app.getErrorString(Value));
	
	foreach sealType in allSealTypes do
	
		index := self.tbl_Seals.addItem(sealType.description);
		sealTi := ti.getSealTI(sealType);
		
		if sealTi = null then
			self.tbl_Seals.accessRow(index).itemObject := sealType;
		else
			self.tbl_Seals.setCellText(index, 2, sealTi.getSealValueAsString);
			self.tbl_Seals.accessRow(index).itemObject := sealTi;
		endif;
		self.tbl_Seals.accessCell(index, 2).inputType := Table.InputType_TextBox;
		self.tbl_Seals.accessRow(index).height := 24;
		
	endforeach;

epilog
	delete allSealTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupSpecialLifts" id="f7a8a51b-8fd6-4d7e-9aa5-c85141a3254a">
        <updating/>
        <source>setupSpecialLifts() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26 March 2015	cnwdap1		Initial creation PAR #
//
vars
	lift 	: CM_SpecialLift;
	idx 	: Integer;

begin
	self.lst_SpecialLift.displayCollection(app.myRoot.allSpecialLifts, false, Table.DisplayCollection_Forward, null, null);
	self.lst_SpecialLift.clearAllSelected;
	
	if self.myTrackedItem &lt;&gt; null then
		foreach lift in self.myTrackedItem.allSpecialLifts discreteLock do
			foreach idx in 1 to self.lst_SpecialLift.listCount do
				if self.lst_SpecialLift.itemObject[idx] = lift then
					self.lst_SpecialLift.itemSelected[idx] := true;
				endif;
			endforeach;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
