        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <CompAttribute name="sealValues" id="564729ab-cb88-416f-ab10-4b74a9534599">
        <type name="HugeStringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="type" id="bce702ae-77e5-4858-a1a4-b104da36c12a">
        <length>11</length>
