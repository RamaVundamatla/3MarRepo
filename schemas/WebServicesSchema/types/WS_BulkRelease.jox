    <JadeMethod name="delete" id="b7d97052-47db-4cdf-86a6-7350cf9810db">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2014	cnwmc5	Initial creation

*/

vars

begin

	delete self.mySubTerminal;
	delete self.status;
	delete self.carrier;
	delete self.consignor;
	delete self.consignee;
	delete self.freightForwarder;
	delete self.dischargePort;
	delete self.operator;
	delete self.type;
	delete self.booking;		//cnwmc5 - 3 June 2016 - TFS 2039
	delete self.destinationTerminal;  //epr TFS 7521 10/11/17
	delete self.myLoadPort; //06/01/2026 navtr3 MTN-36695
	
	if self.allReserveDetails &lt;&gt; null and not self.allReserveDetails.isEmpty then
		self.allReserveDetails.purge();
	endif;
	
	self.allReservePackingChildren.purge; //epr TFS 7521 10/11/17
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="d9509610-7b80-4667-8207-620ec1cb3924">
        <source>getDataForDefSpecial(_attrName: String; bulkRelease : CM_BulkRelease) : String protected;
// ---------------------------------------------------------------------------
// Created:     11 Feb 2009 by cnwdz2
//
// Purpose:     if multiple reserve lines, list attributes for all reserves
// ---------------------------------------------------------------------------
vars
	aReserve 		: CM_ReserveDetail;
	tmpStr,
	tmpDisplay		: String;
	cnt				: Integer;
	
begin
	tmpStr := "";
	cnt    := 1;
	if bulkRelease.releaseByType and bulkRelease.allReserveDetails.size &gt; 1 then
		foreach aReserve in bulkRelease.allReserveDetails discreteLock do
			tmpDisplay := aReserve.getDisplayStringForAttribute( _attrName, true );
			if tmpDisplay &lt;&gt; null then
				tmpStr := tmpStr &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
			endif;
			cnt := cnt + 1;
		endforeach;
		tmpStr := tmpStr[1:tmpStr.length-2];
	else
		aReserve := bulkRelease.allReserveDetails.first;
		if aReserve &lt;&gt; null then
			tmpStr := aReserve.getDisplayStringForAttribute( _attrName, true );
		endif;
	endif;

	return tmpStr;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="bulkRelease" type="CM_BulkRelease"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyCollectionsFromObject" id="a20c5607-87a0-46c2-b0d8-a65e3566b624">
        <updating/>
        <source>setProxyCollectionsFromObject(_object: CM_BulkRelease; _excludeReserveTis : Boolean) updating;
/*

Purpose:			Populates proxy collections on WS_BulkRelease if required

Parameters:			_object				CM_BulkRelease	Used to populate this proxy from
					_excludeReserveTis	Boolean			Whether or not to exclude reserve tis in the proxy.
														Some places in the mobile apps do not need this info so its a waste to populate it

Return Value:		NONE

Date				Who		Reason
04 October 2023		navpw1	Initial creation TFS: 59830 (59831)
01 November 2023	navpw1	TFS: 61036 - Added a new parameter _excludeReserveTis to be the opposite of _includeReserveTis.
											This is because the changes broke the web portal soap calls.

*/

vars
	reserveDetail	: CM_ReserveDetail;
	wsReserveSel	: WS_ReserveSelection;
	wsReserveTI		: WS_ReserveTI;
	
begin
	self.setProxyFromObject(_object);
	
	foreach reserveDetail in _object.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			create wsReserveSel transient;
			wsReserveSel.setProxyFromObject(reserveDetail.CM_ReserveSelection);
			self.allReserveDetails.add(wsReserveSel);
		elseif reserveDetail.isKindOf(CM_ReserveTI) and not _excludeReserveTis then
			create wsReserveTI transient;
			wsReserveTI.setProxyFromObject(reserveDetail.CM_ReserveTI);
			self.allReserveDetails.add(wsReserveTI);
		endif;
	endforeach;
	
	foreach reserveDetail in _object.allReservePackingChildren do					// TFS 2703
		if reserveDetail.isKindOf(CM_ReserveSelection) then							// TFS 2703
			create wsReserveSel transient;											// TFS 2703
			wsReserveSel.setProxyFromObject(reserveDetail.CM_ReserveSelection);		// TFS 2703
			self.allReservePackingChildren.add(wsReserveSel);						// TFS 2703
		elseif reserveDetail.isKindOf(CM_ReserveTI) and not _excludeReserveTis then	// TFS 2703
			create wsReserveTI transient;											// TFS 2703
			wsReserveTI.setProxyFromObject(reserveDetail.CM_ReserveTI);				// TFS 2703
			self.allReservePackingChildren.add(wsReserveTI);						// TFS 2703
		endif;																		// TFS 2703
	endforeach;																		// TFS 2703
	
end;</source>
        <Parameter name="_object" type="CM_BulkRelease"/>
        <Parameter name="_excludeReserveTis" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="e1b68224-9ece-4b7f-9a7a-b365b1e38f47">
        <updating/>
        <source>setProxyFromObject(object: CM_BulkRelease) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03/10/2008	cnwkao1	Initial creation - written for display purposes only. JMT intend to implement updating at a later stage.
10/02/2009 	cnwdz2 	updated the implmentation according to RIA.doc specified by KD
30/09/2016	cnwdap1	STWR TFS 2703 Add packing children to response
11/05/2018  cnwma1	ChangeRequest 38519: PEL1 - WP Cargo Release
04/10/2023	navpw1	TFS: 59830 (59831) - Moved collection populating code to setProxyCollectionsFromObject and made it call this method
08/01/2026	navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/

vars
	idx 			: Integer;
	ti 				: CM_TrackedItem;
	subTerminal 	: CM_SubTerminal;
	tmpCarrier		: CM_Carrier;
	tmpConsignee,
 	tmpConsignor,
	tmpFreightFwder	: CM_ConsigneeConsignor;
	cargoType 		: CM_CargoType;
	msg 			: String;
	reserveDetail	: CM_ReserveDetail;
	wsReserveSel	: WS_ReserveSelection;
	wsReserveTI		: WS_ReserveTI;
	
	tmpDestTerminal	: CM_Terminal;		//cnwmc5 - 2 March 2015 - PAR 35777
	tmpBooking		: CM_BookingRef;	//cnwmc5 - 1 June 2016 - TFS 2039
begin
	inheritMethod(object);
	
	self.releaseNo			:= object.code;
	
	if object.myOperator &lt;&gt; null then
		create self.operator transient;
		self.operator.setProxyFromObject(object.myOperator);
	endif;
	
	if object.myPinNo &lt;&gt; null then
		self.myPinNo		:= object.myPinNo.pinNo;
	endif;
	
	//self.totalRequested		:= self.getDataForDefSpecial(ETRow_TotalRequested,object);		//cnwmc5 - 23 April 2014 - PAR 33988
	self.totalRequested		:= object.getTotalRequested.asStringJMT;							//cnwmc5 - 23 April 2014 - PAR 33988
	
	//self.deliveredToDate	:= object.releasedItemStrings.size;									//cnwmc5 - 23 April 2014 - PAR 33988
	self.deliveredToDate	:= object.getTotalReleased();										//cnwmc5 - 23 April 2014 - PAR 33988
	
	self.totalVolumeRequested	:= object.getTotalVolumeRequested().asStringJMT();				//cnwmc5 - 30 April 2014 - PAR 33988
	
	self.totalWeightRequested	:= object.getTotalWeightRequested().asStringJMT();				//cnwmc5 - 30 April 2014 - PAR 33988
	
	if object.type = BR_TYPE_PACKING then
		if self.deliveredToDate &gt; 0 then
			foreach idx in 1 to self.deliveredToDate do
				if object.releasedItemStrings.size &lt; self.deliveredToDate then
					break;
				endif;
				self.brItemsDelivered := self.brItemsDelivered &amp; object.releasedItemStrings[idx].removeTabCrLfs() &amp; " ";		
			endforeach;
		endif;				
	else
		if self.deliveredToDate &gt; 0 and (not object.allTrackedItemsReleased.isEmpty) then
			foreach ti in object.allTrackedItemsReleased do
				//self.brItemsDelivered := self.brItemsDelivered &amp; ti.id &amp; " was taken by " &amp; ti.releaseVehicle &amp; ' on ' &amp; ti.releasedDT.date.display &amp; ' at ' &amp; ti.releasedDT.time.currentLocaleFormatJMT() &amp; " ";
				//26 Oct 2012	NDL	Par 30622
				// this date conversion etc. is ok cos its a string being translated into the locale of the user. (Which is set up when the user initiates the session
				// based on the locale stored on the user in JMT.)
				msg := app.getErrorString4(TiWasTakenByOnAt, ti.id, ti.releaseVehicle, ti.releasedDT.date.asStringJMT, ti.releasedDT.time.asStringJMT);
				self.brItemsDelivered := self.brItemsDelivered &amp; msg &amp; " ";
			endforeach;	
		endif;		
	endif;
	
	self.cargoType := self.getDataForDefSpecial(ETRow_CargoType,object);
	
	self.isoType   := self.getDataForDefSpecial(ETRow_IsoType,object);
	
	tmpCarrier	:= object.getCarrier();
	if tmpCarrier &lt;&gt; null then
		create self.carrier transient;
		self.carrier.setProxyFromObject(tmpCarrier);
	endif;	
		
	tmpConsignee := object.getConsignee();
	if tmpConsignee &lt;&gt; null then
		create self.consignee transient;
		self.consignee.setProxyFromObject(tmpConsignee);
	endif;
		
	if object.dateRequested.isValid() then
	//	self.requestDate := object.dateRequested.date.String;
		self.requestDate := object.dateRequested.date.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
		self.requestTime := object.dateRequested.time.asStringForWebInterface();
	else
		self.requestDate := app.getErrorString(Unknown);
		self.requestTime := app.getErrorString(Unknown);
	endif;
	
	if object.myDischargePort &lt;&gt; null then
		create self.dischargePort transient;
		self.dischargePort.setProxyFromObject(object.myDischargePort);
	endif;
	
	
	self.remarks := object.cargoRemarks;			//cnwmc5 - 12 Nov 2014 - CCMS 2429
	
	subTerminal := object.mySubTerminal;
	if subTerminal &lt;&gt; null then //22/04/2009 cnwdz2 ccms1735
		create self.mySubTerminal transient;
		self.mySubTerminal.setProxyFromObject(subTerminal);
	endif;
	
	create self.status transient;
	self.status.description := app.releaseStatusEnumToString(object.status);
	self.status.id := object.status;
	
	self.fullRelease := object.fullRelease;
	
	self.bookingConfirmation := object.bookingConfirmation;
	
	tmpConsignor := object.myConsignor;
	if tmpConsignor &lt;&gt; null then
		create self.consignor transient;
		self.consignor.setProxyFromObject(tmpConsignor);
	endif;
	
	self.consignorVoyageCode := object.consignorVoyageCode;
	
	self.deliveryReleaseNumber := object.deliveryReleaseNumber;	
	self.deliveryReasonCode	:= object.deliveryReasonCode;		//navtr3 MTN-36695	
	self.transType := object.type;	
	
	if object.myLoadPort &lt;&gt; null then
		create self.myLoadPort transient;
		self.myLoadPort.setProxyFromObject(object.myLoadPort);
	endif;			//navtr3 MTN-36695
	
	
	if object.getEstimatedRequiredDate() &lt;&gt; null then
		self.estimatedRequiredDate := object.getEstimatedRequiredDate().asStringJMT();
	endif;
	
	tmpFreightFwder := app.myRoot.allConsigneeConsignors[object.freightForwarderCode];
	if tmpFreightFwder &lt;&gt; null then
		create self.freightForwarder transient;
		self.freightForwarder.setProxyFromObject(tmpFreightFwder);
	endif;
	
	self.freightPayerCode := object.freightPayerCode;
	
	self.releaseByType := object.releaseByType;
	
	create self.type transient;
	self.type.set(object.type, app.releaseRequestTypeEnumToString(object.type));
	
	if object.myVoyage &lt;&gt; null then
		self.voyageCode := object.myVoyage.code; 
		self.voyageCodeExternal := object.myVoyage.voyageCodeExternal; //11.05.2018 cnwma1 TFS #38519
		if object.myVoyage.getMyVessel &lt;&gt; null then					   //11.05.2018 cnwma1 TFS #38519
			self.vesselName := object.myVoyage.getMyVessel.name;
		endif;
	endif;	
	
	/*foreach reserveDetail in object.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			create wsReserveSel transient;
			wsReserveSel.setProxyFromObject(reserveDetail.CM_ReserveSelection);
			self.allReserveDetails.add(wsReserveSel);
		elseif reserveDetail.isKindOf(CM_ReserveTI) then
			create wsReserveTI transient;
			wsReserveTI.setProxyFromObject(reserveDetail.CM_ReserveTI);
			self.allReserveDetails.add(wsReserveTI);
		endif;
	endforeach;
	
	foreach reserveDetail in object.allReservePackingChildren do					// TFS 2703
		if reserveDetail.isKindOf(CM_ReserveSelection) then							// TFS 2703
			create wsReserveSel transient;											// TFS 2703
			wsReserveSel.setProxyFromObject(reserveDetail.CM_ReserveSelection);		// TFS 2703
			self.allReservePackingChildren.add(wsReserveSel);						// TFS 2703
		elseif reserveDetail.isKindOf(CM_ReserveTI) then							// TFS 2703
			create wsReserveTI transient;											// TFS 2703
			wsReserveTI.setProxyFromObject(reserveDetail.CM_ReserveTI);				// TFS 2703
			self.allReservePackingChildren.add(wsReserveTI);						// TFS 2703
		endif;																		// TFS 2703
	endforeach;*/																	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	
	//cnwmc5 - 2 March 2015 - PAR 35777
	tmpDestTerminal := object.myTransferToTerminal;
	if tmpDestTerminal &lt;&gt; null then
		create self.destinationTerminal transient;
		self.destinationTerminal.setProxyFromObject(tmpDestTerminal);
	endif;
	
	//cnwmc5 - 1 June 2016 - TFS 2039
	tmpBooking := object.myBookingRefStock;
	if tmpBooking &lt;&gt; null then
		self.noFullsIn := tmpBooking.noFullIsAllowedIn; 		//navtr3 MTN-36695
		create self.booking transient;
		self.booking.setProxyFromObject(tmpBooking);
	endif;	
	
epilog

end;</source>
        <Parameter name="object" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
