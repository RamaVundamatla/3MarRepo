    <JadeMethod name="loadCargoGrpRows" id="0231cd2b-dba6-45fe-9764-386162f812b4">
        <source>loadCargoGrpRows(_table :CM_DataTable input ; _tiArr :CM_TIArray) ;
/*
 
Purpose: adds the cargoGroup row to the table
 
Parameters:	 		
 
Return Value:		
 
Date		Who		Reason
25 Nov 2024 navbs1 Bug MTN-33186: MTN - Performance of Data retrieval in work order operations screen has been affected by cargo grouping
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys
07 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
*/
 
vars
	ti 				: CM_TrackedItem;
	cgGrpDtl 		: CM_CargoGroupDetail;
	result 			: String;
	rowId,colId		: Integer;
	iter 			: Iterator;
	keyTableName 	: String;
	keyCargoGrp		: CM_CargoGroup;
	startRow,endRow,
	row 			: Integer;
	tableRow		: JadeTableRow;
	
begin

	if _table.isPaginated then		// MTN 35316
		// this functionality doesn't work well with paginated table so
		// disable pagination so table works normally
		_table.clearPagination;		// MTN 35316
	endif;
	
	_table.rows := _table.fixedRows;	// MTN 35316
	
	//populate CargoGroupDetails dict 
	foreach ti in _tiArr do 
	 self.populateCargoGrpDtlsDict(_table,ti); //creates cache
	endforeach;
	
	iter := self.allCargoGroupDetails.createIterator;

	self.allCargoGroupDetails.startKeyGeq(_table.name,null,iter);
	
	 while iter.next(cgGrpDtl) do 
		 iter.getCurrentKeys(keyTableName,keyCargoGrp);  //MTN-35226
		 if  keyTableName &lt;&gt; _table.name then 
			break;
		 endif;
		if cgGrpDtl.myCargoGroup = null then
			rowId :=_table.addItem( J_key_Plus.Character);
			if _table.getColumnByRowName(ETRow_Id) &lt;&gt; null then
				colId := _table.getColumnByRowName(ETRow_Id);
				_table.accessCell(rowId, colId).text := app.getErrorString(Unknown);
			endif;
			if _table.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
				colId := _table.getColumnByRowName(ETRow_CargoType);
				_table.accessCell(rowId, colId).text := app.getErrorString(Unknown_cargo_group);
			endif;
			_table.accessRow(rowId).itemObject := null;	
		else
			startRow:= _table.fixedRows+1;
			endRow := _table.rows;
			foreach row in startRow to endRow  do
				tableRow := _table.accessRow(row);
				ti := tableRow.itemObject.CM_TrackedItem;
				if ti = null then 
					//if reached till "Unknown Cargo Group" 
					break;
				endif;

				// the cargo groups ID is 'after' ours, then bail
				if ti.id &gt; cgGrpDtl.myCargoGroup.id then
					break;
				endif;
			endforeach;
			result := cgGrpDtl.getAttributeStringForDefArray(_table.allTblDataEntRows);
			_table.addItemObjectAt(cgGrpDtl.myCargoGroup, J_key_Plus.Character &amp; " " &amp; result,row);
		endif;
		_table.accessedRow.backColor := LightYellow;
		
	 endwhile;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_tiArr" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="loadShtJob" id="9ea12746-1e25-4ae6-826d-77e14c637207">
        <updating/>
        <source>loadShtJob()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.buildCmbTerminalArea();
	
	self.loadTableItems(self.tblAvailCargo);	
	if self.isCargoGrouping and self.tblAvailCargo.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setRowNumberAsFirst(self.tblAvailCargo);
		self.saveXMLStrForTblColumns(self.tblAvailCargo);
	endif;	
	self.loadTblAvail();
	
	self.loadTableItems(self.tblCompletedCargo);
	if self.isCargoGrouping and self.tblCompletedCargo.allTblDataColPropertyNames[1] &lt;&gt; ETRow_RowNumber then
		self.setRowNumberAsFirst(self.tblCompletedCargo);
		self.saveXMLStrForTblColumns(self.tblCompletedCargo);
	endif;
	if not self.chkHideCompleted.value then
		self.loadTblCompleted();
	endif;
	
	self.setTblDataCount();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadShtUnpack" id="e01cb99a-73ca-4c01-995b-c86f1b458691">
        <updating/>
        <source>loadShtUnpack(_relReq : CM_BulkRelease; _resDtl : CM_ReserveDetail)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job 		: CM_Job;
	wod 		: CM_WorkOrderDtl;
	lc			: CM_LocationsController;
	childResDtl	: CM_ReserveDetail;
begin
	job := self.myJob;
	wod := job.myWODtl;
	if wod &lt;&gt; null and wod.isWorkOrderForUnpack then
		lc := wod.CM_WodUnpack.myUnpackToLocation;
	endif;
	
	if lc &lt;&gt; null then
		self.txtUnpack.text 	:= lc.getFullId();
		self.txtUnpack.enabled 	:= false;
	endif;
	
	self.lblTransport.visible := false;
	self.txtTransport.visible := false;
	self.loadTableItems(self.tblParent);
	self.loadTableItems(self.tblChild);
	self.loadTblParent();
	self.grpParentCaption := self.grpAvailParent.caption;
	self.grpChildCaption := self.grpAvailChild.caption;
	
	if job.isWOUnpackJob then
		self.grpToLocation.visible := true;
		self.grpUnpacked.visible := true;
		self.loadTableItems(self.tblUnpacked);
		self.loadTblUnpacked();
		self.grpUnpackedCaption := self.grpUnpacked.caption;
		
	else
		self.grpPacked.visible 	:= true;
		self.btnOk.visible		:= true;
		self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
		
		if _relReq &lt;&gt; null and _relReq.releaseByType then
			childResDtl := _relReq.allReserveDetails.first;
		endif;
		
		if childResDtl &lt;&gt; null then
			self.lblParentResDtl.visible := true;
			self.txtParentResDtl.visible := true;
			self.txtParentResDtl.text 	:= childResDtl.getDescriptionShort();
		endif;
		
		self.lblReleaseReq.visible 	:= true;
		self.txtRelReq.visible 	:= true;
		
		if _resDtl &lt;&gt; null then
			self.lblResDtl.visible 	:= true;
			self.txtResDtl.visible 	:= true;
		endif;
		
		self.btnOk.caption		:= app.getErrorString(Pack_Complete);
		self.btnPack.visible	:= true;
		self.loadTableItems(self.tblPackParent);
		self.loadTableItems(self.tblPackChild);
		self.grpPackedCaption := self.grpPacked.caption;
		self.loadTblChild(null);
		self.loadTblPackedParent();
		self.loadTblPackedChild(null);
	endif;
	self.setTblDataCount();
epilog

end;</source>
        <Parameter name="_relReq" type="CM_BulkRelease"/>
        <Parameter name="_resDtl" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="loadTableItems" id="b14d7f68-ad47-4a48-8ce6-49e5d14e2c3e">
        <source>loadTableItems(_tbl : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
	xmlStr,
	theEntDef			: String;
begin
	theTable := _tbl;
	theTable.allSelectedObjects.clear;
	if self.isCargoGrouping then 		//22.07.2024 navbs1 #64884
		theEntDef := ETDef_LlHeadings;
	else
		theEntDef := ETDef_ContainerData;
	endif;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	
	entTableDef := app.myController.getEntTableDef(theEntDef);
	
	if theTable = self.tblAvailCargo then
		xmlStr := self.defAvailCargo;
	elseif theTable = self.tblCompletedCargo then
		xmlStr := self.defCompletedCargo;
	elseif theTable = self.tblParent then				//14.03.2024 navhl20 #62861
		xmlStr := self.defParent;
	elseif theTable = self.tblChild then				//14.03.2024 navhl20 #62861
		xmlStr := self.defChild;
	elseif theTable = self.tblUnpacked then				//14.03.2024 navhl20 #62861
		xmlStr := self.defUnpacked;
	endif;
	
	if xmlStr &lt;&gt; null then
		theTable.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.fixedRows := 1;
	theTable.rows := 1;
	self.setColorsForTable(theTable);


end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="loadTbToDoTIs" id="69efe4f1-66a2-4da5-b593-82c42e34d445">
        <source>loadTbToDoTIs();
/*
Purpose - 	
Who - NAVAB1
Date - 15MAR2024
ADO -  CR 62818 TASK 62821
13 November 2024	navbs1	Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs
*/

vars
	tiArr 		: CM_TIArray;
	ti			: CM_TrackedItem;
	tbl			: CM_DataTable;
	theDataLine	: String;
begin
	if not self.tblToDo.visible then 	//13.11.2024 navbs1 #33403
		return;
	endif;
	tiArr := self.getAvailableTis();
	tbl := self.tblToDo;
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	tbl.rows 		:= 1;
	
	foreach ti in tiArr do
		tbl.addObject(ti);
	endforeach;
epilog
	delete tiArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblAvail" id="8442a755-a9c9-471b-9f5b-738264caf3c7">
        <source>loadTblAvail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
24 Apr 2024 navlc30 ChangeRequest 63823: EUP | Performance Async Workers workorder operations
18 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
22 Jul 2024 navbs1  ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024 navma1	Bug 65379: MTN - 1090 in work order operations screen
25 Nov 2024 navbs1 Bug MTN-33186: MTN - Performance of Data retrieval in work order operations screen has been affected by cargo grouping
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
07 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
08 Sep 2025 navhl20 Bug MTN-35833: Issue with the Cargo Grouping mode on the Complete Job form
*/

vars
	tiArr 		: CM_TIArray;
	tbl			: CM_DataTable;

begin

	tbl   := self.tblAvailCargo;									//12.08.2024 navma1 #65379
	tiArr := self.getAvailableTis();
	
	tbl.setMyDataClass(CM_TrackedItem);
	
	if self.isBulkMode then											//02.04.2024 navma1 #63302
		tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;			//02.04.2024 navma1 #63302
	endif;

	if not self.myJob.isVoyageWorkpointJob then						//18.06.2024 navhl20 #64602
		tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;
	endif;
	
	if self.isCargoGrouping then 									//22.07.2024 navbs1 #64884
		self.loadCargoGrpRows(tbl,tiArr);
	else
		tbl.clearAllData();											//08.09.2025 navhl20 #35833
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiArr, true);	// MTN 35316
	endif;	
	
epilog
	delete tiArr;
	//navra1 - TFS 63751/Task 63752 - 8th May 2024 - start
	if  tbl.allTblDataObjDict &lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblChild" id="d824d51f-df6c-41ae-a015-a41f96ed95cb">
        <source>loadTblChild(_parent : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
18 Oct 2024 navhl20 Bug 23340: MTN - Performance issues and locks when completing the Retrospective Pack jobs
07 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
*/

vars
	tiSet 		: Collection;
	tbl			: CM_DataTable;

begin
	
	if self.myJob.isKindOf(CM_WOUnpackJob) then							//18.03.2024 navhl20 #62863
		if _parent &lt;&gt; null and _parent.allChildren.isNotEmpty() then
			tiSet := _parent.allChildren;
		endif;
		
		if tiSet = null then
			return;
		endif;
	else
		tiSet := self.getAvailPackTis(false);
	endif;
	
	tbl 			:= self.tblChild;
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;

	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiSet, true);	// MTN 35316
	
	self.setTblDataCount();

epilog
	if not self.myJob.isKindOf(CM_WOUnpackJob) then
		delete tiSet;
	endif;
end;</source>
        <Parameter name="_parent" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadTblCompleted" id="a8afaf98-9b36-4fd2-8273-860e3b852e42">
        <source>loadTblCompleted();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
24 Apr 2024 navlc30 ChangeRequest 63823: EUP | Performance Async Workers workorder operations
22 Jul 2024 navbs1  ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
25 Nov 2024 navbs1 Bug MTN-33186: MTN - Performance of Data retrieval in work order operations screen has been affected by cargo grouping
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
07 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
08 Sep 2025 navhl20 Bug MTN-35833: Issue with the Cargo Grouping mode on the Complete Job form
*/

vars
	tiSet 			: CM_TISet;
	tbl				: CM_DataTable;
	tiArr 			: CM_TIArray;
begin
	tiSet := self.getCompletedTis();
	tbl := self.tblCompletedCargo;
	tbl.setMyDataClass(CM_TrackedItem);
	
	if self.isCargoGrouping then  //22.07.2024 navbs1 #64884
		//25.11.2024 navbs1 #33186 START
		create tiArr transient;
		tiSet.copy(tiArr);
		self.loadCargoGrpRows(tbl, tiArr);
		//25.11.2024 navbs1 #33186 END
	else
		tbl.clearAllData();															//08.09.2025 navhl20 #35833
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiSet, true); // MTN 35316
	endif;
epilog
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - start
	if tbl.allTblDataObjDict &lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;

	delete tiSet;	
	delete tiArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblPackedChild" id="bbfa7b89-16a0-4316-a311-07e917877368">
        <source>loadTblPackedChild(_parent : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
07 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete

*/

vars
	tiSet 		: CM_TISet;
	ti			: CM_TrackedItem;
	tbl			: CM_DataTable;
	theDataLine	: String;

begin
	if _parent &lt;&gt; null and _parent.allChildren.isNotEmpty() then
		tiSet := _parent.allChildren;
	else
		tiSet := self.getCompletedTis();
	endif;
	
	if tiSet = null then
		return;
	endif;
	
	tbl := self.tblPackChild;
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiSet, true);	// MTN 35316
	
epilog	
	//navra1 - TFS 63751/Task 63752 - 8th May 2024 - start
	if tbl.allTblDataObjDict&lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;
end;</source>
        <Parameter name="_parent" type="CM_TrackedItem"/>
    </JadeMethod>
