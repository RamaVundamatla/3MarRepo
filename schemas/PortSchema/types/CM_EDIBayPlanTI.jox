    <JadeMethod name="isForLocal" id="adc51b32-3d7d-4252-9414-05d55a1ed51a">
        <source>isForLocal(_localPort :String): Boolean;
//----------------------------------------------------------------
//	Created:	01 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - pass in local port to save looking up config multiple times when in loop
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	config		: CM_EDIConfig;
	localPort	: String;
begin
	if _localPort &lt;&gt; null then								// par 29842 Sep 2012
		return self.dischargePort.trimBlanks = _localPort;	// par 29842 Sep 2012
	endif;													// par 29842 Sep 2012
	
	if self.myEDIData = null then
		return false;
	endif;
	
	config := self.myEDIData.ediConfig;
	
	if config = null then
		return false;
	endif;

	if config.myTerminal = null then
		return false;
	endif;

	localPort := config.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	
	return self.dischargePort.trimBlanks = localPort;

end;</source>
        <Parameter name="_localPort" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="length" id="1f868e24-f639-4474-876f-2ef9723c86c0">
        <methodInvocation>mapping</methodInvocation>
        <source>length(set : Boolean; _value : Decimal io) mapping;

vars
	olf, olr : Decimal[14,4];
begin
	if not set then
		if (overLengthFront &lt;&gt; null 
		or overLengthBack &lt;&gt; null)
		and (self.overLengthFront &lt;&gt; NULL_INTEGER 			//cnwmc5 - 28 Jan 2014 - PAR 33001
		or self.overLengthBack &lt;&gt; NULL_INTEGER) then		//cnwmc5 - 28 Jan 2014 - PAR 33001
			//cnwmc5 - 28 Jan 2014 - PAR 33001
			olf := self.overLengthFront;
			olr := self.overLengthFront;
			if olf = NULL_INTEGER then
				olf := 0;
			elseif olr = NULL_INTEGER then
				olr := 0;
			endif;
			_value	:= olf + olr;
		endif;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadPort" id="bf069488-f98e-42e1-8599-9cc47295d2fa">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myCargoType" id="1297827a-e40a-4219-8bff-ee0fa88359cf">
        <source>myCargoType(): CM_CargoType;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isoCode		: String;
	isoTypeObj	: CM_ISOType;	
begin
	isoCode := self.isoType.trimBlanks();
	
	if isoCode &lt;&gt; null then
		isoTypeObj := app.myRoot.allISOTypes[isoCode];
		if isoTypeObj &lt;&gt; null then
			return isoTypeObj.myCargoType;
		endif;
	endif;
	
	return inheritMethod();
	
end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f723d40e-94a7-4dae-89c6-5581a7061473">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxy	: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
