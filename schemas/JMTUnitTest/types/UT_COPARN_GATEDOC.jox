    <JadeMethod name="tCoparnSNOEDICuttoffs" id="49d21f96-7df5-46f4-b962-a368afd182b5">
        <source>tCoparnSNOEDICuttoffs();
//
//25 January 2018	jlgrs1	TFS 36425 Initial creation
//
// 09 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
constants
	USER_DEF_NAME : String = "SNO_COPARN";
	CUTOFF1 : String = 'EVERYTHING';
	VesselCode1 : String = "SNOVESSEL1";
	VesselCode2 : String = "SNOVESSEL2";
	Voyage_Code1 : String = "7901N";
	Voyage_Code2 : String = "7902N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo1 : String = "50689001";
	BookingNo2 : String = "50689002";
	Prenote1 : String = "TOLU1714691";
	Prenote2 : String = "TOLU1714692";
vars
	terminal : CM_Terminal;
	oper : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
	booking : CM_BookingRef;
	ia : IntegerArray;
	prenote : CM_TrackedItem;
	release : CM_BulkRelease;
	cutoff : CM_ReceivalCutoffTermDef;
	today : TimeStamp; 
	tomorrow : TimeStamp; 
	yesterday : TimeStamp;
begin
	self.setTerminalConfig(EdiUseOldCoparn, false);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.deleteVoyageCutoff(CUTOFF1);
	create ia transient;
	ia.add(EDIDataType_BookingMultiLine);
	ia.add(EDIDataType_ReleaseRequest);
	ia.add(EDIDataType_RequestMultiLine);
	ia.add (EDIDataType_Prenote);
	ia.add(EDIDataType_GateDocument);
	cutoff := self.addEDIVoyageCutoff(CUTOFF1, DefaultRelativeTo_Departure, ia, 2);
	terminal := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote2);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote2);
	self.assertIsDeleted(prenote);
	self.deleteBooking(BookingNo1);
	booking := self.getBooking(BookingNo1);
	self.assertIsDeleted(booking);
	self.deleteBooking(BookingNo2);
	booking := self.getBooking(BookingNo2);
	self.assertIsDeleted(booking);
	self.deleteReleaseRequest(BookingNo1);
	release := self.getReleaseRequest(BookingNo1);
	self.assertIsDeleted(release);
	self.deleteVessel(VesselCode1);
	vessel := self.getVessel(VesselCode1);
	self.assertIsDeleted(vessel);
	self.deleteVessel(VesselCode2);
	vessel := self.getVessel(VesselCode2);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code1);
	voyage := self.getVoyage(Voyage_Code1);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code1, VesselCode1, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.deleteVoyage(Voyage_Code2);
	voyage := self.getVoyage(Voyage_Code2);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code2, VesselCode2, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	tomorrow := today.addDays(1);
	yesterday := today.addDays(-1);
	beginTransaction;
	voyage.setPropertyValue(CM_Voyage::arrivedDT.name, yesterday);
	voyage.setPropertyValue(CM_Voyage::departedDT.name, tomorrow);
	voyage.setPropertyValue(CM_Voyage::shipExchangeDate.name, yesterday);
	commitTransaction;
	self.updateEDIVoyageCutoff(CUTOFF1, DefaultRelativeTo_ShipExchange, ia, 2);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "HAPAG", oper);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy (CM_EDIEDIFactRule.Item_RFF_1_1, '-', CM_EDIEDIFactRule.Function_RFF_1_1_RelNo);	

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;
	
	// load booking
	coparnInput := self.zCoparnFileEDICuttoffs("11", Prenote1, Prenote2);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, errorMsg);
	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 8);
	
	booking := self.getBooking(BookingNo1);
	self.assertNotNull(booking);

	booking := self.getBooking(BookingNo2);
	self.assertNull(booking);

	self.deleteBooking(BookingNo1);
	booking := self.getBooking(BookingNo1);
	self.assertIsDeleted(booking);

	self.deleteBooking(BookingNo2);
	booking := self.getBooking(BookingNo2);
	self.assertIsDeleted(booking);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		prenote := self.getTrackedItem(Prenote1);
		self.assertNotNull(prenote);
		prenote := self.getTrackedItem(Prenote2);
		self.assertNull(prenote);
	else
		prenote := self.getTrackedItem(Prenote1);
		self.assertNull(prenote);
		prenote := self.getTrackedItem(Prenote2);
		self.assertNull(prenote);
	endif;
	
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote2);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote2);
	self.assertIsDeleted(prenote);

	// load release request
	coparnInput := self.zCoparnFileEDICuttoffs("12", null, null);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, errorMsg);
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	else
		self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	endif;

	prenote := self.getTrackedItem(Prenote1);
	self.assertNull(prenote);
	prenote := self.getTrackedItem(Prenote2);
	self.assertNull(prenote);
	
	release := self.getReleaseRequest(BookingNo1);
	self.assertNotNull(release);
	
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote2);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote2);
	self.assertIsDeleted(prenote);

// load prenote
	coparnInput := self.zCoparnFileEDICuttoffs("27", Prenote1, Prenote2);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"3"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	else
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	endif;
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, errorMsg);
	else
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	endif;
	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);

	if  ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo1);
	endif;
epilog
	self.deleteVoyageCutoff(CUTOFF1);
	delete ia;
end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparnSNOHLL" id="e80f6921-45ce-452d-b111-82cbfce7c24e">
        <source>tCoparnSNOHLL();
//
//14 December 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "50689004";
	Prenote1 : String = "TOLU1714690";
vars
	terminal : CM_Terminal;
	oper : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	release : CM_BulkRelease;
begin
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	terminal := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteBooking(BookingNo);
	booking := self.getBooking(BookingNo);
	self.assertIsDeleted(booking);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "HAPAG", oper);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy (CM_EDIEDIFactRule.Item_RFF_1_1, '-', CM_EDIEDIFactRule.Function_RFF_1_1_RelNo);	

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFileHLL("11", Prenote1);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);

	self.deleteBooking(BookingNo);
	booking := self.getBooking(BookingNo);
	self.assertIsDeleted(booking);
	coparnInput := self.zCoparnFileHLL("12", null);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	release := self.getReleaseRequest(BookingNo);
	self.assertNotNull(release);
	
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	coparnInput := self.zCoparnFileHLL("27", Prenote1);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"3"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.voyageCode, Voyage_Code);
	self.assertEqual(prenote.vesselCode, VesselCode);
//	booking := self.getBooking(BookingNo);
//	self.assertNotNull(booking);
epilog

end;</source>
