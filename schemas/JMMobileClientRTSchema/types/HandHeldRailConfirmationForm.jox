        <updating/>
        <source>doGetWagonDetailsOut(_wagonId : String) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	//errorMsg			: MobileHandHeldThin::DTO_HandHeldGateError;
	dtoContainer		: MobileHandHeldThin::DTO_ContainerInfo;
	inJob				: Boolean;
	infoStr,
	posStr				: String;
	
begin
	self.lblJobInfoOut.caption := 'Waiting for wagon ID match...';
	
	self.myDTOWagonOut.wagonID 		:= self.txtWagonOut.text.trimBlanks.toUpper;
	self.myDTOWagonOut.myTrain		:= self.cmbTrainOut.listObject.MobileHandHeldThin::CM_Train; // PAR 19710
	
	
	app.myHandHeldRailGuiAgent.doGetWagonDetailsOut(self.myDTOWagonOut,
												infoStr);
	
	self.lblJobInfoOut.caption := infoStr;
	self.spawnEntryButtons(self.myDTOWagonOut.allDTOWagonPositions, self.btnCloneOut, self.maxCloneButtonsOut);
	
	
epilog
	
end;


</source>
