    <JadeMethod name="showThumbnailData" id="4292863d-5a13-4b10-a279-437107d15c4a">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	
	if obj = null then
		return;
	endif;

	if app.myCurrentUserCan(self.myTerminal,PmGteDutyDocManager) then
		self.btnDeleteTV.enabled := true;
	else 
		self.btnDeleteTV.enabled:=false;
		if app.myCurrentUserCan(self.myTerminal,PmGteDutyDocSupervisor) or 
			app.myCurrentUserCan(self.myTerminal,PmGteDutyDocInCharge) then
			
			self.btnDeleteTV.enabled := obj.CM_DutyDoc.status = DutyDoc_Pending or
					obj.CM_DutyDoc.status = DutyDoc_Validated; 
		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="50b14866-c7d2-43a2-b573-66ffe53c538f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018633, locale);
end;</source>
    </JadeMethod>
