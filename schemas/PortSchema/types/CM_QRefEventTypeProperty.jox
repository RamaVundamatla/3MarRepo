    </JadeMethod>
    <JadeMethod name="getListBoxPropertyName" id="68581f0d-23a7-45b8-8525-353f12a8cab3">
        <source>getListBoxPropertyName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

begin
	if self.propertyName = "myEventType" then
		return CM_EventType::name.name;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
