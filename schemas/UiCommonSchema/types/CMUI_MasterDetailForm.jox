    <JadeMethod name="translateForm" id="80b7b405-8eaf-4d75-8b3f-e5bef5d26cc7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007796, locale);
	btnAddDetail.translateBubbleHelp(Xlat_0000544, locale);
	btnAddDetail.translateCaption(Xlat_0000545, locale);
	btnAddShow.translateCaption(Xlat_0000547, locale);
	btnDelete.translateCaption(Xlat_0000548, locale);
	btnEdit.translateCaption(Xlat_0000549, locale);
	btnHideDetailEnt.translateBubbleHelp(Xlat_0000537, locale);
	btnHideDetailEnt.translateCaption(Xlat_0000538, locale);
	btnHideSearcher.translateCaption(Xlat_0000540, locale);
	btnNew.translateCaption(Xlat_0000550, locale);
	btnRemoveDtl.translateCaption(Xlat_0000546, locale);
	btnRemoveDtl2.translateBubbleHelp(Xlat_0000552, locale);
	btnRemoveDtl2.translateCaption(Xlat_0000553, locale);
	btnResetSearch.translateCaption(Xlat_0000543, locale);
	btnSearch.translateCaption(Xlat_0000551, locale);
	btnShowSearcher.translateCaption(Xlat_0000541, locale);
	btnUpdateDetail.translateBubbleHelp(Xlat_0000539, locale);
	btnUpdateDetail.translateCaption(Xlat_0000542, locale);
	btnUpdateShow.translateCaption(Xlat_0000554, locale);
	mnuDetailContext.translateCaption(Xlat_0007797, locale);
	mnuDetailEdit.translateCaption(Xlat_0007798, locale);
	mnuDetailEnquire.translateCaption(Xlat_0007799, locale);
	mnuDetailInspect.translateCaption(Xlat_0007800, locale);
	mnuDetailNew.translateCaption(Xlat_0007801, locale);
	mnuDetailOrganiser.translateCaption(Xlat_0007802, locale);
	mnuDetailRemove.translateCaption(Xlat_0007803, locale);
	mnuMastContext.translateCaption(Xlat_0007804, locale);
	mnuMastEdit.translateCaption(Xlat_0007805, locale);
	mnuMastEnquire.translateCaption(Xlat_0007806, locale);
	mnuMastInspect.translateCaption(Xlat_0007807, locale);
	mnuMastNew.translateCaption(Xlat_0007808, locale);
	mnuMastOrganiser.translateCaption(Xlat_0007809, locale);
	mnuMastRemove.translateCaption(Xlat_0007810, locale);
	mnuStockOrderNew.translateCaption(Xlat_0007811, locale);
end;</source>
    </JadeMethod>
