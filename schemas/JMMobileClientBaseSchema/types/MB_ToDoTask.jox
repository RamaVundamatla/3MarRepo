<Class name="MB_ToDoTask" id="fd078879-1c5e-478b-9f05-d15b3288c98e">
    <superclass name="MB_Transient"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="mbTransient"/>
    <PrimAttribute name="code" id="ca2bb3d0-8c5f-44e6-8197-9619baaa864c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="completedTs" id="b2441bc3-27e1-46fc-94ea-2246f9a62dfc">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="description" id="3b040155-483f-407c-9753-6942d1a7f86f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="newState" id="407ad3af-2fe6-4ff8-b30e-46115430ade2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="state" id="2d3eb2d8-c533-478f-8609-45562b390002">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="txnType" id="a2ac846b-9005-43a7-aaa7-0c5b8e97c951">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setNewState" id="310bbdf8-c51d-4f4d-91f6-2c8ae8481b6e">
        <updating/>
        <source>setNewState(_state:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the new state of the receiver in the context of the table
//				control in which it is being held and manipulated.
//
// Parameters:	_state - The current state of the receiver, within the table.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _state = DTO_ToDoTask.Add
	or _state = DTO_ToDoTask.Complete
	or _state = DTO_ToDoTask.Remove
	or _state = DTO_ToDoTask.Selected
	or _state = DTO_ToDoTask.UnSelected
	then
		self.newState	:=	_state;
	else
		self.mbRaiseException("'" &amp; _state.String &amp; "' is not a valid To-Do Task state.");
	endif;
end;</source>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setState" id="e4d26406-429a-4d22-873d-b7a12e53da91">
        <updating/>
        <source>setState(_state:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the current state of the receiver in the context of the table
//				control in which it is being held and manipulated.
//
// Parameters:	_state - The current state of the receiver, within the table.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _state = DTO_ToDoTask.Add
	or _state = DTO_ToDoTask.Complete
	or _state = DTO_ToDoTask.Remove
	or _state = DTO_ToDoTask.Selected
	or _state = DTO_ToDoTask.UnSelected
	then
		self.state		:=	_state;
		self.newState	:=	_state;
	else
		self.mbRaiseException("'" &amp; _state.String &amp; "' is not a valid To-Do Task state.");
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateFromPackage" id="70f6bb85-977d-47c3-ba5d-d89a16b9d83f">
        <updating/>
        <source>translateFromPackage(_todoTask:DTO_ToDoTask) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from a task object received via the
//				DTO package.
//
// Parameters:	_todoTask - A reference to the package task object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	
	self.updateMe(_todoTask.code, _todoTask.completedTs, _todoTask.description, _todoTask.state, _todoTask.txnType);
end;</source>
        <Parameter name="_todoTask" type="MobileServerRTThin::DTO_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="translateFromWebServices" id="118e3a9a-fd60-41b0-9c37-9c876244651b">
        <updating/>
        <source>translateFromWebServices(_todoTask:WebSrv_DTO_ToDoTask) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from a task object received via a
//				Web Services SOAP message.
//
// Parameters:	_todoTask - A reference to the SOAP task object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.updateMe(_todoTask.code, _todoTask.completedTs, _todoTask.description, _todoTask.state, 0 );
end;</source>
        <Parameter name="_todoTask" type="WebSrv_DTO_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="translateToPackage" id="448405ab-9af5-478d-81df-fbb933dd8e37">
        <updating/>
        <source>translateToPackage(_todoTask:DTO_ToDoTask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from the receiver to a task object
//				received via the DTO package.
//
// Parameters:	_todoTask - A reference to the package task object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_todoTask.code			:=	self.code;
	_todoTask.completedTs	:=	self.completedTs;
	_todoTask.description	:=	self.description;
	_todoTask.state			:=	self.newState;
end;</source>
        <Parameter name="_todoTask" type="MobileServerRTThin::DTO_ToDoTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToWebServices" id="69938801-edd3-4b33-96e7-80692056d836">
        <updating/>
        <source>translateToWebServices(_todoTask:WebSrv_DTO_ToDoTask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from the receiver to a task object
//				received via a Web Services SOAP message.
//
// Parameters:	_todoTask - A reference to the SOAP task object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_todoTask.code			:=	self.code;
	_todoTask.completedTs	:=	self.completedTs;
	_todoTask.description	:=	self.description;
	_todoTask.state			:=	self.newState;
end;</source>
        <Parameter name="_todoTask" type="WebSrv_DTO_ToDoTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="c5d5db05-eebf-49b4-bc39-81e4228ccb3f">
        <updating/>
        <source>updateMe(_code:Integer; _completedTs:TimeStamp; _description:String; _state, _txnType :Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the receiver's property values.
//
// Parameters:	_code - The task's unique code.
//				_completedTs - The date/time when the task was completed.
//				_description - A description of the task.
//				_state - The current state of the task.  Refer to DTO_ToDoTask for
//					valid class constants.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.code			:=	_code;
	self.completedTs	:=	_completedTs;
	self.description	:=	_description;
	self.txnType		:= _txnType;
	self.setState(_state);
end;</source>
        <Parameter name="_code" type="Integer"/>
        <Parameter name="_completedTs" type="TimeStamp"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_txnType" type="Integer"/>
    </JadeMethod>
</Class>
