    <JadeMethod name="create" id="270db25f-d7fb-40c2-8c9e-060e804a46fb">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
