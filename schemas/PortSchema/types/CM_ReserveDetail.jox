    <JadeMethod name="getNumItemsBeingActioned" id="5d3b49d6-b134-4cef-a4c8-3354d48e39a0">
        <source>getNumItemsBeingActioned( _excludingJob : CM_Job ) : Integer;
// -----------------------------------------------------------------------------
// Created:		29 September 2009 by consw1
//
// Purpose:		Returns number of items being actioned.
//				Items from given job are not included in the count.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	req	: CM_Request;
	num : Integer;
begin
	if self.myReserveHeader = null then
		return 0;
	endif;
	num:=0;
	foreach req in self.allRequests discreteLock do
		if _excludingJob &lt;&gt; null and
		   req.myJob = _excludingJob then
			continue;
		endif;
		if self.myReserveHeader.allRequestsBeingActioned.includes(req) then
			num:=num + req.getQuantityOnRequest().Integer;
		endif;
	endforeach;

	return num;
epilog

end;</source>
        <Parameter name="_excludingJob" type="CM_Job"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
