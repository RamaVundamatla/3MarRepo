    <JadeMethod name="doSelectUnselectTransMode" id="d6c56508-74a3-4747-8aae-c07990fb21c7">
        <source>doSelectUnselectTransMode(_select : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	idx		: Integer;
