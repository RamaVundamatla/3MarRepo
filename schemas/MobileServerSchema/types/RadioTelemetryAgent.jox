    <JadeMethod name="doChangeQueue" id="7e27bf8d-eb40-4d26-991e-1a7f94008622">
        <updating/>
        <source>doChangeQueue(_newQueueID : String;
			  _stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			Process a change of primary queue to the queue identified by
					_newQueueID


Return Value:		true if the update is successful


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	passport		: CM_Passport;
	machine,
	proxyMachine 	: CM_Machine;
	loadStateSet 	: Boolean;
	queue			: CM_RadioTelemetryQueue;
	
begin
	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;

	// Derive actual queue from passed in ID
	queue := app.getMyTerminalDO_NOT_USE().radioTelemetry.masterQueue.allSubQueuesById[_newQueueID];
	if queue = null then
		_stateInfo.errorString := app.getErrorString1(Err_InvalidQueue, _newQueueID);
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	// And update the primary queue of the current machine
	machine := self.myMediator.machine;
	app.cmsBeginLoad(loadStateSet);
	proxyMachine := machine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	
	app.myTrxUA.trxUpdateMachineQueue(proxyMachine, queue, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;

	// And reset the state back to just logged on
	self.setMediatorState(self.LoggedOn_Reset);
	_stateInfo.guiState	:= self.LoggedOn_Reset;
	
	return true;


epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
	delete proxyMachine;
	
end;</source>
        <Parameter name="_newQueueID" type="String"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogOff" id="616e8385-df06-4b3d-8ba4-98d5f50dfdc0">
        <updating/>
        <source>doLogOff(_stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport : CM_Passport;
	
begin

	passport := app.myPassport;
	
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxLogOff(self, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	// Don't have a mediator to update.
	_stateInfo.guiState 	:= self.LoggedOff;
	
	return true;
	
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));

end;</source>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogon" id="1e43ce13-b8f3-43cc-a279-1df0383756f0">
        <updating/>
        <source>doLogon(_userName: String; _password: String; _clientConnectionDetails: String; _dtoColors : DTO_Colours input; _stateInfo : DTO_StateInfo input): Boolean updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/* DeviceId::Terminal::MachineName::PortNumber */
vars

	passport 	: CM_Passport;
	rtnValue,
	result		: Integer;
	user		: CM_User;
	msg 		: String;
	
begin

	user := app.myRoot.allUsers[_userName];
	
	if user = null then
		_stateInfo.errorString :=  app.getErrorString(ERR_PASSWORD);
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	if not user.canDo(null, Mod_WebApps) then
		_stateInfo.errorString :=  app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps));
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
		
	result := app.validateUserPassword(_userName, _password);	
	passport := app.myPassport;
	if result &lt;&gt; 0 and result &lt;&gt; 75779 then
		// _stateInfo.errorString := app.getErrorString(result); //- cnwmd1 Par 22287
		msg := app.getErrorString(result); //+ cnwmd1 Par 22287
		app.myRoot.resolveMessagesWithExtraInfo(result, msg); //+ cnwmd1 Par 22287
		_stateInfo.errorString := msg; //+ cnwmd1 Par 22287
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
		
	rtnValue := app.myTrxRT.trxLogon(self, _clientConnectionDetails, false, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	if rtnValue &lt;&gt; 0 then
		_stateInfo.guiState 	:= rtnValue;
		_stateInfo.extraInfo	:= self.myMediator.state;
		_stateInfo.lastUpdateTs := self.myMediator.lastUpdateTs;
	else
		_dtoColors.portLogo := app.myPassport.myTerminal.getConfig(RtPortLogoPic).Binary;
		self.setMediatorState(self.LoggedOn_Reset);
		_stateInfo.guiState := self.LoggedOn_Reset;
	endif;

	self.getDTOColors(_dtoColors);
	
	return true;
end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_dtoColors" type="DTO_Colours" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enqTrackedItem" id="81d8ddbf-2f8b-4afe-ac05-46b2abc98693">
        <updating/>
        <source>enqTrackedItem(_tiId	: String; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	
begin

	passport := app.myPassport;
	
	app.myTrxRT.trxEnqTrackedItem(_tiId, self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.LoggedOn_Reset;
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	self.setMediatorState(self.Display_TI);
	_stateInfo.guiState	:= self.Display_TI;
		
	return true;


end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findAllAvailableQueueEntries" id="394ffbac-351c-4885-a98c-2ffbb96c603a">
        <updating/>
        <source>findAllAvailableQueueEntries(_dto : DTO_EnquiryGradingTasks input;
							 _stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			Find all the available queue entries for the current machine


Return Value:		_dto updated with the queue entries added


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	passport		: CM_Passport;
	queueEntries	: CM_RTQueueEntrySet;
	queueEntry		: CM_RTQueueEntry;
	iter			: Iterator;
	
begin
	passport := app.myPassport;
	
	create queueEntries transient;
	iter := self.allNotifiedQueueEntries.createIterator;
	while iter.next(queueEntry) do
		if app.isValidObject(queueEntry) then
			queueEntries.add(queueEntry);
		endif;
	endwhile;
	
	// No available queue entries is an error
	if queueEntries.isEmpty then
		_stateInfo.errorString := app.getErrorString(No_Tasks);
		_stateInfo.guiState	:= self.LoggedOn_Reset;
		return false;
	endif;
	
	// Populate collection of results for return	
	_dto.setFromFindAllQEntriesResults(queueEntries);
	
	self.setMediatorState(self.Display_Show_Queue_Entries);
	_stateInfo.guiState	:= self.Display_Show_Queue_Entries;
	
	return true;


epilog
	delete queueEntries;
	delete iter;
end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findAllAvailableQueues" id="6e5baf63-0051-46b6-b387-68850a0eb636">
        <updating/>
        <source>findAllAvailableQueues(_dto : DTO_EnquiryGradingTasks input;
					   _stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			Find all the available primary queues for the current machine


Return Value:		_dto updated with the queues added


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	passport		: CM_Passport;
	queues			: CM_RTQueueSet;
	queue			: CM_RadioTelemetryQueue;
	
begin
	passport := app.myPassport;
	
	create queues transient;
	
	app.myEnquiryAgent.findAllAvailableQueues(queues,			// _queues : Collection input;
											  self.myMediator,	// _mediator : CM_RadioTelemetryMediator input;
											  passport);		// _passport : CM_Passport input) updating;
	
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.LoggedOn_Reset;
		return false;
	endif;
	
	// Populate collection of results for return	
	_dto.setFromFindQueuesResults(queues);
	
	self.setMediatorState(self.LoggedOn_Reset);
	_stateInfo.guiState	:= self.LoggedOn_Reset;
	
	return true;


epilog
	delete queues;
	
end;</source>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findAllTrackedItems" id="f0e4351d-f2c8-4c5d-bf8d-27ef2b28cbde">
        <updating/>
        <source>findAllTrackedItems(_tiId : String;
					_dto : DTO_EnquiryGradingTasks input;
					_stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
04 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
16 Dec 2009 cnwdap1	CCMS MES 1007 changed signature for app.myEnquiryAgent.findAllTrackedItems
*/

vars
	passport		: CM_Passport;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	
begin
	passport := app.myPassport;
	
	create tiSet transient;
	
	app.myEnquiryAgent.findAllTrackedItems(_tiId, 				// _tiId : String;
										   tiSet,				// _tiSet : CM_TISet input;
										   true,
										   false, 				// don't look at prenoted
										   false,				// CCMS 1007 not a reefer-specific search
										   0,					//02 Dec 2010	NDL Par 26417
										   null,
										   passport);			// _passport : CM_Passport input) updating;
										   
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.LoggedOn_Reset;
		return false;
	endif;
	
	// If there's only one match, then treat as a direct enquiry
	if tiSet.size = 1 then
		return self.enqTrackedItem(tiSet.first.id, _dto, _stateInfo);
	
	else
	
		// Otherwise populate collection of results for return	
		_dto.setFromTISearchResults(tiSet);
		
		self.setMediatorState(self.Display_TI_Search_Results);
		_stateInfo.guiState	:= self.Display_TI_Search_Results;
	endif;
	
	return true;


epilog
	delete tiSet;
	
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentSettings" id="6a231009-3b73-4862-b93d-35fecaeeb85a">
        <updating/>
        <source>getCurrentSettings(_dtoColors : DTO_Colours input; 
				   _stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			Provide a mechanism for the RT client to get all the current settings
					from the database


Return Value:		_dtoColors updated


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	self.getDTOColors(_dtoColors);
	
	_stateInfo.guiState 	:= self.myMediator.state;
	_stateInfo.extraInfo	:= self.myMediator.state;
	_stateInfo.lastUpdateTs := self.myMediator.lastUpdateTs;

	return true;
	

epilog

end;</source>
        <Parameter name="_dtoColors" type="DTO_Colours" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDTOColors" id="c40f13d8-c8ef-48af-adc7-ff19f7681e67">
        <source>getDTOColors(_dtoColors : DTO_Colours input) protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
24 Jan 2006	cnwdvb1	Initial creation
29 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	terminal	: CM_Terminal;
	user		: CM_User;
	maxQueueEnt	: Integer;
	machine		: CM_Machine;
	queue		: CM_RadioTelemetryQueue;
	screenConfig	: CM_RTScreenConfig;
begin
	terminal	:= app.getMyTerminalDO_NOT_USE();
	user		:= app.getMyUser();
	
	if user &lt;&gt; null then
		_dtoColors.userColorBackGeneral	:= user.colorBackgroundRT;
		_dtoColors.userColorForeGeneral	:= user.colorForegroundRT;
		_dtoColors.userColorBackTable	:= user.colorTableBackRT;
		_dtoColors.userColorForeTable	:= user.colorTableForeRT;
		_dtoColors.canChangeQueue 		:= user.canDo(terminal, PmRTChangePrimQueue);	// PAR #16010
		_dtoColors.canRunSelectorQueries:= user.canDo(terminal, PmRTSelectorQueries);	// ccms 1593. cnwvu1. April 2008
	endif;
	
	if terminal &lt;&gt; null then
		screenConfig:=	terminal.myRTVehicleConfig.myDayScreenConfig;
		
		_dtoColors.sysColorBackGeneral		:=	screenConfig.screenBackColour;//terminalObj.getConfig(DefaultRTColorBackground).Integer;
		_dtoColors.sysColorBackTable		:=	screenConfig.tableBackColour; // terminalObj.getConfig(DefaultRTColorTableBack).Integer;
		_dtoColors.sysColorForeGeneral	:=	screenConfig.screenForeColour; //terminalObj.getConfig(DefaultRTColorForeground).Integer;
		_dtoColors.sysColorForeTable		:=	screenConfig.tableForeColour;
		
		/*
		Date		Who		Reason			
		20 Aug 2008	cnwdz2	Par 17782 CCMS Otago 1722 - Thin Client RT Changes: A configurable option at terminal level that
							is used for RT mobile clients to view the list of currently unactioned jobs without pressing 
							the VIEW button after a set down.
		*/
		_dtoColors.rtQueueAfterSetdown	:= terminal.getConfig(RtQueueAfterSetdown).Boolean;
		
		maxQueueEnt	:= terminal.myRTVehicleConfig.maxNumberQueueEntries;  //epr CCMS 1099 moved config
		_dtoColors.showNumberOfQueueEntries	:= maxQueueEnt &gt; 1;							// PAR #16010
	endif;
	
	machine := self.myMediator.machine;
	if machine &lt;&gt; null then
		_dtoColors.machineCode 		:= machine.id;
		_dtoColors.machineLiftType	:= machine.machineLiftType;		// ccms1595 27/11/07
		_dtoColors.primaryQueueId	:= machine.queueId;				// PAR #16010
		_dtoColors.numberOfAvailableQueueEntries := self.allNotifiedQueueEntries.size;
		
//		queue := machine.getQueue();
//		if queue &lt;&gt; null then
//			_dtoColors.numberOfAvailableQueueEntries := queue.allEntries.size;
//		else
//			_dtoColors.numberOfAvailableQueueEntries := 0;
//		endif;
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dtoColors" type="DTO_Colours" usage="input"/>
    </JadeMethod>
