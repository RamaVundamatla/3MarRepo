    <JadeMethod name="getShortHeading" id="ab93d170-e5fa-4d10-b278-e707da812d43">
        <source>getShortHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _locale : CM_Locale) : String;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     See getHeading()
//
// Changes:     8/8/2006 RBarr Retrieve from new TranslatableText structure
// ---------------------------------------------------------------------------
vars
	translation	: XLAT_Translation;
	tmpHeading	: String;
begin

	tmpHeading := self.getTerminologyHeading(_cargoBOLType, _terminal, true);
	if tmpHeading &lt;&gt; null then
		return tmpHeading;
	endif;

	if _locale = null then
		return inheritMethod(_cargoBOLType, _terminal, _locale);
	endif;

	translation := getTranslation(_locale);

	if translation = null or translation.shortText = null then
		return inheritMethod(_cargoBOLType, _terminal, _locale);
	endif;

	return translation.shortText;
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminologyHeading" id="cc742826-e74f-4e8e-ba7c-8b6cb39a72f1">
        <source>getTerminologyHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _isShort : Boolean) : String protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     heading is protected - retrieval of value must come through here.
//				returns alternate heading if terminology relivant
//			 
// ----------   ----------  --------------------------------------------------
vars
	termType		: CM_TerminologyType;
	termDtl			: CM_TerminologyDtl;
	termHdr			: CM_TerminologyHdr;
	
begin
	
	//if entTableRow has a terminology type associated, see if its applicable to 
	//to the terminal cargoBOLType passed in.
	//N.B. the terminal AND/OR the cargoBOLType could validly be null, representing either
	//the default for that terminal where there is no cargoBOLType, or the default for 
	//that cargoBOLType where there is no terminal, or the system default where neither can be resolved
	termType := self.myTerminologyType;
	if termType = null then
		return null;
	endif;
	
	termHdr := app.myRoot.allTerminologyHdrs[termType, _cargoBOLType, _terminal];

	if termHdr = null then
		return null;
	endif;
	
	termDtl := termHdr.myTerminologyDef.allTerminologyDtls[self.myGroup.name, self.name];
	
	if termDtl &lt;&gt; null then
		if _isShort then
			return termDtl.userShortHeading;
		endif;
		return termDtl.userHeading;

	elseif app.isDevelopmentSystem() then
		app.writeLog('The group/Row:' &amp; self.myGroup.name &amp; '/' &amp;  self.name &amp; 
					'is not specify in the XML of the global constant that represents terminology type "' &amp; 
					termType.name &amp; '"', LogINFO);
	endif;
	
	return null;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isShort" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslation" id="029da364-bde6-4895-acae-bbc011b25f7c">
        <source>getTranslation(_locale : CM_Locale):XLAT_Translation;

vars

begin
	if self.myEntTableText &lt;&gt; null then
		return self.myEntTableText.getTranslation(_locale);
	endif;
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
