    <JadeMethod name="buildSelf" id="78174ec4-0925-4143-9d66-874fd6e5f00d">
        <updating/>
        <source>buildSelf() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TruckBedHeight	: Integer = 32;
	
vars
	idx		: Integer;
	frmCont	: GTE_FlexiContainerFrame;
	
begin

	foreach idx in 1 to NumContainerFramesAtStart do
		if idx &gt; self.allFlexiContainerFrames.size then
			frmCont := null;
		else
			frmCont := self.allFlexiContainerFrames[idx].GTE_FlexiContainerFrame;
		endif;
		if frmCont = null then
			frmCont := createContainerFrame();
			self.allFlexiContainerFrames.atPut(idx, frmCont);
		endif;
	endforeach;
	
	self.backColor:=15132390; //cnwas3
	
	if self.myTruckBedLeftPic = null then
		create self.myTruckBedLeftPic transient;
		self.myTruckBedLeftPic.parent := self;
		form.addControl(self.myTruckBedLeftPic);

		self.myTruckBedLeftPic.borderStyle := BorderStyle_None;
		self.myTruckBedLeftPic.width := 63;
		self.myTruckBedLeftPic.height := TruckBedHeight;
		self.myTruckBedLeftPic.transparent := true;
		self.myTruckBedLeftPic.transparentColor := 13554646;	//214, 211, 206		
	endif;

	if self.myTruckBedMiddlePic = null then
		create self.myTruckBedMiddlePic transient;
		self.myTruckBedMiddlePic.parent := self;
		form.addControl(self.myTruckBedMiddlePic);

		self.myTruckBedMiddlePic.borderStyle := BorderStyle_None;
		self.myTruckBedMiddlePic.height := TruckBedHeight;
		self.myTruckBedMiddlePic.stretch := Picture.Stretch_ToControl;
		self.myTruckBedMiddlePic.transparent := true;
		self.myTruckBedMiddlePic.transparentColor := 13554646;	//214, 211, 206
	endif;

	if self.myTruckBedRightPic = null then
		create self.myTruckBedRightPic transient;
		self.myTruckBedRightPic.parent := self;
		form.addControl(self.myTruckBedRightPic);

		self.myTruckBedRightPic.borderStyle := BorderStyle_None;
		self.myTruckBedRightPic.width := 52;
		self.myTruckBedRightPic.height := TruckBedHeight;
		self.myTruckBedRightPic.transparent := true;
		self.myTruckBedRightPic.transparentColor := 13554646;	//214, 211, 206
	endif;

	if self.myTruckCabPicture = null then
		create self.myTruckCabPicture transient;
		self.myTruckCabPicture.parent := self;
		form.addControl(self.myTruckCabPicture);

		self.myTruckCabPicture.borderStyle := BorderStyle_None;
		self.myTruckCabPicture.width := 80;
		self.myTruckCabPicture.height := 112;
		self.myTruckCabPicture.transparent := true;
		self.myTruckCabPicture.transparentColor := 13554646;	//214, 211, 206
	endif;

	if self.myMoveLeftBtn = null then
		create self.myMoveLeftBtn transient;
		self.myMoveLeftBtn.parent := self;
		self.myMoveLeftBtn.visible := false;
		form.addControl(self.myMoveLeftBtn);		
		
		self.myMoveLeftBtn.width := 36;
		self.myMoveLeftBtn.height := 17;///cnwas3
	endif;

	if self.myMoveRightBtn = null then
		create self.myMoveRightBtn transient;
		self.myMoveRightBtn.parent := self;
		self.myMoveRightBtn.visible := false;
		form.addControl(self.myMoveRightBtn);
		
		self.myMoveRightBtn.width := 36;
		self.myMoveRightBtn.height := 17;
	endif;
	
	if self.myDoorsCheckBox = null then
		create self.myDoorsCheckBox transient;
		self.myDoorsCheckBox.parent := self;
		form.addControl(self.myDoorsCheckBox);
		
		self.myDoorsCheckBox.show3D := Show3D_Use3D;
		self.myDoorsCheckBox.height := 17;
		self.myDoorsCheckBox.caption := 'Doors';
		self.myDoorsCheckBox.value := true;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearContainers" id="69e9c760-62c0-4da4-abdc-e0f732283ead">
        <updating/>
        <source>clearContainers() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;

begin

	if self.myFlexiSelectedContainer &lt;&gt; null then
		self.myFlexiSelectedContainer.deSelect();
		self.myFlexiSelectedContainer := null;
	endif;
	
	self.myFlexiDraggedContainer	 := null;
	
	foreach contFrm in self.allFlexiContainerFrames do
		contFrm.enableDoorsDirBtn(true); //27 Jul 2021	NDL	TFS 49911
		contFrm.myContainer	:= null;
		contFrm.visible := false;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="9f101f58-1d0b-48b0-b177-3a0f018bf9e8">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;
	contHeight,
	tmpNum,
	tmpTop	: Integer;

begin

	// Handle vertical positioning
	
	self.myDoorsCheckBox.top := self.topMargin;
	
	self.myMoveLeftBtn.top	:= self.topMargin;
	self.myMoveRightBtn.top	:= self.topMargin;
	
	tmpTop := (self.topMargin/* + self.myMoveLeftBtn.height + 10*/).Integer;
	contHeight := (self.myTruckCabPicture.height - self.myTruckBedLeftPic.height).Integer;

	self.myTruckCabPicture.top 		:= tmpTop;
	self.myTruckBedLeftPic.top 		:= tmpTop + contHeight;
	self.myTruckBedMiddlePic.top 	:= tmpTop + contHeight;
	self.myTruckBedRightPic.top 	:= tmpTop + contHeight;
	
	foreach contFrm in self.allFlexiContainerFrames do
		contFrm.top := tmpTop+30;
		contFrm.height := contHeight-30;
	endforeach;
	
	// handle left positioning

	self.myDoorsCheckBox.left := self.leftMargin;

	self.myTruckCabPicture.left	:= self.leftMargin;
	
	self.myTruckBedLeftPic.left  	:= self.myTruckCabPicture.left + self.myTruckCabPicture.width;
	self.myTruckBedMiddlePic.left	:= self.myTruckBedLeftPic.left + self.myTruckBedLeftPic.width;
	self.myTruckBedRightPic.left 	:= self.clientWidth - self.rightMargin - self.myTruckBedRightPic.width;

	self.myTruckBedMiddlePic.width := self.myTruckBedRightPic.left - self.myTruckBedMiddlePic.left;
	
	// position move left/right buttons centred over truck bed
	self.myMoveLeftBtn.left := self.myTruckBedLeftPic.left + 
							((self.myTruckBedRightPic.left + self.myTruckBedRightPic.width - self.myTruckBedLeftPic.left) / 2) - 
							self.myMoveLeftBtn.width;
	self.myMoveRightBtn.left := self.myMoveLeftBtn.left + self.myMoveLeftBtn.width;
	
	self.displayContainers();

end;</source>
    </JadeMethod>
    <JadeMethod name="countContainers" id="013aa65e-e04b-4749-9cfd-1f300ded3eff">
        <source>countContainers() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2009	cnwas3	Initial creation

*/

vars
	i : Integer;
	container : GTE_FlexiContainerFrame;
begin

	foreach container in self.allFlexiContainerFrames where container.myContainer &lt;&gt; null do
		i := i+1;
	endforeach;
	
	return i;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
