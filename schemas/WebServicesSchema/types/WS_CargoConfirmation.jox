<Class name="WS_CargoConfirmation" id="73448111-ba7f-4bce-8cb1-ab267094085e">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoId" id="eec192ca-3388-4d2a-b690-c80176000a7c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="confirmDT" id="1c4473c6-ea14-48a0-8192-7675bd200057">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="confirmedLocation" id="0dbf8554-9636-4de7-b0a3-28aa9682f559">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="jobId" id="5101ac2b-2f88-45b8-b629-7e09624ef249">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="plannedLocation" id="213676b5-e001-434a-b01c-d80184ea4ce9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="d7b1110c-3e3d-4101-80b8-1d898cb52555">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getAlertDetail" id="f596e294-7159-4c7e-8bd7-1e81413041f6">
        <source>getAlertDetail(_errString : String;
				_isError : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	message : String;

begin

	if _isError then
		message := "Tallyman Stowage Confirmation update failed." &amp; CrLf;
	else
		message := "Tallyman Stowage Confirmation warning." &amp; CrLf;
	endif;
	message := message &amp; "[" &amp; _errString &amp; "]" &amp; CrLf;
	message := message &amp; "Cargo Id = " &amp; self.cargoId &amp; CrLf;
	message := message &amp; "Voyage Job = " &amp; self.jobId &amp; CrLf;
	message := message &amp; "Planned Location  = " &amp; self.plannedLocation &amp; CrLf;
	message := message &amp; "Confirmed Location = " &amp; self.confirmedLocation &amp; CrLf;
	message := message &amp; "Confirm Date/Time = " &amp; self.confirmDT.asStringJMT; 
	
	return message;
epilog

end;</source>
        <Parameter name="_errString" type="String"/>
        <Parameter name="_isError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
