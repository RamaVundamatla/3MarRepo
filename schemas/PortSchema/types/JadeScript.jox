        <source>rel811_par29961();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;
	agent : EntTableAgent;
	array 		: StringArray;
	
begin
	app.initialize();
	
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add("Both_options_allowed");
	tmpArray.add("No_options_allowed");
	tmpArray.add("Grounding_completes");
	tmpArray.add("Grounding_in_transit");
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	
	
	
	
	create agent transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create array transient;	
	array.add ("ETRow_HhLanderGroundingOpt");
	array.add ("ETDef_TerminalSettings");
	
	agent.trxUpdateFromConstant(array);	
	
	return;
	
	write Both_options_allowed;
	write No_options_allowed;
	write Grounding_completes;
	write Grounding_in_transit;
	
	// new category of constants - HHLanderToGround
	write BothOpts;
	write NoOpts;
	write GroundComplete;
	write GroundInTransit;
	
	// config option constant
	write HhLanderGroundingOpt;
	
	write ETRow_HhLanderGroundingOpt;
	write ETDef_TerminalSettings;
	
	
epilog

	delete tmpArray;
	delete transAgent;
	delete agent;
	delete array;

