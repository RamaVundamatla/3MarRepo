    <JadeMethod name="hasJobsLoadedToOps" id="b2305209-ee4d-4c13-9f59-512f54369b49">
        <source>hasJobsLoadedToOps(_workPoint : CM_WorkPoint ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026

*/

vars
	job : CM_Job;
	voyageJob : CM_VoyageJob;
	voyage : CM_Voyage;
begin
	voyage:= self.getVoyage();
	foreach job in voyage.allVoyageJobs do
		voyageJob:=job.CM_VoyageJob;
		if not voyageJob.isLoadedToOperations then
			continue;
		endif;
		
		if not voyageJob.bayId = self.code then
			if voyageJob.isSOB then
				if voyageJob.isKindOf(CM_VoyageDeckJob) and not
					voyageJob.CM_VoyageDeckJob.hasSOBLoadJob(self) then
					continue;
				endif;
			else
				continue;
			endif;
		endif;
		
		if voyageJob.getMyWorkPointObject = _workPoint then
			return true;
		endif;
	endforeach;
	
	
	return false;
	
epilog
	

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
