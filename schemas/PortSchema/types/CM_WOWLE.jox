/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2024 ChangeRequest 64770: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 1

*/

vars

begin
	if self.myOperationalWLE &lt;&gt; null then
		return self.myOperationalWLE.job;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
