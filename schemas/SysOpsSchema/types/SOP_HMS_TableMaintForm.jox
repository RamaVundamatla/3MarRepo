    <JadeMethod name="showTidalTypeRows" id="d4fe49ca-ae00-47e0-b60c-b1200d3e0d17">
        <source>showTidalTypeRows(_chkPointType : Integer);
// --------------------------------------------------------------------------------
// Created:		20 March 2007 by cnwdad1
//
// Purpose:		Shows or hides tidal data rows, depending upon which Check Point Type is
//				passed in.
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	theRow	: Integer;
begin

	tblInput1.hideRowByName(ETRow_TidalModel, false);
	tblInput1.hideRowByName(ETRow_RelativeToTide, false);
	tblInput1.hideRowByName(ETRow_RelativeToTime, false);
	tblInput1.hideRowByName(ETRow_RelativeFromTime, false);
	tblInput1.hideRowByName(ETRow_RelativeToTide2, false);
	tblInput1.hideRowByName(ETRow_RelativeToTime2, false);
	tblInput1.hideRowByName(ETRow_RelativeFromTime2, false);
	tblInput1.hideRowByName(ETRow_MyTimeGapToCheckRegion, false);
	tblInput1.hideRowByName(ETRow_GapBetweenMovements, false);
	tblInput1.hideRowByName(ETRow_GapCheckArrivals, false); //epr par 16514 16/4/08
	tblInput1.hideRowByName(ETRow_GapCheckDepartures, false); //epr par 16514 16/4/08
	tblInput1.hideRowByName(ETRow_TideRangeReference, false);
	tblInput1.hideRowByName(ETRow_TideRangeAmount, false);
	tblInput1.hideRowByName(ETRow_TideRangeReference2, false);
	tblInput1.hideRowByName(ETRow_TideRangeAmount2, false);
	tblInput1.hideRowByName(ETRow_ShipsDepartTimings, false);
	tblInput1.hideRowByName(ETRow_HookCode, false);
	tblInput1.hideRowByName(ETRow_TideState,false);
	
	if _chkPointType = HMS_ChkPointType_Current then
		tblInput1.showRowByName(ETRow_TidalModel, false);
	
	elseif _chkPointType = HMS_ChkPointType_Draft then
		tblInput1.showRowByName(ETRow_TidalModel, false);
	
	elseif _chkPointType = HMS_ChkPointType_HiLo then
		tblInput1.showRowByName(ETRow_TidalModel, false);
		tblInput1.showRowByName(ETRow_RelativeToTide, false);
		tblInput1.showRowByName(ETRow_RelativeToTime, false);
		tblInput1.showRowByName(ETRow_RelativeFromTime, false);
		tblInput1.showRowByName(ETRow_RelativeToTide2, false);
		tblInput1.showRowByName(ETRow_RelativeToTime2, false);
		tblInput1.showRowByName(ETRow_RelativeFromTime2, false);
		
	elseif _chkPointType = HMS_ChkPointType_TimeGap then
		tblInput1.showRowByName(ETRow_MyTimeGapToCheckRegion, false);
		tblInput1.showRowByName(ETRow_GapBetweenMovements, false);
		tblInput1.showRowByName(ETRow_GapCheckArrivals, false); //epr par 16514 16/4/08
		tblInput1.showRowByName(ETRow_GapCheckDepartures, false); //epr par 16514 16/4/08
	//jlgak1 TFS 45620 --&gt;		
	/*elseif _chkPointType = HMS_ChkPointType_TideRange then
		tblInput1.showRowByName(ETRow_TidalModel, false);
		tblInput1.showRowByName(ETRow_TideRangeReference, false);
		tblInput1.showRowByName(ETRow_TideRangeAmount, false);
		tblInput1.showRowByName(ETRow_TideRangeReference2, false);
		tblInput1.showRowByName(ETRow_TideRangeAmount2, false);
	
	elseif _chkPointType = HMS_ChkPointType_ShipsDepart then
		tblInput1.showRowByName(ETRow_TidalModel, false);
		tblInput1.showRowByName(ETRow_RelativeToTide, false);
		tblInput1.showRowByName(ETRow_ShipsDepartTimings, false);	
	elseif _chkPointType = HMS_ChkPointType_UserHookCode then
		theRow := tblInput1.showRowByName(ETRow_HookCode, false);
		tblInput1.disableRow(theRow);
		if self.mode = Mode_View then
			tblInput1.setValue(theRow, 'Dbl-Click to view');
		else
			tblInput1.setValue(theRow, 'Dbl-Click to update');
		endif;	
	elseif _chkPointType = HMS_ChkPointType_TideState then
		//epr par 16884 5/6/08
		tblInput1.showRowByName(ETRow_TidalModel, false);
		tblInput1.showRowByName(ETRow_TideState, false);*/
	//jlgak1 TFS 45620 &lt;--		
	endif;
end;</source>
        <Parameter name="_chkPointType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblInput1_dblClick" id="20722c01-ac5c-4ffa-921b-fa83e6d45ac4">
        <updating/>
        <source>tblInput1_dblClick(table: CM_EntryTable input) updating;
/*
Date		Who		Reason
26 September 2011	cnwcs5	Initial creation - CCMS RIO 2230 / par 28261 Start/Stop Times
*/
vars
	row	:Integer;
begin 
	row := table.getRow(ETRow_HookCodeMinResidenceTime);
	
	if table.row = row and row &gt; table.fixedRows then
		self.showHookCodeMaintForm(); 
		return;
	endif;
	
	inheritMethod(table);

epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblQueryRowColChg" id="889edd68-94fb-4737-bedc-89a80a16a06b">
        <updating/>
        <source>tblQueryRowColChg(table: CM_EntryTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
begin
	if self.myDataClass = HMS_Berth then
		self.doBerthEndPosition(table, newRow);
	elseif self.myDataClass = HMS_CheckPoint then
		self.doClearRestrictionValues(table);
	endif;
	
	return true;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblRoute_cellInputReady" id="9ceeac9a-19db-4885-ba16-b1ab35e4e8b3">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRoute_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRow			: Integer;
	tmpPathSegment	: HMS_PathSegment;
	tmpFromRegion	: HMS_HarbourRegion;
	
begin
	if inputControl = self.cmbPathSegment then
		tmpRow := table.row;
		if tmpRow = table.fixedRows + 1 then
			// this is the first row so have all path segments
			self.cmbPathSegment.listCollection(app.myRoot.allPathSegments, true, 0);
		else
			// only populate with path segments from the previous movement
			tmpPathSegment := table.accessRow(tmpRow - 1).itemObject.HMS_PathSegment;
			if tmpPathSegment = null then
				// do not know where so populate with all
				self.cmbPathSegment.listCollection(app.myRoot.allPathSegments, true, 0);
			else
				tmpFromRegion := tmpPathSegment.myRegionTo;
				self.cmbPathSegment.clear;
				foreach tmpPathSegment in app.myRoot.allPathSegments where
						tmpPathSegment.myRegionFrom = tmpFromRegion do
					self.cmbPathSegment.addItemObject(self.myAssistant.displayEntryHMSPathSegment(tmpPathSegment), tmpPathSegment);
				endforeach;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblRoute_queryRowColChg" id="dcf51a83-27ab-4e01-b8fb-d67ce6b9ae08">
        <controlMethod name="Table::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRoute_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
//	if newRow = table.rows then
	if self.mode &lt;&gt; self.Mode_View and newRow = table.rows then
		table.rows := table.rows + 1;
	endif;
	
	return true;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6fe88858-e981-482d-8685-86179a2ade89">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017690, locale);
	fieldRouteSeg.translateCaption(Xlat_0003848, locale);
	lblDestination.translateCaption(Xlat_0003847, locale);
	lblHarbour.translateCaption(Xlat_0007043, locale);
	lblStartRoute.translateCaption(Xlat_0003849, locale);
	mnuContextHMS.translateCaption(Xlat_0007044, locale);
	mnuDeleteRow.translateCaption(Xlat_0007045, locale);
	mnuInsertRow.translateCaption(Xlat_0007046, locale);
	shtPathSegments.translateCaption(Xlat_0003846, locale);
end;</source>
    </JadeMethod>
</GUIClass>
