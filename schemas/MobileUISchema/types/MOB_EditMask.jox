        <DevControlProperties name="selectionStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Select on focus except if mouse used</value>
                <value>2 - Select on focus always</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="show3D">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - use application default</value>
                <value>1 - Not 3D</value>
                <value>2 - Use 3D</value>
                <value>3 - Use borderStyle</value>
            </optionsList>
        </DevControlProperties>
