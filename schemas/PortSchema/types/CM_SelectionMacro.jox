    <JadeMethod name="identity" id="a314176e-0d49-4704-b89d-19a8f6afa28e">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
