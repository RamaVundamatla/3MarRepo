    <JadeMethod name="doTransactionSearch" id="04158c08-a1ca-40f3-a745-643009413ed2">
        <updating/>
        <source>doTransactionSearch() updating, protected;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	tableName		: String;
	entTableDef		: EntTableDef;
begin
	self.numItemsShown		:= 0;
	self.numItemsSearched	:= 0;
	self.allTransactions.clear();
	self.searchCancelled := false;

	if self.mode = self.Mode_Cargo_Transaction_Enquiry then
		tableName := ETDef_TransactionCargoEnquiry;
		self.cargoTransactionSearch();
	elseif self.mode = self.Mode_Event_Transaction_Enquiry then
		tableName := ETDef_TransactionEventEnquiry;
		self.eventTransactionSearch();
	elseif self.mode = self.Mode_HMS_Transaction_Enquiry then
		tableName := ETDef_TransactionHMSEnquiry;
		self.hmsTransactionSearch();
	elseif self.mode = self.Mode_WO_Transaction_Enquiry then
		tableName := ETDef_TransactionWOEnquiry;
		self.woTransactionSearch();
	elseif self.mode = self.Mode_BOL_Transaction_Enquiry then	//04 Nov 2019	NDL	TFS 47100
		tableName := ETDef_TransactionBOLEnquiry;
		self.bolTransactionSearch();
	endif;

	if not self.doMaxTableSizeCheck(self.numItemsShown, null) then
		return;
	endif;

	// only set the ent table on change of mode
	if self.mode &lt;&gt; self.priorMode then
		entTableDef := app.myController.getEntTableDef(tableName);
		self.tblTransactions.setTblDataEntRowsFromDef(entTableDef);
		self.priorMode := self.mode;
	endif;

	self.populateTransactionTable();
	self.showSearchCriteria();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUndelete" id="1fe7ab65-20c2-4f31-8fe3-b556cf03c14b">
        <updating/>
        <source>doUndelete() protected, updating;
// Feb 2012 CCMS 1262 add bulk un-delete to match bulk delete
vars
	count			: Integer;
	msg1,
	msg2			: String;
	txn				: CM_TITransaction;
	obj				: Object;
	oa				: ObjectArray;
	transactions	: ObjectArray;
	strTrans		: String;
begin
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, only CM_TITransaction has a delete capability, not event or HMS transactions
	if self.mode &lt;&gt; self.Mode_Cargo_Transaction_Enquiry and
	   self.mode &lt;&gt; self.Mode_CargoItem_Enquiry then
		return;
	endif;

	create oa transient;
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.tblTrans.allSelectedObjects.copy(oa);
	else
		self.tblTransactions.allSelectedObjects.copy(oa);
	endif;
	// filter out already un-deleted transactions
	create transactions transient;
	foreach obj in oa do
		txn := obj.CM_TITransaction;
		if txn.deleted then
			transactions.add(txn);
		endif;
	endforeach;

	if transactions.size &lt; 1 then
		app.msgBox('Please select a transaction to un-delete', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	else
		foreach obj in transactions do
			txn := obj.CM_TITransaction;
	
			if txn.myTrackedItem &lt;&gt; null and
			   txn.myTrackedItem.myTerminal &lt;&gt; self.myTerminal then
				app.msgBox('You cannot un-delete this transaction from this terminal.', self.caption, MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			
			count := count + 1;
			if count = 1 then
				strTrans := "'" &amp; txn.typeString &amp; "'";
			endif;
		endforeach;
			
		// show transaction type for single undelete, show count for multiple
		if count = 1 then
			msg1 := app.getErrorString(Transaction);
			msg2 := strTrans;
		else
			msg1 := count.asStringJMT();
			msg2 := app.getErrorString(Transactions);
		endif;
		if (not app.msgBox(app.getErrorString2(ConfirmUndelete, msg1, msg2), app.getErrorString(Confirm_Delete), MsgBox_OK_Cancel) = MB_OK) then
			return;
		endif;
		
		foreach obj in transactions do
			txn := obj.CM_TITransaction;
			app.myTrxUA.trxUndeleteTITransaction(txn, app.myPassport);
		endforeach;
		
		if not app.myPassport.trxCompletedOK then
			app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
			return;
		endif;
		
		if self.mode = self.Mode_CargoItem_Enquiry then
			self.initTblTrans();
			self.showTransactions();
		endif;
	endif;
epilog
	delete oa;
	delete transactions;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="eventTransactionSearch" id="2cf472dd-482c-4014-9cdc-bbfad03f751e">
        <updating/>
        <source>eventTransactionSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
   Jan 2012 cnwjre1	CCMS 1262  transaction enquiry and selector queries, cargo transactions
12 Dec 2019 cnwma1	Bug 47966: STWO - Transaction Enquiry ignores midnight 'Time To'
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	type			: Integer;
	iter			: Iterator;
	eventObj		: CM_EventTransaction;
	dateDict		: CM_EventTransByDateTime;
	typeDateDict	: CM_EventTransByTypeDateTime;
	keyTimeStamp	: TimeStamp;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
	keyType			: Integer;
	atLimit			: Boolean;
	breakOut		: Boolean;
	passport		: CM_Passport;
	user			: CM_User;

begin
	passport := app.myPassport;
	user 	 := app.getMyUser();

	startTimeStamp.setDate(self.filterDateFrom);
	startTimeStamp.setTime(self.filterTimeFrom);
	
	endTimeStamp.setDate(self.filterDateTo);
	endTimeStamp.setTime(self.filterTimeTo);
	
	if self.filterEventType = null then
		// date search
		dateDict := self.myTerminal.allEventsByDateTime;
		iter 	 :=	dateDict.createIterator();
		dateDict.startKeyGeq(startTimeStamp, iter);
	
		while iter.next(eventObj) do
			iter.getCurrentKeys(keyTimeStamp);  //MTN-35226
		
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
		
			if self.includesEventObject(eventObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(eventObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	else
		// transaction type search
		type		 := self.filterEventType.type;
		typeDateDict := self.myTerminal.allEventsByTypeDateTime;
		iter 		 :=	typeDateDict.createIterator();
		self.myTerminal.allEventsByTypeDateTime.startKeyGeq(type, startTimeStamp, iter);
	
		while iter.next(eventObj) do
			iter.getCurrentKeys(keyType, keyTimeStamp);  //MTN-35226
		
			if type &lt;&gt; keyType then
				break;
			endif;
			
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
		
			if self.includesEventObject(eventObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(eventObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	endif;
	self.searchCancelled := breakOut;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fldTrans_click" id="7230ce8a-7429-45f7-89f5-8380730d4568">
        <controlMethod name="Folder::click"/>
