    <JadeMethod name="clearSelectedJob" id="2e54697c-abee-4d41-ab01-361346e2ed89">
        <updating/>
        <source>clearSelectedJob() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2012	cnwer1	Initial creation PAR 29608

*/

vars
	allSelectedObjects : ObjectSet;
	obj : Object;
	selectedIndex : Integer;
	theFrame : CMUI_PointDrawingFrame;
begin
	if self.modeWork &lt;&gt; SHP_ROROPlanningForm.WorkMode_Job then
		return;
	endif;
	create allSelectedObjects transient;
	//deselect all currently selected jobs
	self.allSelectedObjects.copy(allSelectedObjects);
	self.clearAllSelectedObjects;
	foreach obj in allSelectedObjects where obj.isKindOf(CM_RORORequest) do
		if theFrame = null then
			theFrame:= self.getFrameForLayer(obj.CM_RORORequest.myLayout.myDeckLayer);
		endif;
		selectedIndex := theFrame.allPointGraphics.indexOf(obj.CM_RORORequest.myLayout);
		if selectedIndex &gt; 0 then
			self.drawLayoutItemColourCoding(theFrame,selectedIndex,self.modeView = ShpDisplayMode_ColCodeLoad);
		endif;
	endforeach;
		
epilog
	delete allSelectedObjects;
end;</source>
    </JadeMethod>
