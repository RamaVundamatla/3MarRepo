/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	cnwjk3	Initial creation

*/

vars

begin
	// TFS 3294 add date range validation
	if not self.setQueryValues() then
		return;
	endif;
	self.haveToldUserTableActivityFull := false;	// 20 July 2010	NDL	Par 17868
	self.displayAllHistory();
	self.doShowSearcherClick();
end;</source>
