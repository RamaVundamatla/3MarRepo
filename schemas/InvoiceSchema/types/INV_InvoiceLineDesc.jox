    <JadeMethod name="initFilterTable" id="8fde0cfe-1f9c-49d8-b4bf-34fa4fe1d487">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Purpose:		35872 Query by business unit, when there are more than one present
//
// ---------------------------------------------------------------------------

vars
	entTableDef	: EntTableDef;
	
begin

	entTableDef := app.myController.getEntTableDef(ETDef_InvQuery);
	
	if entTableDef &lt;&gt; null then
