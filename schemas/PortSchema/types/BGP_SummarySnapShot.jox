    <JadeMethod name="action" id="a557e802-f884-407e-a3e3-0be5ba4e13bb">
        <updating/>
        <source>action(): Boolean updating;
/*
Date				Who		Reason
30 November 2009	cnwas3 
12 August 2010		cnwcs5	par 23706 - set timestamp to end of query
20/10/2010			cnwcs5	par 25708 - change type of collection used so we don't have the same object in the coll &gt; once
22/11/2012			cnwcs5	par 30618 - allow %MISCDIR% in directory name
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

NOTE: keep the core code in step with the createData method
*/
vars 
	errCode			: Integer;
	errTxt			: String;	
	fileName 		: String;
	
	collection 		: Collection;
	snapshotData 	: CM_SnapshotData;
	ts				: TimeStamp;	// par 23706 cnwcs5	12/08/2010 - time query ended
	msg, path		: String;
	passport		: CM_Passport;
	user, appName	: String;
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	
	passport 	:= app.myPassport;
	user		:= self.getUserCode;
	appName		:= app.name;
	
	if passport &lt;&gt; null then
		passport.setMyTerminal(self.myTerminal);
	endif;
	
	// par 30618 - networkPath could contain %MISCDIR% which will be replaced with the actual value for the misc directory
	path := self.networkPath.substituteDirectory;	
	
	if path &lt;&gt; null then
		fileName := path &amp; self.mySSDefinition.name &amp; "_" &amp; app.actualTimeServer.formatAsYYYYMMDDHHmmSS &amp; ".csv";
	endif;
	
	msg := "fileName = &gt;&gt;&gt;" &amp; fileName &amp; "&lt;&lt;&lt;";
	
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	//get a collection of data based on the selector query...
	create collection as CM_TISet transient;	// par 25708 cnwcs5 20/10/2010
	
	self.getCollection(collection, ts);			// 12/08/2010 cnwcs5 par 23706 - new parameter
	
	msg := 'User ' &amp; passport.getUserCode;
	
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	if collection.isEmpty then
		msg := 'Empty Collection';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	else
		msg := 'Query returned ' &amp; collection.size.String &amp; ' instances';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		
		//build the snapshotdata from the collection and the OutputFormat
		snapshotData := self.mySSDefinition.generateSnapshotDataFromColl(collection, null, ts, self.myTerminal, self.myUser);	// 12/08/2010 cnwcs5 par 23706
		
		if snapshotData &lt;&gt; null then
			// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
			if self.myBankToCharge &lt;&gt; null then
				self.checkLastRun();
				self.doInvoicing(snapshotData);
			endif;
			
			if fileName &lt;&gt; null then
				msg := "exporting....";
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				self.exportToCSV(snapshotData, fileName);
			endif;
		else
			msg := "snapshotData is null";
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
	endif;
	
	return true;
epilog
	delete collection;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkLastRun" id="f29c94e1-f303-4e8e-a808-a08ed187f0b0">
        <source>checkLastRun();
/* Check for extra/missing runs, snapshot lastRun compared against the current BGP task frequency.
	Since the task frequency setup is potentially very complex, only the [relatively] easy-to-handle cases of once-per-day per-time
	or by-day are checked.
*/
vars
	minsDiff,
	hoursDiff	: Integer;
	lastRun	: TimeStamp;
	thisRun	: TimeStamp;
	alertDetails	: String;
	task	: CM_AutoTaskSummarySnapShot;
	autoSchedule	: CM_AutoSchedule;
begin
	lastRun := self.mySSDefinition.lastRun;
	if lastRun = null then
		return;
	endif;

	if self.myUpdateCallbackObject &lt;&gt; null and
	   self.myUpdateCallbackObject.isKindOf(CM_AutoTaskSummarySnapShot) then
		task := self.myUpdateCallbackObject.CM_AutoTaskSummarySnapShot;
		autoSchedule := task.allAutoSchedules.first;	// what if there are more??
		if autoSchedule = null then
			return;
		endif;
		if autoSchedule.selectionState = State_Time and
		   autoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Days and
		   autoSchedule.recurValue = 1 then
			thisRun := app.actualTimeServer;
			minsDiff := thisRun.getDifferenceInMinutes(lastRun);
			hoursDiff := minsDiff div 60;
			if hoursDiff &lt; 12 then			// run too often
				alertDetails := "Snapshot Summary daily task " &amp; autoSchedule.description &amp; " for summary " &amp; self.mySSDefinition.name &amp;
					" last run on " &amp; lastRun.asStringJMT &amp; " is less than a day before the current run at " &amp; thisRun.asStringJMT;
			elseif hoursDiff &gt;= 48 then		// missed a day
				alertDetails := "Snapshot Summary daily task " &amp; autoSchedule.description &amp; " for summary " &amp; self.mySSDefinition.name &amp;
					" last run on " &amp; lastRun.asStringJMT &amp; " is more than a day before the current run at " &amp; thisRun.asStringJMT;
			endif;
		elseif autoSchedule.selectionState = State_Day then
			if autoSchedule.allRunTimes.size = 1 and
			   thisRun.Date = lastRun.Date then
				alertDetails := "Snapshot Summary daily task " &amp; autoSchedule.description &amp; " for summary " &amp; self.mySSDefinition.name &amp;
					" last run on " &amp; lastRun.asStringJMT &amp; " has already been run for " &amp; thisRun.asStringJMT;
			 endif;
		endif;

		if alertDetails &lt;&gt; null then
			app.createAlert(alertDetails, true);
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createData" id="3c897393-627e-42d2-832c-8bb410c4cde3">
        <updating/>
        <source>createData(_atDate : TimeStamp): Boolean updating;
/*
	CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
Purpose:		To create a new snapshot data entry and do associated invoicing (for storage etc)
	on request from the snap shot summary form, to handle missed background runs.

Parameters:		Effective date of the data.

Copy of method 'action' - keep the core code of both in step

Date		Name	TFS#	Description
============================================================================
10 May 2019	jlgdi1	44612 Added query mode type checking when initializing the collection
============================================================================
*/

vars
	collection 		: Collection;
	snapshotData 	: CM_SnapshotData;
	ts				: TimeStamp;
	
begin
	if self.isBillOfLadingMode() then 
		create collection as CM_BOLSet transient;
	else
		create collection as CM_TISet transient;
	endif;	
	
	self.getCollection(collection, ts);
	// for this case, use the parameter as the run date/time
	ts := _atDate;
	if not collection.isEmpty then
		//build the snapshotdata from the collection and the OutputFormat
		snapshotData := self.mySSDefinition.generateSnapshotDataFromColl(collection, null, ts, self.myTerminal, self.myUser);
		if snapshotData &lt;&gt; null and
		   self.myBankToCharge &lt;&gt; null then
			self.doInvoicing(snapshotData);
		endif;
	endif;
	
	return true;
	
epilog
	delete collection;
	return true;
end;</source>
        <Parameter name="_atDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInvoicing" id="6e298689-c770-4639-92dd-a66f3b8aa035">
        <updating/>
        <source>doInvoicing(_snapshotData : CM_SnapshotData) updating, protected;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	theReturn	: Integer;
	map	: CM_TranMapSSSummary;
	ssb	: CM_SnapShotServiceBroker;
	msg : String;
	invalid : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, self.myBankToCharge, invalid); 
	if self.myBankToCharge = null then
		msg := 'No Snapshot Bank To Charge';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	
	endif;
	
	map := self.myBankToCharge.myCurrentTranMapSnapShot;
	if map = null then
		msg := 'No Snapshot TranMap';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	endif;
	
	ssb := map.allSnapShotServiceBrokers[self.mySSDefinition];
	if ssb = null then
		msg := 'No Snapshot TranMap for my definition';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	endif;

	app.myTrxUA.trxUpdateSnapshotCharge(ssb, _snapshotData, app.myPassport);
end;</source>
        <access>protected</access>
        <Parameter name="_snapshotData" type="CM_SnapshotData"/>
    </JadeMethod>
    <JadeMethod name="exportToCSV" id="c0e2b501-0a08-4f33-894c-b17772e1c20a">
        <source>exportToCSV( _snapshotData : CM_SnapshotData; _fileName : String )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	filePath : String;
	file : File;
	agent : CMIF_OutputFormatAgent_SS;
	msg : String;
begin

	filePath := _fileName;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		msg := "FileUnavailable....";
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
	
	// populate the table using the Output format agent
	create agent transient;
	agent.populateTableOrCSV(_snapshotData, null, file);
	
epilog

	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	delete agent;

end;</source>
        <access>protected</access>
        <Parameter name="_snapshotData" type="CM_SnapshotData"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="d7b8b96b-6694-46d8-9f51-a0fa6509808d">
        <source>getCollection( _collection : Collection input; _ts :TimeStamp output )protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023
17/12/2009			cnwcs5	changed parameter usage from io to input and made method protected
12/08/2010			cnwcs5	par 23706 - added _ts parameter
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	userQuery : CM_MenuUserQuery;
	queryAgent : CM_QueryAgentFilter;
	qDef : CM_QueryDefinition;
	enqController : CM_EnquiryController;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	
begin

	_collection.clear();
	
	userQuery := self.mySelectorQuery;	
	queryAgent := app.myQAFilter;
	
	if queryAgent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myQAFilter was null');
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];	
	
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition for mode ' &amp;
										userQuery.queryMode.String &amp; ' could not be found in app.myRoot.allQueryDefinitionObjects');
		return;
	endif;
	
	queryAgent.createEnqControllerForMode(userQuery.queryMode, userQuery.getType, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in userQuery.allCriteriaLineHolders do
		enqController.myCriteriaLineHolder := criteriaHolder ;
		enqController.doQuery(qDef);
	endforeach;
	
	// set _ts parameter as time at end of query
	_ts := app.actualTimeServer;			// 12/08/2010 cnwcs5 par 23706	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	enqController.allObjects.copy(_collection);	
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_ts" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="d488ed6e-6733-4a08-a86b-38a34e20287a">
        <source>getDisplay(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwas3	Initial creation

*/

vars

begin
	return inheritMethod() &amp; Tab &amp; 'Summary Snapshot';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequest" id="ba789c25-8d74-49a0-b62b-b50230897a42">
        <updating/>
        <source>initRequest(_user : CM_User; _terminal : CM_Terminal; _definition : CM_OutputFormat_SS; _selector : CM_MenuUserQuery) updating;
/*
CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
Purpose:	This method is called before 'createData' to set up the object properties.

Parameters:			

*/
vars

begin
	self.myUser	:= _user;
	self.myTerminal	:= _terminal;	

	self.mySSDefinition := _definition;
	self.mySelectorQuery := _selector;
	self.myBankToCharge := _definition.myBankToCharge;
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_definition" type="CM_OutputFormat_SS"/>
        <Parameter name="_selector" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="b0016df8-6893-47ae-a426-c44ffe6d5c0f">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskSummarySnapShot) updating;
/*
Date		Who		Reason
30 November 2009	cnwas3	Initial creation

*/

vars

begin
	self.chkCreateInvoiceCharges 	:= _task.chkCreateInvoiceCharges;
	self.mySelectorQuery 			:= _task.mySelectorQuery;
	self.networkPath 				:= _task.networkPath;
	self.mySSDefinition 			:= _task.mySSDefinition;
	
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	if _task.mySSDefinition.mySelectorQuery &lt;&gt; null then
		self.mySelectorQuery 	:= _task.mySSDefinition.mySelectorQuery;
		self.myBankToCharge 	:= _task.mySSDefinition.myBankToCharge;
	endif;
	
	inheritMethod(_task);
epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTaskSummarySnapShot"/>
    </JadeMethod>
    <JadeMethod name="isBillOfLadingMode" id="76c6c789-983c-421d-90f7-09e9d8a91fa1">
        <source>isBillOfLadingMode() : Boolean;
/*

Purpose: Returns True if the mode of the Selector Query is one of the BOL Modes.
		 Bill of Lading (BOL) Modes are below:
		 1. General Bill of Lading
		 2. General Docket
		 3. Log Docket

Parameters:	None

Return Value: Boolean	

Date		Name	TFS#	Description
============================================================================
10 May 2019	jlgdi1	44612	Initial creation
============================================================================
*/

vars
	userQuery : CM_MenuUserQuery;
	
begin
	userQuery := self.mySelectorQuery;
	
	return userQuery.getType() = CM_QueryDefinition.BOL_Query_Type;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
