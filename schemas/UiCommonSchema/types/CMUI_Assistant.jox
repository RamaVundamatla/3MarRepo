    <JadeMethod name="setLogTreatment" id="b0e18e85-3123-462b-9589-5b9f4ce3d3f6">
        <source>setLogTreatment(_table : CM_EntryTable input; _treatmentCmb : ComboBox input; _grade : CM_LogGrade; _treatment : CM_LogTreatment);
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
