    <JadeMethod name="getOutturnData" id="b98a67a7-6c98-455f-b585-ed0914ff50d6">
        <source>getOutturnData( _changeInTotalQuantity : Integer output;
				_changeInTotalWeight : Decimal output;
				_over : Boolean output;
				_currentTotalQuantity : Integer output;
				_currentTotalWeight : Decimal output
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars

	ti : CM_TrackedItem;
	tiFoundOvers : Boolean;
	tiOverQty : Integer;
	tiOverWeight : Decimal [16,3];
	tiFoundUnders : Boolean;
	tiUnderQty : Integer;
	tiUnderWeight : Decimal [16,3];
	
	totFoundOvers : Boolean;
	totOverQty : Integer;
	totOverWeight : Decimal [16,3];
	totFoundUnders : Boolean;
	totUnderQty : Integer;
	totUnderWeight : Decimal [16,3];
	
	hasTrxMovement : Boolean;
	trxQty : Integer;
	trxWeight : Decimal [16,3];

begin

	foreach ti in self.allTrackedItems discreteLock do
		if ti.hasBeenMerged then	//18 Jan 2018	TFS 36698
			//ignore zombies
			continue;
		endif;
		if ti.isContainer then
			//ignore containers
			continue;
		endif;
		if ti.isChild and ti.myParent.isContainer then
			//ignore things in containers...
			continue;
		endif;
		/* 08 Jan 2018	NDL	TFS 8165
		if not ti.isImport then
		//Only process imports
			continue;
		endif;	*/
		//08 Jan 2018	NDL	TFS 8165
		if not ti.isDischargedFromCurrentVoyage() then
			totFoundUnders := true;
			totUnderQty := totUnderQty + ti.totalQuantity;
			totUnderWeight := totUnderWeight + ti.totalWeight;
			continue;
		endif;
		
		tiFoundOvers := ti.getBulkBreakBulkOverSupply( tiOverQty, tiOverWeight );
		if tiFoundOvers then
			totOverQty := totOverQty + tiOverQty;
			totOverWeight := totOverWeight + tiOverWeight;
			totFoundOvers := true;
		endif;
		tiFoundUnders := ti.getBulkBreakBulkUnderSupply( tiUnderQty, tiUnderWeight );
		if tiFoundUnders then
			totUnderQty := totUnderQty + tiUnderQty;
			totUnderWeight := totUnderWeight + tiUnderWeight;
			totFoundUnders := true;
		endif;
		_currentTotalQuantity := _currentTotalQuantity + ti.totalQuantity;
		_currentTotalWeight := _currentTotalWeight + ti.totalWeight;
	endforeach;
	
	//08 Jan 2018	NDL	TFS 8165 - Take into account stuff that has been transferred in and out.
	hasTrxMovement := self.getEmptyBOLDiscrepancyValue( trxQty, trxWeight );
	if hasTrxMovement then
		if trxQty &gt; 0 then
			totUnderQty := totUnderQty + trxQty;
			totUnderWeight := totUnderWeight + trxWeight;
			totFoundUnders := true;
		elseif trxQty&lt; 0 then
			totOverQty := totOverQty - trxQty;
			totOverWeight := totOverWeight - trxWeight;
			totFoundOvers := true;
		endif;
	endif;
	
	
	if not totFoundOvers and not totFoundUnders then
		//No descrepancies found
		_changeInTotalQuantity := 0;
		_changeInTotalWeight := 0;
		_over := false;
		return;
	endif;
	
	if totFoundOvers and not totFoundUnders then
		// only found over supply descrepancies
		_changeInTotalQuantity := totOverQty;
		_changeInTotalWeight := totOverWeight;
		_over := true;
		return;
	endif;
	
	if not totFoundOvers and totFoundUnders then
		// only found under supply descrepancies
		_changeInTotalQuantity := totUnderQty;
		_changeInTotalWeight := totUnderWeight;
		_over := false;
		return;
	endif;
	
	if totFoundOvers and totFoundUnders then
		// found both sorts
		if totOverQty = totUnderQty and totOverWeight = totUnderWeight then
			// they cancel each other out
			_changeInTotalQuantity := 0;
			_changeInTotalWeight := 0;
			_over := false;
			return;
		else
			//weight and quantity should be proportional, but just in case use the weight first,
			//then use the quantity.
			if totOverWeight &gt; totUnderWeight then
				_changeInTotalQuantity := totOverQty - totUnderQty;
				_changeInTotalWeight := totOverWeight - totUnderWeight;
				_over := true;
				return;
				
			elseif totUnderWeight &gt; totOverWeight then
				_changeInTotalQuantity := totUnderQty - totOverQty;
				_changeInTotalWeight := totUnderWeight - totOverWeight;
				_over := false;
				return;
				
			elseif totOverQty &gt; totUnderQty then
				_changeInTotalQuantity := totOverQty - totUnderQty;
				_changeInTotalWeight := totOverWeight - totUnderWeight;
				_over := true;
				return;
				
			elseif totUnderQty &gt; totOverQty then
				_changeInTotalQuantity := totUnderQty - totOverQty;
				_changeInTotalWeight := totUnderWeight - totOverWeight;
				_over := false;
				return;
				
			endif;
			
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_changeInTotalQuantity" type="Integer" usage="output"/>
        <Parameter name="_changeInTotalWeight" type="Decimal" usage="output"/>
        <Parameter name="_over" type="Boolean" usage="output"/>
        <Parameter name="_currentTotalQuantity" type="Integer" usage="output"/>
        <Parameter name="_currentTotalWeight" type="Decimal" usage="output"/>
    </JadeMethod>
