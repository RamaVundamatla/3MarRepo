    <JadeMethod name="tCoparnSNOMSK" id="e1a6b0cc-8eb7-40d3-ad36-2846453d6d0f">
        <source>tCoparnSNOMSK();
//
//03 April 2018	jlgrs1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "SNO_COPARN";
	VesselCode : String = "VENTO DI NORTADA";
	Voyage_Code : String = "GPS829W18";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "54348618";
	Prenote1 : String = "BSIU4067798";
vars
	terminal : CM_Terminal;
	oper : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	release : CM_BulkRelease;
	shipOperator : CM_Operator;
	cargoOperator : CM_Operator;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	terminal := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipOperator := app.myRoot.allOperators["BOEI"];
	cargoOperator := app.myRoot.allOperators["HLL"];
	self.deleteEDIOutwardXlation(Voyage_Code, XLATION_TYPE_VOYAGETERMINAL, shipOperator, null);
	self.deleteEDIOutwardXlation(Voyage_Code, XLATION_TYPE_VOYAGETERMINAL, cargoOperator, null);
//	self.deleteEDIInwardXlation("UTOP", XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation("HLX", XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation("EST", XLATION_TYPE_OPERATOR, null, null);
	self.createEDIXlation("GPS829W17", Voyage_Code, XLATION_TYPE_VOYAGETERMINAL, true, oper, null);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteBooking(BookingNo);
	booking := self.getBooking(BookingNo);
	self.assertIsDeleted(booking);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	beginTransaction;
	voyage.setPropertyValue("myOperator", shipOperator);
	voyage.allOperators.add(cargoOperator);
	commitTransaction;
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.createEDIXlation("GPS829W17", Voyage_Code, XLATION_TYPE_VOYAGETERMINAL, true, shipOperator, null);
	self.createEDIXlation("GPS829W17", Voyage_Code, XLATION_TYPE_VOYAGETERMINAL, true, cargoOperator, null);
//	self.createEDIXlation("HLX", "UTOP", XLATION_TYPE_OPERATOR, true, null, null);
	self.createEDIXlation("HLX", "HLL", XLATION_TYPE_OPERATOR, true, null, null);
	self.createEDIXlation("EST", "BOEI", XLATION_TYPE_OPERATOR, true, null, null);
		self.setTerminalConfig(EdiUseOldCoparn, false);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "HAPAG-LLOYDX", cargoOperator);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '126', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy (CM_EDIEDIFactRule.Item_RFF_1_1, '-', CM_EDIEDIFactRule.Function_RFF_1_1_RelNo);	
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy (CM_EDIEDIFactRule.Item_NAD_1_1, 'CF', CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper);	

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFileMSK();
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

/*	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
//	booking := self.getBooking(BookingNo);
//	self.assertNotNull(booking);

//	self.deleteBooking(BookingNo);
//	booking := self.getBooking(BookingNo);
//	self.assertIsDeleted(booking);
/*	coparnInput := self.zCoparnFileHLL("12", null);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	release := self.getReleaseRequest(BookingNo);
	self.assertNotNull(release);
	
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	coparnInput := self.zCoparnFileHLL("27", Prenote1);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"3"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
*/
	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 19);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	self.assertEqual(booking.bookingReference, BookingNo);
	self.assertEqual(booking.voyageCode, Voyage_Code);
	self.assertEqual(booking.vesselCode, VesselCode);
	self.assertEqual(booking.operatorCode, "MSK");
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.voyageCode, Voyage_Code);
	self.assertEqual(prenote.vesselCode, VesselCode);
	self.assertEqual(prenote.operatorCode, "MSK");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.deleteEDIInwardXlation("EST", XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIOutwardXlationFCode("EST", XLATION_TYPE_OPERATOR, null, null);
end;</source>
