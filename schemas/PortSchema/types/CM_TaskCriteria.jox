        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1d7bc4d-027f-4eb4-93b5-eaa5e0020fb3">
        <updating/>
        <source>setForUpdate(_proxy: CM_ObjectMatchCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	index: Integer;
begin
	self.allAutoApplyActions.clear();
	foreach index in 1 to _proxy.CM_TaskCriteria.allAutoApplyActions.size do
		self.allAutoApplyActions.add(_proxy.CM_TaskCriteria.allAutoApplyActions[index]);
	endforeach;
	self.moveOnCreation := _proxy.CM_TaskCriteria.moveOnCreation;
	self.moveOnCompletion := _proxy.CM_TaskCriteria.moveOnCompletion;
	self.myToDoTaskDesc := _proxy.CM_TaskCriteria.myToDoTaskDesc;
	self.myTerminal := _proxy.CM_TaskCriteria.myTerminal;
	
	// ### TFS 58761 (60739) 13Nov2023 NAVPW1
	self.allAvailableResourceGroups.clear();
	_proxy.CM_TaskCriteria.allAvailableResourceGroups.copyNoDups(self.allAvailableResourceGroups);
	self.allMandatoryResourceGroups.clear();
	_proxy.CM_TaskCriteria.allMandatoryResourceGroups.copyNoDups(self.allMandatoryResourceGroups);
	// ### TFS 58761 (60739) 13Nov2023 NAVPW1
	
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="b212fe46-9987-48de-a012-57d5eda8784b">
        <updating/>
        <source>setProxyBaseData(_allActions: IntegerArray; _completion, _creation: Integer; _terminal: CM_Terminal; _myToDoDesc: CM_ToDoTaskDesc; 
					_availableResourceTypeGroups, _mandatoryResourceTypeGroups : CM_ResourceTypeGroupByCode input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars

begin
	self.allAutoApplyActions.clear();
	if _allActions &lt;&gt; null then
		if _allActions.includes(TRANS_TYPE_REPAIR) then
			self.allAutoApplyActions.add(TRANS_TYPE_REPAIR);
		endif;
		if _allActions.includes(TRANS_TYPE_PackComplete) then
			self.allAutoApplyActions.add(TRANS_TYPE_PackComplete);
		endif;
		if _allActions.includes(TRANS_TYPE_UnpackComplete) then
			self.allAutoApplyActions.add(TRANS_TYPE_UnpackComplete);
		endif;
	endif;
	self.moveOnCreation := _creation;
	self.moveOnCompletion := _completion;
	self.myToDoTaskDesc := _myToDoDesc;
	self.myTerminal := _terminal;
	
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	self.allAvailableResourceGroups.clear();
	_availableResourceTypeGroups.copyNoDups(self.allAvailableResourceGroups);
	
	self.allMandatoryResourceGroups.clear();
	_mandatoryResourceTypeGroups.copyNoDups(self.allMandatoryResourceGroups);
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
epilog

end;</source>
        <Parameter name="_allActions" type="IntegerArray"/>
        <Parameter name="_completion" type="Integer"/>
        <Parameter name="_creation" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_myToDoDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_availableResourceTypeGroups" type="CM_ResourceTypeGroupByCode" usage="input"/>
        <Parameter name="_mandatoryResourceTypeGroups" type="CM_ResourceTypeGroupByCode" usage="input"/>
    </JadeMethod>
</Class>
