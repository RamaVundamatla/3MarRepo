//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
begin
	self.raiseExceptionIfNull(_pxyBOLOutHdr, 'BOL Out Header Proxy');
	self.raiseExceptionIfNull(_realBOLOutHdr, 'BOL Out Header Existing');
	_pxyBOLOutHdr.raiseExceptionIfNotProxy(method);
	
	if _pxyBOLOutHdr.bolNumber = _realBOLOutHdr.bolNumber then
		_pxyBOLOutHdr.validateForUpdate();
	else
		_pxyBOLOutHdr.validateForCreate();
	endif;

epilog
	
end;</source>
        <Parameter name="_realBOLOutHdr" type="CM_BOLOutHeader"/>
        <Parameter name="_pxyBOLOutHdr" type="CM_BOLOutHeader"/>
    </JadeMethod>
