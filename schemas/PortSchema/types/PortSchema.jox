    <JadeMethod name="returnProcessStackAsString" id="51445d4e-255e-40b0-acca-fcc77cb0e28b">
        <source>returnProcessStackAsString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2012	cnwndl1	Initial creation	Par 29404

*/

vars
	
	stack : HugeStringArray;
	str : String;
	retValue : String;

begin

	create stack transient;
	self.outputProcessStackToStringArry(stack);
	foreach str in stack do
		if retValue = null then
			retValue := str;
		else
			retValue := retValue &amp; "  " &amp; str;
		endif;
	endforeach;
	return retValue;

epilog

	delete stack;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
