    <JadeMethod name="checkFieldsNotNull" id="8c445076-f2c2-4870-bdee-26e4d073c8c4">
        <source>checkFieldsNotNull();
//--------------------------------------------------------------
//Created: 17 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.logID = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Log Id', ETRow_LogId, null);
		app.raiseCMException(Input_required_field_logId, ETRow_LogId, null);
	endif;
	if self.maxSED = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'SED Max', ETRow_SedMax, null);
		app.raiseCMException(Input_required_field_sedMax, ETRow_SedMax, null);
	endif;
	if self.minSED = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'SED Min', ETRow_SedMin, null);
		app.raiseCMException(Input_required_field_sedMin, ETRow_SedMin, null); // cnwdb2	PAR 35364


	endif;	
			
	if self.conditionCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Condition Code', ETRow_LogCondition, null);
		app.raiseCMException(Input_required_field_condCode, ETRow_LogCondition, null); // cnwdb2	PAR 35364
	endif;		
	
	if self.scalerCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Scaler Code', ETRow_ScalerCode, null);
	endif;	
							
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="421cb6e5-a025-4456-9d5d-2112f8a4c317">
        <updating/>
        <source>setForCreate(_pxy : CM_LogScalingDtl; _hdr : CM_LogScalingHdr) updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfTransient(method);

	self.conditionCode	:= _pxy.conditionCode;
	self.logID			:= _pxy.logID;
	self.maxSED			:= _pxy.maxSED;
	self.minSED			:= _pxy.minSED;
	self.scalerCode		:= _pxy.scalerCode;
	
	self.myLogScalingHdr	:= _hdr;

end;</source>
        <Parameter name="_pxy" type="CM_LogScalingDtl"/>
        <Parameter name="_hdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateProxy" id="c2bb1b6c-4557-441d-957e-76a28d7ecc5b">
        <updating/>
        <source>setForUpdateProxy(_logID, _conditionCode : String; _minSED, _maxSED : Decimal; _scalerCode : String) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.conditionCode	:= _conditionCode;
	self.logID			:= _logID;
	self.scalerCode		:= _scalerCode;
	
	if _maxSED &lt; _minSED then
		// Do a swap
		self.maxSED			:= _minSED;
		self.minSED			:= _maxSED;
	else
		self.maxSED			:= _maxSED;
		self.minSED			:= _minSED;
	endif;

end;</source>
        <Parameter name="_logID" type="String"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_minSED" type="Decimal"/>
        <Parameter name="_maxSED" type="Decimal"/>
        <Parameter name="_scalerCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHdrForProxy" id="3518f818-433e-443a-af24-0b4df81127d8">
        <updating/>
        <source>setHdrForProxy(_hdr : CM_LogScalingHdr) updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.myLogScalingHdr	:= _hdr;

end;</source>
        <Parameter name="_hdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="277d968f-c848-4699-b5e8-5c292d871231">
        <updating/>
        <source>setProxy(_logID, _conditionCode : String; _minSED, _maxSED : Decimal; _hdr : CM_LogScalingHdr; _scalerCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.conditionCode	:= _conditionCode;
	self.logID			:= _logID;
	
	// if they come through incorrectly then swap
	if _maxSED &lt; _minSED then
		self.maxSED		:= _minSED;
		self.minSED		:= _maxSED;
	else
		self.maxSED		:= _maxSED;
		self.minSED		:= _minSED;
	endif;
	self.scalerCode		:= _scalerCode;
	
	self.myLogScalingHdr	:= _hdr;

end;</source>
        <Parameter name="_logID" type="String"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_minSED" type="Decimal"/>
        <Parameter name="_maxSED" type="Decimal"/>
        <Parameter name="_hdr" type="CM_LogScalingHdr"/>
        <Parameter name="_scalerCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setScalerCode" id="ed760076-e60d-41a5-a000-5caf1b64338a">
        <updating/>
        <source>setScalerCode(_scalerCode : String) updating;

// cnwdvb1 02 December 2002 

vars

begin

	self.scalerCode := _scalerCode;

end;</source>
        <Parameter name="_scalerCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="74166d42-91e4-4953-bd89-da4130b23fd3">
        <source>validate();
//--------------------------------------------------------------
//Created: 08 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTi 		: CM_TrackedItem;
	terminal 	: CM_Terminal;
	sedUpperLimit	: Integer;
begin

	terminal := self.myLogScalingHdr.myTerminal;
	
	/*
	tmpTi := app.myRoot.lookupTrackedItem(self.logID, TI_CargoType_Log, TI_STATE_NORMAL, TI_SITE_ONSITE, 0, null);

	if tmpTi &lt;&gt; null then
		if tmpTi.myReceivalBOL.isMatched then
			app.raiseCMException2(TI_AlreadyReceived, self.logID, tmpTi.myReceivalBOL.number, ETRow_LogId, null);
		elseif tmpTi.myReceivalBOL.number &lt;&gt; self.myLogScalingHdr.bolNumber then
			app.raiseCMException2(TI_AlreadyReceived, self.logID, tmpTi.myReceivalBOL.number, ETRow_LogId, null);
		endif;
	endif;
	*/
	
	sedUpperLimit := terminal.getConfig(SedUpperLimit).Integer;
	if sedUpperLimit &gt; 0 then
		if self.maxSED &gt; sedUpperLimit then
			app.raiseCMException4(LogSEDUpperLimitExceeded, 'max', self.maxSED.String,
								  self.logID, sedUpperLimit.String, ETRow_SedMax, null);	
		endif;
		if self.minSED &gt; sedUpperLimit then
			app.raiseCMException4(LogSEDUpperLimitExceeded, 'min', self.minSED.String,
								  self.logID, sedUpperLimit.String, ETRow_SedMin, null);	
		endif;	
	endif;
	
end;</source>
    </JadeMethod>
</Class>
