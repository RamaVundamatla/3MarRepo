    <JadeMethod name="getSubTerminal" id="71133120-0ed1-4e16-86e8-1f7dbc0c5bef">
        <source>getSubTerminal(_subTerminalCode : String) : CM_SubTerminal;

/*

Purpose:		Get the required Sub Terminal if passed in value is null then default to "UT_Depot"

Date			Who		Reason
29/04/2014		cnwmh5	Initial creation

*/

vars

	subTerminal				: CM_SubTerminal;
	
	code					: String;

begin

	if _subTerminalCode = null then
		code := "UT_Depot";
	else	
		code := _subTerminalCode;
	endif;

	subTerminal := self.getTerminal().allSubTerminals[code];
	
	return subTerminal;
	
epilog

end;</source>
        <Parameter name="_subTerminalCode" type="String"/>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="getSystemAlert" id="c9de7b9d-8285-4089-ac58-0f3dc0e8c45b">
        <source>getSystemAlert(_alertType : Integer) : CM_SystemAlert;

/*

Purpose:		Get a system alert

Date			Who		Reason
05/02/2014		cnwmh5	Initial creation

*/

vars

	systemAlert					: CM_SystemAlert;
	alertType 					: CM_SystemAlertType;
	
	iter						: Iterator;

begin

	alertType := app.myRoot.allSystemAlertTypes[_alertType];
	if alertType &lt;&gt; null then
		foreach systemAlert in alertType.allSystemAlerts reversed, discreteLock do
			
			if self.opts.includesKey("TrackedItem") then
				if systemAlert.myTrackedItem = self.opts.obj("TrackedItem").CM_TrackedItem then
					break;
				endif;
			endif;		
			
		endforeach;	
	endif;

	return systemAlert;

epilog

	delete iter;

end;</source>
        <Parameter name="_alertType" type="Integer"/>
        <ReturnType type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="getTIsByCargoTypeNoTIId" id="ed969abe-6e14-4f9f-9569-6d40e36497f6">
        <source>getTIsByCargoTypeNoTIId(_cargoType : CM_CargoType; _clearTiArray : Boolean; _tiArray : CM_TIArray io);

/*

Purpose:		Get all TI's for a Cargo Type without a TI id.
				Will go through all terminals and all voyages to 
				see where it is used

Date			Who		Reason
05/11/2014		cnwmh5	Initial creation

*/

vars

	terminal						: CM_Terminal;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	
	iter							: Iterator;
	iter2							: Iterator;
	mergeIter						: MergeIterator;

begin

	if _clearTiArray then
		_tiArray.clear();
	endif;

	terminal := self.getTerminal();
	
	iter := terminal.allVoyagesByCode.createIterator;
	while iter.next(voyage) do
	
		delete mergeIter;
		create mergeIter transient;
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);	
		mergeIter.addCollection(voyage.allOnshipTIsByCargoTypeId);
		mergeIter.startKeyGeq(_cargoType.id, null);
		
		while mergeIter.next(ti) do
			if ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			_tiArray.add(ti);
		endwhile;
		
		delete iter2;
		iter2 := terminal.allOffsiteTIsByCargoTypeId.createIterator;
		terminal.allOffsiteTIsByCargoTypeId.startKeyGeq(_cargoType.id, null, null, iter2);
		while iter2.next(ti) do
			if ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			_tiArray.add(ti);
		endwhile;
		
	endwhile;

epilog

	delete iter;
	delete iter2;
	delete mergeIter;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_clearTiArray" type="Boolean"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="784c0108-3ee2-4fcd-9207-ea3009487942">
        <source>getTerminal() : CM_Terminal;
// 04/07/2011 cnwmh5 Change so can return terminal other than UT
vars
	terminal				: CM_Terminal;
begin

	if self.opts.includesKey("Terminal") then
		terminal := CM_Root.firstInstance.allTerminals[self.opts.str("Terminal")];
	else	
		terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	endif;
	
	if terminal &lt;&gt; null and self.allTerminalsUsed &lt;&gt; null and not self.allTerminalsUsed.includes(terminal) then		// 01/07/2013 cnwmh5
	///if self.allTerminalsUsed &lt;&gt; null and not self.allTerminalsUsed.includes(terminal) then
		self.allTerminalsUsed.add(terminal);
	endif;
	
	return terminal;
	
epilog
	
end;
</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
