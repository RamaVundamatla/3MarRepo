<Class name="CM_YAPriority" id="45d0c77f-ac7e-426c-b0af-2afcf67be5c3">
    <superclass name="CM_YACriteriaPriority"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="myTerminal" id="e89dc3ac-32fc-4f64-9c29-6f1592ab0e46">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allYAPriorities"/>
    </ExplicitInverseRef>
    <JadeMethod name="getMyTerminal" id="37d5fd66-4639-4410-8428-6a3a2c3a8d8c">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     01 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.myTerminal;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getYAPriorityValueForCMIF" id="b79b7e8b-0e07-4938-83d1-7e29ca4b8a71">
        <source>getYAPriorityValueForCMIF(_cmifAutoPlan : CMIF_YAAutoPlan; _yaAgent : CM_YAAutoplanAgent input) : Real;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myYACriteriaType.isCMIFDataMatch(_cmifAutoPlan, self.myYAData) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Item has ' &amp; self.myYACriteriaType.getDescriptionWithData(self.myYAData) &amp; ' received priority value of ' &amp; self.priorityValue.String, false);
		return self.priorityValue;
	endif;
	return 0;

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getYAPriorityValueForCriteria" id="29506ac3-d31d-4825-9faf-b67eda3d5892">
        <source>getYAPriorityValueForCriteria(_yaCriteria : CM_YACriteria) : Real;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
/*	This method calls the data comparisson methods 
	and returns priorityValue if there has been 
	a successful match */
vars

	myData : CM_YAData;

begin

	myData := self.myYAData;
	
	self.sharedLock(myData);
	
	if myData.doDataComparison(_yaCriteria.myYAData) then
		return self.priorityValue;
	endif;
	
	return 0;
	
epilog
	self.unlock(myData);
end;</source>
        <Parameter name="_yaCriteria" type="CM_YACriteria"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="28d35550-f7c6-4272-8eaa-9f9dc524dbe1">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Deep clone the receiver.
//
// Parameters:	None
//
// Returns:		A reference to a transient clone of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj			:=	inheritMethod();
	proxyObj.myTerminal	:=	self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="aab3dcae-1492-460d-b132-d673cd8f077f">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForUpdate(pProxyObj);
	
	self.myTerminal	:=	app.getMyTerminalDO_NOT_USE();
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
</Class>
