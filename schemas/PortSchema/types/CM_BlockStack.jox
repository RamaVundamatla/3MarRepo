    <JadeMethod name="getExtraInfo" id="89c503cd-08e5-4d66-91c1-56ac5cf4f730">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------
//TFS2333 	cnwns1	15/07/16	Multi-timezone issues


vars
	aTI 		: CM_TrackedItem;
	infoString 	: String;
	block 		: CM_DataContainerBlock;
	bc 			: CM_BlockController;
	fifoTS 		: TimeStamp;
	cleanTS 	: TimeStamp;
begin
	//inheritMethod(_dataContainer);	// 26/09/2014 cnwar2 #33907 - move to bottom
	bc := self.myLocationsController;
	if bc &lt;&gt; null then
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Number_Of_Items), DC_Label, 1, null);
		block.addNewItem(bc.allTrackedItemsById.size.String, DC_Data, 1, null);

		if bc.myLocationRestriction &lt;&gt; null then
			infoString := bc.myLocationRestriction.getRestrictionAsString;
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Location_Restriction), DC_Label, 1, null);
			block.addNewItem(infoString, DC_Data, 1, null);
		endif;
	
		/*if bc.allTrackedItemsById.size &lt;&gt; 0 then
			block := _dataContainer.addNewBlock;
			block.addNewItem("", DC_Label, 1, null);
			block.addNewItem("", DC_Data, 1, null);

		// DVB changed not to add in tracked items.
			foreach aTI in bc.allTrackedItemsById do
				block := _dataContainer.addNewBlock;
				block.addNewItem($CM_Tracked_Item, DC_Label, 1, aTI);
				block.addNewItem(aTI.id, DC_Data, 1, aTI);
			endforeach;
		endif;*/
	endif;
	if self.effectiveFIFODate.isValid then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_FIFO_Effective_Date), DC_Label, 1, null);
		fifoTS.cnEcSetDateAndTime(self.effectiveFIFODate,TimeStartOfDay);							//TFS2333 	cnwns1	15/07/16	Multi-timezone issues
		block.addNewItem(self.systemToLocalTime(fifoTS).date().shortFormatJMT(), DC_Data, 1, null);	//TFS2333 	cnwns1	15/07/16	Multi-timezone issues
	endif;
	if self.effectiveCleanDate.isValid then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Cleaned_Effective_Date), DC_Label, 1, null);
		cleanTS.cnEcSetDateAndTime(self.effectiveCleanDate,TimeStartOfDay);							//TFS2333 	cnwns1	15/07/16	Multi-timezone issues
		block.addNewItem(self.systemToLocalTime(cleanTS).date().shortFormatJMT(), DC_Data, 1, null);//TFS2333 	cnwns1	15/07/16	Multi-timezone issues
	endif;
	if self.maxCapacity &lt;&gt; 0 then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Max_Capacity), DC_Label, 1, null);
		block.addNewItem(self.maxCapacity.String, DC_Data, 1, null);
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Overlapped), DC_Label, 1, null);
	block.addNewItem(self.isOverlapped.getYesNo.String, DC_Data, 1, null);
	if self.testIsFull() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Flagged_Full), DC_Label, 1, null);
		block.addNewItem(self.isFull.getYesNo, DC_Data, 1, null);
	endif;
	
	inheritMethod(_dataContainer);	// 26/09/2014 cnwar2 #33907
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
