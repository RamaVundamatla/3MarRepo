    <JadeMethod name="setCaptionForModes" id="58db08bf-7946-4852-8ee2-e80a537dcfd4">
        <updating/>
        <source>setCaptionForModes(_theMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/3/2010	cnwjo3		par 23105
// ---------------------------------------------------------------------------
vars
	theString : String;
	invalid : Boolean;
	vCode : String;
	voyage : CM_Voyage;
begin
	theString := self.setCaptionForModesGetView(_theMode);

	voyage := self.myCurrentVoyage;
	if voyage &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,voyage,invalid);
		vCode := voyage.code;
		vCode := voyage.code &amp; " - " &amp; voyage.vesselName &amp; " (" &amp; voyage.starboardBerthedRWD() &amp; ")";
	endif;
	
	if invalid then
		voyage := null;
		self.myCurrentVoyage := null;  //if I null the invalid object here it will avoid errors in a couple of other areas too
	endif;
	
	if voyage &lt;&gt; null then
		 theString := vCode.trimBlanks &amp; " - " &amp; theString; // &amp; " " &amp; self.myCurrentVoyage.vesselName.trimBlanks &amp; " " ;
		self.setNavigatorHeading(vCode.trimBlanks); // NAVIGATOR
	endif;
	self.setCaption(theString); //epr TFS 2362 4/8/16
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCaptionForModesGetView" id="5b6174cb-e17d-4c07-b6a1-e631dc16aeb4">
        <source>setCaptionForModesGetView(_theMode : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpString, theString : String;
begin
	if self.myBayDrawingController = null then
		return null;
	endif;
	
	if self.myBayDrawingController.printWorked &gt; 0 then	//09 Feb 2018	NDL	TFS 36914
		if self.myBayDrawingController.printWorked = SHP_BayDrawingController.PrintWorkedLoad then
			theString := theString &amp; " " &amp; app.getErrorString(Worked_load) &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode); 
		elseif self.myBayDrawingController.printWorked = SHP_BayDrawingController.PrintWorkedDischarge then
			theString := theString &amp; " " &amp; app.getErrorString(Worked_discharge) &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode); 
		elseif self.myBayDrawingController.printWorked = SHP_BayDrawingController.PrintWorkedBoth then
			theString := theString &amp; " " &amp; app.getErrorString(Worked_load_discharge) &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode); 
		endif;
		
	elseif _theMode = ShpDisplayMode_Actual then
		theString := theString &amp; " " &amp; $SHP_ACTUAL_Bay_View &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode); 
		
	elseif _theMode = ShpDisplayMode_EDI then
		if self.myCurrentEDIBayPlan = null then
			theString := theString &amp; " " &amp; $SHP_EDI_Bay_View &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode) &amp; " - no current EDI"; 
		else
			theString := theString &amp; " " &amp; $SHP_EDI_Bay_View &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode) &amp; " " &amp; self.myCurrentEDIBayPlan.shortDescription; 
		endif;
	elseif _theMode = ShpDisplayMode_Defn then 
		theString := theString &amp; " " &amp; $SHP_DEFINITION_Bay_View; 
		
	elseif _theMode = ShpDisplayMode_Proposed then 
		theString := theString &amp; " " &amp; $SHP_PROPOSED_Bay_View &amp; ", by " &amp; app.getViewModeString(self.myBayDrawingController.viewMode); 

	elseif _theMode = ShpDisplayMode_ColCodeDisch then 
		if self.workingMode = WorkMode_Job then
			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp; $SHP_JOB &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		elseif self.workingMode = WorkMode_Plan then
			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp;  $SHP_PLANNING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		elseif self.workingMode = WorkMode_CustomSeq then
			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp;  $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
			
		else
			theString := theString &amp; " " &amp; $SHP_DISCHARGE &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
		endif;

	elseif _theMode = ShpDisplayMode_ColCodeLoad then 
		// PAR 23426
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.useVoyageAllocations then
			tmpString := " Allocations";
		else
			tmpString := $SHP_By_Discharge_Port;
		endif;
		
		if self.workingMode = WorkMode_Job then
			theString := theString &amp; " " &amp; $SHP_LOAD &amp; $SHP_JOB &amp; $SHP_Mode &amp; tmpString;
			
		elseif self.workingMode = WorkMode_Plan then
			theString := theString &amp; " " &amp; $SHP_LOAD &amp;  $SHP_PLANNING &amp; $SHP_Mode &amp;  tmpString;
			
		elseif self.workingMode = WorkMode_CustomSeq then
			theString := theString &amp; " " &amp; $SHP_LOAD &amp;  $SHP_CUSTOM_SEQUENCING &amp; $SHP_Mode &amp;  tmpString;
			
		else
			theString := theString &amp; " " &amp; $SHP_LOAD &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp; tmpString;
		endif;
		
	elseif _theMode = ShpDisplayMode_VoyGlobProposed then
		if self.myCurrentVoyageInterTerm = null then
			theString := theString &amp; " " &amp; "Proposed" &amp; " " &amp; $SHP_InterTerminalVoyView &amp; " - " &amp; $SHP_NoInterTermVoyage; 
		else
			theString := theString &amp; " " &amp; "Proposed" &amp; " " &amp; $SHP_InterTerminalVoyView &amp; " - " &amp; self.myCurrentVoyageInterTerm.code  &amp; " @ " &amp; self.myCurrentVoyageInterTerm.myTerminal.name; 
		endif;
		
	elseif _theMode = ShpDisplayMode_VoyGlobActual then
		if self.myCurrentVoyageInterTerm = null then
			theString := theString &amp; " " &amp; "Actual" &amp; " " &amp; $SHP_InterTerminalVoyView &amp; " - " &amp; $SHP_NoInterTermVoyage; 
		else
			theString := theString &amp; " " &amp; "Actual" &amp; " " &amp; $SHP_InterTerminalVoyView &amp; " - " &amp; self.myCurrentVoyageInterTerm.code  &amp; " @ " &amp; self.myCurrentVoyageInterTerm.myTerminal.name; 
		endif;
	endif;
	
	if (_theMode = ShpDisplayMode_ColCodeDisch or _theMode = ShpDisplayMode_ColCodeLoad) and self.btnTwinLiftCrane.visible then
		if self.btnTwinLiftCrane.userObject = null then
			if self.btnTwinLiftCrane.value then
				theString := theString &amp; ', ' &amp; 'Twin Lift Mode ';
			else
				theString := theString &amp; ', ' &amp; 'Single Lift Mode ';
			endif;
		endif;
		self.btnTwinLiftCrane.userObject := null; // PAR 14810 This is to stop it showing the mode the first time into Planning mode.
	endif;
//	theString := theString &amp; " ";
	return theString;	

end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="5406284c-2f9a-4fe5-9890-3d4887b71105">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor := self.backColor;
	
	self.frmSelectVoyage.backColor	:= tmpBackColor;
	self.frmAutoDischCC.backColor	:= tmpBackColor;
	self.frmPrintConfirm.backColor	:= tmpBackColor;
	self.frmHatchLidJob.backColor	:= tmpBackColor;
	self.frmTips.backColor	:= tmpBackColor;
	self.frmSeedJob.backColor	:= tmpBackColor;
	self.frmPopupInfo.backColor := tmpBackColor;
	self.frmVoyGlobalMode.backColor := tmpBackColor;
	
	self.frmTipsLegend01.drawFillColor := Blue;
	self.frmTipsLegend01.autoRedraw := true;
	self.frmTipsLegend01.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
	self.frmTipsLegend01.drawFilledRectangle(0,0,frmTipsLegend01.width,frmTipsLegend01.height,Blue);

	self.frmTipsLegend02.drawFillColor := Green;
	self.frmTipsLegend02.autoRedraw := true;
	self.frmTipsLegend02.drawFillStyle := Frame.DrawFillStyle_Cross;
	self.frmTipsLegend02.drawFilledRectangle(0,0,frmTipsLegend02.width,frmTipsLegend02.height,Green);

end;</source>
