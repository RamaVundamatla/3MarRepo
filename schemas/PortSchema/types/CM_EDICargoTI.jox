    <JadeMethod name="verifyVolume" id="c6401247-f013-47cc-90c7-0b2bf7fbaeb0">
        <updating/>
        <source>verifyVolume() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	04 August 2006 By cnwth2

Purpose:	
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Aug 2017	cnwma1	TFS #5695	STWO - Re-Calculate Volumes on Forms and EDI
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
============================================================================*/
vars
	calcVolume	: Decimal[22,4];
	cargoType 	: CM_CargoType;
	product 	: CM_Product;
begin
	if self.length = null or self.height = null or self.width = null then
		return;
	endif;
	
	cargoType:= self.getCargoTypeObj();			// 14.8.2017 cnwma1 TFS #5695
	
	if cargoType &lt;&gt; null then
		product := cargoType.allProducts[null,self.product];
	else
		product := self.getProduct(self.operatorCode, self.product);  // 14.8.2017 cnwma1 TFS #5695		// jlgka1 TFS 44416
	endif;
	
	if cargoType &lt;&gt; null and  			// 14.8.2017 cnwma1 TFS #5027
	 (cargoType.isBreakBulk or cargoType.isBulk) and 
	cargoType.allowAutoVolumeCalc and 
	(product &lt;&gt; null and not product.autoVolumeCalculate) then
		calcVolume := ((self.height/100) * (self.width/100) * (self.length/100)) * self.quantity.max(1) * self.totalQuantity.max(1);
	else
		
		calcVolume := ((self.height/100) * (self.width/100) * (self.length/100));
	endif;
	if self.volume &lt;&gt; null and calcVolume &lt;&gt; null and self.volume &lt;&gt; calcVolume then
		app.raiseCMWarning2(ERR_FIELD_VOLUME, self.volume.String, ' calculated volume differs from field value ', ETRow_Volume, self, self);
	elseif self.volume = null and calcVolume &lt;&gt; null then
		self.volume := calcVolume;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyVoyage" id="3cc610a1-0bdd-405b-952e-ca6553ef4471">
        <updating/>
        <source>verifyVoyage( _terminal : CM_Terminal; _site : Integer ) : CM_Voyage updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
04/02/2014	cnwah9	par 33402
	
----------   ----------  --------------------------------------------------
*/
vars
	voyageCodeStr	: String;
	voyage			: CM_Voyage;
	port			: CM_Port;
	
begin
//	if self.voyageCode = null then		// cnwrl1 09/06/2010 PAR 24299 - what it was
	voyageCodeStr	:= self.getVoyageCode();
	
//cnwah9 par 33402 04/02/2014
	if voyageCodeStr = null then
		if _site = TI_SITE_ONSHIP then
	
		else
			return null;
		endif;
	endif;
	
//	voyage := _terminal.lookupVoyage(self.voyageCode, null, false);
	voyage := _terminal.lookupVoyage(voyageCodeStr, null, false);

	if voyage = null then
		
		//epr par 32677 13/11/13  was only raising error when on ship else warning now always an error as the load db errors.
		//if _site = TI_SITE_ONSHIP then
//			app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, ETRow_VoyageCode, null);	// cnwrl1 09/03/2010 PAR 23008 - what it was
			app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self);
		//else
//			app.raiseCMWarning1(ERR_INVALID_VOYAGE, self.voyageCode, ETRow_VoyageCode, null, self);	// cnwrl1 09/03/2010 PAR 23008 - what it was
		//	app.raiseCMWarning1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self, self);
		//endif;
	endif;
	
	// cnwrl1 10/05/2010 PAR 24061 - start of coding
	// Need to make sure the the DischargePort (if entered) is valid for the Voyage selected.
	if voyage &lt;&gt; null and self.dischargePort &lt;&gt; null then
		port	:= app.myRoot.allPorts[ self.dischargePort ];
		if port &lt;&gt; null and not voyage.allPorts.includes( port ) then
			// NOTE: The DischargePort should never be an invalid Port due to previous checks in method verifyPorts.
			app.raiseCMException2( ERR_DISCHARGE_VOYAGE, self.dischargePort, voyage.code, ETRow_DischargePort, self );
		endif;
	endif;
	// cnwrl1 10/05/2010 PAR 24061 - end of coding
	
epilog
	return voyage;
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_site" type="Integer"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
