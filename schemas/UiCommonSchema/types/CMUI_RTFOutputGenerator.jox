    </Constant>
    <ImplicitInverseRef name="allControlsByFrame" id="e24ee284-4ff9-441b-826d-9009518dcdd3">
        <embedded/>
        <type name="DynaDictionary"/>
        <access>protected</access>
        <text>This is a collection of DynaDictionaries keyed by frame name.
The member collections are collections of controls keyed by type 
(lines first then labels), top position and left position.
The member collections give the order of output for controls
within a frame.</text>
    </ImplicitInverseRef>
