    <JadeMethod name="doSaveSettingsOnExit" id="39a2343a-d232-4fba-a9a7-ba46ce0d7d1d">
        <source>doSaveSettingsOnExit(_user : CM_User);
/* ---------------------------------------------------------------------------
Created:     24 August 2010 by cnwrs2

Purpose:     PAR 24899 - Implement saved window settings for Mobile Devices
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
// ***************************************************************************
// This is similar to method UiCommonSchema::UiCommonSchema::doSaveSettingsOnExit.  
// Changes to this method may also need to be done in that method
// ***************************************************************************

vars
	tmpForm			: Form;
	tmpBaseForm		: MOB_BaseForm;
	idx				: Integer;
	user			: CM_User;
	transUserWindow : CM_UserWindowForOpen;
	menuUserDtl		: CM_MenuUserDtl;
	pxyUserWin		: CM_UserWindowForStartup;
	tmpUserWinSet	: CM_UserWindowForStartupSet;
	str 			: String;
begin
	if app.isSDSSecondaryDB() then	//cnwrs1 nov 2005 make JMTTerminal work on SDSsecondary
		return;
	endif;
	
	//user := app.getMyUser();
	user := _user;
	if user = null then
		return;
	endif;

	create tmpUserWinSet transient;

	foreach idx in 1 to app.formsCount do
		tmpForm := app.forms(idx);
		
		if (not tmpForm.visible) then
			continue;
		endif;

		if (not MOB_BaseForm.hasInstance(tmpForm)) then
			continue;
		endif;
		
		tmpBaseForm := tmpForm.MOB_BaseForm;
		
		if (not tmpBaseForm.isAllowedForSaveOnExit()) then
			continue;
		endif;

		transUserWindow := app.getUserWindow(tmpBaseForm.name, true);
		transUserWindow.setProxy(user,
							tmpBaseForm.name,
							tmpBaseForm.getXMLSettingsForSave(),
							tmpBaseForm.top,
							tmpBaseForm.left,
							tmpBaseForm.width,
							tmpBaseForm.height,
							tmpBaseForm.windowState);
	endforeach;
	
	app.myTrxUA.trxUpdateUserSettingsOnExitMOB(user, app.allUserWindows, app.myPassport);
	
epilog
	if tmpUserWinSet &lt;&gt; null then
		tmpUserWinSet.purge();
		delete tmpUserWinSet;
	endif;
	
	self.allUserWindows.purge;

end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
