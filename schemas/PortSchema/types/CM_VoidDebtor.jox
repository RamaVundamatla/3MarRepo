<Class name="CM_VoidDebtor" id="e7bc2634-f80a-47f2-a996-34f904bba4f7">
    <superclass name="CM_Debtor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The system-defined default debtor</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="initialise" id="5a8f02cf-76ff-4569-9c40-3f5defe5435a">
        <source>initialise();

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	operator : CM_Operator;
	consign : CM_ConsigneeConsignor;

begin

	foreach operator in app.myRoot.allOperators do
		if operator.debtor = null then		// or not global.isValidObject(operator.debtor) then - inversed, can't be invalid
			operator.debtor := self;
		endif;
	endforeach;

	foreach consign in app.myRoot.allConsigneeConsignors do
		if consign.debtor = null then		// or not global.isValidObject(consign.debtor) then - inversed
			consign.setDebtor(self);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
