    <JadeMethod name="addEventRequestsForStop" id="80d5abd6-1e22-4b71-9620-5c64e36b2c37">
        <source>addEventRequestsForStop(	_stopTableTemplate : CM_StopTableTemplate input;
							_remove : Boolean;
							_grade : CM_MTGrade;
							_remarks : String;
							_toDo : CM_ToDoTaskDesc;
							_weight : Decimal
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	eventRequestForStops : CM_EventRequestForStop;

begin

	if _stopTableTemplate = null then
		return;
	endif;
	
	if _remove then
		beginTransaction;
		_stopTableTemplate.allEventRequests.purge();
		commitTransaction;
		
	else
		
		if _grade &lt;&gt; null then
			beginTransaction;
			create eventRequestForStops persistent;
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::type.name, EventRequestTypeGrade );
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::myGrade.name, _grade );									
			eventRequestForStops.setMyStopTemplate( _stopTableTemplate );
			commitTransaction;
		endif;
		if _remarks &lt;&gt; null then
			beginTransaction;
			create eventRequestForStops persistent;
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::type.name, EventRequestTypeRemarks );
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::cargoRemarks.name, _remarks );									
			eventRequestForStops.setMyStopTemplate( _stopTableTemplate );
			commitTransaction;
		endif;
		if _toDo &lt;&gt; null then
			beginTransaction;
			create eventRequestForStops persistent;
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::type.name, EventRequestTypeToDo );
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::myToDoTaskDesc.name, _toDo );									
			eventRequestForStops.setMyStopTemplate( _stopTableTemplate );
			commitTransaction;
		endif;
		if _weight &gt; 0 then
			beginTransaction;
			create eventRequestForStops persistent;
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::type.name, EventRequestTypeWeight );
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::totalWeight.name, _weight );	
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::isWeightCertified.name, true );	
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::weightCertifiedName.name, "WeightCertifiedName" );	
			eventRequestForStops.setPropertyValue( CM_EventRequestForStop::reference.name, "Reference" );	
			eventRequestForStops.setMyStopTemplate( _stopTableTemplate );
			commitTransaction;
		endif;
	
	endif;

epilog

	abortTransaction;

end;</source>
        <Parameter name="_stopTableTemplate" type="CM_StopTableTemplate" usage="input"/>
        <Parameter name="_remove" type="Boolean"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_toDo" type="CM_ToDoTaskDesc"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addEventType" id="a0e180c7-1629-4b33-9088-e2d978ac4c3b">
        <source>addEventType(_eCategory : Integer; _eName : String; _eDescription : String; _eColour : Integer; _eErrorsWarnings : ObjectArray) : CM_EventType;
// --------------------------------------------------------------------------------
// Created:		03 Novemeber 2009 by cnwjo3
//
// Purpose:		Add a new Event type.  Basically emulate System Admin::Event Types
// 29/08/2022	jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
vars
	newEvent					: CM_EventType;
	pxyET						: CM_EventType;
	validEventType				: Boolean;
	etNo						: Integer;
	errorWarning				: Object;
	pxyErrorWarning 			: CM_InterestedWarning;
	weightType 					: CM_MeasurementType;
	weightTypeStr 				: String;
	amtDecPlaces				: Integer;
	startEndDateTimeRequired 	: Boolean;
begin
	//yeah, i know.  Its a weird way of doing it.. but at least you can understand it.
	if _eCategory = CM_EventType.SYSTEM_EVENT then
		//actually i don't think we should really allow system events.... bah again!
		validEventType  := true;
	elseif _eCategory = CM_EventType.WARNING_EVENT then
		//actually at this point we could check if errorsWarnings array has been set.  bah!
		validEventType := true;
	elseif _eCategory =  CM_EventType.TRAIN_EVENT then 
		validEventType := true;
	elseif _eCategory =  CM_EventType.VOYAGE_EVENT then 
		validEventType := true;
	endif;

	if not validEventType then
		return null;
	endif;
	
	if self.opts.includesKey("WeightType") then
		weightTypeStr := self.opts.str("WeightType");
		weightType := app.myRoot.allMeasurementTypesByShortName[weightTypeStr];
		if weightType &lt;&gt; null and weightType.measurementType &lt;&gt; Type_Weight then
			weightType := null;
		endif;
	endif;
	
	if self.opts.includesKey("DecimalPlace") then
		amtDecPlaces := self.opts.int("DecimalPlace");
	endif;
	if self.opts.includesKey("StartEndDateTimeRequired") then
		startEndDateTimeRequired := self.opts.bool("StartEndDateTimeRequired");
	endif;	
	
	create pxyET transient;
	etNo := pxyET.getNextTypeInteger();
	pxyET.setProxy(etNo, _eName, _eDescription, pxyET.classNameToCreate, _eColour, _eCategory, app.myRoot,amtDecPlaces,startEndDateTimeRequired,null);
	
	if weightType &lt;&gt; null then
		pxyET.setShowWeight(true);
		pxyET.setMyWeightType(weightType);
	endif;
		
	if not app.myPassport.trxCompletedOK() then
		return null;  //looks like proxy event type couldn't be created for some reason
	endif;

	if _eErrorsWarnings &lt;&gt; null then
		foreach errorWarning in _eErrorsWarnings do
			create pxyErrorWarning transient;
			pxyErrorWarning.setProxy(errorWarning.XLAT_Translation.myTranslatableText.number);
			pxyErrorWarning.addEventType(pxyET);
		endforeach;
	endif;
	
	//we only add.
	app.myTrxCA.trxCreateEventType(pxyET, newEvent, app.myPassport);
	
	if not app.myPassport.trxCompletedOK() then
		return null;  //looks like proxy event type couldn't be created for some reason
	endif;
	
	return newEvent;
epilog
	delete pxyErrorWarning;
	delete pxyET;
end;</source>
        <Parameter name="_eCategory" type="Integer"/>
        <Parameter name="_eName" type="String"/>
        <Parameter name="_eDescription" type="String"/>
        <Parameter name="_eColour" type="Integer"/>
        <Parameter name="_eErrorsWarnings" type="ObjectArray"/>
        <ReturnType type="CM_EventType"/>
    </JadeMethod>
