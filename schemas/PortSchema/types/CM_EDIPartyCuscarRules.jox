<Class name="CM_EDIPartyCuscarRules" id="cabe6381-1427-4c5a-ae74-59284a265462">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="ediTypeShipManifest" id="6edc400b-463b-4c53-8126-bd04d4e18518">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myChildCargoTypeDefault" id="4ac87822-3caa-4d68-bc7a-80d55d2f87da">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CargoType"/>
        <access>readonly</access>
        <Inverse name="CM_CargoType::allEDIPartyRules"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="69d2b8d8-9b6e-4b27-b9d3-82bcd3f547f2">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2014	cnwrd1	Initial creation

*/

vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_CusCar, null);
	
	if type = null or type.type &lt;&gt; EDIFileType_CusCar then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'CUSCAR file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="19924a6e-cb81-4212-b34a-18e3d3738418">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2014	cnwrd1	Initial creation

*/

vars
	proxy	:CM_EDIPartyCuscarRules;
begin
	proxy :=  inheritMethod();
	
	proxy.ediTypeShipManifest := self.ediTypeShipManifest;
	proxy.myChildCargoTypeDefault := self.myChildCargoTypeDefault; //cnwrd1 par 34193
	
	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0e2b93fd-eaea-4d62-bb95-e56e63f7eff7">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyCuscarRules) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2014	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
	
	self.ediTypeShipManifest := _proxy.ediTypeShipManifest;
	self.myChildCargoTypeDefault := _proxy.myChildCargoTypeDefault; //cnwrd1 par 34193
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyCuscarRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e6e1a198-6cc4-4953-b56a-5dbad81a4d43">
        <updating/>
        <source>setProxy( _aCargoType : CM_CargoType ; _ediTypeShipManifest : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2014	cnwrd1	Initial creation

*/

vars

begin
	self.myChildCargoTypeDefault := _aCargoType; //cnwrd1 par 34193
	self.ediTypeShipManifest := _ediTypeShipManifest;
epilog

end;</source>
        <Parameter name="_aCargoType" type="CM_CargoType"/>
