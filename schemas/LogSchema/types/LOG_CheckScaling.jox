    <JadeMethod name="createCheckScalingData" id="83ed4e64-f232-4c13-bd6a-071f16e8b319">
        <source>createCheckScalingData() protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	frm			: LOG_CreateCheckScaleData;
begin
	create frm transient;
	
	frm := app.getForm(frm.name).LOG_CreateCheckScaleData;
	
	if frm = null then
		app.loadForm(LOG_CreateCheckScaleData,
					LOG_Assistant,
					false,
					false,
					false,
					self.myTerminal,
					self.myMasterMenuAction);
	endif;
	frm.myTerminal := self.myTerminal;
	frm.show;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteDtl" id="817cd096-342c-4393-a666-305d0d34fefa">
        <updating/>
        <source>doDeleteDtl() protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	scaleDtl			: CM_LogCheckScaleDtl;
begin
	scaleDtl := self.tblThumbData.accessRow(self.tblThumbData.row).itemObject.CM_LogCheckScaleDtl;
	
	if scaleDtl = null then
		app.msgBox('Please select a check scaling detail to delete','Nothing selected', 0);
		return;
	endif;	

	if app.msgBox('Are you sure you want delete line ' &amp; scaleDtl.logId &amp; '?', 'Are you sure', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	app.myTrxDA.trxDeleteCheckScalingDtl(scaleDtl, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog('Delete check scaling detail', app.myPassport, null);
		return;
	endif;

	self.showThumbnailData(self.myCurrentObject);	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteHdr" id="eb7dc587-2ffa-4a25-9068-34fb3c712637">
        <source>doDeleteHdr() protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	chkScaleHdr				: CM_LogCheckScaleHdr;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentObject = null then
		app.msgBox('Please select a check scaling header to delete','Nothing selected', 0);
		return;
	endif;
	
	chkScaleHdr := self.myCurrentObject.CM_LogCheckScaleHdr;
	
	if app.msgBox('Are you sure you want to delete check scale header ' &amp; chkScaleHdr.batchNoDescr &amp; '?','Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCheckScalingBatch(chkScaleHdr, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Delete check scaling header', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadCmbScaler" id="6676292e-978d-4ed9-a7f9-6b5f554b97ec">
        <source>doLoadCmbScaler() protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.cmbScaler.clear();
	self.cmbScaler.listCollection(app.myRoot.allUsers, true, 0);
	self.cmbScaler.listIndex := 1;
	
	self.cmbUser.clear();
	self.cmbUser.listCollectionWithAny(app.myRoot.allUsers, ETRow_Code);
	self.cmbUser.listIndex := 1;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="6a7da0f8-e515-4571-9a71-97daa9a54177">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin

	inheritMethod;

	self.tblThumbData.left := Gap;
	self.tblThumbData.top := self.tblThumbData.parent.top + Gap;
	self.tblThumbData.height := self.tblThumbData.parent.height - (Gap * 2);
	self.tblThumbData.width := self.tblThumbData.parent.width - (Gap * 2);
//	self.sptMain.cnEcResizeContents();
	
 	//par11547
	if not self.isSearcherFloating then // if already docked then 
		self.searcherDockUndock(true); // use exsisting code : (Re-dock Searcher)
	else
		self.tblSearch.adjustHeight(self.clientHeight); // is floating so just resize frm
		self.frmSearch.height := tblSearch.height + tblSearch.top + 15;
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDetail" id="2360bbfd-84d4-467b-98f4-37fe67f82c45">
        <updating/>
        <source>doSaveDetail() protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	pxyDtl,
	currentDtl		: CM_LogCheckScaleDtl;
	log				: CM_Log;
	result			: Integer;
	loadState		: Boolean;
begin
	if self.myCurrentScaleDtl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Current scale detail is null');
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	
	pxyDtl := self.myCurrentScaleDtl.pxyCreateUpdateProxy();
	
	pxyDtl.setProxy(self.myCurrentObject.CM_LogCheckScaleHdr,
					self.tblEntDetail.getValueByName(ETRow_LogId).String,
					self.tblEntDetail.getValueByName(ETRow_CheckConditionCode).String,
					self.tblEntDetail.getValueByName(ETRow_CheckSEDMin).Decimal,
					self.tblEntDetail.getValueByName(ETRow_CheckSEDMax).Decimal);
					
	while true do
		app.myTrxUA.trxUpdateCheckScaleDtl(pxyDtl, app.myPassport);

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.hideModalFrame();
			self.showThumbnailData(self.myCurrentObject);
		else
			result := app.showErrorWarningDialog('Check scaling detail update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;

epilog
	delete pxyDtl;
	app.cmsEndLoad(loadState);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveScaler" id="de0a7462-7dbc-4151-976d-87b68e77b5ea">
        <updating/>
        <source>doSaveScaler() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	scaler		: CM_User;
	scaleHdr	: CM_LogCheckScaleHdr;
	row			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateLogCheckScalerCode(self.myCurrentObject.CM_LogCheckScaleHdr, self.cmbScaler.listObject.CM_User, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.hideModalFrame();
			row := self.tblData.row;
			self.zDoSearch();
			self.tblData.setFocus();
			self.tblData.accessRow(row).selected := true;
			self.tblData.rowColumnChg(self.tblData);
			break;
		else
			theResult := app.showErrorWarningDialog('Check scaler code update', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblEntRowColChange" id="105e4e57-5eca-40c4-ba1e-d330fd8bd0cc">
        <source>doTblEntRowColChange() protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	minSED,
	maxSED				: Integer;
begin
	minSED := self.tblEntDetail.getValueByName(ETRow_CheckSEDMin).Integer;
	maxSED := self.tblEntDetail.getValueByName(ETRow_CheckSEDMax).Integer;
	
	if (minSED = null) or (maxSED = null) then
		return;
	endif;
	
	if minSED &gt; maxSED then //swap 'em
		self.tblEntDetail.setValueByName(ETRow_CheckSEDMin, maxSED);
		self.tblEntDetail.setValueByName(ETRow_CheckSEDMin, minSED);
	endif;	

end;</source>
        <access>protected</access>
    </JadeMethod>
