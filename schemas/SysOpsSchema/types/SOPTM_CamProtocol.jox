	self.chkTShipImports.parent := theForm.picSingleSelect2;	// TFS 48785
	self.chkTShipImports.visible := true;						// TFS 48785
	if self.chkTShipImports.form = null then					// TFS 48785
		theForm.addControl(self.chkTShipImports);				// TFS 48785
	endif;														// TFS 48785
	
	//26 Jan 2021	NDL	TFS 50708
	self.chkIncludeRFFBM162.parent := theForm.picSingleSelect2;	
	self.chkIncludeRFFBM162.visible := true;						
	if self.chkIncludeRFFBM162.form = null then					
