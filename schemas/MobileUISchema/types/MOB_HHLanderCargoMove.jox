    <JadeMethod name="doComplete" id="85a9b82f-123d-4534-952e-91ee7466e8cf">
        <updating/>
        <source>doComplete():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005
15 July 2010		cnwdap1	PAR #25021 review use of isImport/isExport for tranships
18/01/2013			cnwmh5	#31005 - Reverse change done for #25820.
01/02/2013			cnwmh5  #31105 - For SOB if not colour coded, marked as SOB, in a job, 
						    or a combination of these then display error message
20/10/2014          cnwma1  PAR #35011 Lander Load from Truck does not ask for move confirmation
17/11/2016 			cnwer1	TFS 2732 refactored to use controller class in PortSchema CMIF_MobileGenericController
26/10/2022          navmv20 Bug 51643: MTN - Cargo Lander Shift on board gives error about not having a job
*/

vars
	mustSelectWle : Boolean;
	wleArray: CM_WLEArray;
	errMess : String;
	tmpFoundLC : CM_LocationsController;
	wle,wleLC  : CM_WorkListEntry;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	checksSubCargo : CM_TrackedItem;
	isRelReqNoDirector : Boolean;
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;

	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, self.txtLocation.text);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	//27 May 2013	NDL	CCMS 2274
	self.myMobileGenericAgent.setSplitValues( 0, 0, null );

	if self.myTrackedItem.isBulkByQuantity and self.myTrackedItem.canSplitTotalQuantity then
		quantity := self.txtQuantity.text.Integer;
		if quantity = 0 or quantity &gt; self.myTrackedItem.totalQuantity then
			errMess := app.getErrorString1(Quantity_Invalid, self.myTrackedItem.totalQuantity.String);
			self.msgBox( errMess , app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	elseif self.myTrackedItem.isBulkByWeight then
		weight := self.tblWeightVolume.getConvertedValue();
		if weight = 0 or weight &gt; self.myTrackedItem.totalWeight then
			errMess := app.getErrorString(Invalid_weight_entered);
			self.msgBox( errMess , app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	elseif self.myTrackedItem.isBulkByVolume then
		volume := self.tblWeightVolume.getConvertedValue();
		weight := volume * self.myTrackedItem.getDensity;
		if volume = 0 or volume &gt; self.myTrackedItem.totalVolume then
			errMess := app.getErrorString(Invalid_volume_entered);
			self.msgBox( errMess , app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	endif;
	
	// we have a location, should be good to go.
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
	
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC, self.myTrackedItem, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.btnTwo.click(self.btnTwo);			
			return false;
		endif;
		
		//epr TFS 2732 15/11/16 refactored into method 
		return self.myMobileGenericAgent.doLanderDischarge(self.myTrackedItem,tmpFoundLC,quantity,weight);
		
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
	
		//if self.hasRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_LOAD) then //cnwas3 par 23601
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_LOAD, self.myTrackedItem, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.btnTwo.click(self.btnTwo);			
			return false;
		endif;
		
		//epr TFS 2732 15/11/16 refactored into method 
		wle:=self.getSelectedTblWLE();
		
		//09 May 2017	NDL	TFS 3045 - derived wle from director task where ti is on release
		if wle = null and self.myTrackedItem.myPrimaryPlannedLocation = null and self.myWorkListEntry &lt;&gt; null then
			if self.myWorkListEntry.isTiAssignedToResDet( self.myTrackedItem ) then
				wle := self.myWorkListEntry;
			endif;
		endif;
		
		
		
		if wle = null then // TFS 4561
			mustSelectWle := self.tblWles.visible; // TFS 4561
			if not self.getExportVoyageJobWle( wle, mustSelectWle ) then // TFS 4561
				if mustSelectWle then // TFS 4561
					return false; // TFS 4561
				endif; // TFS 4561
			endif; // TFS 4561
		
		endif; // TFS 4561
		
		
		// TFS 3045 - Containers only
		//						we get the next free WLE in the job and present that location; however the user then changes the location
		//						it is possible that the WLE is wrong. The WLE will be completed but the container moved to a different location
		//						So get the WLE for the location
		isRelReqNoDirector := self.isRelReqNoDirector();
		if isRelReqNoDirector then
			wleLC := tmpFoundLC.CM_VoyageController.getFirstWLE(true);
			if wleLC &lt;&gt; wle then
				wle := wleLC;
			endif;
		endif;
		
		return self.myMobileGenericAgent.doLanderLoad(self.myTrackedItem,tmpFoundLC,wle,quantity,weight);

		
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard then
		
		//epr TFS 2732 15/11/16 refactored into method 
		//return self.myMobileGenericAgent.doLanderSOB(self.myTrackedItem,tmpFoundLC,quantity,weight); //26/10/2022 navmv20 TFS 51643
		return self.myMobileGenericAgent.doLanderSOB(self.myTrackedItem,tmpFoundLC,quantity,weight,false); //26/10/2022 navmv20 TFS 51643
					
	endif;
	
	self.myMobileGenericAgent.setSplitValues( 0, 0, null );
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCompleteGround" id="b850077d-8013-4292-b859-756a21b1d268">
        <source>doCompleteGround( _groundOption : Integer ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2010	cnwer1	Initial creation epr PAR 25038 15/7/10

*/

vars
	errMess : String;
	tmpFoundLC : CM_LocationsController;	
	quantity : Integer;
	weight : Decimal [16,4];
	checksSubCargo : CM_TrackedItem;
	
begin
	//ALWAYS CALLED FROM DISCHARGE MODE	
	if self.myMobileGenericAgent.checksState &lt;&gt; self.myMobileGenericAgent.ShipDischargeCargo then
		return false;
	endif;
	
	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if self.cmbTA.listObject = null then
		errMess := lblTA.caption.toUpper;
		self.cmbTA.setFocus();
	elseif self.cmbLane.listObject = null then
		errMess := lblLane.caption.toUpper;
		self.cmbLane.setFocus();
	else
		tmpFoundLC := self.cmbLane.listObject.CM_LocationsController;
	endif;
	
	if tmpFoundLC = null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.cmbLane.setFocus();
		return false;
	endif;

	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, self.cmbTA.text);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	//ALWAYS CALLED FROM DISCHARGE MODE
	//02 Aug 2013	NDL	Par 32135
		
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC, self.myTrackedItem, checksSubCargo) &lt;&gt; null then
		self.btnTwo.click(self.btnTwo);			
		return false;
	endif;
		
	if self.myTrackedItem.isBulkByQuantity then
		if self.myTrackedItem.canSplitTotalQuantity then
			quantity := self.txtQuantity.text.Integer;
		endif;
	elseif self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
		weight := self.getBulkWeightValueForMove( self.myTrackedItem, self.tblWeightVolume );
	endif;
		
	//epr TFS 2732 refactored into method on agent to be called from web service
	return self.myMobileGenericAgent.doLanderDischargeToGround(self.myTrackedItem,tmpFoundLC,_groundOption,quantity,weight);

epilog

end;</source>
        <Parameter name="_groundOption" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="aaa54ace-7d7b-40dd-bd04-bfe33ab04138">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604
05/03/2015			cnwmh5	Transient Leaks
*/

vars
	state : Integer;
	top : Real;
	stdWidth : Real;
	width : Real;
	halfWidth : Real;
	
	isoType : CM_ISOType;
	iter : Iterator;
	index : Integer;
	
	btnHeight : Real;
	btnTop : Real;
	btnWidth : Real;
	btnLeft : Real;
	stdHeight : Real;
	tabIndex : Integer;
	tblHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	btnOne.visible := true;

	state := self.myMobileGenericAgent.checksState;
	if _initialSetup then
		self.btnAddCargo.visible := false;
		self.btnInTransit.visible := false;
	endif;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		if state = self.myMobileGenericAgent.ShipDischargeCargo then
			lblState.caption := app.getErrorString(Discharge) &amp; "  ";
			
			//28 Jun 2011	NDL	Par 27003
			if app.getMyUser.canDo(self.myTerminal,PmHHAddCargo) then
				self.btnAddCargo.visible := ( self.myTrackedItem = null );	
			endif;
			
		elseif state = self.myMobileGenericAgent.ShipLoadCargo then
			lblState.caption := app.getErrorString(Load) &amp; "  ";
			btnThree.visible := false;
			
		elseif state = self.myMobileGenericAgent.ShiftOnBoard then
			lblState.caption := app.getErrorString(SHP_Shift_On_Board) &amp; "  ";
			self.btnTwo.visible := false;
			self.btnThree.visible := false;		//10 Jul 2012	NDL	Par 29961
			
		endif;
	endif;
	self.resizeCmdButtons(); // Need to do this early, because some of the buttons resize relative to these guys...
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( self.clientWidth/2 ) - self.resizedMargin - self.resizedMargin;
	
	top := self.resizedMargin;
	width := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( self.resizedMargin,
						 top,
						 width,
						 stdHeight );
						 
	width := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.visible := true;
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnPartCargoId.move( self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
						 top,
						 width,
						 stdHeight );

	
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 top,
							 halfWidth,
							 stdHeight ); 
	
	if _initialSetup then
		self.lblState.visible := true;
		self.lblState.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblState.move( self.resizedMargin + halfWidth + self.resizedMargin,
						 top,
						 halfWidth,
						 stdHeight );
						 
	//02 Aug 2013	NDL	Par 32156
	top := top + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( self.resizedMargin,
							 top,
							 stdWidth,
							 stdHeight ); 
						 
	top := top + self.lblCargoDesc.height + self.resizedMargin;
	if state = self.myMobileGenericAgent.ShipDischargeCargo then
		if _initialSetup then
			self.cmbIsoType.visible := true;
			self.cmbIsoType.setAndIncrementTabIndex( tabIndex );
		endif;
		self.cmbIsoType.move( self.resizedMargin,
							 top,
							 stdWidth - self.resizedMargin - self.resizedMargin - self.btnOne.width,
							 stdHeight );
							 
	//	self.btnAutoPlan.visible := true;
		if _initialSetup then
			self.btnAutoPlan.setAndIncrementTabIndex( tabIndex );
		endif;
		self.btnAutoPlan.move(	self.btnOne.left,
								top,
								self.btnOne.width,
								stdHeight	);
		
		top := top + self.btnAutoPlan.height + self.resizedMargin;
	else
		//08 May 2917	NDL	TFS 3045
		if _initialSetup then
			self.cmbIsoType.visible := false;
		endif;
	endif;
	
	if _initialSetup then
		btnAutoPlan.visible := false;	//14 May 2010	NDL	 Par 23603	disabled and hidden 
		btnAutoPlan.enabled := false;	//14 May 2010	NDL	 Par 23603	disabled and hidden 
	endif;
	
	if self.showToGround then
	
		if _initialSetup then
			self.txtLocation.visible :=false;
			self.cmbSlotLocation.visible := false;//cnwrd1 par 30626 ccms 2209 23.10.12
			self.populateTerminalAreas();
			self.cmbTA.visible := true;
			self.cmbTA.setAndIncrementTabIndex( tabIndex );
		endif;
		self.cmbTA.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight ); 
								 
		top := top + self.cmbTA.height + self.resizedMargin;
		if _initialSetup then
			self.cmbLane.visible := true;
			self.cmbLane.setAndIncrementTabIndex( tabIndex );
		endif;
		self.cmbLane.move( self.resizedMargin,
								 top,
								 stdWidth,
								 stdHeight ); 
		top := top + self.cmbLane.height + self.resizedMargin;
	else
		if _initialSetup then
			self.cmbTA.visible:=false;
			self.cmbLane.visible:=false;
			self.txtLocation.setAndIncrementTabIndex( tabIndex );
			self.txtLocation.visible := true;
		endif;
		self.txtLocation.move(	self.resizedMargin,
								top,
								stdWidth,
								stdHeight );
		if _initialSetup then
			self.cmbSlotLocation.visible := false;//cnwrd1 par 30626 ccms 2209 23.10.12
			self.cmbSlotLocation.setAndIncrementTabIndex( tabIndex );
		endif;
		self.cmbSlotLocation.move(	self.resizedMargin,
									top,
									stdWidth,
									stdHeight );
		top := top + self.txtLocation.height + self.resizedMargin;
	endif;
	
	//04 Dec 2012	NDL	Par 30842
	// need to show based on the rules here here...
	
	if state = self.myMobileGenericAgent.ShipLoadCargo then
		
		if _initialSetup then
			self.btnChangeJob.visible := false;
			self.btnChangeJob.setAndIncrementTabIndex( tabIndex );
		endif;
		self.btnChangeJob.move(	self.btnOne.left,
								top,
								self.btnOne.width,
								stdHeight	);
		top := top + self.btnChangeJob.height + self.resizedMargin;
	endif;
	
	////////////
	if state = self.myMobileGenericAgent.ShipDischargeCargo
	or state = self.myMobileGenericAgent.ShipLoadCargo	//20 Jun 2013	NDL
	or state = self.myMobileGenericAgent.ShiftOnBoard //epr par 35807 6/3/15
	then
		if _initialSetup then
			self.lblQuantity.setAndIncrementTabIndex( tabIndex );
			self.lblQuantity.visible := false;
		endif;
		self.lblQuantity.move(	self.resizedMargin,
								top,
								halfWidth,
								stdHeight );
		if _initialSetup then
			self.txtQuantity.setAndIncrementTabIndex( tabIndex );
			self.txtQuantity.visible := false;
		endif;
		self.txtQuantity.move(	self.resizedMargin + halfWidth + self.resizedMargin,
								top,
								halfWidth,
								stdHeight );
								
		//02 Apr 2014	NDL CCMS 1366
		if _initialSetup then
			self.tblWeightVolume.setAndIncrementTabIndex( tabIndex );
			self.tblWeightVolume.visible := false;
		endif;
		self.tblWeightVolume.move(	self.resizedMargin + halfWidth + self.resizedMargin,
									top,
									halfWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
		
	endif;
	/////////////

	
						 
	if _initialSetup then
		self.cmbIsoType.clear();
		iter := app.myRoot.allISOTypes.createIterator;
		while iter.next(isoType) do
			index := self.cmbIsoType.addItem(isoType.code);
			self.cmbIsoType.itemObject[index] := isoType;
		endwhile;
	endif;
	
	top := btnOne.top - ( btnOne.height * 2 ) - self.resizedMargin;
	if btnFour.visible then
		btnLeft := btnFour.left;
		btnWidth := (btnFour.width * 2) + self.resizedMargin;
	else
		btnLeft := btnThree.left;
		btnWidth := btnThree.width;
	endif;
	if _initialSetup then
		self.btnAddCargo.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnAddCargo.move( 	btnLeft,
							top,
							btnWidth,
							btnOne.height );
							
	inheritMethod(_initialSetup);

	//10 Jul 2012	NDL	Par 29961
	if state = self.myMobileGenericAgent.ShipDischargeCargo and self.showToGround then
		if self.myMobileGenericAgent.hhLanderGroundingOpt = BothOpts or self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit then
		
			if self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit then
				top := btnOne.top;
				btnOne.visible := false;
			else
				// PAR 31996  Transit button aligned with Add Cargo Button
				//top := btnOne.top - btnOne.height - (margin * 2);  
			endif;
			
			btnLeft := btnOne.left;
			btnWidth := btnOne.width;
			if _initialSetup then
				btnInTransit.visible := true;
				self.btnInTransit.setAndIncrementTabIndex( tabIndex );
			endif;
			self.btnInTransit.move( btnLeft,
									top,
									btnWidth,
									stdHeight );
		endif;
	endif;
	
	
	top := self.txtQuantity.top + self.txtQuantity.height + self.resizedMargin;
	if self.btnAddCargo.visible then
		tblHeight := btnAddCargo.top - ( self.resizedMargin + top );
	else
		tblHeight := btnOne.top - ( self.resizedMargin + top );
	endif;
	self.tblWles.move(	self.resizedMargin,
						top,
						self.clientWidth - self.resizedMargin - self.resizedMargin,
						tblHeight );
	
	

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="4657e14a-ef8f-4979-bc06-33b392245af6">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	dataString : String;
	errMess : String;
begin

	//cnwrd1 par 30626 ccms 2209 23.10.12
	if self.cmbSlotLocation.visible = true then
		tmpFoundLC := self.cmbSlotLocation.listObject.CM_LocationsController;
		
		//19 May 2015	NDL	Par 36257
		if tmpFoundLC = null then
			errMess := app.getErrorString( No_Location_entered );
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			self.cmbSlotLocation.setFocus();
			return false;
		endif;
		
		return true;
	endif;
	//20 Oct 2011	NDL	Par 28254
	if self.txtLocation.userObject &lt;&gt; null then
		tmpFoundLC := self.txtLocation.userObject.CM_LocationsController;
		return true;
	endif;
	
	// Find the location we are moving to.
	dataString := self.txtLocation.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblLocation.caption.toUpper or dataString = lblMachine.caption.toUpper or dataString = lblShipLocation.caption.toUpper then
		errMess := app.getErrorString( No_Location_entered );
	else
		//epr TFS 2732 18/11/16 refactored into own method
		tmpFoundLC := self.myMobileGenericAgent.findLanderLocation(dataString);
		
		
		if tmpFoundLC = null then
			errMess := errMess &amp; app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");			
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtLocation.setFocus();
		return false;
	endif; 
	
	return true;
	
epilog

	
end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTIsInTransferArea" id="88edc88f-1eea-4bf9-9edc-157ad1f46b3d">
        <source>findTIsInTransferArea(_cargoId : String; _tiArray :CM_TIArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwer1	Initial creation CCMS MES 1033 - extracted code from selectCargoItems 
						added the WorkPointQueue stuff

*/

vars
	trackedItems : CM_TIArray;
	voyageQueue : CM_VoyageQueue;
	subQueue : CM_RadioTelemetryQueue;
	crane : CM_Crane;
	craneTA : CM_CraneTransferArea;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	interChangeArea : CM_InterchangeArea;
	workPoint : CM_WorkPoint;
begin
	cargoIdLength := _cargoId.length;
	cargoIdReversed := _cargoId.reverse;
	//need to check any that are grounded in one of the crane transfer areas or associated interchange area.
	create trackedItems transient;
	voyage := self.myMobileGenericAgent.myVoyage;
	voyageQueue := voyage.myQueue;
	if voyageQueue = null then
		return;
	endif;
	
	foreach subQueue in voyageQueue.allSubQueuesById do : outerLoop	
		if subQueue.isKindOf(CM_VoyageCraneQueue) then
			crane := subQueue.CM_VoyageCraneQueue.crane;
			if crane = null then
				continue;
			endif;
			craneTA := crane.transferArea;
			if craneTA = null then
				continue;
			endif;
			
			trackedItems.clear();
			craneTA.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	//11 Oct 2010	NDL	Par 25836
					_tiArray.addExclusive(ti);
					break outerLoop;
				endif;
			endforeach;
			
			interChangeArea := craneTA.myDefaultInterchangeArea;
			if interChangeArea &lt;&gt; null then
				trackedItems.clear();
				interChangeArea.getTIs(trackedItems, null);
				foreach ti in trackedItems do
					if ti.id = _cargoId then
						_tiArray.addExclusive(ti);
						break outerLoop;
					elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	//11 Oct 2010	NDL	Par 25836
						_tiArray.addExclusive(ti);
						break outerLoop;
					endif;
				endforeach;
			endif;
		//epr CCMS 1033 30/8/11
		elseif 	subQueue.isKindOf(CM_VoyageWorkPointQueue) then
			workPoint:=subQueue.CM_VoyageWorkPointQueue.myWorkPoint;
			if workPoint = null then
				continue;
			endif;
			interChangeArea :=workPoint.myWorkPointInterchangeArea;
			if interChangeArea = null then
				continue;
			endif;
			trackedItems.clear();
			interChangeArea.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if ti.myVoyage &lt;&gt; voyage then	//03 Jul 2012	NDL	Par 29707 - WPs can share T/As
					continue;
				endif;
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	
					_tiArray.addExclusive(ti);
					break outerLoop;
				endif;
			endforeach;
		endif;
	endforeach;
		
epilog
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExportVoyageJobWle" id="a283455b-d317-4e5c-b2ef-7b01e2261dcf">
        <updating/>
        <source>getExportVoyageJobWle( _wle : CM_WorkListEntry output; _forceSelection : Boolean ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	row : Integer;
	msg : String;
	tmpWle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	container : CM_Container;
	bulkRelease : CM_BulkRelease;
	voyage : CM_Voyage;
	iterJob : Iterator;
	voyJob : CM_VoyageJob;
	voyWle : CM_WorkListEntry;
	req : CM_Request;
	resDet : CM_ReserveDetail;
	
begin

	ti := self.myTrackedItem;
	if ti = null then
		return false;
	endif;

	if ti.canMergeBreakBulk and  self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
	
		//Break bulk 'Releases' can have multiple WLEs and Jobs for a single 'cargo item'
		// A list of the available one has been displayed.
		// Need to make sure a wle is chosen.
		
		if self.tblWles.visible then
			// There are 2 or more contenders when the table is visible.
			
			if self.myWorkListEntry &lt;&gt; null and ti.allWorklistEntries.includes( self.myWorkListEntry ) then
				_wle := self.myWorkListEntry;
				
			else
				foreach row in 1 to self.tblWles.rows do
					if self.tblWles.accessRow( row ).selected then
						_wle := self.tblWles.accessRow( row ).itemObject.CM_WorkListEntry;
						if _wle &lt;&gt; null then
							if self.myWorkListEntry &lt;&gt; _wle then
								self.setMyTrackedItem( ti, _wle );
							endif;
							break;
						endif;
					endif;
				endforeach;
				
				if _forceSelection and _wle = null then
					msg := "Must select the associated move to be actioned";
					self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, false );
				endif;
			
			endif;
			
		else
			// Maximum of one available, we can choose it for them.
			if _wle = null then
				foreach tmpWle in ti.allWorklistEntries do
					if tmpWle.status = WLE_COMPLETED then
						continue;
					endif;
					if not tmpWle.isKindOf(CM_VoyageWLE) then
						continue;
					endif;
					if tmpWle.isReceipt then
						continue;
					endif;
					_wle := tmpWle;
					break;
				endforeach;
			endif;
		
		endif;
	
	
	else

		_wle := self.myTrackedItem.getVoyageWLEUnactioned( true );
		
		if self.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean  then //25 Jul 2018	NDL	TFS 38679
		
			//08 May 2017	NDL	TFS 3045 - Find the next available WLE for empties that have been assigned to an empty release that is planned
			if _wle = null then
				if not ti.isContainer then
					return false;
				endif;
				container :=  ti.CM_Container;
				if not container.isEmpty then
					return false;
				endif;
				bulkRelease := ti.allBulkReleasesAssigned.first;
				if bulkRelease = null or not bulkRelease.isShipType then
					return false;
				endif;
				voyage := bulkRelease.myVoyage;
				if voyage = null or voyage &lt;&gt; self.myMobileGenericAgent.myVoyage then
					return false;
				endif;
					
							
				//OK we got a voyage release request - rip thru the jobs
				iterJob := voyage.allVoyageJobs.createIterator;
				while iterJob.next( voyJob ) do
					if not voyJob.isVoyageJob and not voyJob.isVoyageROROJob then
						//Must be a LOLO load job or a RORO load job
						continue;
					endif;
					if voyJob.isDischargeOrSOB then
						//Only want load jobs
						continue;
					endif;
					if voyJob.status = JOB_COMPLETE then
						continue;
					endif;
					voyWle := voyJob.getNextFreeVoyageWLE;
					if voyWle &lt;&gt; null then
					
						if not voyWle.isTiAssignedToResDet( ti ) then
							continue;
						endif;
						//Finally everything matches, use this one
						self.setMyTrackedItem(	ti, voyWle );
						_wle := voyWle;
						break;
					endif;
				endwhile;
				delete iterJob;
						
			endif;
		
		endif;
		
	endif;

	return (_wle &lt;&gt; null);

epilog

	delete iterJob;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_forceSelection" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTblWLE" id="7cba0d95-c03e-4e43-9cf1-0ae6fb6b5c0e">
        <source>getSelectedTblWLE() : CM_WorkListEntry protected;
/*

Date		Who		Reason
16 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	row : Integer;
begin
	ti := self.myTrackedItem;
	if ti = null then
		return null;
	endif;
	
	if self.tblWles.visible then
		if self.myWorkListEntry &lt;&gt; null and ti.allWorklistEntries.includes( self.myWorkListEntry ) then
			return self.myWorkListEntry;		
		else
			foreach row in 1 to self.tblWles.rows do
				if self.tblWles.accessRow( row ).selected then
					wle := self.tblWles.accessRow( row ).itemObject.CM_WorkListEntry;
					if wle &lt;&gt; null then
						return wle;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	

	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="handleBtnFour" id="48132de4-e888-442e-a106-3810b86d6cfe">
        <updating/>
        <source>handleBtnFour() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

begin

	self.myMobileGenericAgent.allCargoCheckItemSelections.purge;
	self.myMobileGenericAgent.setMyNextTiToAction(null);
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="39acc956-2032-44c6-b4c1-e83c90dcea9d">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Feb 2010	cnwndl1	Initial creation	CCMS MES 1005
15 Jul 2010 cnwer1  PAR 25038
*/

vars

begin
	
	//epr PAR 25038 15/7/10
	if self.showToGround then
		if self.doCompleteGround( GroundComplete ) then
		
			//clear fields ready for the the next item..
			self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
			self.populateTrackedItem();
		endif;
		return;
	endif;
	
	if self.doComplete() then
		//clear fields ready for the the next item..
		self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
		self.populateTrackedItem();
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="3d742ea5-7781-486f-8f00-b276bbf20f1f">
        <updating/>
        <source>handleBtnThree() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	CCMS SFW 1071	Par 23603

*/

vars

begin
	if self.btnThree.caption = app.getErrorString(Back) then
		self.handleBtnFour();
		return;
		
	endif;
	
	//epr TFS 2732 22/11/16 this is never anything but the back button now removing code

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="5ccd8fa7-6581-421a-ba28-628fbc9b5ba4">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/02/2010	cnwndl1	Initial creation	CCMS MES 1005
29/01/2018	jlgdap1	TFS 36405 SNO Correct handling of work point when doing cargo checks
*/
vars
	context : Integer;
	quantity : Integer;
	weight : Decimal [16,4];

begin
	//user clicked checks - show cargo checks form
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.btnTwo.caption = app.getErrorString(Queue) then	//10 Jul 2012	NDL	Par 19961
		if self.myTrackedItem &lt;&gt; null then
			self.doAutoPlan();
		endif;
		self.populateTrackedItem();
		return;
	endif;
		
	
	// do we have any checks to perform?
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_DISC;
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_LOAD;
	else
		return;
	endif;
	//if self.myTerminal.allCargoChecks[context].allCargoCheckItems.size = 0 then
	if self.myTerminal.hasNoCargoCheckItemsFor(context) then	//31 May 2012	NDL Par 29038
		return;
	endif;
	
	self.myMobileGenericAgent.setMyNextTiToAction(self.myTrackedItem);
	self.myMobileGenericAgent.setMyWle(self.myWorkListEntry);	//23 Sep 2013	NDL	Par 32479
	self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
	
	//epr TFS 4024 21/4/17 
	if self.txtLocation.visible and self.txtLocation.text.trimBlanks &lt;&gt; null then
		app.myMobileCargoFindAgent.setStringField1(self.txtLocation.text.trimBlanks);
	elseif self.cmbSlotLocation.visible then
		app.myMobileCargoFindAgent.setStringField1(self.cmbSlotLocation.text.trimBlanks);
	endif;
	if self.txtQuantity.visible then
		quantity := self.txtQuantity.text.Integer;
		app.myMobileCargoFindAgent.setStringField2(quantity.String);	//01 Aug 2013	NDL	Par 32140
	else
		quantity := 0;
		app.myMobileCargoFindAgent.setStringField2(null);
	endif;
	//02 Apr 2014	NDL	CCMS 1366
	if self.tblWeightVolume.visible then
		weight := self.tblWeightVolume.getConvertedValue();
		app.myMobileCargoFindAgent.setDecimalField1(weight);
	else
		weight := 0;
		app.myMobileCargoFindAgent.setDecimalField1(0.00);
	endif;
	
	//30 July 2010	NDL	Par 25158
	if self.showToGround then
		if self.cmbTA.listObject.isKindOf(CM_CraneTransferArea) then
			self.myMobileGenericAgent.setMyCraneTransferArea(self.cmbTA.listObject.CM_CraneTransferArea);
			self.myMobileGenericAgent.setMyWorkPoint(null);														// TFS 36405
		elseif self.cmbTA.listObject.isKindOf(CM_WorkPointInterchangeArea) then									// TFS 36405
			self.myMobileGenericAgent.setMyCraneTransferArea(null);												// TFS 36405
			self.myMobileGenericAgent.setStringField1(self.cmbTA.listObject.CM_WorkPointInterchangeArea.id);	// TFS 36405
		endif;
		self.myMobileGenericAgent.setMyLocationsController(self.cmbLane.listObject.CM_LocationsController);
	endif;

	//28 May 2013	CCMS 2274 Break-bulk
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo
	or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo	//20 Jun 2013	NDL
	then
		self.myMobileGenericAgent.setSplitValues( quantity, weight, null );
	endif;
		
	self.gotoForm(MOB_HHGateCheckCargo, false);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isRelReqNoDirector" id="1d52ff37-2108-4500-9a1a-42e28f0653ce">
        <source>isRelReqNoDirector() : Boolean;
/*
Purpose:			
Date		Who		Reason
22 June 2017	cnwab1	Initial creation
*/

vars
	resdet : CM_ReserveDetail;
begin
		if self.myTrackedItem.isContainer()
		and self.myTrackedItem.myVoyage &lt;&gt; self.myMobileGenericAgent.myVoyage then
			if self.myTrackedItem.getVoyageWLEUnactioned(true) &lt;&gt; null then
				return false;
			endif;
			
			if not self.myTrackedItem.allReserveDetails.isEmpty() then
				foreach resdet in self.myTrackedItem.allReserveDetails discreteLock do
					if resdet.getMyVoyage() = self.myMobileGenericAgent.myVoyage then
						// CONTAINER with different voyage that is assigned to our voyage
						// This is a release request director task on the hand held candidate.
						if self.myTrackedItem.myPrimaryPlannedLocation = null then
							// SO it is not planned, if it has got this far then they are not using machine to do director tasks
							// they are just entering the ID on the Lander and want us to get the next empty ship release request slot.
							return true;
						endif;
					
					endif;
				
				endforeach;
			
			endif;
		endif;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageNonWorked" id="721b25c7-26fc-4ed4-9adf-d7274473043d">
        <source>isVoyageNonWorked(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2013	cnwndl1	Initial creation	Par 32163

*/

vars

begin

// PAR 33644	return self.myHandHeldCheckerAgent.myVoyage.isNonWorkedVoyage;
	return self.myMobileGenericAgent.myVoyage.isHOLDSorSHIP(); // NO LOLO or RORO structure i.e No Job Sheet.

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="popLocationDuringTIPop" id="2adf792e-82a2-4f59-9016-0a82b8b7a472">
        <updating/>
        <source>popLocationDuringTIPop( errorMess : String io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2013	cnwndl1	Initial creation	Par 32140
05/09/2014      cnwma1	PAR #34852 DLR move Error
01/12/2014      cnwma1  PAR #35314  1086 in MOB_HHLanderCargoMove::cmbSlotLocation_displayEntry
12/11/2018	jlgdap1	TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
*/

vars

	wle : CM_WorkListEntry;
	location: String;
	lc: CM_LocationsController;
	job : CM_VoyageJob;
	slotArray : CM_LCArray;
	otherWle : CM_WorkListEntry;
	plannedMoves : CM_FutureMoveArray;
	plannedMove: CM_FutureMove;
	queuedMoves : CM_FutureMoveArray;
	loc : CM_LocationsController;
	invalidObj : Boolean;
	displayStr : String;
	displayArray : StringArray;
	index: Integer;
	size : Integer;
	pmWle : CM_WorkListEntry;
	resdet : CM_ReserveDetail;
	voyreq : CM_VoyageRequest;
	isRelReqNoDirector : Boolean;
	prenote : CM_TrackedItem;					// TFS 41300
begin

//	if self.isVoyageNonWorked then	//08 Aug 2013	NDL	Par 32152
//		self.txtLocation.enabled := true;
//	endif;
	self.txtLocation.enabled := true;	// 02 Apr 2014	NDL	CCMS 1366

	if app.myMobileCargoFindAgent.stringField1 &lt;&gt; null
	or app.myMobileCargoFindAgent.stringField2 &lt;&gt; null
	or app.myMobileCargoFindAgent.decimalField1 &gt; 0
	then
		//This means we have come back from doing some checks, and we had already chosen our location.
		//So put back what we entered
		if app.myMobileCargoFindAgent.stringField1 &lt;&gt; null then
			self.setTxtLocationDetails( app.myMobileCargoFindAgent.stringField1, null ); // cnwma1

			
		endif;
		if app.myMobileCargoFindAgent.stringField2 &lt;&gt; null then
			self.txtQuantity.text := app.myMobileCargoFindAgent.stringField2;
		endif;
		if app.myMobileCargoFindAgent.decimalField1 &gt; 0 then
			if self.myTrackedItem &lt;&gt; null then
				if self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
					self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, app.myMobileCargoFindAgent.decimalField1 );
				endif;
			endif;
		endif;
		
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard then
		if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null and self.myTrackedItem.myPrimaryQueuedLocation.isVoyageController then	//21 Jan 2013	NDL	Par 30892
			self.setTxtLocationDetails( self.myTrackedItem.myPrimaryQueuedLocation.getStowageId(self.myTrackedItem), self.myTrackedItem.myPrimaryQueuedLocation );	//20 Oct 2011	NDL	Par 28254
		elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null and self.myTrackedItem.myPrimaryPlannedLocation.isVoyageController then	//21 Jan 2013	NDL	Par 30892
			self.setTxtLocationDetails( self.myTrackedItem.myPrimaryPlannedLocation.getStowageId(self.myTrackedItem), self.myTrackedItem.myPrimaryPlannedLocation );	//20 Oct 2011	NDL	Par 28254
		endif;
		

	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
	// 02 Apr 2014	NDL	CCMAS 1366
	//	if not self.isVoyageNonWorked then		// PAR 31866
	//		self.txtLocation.enabled := false;
	//	endif;
	
	
		// TFS 3045
		isRelReqNoDirector := self.isRelReqNoDirector();
		
		if self.myTrackedItem.myVoyage &lt;&gt; self.myMobileGenericAgent.myVoyage then
			if self.myTrackedItem.myVoyageTranshipExport = self.myMobileGenericAgent.myVoyage then   // PAR 32140
				// this is OK, is coming off another ship onto this voyage...
			elseif self.myTrackedItem.myCargoType.isBreakBulkMulti or self.myTrackedItem.myCargoType.isBulkMulti then //epr par33948 28/5/14
				
			elseif not isRelReqNoDirector then // TFS 3045
				errorMess := app.getErrorString2(Cargo_Not_For_Voyage, self.myTrackedItem.id, self.myMobileGenericAgent.myVoyage.code);
			endif;
		endif;
		
		//27 June 2012	NDL	Par 29875 - New rule, gotta have a job now....
		self.getExportVoyageJobWle( wle, false ); //23 Sep 2013	NDL	Par 32479
		
		// TFS 41300 special case of prenoted planned voyage cargo									
		if wle = null then																			// TFS 41300
			prenote := self.myTrackedItem.myTerminal.allNotifiedTIsByIdCargoType[self.myTrackedItem.id, self.myTrackedItem.cargoType];		// TFS 41300
			if prenote &lt;&gt; null then																	// TFS 41300
				wle := prenote.getVoyageWLEUnactioned(true);										// TFS 41300
			endif;																					// TFS 41300
		endif;																						// TFS 41300

		if wle &lt;&gt; null then
			job := wle.job.CM_VoyageJob;
		endif;
				
		self.txtLocation.visible := true;
		
		if job &lt;&gt; null and job.allowOutOfOrderLoading then //cnwrd1 par 30626 ccms 2209 23.10.12
			//we want to populate and enable a combo box of free (matching) slot locations for the user to pick from
			//and default to the next one.
			self.cmbSlotLocation.visible := true;
			if job.isVoyageAllocLoad then
				self.btnChangeJob.visible := true;	
			endif;
			self.txtLocation.visible := false;
			self.cmbSlotLocation.clear;
			create slotArray transient;
			job.getEmptySlotLocIDInSequence(slotArray);
			self.cmbSlotLocation.listCollection(slotArray, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
			if self.cmbSlotLocation.listCount &gt; 0 then	//31 Oct 2014 NDL - Tripped over this during fix for 35015
				self.cmbSlotLocation.listIndex:=1;
				//epr TFS 4024 21/4/17
				if  app.myMobileCargoFindAgent.stringField1 &lt;&gt; null then
					index:=self.cmbSlotLocation.findStringExact(1,app.myMobileCargoFindAgent.stringField1);
					if index &gt; 0 then
						self.cmbSlotLocation.listIndex:=index;
					endif;
				endif;
			endif;
			delete slotArray;

		else
			if errorMess &lt;&gt; null then
				self.setTxtLocationDetails( self.lblLocation.caption.toUpper, null );	//20 Oct 2011	NDL	Par 28254
			else
				if self.myMobileGenericAgent.myVoyage.myShipBlockStack &lt;&gt; null and app.getMyUser.canDo(self.myTerminal,PmHHAllowTargetChange) then	// 6 June 2104 DJW 33926
					self.setTxtLocationDetails( self.myMobileGenericAgent.myVoyage.myShipBlockStack.getFullId, self.myMobileGenericAgent.myVoyage.myShipBlockStack );	//20 Oct 2011	NDL	Par 28254
				endif;
				
				// Check for Mt release to Ship  PAR 29865
				//wle := self.myTrackedItem.getVoyageWLE;  //epr par 30726 already got the correct wle for the voyage 
				if wle &lt;&gt; null then
					lc := wle.getNextBulkReleaseLocation();
				endif;
				if lc = null then
					//epr CCMS 1033 23/8/11 getting location if RORO controller (CM_VoyageController)
					if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null and 
						( self.myTrackedItem.myPrimaryQueuedLocation.isKindOf(CM_SlotController) or
							self.myTrackedItem.myPrimaryQueuedLocation.isKindOf(CM_VoyageController)) then
						lc := self.myTrackedItem.myPrimaryQueuedLocation;
					elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then //and 
							//epr may have planned voyage location but the primary isn't primary is just first planned location
					//	( self.myTrackedItem.myPrimaryPlannedLocation.isKindOf(CM_SlotController)or
					//		self.myTrackedItem.myPrimaryPlannedLocation.isKindOf(CM_VoyageController))  then
						// 34510 DJW 4 July 2014 May be planned to multiple locations
						create plannedMoves transient;
						//self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, plannedMoves ); //- cnwma1 05/09/2014 PAR#34852
						if self.myTrackedItem.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then 					   //+ cnwma1 05/09/2014 PAR#34852
							self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMoveDLRLoad, plannedMoves );
						else
							self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, plannedMoves );
						endif;
						create slotArray transient;
						foreach plannedMove in plannedMoves do
							lc := plannedMove.getPrimaryLocation;
							if lc.isVoyageController and lc.CM_VoyageController.getMyVoyage = self.myMobileGenericAgent.myVoyage then
								slotArray.add(plannedMove.getPrimaryLocation);
							endif;			
						endforeach;
						lc:=null; //epr TFS 2732 24/11/16 reset because this var is used further down
						if slotArray.size = 1 then     // If only one choice then use text box
							lc := slotArray[1].CM_LocationsController;
							self.txtLocation.visible := true;	//31 Oct 2014	NDL	Par 35015
							self.cmbSlotLocation.visible := false;	//31 Oct 2014	NDL	Par 35015
						elseif slotArray.size &gt; 1 then
							self.cmbSlotLocation.visible := true;
							self.cmbSlotLocation.clear;
							self.txtLocation.visible := false;
							self.cmbSlotLocation.listCollection(slotArray, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
							if self.cmbSlotLocation.listCount &gt; 0 then	//31 Oct 2014 NDL - Tripped over this during fix for 35015
								self.cmbSlotLocation.listIndex:=1;
							endif;
							delete slotArray;
							
						endif;
						
					endif;
				endif;
				
				if lc = null and self.myTrackedItem.wasPrenotified and wle &lt;&gt; null and wle.job.isVoyageHoldJob then		// TFS 41300
					lc := wle.getTargetLocation();																		// TFS 41300
				endif;																									// TFS 41300
				// #############################################
				// #############################################
				
		//		if lc = null then // TFS 3190
				if lc = null and self.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean then	//16 Jul 2018	NDL	TFS 38679
					resdet := self.myTrackedItem.allReserveDetails.first; // get reserve detail that I am assigned to
					if resdet &lt;&gt; null then
						create slotArray transient;
						foreach resdet in self.myTrackedItem.allReserveDetails discreteLock do
	
							foreach voyreq in resdet.allVoyageRequestsAssigned discreteLock do
								if voyreq.isComplete then
									continue;
								endif;
								lc := voyreq.getLC(); // get the request's location
								if lc &lt;&gt; null then
									slotArray.addExclusive(lc);
								endif;
							endforeach;
							
						endforeach;
					
						lc:=null;
						if slotArray.size = 1 then     // If only one choice then use text box
							lc := slotArray[1].CM_LocationsController;
							self.txtLocation.visible := true;	
							self.cmbSlotLocation.visible := false;	
						elseif slotArray.size &gt; 1 then
							self.cmbSlotLocation.visible := true;
							self.cmbSlotLocation.clear;
							self.txtLocation.visible := false;
							self.cmbSlotLocation.listCollection(slotArray, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
							if self.cmbSlotLocation.listCount &gt; 0 then	
								self.cmbSlotLocation.listIndex:=1;
							endif;
							
						endif;
						delete slotArray;
						
					endif;
				endif;
				
				
				if lc &lt;&gt; null then
					location := lc.getStowageId(self.myTrackedItem);
					self.setTxtLocationDetails( location, lc );	//20 Oct 2011	NDL	Par 28254
				endif;					
			endif;
		endif;
		
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
		//31 Jan 2013	NDl	Par 31102
		if self.myTrackedItem.directDelivery then
			wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
			if wle &lt;&gt; null then
				otherWle := self.myTrackedItem.getDirectDeliveryTargetWle( wle );
				if otherWle &lt;&gt; null then
					lc := otherWle.getTargetLocation;
					if lc &lt;&gt; null then
						self.setTxtLocationDetails( lc.getFullId, lc );
					endif;
				endif;
			endif;
	
		endif;

		// Find location for discharge DW - PAR 31866
		if not self.myTrackedItem.myPrimaryActualLocation.requiresJob then   // 34464
			if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
				lc := self.myTrackedItem.myPrimaryQueuedLocation;
			elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
				lc := self.myTrackedItem.myPrimaryPlannedLocation ;
			endif;
			if lc &lt;&gt; null then
				location := lc.getFullId();
				self.setTxtLocationDetails( location, lc );	
			endif;
		endif;
		self.resetLocationDisplay();
			
		//14 Jun 2016	NDL	TFS 2156
		if not self.showToGround then
			if not self.myTrackedItem.myPrimaryActualLocation.requiresJob then // not for LOLO locations
				// Do we have multiple planned or queued to locations?
				create slotArray transient;
				create plannedMoves transient;
				create queuedMoves transient;
				create displayArray transient;
				
				self.myTrackedItem.getFutureMovesOfType(QUEUE_MODE, TI_FutureMoveQueued, queuedMoves );
				self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, plannedMoves );
				
				on Exception do app.handleDeletedObject( exception, plannedMove, invalidObj );
				if not queuedMoves.isEmpty then
					foreach plannedMove in queuedMoves do
						invalidObj := false;
						loc := plannedMove.getPrimaryLocation;
						pmWle := plannedMove.myWorkListEntry;
						if not invalidObj and loc &lt;&gt; null then
							slotArray.add(loc);
							displayStr := loc.getFullId();
							if pmWle &lt;&gt; null then
								displayStr := displayStr &amp; " (" &amp; pmWle.getMoveAmountDisplay(false) &amp; ")";
							endif;
							displayArray.add(displayStr);
						endif;
					endforeach;
				endif;
				
				if not plannedMoves.isEmpty then
					foreach plannedMove in plannedMoves do
						invalidObj := false;
						loc := plannedMove.getPrimaryLocation;
						pmWle := plannedMove.myWorkListEntry;
						if not invalidObj and loc &lt;&gt; null then
							slotArray.add(loc);
							displayStr := loc.getFullId();
							if pmWle &lt;&gt; null then
								displayStr := displayStr &amp; " (" &amp; pmWle.getMoveAmountDisplay(false) &amp; ")";
							endif;
							displayArray.add(displayStr);
						endif;
					endforeach;
				endif;
				
				if slotArray.size &gt; 1 then
					self.cmbSlotLocation.visible := true;
					self.cmbSlotLocation.clear;
					self.txtLocation.visible := false;
					size := slotArray.size;
					foreach index in 1 to size do
						displayStr := displayArray[index];
						loc := slotArray[index];
						self.cmbSlotLocation.itemObject[ self.cmbSlotLocation.addItem( displayStr ) ] := loc;
					endforeach;
					self.cmbSlotLocation.listIndex:=1;
				endif;
			endif;
		endif;
		
	endif;

epilog

	//08 May 2014	NDL	Par 33926
	self.checkAllowTargetChange();
	delete plannedMoves;
	delete queuedMoves;
	delete slotArray;
	delete displayArray;

end;</source>
        <Parameter name="errorMess" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateTerminalAreas" id="d4f6ce0a-72a6-4bce-b6f7-d697dbe86c72">
        <source>populateTerminalAreas() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603
18 Jun 2012	NDL		Par 29745

*/

vars

begin

	self.popWithCraneWorkPointTermAreas( self.myMobileGenericAgent.myVoyage, self.cmbTA );
	
	self.doChangeTerminalArea();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTrackedItem" id="d3ae363d-c5e7-4222-8601-c28c90a9d7c8">
        <updating/>
        <source>populateTrackedItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005
14/04/2010	cnwas3 par 23664
02 Apr 2014	NDL	CCMS 1366
*/

vars
	isoType : CM_ISOType;
	errorMess : String;
	warningMess : String;
	desc1 : String;
	desc2 : String;
	weightStr : String;
	volumeStr : String;
	measureType : CM_MeasurementType;
begin

	self.cmbIsoType.enabled := false;
	self.cmbIsoType.listIndex := -1;
	self.lblQuantity.visible := false;
	self.txtQuantity.visible := false;
	self.tblWeightVolume.visible := false;
	
	self.toggleChecksQueueButton();	//10 Jul 2012	NDL	Par 29961
	
	//11 Oct 2017	NDL	TFS 7089
	if self.btnInTransit.visible then
		self.btnInTransit.enabled := true;
	endif;

	if self.myTrackedItem = null then
		self.txtCargoId.text := lblCargoId.caption.toUpper;
		self.txtCargoId.setFocus();
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
		self.cmbIsoType.visible := false;	//02 Aug 2013	NDL	Par 32156
		self.cmbSlotLocation.clear();
		self.cmbSlotLocation.visible := false;
		self.btnChangeJob.visible := false;
		self.txtLocation.visible := not self.showToGround;
		self.setTxtLocationDetails( null, null ); //01 Oct 2014	NDL	Par 34967 - needs to be cleared before the reset when no ti
		self.resetLocationDisplay();
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then	//10 Jul 2012	NDL	Par 29961
			//5/3/12 epr par 28104
			if app.getMyUser.canDo(self.myTerminal,PmHHAddCargo) then
				self.btnAddCargo.visible := true;	
			endif;
		endif;
	else
		
		self.txtCargoId.text := self.myTrackedItem.id;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );	//02 Aug 2013	NDL	Par 32156
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;	//02 Aug 2013	NDL	Par 32156
		
		//11 Oct 2017	NDL	TFS 7089
		if self.myTrackedItem.myCargoType.allowDuplicates then
			self.btnInTransit.enabled := false;
		endif;
		
		//14 Dec 2010	NDL	Par 26568
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
			if self.myTrackedItem.isImport and not self.myTrackedItem.isPlannedToVoyage(self.myMobileGenericAgent.myVoyage) then   // 34510 DJW 7 July 2014
				warningMess := self.myTrackedItem.id &amp; "  " &amp; app.getErrorString(Cargo_marked_import_not_loaded);	
			endif;
		elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
			if self.myTrackedItem.isExport then
				warningMess := self.myTrackedItem.id &amp; "  " &amp; app.getErrorString(Cargo_marked_export_discharge);
			endif;
			
		endif;
		
		if self.myTrackedItem.canSplitTotalQuantity
		or self.myTrackedItem.isBulkByWeight
		or self.myTrackedItem.isBulkByVolume
		then
			if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo
			or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo	//20 Jun 2013	NDL	
			or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard //epr par 35807 6/3/15
			then
				self.lblQuantity.visible := true;
				self.txtQuantity.text := "";
				if self.myTrackedItem.isBulkByQuantity then
					self.txtQuantity.visible := true;
				elseif self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
					self.setBulkWeightVolumeFields( self.myTrackedItem, self.tblWeightVolume, self.lblQuantity, 0.00 );
				endif;
			endif;
		endif;
		
		if warningMess &lt;&gt; null then
			if self.msgBox( warningMess, app.getErrorString(Continue), MsgBox_OK_Cancel, false ) = MsgBox_Return_OK then
				// do nothing, user says its ok.
			else
				self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
				self.populateTrackedItem();
				return;
			endif;
		endif;
		
		self.popLocationDuringTIPop( errorMess ); //01 Aug 2013 NDL	Par 32140
		
		isoType := self.myTrackedItem.getISOTypeObject();	// 28 Apr 2010	NDL	Par 23822
		if isoType &lt;&gt; null then
			self.cmbIsoType.listIndex := self.cmbIsoType.findObject( isoType );
			self.cmbIsoType.enabled := self.myMobileDataAgent.myTerminal.getConfig(GateCheckAllowsIsoChg).Boolean;
		endif;
	//	self.cmbIsoType.visible := self.myTrackedItem.isContainer;	//02 Aug 2013	NDL	Par 32156
		self.cmbIsoType.visible := self.myTrackedItem.isContainer and (self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo);	//08 May 2017	NDl	TFS 3045
		
		app.myMobileCargoFindAgent.clearHistory(true);
		
		if errorMess &lt;&gt; null then
			self.msgBox( errorMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
			self.populateTrackedItem();
		endif;
		
	endif;
	
	self.setupTblWles();
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="resetLocationDisplay" id="11d4984e-3afa-40d9-b6a6-5c660c349468">
        <source>resetLocationDisplay();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2010	cnwndl1	Initial creation

*/

vars
	dataString: String;
begin
	dataString := self.txtLocation.text.trimBlanks.toUpper;   // 34464
	if dataString = null or dataString = lblLocation.caption.toUpper or dataString = lblMachine.caption.toUpper or dataString = lblShipLocation.caption.toUpper then
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myPrimaryActualLocation.requiresJob then
				self.setTxtLocationDetails( self.lblMachine.caption.toUpper, null );	//20 Oct 2011	NDL	Par 28254
			else
			//self.txtLocation.text := self.lblMachine.caption.toUpper;
				self.setTxtLocationDetails( self.lblLocation.caption.toUpper, null );	
			endif;
		elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
			//self.txtLocation.text := self.lblShipLocation.caption.toUpper;
			self.setTxtLocationDetails( self.lblShipLocation.caption.toUpper, null );	//20 Oct 2011	NDL	Par 28254
		else
			//self.txtLocation.text := self.lblLocation.caption.toUpper;
			self.setTxtLocationDetails( self.lblLocation.caption.toUpper, null );	//20 Oct 2011	NDL	Par 28254
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeCmdButtons" id="257bc1bc-5dd8-4243-ba4b-c0d35ea363c9">
        <updating/>
        <source>resizeCmdButtons() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2015	cnwndl1	Initial creation

*/

vars

	btnWidth : Real;
	btnHeight : Real;
	btnTop : Real;
	left2 : Real;
	left3 : Real;
	left4 : Real;

begin

	//inheritMethod();  //super class version is based on visibility....
	
	btnWidth := ( self.clientWidth - ( 5 * self.resizedMargin )) / 4;
	btnHeight := self.getCMDButtonsHeight();
	btnTop := self.clientHeight - btnHeight - self.resizedMargin;
	
	if btnWidth &gt; 4 * btnHeight then
		btnWidth := 4 * btnHeight;
	endif;
	
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(HhSpreadButtons).Boolean then
		left2 := ( self.clientWidth - self.resizedMargin - btnWidth ) * (2 / 3);
		left3 := ( self.clientWidth - self.resizedMargin - btnWidth ) * (1 / 3);
		left4 := self.resizedMargin;
	endif;
	
	self.btnOne.width := btnWidth;
	self.btnOne.height := btnHeight;
	self.btnOne.top := btnTop;
	self.btnOne.left := self.clientWidth - self.resizedMargin - btnWidth;
	
	self.btnTwo.width := btnWidth;
	self.btnTwo.height := btnHeight;
	self.btnTwo.top := btnTop;
	if left2 &gt; 0 then
		self.btnTwo.left := left2;
	else
		self.btnTwo.left := self.btnOne.left - self.resizedMargin - btnWidth;
	endif;
	
	self.btnThree.width := btnWidth;
	self.btnThree.height := btnHeight;
	self.btnThree.top := btnTop;
	if left3 &gt; 0 then
		self.btnThree.left := left3;
	else
		self.btnThree.left := self.btnTwo.left - self.resizedMargin - btnWidth;
	endif;
		
	self.btnFour.width := btnWidth;
	self.btnFour.height := btnHeight;
	self.btnFour.top := btnTop;
	if left4 &gt; 0 then
		self.btnFour.left := left4;
	else
		self.btnFour.left := self.btnThree.left - self.resizedMargin - btnWidth;
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="735f3bc2-b054-4222-9e81-c84d1cd5cbce">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	cargoId : String;
	term : CM_Terminal;
	tiArray : CM_TIArray;
	voyage : CM_Voyage;
	location: CM_LocationsController;
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.id &lt;&gt; cargoId then
			self.myMobileGenericAgent.setSplitValues( 0, 0, null );
		endif;
	endif;

	self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
	self.lblCargoType.caption := null;
	self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
	self.txtQuantity.text := null;
	self.cmbSlotLocation.clear();	//14 Jun 2016	NDL	TFS 2156
	
	term := self.myMobileDataAgent.myTerminal;
	voyage := self.myMobileGenericAgent.myVoyage;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
		self.myMobileGenericAgent.findLanderCargo(cargoId,tiArray);		
	endif;
		
	if not manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.setMyTrackedItem(	tiArray.first, null );	//23 Sep 2013	NDL	Par 32479		
		populateTrackedItem();
		return;
		
	else
		// more than one found.
		app.myMobileCargoFindAgent.setMyVoyage( self.myMobileGenericAgent.myVoyage );
		app.myMobileCargoFindAgent.setMyBOL( self.myMobileGenericAgent.myBOL );
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		
		//10 Apr 2018	NDL	TFS 37593
		if self.showToGround then
			if self.cmbTA.listObject.isKindOf(CM_CraneTransferArea) then
				self.myMobileGenericAgent.setMyCraneTransferArea(self.cmbTA.listObject.CM_CraneTransferArea);
				self.myMobileGenericAgent.setMyWorkPoint(null);														
			elseif self.cmbTA.listObject.isKindOf(CM_WorkPointInterchangeArea) then									
				self.myMobileGenericAgent.setMyCraneTransferArea(null);												
				self.myMobileGenericAgent.setStringField1(self.cmbTA.listObject.CM_WorkPointInterchangeArea.id);	
			endif;
			self.myMobileGenericAgent.setMyLocationsController(self.cmbLane.listObject.CM_LocationsController);
		else
			app.myMobileCargoFindAgent.setStringField1( self.txtLocation.text );
		endif;
		
		if self.txtQuantity.visible then
			app.myMobileCargoFindAgent.setStringField2(self.txtQuantity.text.trimBlanks);	//01 Aug 2013	NDL	Par 32140
		else
			app.myMobileCargoFindAgent.setStringField2(null);
		endif;
		//02 Apr 2014	NDL	CCMS 1366
		if self.tblWeightVolume.visible then
			app.myMobileCargoFindAgent.setDecimalField1(self.tblWeightVolume.getConvertedValue);
		else
			app.myMobileCargoFindAgent.setDecimalField1(0.00);
		endif;
		app.myMobileCargoFindAgent.setDoSearchImmediate(true);
		
		//11 Oct 2010	NDL	Par 25836
		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo
		or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard then
			app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSHIP);
		else
			app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		endif;
	
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setMyWle(null);	//23 Sep 2013	NDL	Par 32479
		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	

epilog
	delete tiArray;


end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLblQuantity" id="6b7aa1e1-0240-45d0-b4d8-6a675dcacdb4">
        <updating/>
        <source>setLblQuantity() updating;
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
//	str: String;
//	pos: Integer;
	job : CM_Job;
	wle : CM_WorkListEntry;
	quantity : Integer;
	locale	: CM_Locale;
	
begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canMergeBreakBulk then
		
		wle := self.myWorkListEntry;
		if wle = null and self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
			self.getExportVoyageJobWle( wle, false );
		endif;
		if wle = null or wle.isPlanned then   // 34510 DJW 7 Jul 2014
			quantity := self.myTrackedItem.totalQuantity;
		else
			quantity := wle.quantity;
		endif;
	endif;
	
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
	endif;
	
	if self.myTrackedItem = null
	or ( not self.myTrackedItem.isBulkByWeight and not self.myTrackedItem.isBulkByVolume )
	then
	
		self.lblQuantity.translateCaption(Xlat_0019103, locale);
		
		if quantity &gt; 0 then
			self.lblQuantity.caption := self.lblQuantity.caption &amp; " (" &amp; quantity.String &amp; ")";
		endif;
	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9c2057ee-d698-4a19-9c58-29c078aedfd4">
        <updating/>
        <source>setMyTrackedItem(	_ti : CM_TrackedItem; _wle : CM_WorkListEntry ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

begin

	self.myTrackedItem := _ti;
	self.myWorkListEntry := _wle;
	
	self.setLblQuantity();

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setTxtLocationDetails" id="2547090d-493e-475b-93ab-230ea03fd02c">
        <source>setTxtLocationDetails( _text : String; _location : CM_LocationsController ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2011	cnwndl1	Initial creation	Par 28254

*/

vars

begin

	self.txtLocation.text := _text;
	self.txtLocation.userObject := _location;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="ce6d8c08-6307-4af7-9ebb-dcb8034c7c87">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10/02/2010	cnwndl1	Initial creation
29/01/2018	jlgdap1	TFS 36405 SNO Correct handling of work points when doing cargo checks
*/

vars

	state : Integer;
	top : Real;
	stdWidth : Real;
	width : Real;
	halfWidth : Real;
	
	isoType : CM_ISOType;
	iter : Iterator;
	index : Integer;
	
	btnHeight : Real;
	btnTop : Real;
	btnWidth : Real;
	btnLeft : Real;
	stdHeight : Real;
	tabIndex : Integer;
	
	wpic : CM_WorkPointInterchangeArea;			// TFS 36405
	
begin
	
	self.doResizeControls( true );
	
	populateTrackedItem();
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
		btnThree.enabled := true;
	else
		btnThree.enabled := false;
	endif;
	
	//30 July 2010	NDL	Par 25158
	if self.showToGround then
		if self.myMobileGenericAgent.myCraneTransferArea	&lt;&gt; null then
			cmbTA.listIndex := cmbTA.findObject(self.myMobileGenericAgent.myCraneTransferArea);
			self.doChangeTerminalArea();
		elseif self.myMobileGenericAgent.stringField1 &lt;&gt; null then															// TFS 36405
			wpic := self.myTerminal.allTerminalAreas[self.myMobileGenericAgent.stringField1].CM_WorkPointInterchangeArea;	// TFS 36405
			self.cmbTA.listIndex := self.cmbTA.findObject(wpic);															// TFS 36405
			self.doChangeTerminalArea();																					// TFS 36405
		endif;
		if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
			self.cmbLane.listIndex := self.cmbLane.findObject(self.myMobileGenericAgent.myLocationsController);
		endif;
		self.myMobileGenericAgent.setMyCraneTransferArea(null);
		self.myMobileGenericAgent.setMyLocationsController(null);
		self.myMobileGenericAgent.setStringField1(null);																	// TFS 36405
	endif;

epilog

	//08 May 2014	NDL	Par 33926
	self.checkAllowTargetChange();

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f38b8573-352a-4e67-b4c9-6d4cc63ecc39">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	//10 Jul 2012	NDL	Par 29961
	self.myMobileGenericAgent.setHHLanderGroundingOpt();
	if self.myMobileGenericAgent.dischargeToHHOption = DiscHHLander_ToMach then	//13 Aug 2012	NDL	Par 29961
		self.toGroundAllowed := false;
	else
		self.toGroundAllowed := self.myMobileGenericAgent.hhLanderGroundingOpt &lt;&gt; NoOpts; // 0,2,3 all OK.
	endif;

	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo and ( not self.toGroundAllowed ) then	//10 Jul 2012	NDL	Par 29961
		self.setupCmdButtons(3, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Back), null, null );
	elseif self.showToGround then
		self.setupCmdButtons(3, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Back), null, null );
	else
		self.setupCmdButtons( 4, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Ground), app.getErrorString(Back), null );
	endif;
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	//self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToProcess; // populated if returning from a search.
	self.setMyTrackedItem(	app.myMobileCargoFindAgent.myTrackedItemToProcess, null );	//23 Sep 2013	NDL	Par 32479
	if self.myTrackedItem = null then
		//self.myTrackedItem := self.myHandHeldCheckerAgent.myNextTiToAction;	// returning from another screen
		self.setMyTrackedItem(	self.myMobileGenericAgent.myNextTiToAction, self.myMobileGenericAgent.myWle );	//23 Sep 2013	NDL	Par 32479
	endif;
	
	//05 Aug 2013	NDL	Par 32156
	if self.isVoyageNonWorked then
		self.lblMachine.caption := self.lblLocation.caption;
	endif;

	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTblWles" id="6a3c1f7e-acc1-4dd3-9fce-ec4c6a21cff0">
        <updating/>
        <source>setupTblWles() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	state : Integer;
	tabIndex : Integer;
	top : Real;
	tblHeight : Real;
	makeVisible : Boolean;
	wle : CM_WorkListEntry;
	tableString : String;
	index : Integer;
	wleLocationId : String;
	preSelectWleAt : Integer;
	preSelectWle : CM_WorkListEntry;
	lc : CM_LocationsController;
	wleAmount : String;
    resdet : CM_ReserveDetail;
    voyreq : CM_VoyageRequest;
begin

	self.setResizeableMarginAndFontSize();
	top := self.txtQuantity.top + self.txtQuantity.height + self.resizedMargin;
	if self.btnAddCargo.visible then
		tblHeight := btnAddCargo.top - ( self.resizedMargin + top );
	else
		tblHeight := btnOne.top - ( self.resizedMargin + top );
	endif;
	state := self.myMobileGenericAgent.checksState;
	tabIndex := self.btnAddCargo.tabIndex + 1;
						
	self.tblWles.fixedRows := 1;
	self.tblWles.fixedColumns := 0;
	self.tblWles.rows := 1;
	self.tblWles.columns := 3;
	
	if self.myTrackedItem &lt;&gt; null  then // TFS 3673
		if self.myTrackedItem.isBulkCargo then // TFS 3673
			self.tblWles.setCellText(1,1,"RT" &amp; Tab &amp; app.getErrorString(CM_Weight) &amp; Tab &amp; app.getErrorString(Location)); // TFS 3673
		else
			self.tblWles.setCellText(1,1,"RT" &amp; Tab &amp; app.getErrorString(CM_Quantity) &amp; Tab &amp; app.getErrorString(Location)); // TFS 3673
	
		endif;
	else
		self.tblWles.setCellText(1,1,"RT" &amp; Tab &amp; app.getErrorString(CM_Quantity) &amp; Tab &amp; app.getErrorString(Location));
	endif;
	
	if state = self.myMobileGenericAgent.ShipDischargeCargo or state = self.myMobileGenericAgent.ShiftOnBoard then
			makeVisible := false;
			
	elseif state = self.myMobileGenericAgent.ShipLoadCargo then
		if self.myWorkListEntry &lt;&gt; null then
			preSelectWle := self.myWorkListEntry;
			if self.myTrackedItem = null
			or ( not self.myTrackedItem.allWorklistEntries.includes(preSelectWle) and not preSelectWle.isTiAssignedToResDet( self.myTrackedItem )     )
			or preSelectWle.status = WLE_COMPLETED
			or not preSelectWle.isKindOf(CM_VoyageWLE)
			or preSelectWle.isReceipt
			then
				preSelectWle := null;
			endif;
		endif;
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canMergeBreakBulk then
			foreach wle in self.myTrackedItem.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if not wle.isKindOf(CM_VoyageWLE) then
					continue;
				endif;
				if wle.isReceipt then
					continue;
				endif;
				// 34510 DJW 4 July 2014 Ignore WLES that are not targeting this voyage
				lc := wle.getTargetLocation;
				if lc &lt;&gt; null and lc.isVoyageController then
					if self.myMobileGenericAgent.myVoyage &lt;&gt; lc.CM_VoyageController.myVoyage then
						continue;
					endif;
				endif;

				wleLocationId := null;
				if wle.myFutureMove &lt;&gt; null then
					wleLocationId := wle.myFutureMove.getPrimaryLocationId();
				endif;
				
				if self.myTrackedItem.isBulkCargo then // TFS 3673
					wleAmount := wle.weight.asStringWeightJMT(); // TFS 3673
				else
					wleAmount := wle.quantity.String;
				endif;

				tableString := wle.getDisplayStringForAttribute(ETRow_RadioTelemetry,false) &amp; Tab &amp; 
								wleAmount	 &amp; Tab &amp; 
								wleLocationId;
								
				
				index := self.tblWles.addItem(tableString);
				self.tblWles.accessRow( index ).itemObject := wle;
				if preSelectWle = null then
					lc := wle.getTargetLocation;
					if lc &lt;&gt; null and lc.isVoyageController then
						if self.myMobileGenericAgent.myVoyage = lc.CM_VoyageController.myVoyage then
							preSelectWleAt := index;
							preSelectWle := wle;
						endif;
					endif;
				elseif preSelectWle = wle then
					preSelectWleAt := index;
				endif;
			endforeach;
			
			
			
			if self.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean then	//16 Jul 2018	NDL	TFS 38679
			
				// TFS 3190 - If no WLEs, look for ship rel reqs that are assigned to HOLD locations
				makeVisible := self.tblWles.rows &gt;= self.tblWles.fixedRows + 2;
	
				if not makeVisible then
				
					foreach resdet in self.myTrackedItem.allReserveDetails discreteLock do
						foreach voyreq in resdet.allVoyageRequestsAssigned discreteLock do
							if voyreq.isComplete then
								continue;
							endif;
							wle := voyreq.allWorkListEntries.first;
							
							if wle.status = WLE_COMPLETED then
								continue;
							endif;
							if not wle.isKindOf(CM_VoyageWLE) then
								continue;
							endif;
							if wle.job = null then
								continue;
							endif;
							if not wle.job.isVoyageHoldJob() then
								continue;
							endif;
							if wle.isReceipt then // LOAD ONLY
								continue;
							endif;
							lc := wle.getTargetLocation();
							if lc &lt;&gt; null and lc.isVoyageController then
								if self.myMobileGenericAgent.myVoyage &lt;&gt; lc.CM_VoyageController.myVoyage then
									continue;
								endif;
							endif;
			
							wleLocationId := null;
							if wle.myFutureMove &lt;&gt; null then
								wleLocationId := wle.myFutureMove.getPrimaryLocationId();
							endif;
							
							if self.myTrackedItem.isBulkCargo then // TFS 3673
							
								wleAmount := app.getWeightForDefaultDisplay(wle.weight); // TFS 3673
							else
								wleAmount := wle.quantity.String;
							endif;
							
							tableString := wle.getDisplayStringForAttribute(ETRow_RadioTelemetry,false) &amp; Tab &amp; 
											wleAmount	 &amp; Tab &amp; 
											wleLocationId;
											
							index := self.tblWles.addItem(tableString);
							self.tblWles.accessRow( index ).itemObject := wle;
							
							
							
						endforeach;
					endforeach;
				
				endif;
				
			endif;
			
			makeVisible := self.tblWles.rows &gt;= self.tblWles.fixedRows + 2;
			
			if makeVisible and preSelectWleAt &gt; self.tblWles.fixedRows and preSelectWleAt &lt;=  self.tblWles.rows then
				self.tblWles.accessRow( preSelectWleAt ).selected := true;
				self.setMyTrackedItem( self.myTrackedItem, preSelectWle );
				self.tblWles.row := preSelectWleAt;
				
			endif;
		
		else
			makeVisible := false;
			
		endif;
		
		
	endif;
	
	self.tblWles.visible := makeVisible;
	self.tblWles.setAndIncrementTabIndex( tabIndex );
	self.tblWles.move(	self.resizedMargin,
						top,
						self.clientWidth - self.resizedMargin -self.resizedMargin,
						tblHeight );
						
	self.setLblQuantity();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showToGround" id="3d12ebb7-7688-42d3-ba20-c18c96a55684">
        <source>showToGround() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2010	cnwer1	Initial creation

*/

vars
	state : Integer;
begin
	state := self.myMobileGenericAgent.checksState;
	
	if state = self.myMobileGenericAgent.ShipDischargeCargo then
		return  self.myMobileGenericAgent.dischargeToHHOption = DiscHHLander_ToGround;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showToMachine" id="bf585fd1-6603-4e9c-a18e-e0ae6559d72d">
        <source>showToMachine() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2010	cnwer1	Initial creation

*/

vars
	state : Integer;
begin
	state := self.myMobileGenericAgent.checksState;
	
	if state = self.myMobileGenericAgent.ShipDischargeCargo then
		return  self.myMobileGenericAgent.dischargeToHHOption = DiscHHLander_ToMach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblWles_mouseUp" id="0d523e15-eeaf-4744-a54f-1386a8cc70e0">
        <controlMethod name="CM_Table::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWles_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	row : Integer;
	obj : Object;
	wle : CM_WorkListEntry;

begin

	self.setMyTrackedItem( self.myTrackedItem, null );
	row := self.tblWles.row;
	if row &gt; self.tblWles.fixedRows and row &lt;= self.tblWles.rows then
	
		obj := self.tblWles.accessRow( self.tblWles.row ).itemObject;
		if obj &lt;&gt; null and CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.allWorklistEntries.includes( wle ) then
				self.setMyTrackedItem( self.myTrackedItem, wle );
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="toggleChecksQueueButton" id="85d37ee8-4618-4c31-b33b-c19064c63b9b">
        <source>toggleChecksQueueButton();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

	lc: CM_LocationsController;

begin

	if self.myMobileGenericAgent.checksState &lt;&gt; self.myMobileGenericAgent.ShipDischargeCargo then
		//don't touch it.
		return;
	endif;
	
	self.btnTwo.caption := app.getErrorString(Checks);
	self.txtLocation.enabled := true;
	self.btnOne.enabled := true;
	self.btnInTransit.enabled := true;
	self.btnThree.enabled := true;
	
	if self.toGroundAllowed then
		if self.myTrackedItem &lt;&gt; null then
			lc := self.myTrackedItem.myPrimaryActualLocation;
			if lc &lt;&gt; null and ( lc.isCraneLaneController  or ( lc.isYardLocation and lc.CM_YardController.isInterchangeAreaLocation ) ) then
				if not self.myTrackedItem.isQueued then
					//the user has selected a ti that is sitting in an interchange area that has been landed and completed.
					//They might now want to queue it to a proper position in the yard.
					self.btnTwo.caption := app.getErrorString(Queue);
					self.txtLocation.enabled := false;
					self.btnOne.enabled := false;
					self.btnInTransit.enabled := false;
					if btnThree.caption &lt;&gt; app.getErrorString(Back) then
						self.btnThree.enabled := false;
					endif;
					
				elseif self.myTrackedItem.isQueued then
					lc := self.myTrackedItem.myPrimaryQueuedLocation;
					if lc.isYardLocation then
						if btnThree.caption &lt;&gt; app.getErrorString(Back) then
							self.btnThree.enabled := false;
						endif;
					endif;
					
				endif;
			endif;
		endif;
	endif;
	

epilog

	//08 May 2014	NDL	Par 33926
	self.checkAllowTargetChange();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fee10d2d-b968-4d7e-b48e-2bdf5c24c94d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013957, locale);
	btnAddCargo.translateCaption(Xlat_0016610, locale);
	btnAutoPlan.translateCaption(Xlat_0014417, locale);
	btnChangeJob.translateCaption(Xlat_0018480, locale);
	btnInTransit.translateCaption(Xlat_0018055, locale);
	lblCargoId.translateCaption(Xlat_0013958, locale);
	lblLane.translateCaption(Xlat_0015176, locale);
	lblLocation.translateCaption(Xlat_0013959, locale);
	lblMachine.translateCaption(Xlat_0014800, locale);
//	lblNewCargoId.translateCaption(Xlat_0019102, locale);
	lblQuantity.translateCaption(Xlat_0019103, locale);
	lblShipLocation.translateCaption(Xlat_0015177, locale);
	lblState.translateCaption(Xlat_0013960, locale);
	lblTA.translateCaption(Xlat_0015178, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="8c8d2927-b00d-4b76-87eb-40611156828b">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		//self.txtCargoId.text := null;
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="087ce765-d061-4224-8b39-c216f0924909">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		//self.selectCargoItem( false );
		//24 Jun 2013	NDL Par 31886
		if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text )
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )	//01 Aug 2013	NDL	Par 32140
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="49ca2abb-b35f-42e5-99b3-f4b4c1cf667c">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then	//17 May 2010	NDL	Par 23603
		if self.txtLocation.text = self.lblMachine.caption.toUpper then
			self.txtLocation.selStart := 0;
			self.txtLocation.selLength := self.lblMachine.caption.length;
		endif;
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then	
		if self.txtLocation.text = self.lblShipLocation.caption.toUpper then
			self.txtLocation.selStart := 0;
			self.txtLocation.selLength := self.lblShipLocation.caption.length;
		endif;
	else
		if self.txtLocation.text = self.lblLocation.caption.toUpper then
			self.txtLocation.selStart := 0;
			self.txtLocation.selLength := self.lblLocation.caption.length;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="e7ed0e97-b8dc-4d23-8a81-cb479c4a2e21">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if self.txtLocation.text.trimBlanks = null then
		self.resetLocationDisplay;
	
	//01 Aug 2013	NDL	Par 32140
// PAR 33644	elseif self.myHandHeldCheckerAgent.myVoyage.isNonWorkedVoyage then
//	elseif self.myHandHeldCheckerAgent.myVoyage.isHOLDSorSHIP() then // NO LOLO or RORO structure i.e No Job Sheet.
	else//// 02 Apr 2014	NDL	CCMAS 1366
		if self.txtLocation.userObject &lt;&gt; null then
			if self.txtLocation.text &lt;&gt; self.txtLocation.userObject.CM_LocationsController.getFullId then
				self.txtLocation.userObject := null;
			endif;
		endif;
	endif;
	
	self.txtLocation.selStart := 0;
	self.txtLocation.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
