    <JadeMethod name="getAllCheckAreas" id="bfa29876-6616-401c-9de1-dcafe302fbe2">
        <source>getAllCheckAreas(_terminal : CM_Terminal; _checkAreas : IntegerArray io);

vars
	stopTableTemplate : CM_StopTableTemplate;
begin
	stopTableTemplate := self.allStopTableTemplates[_terminal, self];
	_checkAreas.clear;
	if stopTableTemplate &lt;&gt; null then
		stopTableTemplate.allPreventAreas.copy(_checkAreas);
	endif;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_checkAreas" type="IntegerArray" usage="io"/>
    </JadeMethod>
