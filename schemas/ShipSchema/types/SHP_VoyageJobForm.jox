    <JadeMethod name="doCancel" id="1d3205d9-660f-4e6c-8f97-efe8195dc8f6">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if self.tblJobEdit.hasChanged then
		theReturn := app.msgBox(app.getErrorString1(ConfirmCancel, 'some data'),"Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComboBayIdBuild" id="ccd4395b-a764-4334-9c14-01c02cf1bcf7">
        <source>doComboBayIdBuild();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aVoyage : CM_Voyage;
	idx : Integer;
begin
	self.cmbBayId.clear;
	if self.filterVoyage = null then
		return;
	endif;
	
	aVoyage := self.filterVoyage;
	if aVoyage = null then
		return;
	elseif aVoyage.myCellularVoyageStructure = null then
		return;
	endif;
	
	
	foreach aBay in aVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal do
		idx := self.cmbBayId.addItem(aBay.id);
		self.cmbBayId.itemObject[idx] := aBay;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboCraneWorkPointBuild" id="9f301fcb-01b9-403d-b164-fb600f12a63e">
        <source>doComboCraneWorkPointBuild() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/07/2011	cnwer1	Initial creation CCMS MES 1033
07/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
*/

vars
	addCranes,
	addWorkPoints : Boolean;
begin
	self.cmbCrane.clear;
	
	addCranes:=true;
	addWorkPoints:=true;
	
	if self.mode &lt;&gt; self.Mode_Add then
		//epr par 31094 11/2/12
		//if self.myCurrentObject.isKindOf(CM_VoyageDeckJob) then	// TFS 3516
		if self.myCurrentObject.isKindOf(CM_VoyageDeckJob) 			// TFS 3516
		or self.myCurrentObject.isKindOf(CM_VoyageHoldJob) then		// TFS 3516
			addCranes:=false;
		else
			addWorkPoints:=false;
		endif;	
	endif;
	
	//epr par 31094 11/2/12
	self.myAssistant.comboBoxVoyageWorkPoints(self.cmbCrane,self.filterVoyage,addCranes,addWorkPoints);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboDeckIdBuild" id="e3a5ec4c-b4fc-4ca7-b599-809cee906bd8">
        <source>doComboDeckIdBuild() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.cmbDeckId.clear;
	if self.filterVoyage = null then
		return;
	endif;
	
	if self.filterVoyage.myROROStructure = null then
		return;
	endif;
	
	self.myAssistant.comboBoxRORODecks(self.cmbDeckId,self.filterVoyage.myROROStructure,null);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboHatchLidClick" id="4eccdd62-b040-4862-b9e3-af3422bf60f1">
        <source>doComboHatchLidClick(_table : Table; _row : Integer; _entRowTransName : String;_value : String);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if mode &lt;&gt; self.Mode_View then
		self.cmbHatchLids.height := self.cmbHatchLids.rows * 17;
	endif;
end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_entRowTransName" type="String"/>
        <Parameter name="_value" type="String"/>
