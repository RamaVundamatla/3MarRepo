    <JadeMethod name="getChargedDaysWorking" id="bb7e14d2-6382-46c0-8d3b-8c4081dda7a4">
        <source>getChargedDaysWorking() : Boolean;
// CCMS 1295 free storage days, modified CCMS DPH 2278 for extended charged and free day types
vars
	result	: Boolean;
	chargeType	: Integer;
begin
	if self.myTrackedItem &lt;&gt; null then
		chargeType := self.myTrackedItem.getChargedDaysType();
		if chargeType = CM_StorageDetail.Working_Days then
			result := true;
		endif;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChargedDaysWorkingAndComp" id="2723f445-2d04-41db-8b03-6167d4713344">
        <source>getChargedDaysWorkingAndComp():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2017	jlgndl1	Initial creation	TFS 7032

*/

vars
	result	: Boolean;
	chargeType	: Integer;
begin
	if self.myTrackedItem &lt;&gt; null then
		chargeType := self.myTrackedItem.getChargedDaysType();
		if chargeType = CM_StorageDetail.Working_Compulsory_Days then
			result := true;
		endif;
	endif;
	
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCompletedTaskString" id="521f577c-1d15-4082-969f-72d3366e8ed3">
        <source>getCompletedTaskString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	str : String;
	usage : CM_ResourceTypeUsage;
	usageStr : String;
	resourceStr : String;
	toDoRemarks : String;
	
begin

	if self.myToDoTask = null then
		//str := app.getErrorString(Todo_Task_Completed) &amp; self.typeString;	//cnwrs1 CCMS 1826 29 July 2010
	else
		if self.myToDoTask.toDoTaskDescTrxTypeOnCreate = self.type then	//cnwrs1 CCMS 1826 29 July 2010
			str := app.getErrorString(Todo_Task_Created) &amp; self.myToDoTask.toDoTaskDescDesc;
		elseif self.myToDoTask.toDoTaskDescTransType = self.type then
			str := app.getErrorString(Todo_Task_Completed) &amp; self.myToDoTask.toDoTaskDescDesc;
		endif;
	endif;
	
	if not self.allResourceUsages.isEmpty then
		
		foreach usage in self.allResourceUsages do
			usageStr := usage.displayLine;
			if usageStr &lt;&gt; null then
				if resourceStr &lt;&gt; null then
					resourceStr := resourceStr &amp; ", ";
				endif;
				resourceStr := resourceStr &amp; usageStr;
			endif;
		endforeach;
		if resourceStr &lt;&gt; null then
			str := str &amp; "  " &amp; "Resources used" &amp; ": " &amp; resourceStr;
		endif;
	endif;
	
	//06 Jan 2016	NDL	Par 37379
	self.appendToDoTaskRemarks( str );
	
	//03 Nov 2014	NDL	Par 35160
	self.appendReferenceString( str );
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignGroupCode" id="3ce57bbc-5afd-4723-86f6-c6f3367dacb8">
        <source>getConsignGroupCode() : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 9 November 2018
TFS#		: 40670
Function	: Return concatenated string of Consignee and Consignor Group.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	consigneeConsignorGroup : String;
	consigneeConsignor		: CM_ConsigneeConsignor;
begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.consignee &lt;&gt; null then
		consigneeConsignor := app.myRoot.allConsigneeConsignors[self.myTrackedItem.consignee];
		if consigneeConsignor &lt;&gt; null then
			if consigneeConsignor.myConsignGroup &lt;&gt; null then
				consigneeConsignorGroup := consigneeConsignor.myConsignGroup.code;
			endif;
		endif;
	endif;
	
	if self.myTrackedItem.consignor &lt;&gt; null and self.myTrackedItem.consignee &lt;&gt; self.myTrackedItem.consignor then
		consigneeConsignor := app.myRoot.allConsigneeConsignors[self.myTrackedItem.consignor];		
		if consigneeConsignor &lt;&gt; null then
			if consigneeConsignorGroup &lt;&gt; null then
				if consigneeConsignor.myConsignGroup &lt;&gt; null then
					if consigneeConsignorGroup &lt;&gt; consigneeConsignor.myConsignGroup.code then	
						consigneeConsignorGroup := consigneeConsignorGroup &amp; ", " &amp; consigneeConsignor.myConsignGroup.code;
					endif;
				endif;
			else
				if consigneeConsignor.myConsignGroup &lt;&gt; null then
					consigneeConsignorGroup := consigneeConsignor.myConsignGroup.code;		
				endif;	
			endif;
		endif;
	endif;	
	return consigneeConsignorGroup;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="c24c4b28-046e-4cd0-a9d7-f6f3a307e66d">
        <source>getConsignee(): CM_ConsigneeConsignor;
//----------------------------------------------------------------
//	Created:	28 June 2005	by Jason Chapman  (cnwjc2)
//
//	Is used in reports
//----------------------------------------------------------------
vars	
	root	: CM_Root;
begin

	if self.consignee = null then
		return null;
	endif;

	if self.myTerminal &lt;&gt; null then
		root := self.myTerminal.myRoot;
	else
		return null;
	endif;

	return root.allConsigneeConsignors[self.consignee];

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getConsigneeDesc" id="8b2dca7c-f008-4e84-8a53-e0976ddbc157">
        <source>getConsigneeDesc() : String;

/*
Purpose:	Return the TrackedItem myConsignee Description (if not null else returns null).
			This is used in JadeReportWriter so do not delete.

Date			Who		Reason
18 May 2010		cnwrl1	Initial creation as part of PAR 24246 - Make Consignee and Consignor Description available in JRW
*/
	
vars
	
begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	return self.myTrackedItem.getConsigneeDesc();
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignor" id="6b0c0f77-409b-4c98-aa51-840e39636ebb">
        <source>getConsignor(): CM_ConsigneeConsignor;
//----------------------------------------------------------------
//	Created:	28 June 2005	by Jason Chapman  (cnwjc2)
//
//	Is used in reports
//----------------------------------------------------------------
vars	
	root	: CM_Root;
begin

	if self.consignor = null then
		return null;
	endif;

	if self.myTerminal &lt;&gt; null then
		root := self.myTerminal.myRoot;
	else
		return null;
	endif;

	return root.allConsigneeConsignors[self.consignor];

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getConsignorDesc" id="a2e20c8b-cb80-4ee1-9f91-aa3f1acf2412">
