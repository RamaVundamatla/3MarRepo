    <JadeMethod name="doGenerateAuthToken" id="11d73036-a286-4f95-ba1d-1f2c82bb87c8">
        <source>doGenerateAuthToken();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
02 November 2023	navmd1	TFS 61072 Fix clearing password on edit after we've masked it

*/

vars
	theForm : SOP_TableMaintForm;
	formObj	: SOP_GenerateAuthTokenForm;
	token 	: CM_LongString;
	
begin
	theForm := self.myForm;
	
	create formObj;
	create token transient;
	
	formObj.setReturnString(token);
	formObj.showModal();
	
	if formObj.modalResult= IDOK then
		theForm.tblInput1.setValueByName(ETRow_Password, token.string);		// Show in the table
		theForm.setEnteredPassword(token.string);							// Actually used when saving to db
	endif;
	
epilog
	delete token;
end;</source>
    </JadeMethod>
