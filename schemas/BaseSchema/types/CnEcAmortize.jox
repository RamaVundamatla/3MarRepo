    <ImplicitInverseRef name="allLoanInstalments" id="79d5b3c3-04dc-4f30-a2a8-55aaa0f76c49">
        <memberTypeInverse/>
        <type name="CnEcLoanInstalmentArray"/>
        <access>readonly</access>
