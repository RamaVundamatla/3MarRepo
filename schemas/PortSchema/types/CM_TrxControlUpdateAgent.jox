    <JadeMethod name="trxMachineDriverInitiatedMove" id="6e5c521c-44b8-488c-8927-59f02d44e9a9">
        <updating/>
        <source>trxMachineDriverInitiatedMove(	_machine : CM_Machine input;
								_ti : CM_TrackedItem input;
								_twinTi : CM_TrackedItem input;
								_moveQuantity : Integer;
								_moveWeight : Decimal;
								_passport : CM_Passport input) updating;
/*

Date		Who		Reason
26 May 2017	cnwer1	Initial creation TFS 995

*/

vars

	autoPlan : Boolean;
	terminal : CM_Terminal;
	rtConfig :  CM_RTVehicleConfig;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.initialiseForStartAutoPlan(_passport);
	
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	self.raiseExceptionIfNull(_ti, app.getErrorString(Cargo));
	
	if _passport.hasErrors() then
		return;
	endif;
	
	terminal := _machine.getMyTerminal();
	rtConfig := terminal.getRTVehicleConfigForObject(_machine);
	
	if rtConfig = null then
		//raise error
		app.raiseCMException1(Machine_require_vehicle_config,_machine.id,null,null);
		return;
	endif;
	
	//epr TFS 6846 8/9/17
	autoPlan:=rtConfig.autoplanDriverInitiatedMove;
	
	beginTransaction;

	app.myUtilityUA.utlMachineCreateInitiatedMove(	_ti,_twinTi,_machine ,_moveQuantity ,	_moveWeight ,autoPlan,false,_passport);
	
	_passport.doDeferredUpdates();
		
epilog
	
	self.finaliseActivityWithPassport(_passport);


end;</source>
