    <JadeMethod name="getDisplayStringForAttribute" id="aa9f084c-6e3a-4608-8f3c-45fc4d1fa453">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
08 August 2023	navab1	CR 56094 TASK 59618
*/

vars

begin
	if _attrName = ETRow_CustAgent then
		if self.myCustomsAgent &lt;&gt; null then
			return self.myCustomsAgent.code;
		endif;
		return null;

	elseif _attrName = ETRow_HsCodes then
		if self.myHSCode &lt;&gt; null then
			return self.myHSCode.description;
		endif;
		return "";
	elseif	_attrName = ETRow_CargoTypeCode then
		return self.getCargoTypeCode();
	elseif	_attrName = ETRow_CargoTypeDesc then
		return self.getCargoTypeDesc();
	elseif	_attrName = ETRow_CargoSubTypeCode then
		return self.getCargoSubTypeCode();
	elseif	_attrName = ETRow_CargoSubTypeDesc then
		return self.getCargoSubTypeDesc();
	elseif	_attrName = ETRow_CommodityCode then
		return self.getCommodityCode();
	elseif	_attrName = ETRow_CommodityDesc then
		return self.getCommodityDesc();
	elseif	_attrName = ETRow_HasAttachments then
		return self.hasAttachments().getYes();
	elseif _attrName = ETRow_CustAgentDesc then
		if self.myCustomsAgent &lt;&gt; null then
			return self.myCustomsAgent.name;
		endif;
		return null;
	elseif _attrName = ETRow_CustLicense then
		if self.myCustomLicense &lt;&gt; null then
			return self.myCustomLicense.code;
		endif;
		return null;
	elseif _attrName = ETRow_CustLicenseDesc then
		if self.myCustomLicense &lt;&gt; null then
			return self.myCustomLicense.description;
		endif;
		return null;
	elseif _attrName = ETRow_CustDocType then
		if self.myCustomDocumentType &lt;&gt; null then
			return self.myCustomDocumentType.code;
		endif;
		return null;
	elseif _attrName = ETRow_CustDocTypeDesc then
		if self.myCustomDocumentType &lt;&gt; null then
			return self.myCustomDocumentType.description;
		endif;
		return null;
	elseif _attrName = ETRow_Direction then
		return CM_CustomDocumentType@getDirectStrFromInt(self.direction);
	elseif _attrName = ETRow_Sequence then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return self.sequence.String;  // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
	elseif _attrName = ETRow_Status then
		return CM_CustomDocument@getStatusStrFromInt(self.status); // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1 changed to status // ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1  CM_CustomDocument@getStatusStrFromInt(self.sequence);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
