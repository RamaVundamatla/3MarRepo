    <JadeMethod name="setOrig" id="7dee2113-2868-4068-b326-943c977796f6">
        <updating/>
        <source>setOrig() updating;
/*
Purpose: Set the orig values base of current values		

Date		Who		Reason
28 April 2011	cnwdw1	Initial creation
*/
vars

begin
	self.origTop := self.top;
	self.origLeft := self.left;
	self.origHeight := self.height;
	self.origWidth := self.width;
epilog

end;</source>
