    <JadeMethod name="machineConfig" id="bf844b4d-877b-44e8-a0e1-56dbbe7bcf15">
        <source>machineConfig(_machine: CM_Machine);
//10 February 2011	cnwdw1	
//
// 23/02/2012	cnwmh5		Replace use of _opts with self.opts
vars
	pxyRTVehicleConfig: CM_RTVehicleConfig;
	pxyTaskView,
	pxyCargoView,
	pxyDirectorView: EntTableView;

	entDef 			: EntTableDef;
	
	entTableRowArray : EntTableRowArray;
	entTableRow		: EntTableRow;
	removeQueueViewArray : StringArray;
	
begin

	if _machine.myRTVehicleConfig = null then
		self.machineDefaultConfig(_machine);
	endif;
	
	pxyRTVehicleConfig := app.createUpdateProxy(_machine.myRTVehicleConfig).CM_RTVehicleConfig;
	
	pxyRTVehicleConfig.setAutoResequenceJobs(self.opts.bool("AutoResequenceJobs"));
	pxyRTVehicleConfig.setPropertyValue("overstowMoveMode", self.opts.int("OverstowMoveMode"));							// 26/07/2011 cnwmh5
	pxyRTVehicleConfig.setPropertyValue("maxNumberOverstowForDriver", self.opts.int("MaxNumberOverstowForDriver"));  	// 26/07/2011 cnwmh5

	create pxyCargoView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
	entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
	create pxyDirectorView transient;
	entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);
	create pxyTaskView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
	pxyRTVehicleConfig.setViewDetails(pxyCargoView, pxyDirectorView, pxyTaskView);
	
	// 01/08/2014 cnwmh5 - remove supplied table rows
	if self.opts.includesKey("RemoveVisibleQueueEntry") then
		removeQueueViewArray := self.opts.obj("RemoveVisibleQueueEntry").StringArray;
		//create entTableRowArray transient;
		entTableRowArray := entDef.allEntTableRows;
		beginTransaction;
		foreach entTableRow in entTableRowArray do
			if removeQueueViewArray.includes(entTableRow.name) then
				pxyTaskView.allEntTableRows.remove(entTableRow);
			endif;
		endforeach;
		commitTransaction;
	endif;	
	
	app.myTrxUA.trxUpdateRTVehicleConfig(pxyRTVehicleConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog	
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="machineCraneActionPickup" id="e515a72b-7549-4918-b55a-7d647b91beb0">
        <source>machineCraneActionPickup(_machine : CM_Machine io; _ti, _twinTi : CM_TrackedItem io);

/*

Purpose:		Do twin crane pickup

Date			Who		Reason
27 October 2011	cnwmh5	Initial creation

*/

vars
	
	mediator				: CM_RadioTelemetryMediator;
	
begin

	create mediator transient;
	mediator.machine := _machine;
	mediator.canBeAllocatedTwinTasks := true;

	app.myTrxRT.trxActionCranePickup(_ti, _twinTi, mediator, true, false, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete mediator;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_twinTi" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="machineDefaultConfig" id="4a46d53d-3ed1-4750-ba1c-df26dcb70145">
        <source>machineDefaultConfig(_machine: CM_Machine);
//18 February 2011	cnwdw1	
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 01/07/2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
vars
	terminal : CM_Terminal;
	realRTVehicleConfig,
	pxyRTVehicleConfig : CM_RTVehicleConfig;
	screenBackColour,
	screenForeColour,
	tableBackColour,
	tableForeColour,
	taskViewMode,
	defaultTaskViewMode,
	overstowMoveMode,
	defaultGraphicView : Integer;
	allAvailableViews 	: IntegerArray;
	pxyDayScreenConfig,
	pxyNightScreenConfig : CM_RTScreenConfig;
	tbl : Table;
	pxyTaskView,
	pxyCargoView,
	pxyDirectorView: EntTableView;
	entDef 			: EntTableDef;
	doSwapCargoNotJob		: Boolean; //29/10/2025	navkc1 JIRA 36186
begin
	create tbl transient;
	//just add the top for now
	create allAvailableViews transient;
	allAvailableViews.add(CM_RTVehicleConfig.VIEW_TOP);
	
	taskViewMode:=CM_RTVehicleConfig.TASKVIEW_LIST;
	defaultTaskViewMode:=taskViewMode;
	
	terminal := getTerminal();
	
	realRTVehicleConfig:=null;
	create pxyRTVehicleConfig transient;

	create pxyDayScreenConfig transient;
	
	screenBackColour:= terminal.getConfig(DefaultRTColorBackground).Integer;
	if screenBackColour = 0 then
		screenBackColour:=tbl.getSystemColor(Form.Color_3DFace);
	endif;
	screenForeColour:=terminal.getConfig(DefaultRTColorForeground).Integer;
	if screenForeColour = 0 then
		screenForeColour:=tbl.getSystemColor(Form.Color_WindowText);
	endif;
	tableBackColour:=terminal.getConfig(DefaultRTColorTableBack).Integer;
	if tableBackColour = 0 then
		tableBackColour:=White;
	endif;
	tableForeColour:=terminal.getConfig(DefaultRTColorTableFore).Integer;
	if tableForeColour = 0 then
		tableForeColour:=tbl.getSystemColor(Form.Color_WindowText);
	endif;
	
	//29/10/2025	navkc1 JIRA 36186
	if self.opts.includesKey("doSwapCargoNotJob") then
		doSwapCargoNotJob := self.opts.bool("doSwapCargoNotJob"); //29/10/2025	navkc1 JIRA 36186
	endif;
	
	pxyDayScreenConfig.setDetails(	screenBackColour,
									screenForeColour,
									tableBackColour,
									tableForeColour,
									tableForeColour);
								
	create pxyNightScreenConfig transient;
	pxyNightScreenConfig.setDetails(screenBackColour,
									screenForeColour,
									tableBackColour,
									tableForeColour,
									tableForeColour);

	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	create pxyTaskView transient;
	entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
	
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
	create pxyCargoView transient;
	entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
	create pxyDirectorView transient;
	entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);

	if terminal.getConfig(AutoPlanShiftOverStows).Boolean then
		overstowMoveMode:=CM_RTVehicleConfig.OSTOW_AUTOPLAN;
	else
		overstowMoveMode:=CM_RTVehicleConfig.OSTOW_NONE;
	endif;

	pxyRTVehicleConfig.setDetails(	taskViewMode,
								defaultTaskViewMode,
								terminal.getConfig(AutoPlanAutomaticGetNextTask).Boolean,
								false,
								false,
								true,
								true,
								true,
								terminal.getConfig(AutoReseqJobsSetDown).Boolean,
								overstowMoveMode,
								0,
								true,
								true,
								terminal.getConfig(MaxNumOverstowMoves).Integer,
								terminal.getConfig(MaxRowsForRTQueries).Integer,
								terminal.getConfig(RtMaxNumQueueEntries).Integer,
								terminal.getConfig(RtNumOfSearchResults).Integer,
								allAvailableViews,
								defaultGraphicView,
								COLUMN_LABEL_TOP,
								ROW_LABEL_LEFT,
								terminal.getConfig(SelectorQueriesForRT).CM_SelectorQueryAccess,
								pxyNightScreenConfig,
								pxyDayScreenConfig,
								14,
								16,
								pxyCargoView,
								pxyDirectorView,
								pxyTaskView,
								false,
								false,
								false,
								null,
								false,
								null,
								null,
								null,
								0,
								0,
								true,
								false,			// 29/11/19 JLGNS1 TFS47394
								false,			// TFS 51409
								false,			// TFS 51409
								false,			//01.09.2021 navma1 #51485
								false,
								doSwapCargoNotJob	//29/10/2025	navkc1 JIRA 36186
								);


	app.myTrxCA.trxCreateRTVehicleConfig(pxyRTVehicleConfig,realRTVehicleConfig,null, terminal,_machine.getMachineType,_machine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); // cnwma1 30/04/2014

epilog
	delete allAvailableViews;
	delete tbl;
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="machineDeleteConfig" id="ecaf44b0-ce9b-4ed9-bca1-4332fdcc4233">
        <source>machineDeleteConfig(_machine: CM_Machine);
/*

Purpose:	Delete RT Vehicle Config		

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
