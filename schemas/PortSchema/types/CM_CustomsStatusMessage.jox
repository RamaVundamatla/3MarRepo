    <JadeMethod name="setForCreate" id="538824a7-4814-4d5f-8fe3-896f7489cc81">
        <updating/>
        <source>setForCreate(_proxy : CM_CustomsStatusMessage) updating;
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
begin
	self.dispositionCode := _proxy.dispositionCode;
	self.entryNumber := _proxy.entryNumber;
	self.entryType := _proxy.entryType;
	self.foreignPort := _proxy.foreignPort;
	self.inBondInformation := _proxy.inBondInformation;
	self.inTransitPort := _proxy.inTransitPort;
	self.portCode := _proxy.portCode;
	self.quantity := _proxy.quantity;
	self.remarks := _proxy.remarks;
	self.controlNumber := _proxy.controlNumber;
	self.timeMessage := _proxy.timeMessage;
	self.timeReceived := _proxy.timeReceived;
	//self.afterStatusCode := _proxy.myBOL.getStatus();
	
	//self.myCustomsBOL := _proxy.myCustomsBOL.pxyGetRealObject();
	self.myBOL := _proxy.myBOL;							//cnwmc5 - 10 July 2014 - CCMS 2353
	self.voyageOperator := _proxy.voyageOperator;		//cnwmc5 - 10 July 2014 - CCMS 2353
	
	//CCMS SFW 1039 PAR18889 cnwsh3	- Collection added to terminal for reporting on messages received and loaded into system.
	self.myTerminal := _proxy.myTerminal;
epilog
end;</source>
        <Parameter name="_proxy" type="CM_CustomsStatusMessage"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromEDIBOL" id="75869b63-6390-49cb-8f1e-485f85ba7653">
        <updating/>
        <source>setForCreateFromEDIBOL(_realBOLIn : CM_BOLIn input; _ediDataBOL : CM_EDIDataBillOfLading) updating;
// ---------------------------------------------------------------------------
// Created:	29 September 2009 cnwsh3
// ---------------------------------------------------------------------------
vars
begin
	//Only ever called when processing a 309 message so the disposition code is by defualt, '309'
	self.dispositionCode:= EDI_X12TransactionCode309;
	self.entryNumber 	:= null;
	self.entryType 		:= null;
	self.foreignPort 	:= null;
	self.inBondInformation := null;
	self.inTransitPort 	:= null;
	self.portCode 		:= _ediDataBOL.portCode;
	self.quantity 		:= _ediDataBOL.quantityOnBill;
	self.remarks 		:= app.getErrorString(FileReceived309);
	self.timeMessage 	:= _ediDataBOL.postedDT;
	self.timeReceived 	:= _ediDataBOL.processDateTime;
	self.controlNumber 	:= null;
	
    //TBD CAMIR cnwgb1
	//self.myCustomsBOL 	:= _realBOLIn.myCustomsBOLExt;
	//self.afterStatusCode:= _realBOLIn.myCustomsBOLExt.getStatus();
	//CCMS SFW 1039 PAR18889 cnwsh3	- Collection added to terminal for reporting on messages received and loaded into system.
	self.myTerminal 	:= _realBOLIn.myTerminal;
	
epilog
end;</source>
        <Parameter name="_realBOLIn" type="CM_BOLIn" usage="input"/>
        <Parameter name="_ediDataBOL" type="CM_EDIDataBillOfLading"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="b05c9258-5dd5-4c1a-bb63-3e1677464387">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 18 February 2009
//
// Implemented version:
// 
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
//----------------------------------------------------------------------
vars

begin
	self.myTerminal := _terminal;
epilog
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3dbe8557-b5e0-4623-8e85-9c75f790d22d">
        <updating/>
        <source>setProxy(
	_dispositionCode :String;
	_entryNumber :String;
	_entryType :String;
	_foreignPort :String;
	_inBondInformation :String;
	_inTransitPort :String;
	_portCode :String;
	_quantity :Integer;
	_remarks :String;
	_timeMessage :TimeStamp;
	_timeReceived :TimeStamp;
	_controlNumber :Integer;
	_terminal : CM_Terminal;
	_type : Integer;
	_bol : CM_BOLIn;
	_voyageOperator : String) updating;
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
begin
	self.raiseExceptionIfNotTransient(method);

	self.dispositionCode := _dispositionCode;
	self.entryNumber := _entryNumber;
	self.entryType := _entryType;
	self.foreignPort := _foreignPort;
	self.inBondInformation := _inBondInformation;
	self.inTransitPort := _inTransitPort[1:4];
	self.portCode := _portCode;
	self.quantity := _quantity;
	self.remarks := _remarks;
	self.timeMessage := _timeMessage;
	self.timeReceived := _timeReceived;
	self.controlNumber := _controlNumber;
	//CCMS SFW 1039 PAR18889 cnwsh3	- Collection added to terminal for reporting on messages received and loaded into system.
	self.myTerminal := _terminal;
	self.myBOL := _bol;						//cnwmc5 - 10 July 2014 - CCMS 2353
	self.voyageOperator := _voyageOperator;		//cnwmc5 - 10 July 2014 - CCMS 2353
epilog
end;</source>
        <Parameter name="_dispositionCode" type="String"/>
        <Parameter name="_entryNumber" type="String"/>
        <Parameter name="_entryType" type="String"/>
        <Parameter name="_foreignPort" type="String"/>
        <Parameter name="_inBondInformation" type="String"/>
        <Parameter name="_inTransitPort" type="String"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_timeMessage" type="TimeStamp"/>
        <Parameter name="_timeReceived" type="TimeStamp"/>
        <Parameter name="_controlNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_voyageOperator" type="String"/>
    </JadeMethod>
