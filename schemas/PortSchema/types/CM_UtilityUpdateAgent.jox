	exclusiveLock(realTaxCode);

	if _passport.noErrors and realTaxCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tax Code', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTaxCode, true);
	endif;
	
	if _passport.noErrors then
		realTaxCode.setForUpdate(_pxyTaxCode, _passport);
	endif;

	if _passport.noErrors then
