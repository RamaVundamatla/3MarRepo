    <JadeMethod name="updateTI" id="54436d4a-1ef8-4712-8ab7-6922624f5260">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2006 by cnwrs2
//
// Purpose:    
// 
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 02/05/2022		jlizm1			TFS 53083 GPHA revceival/release of tranship cargo
// ---------------------------------------------------------------------------
vars
	ti: CM_TrackedItem;

begin
	inheritMethod(_passport);

	// store PIN here (ccms-1037)
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		if ti.releaseRequest &lt;&gt; null
		and ti.releaseRequest.pinNo &lt;&gt; null
		then
			if self.pinNo = null then
				self.pinNo := ti.releaseRequest.pinNo;
			endif;
		endif;

		if ti.isTranshipItem then
			if ti.getTransitStatus() &lt;&gt; TI_TransitStatusInterModal then
				// tranship cargo can only be released by road if it has Intermodal transit status
				app.raiseCMException2(Trans_item_trans_items_canno_, ti.id, app.getErrorString(Road), null, self);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
