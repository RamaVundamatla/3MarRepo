    <JadeMethod name="doSanitiseFilesInFolder" id="937b9269-b837-43ab-b047-0d9771ef7ad2">
        <source>doSanitiseFilesInFolder(_envName, _srcFolderPath, _destFolderPath : String; _agent : DEV_SourceCompareFileAgent input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2021	navmd1	Initial creation TFS: 52202

*/

vars
	file						: FileNode;
	srcFolder,
	destFolder					: FileFolder;
	allFiles					: FileNodeArray;
	currentNumFile,
	numFiles					: Integer;
	start, stop					: TimeStamp;
begin

	//self.writeConsoleText(CrLf &amp; "Processing " &amp; _envName);
	self.writeConsoleText(CrLf &amp; "Processing Files in folder");
	self.writeConsoleText("---------------------------------------------");
	
	// Check SRC folder exists
	create srcFolder transient;
	srcFolder.fileName := _srcFolderPath;
	srcFolder.mask := "*.scm";
	
	if not srcFolder.isAvailable() then
		self.writeConsoleText("Folder " &amp; srcFolder.fileName &amp; " not found, exiting");
		return;
	endif;
	
	// Check DEST folder exists
	create destFolder transient;
	destFolder.fileName := _destFolderPath;
	if not destFolder.isAvailable() then
		self.writeConsoleText("Folder " &amp; destFolder.fileName &amp; " not found, exiting");
		return;
	endif;
	
	allFiles := srcFolder.files;
	numFiles := allFiles.size+1;
	
	if numFiles = 0 then
		self.writeConsoleText("No scm files found in srouce directory, exiting");
		return;
	endif;
	
	start := app.actualTimeServer;
	
	self.updateStatusLine(_envName, "");
	
	foreach file in allFiles  do
		// Skip sub directories
		if (file.isKindOf(FileFolder)) then
			continue;
		endif;
		
		currentNumFile := currentNumFile + 1;
		
		self.updateStatusLine(_envName, file.name.replace(".scm", "")  &amp; " File " &amp; currentNumFile.asStringJMT() &amp; " of " &amp; numFiles.asStringJMT());
		self.updateProgressBar(currentNumFile, numFiles+1);
		self.pbFileProgress.refreshNow();
		self.slStatus.refreshNow();
		
		_agent.doSanitiseScmFile(file.fileName, file.name.replace(".scm", ""), _envName, _destFolderPath, self.shouldExtractFiles, self.shouldCleanFiles);
		
		self.writeConsoleText("Processed " &amp; file.name.replace(".scm", ""));
		self.writeConsoleText("");
		self.txtConsole.refreshNow();
	endforeach;
	
	self.updateProgressBar(currentNumFile, numFiles);
	stop := app.actualTimeServer;
	
	//write CrLf &amp; _envName &amp; " Process Time: " &amp; (stop - start).asStringJMT();
	write CrLf &amp; "Process Time: " &amp; (stop - start).asStringJMT();

epilog
	delete srcFolder;
	delete destFolder;
	
end;</source>
        <access>protected</access>
        <Parameter name="_envName" type="String"/>
        <Parameter name="_srcFolderPath" type="String"/>
        <Parameter name="_destFolderPath" type="String"/>
        <Parameter name="_agent" type="DEV_SourceCompareFileAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSourceCompare" id="02e5328e-ef53-4b63-9915-77feff02dc0f">
        <source>doSourceCompare();
/*

Purpose:			Do our source comparison (Probably should be renamed to Reorganise/Clean Schema Files)

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/
	
vars

begin
	self.toggleFormControls(false);
	self.txtConsole.text := "";
	
	//self.beginNotification(self.myAgent, DevSourceCompareUpdateStatus, Response_Continuous, 0);
	
	self.doSanitiseFilesInFolder("DMAST", txtDMastSrcDir.text, txtDMastDestDir.text, self.myFileAgent);
	
	//self.doSanitiseFilesInFolder("WMAST", txtDMastSrcDir.text, txtDMastDestDir.text, self.myAgent);
	
	//self.endNotification(self.myAgent, DevSourceCompareUpdateStatus);
	
	self.writeConsoleText("Finished Processing");
	app.msgBox("Finished Processing", "Finished!!", MsgBox_OK_Only);
	
epilog
	self.toggleFormControls(true);

end;</source>
    </JadeMethod>
    <JadeMethod name="excludeFilename" id="62f91618-dee3-4a51-b3fe-91a3c8a646e9">
        <source>excludeFilename(_fileName : String) : Boolean protected;
/*

Purpose:			Returns a boolean representing whether or not we need to exclude the file name from processing

Parameters:			_fileName: File name to check

Return Value:		A boolean representing whether we are processing this file or not

Date		Who		Reason
08 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if _fileName.endsWith(".cleaned") then
		return true;
	endif;
	
	if _fileName.endsWith("addedFiles") then
		return true;
	endif;
	
	if _fileName.endsWith("deletedFiles") then
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
