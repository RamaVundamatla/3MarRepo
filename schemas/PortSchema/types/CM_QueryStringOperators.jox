<Class name="CM_QueryStringOperators" id="2deca627-f0c4-46b7-b3e1-3cbb47834bd3">
    <superclass name="CM_QueryOperator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="searchValue" id="974d7694-96a6-4aca-b365-336bd5033bb8">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getSearchValue" id="f7029f01-32c9-4f55-889c-e67c2765828e">
        <source>getSearchValue(): Any;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.searchValue;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="d5bf8493-d809-4e27-856a-72905d7aeddf">
        <source>getSearchValueStr(_prop : CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return _prop.translateToDisplayValue(self.searchValue);

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="ab79219e-4912-4861-834e-181ecd9373cc">
        <updating/>
        <source>	setSearchValue(_value: Any) updating;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.searchValue := null;
	if _value &lt;&gt; null then // par 18123
		self.searchValue := _value.String;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
