    <JadeMethod name="getDisplayTempFarenheit" id="14ef36a0-179b-4b5f-a260-c623130a8a7b">
        <source>getDisplayTempFarenheit():String;
// ---------------------------------------------------------------------------
// Created:     13 October 2008 by concms1
//
// Purpose:     Gate Ticket Printing - CCMS 1035 (JRW)
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//return self.getDisplayTemperature (false, false);
	
	if self.carriageTempF = null then
		return null;
	endif;
	return app.temperatureDisplayString(self.carriageTempF) &amp; Degrees_F;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTemperature" id="7f2b3f24-7119-43ad-ac42-cb22437585a2">
        <source>getDisplayTemperature(_displayBoth: Boolean; _returnCelcius: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	tmpTI := self.getContainer();

	if tmpTI &lt;&gt; null then
		return tmpTI.getDisplayTemperature(_displayBoth, _returnCelcius);

	endif;
	
	if _returnCelcius then
		if self.carriageTempC = NULL_TEMPERATURE or self.carriageTempC = null then
			return null;
		endif;
	else
		if self.carriageTempF = NULL_TEMPERATURE or self.carriageTempF = null then
			return null;
		endif;
	endif;

	
	if not _returnCelcius then
		if _displayBoth then
			return app.temperatureDisplayString(self.carriageTempF) &amp; Degrees_F &amp; " / " &amp; app.temperatureDisplayString(self.carriageTempC) &amp; Degrees_C;
		elseif self.displayTempFahrenheit then
			return app.temperatureDisplayString(self.carriageTempF) &amp; Degrees_F;
		endif;
	endif;
	

	return app.temperatureDisplayString(self.carriageTempC); 
		
end;</source>
        <Parameter name="_displayBoth" type="Boolean"/>
        <Parameter name="_returnCelcius" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
