    <JadeMethod name="setMySlotController" id="ed70e1d1-fee7-4403-87d6-889b8a188fd2">
        <updating/>
        <source>setMySlotController(_slotController : CM_SlotController input) updating;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------    
														
------------------------------------------------------------------------
*/
begin
	self.mySlotController := _slotController;
	_slotController.addSlotRequest((self.isLoad), self);
	self.myBay := _slotController.myBayVoyage;
end;</source>
        <Parameter name="_slotController" type="CM_SlotController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b96a1dc2-7e01-4723-ac6a-31d85010c76c">
        <updating/>
        <source>setProxy(_cargoType,_doorsDirection,_motorDirection,_moveType,_numSeqPort,_numSeqStarBoard,
         _ordinalDeck, _ordinalCell, _ordinalTier : Integer;
         _empty,_fixed,_fortyBack,_fortyFront,_halfHeight,_hazardous,_overDimension,_power,_reefer,_sequenced,_unavailable,_waterCooled:Boolean
         ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.setMoveType(_moveType);
	self.cargoType := _cargoType;

	self.doorsDirection := _doorsDirection;
	self.motorDirection := _motorDirection;
	self.empty := _empty;
	self.fortyBack := _fortyBack;
	self.fortyFront := _fortyFront;
	self.hazardous := _hazardous;
	self.overDimension := _overDimension;
	self.power := _power;
// PAR7496 AKB2004FEB		self.reefer := _reefer;
	self.unavailable := _unavailable;
	self.waterCooled := _waterCooled;
	self.halfHeight := _halfHeight;
	self.fixed := _fixed;
	self.numSeqPort := _numSeqPort;
	self.numSeqStarBoard := _numSeqStarBoard;
	self.ordinalDeck := _ordinalDeck;
	self.ordinalCell := _ordinalCell;
	self.ordinalTier := _ordinalTier;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_doorsDirection" type="Integer"/>
        <Parameter name="_motorDirection" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_numSeqPort" type="Integer"/>
        <Parameter name="_numSeqStarBoard" type="Integer"/>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <Parameter name="_ordinalTier" type="Integer"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_fixed" type="Boolean"/>
        <Parameter name="_fortyBack" type="Boolean"/>
        <Parameter name="_fortyFront" type="Boolean"/>
        <Parameter name="_halfHeight" type="Boolean"/>
        <Parameter name="_hazardous" type="Boolean"/>
        <Parameter name="_overDimension" type="Boolean"/>
        <Parameter name="_power" type="Boolean"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_sequenced" type="Boolean"/>
        <Parameter name="_unavailable" type="Boolean"/>
        <Parameter name="_waterCooled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy40FromFrontEnd" id="6f95e6de-355b-488f-9ca3-3052eb695504">
        <updating/>
        <source>setProxy40FromFrontEnd() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		for back end load colour coding. Copies all the attributes from the front end to this the backend.
//
// ---------------------------------------------------------------------------

vars
	realRequest, realFwdRequest : CM_SlotRequest;
	myRealSlot, myRealFwdSlot : CM_SlotController;
begin
	if (not self.isLoad) then
		return;
	endif;
	
	self.raiseExceptionIfNotProxy(method);

	realRequest := self.pxyGetRealObject.CM_SlotRequest;
	
	if realRequest &lt;&gt; null then
		myRealSlot := realRequest.mySlotController;
		if myRealSlot.isFortyBack then
			myRealFwdSlot := myRealSlot.myForwardSlot;
			if myRealFwdSlot &lt;&gt; null then
				realFwdRequest := myRealFwdSlot.mySlotRequestLoad;
				if realFwdRequest &lt;&gt; null then
					self.set40AttribsFromFrontEnd(realFwdRequest);
				endif;
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyAttribute" id="9410b0f4-ede4-4552-9082-647a0347422f">
        <updating/>
        <source>setProxyAttribute(_theAttribute : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theMTCode 		: String;
	theMTCommodity 	: CM_Commodity;
	commodityGroup 	: CM_CommodityGroup;	//cnwas3 PAR 24273
begin
	if _theAttribute = self.Attribute_Erase then
		// we actually ERASE the slot request, not null it out as is done here, but this can be used to initialise
		self.crib := false;
		self.frame := false;	//05 Feb 2018	NDL	TFS 36752
		self.flat := false;
		self.fantainer := false;
		self.opentop := false;
		self.tank := false;
		self.empty := false;
		self.fortyBack := false;
		self.fortyFront := false;
		self.hazardous := false;
		self.highCubed := false;
		self.overDimension := false;
		self.power := false;
// PAR7496 AKB2004FEB			self.reefer := false;
		self.unavailable := false;
		self.waterCooled := false;
		self.halfHeight := false;
		self.setMoveType(NULL_MOVETYPE);
		self.myCargoType := null;
//		self.myCommodity := null;
		self.myCommodityGroup := null;
		self.myDischargePort := null;
		self.cargoType := null;
		self.dischargePort := null;
		self.commodity := null;
		self.doorsDirection := TI_DOORSDIRN_NULL;
		self.motorDirection := Motor_Null;
		//self.numSeqPort := null;
		//self.numSeqStarBoard := null;
		self.numSeqPortCustom := null;
		self.numSeqStarboardCustom := null;
		
	else
		if _theAttribute = self.Attribute_Empty then
			self.empty := not self.getAttrEmpty();
			if not self.empty then		//cnwas3 PAR 24273
				theMTCode := app.myPassport.myTerminal.getDefaultEmptyCommodity();
				theMTCommodity := app.myRoot.allCommodities[theMTCode];
				if theMTCommodity &lt;&gt; null then
					self.myCommodityGroup := theMTCommodity.myCommodityGroup;
					commodityGroup := self.getAttrCommodityGroup();		//cnwas3 PAR 24273
					if commodityGroup &lt;&gt; null then						//cnwas3 PAR 24273
						self.commodity := commodityGroup.code;			//cnwas3 PAR 24273
					endif;
				endif;
			else			
//				self.myCommodity := null;
				self.myCommodityGroup := null;
				self.commodity := null;
			endif;
		elseif _theAttribute = self.Attribute_ColourCode then
			// check if we have to change back to non-sob/rehandle request
			if self.isSOB or self.isRehandle then
				if self.isLoad then
					self.setMoveType(LOAD_MOVETYPE);
				else
					self.setMoveType(DISCHARGE_MOVETYPE);
				endif;
			endif;
		elseif _theAttribute = self.Attribute_DLR then
			self.setMoveType(DLR_MOVETYPE);
		elseif _theAttribute = self.Attribute_SOB then
			self.setMoveType(SOB_MOVETYPE);
		elseif _theAttribute = self.Attribute_Forty then
			if self.pxyGetRealObject() = null then // create
				self.fortyFront := self.mySlotController.myBayVoyage.isForwardBay();
				self.fortyBack := self.mySlotController.myBayVoyage.isAftBay();
			else
				// Not done here - refer to CM_SlotController.updateSlotRequestAttribute
			endif;

		elseif _theAttribute = self.Attribute_Tank then
			self.tank := not self.getAttrTank();
			if not self.tank then		//cnwas3 PAR 24273
				self.crib := false;
				self.frame := false; //05 Feb 2018	NDL	TFS 36752
				self.opentop := false;
				self.flat := false;
				self.fantainer := false;
			endif;
		elseif _theAttribute = self.Attribute_Crib then
			self.crib := not self.getAttrCrib();
			if not self.crib then		//cnwas3 PAR 24273
				self.tank := false;
				self.opentop := false;
				self.flat := false;
				self.fantainer := false;
				self.frame := false; //05 Feb 2018	NDL	TFS 36752
			endif;
		elseif _theAttribute = self.Attribute_Frame then	//05 Feb 2018	NDL	TF S36752
			self.frame := not self.getAttrFrame();
			if not self.frame then
				self.tank := false;
				self.opentop := false;
				self.flat := false;
				self.fantainer := false;
				self.crib := false; //05 Feb 2018	NDL	TFS 36752
			endif;
		elseif _theAttribute = self.Attribute_Opentop then
			self.opentop := not self.getAttrOpenTop();
			if not self.opentop then		//cnwas3 PAR 24273
				self.tank := false;
				self.crib := false;
				self.frame := false; //05 Feb 2018	NDL	TFS 36752
				self.flat := false;
				self.fantainer := false;
			endif;
		elseif _theAttribute = self.Attribute_Flat then
			self.flat := not self.getAttrFlatRack();
			if not self.flat then		//cnwas3 PAR 24273
				self.tank := false;
				self.crib := false;
				self.frame := false; //05 Feb 2018	NDL	TFS 36752
				self.opentop := false;
				self.fantainer := false;
			endif;
		elseif _theAttribute = self.Attribute_Fantainer then
			self.fantainer := not self.getAttrFantainer();
			if not self.fantainer then		//cnwas3 PAR 24273
				self.tank := false;
				self.crib := false;
				self.frame := false; //05 Feb 2018	NDL	TFS 36752
				self.opentop := false;
				self.flat := false;
			endif;
			
			
		elseif _theAttribute = self.Attribute_Hazardous then
			self.hazardous := not self.getAttrHazardous();
		elseif _theAttribute = self.Attribute_Hicubed then
			self.highCubed := not self.getAttrHiCubed();
			self.halfHeight := false;
		elseif _theAttribute = self.Attribute_OD then
			self.overDimension := not self.getAttrOverDimensioned();
			self.halfHeight := false;
		elseif _theAttribute = self.Attribute_Power then
			self.power := not self.getAttrPowerRequired();
// PAR7496 AKB2004FEB			elseif _theAttribute = self.Attribute_Reefer then
// PAR7496 AKB2004FEB				self.reefer := not self.reefer;
		elseif _theAttribute = self.Attribute_Unavailable then
			self.unavailable := not self.unavailable;
		elseif _theAttribute = self.Attribute_Watercooled then
			self.waterCooled := not self.getAttrWaterCooled();
		elseif _theAttribute = self.Attribute_Half then
			self.halfHeight := not self.getAttrHalfHeight();
			self.highCubed := false;
		endif;
	endif;
end;</source>
        <Parameter name="_theAttribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyCargoSubtype" id="e2dfa8a8-a39a-4688-9644-b003184b3883">
        <updating/>
        <source>setProxyCargoSubtype(_cargoSubtype : CM_Product) updating;

/*

