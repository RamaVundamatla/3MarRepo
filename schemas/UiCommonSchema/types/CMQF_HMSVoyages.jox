<Class name="CMQF_HMSVoyages">
    <JadeMethod name="setFromAgent" id="dd09e303-804a-49e5-97da-e6ba55276c85">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 03/03/2020	jlgdap1		TFS 48731 PNL New Web Portal not generating reports / timing out
//							Web Portal returns dates in dd/mm/yyyy hh:mm format, regardless of 
//							whether the time portion is displayed or not. So here we need to 
// 							cater for a Date (if the parameter is hidden) or a timestamp
//							(if the parameter is shown)
vars
	str : String;
begin


	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_MyVessel) then
		self.setMyVessel( _agent.getSelectedVessel() );
	endif;

	if _agent.isRowIncluded(ETRow_MyVoyage) then
		self.setMyVoyage( _agent.getSelectedVoyage() );
	endif;
	
	// Arrival
	if _agent.isRowIncluded(ETRow_ArrivalsDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).String, 
								self.arriveDateFromType, self.arriveDateFromFactor, ETRow_ArrivalsDateFrom);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateFrom), 
								self.arriveDateFromType, self.arriveDateFromFactor, ETRow_ArrivalsDateFrom);
		else
			//self.arriveDateFrom := _agent.getSelectedHMSDate(ETRow_ArrivalsDateFrom);		PAR 10970
			//self.arriveDateFrom := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).Date;					// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).String;									// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.arriveDateFrom := str.Date;																	// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.arriveDateFrom := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).String, 
								self.arriveDateToType, self.arriveDateToFactor, ETRow_ArrivalsDateTo);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateTo), 
								self.arriveDateToType, self.arriveDateToFactor, ETRow_ArrivalsDateTo);
		else
			//self.arriveDateTo := _agent.getSelectedHMSDate(ETRow_ArrivalsDateTo);		PAR 10970
			//self.arriveDateTo := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).Date;						// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).String;										// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.arriveDateTo := str.Date;																		// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.arriveDateTo := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsTimeFrom) then
//		self.arriveTFrom := _agent.getSelectedHMSTime(ETRow_ArrivalsTimeFrom);
		self.arriveTFrom  := _agent.getValueByNameIfVisible(ETRow_ArrivalsTimeFrom).Time;
		
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsTimeTo) then
//		self.arriveTTo := _agent.getSelectedHMSTime(ETRow_ArrivalsTimeTo);
		self.arriveTTo  := _agent.getValueByNameIfVisible(ETRow_ArrivalsTimeTo).Time;
	endif;
	
	// Departure.
	
	if _agent.isRowIncluded(ETRow_DepartedDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_DepartedDateFrom).String, 
								self.departDateFromType, self.departDateFromFactor, ETRow_DepartedDateFrom);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DepartedDateFrom), 
								self.departDateFromType, self.departDateFromFactor, ETRow_DepartedDateFrom);
		else
			//self.departDateFrom := _agent.getSelectedHMSDate(ETRow_DepartedDateFrom);		PAR 10970
			//self.departDateFrom := _agent.getValueByNameIfVisible(ETRow_DepartedDateFrom).Date;					// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_DepartedDateFrom).String;									// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.departDateFrom := str.Date;																	// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.departDateFrom := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_DepartedDateTo).String, 
								self.departDateToType, self.departDateToFactor, ETRow_DepartedDateTo);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DepartedDateTo), 
								self.departDateToType, self.departDateToFactor, ETRow_DepartedDateTo);
		else
			//self.departDateTo := _agent.getSelectedHMSDate(ETRow_DepartedDateTo);		PAR 10970
			//self.departDateTo := _agent.getValueByNameIfVisible(ETRow_DepartedDateTo).Date;						// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_DepartedDateTo).String;										// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.departDateTo := str.Date;																		// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.departDateTo := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedTimeFrom) then
//		self.departTFrom := _agent.getSelectedHMSTime(ETRow_DepartedTimeFrom);
		self.departTFrom  := _agent.getValueByNameIfVisible(ETRow_DepartedTimeFrom).Time;
		
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedTimeTo) then
//		self.departTTo := _agent.getSelectedHMSTime(ETRow_DepartedTimeTo);
		self.departTTo  := _agent.getValueByNameIfVisible(ETRow_DepartedTimeTo).Time;

	endif;
	
	// In Port
	
	if _agent.isRowIncluded(ETRow_InPortDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_InPortDateFrom).String, 
								self.inPortDateFromType, self.inPortDateFromFactor, ETRow_InPortDateFrom);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_InPortDateFrom), 
								self.inPortDateFromType, self.inPortDateFromFactor, ETRow_InPortDateFrom);
		else
			//self.inPortDateFrom := _agent.getSelectedHMSDate(ETRow_InPortDateFrom);		PAR 10970
			//self.inPortDateFrom := _agent.getValueByNameIfVisible(ETRow_InPortDateFrom).Date;						// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_InPortDateFrom).String;										// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.inPortDateFrom := str.Date;																	// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.inPortDateFrom := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_InPortDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_InPortDateTo).String, 
								self.inPortDateToType, self.inPortDateToFactor, ETRow_InPortDateTo);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_InPortDateTo), 
								self.inPortDateToType, self.inPortDateToFactor, ETRow_InPortDateTo);
		else
			//self.inPortDateTo := _agent.getSelectedHMSDate(ETRow_InPortDateTo);		PAR 10970
			//self.inPortDateTo := _agent.getValueByNameIfVisible(ETRow_InPortDateTo).Date;							// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_InPortDateTo).String;										// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.inPortDateTo := str.Date;																		// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.inPortDateTo := str.TimeStamp.date;															// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_InPortTimeFrom) then
//		self.inPortTFrom := _agent.getSelectedHMSTime(ETRow_InPortTimeFrom);		
		self.inPortTFrom  := _agent.getValueByNameIfVisible(ETRow_InPortTimeFrom).Time;
	endif;
	
	if _agent.isRowIncluded(ETRow_InPortTimeTo) then
//		self.inPortTTo := _agent.getSelectedHMSTime(ETRow_InPortTimeTo);		
		self.inPortTTo  := _agent.getValueByNameIfVisible(ETRow_InPortTimeTo).Time;
	endif;

	if _agent.isRowIncluded(ETRow_IncludeCancelled) then
		self.includeCancelled  := _agent.getValueByNameIfVisible(ETRow_IncludeCancelled).Boolean;
	endif;	
	
	// PAR #35826 Expected Arrival/Departure From/To Date/Time
	if _agent.isRowIncluded(ETRow_ExpectedArrivalDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ExpectedArrivalDateFrom), 
								self.estimatedArrivalDateFromType, self.estimatedArrivalDateFromFactor, ETRow_ExpectedArrivalDateFrom);
		else
			//self.estimatedArrivalDateFrom := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalDateFrom).Date;	// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalDateFrom).String;							// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.estimatedArrivalDateFrom := str.Date;															// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.estimatedArrivalDateFrom := str.TimeStamp.date;												// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedArrivalDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ExpectedArrivalDateTo), 
								self.estimatedArrivalDateToType, self.estimatedArrivalDateToFactor, ETRow_ExpectedArrivalDateTo);
		else
			//self.estimatedArrivalDateTo := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalDateTo).Date;		// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalDateTo).String;								// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.estimatedArrivalDateTo := str.Date;															// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.estimatedArrivalDateTo := str.TimeStamp.date;													// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedArrivalTimeFrom) then
		self.estimatedArrivalTimeFrom  := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalTimeFrom).Time;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedArrivalTimeTo) then
		self.estimatedArrivalTimeTo  := _agent.getValueByNameIfVisible(ETRow_ExpectedArrivalTimeTo).Time;
	endif;

	if _agent.isRowIncluded(ETRow_ExpectedDepartDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ExpectedDepartDateFrom), 
								self.estimatedDepartDateFromType, self.estimatedDepartDateFromFactor, ETRow_ExpectedDepartDateFrom);
		else
			//self.estimatedDepartDateFrom := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartDateFrom).Date;	// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartDateFrom).String;								// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.estimatedDepartDateFrom := str.Date;															// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.estimatedDepartDateFrom := str.TimeStamp.date;													// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedDepartDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ExpectedDepartDateTo), 
								self.estimatedDepartDateToType, self.estimatedDepartDateToFactor, ETRow_ExpectedDepartDateTo);
		else
			//self.estimatedDepartDateTo := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartDateTo).Date;		// TFS 48731
			str := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartDateTo).String;								// TFS 48731
			if str.Date.isValid then																				// TFS 48731
				self.estimatedDepartDateTo := str.Date;																// TFS 48731
			elseif str.TimeStamp.isValid then																		// TFS 48731
				self.estimatedDepartDateTo := str.TimeStamp.date;													// TFS 48731
			endif;																									// TFS 48731
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedDepartTimeFrom) then
		self.estimatedDepartTimeFrom  := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartTimeFrom).Time;
	endif;
	if _agent.isRowIncluded(ETRow_ExpectedDepartTimeTo) then
		self.estimatedDepartTimeTo  := _agent.getValueByNameIfVisible(ETRow_ExpectedDepartTimeTo).Time;
	endif;
	// PAR #35826 End

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
