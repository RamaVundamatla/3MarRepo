        <source>makeTrackedItemTranship(_controller : CMIF_TranshipTIController input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2010	cnwdap1	Initial creation
*/
vars
	ti : CM_TrackedItem;

begin
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateTrackeditemsTranShip(_controller, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog

