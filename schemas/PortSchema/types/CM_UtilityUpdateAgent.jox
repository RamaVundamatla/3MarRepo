    <JadeMethod name="utlUpdateStockOrderAllocation" id="0cb7f5ed-08d1-40bc-a824-fe9e304498ff">
        <source>utlUpdateStockOrderAllocation(_pxyAllocation: CM_StockOrderAllocation; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realAllocation	: CM_StockOrderAllocation;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

	_pxyAllocation.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyAllocation.pxyGetRealObjectAndEdition(realAllocation, expectedEdition);

	if realAllocation = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_StockOrderAllocation.name, null, null);
		return;
	endif;

	app.myValUA.valStockOrderAllocation(realAllocation, _pxyAllocation);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;	

	app.setContinueCMExceptions(false);
	
	exclusiveLock(realAllocation);
	
	if _passport.noErrors and realAllocation.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stock Order Line', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realAllocation, true);
	endif;
	
	if _passport.noErrors then
		if _pxyAllocation.allocQuantity = 0 then
			global.causeEvent(realAllocation.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Delete_Event), false, realAllocation);											
			realAllocation.erase(NORMAL_ERASE);
		else
			realAllocation.setForUpdate(_pxyAllocation);
			if _passport.noErrors then
				global.causeEvent(realAllocation.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Update_Event), false, realAllocation);			
				self.myUpdateAuditAgent.audUpdateGeneric(realAllocation, false);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_pxyAllocation" type="CM_StockOrderAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateStockOrderFromCMIF" id="92c75122-a24d-42f3-935f-62acbd9101e7">
        <source>utlUpdateStockOrderFromCMIF(_cmifStockOrder: CMIF_LogStockOrderLine input; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jul 2008	cnwkpd1	PAR #17298 - Handle add of new line being attached to an existing
					order

*/

vars
	tmpLine,
	otherLine	: CM_LogStockOrderLine;
	
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValUA.valLogStockOrderLine(_cmifStockOrder, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	tmpLine := _cmifStockOrder.myLogStockOrderLine;
	
	if _cmifStockOrder.mode = _cmifStockOrder.Mode_Update then
		
		exclusiveLock(tmpLine.myStockOrderHeader);
		exclusiveLock(tmpLine);
		
		if tmpLine.myLogLot &lt;&gt; null then
			exclusiveLock(tmpLine.myLogLot);
		endif;

		if _passport.noErrors and tmpLine.myStockOrderHeader.edition &lt;&gt; _cmifStockOrder.expectedEditionForHeader then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stock order header', null, null);
			return;
		endif;

		if _passport.noErrors and tmpLine.edition &lt;&gt; _cmifStockOrder.expectedEditionForLine then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stock order line', null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		_cmifStockOrder.set(_passport);
		
		// PAR #17298 - if myLogStockOrderLine has been created, need this for subsequent update
		// of discharge port and consignee
		tmpLine := _cmifStockOrder.myLogStockOrderLine;		
	endif;
	
	//8 sep 2008 cnwdz2 par 16840
	if _passport.noErrors and tmpLine &lt;&gt; null and _cmifStockOrder.updateLogLotDetails then
		foreach otherLine in tmpLine.myLogLot.allLogStockOrderLines do
			// if otherLine = tmpLine then // Par 9970 - New is special case as tmpline needs to be changed as well. 
			if otherLine = tmpLine and _cmifStockOrder.mode &lt;&gt; _cmifStockOrder.Mode_Add then
				continue;
			endif;
			otherLine.setDischargePort(_cmifStockOrder.dischargePort);
			otherLine.setConsignee(_cmifStockOrder.consigneeCode);
		endforeach;
	endif;

end;</source>
        <Parameter name="_cmifStockOrder" type="CMIF_LogStockOrderLine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
