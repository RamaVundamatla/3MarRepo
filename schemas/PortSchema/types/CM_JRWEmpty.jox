<Class name="CM_JRWEmpty" id="d48afc9e-fb89-41e9-8c22-66545a95ba69">
    <superclass name="CM_JRWContainer"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allActiveReleases" id="73edace5-4da1-4ff4-8c93-b10594254ba5">
        <memberTypeInverse/>
        <type name="CM_BulkReleaseByTypeStCodeDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allMTSummaryObjects" id="bd2121da-ef31-46d3-8d4e-85342d94271f">
        <memberTypeInverse/>
        <type name="CMIF_MTSummaryByOpISOGrpAvaGrd"/>
    </ImplicitInverseRef>
