        <updating/>
        <source>btnTargetSearch_gotFocus(btn: Button input) updating;
/*

Date		Who		Reason
18 November 2015	cnwer1	Initial creation PAR

*/

vars
	twinRow : Integer;
begin
	//epr par 36977 18/11/15
	if self.btnSwap.visible then
		twinRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinTargetID);
		if self.tblMoveEntry.row  &lt;&gt; twinRow then
			self.tblMoveEntry.row:=twinRow;
			self.tblMoveEntry.	setFocus();
		endif;
	endif;
epilog

end;</source>
