    <JadeMethod name="checkCommonFilters" id="d17e9f2e-89db-42c0-8168-63025e8158fa">
        <source>checkCommonFilters(_txn : CM_TITransaction) : Boolean;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version: CCMS 1765 PAR18532
// 
//----------------------------------------------------------------------
vars

begin
	if _txn.myTrackedItem = null then
		return false;
	endif;
	//Filter the imex codes
	if self.allIMEXStatusCodes.isNotEmpty and 
	   not (self.allIMEXStatusCodes.includes(_txn.myTrackedItem.getImExStatusObject)) then
		return false;
	endif;
	//Check I match a cargo type if one has been passed through.
	if self.getMyCargoType &lt;&gt; null and 
	   not (self.getMyCargoType = _txn.myTrackedItem.myCargoType) then
		return false;
	endif;
	
	if self.getMyVoyage &lt;&gt; null and
	   _txn.myTrackedItem.myVoyage &lt;&gt; null and 
	   not (self.getMyVoyage = _txn.myTrackedItem.myVoyage) then
		return false;
	endif;
	
	if self.getMySubTerminal &lt;&gt; null //29/04/2009 cnwdz2 ccms1735
	and not (self.getMySubTerminal = _txn.myTrackedItem.mySubTerminal)
	then
		return false;
	endif;

	return true;
epilog
end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
