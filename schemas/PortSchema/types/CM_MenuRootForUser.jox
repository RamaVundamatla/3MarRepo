        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="canDo" id="b4b588a9-63fc-47b6-bcae-491998474b0d">
        <source>canDo(_permValue: Integer; _rptId: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     12 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _rptId &lt;&gt; null then
		return false;
	endif;
	
	return self.myUser.canDo(null, _permValue);
	

end;</source>
        <Parameter name="_permValue" type="Integer"/>
        <Parameter name="_rptId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="a85a4080-b2d3-443d-b3e7-20c583eac71f">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     10 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
     //par 18483
	return app.getErrorString(SystemItems); 
	//return 'System Items';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resetMenu" id="53d9fce3-ce51-4f0f-8224-d5f52691b950">
        <updating/>
        <source>resetMenu(_source: CM_MenuRoot; _clearFirst: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/01/2019	jlgdap1		TFS 41738 System Items icon is missing in Navigator
//
vars

begin
	inheritMethod(_source, _clearFirst);
	
	if self.pictureStringButton = null then
		self.pictureStringButton := _source.pictureStringButton;
		self.pictureStringButtonDown := _source.pictureStringButtonDown;
		self.pictureStringIcon := _source.pictureStringIcon;
	endif;
epilog

end;</source>
        <Parameter name="_source" type="CM_MenuRoot"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPosition" id="f96fdfd5-4c1b-48d1-9d94-451a26e9d386">
        <updating/>
        <source>setPosition(_position : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2004	cnwth2
//
// Purpose:     position used as the insert pos for the system items menu in the navigator
//
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.position := _position;

end;</source>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
</Class>
