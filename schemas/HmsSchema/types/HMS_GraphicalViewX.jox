    <JadeMethod name="openExistConfirmWindows" id="7c680a3b-00c7-44e4-8171-27a0bbbe13df">
        <updating/>
        <source>openExistConfirmWindows() updating, protected;

vars
 	move:		HMS_VoyageMovement;
 	warnDT,
 	now:		TimeStamp;
 	userCode	: String;
 	numHours	: Integer;
begin

	if self.myHarbour = null then
		return;
	endif;
	
	numHours := self.myHarbour.numHoursOutForWarnings;
	warnDT := warnDT.changeByXXHours(numHours);
	
	userCode := app.getMyUserCode();
	// This method checks to see if there are any movements that require 
	// confirmation for the current user. If there are, then open these window.
	//foreach move in app.theUser.CM_HMS_User.allPermMovesToConfirm do
	foreach move in self.myHarbour.allVoyageMovements do
		if (not move.allUserCodesForConfirmation.includes(userCode)) then
			continue;
		endif;
		
		if move.occursOnDTNEW &gt; warnDT then
			continue;
		endif;
		
		if move.occursOnDTNEW &lt; now then
    		self.myHarbour.causeEvent(OpenActualConfirmWindow, true, move);
    	else
    		self.myHarbour.causeEvent(OpenPlannedConfirmWindow, true, move);
    	endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionCurrentTimeLine" id="88005eb4-e70e-41c3-a948-f1d42a208075">
        <updating/>
        <source>positionCurrentTimeLine(_top : Integer) updating;
//-----------------------------------------
// Created: November 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpWharfCntrl : HMS_WharfDrawControl;
begin
	foreach tmpWharfCntrl in self.allWharfDrawControlsVisible do
		tmpWharfCntrl.positionCurrentTimeLine(_top);
	endforeach;	
	
end;</source>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="666c99f9-6e0f-4fba-9bb4-c96342442e3f">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin
	
	if self.myViewController &lt;&gt; null and (not self.myViewController.allChanges.isEmpty) then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
			result := app.msgBox(app.getErrorString(UnsavedChangesInView), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rebuildScaleTime" id="4cbef216-6d02-4a71-b6e6-41c3405294a2">
        <source>rebuildScaleTime(pStartDT,pFinishDT:TimeStamp; _forcedBuild : Boolean) protected;

vars
begin
	// setup the time scale
	if self.myDrawTimeLabel.fromTimePeriod &lt;&gt; pStartDT 
	or self.myDrawTimeLabel.toTimePeriod &lt;&gt; pFinishDT
	or _forcedBuild then
		self.myDrawTimeLabel.setTimePeriod(pStartDT, pFinishDT);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pStartDT" type="TimeStamp"/>
        <Parameter name="pFinishDT" type="TimeStamp"/>
        <Parameter name="_forcedBuild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rebuildScaleWharf" id="93c4424c-0636-43d2-a701-8a225274196b">
        <updating/>
        <source>rebuildScaleWharf()updating, protected;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpTop : Integer;
	tmpWidth : Real;
	tmpWharfDrawControl	: HMS_WharfDrawControl;
begin
	
	// get top position for current time line
	tmpTop := self.myDrawTimeLabel.getCurrentTimeTopPosition();

	foreach tmpWharfDrawControl in self.allWharfDrawControlsVisible do
		tmpWharfDrawControl.drawMe();
		// draw midnight lines
		self.myDrawTimeLabel.drawMidnightLines(tmpWharfDrawControl.myScrollingFrame);
		// calculate total width of all wharves to get wharf lable width
		tmpWidth := tmpWidth + tmpWharfDrawControl.myScrollableLabelFrame.width;
		// reposition current time line for this wharf control
		tmpWharfDrawControl.positionCurrentTimeLine(tmpTop);					
	endforeach;
	
	// reset wharf lable width
	self.setTotalWharfLabelWidth(tmpWidth);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rebuildShips" id="dac65578-3620-47e0-bd7a-92322eea60f6">
        <updating/>
        <source>rebuildShips() updating, protected;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make progress bar updates time-based, not object counts
vars
	workingVoyage		: CMIF_HMS_WorkingVoyage;
	selectedMovement	: CMIF_HMS_WorkingMovement;
	tmpWorkingVoyages	: HMS_ViewVoyageByCodeArrDTDict;
	tmpMonitor			: CMIF_Monitor;
	message				: String;
	partsDone			: Integer;
	partsInJob			: Integer;
	count				: Integer;
	allOperatorsObj		: CM_OperatorByCodeDict;
	allVesselsObj		: CM_VesselByCodeDict;
	lastUpdate 			: Decimal [20];						// PAR #35843
	
begin
	if (not self.frmModalDialog.visible) and (not self.isFirstActivateComplete) then
		self.progressStart(myViewController.allVoyagesViewedByCode.size, null, null, null,'Loading data into view');	
	endif;	

	tmpMonitor := app.myPassport.myCMIFMonitor;
	if tmpMonitor &lt;&gt; null then
		message := tmpMonitor.message;
		partsDone := tmpMonitor.partsDone;
		partsInJob := tmpMonitor.partsInJob;
	endif;

	self.clearDragPictures();
	
	//Use collection for the current view which includes unsaved stack changes (edits/deletes/berth position etc..)
	tmpWorkingVoyages := self.myViewController.allVoyagesViewedByCode;
	tmpWorkingVoyages.removeInvalidObjects();
	
	selectedMovement := self.myCurrentWorkingMovement;
	

	
	count := 0;
	// draw the ships for the selected view
	foreach workingVoyage in tmpWorkingVoyages do
		app.writeLog ("Voyage in tmp working " &amp; workingVoyage.code &amp; " at " &amp; workingVoyage.arrivedDT.String, LogINFO);
		if tmpMonitor &lt;&gt; null then	
			count := count + 1;
			//if count mod 50 = 0 then																	// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
		endif;
			//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
		// use collection on form
		self.rebuildVoyage(workingVoyage, selectedMovement); 
	endforeach;

	//Belts and braces check
	if self.myCurrentDragPicture = null then 
		//No selected drag picture (voyage) found to match selected movement so clear the form info
		self.setMyCurrentWorkingMovement(null);	
	endif;
	
	//See if any ships are currently at anchor
	self.showAnchoredShips();
epilog
	
	self.progressFinish();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rebuildVoyage" id="33ec98a5-9619-4146-93d1-48303f17c742">
        <updating/>
        <source>rebuildVoyage(_workingVoyage : CMIF_HMS_WorkingVoyage; _selectedMovement : CMIF_HMS_WorkingMovement)updating;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
// NOTE: _selectedMovement does NOT have to be a movement for this voyage
//		 but is passed through here as this is called when rebuilding the screen
//-----------------------------------------
vars
	tmpWharfCntrl	: HMS_WharfDrawControl;
	tmpWharf		: HMS_Wharf;
	nextMove		: CMIF_HMS_WorkingMovement;
	workingMovement	: CMIF_HMS_WorkingMovement;
	viewStartDT		: TimeStamp;
	viewFinishDT	: TimeStamp;
	moveStartDT		: TimeStamp;
	moveFinishDT	: TimeStamp;
	isRestricted	: Boolean;
	


begin
	if _workingVoyage = null then
		app.writeLog ("_workingVoyage is null", LogINFO);
		return;
	endif;
	

	if (not global.isValidObject(_workingVoyage)) then
		app.writeLog ("_workingVoyage is not valid ", LogINFO);
		// must have been deleted
		return;
	endif;

	self.clearVoyageFromView(_workingVoyage);
	isRestricted	:=	false;
	
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
		// use collection on form
	if not self.isVoyageDisplayed(_workingVoyage) then
		
		if chkShowVoyages.value then
			isRestricted	:=	true;
		else
			app.writeLog ("not displayed", LogINFO);
			return;
		endif;
	endif;
	
	if isRestricted then
		if not self.aAllRestrictedWorkingVoyages.includes(_workingVoyage) then
			self.aAllRestrictedWorkingVoyages.add(_workingVoyage);
		endif;
	else
		if self.aAllRestrictedWorkingVoyages.includes(_workingVoyage) then
			self.aAllRestrictedWorkingVoyages.remove(_workingVoyage);
		endif;
	endif;
	
	viewStartDT		:=	self.myViewController.viewStartDT;
	viewFinishDT	:=	self.myViewController.viewFinishDT;
	
	// rebuild all movements for this voyage
	
	app.writeLog ("Dislay move for " &amp; _workingVoyage.code &amp; " at " &amp; _workingVoyage.arrivedDT.String, LogINFO);
	foreach workingMovement in _workingVoyage.allWorkingMovements do
		tmpWharf := workingMovement.myBerth.myWharf;
		
		if tmpWharf = null then
			app.writeLog ("Voyage no wharf" &amp; _workingVoyage.code &amp; " at " &amp; _workingVoyage.arrivedDT.String, LogINFO);
			// Hmm.. movement without a wharf a bit strange but nother user can do.
			continue;
		endif;
		
		tmpWharfCntrl	:=	self.allWharfDrawControls[tmpWharf.code];
		
		if tmpWharfCntrl = null then
			// the wharf for this movement is not in this view
			continue;
		endif;
		
		nextMove	:=	workingMovement.getMovementNext();
		
		if (not global.isValidObject(nextMove)) then
			// must have been deleted
			continue;
		endif;

		moveStartDT		:=	workingMovement.occursOnDT;
		moveFinishDT	:=	nextMove.occursOnDT;
		
		// Check this movement (or part thereof) is within view range period
		if (moveStartDT  &gt;= viewStartDT and moveStartDT  &lt;= viewFinishDT)
		or (moveFinishDT &gt;= viewStartDT and moveFinishDT &lt;= viewFinishDT)
		or (moveStartDT &lt;= viewStartDT and moveFinishDT &gt;= viewFinishDT)
		then
			// Display this movement
			tmpWharfCntrl.addSprite(workingMovement, nextMove, _selectedMovement, self.aAllRestrictedWorkingVoyages);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="registerNotifications" id="2074d576-f326-4f21-bdc9-43ddd92faf77">
        <source>registerNotifications()protected;

vars
	tmpBerth : HMS_Berth;
	
begin
	// End notes done in self.buildMap()
	// as Wharf notes added in self.setupWharfControls()

	// Begin system notification of any new voyages
	beginClassNotification(HMS_VoyageData, false, Object_Delete_Event, Response_Continuous, 1);
	beginClassNotification(HMS_VoyageData, false, Object_Create_Event, Response_Continuous, 1);
	beginClassNotification(HMS_VoyageData, false, Object_Update_Event, Response_Continuous, null);
// cnwdad1 18/07/2007 - PAR #14383: New vessels weren't being added to the selector's "available" list.
	beginClassNotification(CM_Vessel, false, Object_Create_Event, Response_Continuous, 0);
	beginClassNotification(CM_Vessel, false, Object_Delete_Event, Response_Continuous, 0);
	
	beginClassNotification(HMS_PlanningNote, false, Object_Create_Event, Response_Continuous, 0);	//09 Mar 2016	NDL	TFS 1627
	
	foreach tmpBerth in self.allBerthsInView do
		self.beginNotification(tmpBerth, RefreshView, Response_Continuous, 0);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
