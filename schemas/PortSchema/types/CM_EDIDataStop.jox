    <JadeMethod name="verifyEDIDataTIs" id="324b93d5-54a4-4ab6-8be2-70256ef554a0">
        <updating/>
        <source>verifyEDIDataTIs( _passport : CM_Passport input ) : Integer updating;
//
// Purpose:	To verify the EDI Data loaded.
/* Changes

Date		Name	TFS#		Description
============================================================================
sept 2009 	cnwrs1 CCMS Messina 1008
13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;

begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions( true );	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal;
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1( Err_InvalidTerminal, null, null, null );
		return passport.allErrorWarnings.size;
	endif;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException( UnknownUser, null, null );
		return passport.allErrorWarnings.size;
	endif;
	
	progressStr	:= app.getString( Verifying_Loaded_Details, partsInJob.display );
	progressTS	:= app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do : ediTI_loop
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		// now validate each ediTrackedItem
		self.zValidateEdiData( ediTI.CM_EDIStopTI, terminal, passport );
	endforeach ediTI_loop;
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	return passport.allErrorWarnings.size;
	
epilog
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zEventRequestStopsTransaction" id="687e8ce7-47b0-41fd-9d70-5be2863838be">
        <source>zEventRequestStopsTransaction(
	_id			: String input;
	_cargoType	: CM_CargoType input;
	_ediStopTI	: CM_EDIStopTI input;
	_terminal	: CM_Terminal input;
	_passport	: CM_Passport input ) protected;
	
/*
Purpose:	This method provides a common point for the creation and action of the CM_EventRequestStops.

Date				Who		Reason
11 March 2010		cnwrl1	Initial creation as part of PAR 22926 - Allow for BOL Stops
// 22 June 2011	cnwrs1		par 27724 - Change default autCleanup friom false to true
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 4
08 may 2014		cnwer1		CCMS 2289 - changes to update to do tasks, grades and remarks
05 may 2016		cnwdap1		TFS #1699 Verified Gross Mass changes
16 Jan 2017		cnwma1		TFS #2885:QNS - Additional Data Mapping in Customs Message

*/
	
vars
	isClear				: Boolean;
	stopsTable			: CM_StopsTable;
	user				: CM_User;
	pxyRequestStops		: CM_EventRequestStops;
	cmifEventReq		: CMIF_EventRequestController;
	emailAddresses		: CM_StringArray;
	grade 				: CM_MTGrade;
	toDoTask			: CM_ToDoTaskDesc;
	cargoRemarks		: String;
	ti 					: CM_TrackedItem;
	toDoRemarks			: String;
	isWeightCertified	: Boolean;						// TFS #1699
begin
	
	create cmifEventReq transient;
	create emailAddresses transient;
	

	
	user	:= app.getMyUser();
	
	if _ediStopTI.stopCode &lt;&gt; null then
		stopsTable	:= app.myRoot.getStopTableForId( _ediStopTI.stopCode.Integer );
	
		if stopsTable = null then
			// should not happen because of previous validation but ...
			app.raiseCMException1( Stops_Id_Does_Not_Exist, _ediStopTI.stopCode, ETRow_StopCode, _ediStopTI );
			return;
		endif;
		isClear	:= _ediStopTI.stopAction = CM_EDITrackedItem.EDI_ACTION_DELETE;	// ie do we want to remove this stop
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeStops,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											stopsTable,
											// Auto cleanup this request. par 27724 cnwrs1 22 June 2011
											_ediStopTI.deliveryReleaseNumber,	// ie the additional required information for any stop needing it
											_ediStopTI.clearanceExpiryDate,
											true,null,null,null,
											_ediStopTI.getCustomsAgent,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											_ediStopTI.getTIBillOfLading,		//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											_ediStopTI.clearCustomsAgent,		//_clearCustAgent //cnwmc5 - 11 Jan 2016 - PAR 37275
											_ediStopTI.description,  			// 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTISealNumOperator, 	// 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTINotificationType    // 16/01/2017 cnwma1 TFS #2885
											);								// isEDI
	
		ti := _ediStopTI.getTrackedItem;
		if ti &lt;&gt; null then
			pxyRequestStops.setMyTrackedItem(ti,_passport);
		endif;
		
		// set up the CMIF details
		//epr CCMS 2289 8/5/14
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	if _ediStopTI.gradeCode &lt;&gt; null then
		grade:= app.myRoot.allAvailableAvailabilityGrades[_ediStopTI.gradeCode.Integer];
		if grade = null then
			app.raiseCMException1( Invalid_AvailabilityGrade, _ediStopTI.gradeCode, null, _ediStopTI );
			return;
		endif;
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeGrade,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											null,
											// Auto cleanup this request. par 27724 cnwrs1 22 June 2011
											_ediStopTI.deliveryReleaseNumber,	// ie the additional required information for any stop needing it
											_ediStopTI.clearanceExpiryDate,
											true,null,grade,null,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											_ediStopTI.description,				// 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTISealNumOperator,    // 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTINotificationType    // 16/01/2017 cnwma1 TFS #2885
											);								// isEDI
	
		// set up the CMIF details
		//epr CCMS 2289 8/5/14
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	if _ediStopTI.toDoTaskShort &lt;&gt; null then
		toDoTask:= app.myRoot.allToDoTaskDescsByShortDesc[_ediStopTI.toDoTaskShort];
		if toDoTask = null then
			// should not happen because of previous validation but ...
			app.raiseCMException1( ERR_NO_TODO_TASK, _ediStopTI.toDoTaskShort, null, _ediStopTI );
			return;
		endif;
		
		isClear	:= _ediStopTI.toDoAction = CM_EDITrackedItem.EDI_ACTION_DELETE;
		
		toDoRemarks := _ediStopTI.toDoRemarks;//06 Oct 2015	NDL	Par 37011
		
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeToDo,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											null,
											// Auto cleanup this request. par 27724 cnwrs1 22 June 2011
											_ediStopTI.deliveryReleaseNumber,	// ie the additional required information for any stop needing it
											_ediStopTI.clearanceExpiryDate,
											true,toDoTask,null,null,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											toDoRemarks,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											_ediStopTI.description,           // 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTISealNumOperator,  // 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTINotificationType  // 16/01/2017 cnwma1 TFS #2885
											);								// isEDI
	
		// set up the CMIF details
		//epr CCMS 2289 8/5/14
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	cargoRemarks:=_ediStopTI.cargoRemarks;
	
	if cargoRemarks &lt;&gt; null then
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeRemarks,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											null,
											// Auto cleanup this request. par 27724 cnwrs1 22 June 2011
											_ediStopTI.deliveryReleaseNumber,	// ie the additional required information for any stop needing it
											_ediStopTI.clearanceExpiryDate,
											true,null,null,cargoRemarks,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											_ediStopTI.description,		      // 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTISealNumOperator,  // 16/01/2017 cnwma1 TFS #2885
											_ediStopTI.getTINotificationType  // 16/01/2017 cnwma1 TFS #2885
											);								// isEDI
	
		// set up the CMIF details
		//epr CCMS 2289 8/5/14
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	isWeightCertified := _ediStopTI.isWeightCertified;																									// TFS #1699
	if isWeightCertified then																															// TFS #1699
		create pxyRequestStops transient;																												// TFS #1699
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeWeight,																					// TFS #1699
												emailAddresses,						// no actual email is required										// TFS #1699
												null,								// remarks															// TFS #1699
												_id,																									// TFS #1699
												user,																									// TFS #1699
												_cargoType,																								// TFS #1699
												user.myOrganisation,																					// TFS #1699
												_terminal,																								// TFS #1699
												EventRequestPending,																					// TFS #1699
												isClear,																								// TFS #1699
												false,								// isNotify															// TFS #1699
												_ediStopTI.billOfLading,			// reference														// TFS #1699
												true,																									// TFS #1699
												null,																									// TFS #1699
												null,	// ie the additional required information for any stop needing it								// TFS #1699
												null,																									// TFS #1699
												true, null, null, cargoRemarks,																			// TFS #1699
												null,	//_custAgent																					// TFS #1699
												null,	//_toDoRemarks																					// TFS #1699
												null,	//_tiBOL																						// TFS #1699
												null,	//_clearCustAgent																				// TFS #1699
												_ediStopTI.description,          // 16/01/2017 cnwma1 TFS #2885
												_ediStopTI.getTISealNumOperator, // 16/01/2017 cnwma1 TFS #2885
												_ediStopTI.getTINotificationType);// 16/01/2017 cnwma1 TFS #2885
																																						// TFS #1699
																																						// TFS #1699
		pxyRequestStops.setProxyWeightCertified(_ediStopTI.totalWeight, isWeightCertified, _ediStopTI.weightCertifiedName, _ediStopTI.weightCertifiedReference);	// TFS #1699
		// set up the CMIF details																														// TFS #1699
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);																					// TFS #1699
	endif;																																				// TFS #1699
	
//	if cmifEventReq.allPxyCargoUpdateRequests.isEmpty then
		
//	endif;
	

	
	cmifEventReq.action(_passport);
	
epilog
	delete emailAddresses;
	cmifEventReq.allPxyCargoUpdateRequests.purge;
	delete cmifEventReq;

	
end;
</source>
        <access>protected</access>
        <Parameter name="_id" type="String" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType" usage="input"/>
        <Parameter name="_ediStopTI" type="CM_EDIStopTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zLoadDB" id="85e0f3ee-7db8-4b44-8b49-a1126d06cfc6">
        <updating/>
        <source>zLoadDB(
	_ediStopTI	: CM_EDIStopTI input;
	_terminal	: CM_Terminal input;
	_passport	: CM_Passport input ) updating;
	
/*
Purpose:		This method will create the actual EventRequestStops transaction OR
				will create a BOL Stop via zLoadDB_BOL method.

Date				Who		Reason
17 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
11/03/2010			cnwrl1	PAR 22926 - Allow for BOL Stops
*/
	
vars

begin
	// since this EDI object has been validated we know have either a cargo Id or a BOL.
	//epr par 32129 20/11/14 only load BOL if no cargo id
	if _ediStopTI.id = null and  _ediStopTI.billOfLading &lt;&gt; null then
		self.zLoadDB_BOL( _ediStopTI, _terminal, _passport );
		return;
	endif;
	
	// Otherwise must be for a cargo Id.
	// NOTE: The stop will be checked if it is relevant at the time it is applied.
	self.zEventRequestStopsTransaction(	_ediStopTI.id,
										_ediStopTI.myCargoType,
										_ediStopTI,
										_terminal,
										_passport );
epilog
	
end;
</source>
        <Parameter name="_ediStopTI" type="CM_EDIStopTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zLoadDB_BOL" id="cc6929ad-b491-432c-a318-0ec8281c067c">
        <source>zLoadDB_BOL(
	_ediStopTI	: CM_EDIStopTI input;
	_terminal	: CM_Terminal input;
	_passport	: CM_Passport input ) protected;
	
/*
Purpose:	Load to the database EDI BOL Stops
			This can be done one of 2 ways:
			1) If the stopTable includes the bolType (aka BOL Stop) then the stop will be applied to the BOL only.
			2) Otherwise the stop will be applied to all cargo Ids on the BOL that match the cargo type(s) on the stopTable.
	
Date				Who		Reason
11 March 2010		cnwrl1	Initial creation as part of PAR 22926 - Allow for BOL Stops
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 4
*/
	
vars
	ediStopTI			: CM_EDIStopTI;
	trackedItem			: CM_TrackedItem;
	stopsTable			: CM_StopsTable;
	voyage				: CM_Voyage;
	bol					: CM_BOL;
	bolSet				: CM_BOLSet;
	stopIDs				: IntegerArray;
	
begin
	ediStopTI	:= _ediStopTI;				// to reduce dereferencing set a local variable
	
	voyage	:= _terminal.lookupVoyage( ediStopTI.getVoyageCode().trimBlanks, null, false );
	if voyage = null then
		// should not happen because of previous validation but ...
		app.raiseCMException2( Voyage_DoesNotExist_4_Terminal, ediStopTI.getVoyageCode().trimBlanks,_terminal.code, ETRow_VoyageCode, ediStopTI );
		return;
	endif;
	
	bol	:=	voyage.doesBOLAlreadyExist( ediStopTI.billOfLading );
	if bol = null then
		// should not happen because of previous validation but ...
		app.raiseCMException2( BOL_not_found_voyage, ediStopTI.billOfLading, ediStopTI.getVoyageCode(), ETRow_BillOfLading, ediStopTI );
		return;
	endif;
	
	stopsTable	:= app.myRoot.getStopTableForId( ediStopTI.stopCode.Integer );
	if stopsTable = null then
		// should not happen because of previous validation but ...
		app.raiseCMException1( Stops_Id_Does_Not_Exist, ediStopTI.stopCode, ETRow_StopCode, ediStopTI );
		return;
	endif;
	
	// Get to here OK so process this EDI data.
	create bolSet transient;
	create stopIDs transient;
	
	if stopsTable.isValidForCargoType( bol.bolType ) then
		// Apply the stop to the BOL only.
		bolSet.add( bol );
		stopIDs.add( stopsTable.id );
		
		if ediStopTI.stopAction = CM_EDITrackedItem.EDI_ACTION_ADD then
			app.myUtilityCA.utlCreateStopsForBOLs( bolSet, stopIDs, _passport );
		else
			app.myUtilityDA.utlDeleteStopBOLsBulk( bolSet, stopsTable, ediStopTI.deliveryReleaseNumber, _passport );
		endif;
		
		return;
	endif;
	
	// Otherwise apply the stop to the all of the TIs on this BOL with matching cargoTypes.
	foreach trackedItem in bol.allTrackedItems discreteLock do : trackedItem_loop
		// NOTE: The stop will be checked if it is relevant at the time it is applied.
		self.zEventRequestStopsTransaction(	trackedItem.id,
											trackedItem.myCargoType,
											_ediStopTI,
											_terminal,
											_passport );
		if _passport.hasErrors then
			return;
		endif;
	endforeach trackedItem_loop;
	
epilog
	delete bolSet;
	delete stopIDs;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediStopTI" type="CM_EDIStopTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zValidateEdiData" id="f67fc1df-2ba5-4f03-abfe-57e6161c8d94">
        <source>zValidateEdiData(
	_ediStopTI	: CM_EDIStopTI input;
	_terminal	: CM_Terminal input;
	_passport	: CM_Passport input ) protected;

/*
Purpose:	Because these EDI Data Stops are going to be set up as CM_EventRequestStops which can
			then be processed at a later date eg when the container actually arrives at the terminal,
			the validation done here is very basic eg:
			1) The mantatory fields have some appropriate values.
			2) cargo type supplied is a valid value.
			3) That the stop id supplied exists and is valid for the supplied cargo type and terminal.
			4) If the stop is being removed and requires additional information then this is also supplied.
			
			Note: This method assumes that the terminal has already been checked to see that it exists.

Date				Who		Reason
16 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
06 May 2016			cnwdap1	TFS #1699 Verified Gross Mass changes - allow just total weight to be changed
*/
	
vars
	cargoTI				: Boolean;
	action				: String;
	ediStopTI			: CM_EDIStopTI;
	stopsTable			: CM_StopsTable;
	voyage				: CM_Voyage;
	bol					: CM_BOL;
	toDoTask : CM_ToDoTaskDesc;
	bolString	 		: String;
begin
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	ediStopTI	:= _ediStopTI;				// to reduce dereferencing set a local variable
	
	// check that the action is valid
	action	:=  ediStopTI.stopAction;
	if action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD and action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE	then
		if action = null and ediStopTI.stopCode = null then	//10 Mar 2016	NDL	TFS 1650
			// Not processing a stop is OK.
		else
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_StopAction, ediStopTI);
			return;
		endif;
	endif;
	
	if (ediStopTI.id = null and ediStopTI.billOfLading = null)
	//or (ediStopTI.id &lt;&gt; null and ediStopTI.billOfLading &lt;&gt; null)
	then
		app.raiseCMException(MustEnter_Cargo_Or_BOL_Info, ETRow_Id, ediStopTI);
		return;						// not much point doing further validation
	endif;
	
	cargoTI	:= ediStopTI.id &lt;&gt; null;	
	if cargoTI then							// cnwrl1 11/03/2010 PAR 22926
		// check that the cargo type is valid.
		if ediStopTI.myCargoType = null
		or ediStopTI.cargoType &lt; TI_CargoType_Container
		then
			app.raiseCMException1(Cargo_Type_Invalid, ediStopTI.cargoTypeDescr, ETRow_CargoTypeDescr, ediStopTI);
			return;
		endif;
			
	else								// Bill Of Lading
		// attempt to find this voyage on this terminal ignoring archived voyages.
		if ediStopTI.getVoyageCode().trimBlanks() = null then
			app.raiseCMException1(Voyage_code_invalid, ediStopTI.getVoyageCode().trimBlanks(), ETRow_Id, ediStopTI);
			return;
		endif;
		
		voyage	:= _terminal.lookupVoyage(ediStopTI.getVoyageCode().trimBlanks(), null, false);
		if voyage = null then
			app.raiseCMException2(Voyage_DoesNotExist_4_Terminal, ediStopTI.getVoyageCode().trimBlanks(),_terminal.code, ETRow_VoyageCode, ediStopTI);
			return;
		endif;
		
		// need to check that BOL exists
		bol	:=	voyage.doesBOLAlreadyExist(ediStopTI.billOfLading);
		if bol = null then
			app.raiseCMException2(BOL_not_found_voyage, ediStopTI.billOfLading, ediStopTI.getVoyageCode(), ETRow_BillOfLading, ediStopTI);
			return;
		endif;
	endif;
	
	//epr TFS 3642 9/3/17 
	self.checkEDICutoff(ediStopTI.getVoyageCode.trimBlanks(),null,ediStopTI);
	
	// check that the supplied stop id is for a valid stop table.
	stopsTable	:= app.myRoot.getStopTableForId(ediStopTI.stopCode.Integer);
	if stopsTable = null then
		if action = null and ediStopTI.stopCode = null then	//10 Mar 2016	NDL	TFS 1650
			// Not processing a stop is OK.
		else
			app.raiseCMException1(Stops_Id_Does_Not_Exist, ediStopTI.stopCode, ETRow_StopCode, ediStopTI);
			return;
		endif;
	endif;
	
	//10 Mar 2016	NDL	TFS 1650
	if stopsTable = null and action = null then
		//we have no stop. make sure we are trying to process a todo then..
		action := ediStopTI.toDoAction;
		if  ediStopTI.toDoTaskShort &lt;&gt; null then
			toDoTask :=app.myRoot.allToDoTaskDescsByShortDesc.getAtKey( ediStopTI.toDoTaskShort );
		endif;
		if action = null and toDoTask = null then
			if not ediStopTI.isWeightCertified and ediStopTI.weightCertifiedName = null and ediStopTI.weightCertifiedReference = null then	// TFS #1699
				app.raiseCMException(Each_cargo_updat_reque_must_id,ETRow_StopCode, ediStopTI);
				return;
			endif;																															// TFS #1699
		elseif action = null then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_ToDoAction, ediStopTI);
			return;
		elseif toDoTask = null then
			app.raiseCMException(Input_required_field_toDoReqst, ETRow_ToDoTaskShort, ediStopTI);
			return;
		endif;
	endif;
	
	if stopsTable &lt;&gt; null then		//10 Mar 2016	NDL	TFS 1650
		// make sure this stop table is available for entry
		if not app.myRoot.allAvailableStopsTables.includes(stopsTable) then
			app.raiseCMException1(Stop_NotAvailableForEntry, stopsTable.heading &amp; " 'Id= " &amp; ediStopTI.stopCode &amp; "'", ETRow_StopCode, ediStopTI);
			return;
		endif;
		
		// check that this stop table is valid for the terminal being processed.
		if not stopsTable.isValidForTerminal(_terminal) then
			app.raiseCMException2(Stop_NotAllowed_4This_Terminal, ediStopTI.stopCode, _terminal.code, ETRow_StopCode, ediStopTI);
			return;
		endif;
		
		// check that this stop table is valid for the cargo type being processed (not applicable for BOL)
	//	if not cm_StopsTable.isValidForCargoType(ediStopTI.cargoType) then	// cnwrl1 11/03/2010 PAR 22926 - what it was
		if cargoTI and not stopsTable.isValidForCargoType(ediStopTI.cargoType) then
			app.raiseCMException2(StopCargoTypeMismatch, ediStopTI.stopCode, ediStopTI.cargoType.display &amp; Space &amp; ediStopTI.myCargoType.description, ETRow_StopCode, ediStopTI);
			return;
		endif;
		// Note: cannot check that this stop is relevant for this tracked item
		// since the tracked item might not have arrived yet!
		
		// check that if this stop table needs additional information then this has been supplied if the action is delete.
		// This additional information is passed in via the deliveryReleaseNumber field
		// but can be for any of the required information eg CEDO, CustomsEntryNumber etc.
		if action = CM_EDITrackedItem.EDI_ACTION_DELETE
		and stopsTable.requiresInfo
		and ediStopTI.deliveryReleaseNumber = null	// ie the additional required information for any stop needing it
		then
			app.raiseCMException1(Stop_Delete_Missing_ReqInfo, ediStopTI.stopCode, ETRow_StopCode, ediStopTI);
			return;
		endif;
	
	endif;
	
	//epr TFS 4530 26/6/17
	bolString:= ediStopTI.getTIBillOfLading;
	if bolString &lt;&gt; null and bolString.length &gt; 30 then
		app.raiseCMException2(ERR_STRING_TO_LONG,CM_TrackedItem::billOfLading.name,"30",null,ediStopTI);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ediStopTI" type="CM_EDIStopTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
