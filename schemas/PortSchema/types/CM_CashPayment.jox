    <JadeMethod name="setProformaDetails2" id="73bcc995-c4d9-4a4a-986b-8657797bbbc2">
        <updating/>
        <source>setProformaDetails2(_invoiceLines : CM_InvoiceLineSet; _paidDescriptions : StringArray; _paidQuantities : RealArray; _paidTotals : DecimalArray) updating;

/*

Purpose:			Save the proforma invoice line description, quantity and total values, for reporting.
					34990 Save the difference between the current full proforma details and previously-paid proforma details.
Parameters:			

Return Value:		


Date		Who		Reason
13/02/2013	cnwjre1	Initial creation
20/10/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges - setting of proformaLineDescriptions
Aug 2016	cnwjre1	The proformaLineDescriptions, proformaLineQuantites and proformaLineTotals don't need to be maintained 
					since CM_ProformaDetails were introduced so the code for this has been removed
*/

vars

begin
// TFS 45953	self.proformaLineDescriptions.clear();
// TFS 45953	self.proformaLineQuantities.clear();
// TFS 45953	self.proformaLineTotals.clear();
	

end;</source>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet"/>
        <Parameter name="_paidDescriptions" type="StringArray"/>
        <Parameter name="_paidQuantities" type="RealArray"/>
        <Parameter name="_paidTotals" type="DecimalArray"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="434d946f-c89e-4d9d-9105-f5eefc923a37">
        <updating/>
        <source>setProxy(	_cashValue,
			_taxAmount 		     : Decimal;
			_dateTime 		     : TimeStamp;
			_proformaDesc        : String;
			_manual 		     : Boolean;
			_status 		     : Integer;
			_voided 		     : Boolean;	
			_myDebtorTerminal    : CM_DebtorTerminal;
			_myTrackedItem 	     : CM_TrackedItem;
			_myInvoice		     : CM_Invoice;
			_vvr 			     : CM_VehicleVisitRecord;
			_myUser 		     : CM_User
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	    cnwndl1	Initial creation	Par 29968
31 Jan  2020        cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars

begin

	self.cashValue        := _cashValue;
	self.taxAmount        := _taxAmount;
	self.dateTime         := _dateTime;
	self.proformaDesc     := _proformaDesc;
	self.manual 	      := _manual;
	self.status 	  	  := _status;
	self.myDebtorTerminal := _myDebtorTerminal;
	self.myTrackedItem    := _myTrackedItem;
	self.myInvoice		  := _myInvoice;
	self.myUser 		  := _myUser;
	
	self.setVoided( _voided );
	self.setVehicleVisitRecord(_vvr);
epilog

end;</source>
        <Parameter name="_cashValue" type="Decimal"/>
        <Parameter name="_taxAmount" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_proformaDesc" type="String"/>
        <Parameter name="_manual" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_voided" type="Boolean"/>
        <Parameter name="_myDebtorTerminal" type="CM_DebtorTerminal"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_myInvoice" type="CM_Invoice"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_myUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromInvoiceLine" id="e20cc10d-9d6e-4cad-9bf8-699b37b9159c">
        <updating/>
        <source>setPxyFromInvoiceLine(_invoiceLine : CM_InvoiceLine) updating;
/*
Purpose:	

Date		Who		Reason
20 May 2025	navab1	JIRA 34909
*/

vars
	term : CM_Terminal;
	debtTerm : CM_DebtorTerminal;
begin
	self.cashValue := _invoiceLine.lineTotal;
	self.dateTime := _invoiceLine.chargeTime;
	
	self.manual := false;
	
	
	term := self.myTerminal;
	debtTerm := _invoiceLine.debtor.allDebtorTerminals[term];
	
	self.myDebtorTerminal := debtTerm;
	self.myInvoiceLine := _invoiceLine;
	self.myTerminal := term;
	self.myTrackedItem := _invoiceLine.trackedItem;
	self.myVoyage := _invoiceLine.getMyVoyageObject();
	self.status := Status_Normal;
	
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="3e415e62-4107-4619-ba42-e1665959b770">
        <updating/>
        <source>setStatus(_value : Integer) updating;

vars

begin
	self.status := _value;
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTaxForReceiptDetail" id="163bc697-4edc-4095-87e6-0e70ce7a116a">
        <updating/>
        <source>setTaxForReceiptDetail() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2024	navab1	Initial creation

*/

vars
	proformaDetail : CM_ProformaDetails;
	invLine : CM_InvoiceLine;
begin
	invLine := self.myInvoiceLine;
	
	create proformaDetail transient; 
	if invLine &lt;&gt; null then
		proformaDetail.setMyInvoiceLineType(invLine.invoiceLineDesc);
	endif;
	proformaDetail.setTaxToRemarks(TaxForCashReceiptRemarks);
	self.setProformaDetail(proformaDetail);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setVehicleVisitRecord" id="424aef0d-5762-44bd-a580-be20e5d15b0d">
        <updating/>
        <source>setVehicleVisitRecord( _vvr : CM_VehicleVisitRecord ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	driver : CM_DriverDetails;
	carrier : CM_Carrier;

begin

	if _vvr &lt;&gt; null then
	
		driver := _vvr.myDriverDetails;
		if _vvr.carrierCode &lt;&gt; null then
			carrier := _vvr.getCarrier;
		endif;
		if driver &lt;&gt; null then
			self.myDriver := driver;
		endif;
		if carrier &lt;&gt; null then
			self.myCarrier := carrier;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setVoided" id="6884f54e-a0b8-43e0-91a2-b7c6b644fae1">
        <updating/>
        <source>setVoided( _voided : Boolean ) updating;

// DO NOT USE - VOIDED IS VIRTUAL AND HAS A MAPPING METHOD
// THIS METHOD DOES NOTHING.







/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.voided := _voided;

epilog

end;</source>
        <Parameter name="_voided" type="Boolean"/>
    </JadeMethod>
