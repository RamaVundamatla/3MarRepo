    <JadeMethod name="asStringWeightJMTLeadingSpaces" id="e939773a-fd85-45e9-abba-d2ad538b8a09">
        <source>asStringWeightJMTLeadingSpaces(_digits:Integer):String;
//
//06 Aug 2012	cnwrs1	- Par 30155 CCMS 1017 weight change for maersk Stock report has not worked correctly
//
vars
	padding : String;
	leadingZeros : Integer;
	index : Integer;
begin
	if self &lt; 10 then
		leadingZeros := _digits - 1;
	elseif self &lt; 100 then
		leadingZeros := _digits - 2;
	elseif self &lt; 1000 then
		leadingZeros := _digits - 3;
	elseif self &lt; 10000 then
		leadingZeros := _digits - 4;
	elseif self &lt; 100000 then
		leadingZeros := _digits - 5;
	elseif self &lt; 1000000 then
		leadingZeros := _digits - 6;
	elseif self &lt; 1000000 then
		leadingZeros := _digits - 7;
	endif;
	if leadingZeros &lt; 1 then
		return self.String;
	else
		foreach index in 1 to leadingZeros do
			padding := padding &amp; " ";
		endforeach;
		return padding &amp; self.asStringWeightJMT();
	endif;
end;
</source>
        <Parameter name="_digits" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
