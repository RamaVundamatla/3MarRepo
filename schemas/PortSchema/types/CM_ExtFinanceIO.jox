    <JadeMethod name="oracleDateFormat" id="2a12f5ef-9124-42b5-8404-998d653c8c9f">
        <source>oracleDateFormat(_dt : Date) : String protected;

vars
	result	: String;
begin
	result := "TO_DATE('" &amp; _dt.format('dd/MM/yyyy') &amp; "', 'DD/MM/YYYY')";
	return result;
end;
</source>
        <access>protected</access>
        <Parameter name="_dt" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="oracleTSFormat" id="3085b97a-a3d3-438e-9807-6889c6164d2f">
        <source>oracleTSFormat(_ts : TimeStamp) : String protected;

vars
	result	: String;
begin
	result := "TO_DATE('" &amp; _ts.date.format('dd/MM/yyyy') &amp; " " &amp; _ts.time.formatAsHHmmSS() &amp; "', 'DD/MM/YYYY HH24:MI:SS')";
	return result;
end;
</source>
        <access>protected</access>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
