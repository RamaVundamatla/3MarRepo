    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="89b2ad2d-ab2c-484d-8f87-56e98d0d8087">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _delayType: CM_DelayType; lstIndex: Integer): String updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	09 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	 failedDAC  :CM_DataAccessController;

begin
	if _delayType = null then
		return null;
	endif;
	
	/*if _delayType.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _delayType then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;*/
		

	if (not _delayType.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	return _delayType.description;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_delayType" type="CM_DelayType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="0e913af6-c7a7-4f61-b4af-4beed6cb62c5">
        <source>getCollectionJMT(): Collection protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return app.myRoot.allDelayTypes;
end;
</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
