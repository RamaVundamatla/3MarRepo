    <JadeMethod name="requiresMoreThan1TwentyLC" id="4ee37e69-fceb-4bff-be26-2b20cea2a28c">
        <source>requiresMoreThan1TwentyLC() : Boolean;
// ---------------------------------------------------------------------------
// Created:		07 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415 CCMS 1029
//
// ---------------------------------------------------------------------------
vars
begin
	if self.is40 or self.is45() or self.is53() then
