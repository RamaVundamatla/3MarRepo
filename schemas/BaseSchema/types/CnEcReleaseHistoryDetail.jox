    <JadeMethod name="updateMe" id="e95ed97d-c4ee-4af6-bfa4-f17892366872">
        <updating/>
        <source>updateMe(pTimestamp:TimeStamp; pText:String; pHistoryMasterObj:CnEcReleaseHistoryMaster) updating;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Updates the receiver's history details.
//
// Parameters:	pTimestamp - The timestamp of the release event.
//				pText - A description of the release event.
//				pHistoryMasterObj - The owning master release object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set property values.
	
	self.itemText		:=	pText;
	
	// Set key properties.
	
	self.itemTime		:=	pTimestamp;
	
	// Set references.
	
	self.myMaster		:=	pHistoryMasterObj;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster"/>
    </JadeMethod>
</Class>
