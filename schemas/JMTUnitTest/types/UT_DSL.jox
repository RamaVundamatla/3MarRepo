        <source>setInclusiveStorageConfig( _value : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2019	jlgndl1	Initial creation	TFS 45574

*/

vars

	storageConfig : CM_StorageConfig;

begin

	storageConfig := self.getTerminal.myStorageConfig;
