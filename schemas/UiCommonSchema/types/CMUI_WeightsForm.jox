    <JadeMethod name="closeIfNoUpdateButtonsVisible" id="b9bb4ca6-86d3-4ad7-bf26-92f469db088e">
        <updating/>
        <source>closeIfNoUpdateButtonsVisible() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

//	theReturn : Integer;
//	pxyWeighing :CM_VehicleVisitWeighing;

begin

	self.calculate( false, null );
	
	if btnUpdCargo.visible then
		return;
	endif;
	if btnUpdChassis.visible then
		return;
	endif;
	if btnUpdGenny.visible then
		return;
	endif;
	if btnUpdMachine.visible then
		return;
	endif;
	if btnUpdTruck.visible then
		return;
	endif;
	
	self.doAddVvrWeighingRecord( true );	//08 July 2019	NDL	TFS 44965
	/*
	if self.myVehicleVisitRecord &lt;&gt; null then
	
		create pxyWeighing transient;
		self.setVVRWeighingProxy( pxyWeighing );
		
		while true do
			app.myTrxUA.trxAddVVRWeighing(self.myVehicleVisitRecord, pxyWeighing, app.myPassport);

			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Weigh_vehicle), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged     := true;
					continue;
				endif;
				break;
			endif;
			break;
		endwhile;
	endif;
	
	self.modalResult := theReturn;
	self.unloadForm;
	
	*/

epilog

//	delete pxyWeighing;

end;</source>
