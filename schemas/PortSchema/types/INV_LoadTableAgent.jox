<Class name="INV_LoadTableAgent" id="984ede98-eab5-42f6-bee7-e90cb46cc1e6">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <ImplicitInverseRef name="myForm" id="76d582ec-2462-4056-bbc0-b791235b2d2b">
        <embedded/>
        <type name="Form"/>
    </ImplicitInverseRef>
    <JadeMethod name="doImport" id="5a712baf-f0d6-4bd4-95b8-32add4f0b48c">
        <source>doImport(): Boolean;

/*

Purpose:	JMT 1010 Interface Load		

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/

vars
	impFile		: File;
	cmifMonitor	: CMIF_Monitor;
	theForm		: Form;	
begin
	
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

	self.getImportFile(impFile);
	theForm := self.myForm;
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := theForm;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

//	self.initModalDialog();
//	theForm.lblModalMessage.caption := Cr &amp; "Importing " &amp; getTableName;
//	theForm.frmModalDialog.visible := true;

	app.doWindowEvents(0);

	
	if impFile.fileName = null then
		return true;
	else
		doImportTrx(impFile);
		//app.myTrxCA.trxImportUNDGCodesFromFile(impFile, app.myPassport);
	endif;
		
	return app.myPassport.trxCompletedOK;
	
epilog
//	theForm.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete impFile;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doImportTrx" id="29f48fa6-84ed-4a39-bf26-51216328e228">
        <source>doImportTrx(_impFile: File) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/


vars

begin
//	app.myTrxCA.trxImportUNDGCodesFromFile(_impFile, app.myPassport);
end;</source>
        <access>protected</access>
        <Parameter name="_impFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="getImportFile" id="7cc11382-c751-4259-a8d8-03f4d8a13fa9">
        <source>getImportFile(_file: File io);

/*

Purpose:	JMT 1010 Interface Load 		

Parameters:			

Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/


vars
	fileGet		 		: CMDFileOpen;
	fileName			: String;
	
begin
	if _file = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet;
	fileGet.filter 		:= getImportFilter;	
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	if fileGet.open = 0 then	//user clicked OK
		_file.fileName := fileGet.fileName;
	endif;
	
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getImportFilter" id="b6504a12-e918-463e-a1b1-303dc761cced">
        <source>getImportFilter() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/

vars

begin

	return '.csv|*.csv';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
