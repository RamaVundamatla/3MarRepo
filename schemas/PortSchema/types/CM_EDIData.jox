    <JadeMethod name="loadDB" id="c7d43021-3329-46c7-a35c-d5807db91f66">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;
// Parameters:  _mergeCargo - Only relevant when loading a Bay Plan.
//				_passport - A reference to the current user Passport object.
begin
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " reimplement this method in your sub-class");
end;</source>
