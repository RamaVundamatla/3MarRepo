    <JadeMethod name="actionTI" id="63b71128-920e-4519-8073-1460b4df29fa">
        <updating/>
        <source>actionTI(_ti: CM_TrackedItem input; _actionType: String; _passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	before, after	: Integer;
begin
	//should have already established that this action is valid to perform on this TI
	if _ti = null then
		return false;
	endif;
	
	before := _ti.allToDoTasksToDo.size;
	
	if _actionType = EDIAction_Add then
		_ti.addToDoTask(self.description, _passport);
		
	elseif _actionType = EDIAction_Remove then
		_ti.removeToDoTask(self.description, _passport);
		
	elseif _actionType = EDIAction_Complete then
		_ti.setToDoTaskComplete(self.code, _passport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid EDI Action ' &amp; _actionType);
		return false;
	endif;
	
	after := _ti.allToDoTasksToDo.size;
	
	return before &lt;&gt; after;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_actionType" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
