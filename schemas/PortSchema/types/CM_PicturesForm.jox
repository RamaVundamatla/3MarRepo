    <JadeMethod name="saveCarPictureToDB" id="f59e16f9-61ee-48dd-9fec-63ddb6993e34">
        <source>saveCarPictureToDB();
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     Should only ever be called from app.loadIcons() as the further content of
//				of this calling method is required to be executed (CM_ToolbarIconsForm)
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	root		: CM_Root;
	terminal	: CM_Terminal;

begin

	root := app.myRoot;
	
	// need to think about doing this as some form of trx???

	beginTransaction;
	// TOOLBAR NAVI ICONS

	root.setConfig(PicCargo20Stand, self.picCargo20Stand.picture,false);
	root.setConfig(PicCargo20Flat, self.picCargo20Flat.picture,false);
	root.setConfig(PicCargo20Open, self.picCargo20Open.picture,false);
	root.setConfig(PicCargo20Reefer, self.picCargo20Reefer.picture,false);
	root.setConfig(PicCargo20Integ, self.picCargo20Integ.picture,false);
	root.setConfig(PicCargo20Side, self.picCargo20Side.picture,false);
	root.setConfig(PicCargo10Stand, self.picCargo10Stand.picture,false);
	root.setConfig(PicCargoCOU, self.picCargoCOU.picture,false);
	root.setConfig(PicCargo40Stand, self.picCargo40Stand.picture,false);
	root.setConfig(PicCargo40Flat, self.picCargo40Flat.picture,false);
	root.setConfig(PicCargo40Open, self.picCargo40Open.picture,false);
	root.setConfig(PicCargo40Integ, self.picCargo40Integ.picture,false);
	root.setConfig(PicCargo40Hinteg, self.picCargo40Hinteg.picture,false);
	root.setConfig(PicCargo40Hi, self.picCargo40Hi.picture,false);
	
epilog
	commitTransaction;	

end;</source>
    </JadeMethod>
    <JadeMethod name="savePicturesToDatabase" id="0351825b-2dbc-4e7f-881e-1ad8fd1a19f7">
        <source>savePicturesToDatabase();
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     Should only ever be called from app.loadIcons() as the further content of
//				of this calling method is required to be executed (CM_ToolbarIconsForm)
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/08/2015	cnwdap1		PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 21/11/25 navsaa30 MTN-36586 MTN | Add a new Portia Assistant icon to the existing MTN application UI
// ---------------------------------------------------------------------------
vars
	root		: CM_Root;
	terminal	: CM_Terminal;

begin

	root := app.myRoot;
	
	// need to think about doing this as some form of trx???

	beginTransaction;
	// TOOLBAR NAVI ICONS

	root.setConfig(P16ArrowDown, self.p16ArrowDown.picture,false);
	root.setConfig(P16ArrowLeft, self.p16ArrowLeft.picture,false);
	root.setConfig(P16ArrowRight, self.p16ArrowRight.picture,false);
	root.setConfig(P16ArrowUp, self.p16ArrowUp.picture,false);
	root.setConfig(P16ArrowDown3d, self.p16ArrowDown3d.picture,false);
	root.setConfig(P16ArrowRight3d, self.p16ArrowRight3d.picture,false);
	root.setConfig(P16BlueBullet, self.p16BlueBullet.picture,false);
	root.setConfig(P16BookUp, self.p16BookUp.picture,false);
	root.setConfig(P16Consignee, self.p16Consignee.picture,false);
	root.setConfig(P16GateOutUp, self.p16GateOutUp.picture,false);
	root.setConfig(P16Hazard, self.p16Hazard.picture,false);
	root.setConfig(P16GateInUp, self.p16GateInUp.picture,false);
	root.setConfig(P16EnqUp, self.p16EnqUp.picture,false);
	root.setConfig(P16ISOGroup, self.p16ISOGroup.picture,false);
	root.setConfig(P16DisPort, self.p16DisPort.picture,false);
	root.setConfig(P16AutoMask, self.p16AutoMask.picture,false);
	root.setConfig(P16Comm, self.p16Comm.picture,false);
	root.setConfig(P16GlobVoy, self.p16GlobVoy.picture,false);
	root.setConfig(P16EmptyUp, self.p16EmptyUp.picture,false);
	root.setConfig(P16LogGrade, self.p16LogGrade.picture,false);
	root.setConfig(P16LogVoy, self.p16LogVoy.picture,false);
	root.setConfig(P16MoveLeftBot, self.p16MoveLeftBot.picture,false);
	root.setConfig(P16MoveLeftTop, self.p16MoveLeftTop.picture,false);
	root.setConfig(P16MoveRightTop, self.p16MoveRightTop.picture,false);
	root.setConfig(P16MultiSelect, self.p16MultiSelect.picture,false);
	root.setConfig(P16Operator, self.p16Operator.picture,false);
	root.setConfig(P16Other01, self.p16Other01.picture,false);
	root.setConfig(P16Other02, self.p16Other02.picture,false);
	root.setConfig(P16Other03, self.p16Other03.picture,false);
	root.setConfig(P16Other04, self.p16Other04.picture,false);
	root.setConfig(P16Other05, self.p16Other05.picture,false);
	root.setConfig(P16Other06, self.p16Other06.picture,false);
	root.setConfig(P16Other07, self.p16Other07.picture,false);
	root.setConfig(P16Other08, self.p16Other08.picture,false);
	root.setConfig(P16Other09, self.p16Other09.picture,false);
	root.setConfig(P16Other10, self.p16Other10.picture,false);
	root.setConfig(P16Other11, self.p16Other11.picture,false);
	root.setConfig(P16Other12, self.p16Other12.picture,false);
	root.setConfig(P16Other13, self.p16Other13.picture,false);
	root.setConfig(P16Other14, self.p16Other14.picture,false);
	root.setConfig(P16Other15, self.p16Other15.picture,false);
	root.setConfig(P16Other16, self.p16Other16.picture,false);
	root.setConfig(P16Other17, self.p16Other17.picture,false);
	root.setConfig(P16Other18, self.p16Other18.picture,false);
	root.setConfig(P16Other19, self.p16Other19.picture,false);
