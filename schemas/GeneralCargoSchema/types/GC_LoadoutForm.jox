    <JadeMethod name="addControlCmbCargoDetail" id="5f9ec431-e835-4300-8687-dab05377f400">
        <updating/>
        <source>addControlCmbCargoDetail(_row, _newIdx : Integer) : CMUI_ComboBoxCargoTypeForTerm updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newCombo 	: CMUI_ComboBoxCargoTypeForTerm;
	idx			: Integer;
begin

	if _newIdx = 0 then
		self.newIndex := self.newIndex + 1;
		idx := self.newIndex;
	else
		idx := _newIdx;
	endif;

	newCombo := self.cmbCargoDetail.loadControl(idx).CMUI_ComboBoxCargoTypeForTerm;
	self.allClonedControls.add(newCombo);
//	newCombo.automaticCellControl := true;
	newCombo.CMUI_ComboBoxCargoTypeForTerm.myTerminal := self.myTerminal;
	self.tblDataDetail.accessCell(_row, self.colCargoType).cellControl := newCombo;

	return newCombo;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_newIdx" type="Integer"/>
        <ReturnType type="CMUI_ComboBoxCargoTypeForTerm"/>
    </JadeMethod>
    <JadeMethod name="addControlCmbItem" id="37933cb0-4f04-46ef-84f2-c03ac4d690f2">
        <updating/>
        <source>addControlCmbItem(_row, _newIdx : Integer) : CMUI_ComboBox updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newCombo 	: CMUI_ComboBox;
	idx			: Integer;
begin

	if _newIdx = 0 then
		self.newIndex := self.newIndex + 1;
		idx := self.newIndex;
	else
		idx := _newIdx;
	endif;

	newCombo := self.cmbItem.loadControl(idx).CMUI_ComboBox;
	self.allClonedControls.add(newCombo);
//	newCombo.automaticCellControl := true;
	self.tblDataDetail.accessCell(_row, self.colItem).cellControl := newCombo;

	return newCombo;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_newIdx" type="Integer"/>
        <ReturnType type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="addControlCmbProductDetail" id="410ed0b8-de7a-432a-a7c8-d2babea25d7f">
        <updating/>
        <source>addControlCmbProductDetail(_row, _newIdx : Integer) : CMUI_ComboProduct updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newCombo 	: CMUI_ComboProduct;
	idx			: Integer;
begin

	if _newIdx = 0 then
		self.newIndex := self.newIndex + 1;
		idx := self.newIndex;
	else
		idx := _newIdx;
	endif;
	if self.colProduct &gt; 0 then
		newCombo := self.cmbProductDetail.loadControl(idx).CMUI_ComboProduct;
		self.allClonedControls.add(newCombo);
	//	newCombo.automaticCellControl := true;
		self.tblDataDetail.accessCell(_row, self.colProduct).cellControl := newCombo;
	endif;

	return newCombo;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_newIdx" type="Integer"/>
        <ReturnType type="CMUI_ComboProduct"/>
    </JadeMethod>
    <JadeMethod name="addObjectToDetailTable" id="dd3f2f76-c807-4092-b8b6-9992adc45508">
        <updating/>
        <source>addObjectToDetailTable(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowIdx : Integer;
	tmpTable : CM_DataTable;
	rowArray : EntTableRowArray;
	newTxtBox : CMUI_TextBox;
	newCombo : CMUI_ComboBox;
	assist : CMUI_Assistant;
	bolOutLine : CMIF_BOLOutLine;
	strId		: String;
	intCargoTypeId		: Integer;
begin
	inheritMethod(_obj);
	if self.mode = self.Mode_Edit
	or self.mode = self.Mode_New then
	
		tmpTable := self.tblDataDetail;
		self.newIndex := self.newIndex + 1;
		bolOutLine :=	_obj.CMIF_BOLOutLine;
		rowIdx := tmpTable.rows;

		newCombo := self.addControlCmbCargoDetail(rowIdx, newIndex).CMUI_ComboBoxCargoTypeForTerm;
		newCombo.CMUI_ComboBoxCargoTypeForTerm.setObject(bolOutLine.myCargoType);
		
		//Load product control
		newCombo := self.addControlCmbProductDetail(rowIdx, newIndex).CMUI_ComboProduct;
		newCombo.CMUI_ComboProduct.myCargoType := bolOutLine.myCargoType;
		newCombo.CMUI_ComboProduct.setObject(bolOutLine.myProduct);

		// load item 		
		newCombo := self.addControlCmbItem(rowIdx, newIndex).CMUI_ComboBox;

		if bolOutLine.myTrackedItem &lt;&gt; null then 
			strId := bolOutLine.myTrackedItem.id;
		endif;
		
		if bolOutLine.myProduct &lt;&gt; null then  
			//self.myAssistant.comboBoxTIsByProduct(newCombo, bolOutLine.myProduct, strId); 	
			self.maintainIDCombos(null);
		else 
			if bolOutLine.myCargoType &lt;&gt; null then 
				intCargoTypeId := bolOutLine.myCargoType.id;
			endif;
			self.myAssistant.comboBoxTrackedItemToPack(newCombo,intCargoTypeId ,TI_STATE_NORMAL,strId);		
		endif;

		tmpTable.accessRow(rowIdx).itemObject := bolOutLine;
		self.setTblDataDetailCells(rowIdx);
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObjectsForHaveOpTerm" id="b9344520-d19f-4962-aa77-4cc4d6306ec4">
        <source>addObjectsForHaveOpTerm(_opTerm : CM_OperatorTerminal) protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:  
//18 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support   
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter					: Iterator;
	bol						: CM_BOL;
	bolByStatusDict			: CM_BOLByTypeStatusNumDTDict;
	filtFromDT,
	filtToDT,
	startDT,
	refDateKey				: TimeStamp;
	bolNumFilt,
	bolNumberKey			: String;
	numFound,
	numSearched,
	bolTypeKey,
	statusFilt,
	statusKey				: Integer;
	breakOut,
	haveValidToDT,
	haveValidFromDT			: Boolean;
	tbl						: CM_DataTable;
	passport				: CM_Passport;
	filtStringIsInteger		: Boolean;

begin
	passport := app.myPassport;
	tbl := self.tblDataMaster;
	bolNumFilt := self.filtDocketNumber;
	statusFilt := self.filtStatus;
	
	if self.filtDateFrom.isValid then
		filtFromDT := self.filtDateFrom.TimeStamp;
		haveValidFromDT := true;
	endif;
	
	if self.filtDateTo.isValid then
		filtToDT := self.filtDateTo.TimeStamp;
		filtToDT.setTime('23:59:59:999'.Time);
		haveValidToDT := true;//saves a .isValid while iterating which is slower than evaluating a local boolean
	endif;
	
	//18 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtFromDT := self.localToSystemTime(filtFromDT);
	filtToDT := self.localToSystemTime(filtToDT);
	
	filtStringIsInteger := bolNumFilt.isInteger;
	bolByStatusDict := _opTerm.allBOLByTypeStatusNumber;
	iter := bolByStatusDict.createIterator;
	
	bolByStatusDict.startKeyGeq(BOLType_GeneralDocket, statusFilt, bolNumFilt, filtFromDT, iter);
	while iter.next(bol) do
		bolByStatusDict.getIteratorKeys(bolTypeKey, statusKey, bolNumberKey, refDateKey, iter);
		
		if statusFilt &lt;&gt; null and
		   statusFilt &lt;&gt; statusKey then
			break;
		endif;
		
		if (not filtStringIsInteger) and bolNumberKey.keyOutOfRange(bolNumFilt, true) then
			break;
		endif;
		
		if (not bolNumberKey.startsWith(bolNumFilt)) then
			continue;
		endif;
		
		if haveValidFromDT then
			if refDateKey &lt; filtFromDT then
				continue;
			endif;
		endif;
		
		if haveValidToDT then
			if refDateKey &gt; filtToDT then
				continue;
			endif;
		endif;
		
		numSearched := numSearched + 1;
		if (not self.includeObject(bol, passport)) then	
			continue;
		endif;
		
		numFound := numFound + 1;
		self.addObjectToMasterTable(tbl, bol, numSearched, numFound, breakOut);
		
		if breakOut then
			break;
		endif;
		
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_opTerm" type="CM_OperatorTerminal"/>
    </JadeMethod>
    <JadeMethod name="addObjectsForHaveTerminal" id="f2c2f5f2-9a97-43c6-99a7-82187b81bc54">
        <source>addObjectsForHaveTerminal(_terminal : CM_Terminal) protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter					: Iterator;
	bolOut					: CM_BOLOut;
	bolByStatusDict			: CM_BOLOutByTypeStatusDTNumDict;
	filtFromDT,
	filtToDT,
	startDT,
	refDateKey				: TimeStamp;
	bolNumFilt,
	bolNumberKey			: String;
	startPos,
	numFound,
	numSearched,
	bolTypeKey,
	statusFilt,
	statusKey				: Integer;
	breakOut,
	haveValidToDT,
	haveValidFromDT			: Boolean;
	tbl						: CM_DataTable;
	passport				: CM_Passport;
	filtStringIsInteger		: Boolean;
begin
	passport := app.myPassport;
	tbl := self.tblDataMaster;
	bolNumFilt := self.filtDocketNumber;
	statusFilt := self.filtStatus;
	
	if self.filtDateFrom.isValid then
		filtFromDT := self.filtDateFrom.TimeStamp;
		haveValidFromDT := true;
	else
		filtFromDT := null;
	endif;
	
	if self.filtDateTo.isValid then
		filtToDT := self.filtDateTo.TimeStamp;
		filtToDT.setTime('23:59:59:999'.Time);
		haveValidToDT := true;//saves a .isValid while iterating which is slower than evaluating a local boolean
	else
		filtToDT := null;
	endif;
	
	//18 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtFromDT := self.localToSystemTime(filtFromDT);
	filtToDT := self.localToSystemTime(filtToDT);
	
	filtStringIsInteger := bolNumFilt.isInteger;
	bolByStatusDict := _terminal.allBOLsReleasedByTypeStatDTNum;
	iter := bolByStatusDict.createIterator;
	
	bolByStatusDict.startKeyGeq(BOLType_GeneralDocket, statusFilt, filtFromDT, bolNumFilt, iter);

	while iter.next(bolOut) do
		bolByStatusDict.getIteratorKeys(bolTypeKey, statusKey, refDateKey, bolNumberKey, iter);
		
		if statusFilt &lt;&gt; null and
		   statusFilt &lt;&gt; statusKey then
			break;
		endif;
		
		if haveValidFromDT then
			if refDateKey &lt; filtFromDT then
				continue;
			endif;
		endif;
		
		if haveValidToDT then
			if refDateKey &gt; filtToDT then
				continue;
			endif;
		endif;
		
		if (not filtStringIsInteger) and bolNumberKey.keyOutOfRange(bolNumFilt, true) then
			break;
		endif;
		
		if (not bolNumberKey.startsWith(bolNumFilt)) then
			continue;
		endif;
		
		numSearched := numSearched + 1;
		if (not self.includeObject(bolOut, passport)) then	
			continue;
		endif;
		
		numFound := numFound + 1;
		self.addObjectToMasterTable(tbl, bolOut, numSearched, numFound, breakOut);
		
		if breakOut then
			break;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="addObjectsForHaveVoyage" id="e905fef7-3fbb-478c-a7a5-7b2156395ce3">
        <source>addObjectsForHaveVoyage(_voyage : CM_Voyage) protected;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter					: Iterator;
	bolOut					: CM_BOLOut;
	bolByStatusDict			: CM_BOLOutByTypeStatusNumDTDict;
	filtFromDT,
	filtToDT,
	startDT,
	refDateKey				: TimeStamp;
	bolNumFilt,
	bolNumberKey			: String;
	numFound,
	numSearched,
	bolTypeKey,
	statusFilt,
	statusKey				: Integer;
	breakOut,
	haveValidToDT,
	haveValidFromDT			: Boolean;
	tbl						: CM_DataTable;
	passport				: CM_Passport;
	filtStringIsInteger		: Boolean;
begin
	passport := app.myPassport;
	tbl := self.tblDataMaster;
	bolNumFilt := self.filtDocketNumber;
	statusFilt := self.filtStatus;
	
	if self.filtDateFrom.isValid then
		filtFromDT := self.filtDateFrom.TimeStamp;
	endif;
	
	if self.filtDateTo.isValid then
		filtToDT := self.filtDateTo.TimeStamp;
		filtToDT.setTime('23:59:59:999'.Time);
		haveValidToDT := true;//saves a .isValid while iterating which is slower than evaluating a local boolean
	endif;
	
	//18 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtFromDT := self.localToSystemTime(filtFromDT);
	filtToDT := self.localToSystemTime(filtToDT);
	
	filtStringIsInteger := bolNumFilt.isInteger;
	bolByStatusDict := _voyage.allBOLOutByTypeStatusNumDT;
	iter := bolByStatusDict.createIterator;
	
	bolByStatusDict.startKeyGeq(BOLType_GeneralDocket, statusFilt, bolNumFilt, filtFromDT, iter);
	while iter.next(bolOut) do
		bolByStatusDict.getIteratorKeys(bolTypeKey, statusKey, bolNumberKey, refDateKey, iter);
		
		if statusFilt &lt;&gt; null and
		   statusFilt &lt;&gt; statusKey then
			break;
		endif;
		
		if bolNumberKey.keyOutOfRange(bolNumFilt, true) then
			break;
		endif;
		
		if (not filtStringIsInteger) and bolNumberKey.keyOutOfRange(bolNumFilt, true) then
			break;
		endif;
		
		if haveValidToDT then
			if refDateKey &gt; filtToDT then
				break;
			endif;
		endif;
		
		numSearched := numSearched + 1;
		if (not self.includeObject(bolOut, passport)) then	
			continue;
		endif;
		
		numFound := numFound + 1;
		self.addObjectToMasterTable(tbl, bolOut, numSearched, numFound, breakOut);
		
		if breakOut then
			break;
		endif;
		
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="12c83fef-ee13-4208-ada1-110bdf333a27">
        <updating/>
        <source>addObjectsToTable(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	opTerm			: CM_OperatorTerminal;
	
begin
	if CM_NullOperator.hasInstance(self.myFiltOperator) then
		self.myFiltOperator := null;
	endif;
	
	if self.myFiltVoyage &lt;&gt; null then
		self.addObjectsForHaveVoyage(self.myFiltVoyage);

	elseif self.myFiltOperator &lt;&gt; null then
		opTerm := self.myFiltOperator.allOperatorTerminals[self.myTerminal];
		if opTerm &lt;&gt; null then
			self.addObjectsForHaveOpTerm(opTerm);
		endif;
		
	else
		self.addObjectsForHaveTerminal(self.myTerminal);
	endif;

	self.tblDataMaster.colourRows(self.colorRow1, self.colorRow2);
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addProxyObjectToDetailTable" id="1ffb208b-fdcf-491c-9a04-41a7946a1a30">
        <updating/>
        <source>addProxyObjectToDetailTable(_tbl: CM_DataTable input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rowIdx : Integer;
	tmpTable : CM_DataTable;
	rowArray : EntTableRowArray;
	newCombo : CMUI_ComboBoxObject;
	newCmb : CMUI_ComboBox;
	assist : CMUI_Assistant;
	bolOutLine : CMIF_BOLOutLine;
	intCargoTypeId	: Integer;
	strId 		: String;
begin
	inheritMethod(_tbl, _obj);
	if self.mode = self.Mode_Edit
	or self.mode = self.Mode_New then
	
		//Add controls for update mode - 
		tmpTable := self.tblDataDetail;
		self.newIndex := self.newIndex + 1;
		bolOutLine :=	_obj.CMIF_BOLOutLine;
		rowIdx := tmpTable.rows;

		//Load cargotype control
		newCombo := self.addControlCmbCargoDetail(rowIdx, newIndex).CMUI_ComboBoxCargoTypeForTerm;
		newCombo.setObject(bolOutLine.myCargoType);

		//Load product control
		if self.colProduct &gt; 0 then
			newCombo := self.addControlCmbProductDetail(rowIdx, newIndex).CMUI_ComboProduct;
			newCombo.CMUI_ComboProduct.setCargoType(bolOutLine.myCargoType); 
			newCombo.CMUI_ComboProduct.setObject(bolOutLine.myProduct);
		endif;

		// load item 		
		newCmb := self.addControlCmbItem(rowIdx, newIndex).CMUI_ComboBox;

		if bolOutLine.myTrackedItem &lt;&gt; null then 
			strId := bolOutLine.myTrackedItem.id;
		endif;
		
		if bolOutLine.myProduct &lt;&gt; null then  
			//self.myAssistant.comboBoxTIsByProduct(newCmb, bolOutLine.myProduct, strId); 	
			self.maintainIDCombos(null);
			if bolOutLine.myTrackedItem &lt;&gt; null then 
			// it is a stock order with item allocation being added. Need to add item to combo as above 
			// myAssistant.comboBoxTIsByProduct will not add it due to the item being associated with this stock order.
				newCmb.itemObject[newCmb.addItem(strId)] := bolOutLine.myTrackedItem;
				newCmb.text := strId; // will want this one selected then.
			endif;	
		else 
			if bolOutLine.myCargoType &lt;&gt; null then 
				intCargoTypeId := bolOutLine.myCargoType.id;
			endif;
			
			self.myAssistant.comboBoxTrackedItemToPack(newCmb,intCargoTypeId ,TI_STATE_NORMAL,strId);		
		endif;

		tmpTable.accessRow(rowIdx).itemObject := bolOutLine;
		self.setTblDataDetailCells(rowIdx);		
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
