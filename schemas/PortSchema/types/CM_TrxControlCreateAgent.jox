    <JadeMethod name="trxCreateTIRequestForJob" id="1f540b58-4811-44cb-9caf-91bd37d4eb97">
        <updating/>
        <source>trxCreateTIRequestForJob(	_job : CM_Job input; 
							_ti : CM_TrackedItem input;
							_isReceipt : Boolean;
							_quantity : Integer;
							_weight : Decimal;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
07 July 2014	cnwer1	Initial creation PAR 34466

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	// Start the transaction
	beginTransaction;

	// Perform the operation
	self.raiseExceptionIfNull(_job,"Job");
	self.raiseExceptionIfNull(_ti,"Cargo");
	
	if _passport.hasErrors then
		return;
	endif;
	
	_job.addJobRequest(_ti,_isReceipt,_quantity,_weight,_passport);
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
