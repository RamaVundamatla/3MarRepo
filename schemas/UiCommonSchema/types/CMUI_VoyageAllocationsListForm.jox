/*
Date		    Who			Reason
12 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	
begin
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then 
