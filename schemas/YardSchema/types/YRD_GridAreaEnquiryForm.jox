	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="handlePosFrameViewMouseMove" id="2247ce49-0a00-4de7-b3e7-83c25a911d86">
        <updating/>
        <source>handlePosFrameViewMouseMove(frame: CMUI_MoveableFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theScale,
	tmpLeft,
	tmpTop	: Real;
	theX, 
	theY 	: Integer;
begin
	theScale := self.positionScaleX;
	
	tmpLeft := frame.left;
	tmpTop := frame.top;
	
	if tmpLeft &lt; 0 then
		tmpLeft := 0;
	elseif tmpLeft &gt; frame.parent.width then
		tmpLeft := frame.parent.width;
	endif;
	
	if tmpTop &lt; 0 then
		tmpTop := 0;
	elseif tmpTop &gt; frame.parent.height then
		tmpTop := frame.parent.height;
	endif;
	
	theX := (tmpLeft * theScale).Integer;
	theY := (tmpTop * theScale).Integer;
	
	self.dkbGridArea.scrollTo(theX, theY);
	
end;</source>
        <access>protected</access>
        <Parameter name="frame" type="CMUI_MoveableFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
