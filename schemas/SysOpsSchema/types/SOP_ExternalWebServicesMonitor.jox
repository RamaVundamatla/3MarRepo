        <source>btnDetails_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 10/10/2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
vars

begin
	//jlier1 TFS 56856 30/3/23
	if self.cmbInterfaceName.listObject &lt;&gt; null and self.cmbInterfaceName.listObject.isKindOf(CM_ExternalWebServiceDef) then
		self.myAssistant.showTableMaintForm(self.cmbInterfaceName.listObject.CM_ExternalWebServiceDef , self.myMasterMenuAction, true, false);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
