<Class name="CMQF_RailRakeClear" id="9dc50fdc-2718-4549-8a4f-1e2b3210c3e5">
    <superclass name="CMQF_TrackedItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="myTrain" id="7ecb51d0-09ce-4c01-a69f-a9757d063bb5">
        <embedded/>
        <type name="CM_Train"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="filterObjects" id="db1b9b32-203f-44dc-9879-b93eaecb6bc8">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwmd1	Initial creation

*/

vars
	train : CM_Train;
	tis : CM_TIArray;
	qryParam	: CM_QueryReportParam;
begin
	create tis transient;
	train := self.getMyTrain;
	
	if train = null then
		return;
	endif;
	
	train.getAllTrackedItems(false, tis);
	
	tis.copy(_collection);
	
	create qryParam transient;
	qryParam.setProxy("InwardOutward", "InwardOutward", false, String.number, "Outward");
	self.allQueryReportParams.add(qryParam);
	
	create qryParam transient;
	qryParam.setProxy("TrainName", "TrainName", false, String.number, train.description);
	self.allQueryReportParams.add(qryParam);
epilog
	delete tis;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects_old" id="39b94c63-49e9-4184-933b-4788db7e7506">
        <updating/>
        <source>filterObjects_old(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	17 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	terminal	: CM_Terminal;
	ta			: CM_TerminalArea;
	rail		: CM_Rail;
	railLine	: CM_RailLine;
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
	tiArray		: CM_TIArray;
begin
	create tiArray transient;
	foreach terminal in self.allTerminals do
		foreach ta in terminal.allTerminalAreasByTypeId discreteLock where ta.type = TA_TYPE_RAILWAY_TRACK do
			
			tiArray.clear;		
			if CM_Rail.hasInstance(ta) then
				rail := ta.CM_Rail;
				foreach railLine in rail.allRailLines do
					railLine.getAllTrackedItems(tiArray);
					if breakOut then
						return;
					endif;
				endforeach;
			endif;
			
			//wont be thousands - can take this hit
			foreach ti in tiArray do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
//				if breakOut then
//					return;
//				endif;
			endforeach;
			
		endforeach;
	endforeach;	

epilog
	delete tiArray;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyTrain" id="844a39be-d933-457a-a60b-1443c39b9078">
        <source>getMyTrain():CM_Train;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	train : CM_Train;
	edition : Integer;
	invalidObj : Boolean;

begin

	train := self.myTrain;

	if train = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, train, invalidObj );
	edition := train.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return train;

epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="3b3dd782-6fb7-4a1e-bd0d-6b2d15678eec">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	17 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrain" id="d0c96d7a-0b04-4e02-8bee-c97c3835ca9b">
        <updating/>
        <source>setMyTrain( _train : CM_Train ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myTrain := _train;

epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
