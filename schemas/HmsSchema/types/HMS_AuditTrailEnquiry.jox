    <JadeMethod name="populateAuditEnquirySearcher" id="4e870de3-7e0a-4f06-a7df-95d0319be7c1">
        <updating/>
        <source>populateAuditEnquirySearcher() updating;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
// 24/5/16	cnwmp6	TFS 488 - Multi timezone support
//-----------------------------------------
vars
	listCnt,
 	count			: Integer;
 	obj				: Object;
	searchStartDT	: TimeStamp;
	searchEndDT		: TimeStamp; 	
	localStartDT	: TimeStamp;
	localEndDT		: TimeStamp;
	
begin
	// Clear collections
	self.myAuditEnquirySearcher.allFoundTransactions.clear();
	self.myAuditEnquirySearcher.allSelectedTerminals.clear();
	self.myAuditEnquirySearcher.allSelectedTransactionTypes.clear();
	self.myAuditEnquirySearcher.allSelectedUsers.clear();
	self.myAuditEnquirySearcher.allSelectedVessels.clear();
	
	// Get start and finish DT's
	if optLoggedAfter.value then
// cnwdad1 17/06/2009 - PAR #19942.
		//self.myAuditEnquirySearcher.startDateTime := (txtAfterDate.text &amp; "," &amp; txtAfterTime.text).TimeStamp;
		localStartDT.setDate(txtAfterDate.getDate());
		localStartDT.setTime(txtAfterTime.getTime());
		
		self.myAuditEnquirySearcher.startDateTime := self.localToSystemTime(localStartDT);
		self.myAuditEnquirySearcher.endDateTime := null;
	elseif optLoggedBefore.value then
		self.myAuditEnquirySearcher.startDateTime := null;
// cnwdad1 17/06/2009 - PAR #19942.
		//self.myAuditEnquirySearcher.endDateTime := (txtBeforeDate.text &amp; "," &amp; txtBeforeTime.text).TimeStamp;
		localEndDT.setDate(txtBeforeDate.getDate());
		localEndDT.setTime(txtBeforeTime.getTime());
		
		self.myAuditEnquirySearcher.endDateTime := self.localToSystemTime(localEndDT);
	else
// cnwdad1 17/06/2009 - PAR #19942.
//		searchStartDT := (txtBtwDateA.text &amp; "," &amp; txtBtwTimeA.text).TimeStamp;
//		searchEndDT := (txtBtwDateB.text &amp; "," &amp; txtBtwTimeB.text).TimeStamp;
		localStartDT.setDate(txtBtwDateA.getDate());
		localStartDT.setTime(txtBtwTimeA.getTime());
		searchStartDT := self.localToSystemTime(localStartDT);
		localEndDT.setDate(txtBtwDateB.getDate());
		localEndDT.setTime(txtBtwTimeB.getTime());
		searchEndDT := self.localToSystemTime(localEndDT);
		
		if searchStartDT &lt; searchEndDT then
			self.myAuditEnquirySearcher.startDateTime := searchStartDT;
			self.myAuditEnquirySearcher.endDateTime := searchEndDT;	
		else
			self.myAuditEnquirySearcher.startDateTime := searchEndDT;
			self.myAuditEnquirySearcher.endDateTime := searchStartDT;
			txtBtwDateA.setDate(localEndDT.Date);
			txtBtwDateB.setDate(localStartDT.Date);				
		endif;			
	endif;
	
	listCnt := lbxFiltersApplied.listCount;
	count := count+1;
	
	while count &lt;= listCnt do

		obj := lbxFiltersApplied.itemObject[count];
		if obj = null then
			count := count+1;		
			continue;
		endif;
		
		// Add selected terminal
		if CM_Terminal.hasInstance(obj) then
			// Add to selectedUsers coll
			self.myAuditEnquirySearcher.allSelectedTerminals.add(obj.CM_Terminal);
		endif;
	
		// Add selected users
		if CM_User.hasInstance(obj) then
			// Add to selectedUsers coll
			self.myAuditEnquirySearcher.allSelectedUsers.add(obj.CM_User);
		endif;

		// Add selected ships
		if CM_Vessel.hasInstance(obj) then
			// Add to selectedShips coll
			self.myAuditEnquirySearcher.allSelectedVessels.add(obj.CM_Vessel);
		endif;

		// Add selected transaction types
		if HMS_Transaction.hasInstance(obj) then
			// Add to selectedTransTypes coll
			self.myAuditEnquirySearcher.allSelectedTransactionTypes.add(lbxFiltersApplied.itemData[count].Integer);
		endif;
		count := count+1;
	endwhile;
	
	if self.myAuditEnquirySearcher.allSelectedTerminals.isEmpty then
		self.myAuditEnquirySearcher.allSelectedTerminals.add(self.myTerminal);
	endif;
	
	if self.myHarbour &lt;&gt; null then
		self.myHarbour.getHMSTransForAuditEnquiry(self.myAuditEnquirySearcher, app.myPassport);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateResultsTable" id="f937671e-5127-4d54-be76-badf83bbd65f">
        <updating/>
        <source>populateResultsTable() updating;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
	transaction		: HMS_Transaction;
	iter			: Iterator;
	tmpStr			: String;
	tmpTable		: CM_DataTable;
begin
	app.mousePointer := MousePointer_HourGlass;
	// This method loads the transaction into the table according to the search criteria
	self.tblDetails.rows := self.tblDetails.fixedRows;
	tmpTable := self.tblResults;
    tmpTable.rows := tmpTable.fixedRows;

	iter := self.myAuditEnquirySearcher.allFoundTransactions.createIterator();
	while iter.next(transaction) do
		// Add details to table
		tmpStr := transaction.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
		tmpTable.addItemObject(transaction, tmpStr);
	endwhile;

	tmpTable.colourRows(self.colorRow1, self.colorRow2);

epilog
	delete iter;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="fea9742b-aa6d-4dac-96aa-465196f6a47d">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------------------
//Created: 31 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.fldCriteria.backColor := self.backColor;
	self.fldMain.backColor := self.backColor;
