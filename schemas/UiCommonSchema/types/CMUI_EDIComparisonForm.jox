    <JadeMethod name="setEntTableRowsForDBItem" id="37ae26a1-f921-4503-b5e9-8dd0693bacc6">
        <source>setEntTableRowsForDBItem(_ediColl :EntTableRowArray; _dbColl :EntTableRowArray input) protected;
/*
Date		Who		Reason
01 August 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	etRow, etRowDB, etRowDummy	:EntTableRow;
begin
	self.allEntTableRowsForDBItem.purge;
	
	foreach etRow in _ediColl do
		// we are going to clone the EDI row and then change the property name
		etRowDB := etRow.cloneSelfAs (EntTableRowProxy, true).EntTableRowProxy; 
		
		etRowDB.EntTableRowProxy.setFromRealObject (etRow);
		etRowDB.EntTableRowProxy.setBasicDetails (self.getDBNameForEDIRow (etRow.name), etRow.getRawHeadingValue, etRow.inputType, etRow.visible);
		
		_dbColl.add (etRowDB);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediColl" type="EntTableRowArray"/>
        <Parameter name="_dbColl" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
