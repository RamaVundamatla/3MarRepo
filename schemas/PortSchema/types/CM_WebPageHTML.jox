<Class name="CM_WebPageHTML" id="346baa00-2cd5-4f67-8678-96806dd7d90c">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webclas"/>
    <PrimAttribute name="html" id="6bda52e2-763d-4891-a1db-2e06e3cb2015">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myWebSiteConfig" id="36c839dd-85f6-4a2b-b4be-2536717d1107">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_WebSiteConfig"/>
