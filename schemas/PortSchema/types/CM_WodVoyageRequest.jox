    <JadeMethod name="checkWODtlCanBeEdited" id="3f3d3756-0a8a-480e-b104-fd0d1d01c211">
        <source>checkWODtlCanBeEdited(): Boolean;
/*

Purpose:			TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.getMyVoyageObject();
	
	if voyage.isWorkOrderForVoyageCargo() then
		return false;
	endif;
	
	if voyage.isWorkOrderForIMSR() then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
