    <JadeMethod name="matchesBookingRef" id="c5aabf59-bfc2-41df-9584-9e5130c13fe8">
        <source>matchesBookingRef(_yaData: CM_YADataObjects): Boolean;

// dh par 17636 - added this as the inheritance of these checks in this hierarchy
// 				seems upside down - not sure if it is safe to fix it so instead will 
//				add this to avoid repeating code.
vars
	br : CM_BookingRef;
begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	if _yaData.matches(self.myTrackedItem.myBookingRef) then
		return true;
	endif;
	// dh added this third check for par 17636
	if self.myTrackedItem.myBookingRef = null // dh par 17636 29/7/2008 - just in case ti not yet attached to booking ref
	and self.myTrackedItem.bookingReference &lt;&gt; null then
		if self.myTerminal = null then
			return false;
		endif;
		br := self.myTerminal.getBookingReference(self.myTrackedItem.operatorCode, self.myTrackedItem.bookingReference.trimRight, self.myTrackedItem.myVoyage); // adm 150908 Par 17936		
		if _yaData.matches(br) then
			return true;
		endif;	
	endif;
	return false;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
