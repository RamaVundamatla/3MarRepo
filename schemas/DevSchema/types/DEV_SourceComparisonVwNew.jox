    <JadeMethod name="removeItemForIndex" id="a5df553f-a6d8-4e87-8b4b-49e0f707ef6e">
        <source>removeItemForIndex(_index : Integer; _listBox : ListBox) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	index,
	selLevel,
	level		: Integer;
begin
	//listBox := self.mnuLBContext.userObject.ListBox;
	listBox := _listBox;
	
	if listBox = null or _index &lt; 1 or _index &gt; listBox.listCount then
		app.raiseUnexpectedProgramError(class.name, method.name, "Invalid Item Index");
		return;
	endif;
	
	selLevel := listBox.itemLevel[_index];

	// Remove the selected item
	listBox.removeItem(_index);
	
	// Also remove the 'Header' items if this was the only subitem
	index := _index;
	level := selLevel;
	while index &gt; 1 do
		// If the one above us is at a lower level,
		// and the one below us (if it exists) is also at a lower level
		if listBox.itemLevel[index-1] &lt; level and (listBox.listCount &lt; index or listBox.itemLevel[index] &lt; level) then
			listBox.removeItem(index-1);
			index -= 1;
			level -= 1;
			continue;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_listBox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="resetData" id="cfe55b94-7bae-4e20-8d56-aeeb7fc95b1b">
        <source>resetData() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	
begin
	self.lblCurrLastModified.caption := "";
	self.lblLoadLastModified.caption := "";
	
	self.jeLoaded.text := "Double-click the results down the bottom to show detailed info";
	self.jeCurrent.text := "Double-click the results down the bottom to show detailed info";
	
	if app.myCnKarmaCntrl.environmentId[1:8].toUpper() = "NAVWMAST" then
		self.gbCurrent.caption := "Current (WMAST)";
		self.gbLoaded.caption := "Loaded (DMAST)";
	endif;
	
	//self.qlbMissingMethods.clear();
	//self.qlbGlobalConstants.clear();
	//self.qlbDifferentMethods.clear();
	//self.qlbClassData.clear();
	
	//self.qlbMissingMethods.refreshNow();
	//self.qlbGlobalConstants.refreshNow();
	//self.qlbDifferentMethods.refreshNow();
	//self.qlbClassData.refreshNow();
	
	//if self.differentClasses.size() &gt; 0 then
	//	self.differentClasses.purge();
	//endif;
	
	self.cmbSelectReport.sorted := false;
	
	self.loadReports();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
