    <JadeMethod name="setForCreate" id="20f221d0-7deb-4c77-b714-f8b943f10ee8">
        <updating/>
        <source>setForCreate( _proxy: CM_CashReceipt ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/07/2012	cnwndl1	Initial creation	Par 29968
06/01/2015	cnwdap1	PAR #37337 Create an invoice line and charges for any minimum charge proforma details
16/03/2016	cnwdap1	PAR #37543 There can be more than 1 minimum charge invoice line 
08/08/2017	jgldap1	TFS 5740 AAT Changes to Pro Forma Invoices
21/01/2019	jlgdap1	TFS 42925 PEL1 Container Services Estimation Approval Countdown
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	terminal				: CM_Terminal;
// TFS 38732 bank					: CM_Bank;
	debtor					: CM_Debtor;
	transientInvoiceLine,
	invoiceLine				: CM_InvoiceLine;
	invoice					: CM_Invoice;
	proformaDetails			: CM_ProformaDetails;
	cashInvoice				: CM_Invoice;
	cashInvoiceType			: CM_InvoiceDesc;
	trackedItem				: CM_TrackedItem;
	trx						: CM_TITransaction;
	chargedTIs				: CM_TISet;
	transientMinCharge		: CM_InvoiceLine;				// PAR #37337
	minChargeInvLine		: CM_InvoiceLine;				// PAR #37337
	minChargeCharge			: CM_Charge;					// PAR #37337
	now						: TimeStamp;					// PAR #37337
	seqNum, seqNum2			: Integer;						// PAR #37337
	service					: CM_Service;					// PAR #37337
	transientMinCharges		: CM_InvoiceLineBySeqNumDict;	// PAR #37543
	voyage : CM_Voyage; // TFS 37454
	finIO					: CM_ExtFinanceIO;
	canLogExtra				: Boolean;						//26.02.2025 navah1	#34141
begin
	
	canLogExtra	:= app.canLogExtraDetail();					//26.02.2025 navah1	#34141
	self.myBank := _proxy.pxyGetBank(); // TFS 38732 refactored bank to use bank on cargo, which is stored on invoice lines.
	
	

	inheritMethod(_proxy);		// this does setForUpdate
	
	create transientMinCharges transient;					// PAR #37543
	
	// 34555 this used to call setForUpdate which has already been done, so the internal number got incremented twice
	terminal := _proxy.getDebtorTerminal().myTerminal;
	// 32498 - create new invoice for cash payment
	_proxy.allTrackedItems.copy(self.allTrackedItems);
	
	
	// TFS 39236 cashInvoiceType := terminal.getConfig(CashInvoiceType).CM_InvoiceDesc;
	
	cashInvoiceType := _proxy.getCashInvoiceType(false); // TFS 39236
	
	// ### JIRA 34937 23MAY2025 NAVAB1
	if not app.isWebApp
	and not app.isJMTUnitTest then // ### JIRA 34937 06JUN2025 NAVAB1 failing UTs
		self.paymentStatus := CM_CashReceipt.PAID;  
	endif;
	
	// if a cash invoice type is configured, copy all of the existing invoice lines to a new invoice of this type
	//   and save the pro forma invoice lines against this new invoice, otherwise just copy the existing invoice lines as they are and do nothing with the pro formas.
	// proxy proforma invoice lines are transient - create persistent CM_ProformaDetails from them
	foreach transientInvoiceLine in _proxy.allProformaInvoiceLines do
		proformaDetails := transientInvoiceLine.createProformaDetail(self);
		self.allProformaDetails.add(proformaDetails);
		
		// PAR #37337 if the proforma details is for a "minimum charge" invoice line type, 		// PAR #37337
		// create a minimum charge invoice line 												// PAR #37337
		if transientInvoiceLine.invoiceLineDesc.isUsedAsMinimumCharge then						// PAR #37337
			//transientMinCharge := transientInvoiceLine;										// PAR #37337	// PAR #37543
			transientMinCharges.add(transientInvoiceLine);														// PAR #37543
		endif;																					// PAR #37337
	endforeach;

	// 34755 copy the invoice lines unconditionally so they're available for printing
	_proxy.allInvoiceLines.copy(self.allInvoiceLines);
	
	// TFS 5740 cash receipt proforma print subclass doesn't need anything after this	// TFS 5740
	if self.isCashReceiptProformaPrint then 											// TFS 5740
		// LOG CASH
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " CASH is isCashReceiptProformaPrint, RETURNING", LogINFO.String);
		endif;
		return;																			// TFS 5740
	endif;																				// TFS 5740

	if _proxy.allInvoiceLines.isEmpty and
	   _proxy.allTrackedItems.isEmpty and
	   _proxy.allProformaInvoiceLines.isEmpty then
		// advance payment, not cargo payment, don't create an invoice 33688
	else
	// create new invoice and move any invoice lines to it
	// 36529 for ADP always create a cash invoice for every receipt as the cash receipt number is the invoice external number
	// 36476 done as an option, 30/05/2016 from TFS 1990 testing add the test for cash invoice type being configured
		if cashInvoiceType &lt;&gt; null then
			if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
				debtor := self.getDebtorTerminal().myDebtor;
				// TFS 38732 bank := cashInvoiceType.company;
				create invoice;
				invoice.initialise(self.myBank, cashInvoiceType, debtor, null, false, self.paymentType);	// no transaction, not _forcedStatusOpen
				self.setCashInvoice(invoice);
				invoice.setCashReceipt(self);
			else
				if self.allTrackedItems.isEmpty() then // TFS 37454
						voyage := self.myVoyage;
						cashInvoice := voyage.getCashInvoice();
						if cashInvoice = null then
							debtor := self.getDebtorTerminal().myDebtor;
							// TFS 38732 bank := cashInvoiceType.company;
							create invoice;
							invoice.initialise(self.myBank, cashInvoiceType, debtor, null, false, self.paymentType);	// no transaction, not _forcedStatusOpen
							self.setCashInvoice(invoice);
							invoice.setCashReceipt(self);
							invoice.setVoyage(voyage);
						endif;
				
				else
					foreach trackedItem in self.allTrackedItems do
						cashInvoice := trackedItem.getCashInvoice();
						if cashInvoice &lt;&gt; null then
							continue;
						endif;
						debtor := self.getDebtorTerminal().myDebtor;
						// TFS 38732 bank := cashInvoiceType.company;
						create invoice;
						invoice.initialise(self.myBank, cashInvoiceType, debtor, null, false, self.paymentType);	// no transaction, not _forcedStatusOpen
						self.setCashInvoice(invoice);
						invoice.setCashReceipt(self);
						break;
					endforeach;
				endif;			endif;
		endif;
	
		/* TFS 48127 JLGAB1 move this code to processing of the cash payments (CM_CashPayment::setForUpdate)
			JLGAB1 this code moves ALL invoice lines that are for a cash debtor but on a non cash invoice to the first cash invoice for this cargo.
			JLGAB1	However for subsequent cash receipts that pick up further invoice lines for a cash debtor but on a non cash invoice,
						they are not moved to any cash invoice at all. They are left on their 'credit' invoice type
			JLGAB1 These invoice lines are joined to a cash payment the invoice line should be on the same cash invoice as the payment ALWAYS
			
	// 33885 do this per cargo item - some may have been paid from a prior receipt and already have a cash invoice
		if invoice &lt;&gt; null then			// null test added from TFS 1990 testing
			foreach trackedItem in self.allTrackedItems do
				cashInvoice := trackedItem.getCashInvoice();
					if cashInvoice &lt;&gt; null then
						continue;
					endif;
		// TFS 1990 24/05/2016 get the invoice lines from the tracked item not transactions to get those copied from split/merged items
						foreach invoiceLine in trackedItem.invoiceLines where invoiceLine.debtor.isCashOnlyDebtor(terminal) do
							if invoiceLine.voided or
							   invoiceLine.invoice.isPosted then		// 36529 don't move posted invoice lines
								continue;
							endif;
							invoiceLine.moveLineToInvoice(invoice);
						endforeach;
			endforeach;
		endif;
		TFS 48127 */

		
		// PAR #37337 do we need to create a minimum charge invoice line						// PAR #37337
		//if transientMinCharge &lt;&gt; null then													// PAR #37337	// PAR #37543
		foreach transientMinCharge in transientMinCharges do													// PAR #37543
			create minChargeInvLine persistent;													// PAR #37337
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 						// PAR #37337
			minChargeInvLine.setForCreate(	seqNum, false, transientMinCharge.remarks,			// PAR #37337 
											transientMinCharge.invoiceLineDesc, invoice, 		// PAR #37337
											self.getDebtor, self.myBank, 1, now	);				// PAR #37337
			create minChargeCharge persistent;													// PAR #37337
			seqNum2 := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE);							// PAR #37337
			if not transientMinCharge.invoiceLineDesc.services.isEmpty then						// PAR #37337
				service := transientMinCharge.invoiceLineDesc.services.first;					// PAR #37337
			endif;																				// PAR #37337
			minChargeCharge.setForCreate(null, minChargeInvLine, seqNum2, service);				// PAR #37337
			minChargeCharge.total := transientMinCharge.lineTotal;								// PAR #37337
			minChargeCharge.isTotalSetExplicitly := true;										// PAR #37337
			minChargeCharge.setRateForMinMax(minChargeCharge.total);							// PAR #37337
			
			minChargeInvLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well
		//endif;																				// PAR #37337	// PAR #37543
		endforeach;																								// PAR #37543
	endif;
	if self.externalInvoiceNumber = null and					// 7/9/18 MAP TFS40723
		not self.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then //11/07/2024	navkc1 CR 64839 Task 64856 - When it's draft, dont generate external receipt number, as it might get deleted and we don't want a gap between them
		finIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIO &lt;&gt; null then
			self.externalInvoiceNumber := finIO.getExternalReciptNumber(self);				// +TFS38181 
			
			// LOG CASH
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " CASH RECEIPT CREATION  externalInvoiceNumber : " &amp; self.externalInvoiceNumber, LogINFO.String);
			endif;
		endif;
	endif;
	
	self.doSAPRequestWOTimer();					// TFS 42925
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if self.requiresBGPRequestForStatus() then
		self.doBGPAdvanceRequest();
	endif;
	
epilog
	delete chargedTIs;
	delete transientMinCharges;					// PAR #37543
end;</source>
        <Parameter name="_proxy" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1b54a03d-c309-490f-b4b5-7b05d87e208b">
        <updating/>
        <source>setForUpdate( _proxy: CM_CashReceipt ) updating;

/*

Purpose:			Update the base CM_CashReceipt properties

Parameters:			

Return Value:		


Date		Who		Reason
18 Jul 2012	cnwndl1	Initial creation	Par 29968
16 Nov 2016 cnwma1	TF #2985:PAR38341 QNS - Changes to existing Oracle R12 Interface for Hamad port multi terminal go-live (JMT changes)
08 Aug 2017	jgldap1	TFS 5740 AAT Changes to Pro Forma Invoices
26 Nov 2019 cnwma1  Bug 47681: PIBT - Unable to save receipts
*/

vars

begin

	inheritMethod(_proxy);

	self.chequeBank	  		    := _proxy.chequeBank;
	self.chequeBranch		    := _proxy.chequeBranch;
	self.chequeNumber 		    := _proxy.chequeNumber;
	self.chequeDate  		    := _proxy.chequeDate;
	self.cashId1 	  		    := _proxy.cashId1;
	self.cashId2 	  		    := _proxy.cashId2;
	self.cashId3 	  		    := _proxy.cashId3;
	self.cashId4 	 		    := _proxy.cashId4;
	self.cashPayment1		    := _proxy.cashPayment1;
	self.cashPayment2 		    := _proxy.cashPayment2;
	self.effectiveDate		    := _proxy.effectiveDate;
	self.externalInvoiceNumber  := _proxy.externalInvoiceNumber;
	self.externalReceiptNumber  := _proxy.externalReceiptNumber;
	self.cashAllocationRequired := _proxy.cashAllocationRequired;
	self.cashAlreadyAllocated   := _proxy.cashAlreadyAllocated;
	self.cashPaymentRequired 	:= _proxy.cashPaymentRequired;
	self.totalCargoCharges 	    := _proxy.totalCargoCharges;
	self.myVoyage 			    := _proxy.myVoyage;
	self.myAgent 				:= _proxy.myAgent;
	self.myWorkOrder 			:= _proxy.myWorkOrder; 				   // TFS 38524
	self.myUser 				:= _proxy.myUser;
	self.myPaymentMethod 		:= _proxy.myPaymentMethod;
	self.sequenceNum 			:= 0;								   // 34277 handle change of debtor/terminal and sequence
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	self.externalFinancialId	:= _proxy.externalFinancialId;
	self.externalRef1 			:= _proxy.externalRef1;
	self.externalTransaction	:= _proxy.externalTransaction;
	self.externalUserCode 		:= _proxy.externalUserCode;
	self.remarks				:= _proxy.remarks;
	self.paymentStatus			:= _proxy.paymentStatus;
	
	//11/07/2024	navkc1 CR 64837 Task 64851 - For draft cash receipt from Cash API, we use OID as the SeqNum temporarily.
	if self.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
		//self.sequenceNum := self.cnGetInstanceId(self);//02/08/2024	navkc1 CR 65382 Task 65394
		self.sequenceNum := _proxy.getNextDraftSeqNum(); //02/08/2024	navkc1 CR 65382 Task 65394
	else
		if _proxy.sequenceNum = 0 then                                 //26.11.2019 cnwma1 #47681
	//	TFS 47985	self.sequenceNum := _proxy.myDebtorTerminal.getNextRecSeqNum;
			self.sequenceNum := _proxy.getNextRecSeqNum(); //	TFS 47985
		else
			self.sequenceNum := _proxy.sequenceNum;
		endif;
	endif;
	
	self.myDebtorTerminal 		:= _proxy.myDebtorTerminal;
	self.paymentType 			:= _proxy.paymentType;				 //09 Oct 2018	NDL	TFS 41281
	
	self.taxValue1 				:= _proxy.taxValue1;
	self.taxValue2 				:= _proxy.taxValue2;
	self.taxValue3 				:= _proxy.taxValue3;
	self.taxCode1 				:= _proxy.taxCode1;
	self.taxCode2 				:= _proxy.taxCode2;
	self.taxCode3				:= _proxy.taxCode3;
	self.shipReleaseDate 		:= _proxy.shipReleaseDate;			// 36457
	self.roundingDifference    := _proxy.roundingDifference;

	if not self.isCashReceiptProformaPrint then						// TFS 5740
		self.myTerminal := _proxy.myDebtorTerminal.myTerminal;
	endif;															// TFS 5740

epilog

end;</source>
        <Parameter name="_proxy" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateDebtor" id="c7ce6c12-c3eb-42e7-a626-a0a443675bd3">
        <updating/>
        <source>setForUpdateDebtor(_debtorTerminal : CM_DebtorTerminal input; 
								_agent : CM_Object; _comments : String) updating;
/*
Purpose:	TFS 46032		
Date				Who			Reason
AUGUST 2019		JLGAB1 initial creation
*/


vars
	cashPayment		: CM_CashPayment;
	cashInvoice		: CM_Invoice;
	invoiceLine		: CM_InvoiceLine;
	priorDebtor, newDebtor : CM_Debtor;
	priorName,
	newName			: String;
	audit			: CM_AuditLineDescChanged;
	nextSeq : Integer;
begin

	priorDebtor := self.myDebtorTerminal.myDebtor;
	newDebtor := _debtorTerminal.myDebtor;

	if priorDebtor &lt;&gt; newDebtor then	
		nextSeq := _debtorTerminal.getNextRecSeqNum();

		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);
		self.sequenceNum := 0;	// handle change of debtor/terminal and sequence
		self.myDebtorTerminal := _debtorTerminal;
		self.sequenceNum := nextSeq;
		self.myAgent :=_agent;
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);
		
		// update the debtor on the cash payments
		foreach cashPayment in self.allCashPayments do
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(cashPayment, true);
			cashPayment.setDebtorTerminal(_debtorTerminal);
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(cashPayment, false);
		endforeach;
	endif;
	
	
	cashInvoice := self.myCashInvoice;
	if cashInvoice &lt;&gt; null then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(cashInvoice, true);
		cashInvoice.narration := _comments[1:640];
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(cashInvoice, false);	

		if priorDebtor &lt;&gt; newDebtor then	
			cashInvoice.debtor :=  newDebtor;
			foreach invoiceLine in cashInvoice.invoiceLines do
				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoiceLine, true);
				invoiceLine.setDebtor(newDebtor);
				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoiceLine, false);
			endforeach;
		endif;															
	endif;
	
	
	if priorDebtor &lt;&gt; newDebtor then
		// audit this, re-using CM_AuditLineDescChanged to avoid needing to create a new audit class
		create audit persistent;
		audit.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT);
		audit.userId := app.getMyUserCode();
		audit.datetime := app.actualTimeServer;
		if priorDebtor &lt;&gt; null then
			priorName := priorDebtor.name;
		endif;
		if newDebtor &lt;&gt; null then
			newName := newDebtor.name;
		endif;
		
		audit.remarks :=app.getErrorString3(AUDIT_CASHRECEIPT_REMARKS,self.externalInvoiceNumber,priorName,newName);
		audit.auditedFOs.add(self);
	endif;

epilog

end;</source>
        <Parameter name="_debtorTerminal" type="CM_DebtorTerminal" usage="input"/>
        <Parameter name="_agent" type="CM_Object"/>
        <Parameter name="_comments" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyMatchingInvoice" id="9272784c-dacf-418c-9506-8d38ee5d5adb">
