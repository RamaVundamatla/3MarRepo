end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="moveLabel" id="a8fe7683-b0d2-494d-9dd8-ceee9d43ece9">
        <source>moveLabel( _label : CMUI_Label input; _topMMs : Real; _leftMMs : Real; _rightMMs : Real; _bottomMMs : Real ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	vTop : Real;
	vLeft : Real;
	vWidth : Real;
	vHeight : Real;

begin

	vTop := ( _topMMs + baseTopOffset ) * self.pixelsPerMM;
	vLeft := ( _leftMMs + baseLeftOffset ) * self.pixelsPerMM;
	vWidth := ( _rightMMs -_leftMMs ) * self.pixelsPerMM;
	vHeight := ( _bottomMMs -_topMMs ) * self.pixelsPerMM;

	_label.move( vLeft, vTop, vWidth, vHeight );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <Parameter name="_topMMs" type="Real"/>
        <Parameter name="_leftMMs" type="Real"/>
        <Parameter name="_rightMMs" type="Real"/>
        <Parameter name="_bottomMMs" type="Real"/>
    </JadeMethod>
    <JadeMethod name="populateLineUp" id="47c8bf02-9a55-4241-806e-b5c7c63f807c">
        <updating/>
        <source>populateLineUp():String protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	obj : Object;
	firstLabel : CMUI_Label;
	label : CMUI_Label;
	charWidth : Integer;
	charHeight : Integer;
	labelWidth : Real;
	labelHeight : Real;
	numChars : Integer;
	str : String;
	repDetails : String;

begin

	self.doingLineUp := true;

	repDetails := self.class.name &amp; "?DOT?"
					&amp; self.baseLeftOffset.String
					&amp; "?" &amp; self.baseTopOffset.String
					&amp; "?" &amp; app.printer.drawFontSize.String
					&amp; "?" &amp; app.printer.drawFontName;
					//&amp; "?" &amp; app.printer.getPrinterName;

	if self.allLabelsArray.isEmpty then
		return repDetails;
	endif;
	firstLabel := self.allLabelsArray.first.CMUI_Label;
	charWidth := firstLabel.getTextExtent( "X" );
	charHeight := firstLabel.getTextHeight( "X" );

	foreach obj in self.allLabelsArray do
		str := null;
		label := obj.CMUI_Label;
		labelWidth := label.width;
		labelHeight := label.height;
		numChars := ((labelWidth / charWidth).Integer + 1 ) * ((labelHeight / charHeight).Integer + 1 );
		while str.length &lt; numChars do
			str := str &amp; "X";
		endwhile;
		label.caption := str;
	endforeach;
	
	return repDetails;


epilog

end;</source>
        <access>protected</access>
