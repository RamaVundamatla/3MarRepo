<GUIClass name="JSSBaseReport" id="3ca01017-b504-4f5d-b058-878372da9698">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <Constant name="ERROR_TITLE" id="ef23b516-7a5f-4d60-9aa2-5945f2330177">
        <source>"Error"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="aError" id="bd4fc947-d698-472c-a7a6-f72f0d5b2598">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="aObjectEdition" id="ba2a860c-2d0f-4580-9470-cacd74b3d333">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="lblError" id="9c8d0d29-b3a0-4d91-967f-0f4a2cd97485">
        <embedded/>
        <type name="JSSLabel"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayError" id="dce0cafb-0200-4128-a674-80e7fbedf5bf">
        <updating/>
        <source>displayError() : Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 November 2001 by cnwdad1
//
// Purpose:		This method should be invoked after a transaction agent method has
//				been called, preferably from the epilog of the doFormUpdate()
//				method.
//
//				If an error has occurred, then this method will show a message box
//				with the error message, and then reset the form's error property.
//				Note that the form's error property should have been set by the
//				return value of the transaction agent method called that was by
//				the doFormUpdate() method.
//
//				A simple way to use this method would be to inherit the doFormUpdate()
//				method from the epilog of its subclass reimplementation.
//
// Parameters:	None
//
// Returns:		True if there was no error, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aError = null then
		return true;
	else
		app.msgBox(self.aError, self.ERROR_TITLE, MsgBox_Stop_Icon + MsgBox_OK_Only);
		self.aError	:=	null;
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="a63d44eb-8362-4443-b060-3389b8b562de">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that may be performed any number of times during the lifetime
//				of the form instance.  A typical example of this would be to populate
//				or initialize the form's controls, and to synchronize the object(s)
//				being dealt with and store off it's OID.
//
//				Note that this method is already invoked by the "load" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="9f7613d6-ffbb-445d-8d12-33d99a04b20b">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that should only be performed once during the lifetime of
//				the form instance.
//
//				Note that this method is already invoked by the "load" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="3eab159d-53de-43ca-950f-03b070b6d2cb">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that should only be performed when form instance is being
//				unloaded.
//
//				Note that this method is already invoked by the "unload" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="7b4d823f-ce8f-494e-8cc9-2b81b6720178">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to call
//				transaction agent methods.
//
//				The epilog of the reimplemented update method should either:
//
//					a) Return the value of the "displayError() method; or
//					b) Inherit the behaviour of this method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: Boolean;
	
begin
	returnValue	:=	self.displayError();
	
	if returnValue then
		self.doFormInitialize();
	endif;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="881b60b4-93f3-4253-bc9c-14d193b89db1">
        <updating/>
        <source>doFormValidate(pIsDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to validate
//				the form's contents, typically prior to calling a transaction agent
//				method from the doFormUpdate() method.
//
//				Note that the reimplementation of this method should not contain
//				buisiness rules pertaining to the persistence of data (such rules
//				should be implemented at the model level).
//
// Parameters:	None
//
// Returns:		True if the form's contents are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintReport" id="78fea398-3851-4f43-a9cf-75e360624251">
        <updating/>
        <source>doPrintReport():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				any printing.
//
// Parameters:	None
//
// Returns:		True if the report was successfully printed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssXHandler" id="5eb5bf0e-2036-47d8-b35d-6574a5b061a0">
        <source>jssXHandler(pTheException:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		Handler for exceptions raised by the printer class.  If the error
//				was not caused by the printer, then the handling is passed back to
//				the next handler in the stack.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorCode		: String;
	errorMessage	: String;
	theMethodCall	: MethodCallDesc;
	
begin
	theMethodCall	:=	pTheException.currentMethodDesc;
	
	if theMethodCall &lt;&gt; null then
		if theMethodCall.method.schemaType = Printer then
			abortTransaction;
			
			errorCode		:=	pTheException.errorCode.String;
			errorMessage	:=	pTheException.errorItem;
			
			if errorMessage = null then
				errorMessage	:=	app.printer.jssTranslateConstant(errorCode.Integer);
			endif;
			
			if pTheException.extendedErrorText &lt;&gt; null then
				errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; pTheException.extendedErrorText;
			endif;
			
			app.msgBox(errorMessage, "Error " &amp; errorCode, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return Ex_Abort_Action;
		endif;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="599e3da0-969b-4678-b8f8-5a93d6528885">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doFormLoad();
	self.doFormInitialize();
end;</source>
    </JadeMethod>
    <JadeMethod name="resynchObjectAndSetEdition" id="89d32513-1239-4a39-b8f2-2292a3788464">
        <updating/>
        <source>resynchObjectAndSetEdition(pTheObject:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2001 by cnwdad2
//
// Purpose:		Resynchronizes the target object and stores its edition
//
// Parameters:	theObject - The object for which to resynch and store the edition
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pTheObject = null then
		self.aObjectEdition	:=	0;
	else
		self.aObjectEdition	:=	pTheObject.edition();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="unload" id="7f79ec42-01de-49c1-936d-1612d24fd1a8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doFormUnload();
end;</source>
    </JadeMethod>
</GUIClass>
