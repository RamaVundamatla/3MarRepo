/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation

*/

vars

begin

	textbox.text := self.tblUserData.getCellText(self.tblUserData.row, 2);

epilog

end;</source>
