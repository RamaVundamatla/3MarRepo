    <JadeMethod name="getValue" id="e0185d72-0e04-472e-9849-864ddd7aafbc">
        <source>getValue():Any;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Returns the value of this member of the JSSSorter's dynamic dictionary.
//
// Parameters:	None
//
// Returns:		The value of the property corresponding to the type of sort.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.typeOfSort = JSSSorter.AS_BOOLEAN then
		return self.booleanValue;
		
	elseif self.typeOfSort = JSSSorter.AS_CHARACTER then
		return self.charValue;
		
	elseif self.typeOfSort = JSSSorter.AS_DATE then
		return self.dateValue;
		
	elseif self.typeOfSort = JSSSorter.AS_DECIMAL then
		return self.decimalValue;
		
	elseif self.typeOfSort = JSSSorter.AS_INTEGER then
		return self.integerValue;
		
	elseif self.typeOfSort = JSSSorter.AS_REAL then
		return self.realValue;
		
	elseif self.typeOfSort = JSSSorter.AS_STRING then
		return self.stringValue;
		
	elseif self.typeOfSort = JSSSorter.AS_TIME then
		return self.timeValue;
		
	elseif self.typeOfSort = JSSSorter.AS_TIMESTAMP then
		return self.timestampValue;
		
	endif;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="7786c581-a748-42d1-9d16-91902230ef48">
        <updating/>
        <source>setValue(pValue:Any; pSortType:String) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.typeOfSort	:=	pSortType;
	
	if pSortType = JSSSorter.AS_BOOLEAN then
		self.booleanValue	:=	pValue.Boolean;
		
	elseif pSortType = JSSSorter.AS_CHARACTER then
		self.charValue		:=	pValue.Character;
		
	elseif pSortType = JSSSorter.AS_DATE then
		self.dateValue		:=	pValue.Date;
		
	elseif pSortType = JSSSorter.AS_DECIMAL then
		self.decimalValue	:=	pValue.Decimal;
		
	elseif pSortType = JSSSorter.AS_INTEGER then
		self.integerValue	:=	pValue.Integer;
		
	elseif pSortType = JSSSorter.AS_REAL then
		self.realValue		:=	pValue.Real;
		
	elseif pSortType = JSSSorter.AS_STRING then
		self.stringValue	:=	pValue.String;
		
	elseif pSortType = JSSSorter.AS_TIME then
		self.timeValue		:=	pValue.Time;
		
	elseif pSortType = JSSSorter.AS_TIMESTAMP then
		self.timestampValue	:=	pValue.TimeStamp;
		
	endif;
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pSortType" type="String"/>
    </JadeMethod>
</Class>
