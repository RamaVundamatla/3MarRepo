    <JadeMethod name="listFlags" id="2273a971-d3cf-4687-a7a7-fccdcbd295ec">
        <source>listFlags() :String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	if self.ammended then
		str := str&amp;"/Amended ";
	elseif self.deleted then
		str := str&amp;"/Deleted ";
	elseif self.noCharge then
		str := str&amp;"/NoCharge ";
	elseif self.superseded then
		str := str&amp;"/Superseded ";
	elseif self.systemGenerated then
		str := str&amp;"/SystemGenerated ";
	elseif self.userGenerated then
		str := str&amp;"/UserGenerated ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadPort" id="beb1da2c-17d0-4b3c-a185-abb609ca535c">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 and 
		   app.myRoot &lt;&gt; null then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="logicallyDelete" id="cd3aa0df-d751-4552-b858-0d35bde13981">
        <updating/>
        <source>logicallyDelete() updating;
/*
 ------------------------------------------------------------------------
Created:			16 September 2002 by cnwdwq1
Purpose:			Converted from C++
Changed On			Changed By		Reason
--------------		--------------	-----------------------------------------
18/12/2012			cnwcs5 			CCMS SFW 1294 /par 30855
02/09/2024			navnk30			Bug 65914: EUP | COO - Changes to be made on the Transactions after approving the COO
23 Oct 2024			navlw1			JIRA-33107: Invoice Logging Use Levels
---------------------------------------------------------------------------
*/
vars

begin 
	if (not self.deleted) then
		if self.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then			// par 30855
			self.createCAMSAuditTransaction (AuditDeleted, self, app.myPassport);		// par 30855
		endif;																	// par 30855
	endif;
	
	self.deleted := true;
	self.deletedByUser := app.getMyUserCode();		// 16/10/18 MAP TFS41191
	app.invLog("Transaction " &amp; self.id &amp; " logically deleted by " &amp; self.deletedByUser &amp; ". Reason: " &amp; self.deletedReason &amp; ".", LogTRACE.String);	//02.09.2024 navnk30 #65914
end;</source>
    </JadeMethod>
    <JadeMethod name="myCountryOfOrigin" id="4023a0d6-542a-4086-aff8-1dc88964c4cd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
