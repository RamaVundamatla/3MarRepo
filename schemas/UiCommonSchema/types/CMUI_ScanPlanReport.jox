    <JadeMethod name="getBigCellPictureFromCMIF" id="180417f7-e38f-4e1a-9b67-265b2e960ea5">
        <source>getBigCellPictureFromCMIF( _cmif : CMIF_ScanPlanReportSlot ):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963
28 Oct 2020	NDL		Change font sizes and fiddle with pixels for line up.

*/

vars

	backColour : Integer;
	foreColour : Integer;

begin

	frmCellBig.clearGraphics();

	if _cmif.attr16_Colour &lt;&gt; null then
		backColour := _cmif.attr16_Colour.colour;
	else
		backColour := White;
	endif;
	
	if backColour = WindowsGrey then
		foreColour := Black;
	else
		foreColour := backColour.getInverseColour;
	endif;

	frmCellBig.backColor := backColour;
	
	lblB1.visible := false;
	lblB2.visible := false;
	lblB3.visible := false;
	lblB4.visible := false;
	lblB5.visible := false;
	lblB6.visible := false;
	lblB7.visible := false;
	lblB8.visible := false;
	lblB9.visible := false;
	lblB10.visible := false;
	lblB11.visible := false;
	lblB12.visible := false;
	lblBFont.visible := false;
	
	lblB1.backColor := backColour;
	lblB2.backColor := backColour;
	lblB3.backColor := backColour;
	lblB4.backColor := backColour;
	lblB5.backColor := backColour;
	lblB6.backColor := backColour;
	lblB7.backColor := backColour;
	lblB8.backColor := backColour;
	lblB9.backColor := backColour;
	lblB10.backColor := backColour;
	lblB11.backColor := backColour;
	lblB12.backColor := backColour;
	lblBFont.backColor := backColour;
	
	lblB1.foreColor := foreColour;
	lblB2.foreColor := foreColour;
	lblB3.foreColor := foreColour;
	lblB4.foreColor := foreColour;
	lblB5.foreColor := foreColour;
	lblB6.foreColor := foreColour;
	lblB7.foreColor := foreColour;
	lblB8.foreColor := foreColour;
	lblB9.foreColor := foreColour;
	lblB10.foreColor := foreColour;
	lblB11.foreColor := foreColour;
	lblB12.foreColor := foreColour;
	lblBFont.foreColor := foreColour;
	
	if _cmif.isBlockedSlot then
		frmCellBig.drawFillStyle := DrawFillStyle_DownDiagonal;
		frmCellBig.drawFilledRectangle( 0, 0, frmCellBig.width, frmCellBig.height, Grey );
		return frmCellBig.createPictureIndirect( false, true );
	endif;
	
	if _cmif.attr09_MT then
		lblB1.visible := true; 
		lblB1.fontName := "Wingdings 2";
		lblB1.caption := 162.Character;
	endif;
		
	if _cmif.attr02_HighCube then
		lblB2.visible := true;
		lblB2.fontName := "Wingdings 3";
		lblB2.caption := 129.Character;
		lblB4.visible := true;
		lblB4.fontName := "Wingdings 3";
		lblB4.caption := 129.Character;
	endif;
	
	if _cmif.attr03_OverHeight then
		lblB3.visible := true;
		lblB3.fontName := "Wingdings 3";
		lblB3.caption := 129.Character;
	endif;
	
	if _cmif.attr10_Haz then
		lblB1.visible := true;
		lblB1.fontName := "Arial";
		lblB1.caption := "!";
		lblB5.visible := true;
		lblB5.fontName := "Arial";
		lblB5.caption := "!";
	endif;
	
	if _cmif.attr06_OverWidthLeft then
		lblB6.visible := true;
		lblB6.fontName := "Wingdings 3";
		lblB6.caption := 132.Character;
	endif;
	
	if _cmif.attr11_SOB_DLR then
		lblB7.visible := true;
		lblB7.fontName := "Wingdings 2";
		lblB7.caption := 183.Character;
	elseif _cmif.attr13_Tranship then
		lblB7.visible := true;
		lblB7.fontName := "Wingdings 2";
		lblB7.caption := 154.Character;
	endif;
	
	if _cmif.attr01_Over40Long then
		lblB8.visible := true;
		lblB8.fontName := "Wingdings 3";
		lblB8.caption := 130.Character;
		lblB10.visible := true; 
		lblB10.fontName := "Wingdings 3";
		lblB10.caption := 130.Character;
	endif;
	
	if _cmif.attr04_OverLength then
		lblB9.visible := true;
		lblB9.fontName := "Wingdings 3";
		lblB9.caption := 130.Character;
	endif;
	
	if _cmif.attr05_OverWidthRight then
		lblB12.visible := true; 
		lblB12.fontName := "Wingdings 3";
		lblB12.caption := 131.Character;
	endif;
	
	if _cmif.attr07_FlatRack then
		lblB11.visible := true;
		lblB11.fontName := "Wingdings 2";
		lblB11.caption := 162.Character;
	elseif _cmif.attr08_Reefer then
		lblB11.visible := true; 
		lblB11.fontName := "Wingdings 2";
		lblB11.caption := 175.Character;
	endif;
	
	if _cmif.attr14_40_53_Backend then
		lblBFont.top := -5;
		lblBFont.height := frmCellBig.height;
		lblBFont.visible := true; 
		lblBFont.fontSize := 84;
		lblBFont.fontName := "Wingdings 2";
		lblBFont.caption := 211.Character;
	elseif _cmif.attr17_Cont_Id &lt;&gt; null then
		lblBFont.top := lblB12.top;
		lblBFont.height := lblB12.height;
		lblBFont.visible := true;
		lblBFont.fontSize := 20;
		lblBFont.fontName := "Arial";
		if _cmif.attr17_Cont_Id.length &gt; 4 then
			lblBFont.caption := _cmif.attr17_Cont_Id[1:4] &amp; Cr &amp; _cmif.attr17_Cont_Id[5:end];
		else
			lblBFont.caption := _cmif.attr17_Cont_Id;
		endif;
	endif;
	
	return frmCellBig.createPicture( false, true, 24 ); //.convertPicture(Window.PictureType_Jpeg);
		

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ScanPlanReportSlot"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getLegendPicFromCMIF" id="d2ea559e-5e3d-43dd-8dde-679ef4fd1768">
        <source>getLegendPicFromCMIF( _cmif : CMIF_ScanPlanReportSlot; _legend : CMIF_ScanPlanLegend; _large : Boolean ):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2020	jlgndl1	Initial creation	TFS 49963
28 Oct 2020	NDL		Change font sizes and fiddle with pixels for line up.

*/

constants

	Hi : Integer = 0;
	Mid : Integer = 16;	
	Lo : Integer = 36;

vars

	left1 : Real;
	left2 : Real;
	left3 : Real;
	left4 : Real;
	left5 : Real;

begin

	frmCellLeg.clearGraphics();
	if _legend.colour &lt;&gt; null then
		frmCellLeg.backColor := _legend.colour;
	else
		frmCellLeg.backColor := White;
	endif;
	
	if _large then
		frmCellLeg.width := frmCellLeg.height * 1.6;
		left2 := frmCellLeg.width / 5;
	else
		frmCellLeg.width := frmCellLeg.height;
		left2 := frmCellLeg.width / 6;
	endif;
	
	left1 := 4;
	left3 := left2 * 2;
	left4 := left2 * 3;
	left5 := left2 * 4;
	
	lblLeg1.visible := false;
	lblLeg2.visible := false;
	
	lblLeg1.alignment := 7;	//Centre - MIDDLE
	lblLeg2.alignment := 7;	//Centre - MIDDLE
	
	lblLeg1.fontSize := 20;
	lblLeg2.fontSize := 20;
	
	lblLeg1.width := 20;
	lblLeg1.height := 20;
	lblLeg2.width := 20;
	lblLeg2.height := 20;
	
	if _cmif.attr01_Over40Long then
		lblLeg1.left := left2;
		lblLeg1.top := Lo -3;
		lblLeg1.height := 23;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 3";
		lblLeg1.caption := 130.Character;	
		lblLeg2.left := left4;
		lblLeg2.top := Lo -3 ;
		lblLeg2.height := 23;
		lblLeg2.alignment := 6;//Centre - TOP
		lblLeg2.visible := true; 
		lblLeg2.fontName := "Wingdings 3";
		lblLeg2.caption := 130.Character;
		
	elseif _cmif.attr02_HighCube then
		if _large then
			lblLeg1.left := left2;
			lblLeg1.top := Hi;
			lblLeg1.visible := true;
			lblLeg1.fontName := "Wingdings 3";
			lblLeg1.caption := 129.Character;
			lblLeg2.left := left4;
			lblLeg2.top := Hi;
			lblLeg2.visible := true;
			lblLeg2.fontName := "Wingdings 3";
			lblLeg2.caption := 129.Character;
		else
			lblLeg1.left := left3;
			lblLeg1.top := Mid;
			lblLeg1.alignment := 6;//Centre - TOP
			lblLeg1.fontSize := 18;
			lblLeg1.visible := true;
			lblLeg1.fontName := "Arial";
			lblLeg1.caption := "H";
		endif;
		
	elseif _cmif.attr03_OverHeight then
		lblLeg1.left := left3;
		lblLeg1.top := Hi -3;
		lblLeg2.alignment := 6;//Centre - TOP
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 3";
		lblLeg1.caption := 129.Character;
		
	elseif _cmif.attr04_OverLength then
		lblLeg1.left := left3;
		lblLeg1.top := Lo -3;
		lblLeg1.height := 23;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 3";
		lblLeg1.caption := 130.Character;
		
	elseif _cmif.attr05_OverWidthRight then
		lblLeg1.left := left5;
		lblLeg1.top := Mid;
		lblLeg1.height := 23;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.visible := true; 
		lblLeg1.fontName := "Wingdings 3";
		lblLeg1.caption := 132.Character;
		
	elseif _cmif.attr06_OverWidthLeft then
		lblLeg1.left := left1;
		lblLeg1.top := Mid;
		lblLeg1.height := 23;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 3";
		lblLeg1.caption := 131.Character;
		
	elseif _cmif.attr07_FlatRack then
		lblLeg1.left := left1;
		lblLeg1.top := Lo;
		lblLeg1.alignment := 8;//Centre - Bottom
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 162.Character;
		
	elseif _cmif.attr08_Reefer then
		lblLeg1.left := left1;
		lblLeg1.top := Lo;
		lblLeg1.visible := true; 
		lblLeg1.fontSize := 16;
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 175.Character;
		
	elseif _cmif.attr09_MT then
		lblLeg1.left := left1;
		lblLeg1.top := Hi -1;
		lblLeg1.height := 23;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.visible := true; 
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 162.Character;
		
	elseif _cmif.attr10_Haz then
		lblLeg1.left := left1;
		lblLeg1.top := Hi;
		lblLeg1.visible := true;
		lblLeg1.fontName := "Arial";
		lblLeg1.caption := "!";
		lblLeg2.left := left5;
		lblLeg2.top := Hi;
		lblLeg2.alignment := 1;	//Left - MIDDLE
		lblLeg2.visible := true;
		lblLeg2.fontName := "Arial";
		lblLeg2.caption := "!";
		
	elseif _cmif.attr11_SOB_DLR then
		lblLeg1.left := left5;
		lblLeg1.top := Lo;
		lblLeg1.alignment := 1;	//Left - MIDDLE
		lblLeg1.visible := true;
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 183.Character;
		
	elseif _cmif.attr13_Tranship then
		lblLeg1.left := left5;
		lblLeg1.top := Lo;
		lblLeg1.alignment := 1;	//Left - MIDDLE
		lblLeg1.visible := true;
		lblLeg1.fontSize := 16;
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 154.Character;
		
	elseif _cmif.attr14_40_53_Backend then
		lblLeg1.left := (frmCellLeg.width / 2) - (frmCellLeg.height / 2 );
		lblLeg1.top := 0;
		lblLeg1.width := frmCellLeg.height;
		lblLeg1.height := frmCellLeg.height;
		lblLeg1.alignment := 6;//Centre - TOP
		lblLeg1.fontSize := 48;
		lblLeg1.visible := true; 
		lblLeg1.fontName := "Wingdings 2";
		lblLeg1.caption := 211.Character;
	
	endif;
	
	return frmCellLeg.createPicture( false, true, 24 );
	
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ScanPlanReportSlot"/>
        <Parameter name="_legend" type="CMIF_ScanPlanLegend"/>
        <Parameter name="_large" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getMediumCellPictureFromCMIF" id="acca0542-2ec8-4ee7-adfe-6c1b9db9877a">
        <source>getMediumCellPictureFromCMIF( _cmif : CMIF_ScanPlanReportSlot ):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2020	jlgndl1	Initial creation	TFS 49963
28 Oct 2020	NDL		Change font sizes and fiddle with pixels for line up.

*/

vars

	backColour : Integer;
	foreColour : Integer;

begin

	frmCellMedium.clearGraphics();

	if _cmif.attr16_Colour &lt;&gt; null then
		backColour := _cmif.attr16_Colour.colour;
	else
		backColour := White;
	endif;
	
	if backColour = WindowsGrey then
		foreColour := Black;
	else
		foreColour := backColour.getInverseColour;
	endif;

	frmCellMedium.backColor := backColour;
	
	lblM1.visible := false;
	lblM3.visible := false;
	lblM5.visible := false;
	lblM6.visible := false;
	lblM7.visible := false;
	lblM9.visible := false;
	lblM11.visible := false;
	lblM12.visible := false;
	lblMFont.visible := false;
	
	lblM1.backColor := backColour;
	lblM3.backColor := backColour;
	lblM5.backColor := backColour;
	lblM6.backColor := backColour;
	lblM7.backColor := backColour;
	lblM9.backColor := backColour;
	lblM11.backColor := backColour;
	lblM12.backColor := backColour;
	lblMFont.backColor := backColour;
	
	lblM1.foreColor := foreColour;
	lblM3.foreColor := foreColour;
	lblM5.foreColor := foreColour;
	lblM6.foreColor := foreColour;
	lblM7.foreColor := foreColour;
	lblM9.foreColor := foreColour;
	lblM11.foreColor := foreColour;
	lblM12.foreColor := foreColour;
	lblMFont.foreColor := foreColour;
	
	if _cmif.isBlockedSlot then
		frmCellMedium.drawFillStyle := DrawFillStyle_DownDiagonal;
		frmCellMedium.drawFilledRectangle( 0, 0, frmCellMedium.width, frmCellMedium.height, Grey );
		return frmCellMedium.createPictureIndirect( false, true );
	endif;
	
	if _cmif.attr09_MT then
		lblM1.visible := true; 
		lblM1.fontName := "Wingdings 2";
		lblM1.caption := 162.Character;
	endif;
	
	if _cmif.attr03_OverHeight then
		lblM3.visible := true;
		lblM3.fontName := "Wingdings 3";
		lblM3.caption := 129.Character;
	endif;
	
	if _cmif.attr10_Haz then
		lblM1.visible := true;
		lblM1.fontName := "Arial";
		lblM1.caption := "!";
		lblM5.visible := true;
		lblM5.fontName := "Arial";
		lblM5.caption := "!";
	endif;
	
	if _cmif.attr05_OverWidthRight then
		lblM6.visible := true;
		lblM6.fontName := "Wingdings 3";
		lblM6.caption := 132.Character;
	endif;
	
	if _cmif.attr11_SOB_DLR then
		lblM7.visible := true;
		lblM7.fontName := "Wingdings 2";
		lblM7.caption := 183.Character;
	elseif _cmif.attr13_Tranship then
		lblM7.visible := true;
		lblM7.fontName := "Wingdings 2";
		lblM7.caption := 154.Character;
	endif;
	
	if _cmif.attr04_OverLength then
		lblM9.visible := true;
		lblM9.fontName := "Wingdings 3";
		lblM9.caption := 130.Character;
	endif;
	
	if _cmif.attr06_OverWidthLeft then
		lblM12.visible := true;
		lblM12.fontName := "Wingdings 3";
		lblM12.caption := 131.Character;
	endif;
	
	if _cmif.attr07_FlatRack then
		lblM11.visible := true;
		lblM11.fontName := "Wingdings 2";
		lblM11.caption := 162.Character;
	elseif _cmif.attr08_Reefer then
		lblM11.visible := true;
		lblM11.fontName := "Wingdings 2";
		lblM11.caption := 175.Character;
	endif;
	
	if _cmif.attr14_40_53_Backend then
		lblMFont.top := -10;
		lblMFont.height := frmCellMedium.height;
		lblMFont.left := 0;
		lblMFont.width := frmCellMedium.width;
		lblMFont.visible := true;
		lblMFont.fontSize := 72;
		lblMFont.fontName := "Wingdings 2";
		lblMFont.caption := 211.Character;
	elseif _cmif.attr15_SizeFeet &lt;&gt; null or _cmif.attr02_HighCube then
		lblMFont.top := lblM12.top;
		lblMFont.height := lblM12.height;
		lblMFont.left := lblM3.left;
		lblMFont.width := lblM3.width;
		lblMFont.visible := true;
		lblMFont.fontSize := 18;
		lblMFont.fontName := "Arial";
		if _cmif.attr02_HighCube then
			lblMFont.caption := _cmif.attr15_SizeFeet.String &amp; "H";
		else
			lblMFont.caption := _cmif.attr15_SizeFeet.String;
		endif;
	endif;
	
	return frmCellMedium.createPicture( false, true, 24 ); //.convertPicture(Window.PictureType_Jpeg);
		

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ScanPlanReportSlot"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
</GUIClass>
