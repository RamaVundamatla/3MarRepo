    <JadeMethod name="getTotalRequestedDisplay" id="6b4ca3c4-56a5-4cc3-8772-6fc0b11e9142">
        <source>getTotalRequestedDisplay() : String;
/*

Date		Who		Reason
23 June 2014	cnwer1	Initial creation PAR 34406

*/

vars
	ct : CM_CargoType;
begin
	ct := self.getCargoType;

		
	if  ct &lt;&gt; null then
		if ct.isBulkMulti then
			return ct.getBulkTrackByDisplayForWeight(self.weightRequested,self.getDensityFromCargoType,true);
		elseif ct.isBreakBulkMulti then
			return self.getQuantityOnRequest.asStringJMT;
		endif;
	endif;
	
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
