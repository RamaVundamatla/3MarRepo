    <JadeMethod name="showGCAreaEnquiryForm" id="8ddc6f71-6398-4388-8289-c11cf525b4cd">
        <source>showGCAreaEnquiryForm(_objs : ObjectArray; _masterMenuAction : CMUI_MenuAction; _gcArea : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		#### NOTE ##### from the calling method DO NOT delete your '_objs : ObjectSet', that is delt with by the assistant!
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	enqForm : Form;
	aClass : Class;
	assistClass : Class;
	jrw : Schema;
	obj : Object;
	objs : ObjectSet;
begin
	jrw := rootSchema.getSchema("YardSchema");
	aClass := jrw.getClass("YRD_GCAreaEnquiryForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	if _objs = null or  _objs.isEmpty then
		app.msgBox("Please select some GC racks to enquire on.","GC Racking Enquiry Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	enqForm.setPropertyValue("myCurrentTerminalArea", _gcArea); 
	

	// #### NOTE ##### from the calling method DO NOT delete your '_objs : ObjectSet', that is delt with by the assistant!
	create objs transient;
	_objs.copy(objs);
	enqForm.userObject := objs;
	enqForm.show(); 
	
epilog

end;</source>
