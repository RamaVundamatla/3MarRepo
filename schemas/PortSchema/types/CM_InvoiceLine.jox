    </JadeMethod>
    <JadeMethod name="setFromQuantityRangeMap" id="4d89ec07-6774-47bf-88f0-db41906ee622">
        <updating/>
        <source>setFromQuantityRangeMap(_qrm : CM_QuantityRangeMap) updating;
// ---------------------------------------------------------------------------
// Created:		12 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	zero : Boolean;
	charge	: CM_Charge;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	if _qrm = null then
		return;
	endif;
	
	if _qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single 
	and not _qrm.myQuantityMap.chargeZero then
		// TFS 2901 - if resyncing and the range map has changed from escating to single 
		// 					we must zero out the range otherwise in 'adjustQuantityForRange' it just returns with the current 'pre-escalated' value.
		//  TFS 38113		self.setQuantityRange(0, 0, false); 
		self.setQuantityRange(null); // TFS 38113
		return;
	endif;

// TFS 38113	zero := (_qrm.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single and _qrm.myQuantityMap.chargeZero);
	
	self.setQuantityRange(_qrm); // TFS 38113
epilog
	// CCMS 1264, do here as everything required has been set up
	self.calculateQuantity();
	foreach charge in self.charges do
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
	endforeach;
end;</source>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="setInvoice" id="7159d076-f128-45d8-8835-926f912f0490">
        <updating/>
        <source>setInvoice(_invoice: CM_Invoice) updating;
/*

Purpose:		

	Sets the invoice for the invoiceLine

Parameters:			

	_invoice: The invoice to set the value to on the invoice line object

Return Value:		

	None

Date		Who		Reason
13/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars

begin
	self.invoice := _invoice;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setManual" id="f9591770-4fd5-4ffd-a2e9-a88b22b9c0de">
        <updating/>
        <source>setManual(_value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2016	cnwjre1	Initial creation

*/

