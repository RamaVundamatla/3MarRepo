    <JadeMethod name="getMyObjectExtension" id="5a2bd615-a740-43ab-85c8-af57a16e36ca">
        <source>getMyObjectExtension() : CM_ObjectExtension;
/*

Purpose:			Get the CM_ObjectExtension object associated with the receiver

Parameters:			None

Return Value:		If there is already an existing CM_ObjectExtension for this object, then
					return it, otherwise null

Date		Who		Reason
26 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
23/02/2012	cnwcs5	par 29158 - CCMS CPL 2086 - Allow transients to have object extensions 
*/

vars
	returnVal		: CM_ObjectExtension;
	root			: CM_Root;
	proxyMgr		: CM_ProxyManager;
	gotException	: Boolean;
begin
	if self.isTransient then
		// par 29158 - for transients object extensions are stored on the proxy manager.
		// this means they can only have values within the scope of the JMT application.
		proxyMgr := app.myProxyManager;
		
		if proxyMgr = null then
			return null;
		endif;
		
		returnVal := proxyMgr.allCMObjectExtensions[self];
	else
	
		on Exception do app.handleDeletedObject (exception, root, gotException);
		
		// This method needs to work outside the scope of a JMT application
		root := app.myRoot;
		
		if root = null then
			root := CM_Root.firstInstance();
		endif;
		
		// If there is no CM_Root, then there can be no CM_ObjectExtension
		if root = null then
			return null;
		endif;
		
		returnVal := root.allCMObjectExtensions[self];
	endif;
	
	return returnVal;
epilog

end;</source>
        <ReturnType type="CM_ObjectExtension"/>
    </JadeMethod>
