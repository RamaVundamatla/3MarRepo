    <JadeMethod name="utlDeleteVesselSection" id="1671f892-5d32-469b-b78c-1b2542f5ea58">
        <source>utlDeleteVesselSection(_vesselSection : CM_VesselSection input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	auditObject ,
	structure 	: CM_Object;
	beforeText, afterText 	: String;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCM_Object(_vesselSection,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	auditObject:=_vesselSection.getAuditParent; //want to add audits to the vessel/voyage
	structure :=_vesselSection.getStructure; //will be either the vessel or voyage structure
	beforeText:=structure.getAuditText; //vessel structure holds allTanks
	
	if _passport.noErrors then
		_vesselSection.erase(NORMAL_ERASE);
	endif;
	
	afterText:=structure.getAuditText;
	
	app.myAA.auditUpdateTrx(auditObject,beforeText, afterText);
	
epilog

end;</source>
        <Parameter name="_vesselSection" type="CM_VesselSection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
