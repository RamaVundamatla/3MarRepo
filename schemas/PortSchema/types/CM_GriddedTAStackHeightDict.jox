<CollClass name="CM_GriddedTAStackHeightDict" id="94ff5024-9a11-4382-bb46-855f4ee80c27">
    <loadFactor>66</loadFactor>
    <memberType name="CM_GriddedTAStackHeight"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stackHeightCrit"/>
    <MemberKey>
        <property name="CM_ObjectMatchCriteria::priority"/>
    </MemberKey>
    <JadeMethod name="getFirstMatching" id="3903a4f6-560f-43aa-a5ad-0b5edd07bf62">
        <source>getFirstMatching( _ti : CM_TrackedItem ):CM_GriddedTAStackHeight;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	griddedStackHeight : CM_GriddedTAStackHeight;
	iter : Iterator;

begin

	iter := self.createIterator;
	while iter.next( griddedStackHeight ) do
		if not griddedStackHeight.matches( _ti ) then
			continue;
		endif;
		return griddedStackHeight;
	endwhile; 
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_GriddedTAStackHeight"/>
    </JadeMethod>
</CollClass>
