    <JadeMethod name="tRORODeckPlanWithChildren" id="ee3cb296-0c73-4d65-bcd0-602535d535a1">
        <source>tRORODeckPlanWithChildren();
// cnwrs1 
// CCMS 1009 Plans Deck Extract Par 29024
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	UserDefinedShipManifest	= 'UT DeckPlan Child';
	UserDefinedDeckPlanNoBOL	= 'Unit Test Deck Plan No BOL';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANS1009C";
	TestOperator = 'MSK';
	ContainerId1 = "OOTL0002914";
	ContainerId2 = "OOTL0002915";
	ContainerId3 = "OOTL0002916";
	ContainerId4 = "OOTL0002917";
	ContainerId5 = "OOTL0002918";
	ContainerId6 = "OOTL0002919";
	ContainerId7 = "OOTL0002920";
	GCCargoId1 = "CANN0001111";
	GCCargoId2 = "CANN0001122";
vars
	theLines : HugeStringArray;
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	startLocn : CM_ROROLocnDefn; 
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	parentTI : CM_TrackedItem;
	childTI : CM_TrackedItem;
	unloadArray : StringArray512;
	clientRefNum : Integer;
	tiSet : CM_TISet;
	tempStr : String;
begin
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

////	self.deleteVessel(ShipName);
////	self.assertNull(self.getVessel(ShipName));
	operator := app.myRoot.allOperators[TestOperator];

//	vessel := self.addVesselConRORO(ShipName, operator);
	vessel := self.getVessel(ShipName);
	
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created/
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		self.updateEDITIRemarks(ediFile);
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		self.updateEDITIRemarks(ediFile);
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// create file 01 edi user defined data to load
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId1&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId2&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId4&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId3&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId5&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1024,,,,'&amp;ContainerId6&amp;',1,4100,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1004,,,,'&amp;ContainerId7&amp;',1,4100,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',
C,A,,,,,CANNON,,,,,,,,,,,,AUSYD,D1004,,,,'&amp;GCCargoId1&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,22111,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId7&amp;',CONT,
C,A,,,,,CANNON,,,,,,,,,,,,AUSYD,D1004,,,,'&amp;GCCargoId2&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,22111,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId7&amp;',CONT,';	//cnwmc5 - PAR 30952

	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	ediControllerAgent.setEdiClientRef(clientRef);
/*
	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);*/
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

//	self.updateEDITIRemarks(ediFile);
	// now check that the correct tarckeditems have been created
	parentTI := self.getTrackedItemOnVoy(ContainerId1, VoyageName);
	self.assertNotNullMsg(parentTI, 'No parent trackedItem');
	idx := 0;
	foreach childTI in parentTI.allChildren do
		idx := idx + 1;
		if idx = 1 then
			self.assertEqualMsg(childTI.id, ContainerId2, errorStr);
		elseif idx = 2 then
			self.assertEqualMsg(childTI.id, ContainerId4, errorStr);
		elseif idx = 3 then
			self.assertEqualMsg(childTI.id, ContainerId3, errorStr);
		elseif idx = 4 then
			self.assertEqualMsg(childTI.id, ContainerId5, errorStr);
		endif;
	endforeach;
	self.assertEqualMsg(idx, 4, "insufficent children");
	
	// create file 01 edi user defined data to load
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId6&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId7&amp;',CONT,';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	ediControllerAgent.setEdiClientRef(clientRef);

/*	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS.display, errorStr);
*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	// now extract the details
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlanNoBOL];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	create unloadArray transient;
	unloadArray.add("V,A,UT_EDIPLANS1009C,JJRORO");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10091,,0.0000,,OOTL0002920,Remain On Board,4100,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002914,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,14777,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002915,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002917,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002916,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002918,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10241,,0.0000,,OOTL0002919,Remain On Board,4100,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	idx := 0;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
//		write ediText;
		self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
	endforeach;

	// now extract the proposed details
	delete ediDataParams;
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlanNoBOL];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, PROPOSED_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	unloadArray.clear();
	unloadArray.add("V,A,UT_EDIPLANS1009C,JJRORO");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10091,,0.0000,,OOTL0002920,Remain On Board,4100,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002914,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,14777,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002915,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002917,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002916,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10201,,0.0000,,OOTL0002918,Remain On Board,2063,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,OOTL0002914,ISO Container");
	unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D10241,,0.0000,,OOTL0002919,Remain On Board,4100,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,Created by unit test UT_RORO::tRORODeckPlanWithChildren,,,,12589,,,,0.000,UT_EDIPLANS1009C,,,0.0000,,,");
	idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
//		write ediText;
		self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
	endforeach;
	
	// 10/09/2015 cnwmh5
	create tiSet transient;
	voyage.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach parentTI in tiSet discreteLock do
		parentTI.setRemarks(self.createdByUnitTest(null), true);
	endforeach;
	commitTransaction;

epilog
	delete unloadArray;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete theLines;
	delete tiSet;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanWithRotation" id="b4527f15-3ffe-4a5c-a8c5-0c8690576747">
        <source>tRORODeckPlanWithRotation();
// cnwrs1 
// CCMS 1009 Plans Deck Load with Rotation
//
constants
	UserDefinedShipManifest	= 'Unit Test Ship Manifest_2';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANS1009";
	TestOperator = 'MSK';
	ContainerId = "OOTL2914";
vars
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	startLocn : CM_ROROLocnDefn; 
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
	roroDeck : CM_DeckVoyage;
	error : CM_Error;
	locationID : String;
	wrongError : Boolean;
	ti : CM_TrackedItem;
	tempStr : String;
begin
	app.writeLog("***Setting up initial voyage***", LogINFO);
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

////	self.deleteVessel(ShipName);
////	self.assertNull(self.getVessel(ShipName));
	operator := app.myRoot.allOperators[TestOperator];

//	vessel := self.addVesselConRORO(ShipName, operator);
	vessel := self.getVessel(ShipName);
	
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created/
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	app.writeLog("***File1 Create a 2X5 Rotation***", LogINFO);
	// create EDI file 01 do a 2x5 rotation of a defined position this should work
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
L,D2008,S,,Yes,2X5
C,A,,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2008R,:: 1.2:+450 ::  1.1 :1.2:+440:  1.3:+889,,,'&amp;ContainerId&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
/*	ediControllerAgent.setEdiClientRef(clientRef);
	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);*/

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

	// now check that the correct slots are rotated
	foreach ediTI in ediFile.ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) do
		locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks();
		if locationID &lt;&gt; null then
			if ediTI.CM_EDILayoutTI.isRotationMaster then
				locationID := locationID &amp; "R"; // has been rotated will now have an R in teh end
			endif;
