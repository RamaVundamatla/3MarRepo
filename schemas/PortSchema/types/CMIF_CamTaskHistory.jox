    <JadeMethod name="getDisplayStringForAttribute" id="3e03c345-0f0a-411a-80ce-f5400117e07f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	if _attrName = ETRow_CamProtocol then
		return self.camProtocol.code;
	elseif _attrName = ETRow_SequenceNumber then
		return self.seqNumber.asStringJMT;
	elseif _attrName = ETRow_Computer then
		return self.computerName;
	elseif _attrName = ETRow_Messages then
		return self.messageCount.asStringJMT;
	elseif _attrName = ETRow_ErrorMessage then
		return self.errorMessage;
	elseif _attrName = ETRow_TaskStatus then
		return self.statusString();
	elseif _attrName = ETRow_RunDate then
		return self.runDateTime.asStringJMT;
	elseif _attrName = ETRow_ProtocolDesc then
		return self.camProtocol.description;
	elseif _attrName = ETRow_RegexResult then
		return self.foundString;
	endif;
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFoundString" id="7e330836-7116-423e-9d6d-3b011631b7db">
        <updating/>
        <source>setFoundString(_match: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	self.foundString := _match;
epilog

end;</source>
        <Parameter name="_match" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRealObj" id="a310b340-5e98-48f6-a43b-0ba08759aeb9">
        <updating/>
        <source>setRealObj(_camsTaskHist: CM_CamTaskHistory) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	self.realTaskHistory := _camsTaskHist;
	self.status := _camsTaskHist.status;
	self.computerName := _camsTaskHist.computerName;
	self.seqNumber := _camsTaskHist.seqNumber;
	self.messageCount := _camsTaskHist.messageCount;
	self.errorMessage := _camsTaskHist.errorMessage;
	self.runDateTime := _camsTaskHist.runDateTime;
	self.camProtocol := _camsTaskHist.camProtocol;
epilog

end;</source>
        <Parameter name="_camsTaskHist" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="a38eee8a-bc2f-481b-891d-3ec101fb54ab">
        <source>statusString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

begin
    if self.status = CAM_IDLESTATUS then
        return "Idle";
    elseif self.status = CAM_EXTRACTSTATUS then
        return "Extract";
    elseif self.status = CAM_SENDSTATUS then
        return "Send";
    elseif self.status = CAM_COMPLETESTATUS then
        return "Complete";
    elseif self.status = CAM_RESENDSTATUS then
        return "Resend";
    elseif self.status = CAM_HOLDSTATUS then
        return "Hold";
    elseif self.status = CAM_ERRORSTATUS then
        return "ERROR";
    else
        return self.status.String;
    endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
