Purpose:			Returns our display value for the selected object

Parameters:			combobox	ComboBox	The combobox that lost focus
					obj			Any			The object that was selected
					lstIndex	Integer		The index of the selected object

Return Value:		String	Representing the text we want to display

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars

begin
	if obj = null or not obj.isKindOf(CM_TerminalArea) then
		return null;
		
	endif;
	
	return obj.CM_TerminalArea.id;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
