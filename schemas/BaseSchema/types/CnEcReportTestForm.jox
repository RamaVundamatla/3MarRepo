    <JadeMethod name="btnServer_click" id="cac25224-2403-4896-9d87-3992ce075497">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnServer_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	app.startApplication("BaseSchema", "BasePrintServerGui");
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="6c3e63c0-9bc3-4013-addb-f67203c79a61">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	//centreWindow();
	self.alwaysOnTop(true);
end;</source>
        <access>protected</access>
