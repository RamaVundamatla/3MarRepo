    <JadeMethod name="changeYearForCopy" id="04d211b1-fc7a-46f6-91d0-983c33c7d0f5">
        <updating/>
        <source>changeYearForCopy(_toYear : CM_CalendarYear; _currentDate : CM_CalendarDate) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	saveDate : Date;
	yearDifference,
	currentYear : Integer;
begin

	saveDate := _currentDate.date;
	
	currentYear :=	_currentDate.date.year();		// get the year 	
	yearDifference := _toYear.year- currentYear; // find the difference so now how many to add on when seting date
	
	if yearDifference &lt;&gt; 0 then
		saveDate  := saveDate.cnEcAddYears(yearDifference);  //add on difference to current date
	endif;	
	
	self.date := saveDate;
end;</source>
        <Parameter name="_toYear" type="CM_CalendarYear"/>
        <Parameter name="_currentDate" type="CM_CalendarDate"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b14015a2-553b-4265-b5ee-fbefe349b935">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Date then
		return self.date.String;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringForTable" id="cd0c3668-de1a-4d96-9eb3-c9f08a48a8a8">
        <source>getStringForTable():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	year : String;
	date : String;
	day : String;
	time : String;
	descr : String;
	
	retValue : String;
	
begin

	if self.myCalendarYear &lt;&gt; null then
		year := self.myCalendarYear.year.String;
	else
		year := self.date.year.String;
	endif;
	
	date := self.date.asStringJMT;
	
	day := self.date.format("dddd");
	
	time := self.getTimeDisplay();
	
	descr := self.description;
	
	retValue := year &amp; Tab &amp; date &amp; Tab &amp; day &amp; Tab &amp; time &amp; Tab &amp; descr;
	
	return retValue;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeDisplay" id="bd50eae5-9cd6-4c00-8313-33043cc6ed84">
        <source>getTimeDisplay():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation

*/

vars

	nullTime : Time;
	timeStr : String;

begin

	nullTime := "00:00".Time;
	if startTime = nullTime and endTime = nullTime then
		timeStr := " ";
	elseif endTime &lt;&gt; nullTime then
		timeStr := startTime.asStringJMT &amp; " - " &amp; endTime.asStringJMT;
	elseif startTime &lt;&gt; nullTime then
		timeStr := startTime.asStringJMT &amp; " - " &amp; "23:59:59".Time.asStringJMT;
	endif;
	
	return timeStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
