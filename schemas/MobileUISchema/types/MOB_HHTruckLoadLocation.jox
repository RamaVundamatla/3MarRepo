    <JadeMethod name="populateLocations" id="ec9082b6-590f-421b-bbba-f2c3080ef73d">
        <updating/>
        <source>populateLocations() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950

*/

constants
	TAB_INDEX_START = 1000;
vars
	size : Integer;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	
	locations : CM_LCArray;
	types : StringArray512;
	lc : CM_LocationsController;
	
	buttonWidth : Real;
	buttonHeight : Integer;
	buttonOffset : Integer;
	
	wle : CM_WorkListEntry;
	index : Integer;
	lcCargoTypesStr : String;
	
begin

	size := self.locnButtonCount;
	if size &gt; 0 then
		foreach buttonNumber in 1 to size do
			menuButton := self.btnLocationTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
	endif;
	
	self.locnButtonCount := 0;
	buttonNumber := 0;
	buttonOffset := 0;
	
	create locations transient;
	create types transient;
	wle := self.myMobileGenericAgent.getUnActionedIsAnyIdAnyAmount();
	if wle &lt;&gt; null then
		wle.getLocnsForAnyIdAnyAmount( locations, types );
	endif;
	
	size := locations.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnLocationTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmLocation, self.btnLocationTemp.height, self.scrLocations );
	
	if not locations.isEmpty then
		foreach index in 1 to locations.size discreteLock do
			
			lc := locations[index];
			lcCargoTypesStr := types[index];
			
			buttonNumber := buttonNumber + 1;
			menuButton := self.btnLocationTemp.loadControl( buttonNumber ).MOB_Button;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight - 4 );
			
			menuButton.userObject := lc;
			menuButton.caption := lc.getFullId &amp; " - " &amp; lcCargoTypesStr;
			
			menuButton.enabled := true;
			
			buttonOffset := buttonOffset + buttonHeight - 2;
			menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
			
		endforeach;
	endif;
	
	
	self.locnButtonCount := buttonNumber;
	
	self.btnLocationTemp.visible := false;
	self.frmLocation.caption := null;
	
	lblNoLocation.visible := (buttonNumber = 0);
	
	self.resizeScrollButtons(); 

epilog

	delete locations;
	delete types;

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeScrollButtons" id="ce07fc31-cbc3-4136-bd93-fcec1cb44542">
        <updating/>
        <source>resizeScrollButtons()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlgndl1	Initial creation

*/

vars
	
	buttonHeight : Integer;
	buttonWidth : Real;
	buttonTop : Integer;
	index : Integer;
	menuButton : MOB_Button;

begin

	self.setResizeableMarginAndFontSize();
						
	buttonHeight := self.getScrollingButtonHeight();
	
	if self.locnButtonCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.locnButtonCount, self.frmLocation, self.btnLocationTemp.height, self.scrLocations );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.locnButtonCount do
			menuButton := self.btnLocationTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnLocationTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.locnButtonCount, self.frmLocation, self.btnLocationTemp.height, self.scrLocations );
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrLocations_change" id="9a661fb1-ce92-4956-bba7-9280f447ec49">
