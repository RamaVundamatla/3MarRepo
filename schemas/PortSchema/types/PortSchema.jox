    <JadeMethod name="initializeJMTVersion" id="ae11da0c-2935-4876-a8f7-1aefc7b64afc">
        <updating/>
        <source>initializeJMTVersion() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 32113

*/

vars

begin
	if app.myCnCntrl = null then
		self.setupAppVersion();
		self.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	endif;

	self.writeLog('Application version is ' &amp; app.appVersion, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	self.writeLog('Build date is ' &amp; app.getJMTReleaseExtractTime.asStringJMT, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	
	terminate;
	
end;</source>
