    <JadeMethod name="doCancel" id="1c4bf77d-e923-4289-84b7-617d4ef5cbdd">
        <updating/>
        <source>doCancel() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars

