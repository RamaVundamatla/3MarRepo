    <JadeMethod name="populateCmbForSystemLicense" id="401255e6-0268-4deb-a5d5-0525e648effa">
        <updating/>
        <source>populateCmbForSystemLicense()updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
begin
	
	self.cmbLicenseFor.clear();
	self.cmbLicenseFor.addItemObject(ProductStr_JMT, app.myRoot);
	self.cmbLicenseFor.addItemObject(ProductStr_JMT_EDI, app.myRoot);
	self.cmbLicenseFor.addItemObject(ProductStr_EWS, app.myRoot);// ### JIRA 33543 12DEC2024 NAVAB1
	self.cmbLicenseFor.addItemObject(ProductStr_SUBS, app.myRoot);	//18 Jun 2020	NDL	TFS 49569
	

	if (not app.myRoot.isLicensedForProductCode(ProductCode_JMT)) then
		// Site license so just populate with "System"
		cmbLicenseFor.enabled	:= false;
		self.ckbTerminal.enabled := false;
	else
		self.ckbTerminal.enabled := true;		
	endif;
	
	self.cmbLicenseFor.listObject := app.myRoot;
	
	if (not app.myRoot.isMultiTerminal) then
		self.ckbTerminal.visible := false;
	endif;

	self.showCurrentLicenseObject(self.cmbLicenseFor.listObject.CM_Object);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbForTerminalLicense" id="9f0a857d-f4c3-46a9-8bbd-08abf53582a4">
        <updating/>
        <source>populateCmbForTerminalLicense() updating, protected;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
	idx,	
	listIdx	 : Integer;
	tmpTerminal	: CM_Terminal;
	iter : Iterator;
begin

	cmbLicenseFor.clear();

	iter := app.myRoot.allTerminals.createIterator();
	
	while iter.next(tmpTerminal) do
		idx := cmbLicenseFor.addItemObject(tmpTerminal.name, tmpTerminal);
		if tmpTerminal = self.myLicenseObject then
			listIdx := idx;
		endif;
	endwhile;
	
	if listIdx &gt; 0 then
		cmbLicenseFor.listIndex := listIdx;
	elseif self.myTerminal &lt;&gt; null then	
		cmbLicenseFor.listIndex := cmbLicenseFor.findObject(self.myTerminal);
	elseif idx &gt; 0 then
		cmbLicenseFor.listIndex := 1;
	endif;

	self.showCurrentLicenseObject(cmbLicenseFor.listObject.CM_Object);
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9d5c4fe2-1f17-4a07-a858-31e8a7b7cb39">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002		cnwth2	
//Ui_Enter_License_Key
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpTop,
	cntrlLeft,
	cntrlWidth	: Real;

begin

	inheritMethod();

	lblDescription.fontSize := 10;
	lblDescription.caption := app.getErrorString(Ui_Enter_License_Key);
	lblDescription.top		:= WinTopMargin;
	lblDescription.left		:= WinLeftMargin;
	lblDescription.width	:= self.clientWidth - lblDescription.left - (WinRightMargin);
	lblDescription.height	:= lblDescription.getTextHeightForWidth(lblDescription.caption, lblDescription.width.Integer);

	//cnwsh3 26/04/2006	Added an extra 5 pixels to allow for font changes in 7.4.2.
	//lblDetails caption is now longer
	cntrlLeft	:= WinLeftMargin + lblName.width + HorizontalSpacing + 5;
	
	cntrlWidth	:= self.clientWidth - cntrlLeft - WinRightMargin;
	tmpTop := lblDescription.top + lblDescription.height + (VerticalSpacing * 2);

	self.ckbTerminal.move(self.width - self.ckbTerminal.width - WinRightMargin, tmpTop, self.ckbTerminal.width, self.ckbTerminal.height);

	tmpTop			:= tmpTop + ckbTerminal.height + (VerticalSpacing * 2);
	
	lblLicenseFor.top 	:= tmpTop;
	lblLicenseFor.left 	:= WinLeftMargin;

	cmbLicenseFor.top 	:= tmpTop;
	cmbLicenseFor.left 	:= cntrlLeft;

	tmpTop			:= tmpTop + lblLicenseFor.height + (VerticalSpacing * 2);

	lblName.top 	:= tmpTop;
	lblName.left 	:= WinLeftMargin;
	
	txtName.left	:= cntrlLeft;
	txtName.top		:= tmpTop;

	tmpTop			:= tmpTop + lblName.height + (VerticalSpacing * 2);
	lblKey.top		:= tmpTop;
	lblKey.left		:= WinLeftMargin;

	txtKey.left		:= cntrlLeft;
	txtKey.top		:= tmpTop;

	// ### JIRA 33503 06JAN2025 NAVAB1
	tmpTop			:= tmpTop + lblKey.height + (VerticalSpacing * 2);
	
	lblExpDate.top		:= tmpTop;
	lblExpDate.left		:= WinLeftMargin;

	txtExpDate.left		:= cntrlLeft;
	txtExpDate.top		:= tmpTop;
	
	
	
	
	tmpTop			:= tmpTop + lblExpDate.height + (VerticalSpacing * 2); // ### JIRA 33503 06JAN2025 NAVAB1
	lblDetails.top	:= tmpTop;
	lblDetails.left	:= WinLeftMargin;
	
	tblDetails.left	:= cntrlLeft;
	tblDetails.top	:= tmpTop;
	
	if self.permissionMaint &lt;&gt; PmAdmConfigMaint then
		self.btnDelete.visible := false;
	endif;	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDelete.visible := false;
		self.txtKey.enabled:= false;
		self.txtName.enabled:= false;
	endif;

	self.centreWindow();
	self.cmbLicenseFor.setFocus();

epilog
	self.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAdvancePermission" id="1126d6dc-9ec8-4ad9-bc43-0feb26160024">
        <source>showAdvancePermission(_permissions : StringArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2022	navkc1	Initial creation - ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1

*/

vars
	constant	: Constant;
	permObj		: CM_PermissionObject;
	perm		: String;
	canDo		: Boolean;
	root		: CM_Root;
	termRoot	: CM_SecurityRoleTerminalRoot;
	index		: Integer;
	
begin	
	// Return if nothing to do
	if _permissions.size() = 0 then
		return;
	endif;
	
	// Get Root object
	root := app.myRoot;
	
	// Get Terminal Root object
	termRoot := root.mySecurityRoleTerminal;
	
	tblDetails.sortColumn[1] := 0; // Advance permissions to be at the bottom of the table. 
	
	// Add a 'seperator' before advance permissions
	index := tblDetails.addItem(null);
	tblDetails.accessRow(index).height := 3;
	tblDetails.accessedRow.backColor := Black;
	tblDetails.accessedRow.enabled := false;
	
	// Check permissions
	foreach perm in _permissions do
		constant := currentSchema.getConstant(perm);
		create permObj transient;
		permObj.setFromXML(constant);
		canDo := termRoot.canDo(permObj.constValue);
		// Add to table if have permission
		if canDo then
			tblDetails.addItem(permObj.description &amp; Tab &amp; canDo.getYesNo());
		endif;
		delete permObj;
	endforeach;
epilog
	delete permObj;
end;</source>
        <Parameter name="_permissions" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="f5308522-7fec-4534-aea4-b488bed925a2">
        <source>showColourLegend();
/*
Purpose:	

Date		Who		Reason
31 December 2024	navab1	JIRA 33503
*/

vars
	colLegend		: CMUI_ColourLegend;
	vjs				: CM_VoyageJobSheet;
	tmpColour		: Integer;
	workPointObject	: CM_Object;
	licType : String;
begin
	licType := self.cmbLicenseFor.text;
	
	create colLegend;
	self.setNavigatorHeading( colLegend.caption ); 
	
	colLegend.centreWindow;
	
	colLegend.height := 150;
	colLegend.width := 180;
	colLegend.minimumHeight := 150;
	colLegend.minimumWidth := 180;
	
	if licType = ProductStr_JMT_EDI then
		tmpColour := CM_EDIFileType@getColourForRow(CM_EDIFileType.EDI_Bundle_BASE); 	
		colLegend.addLegendItem(CM_EDIFileType.EDI_Bundle_BASE_Str, tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := CM_EDIFileType@getColourForRow(CM_EDIFileType.EDI_Bundle_EDIFACT); 	
		colLegend.addLegendItem(CM_EDIFileType.EDI_Bundle_EDIFACT_Str, tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := CM_EDIFileType@getColourForRow(CM_EDIFileType.EDI_Bundle_SUZANO); 	
		colLegend.addLegendItem(CM_EDIFileType.EDI_Bundle_SUZANO_Str, tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := CM_EDIFileType@getColourForRow(CM_EDIFileType.EDI_Bundle_X12); 	
		colLegend.addLegendItem(CM_EDIFileType.EDI_Bundle_X12_Str, tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := CM_EDIFileType@getColourForRow(CM_EDIFileType.EDI_Bundle_CUSTOM); 	
		colLegend.addLegendItem(CM_EDIFileType.EDI_Bundle_CUSTOM_Str, tmpColour.getInverseColour(), tmpColour,null, false);

		colLegend.caption := "Colour Legend - Electronic data interchange";
	elseif licType = ProductStr_SUBS then
		tmpColour := Cn_PaleBlue; 	
		colLegend.addLegendItem("External Modules", tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := PalePink; 	
		colLegend.addLegendItem("Advanced Modules", tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := Cn_WedgeWoodBlue; 	
		colLegend.addLegendItem("Operational Modules", tmpColour.getInverseColour(), tmpColour,null, false);

		colLegend.caption := "Colour Legend - Subscriptions";
	elseif licType = ProductStr_EWS then 
		tmpColour := PalePink; 	
		colLegend.addLegendItem("External Web Service Type", tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := Cn_PaleBlue; 	
		colLegend.addLegendItem("EWS Endpoint Type", tmpColour.getInverseColour(), tmpColour,null, false);
	
		colLegend.caption := "Colour Legend - External Web Services";
	else
		tmpColour := PaleGreen; 	
		colLegend.addLegendItem("Base Module", tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := PalePink; 	
		colLegend.addLegendItem("Core Modules", tmpColour.getInverseColour(), tmpColour,null, false);
		tmpColour := Cn_WedgeWoodBlue; 	
		colLegend.addLegendItem("System Modules", tmpColour.getInverseColour(), tmpColour,null, false);
		
		colLegend.caption := "Colour Legend - System";
	endif;
	
	
	colLegend.showModal;
	
epilog
	delete colLegend;
	self.setNavigatorHeading( self.caption );

end;</source>
    </JadeMethod>
    <JadeMethod name="showCurrentLicenseObject" id="745c5a50-7b94-4d11-8350-5d2e2354c416">
        <updating/>
        <source>showCurrentLicenseObject(_obj : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/09/2022	navkc1		Initial creation - ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 22/01/2024	jlizm1		TFS 62072 Advanced damage license changes
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constantsl
vars

begin

	tblDetails.clear;
	tblDetails.sortColumn[1] := 1;
	self.txtKey.text := ""; // ### JIRA 33957 13FEB2025 NAVAB1
	self.myLicenseObject := _obj;
	if _obj = null then
		return;
	endif;
	
	beginLoad;
	
	sharedLock(_obj);
	self.expectedEdition := _obj.edition;

	if _obj.isKindOf(CM_Root) then
		if self.cmbLicenseFor.text = ProductStr_JMT_EDI then
			txtName.text := _obj.CM_Root.licenseNameEDI;
			self.showLicenceDetailsEDI(_obj.CM_Root);					
		elseif self.cmbLicenseFor.text = ProductStr_SUBS then	//18 Jun 2020	NDL	TFS 49569
			txtName.text := _obj.CM_Root.licenseName;
			self.showLicenceDetailsSubs(_obj.CM_Root);				
		// ### JIRA 33545 12DEC2024 NAVAB1
		elseif self.cmbLicenseFor.text = ProductStr_EWS then 
			txtName.text := _obj.CM_Root.licenseEWS;
			self.showLicenceDetailsEWS(_obj.CM_Root);					
		else
			txtName.text := _obj.CM_Root.licenseName;
			self.showLicenseDetailsRoot(_obj.CM_Root);
		endif;
	else
		txtName.text := _obj.CM_Terminal.licenseName;
		self.showLicenseDetailsTerminal(_obj.CM_Terminal);
	endif;
	
epilog
	endLoad;
	if _obj &lt;&gt; null then		
		unlock(_obj);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showLicenceDetailsEDI" id="1ad1c5c3-46fa-40ba-911b-60d002c83547">
        <source>showLicenceDetailsEDI(_root : CM_Root) protected;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
	canDo		: Boolean;
	ediFileType	: CM_EDIFileType;
	camProtDesc	: CM_CamProtocolDesc;
	idx,
	color1,
	color2,
	theColor, bundle	: Integer;
	tmpDict		: CM_EDIFileTypeByNameDict;
	tmpCAMDict	: CM_CamProtocolDescByNameDict;
begin

	self.tblDetails.rows := 0;

	//EDI
	// ### JIRA 33505 06JAN2025 NAVAB1 // ### JIRA 33957 13FEB2025 NAVAB1 moved this up incase there is an exception in the following call
	self.showLicenseExpiry(ProductCode_JMT_EDI);

	if (not _root.isLicensedForProductCode(ProductCode_JMT_EDI)) then
		tblDetails.addItem(app.getErrorString(LicenseDetailsNotYetEntered));
		return;
	endif;
	
	/*// ### JIRA 33503 31DEC2024 NAVAB1
	color1		:= self.colorRow1;
	color2		:= self.colorRow2;
	theColor	:= color1;
*/

	tmpDict := self.myEDIFileTypeAgent.allEDIFileTypes;

	foreach ediFileType in tmpDict do

		canDo := _root.canDoEDIFileType(ediFileType.type);
		idx := self.tblDetails.addItemObject(ediFileType, ediFileType.name &amp; Tab &amp; canDo.getYesNo());
		/*// ### JIRA 33503 31DEC2024 NAVAB1
		if theColor = color1 then
			theColor := color2;
		else
			theColor := color1;
		endif;
		*/
		
		// ### JIRA 33503 31DEC2024 NAVAB1
		bundle := ediFileType.getEDIBundle(); 
		theColor := ediFileType@getColourForRow(bundle);
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;


	//CAMS

	tmpCAMDict := self.myEDIFileTypeAgent.allCAMProtocolDescs;

	foreach camProtDesc in tmpCAMDict do

		canDo := _root.canDoEDIFileType(camProtDesc.type);
		idx := self.tblDetails.addItemObject(camProtDesc, camProtDesc.name &amp; Tab &amp; canDo.getYesNo());
		
		/*// ### JIRA 33503 31DEC2024 NAVAB1
		if theColor = color1 then
			theColor := color2;
		else
			theColor := color1;
		endif;
		*/
		
		// ### JIRA 33503 31DEC2024 NAVAB1
		bundle := camProtDesc.getEDIBundle(); 
		theColor := camProtDesc.getColourForRow(bundle); 
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;


	
end;</source>
        <access>protected</access>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="showLicenceDetailsEWS" id="5759c674-5399-493f-a0ca-fcc34d481fa6">
        <updating/>
        <source>showLicenceDetailsEWS(_root : CM_Root) updating, protected ;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33545
*/

vars
	canDo		: Boolean;
	ewsType	: CM_ExternalWebServiceType;
	endpointType	: CM_EWSEndpointType;
	idx,
	color1,
	color2,
	theColor	: Integer;
	tmpDict		: CM_ExtWebServiceTypeByType;
	tmpEPDict	: CM_EWSEndpointTypebyType;
	lclDate : Date;
	lclRoot : CM_Root;
begin
	self.tblDetails.rows := 0;
	//EWS
	// ### JIRA 33505 06JAN2025 NAVAB1 // ### JIRA 33957 13FEB2025 NAVAB1 moved this up incase there is an exception in the following call
	self.showLicenseExpiry(ProductCode_EWS);

	if (not _root.isLicensedForProductCode(ProductCode_EWS)) then
		tblDetails.addItem(app.getErrorString(LicenseDetailsNotYetEntered));
		return;
	endif;
	
	color1		:= self.colorRow1;
	color2		:= self.colorRow2;
	theColor	:= color1;

	
	tmpDict := self.myEWSTypeAgent.allEWSTypesByType;
	lclRoot := _root;
	
	foreach ewsType in tmpDict do

		canDo := lclRoot.canDoEWSType(ewsType.type, lclDate);
		// ### JIRA 34135 21JAN2025 NAVAB1 changed yes/no 'expired' 'valid until'
		if canDo then
			idx := self.tblDetails.addItemObject(ewsType, ewsType.name &amp; Tab &amp;  " Yes (valid until " &amp; lclDate.format("dd MMM yyyy") &amp; " )");
		else
// ### JIRA 33957 12FEB2025 NAVAB1			idx := self.tblDetails.addItemObject(ewsType, ewsType.name &amp; Tab &amp; canDo.getYesNo());
			if lclDate.isValid() then
				idx := self.tblDetails.addItemObject(ewsType, ewsType.name &amp; Tab &amp;  " No (expired " &amp; lclDate.format("dd MMM yyyy") &amp; " )" );
			else
				idx := self.tblDetails.addItemObject(ewsType, ewsType.name &amp; Tab &amp; " No"); // &amp; " ( to " &amp; lclDate.format("dd MMM yyyy") &amp; " )" );
			endif;
		endif;
		
		// ### JIRA 33503 31DEC2024 NAVAB1
		theColor := ewsType.getColourForRow();
		tblDetails.accessRow(idx).foreColor := theColor.getInverseColour();
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;


	//ENDPOINT

	tmpEPDict := self.myEWSTypeAgent.allEWSEndpointTypeByType;

	foreach endpointType in tmpEPDict do

		canDo := lclRoot.canDoEWSType(endpointType.type, lclDate);

		// ### JIRA 34135 21JAN2025 NAVAB1 changed yes/no 'expired' 'valid until'
		if canDo then
			idx := self.tblDetails.addItemObject(endpointType, endpointType.name &amp; Tab &amp;  " Yes (valid until " &amp; lclDate.format("dd MMM yyyy") &amp; " )");
		else
			// ### JIRA 33957 12FEB2025 NAVAB1idx := self.tblDetails.addItemObject(endpointType, endpointType.name &amp; Tab &amp; canDo.getYesNo());
			if lclDate.isValid() then
				idx := self.tblDetails.addItemObject(endpointType, endpointType.name &amp; Tab &amp;  " No (expired " &amp; lclDate.format("dd MMM yyyy") &amp; " )" );
			else
				idx := self.tblDetails.addItemObject(endpointType, endpointType.name &amp; Tab &amp; " No"); // &amp; " ( to " &amp; lclDate.format("dd MMM yyyy") &amp; " )" );
			endif;
		endif;
		
		// ### JIRA 33503 31DEC2024 NAVAB1
		theColor := endpointType.getColourForRow();
		tblDetails.accessRow(idx).foreColor := theColor.getInverseColour();
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;


	
end;</source>
        <access>protected</access>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="showLicenceDetailsSubs" id="6ff6f1dc-e556-4ccc-81d8-9f0d9ca53d31">
        <source>showLicenceDetailsSubs(_root : CM_Root) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2020	jlgndl1	Initial creation	TFS 49569
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
*/

vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	permDict	: CM_PermissionObjectByNameDict;
	canDo		: Boolean;
	isLicensed	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue,
	tmpNum		: Integer;
	subsExpDate : Date;
	licenseName : String;
	prodCode : String;

begin

	tblDetails.rows := 0;

	// ### JIRA 33505 06JAN2025 NAVAB1 // ### JIRA 33957 13FEB2025 NAVAB1 moved this up incase there is an exception in the following call
	self.showLicenseExpiry(ProductCode_Subs);

	if (not _root.isLicensedForProductCode(ProductCode_JMT)) then
		tblDetails.addItem(app.getErrorString(LicenseDetailsNotYetEntered));
		return;
	endif;
	
	if self.cmbLicenseFor.text = ProductStr_JMT_EDI then
		self.showLicenceDetailsEDI(_root);
		return;
	endif;
	
	/*// ### JIRA 33503 31DEC2024 NAVAB1
	color1		:= self.colorRow1;
	color2		:= self.colorRow2;
	theColor	:= color1;
	*/
	
	create permAgent transient;
	permAgent.populatePermissionDict(false, true, 4);	//PermType_Subscriptions  in DEVSchema
	permDict := permAgent.allPermissionsByName;
	licenseName := app.myRoot.licenseName;
	prodCode := 'SUBS';
	
	foreach permObj in permDict do
		tmpValue := permObj.constValue;

		tmpNum := tmpValue - Mod_BaseView;
		canDo := app.myCheckerObject.sendMsgWithIOParams('isSubsLicensed', licenseName, prodCode, tmpNum, subsExpDate ).Boolean;
		
		// ### JIRA 34135 21JAN2025 NAVAB1 changed 'valid until'
		if subsExpDate &lt;&gt; null then
			if canDo then
				idx := tblDetails.addItem( permObj.description &amp; Tab &amp; canDo.getYesNo &amp; " (valid until " &amp; subsExpDate.format("dd MMM yyyy") &amp; " )" );
			else
				idx := tblDetails.addItem( permObj.description &amp; Tab &amp; canDo.getYesNo &amp; " (expired " &amp; subsExpDate.format("dd MMM yyyy") &amp; " )" );
			endif;
		else
			idx := tblDetails.addItem( permObj.description &amp; Tab &amp; canDo.getYesNo );
		endif;
		
		/*// ### JIRA 33503 31DEC2024 NAVAB1
		if theColor = color1 then
			theColor := color2;
		else
			theColor := color1;
		endif;
		*/
		// ### JIRA 33503 31DEC2024 NAVAB1
		theColor := permObj.getColourForRow();
		tblDetails.accessRow(idx).foreColor := theColor.getInverseColour();
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;

epilog

	delete permAgent;
	
end;</source>
        <access>protected</access>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="showLicenseDetailsRoot" id="8c480a54-a2a4-41c6-8676-53f36568dea6">
        <updating/>
        <source>showLicenseDetailsRoot(_root : CM_Root) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	permDict	: CM_PermissionObjectByNameDict;
	hasEDIBaseBundle,
	canDo		: Boolean;
	isLicensed	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue,
	tmpNum		: Integer;
	licenseName: String;
	expDate : Date;
	ediFileType	: CM_EDIFileType;
	camProtDesc	: CM_CamProtocolDesc;
	tmpDict		: CM_EDIFileTypeByNameDict;
	tmpCAMDict	: CM_CamProtocolDescByNameDict;
begin
	
	tblDetails.rows := 0;
	tblDetails.sortColumn[1] := 1; // ### JIRA 33503 31DEC2024 NAVAB1 no sorting

	// ### JIRA 33505 06JAN2025 NAVAB1 // ### JIRA 33957 13FEB2025 NAVAB1 moved this up incase there is an exception in the following call
	self.showLicenseExpiry(ProductCode_JMT);

	if (not _root.isLicensedForProductCode(ProductCode_JMT)) then
		tblDetails.addItem(app.getErrorString(LicenseDetailsNotYetEntered));
		return;
	endif;
	
	if self.cmbLicenseFor.text = ProductStr_JMT_EDI then
		self.showLicenceDetailsEDI(_root);
		return;
	endif;
	
	//18 Jun 2020	NDL	TFS 49569
	if self.cmbLicenseFor.text = ProductStr_SUBS then
		self.showLicenceDetailsSubs(_root);
		return;
	endif;
	
	// ### JIRA 33545 12DEC2024 NAVAB1
	if self.cmbLicenseFor.text = ProductStr_EWS then
		self.showLicenceDetailsEWS(_root);
		return;
	endif;
	
	
	
	/*// ### JIRA 33503 31DEC2024 NAVAB1
	color1		:= self.colorRow1;
	color2		:= self.colorRow2;
	theColor	:= color1;
`*/
	create permAgent transient;
	permAgent.populatePermissionDict(false, true, 0);
	permDict := permAgent.allPermissionsByName;
	
	foreach permObj in permDict do
		tmpValue := permObj.constValue;
		if tmpValue = Mod_BaseView then
			continue;
		endif;
		if tmpValue = PmNum01 or
		   tmpValue = PmNum02 or
		   tmpValue = PmNum03 or
		   tmpValue = PmNum04 or
		   tmpValue = PmNum05 or
		   tmpValue = PmNum06 or
		   tmpValue = PmNum07 or
		   tmpValue = PmNum08 or
		   tmpValue = PmNum09 or
		   tmpValue = PmNum10 or
		   tmpValue = PmAdmInternal then
			continue;
		endif;

		// ### JIRA 33503 31DEC2024 NAVAB1
		if not permObj.showInLicenseApp(self.txtName.text.trimBlanks()) then
			continue;
		endif;
		
		tmpNum := tmpValue - Mod_BaseView;
		canDo := app.myCheckerObject.sendMsgWithParams('isLicensed', app.myRoot.licenseName, 'JMT', tmpNum).Boolean;
		//		canDo := _root.canDo(permObj.constValue);
		/* // ### JIRA 33503 31DEC2024 NAVAB1
		if theColor = color1 then
			theColor := color2;
		else
			theColor := color1;
		endif;
		*/
		theColor := permObj.getColourForRow();
		if tmpValue = Mod_BaseSystem then
			idx := tblDetails.addItem(" " &amp; permObj.description &amp; Tab &amp; canDo.getYesNo);
		else
			idx := tblDetails.addItem(permObj.description &amp; Tab &amp; canDo.getYesNo);
		endif;
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;
	
	idx := tblDetails.addItem(" " &amp; app.getErrorString(Number_Of_Terminals) &amp; Tab &amp; _root.numTerminalsAllowed.String);
	/* // ### JIRA 33503 31DEC2024 NAVAB1
	if theColor = color1 then
		theColor := color2;
	else
		theColor := color1;
	endif;
	*/
	
	// ### JIRA 33503 31DEC2024 NAVAB1
	theColor := PaleGreen;
	tblDetails.accessRow(idx).foreColor := theColor.getInverseColour();
	tblDetails.accessRow(idx).backColor := theColor;
	
	//23/12/2024	navkc1 JIRA Story MTN-33491 - Row for EDI Base Bundle
	// EDI
	tmpDict := self.myEDIFileTypeAgent.allEDIFileTypes;
	foreach ediFileType in tmpDict do
		canDo := _root.canDoEDIFileType(ediFileType.type);
		if canDo then
			hasEDIBaseBundle := true;
			break;
		endif;
	endforeach;
	
	// CAMS
	if not hasEDIBaseBundle then
		tmpCAMDict := self.myEDIFileTypeAgent.allCAMProtocolDescs;
		foreach camProtDesc in tmpCAMDict do
			
			canDo := _root.canDoEDIFileType(camProtDesc.type);
			if canDo then
				hasEDIBaseBundle := true;
				break;
			endif;
		endforeach;
	endif;
	
	//23/12/2024	navkc1 JIRA Story MTN-33491 Row for EDI Base Bundle
	idx := self.tblDetails.addItem("EDI " &amp; CM_EDIFileType@getEDIBundleStr(CM_EDIFileType.EDI_Bundle_BASE) &amp; Tab &amp; hasEDIBaseBundle.getYesNo());
	theColor := PaleGreen;
	self.tblDetails.accessRow(idx).backColor := theColor;
	self.tblDetails.accessRow(idx).foreColor := theColor.getInverseColour();
	
epilog
	delete permAgent;
	
end;</source>
        <access>protected</access>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="showLicenseDetailsTerminal" id="3fb7819a-fbff-4a0d-abf1-036c8c2dc0a9">
        <source>showLicenseDetailsTerminal(_terminal : CM_Terminal) protected;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	permDict	: CM_PermissionObjectByNameDict;	
	canDo		: Boolean;
	isLicensed	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;

begin

	tblDetails.rows := 0;

	if (not _terminal.isLicensed) then
		tblDetails.addItem(app.getErrorString(LicenseDetailsNotYetEntered));
		return;
	endif;
	
	color1		:= self.colorRow1;
	color2		:= self.colorRow2;
	theColor	:= color1;

	create permAgent transient;
	permAgent.populatePermissionDict(false, true, 0);
	permDict := permAgent.allPermissionsByName;	
	
	foreach permObj in permDict do
		tmpValue := permObj.constValue;
		if tmpValue = Mod_BaseView then
			continue;
		endif;
		if tmpValue = PmNum01 or
		   tmpValue = PmNum02 or
		   tmpValue = PmNum03 or
		   tmpValue = PmNum04 or
		   tmpValue = PmNum05 or
		   tmpValue = PmNum06 or
		   tmpValue = PmNum07 or
		   tmpValue = PmNum08 or
		   tmpValue = PmNum09 or
		   tmpValue = PmNum10 or
		   tmpValue = PmAdmInternal then
			continue;
		endif;
		canDo := _terminal.canDo(permObj.constValue);
			// RBarr 1/9/2006 Localisation changes - translate the permisisons description
//		idx := tblDetails.addItem(permObj.description &amp; Tab &amp; canDo.getYesNo);
		idx := tblDetails.addItem(permObj.getTranslatedDescription &amp; Tab &amp; canDo.getYesNo);
		if theColor = color1 then
			theColor := color2;
		else
			theColor := color1;
		endif;
		tblDetails.accessRow(idx).backColor := theColor;
	endforeach;
	
epilog
	delete permAgent;
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showLicenseExpiry" id="14e4178d-ce19-4ac6-a2cf-2ad82f1e4a91">
        <source>showLicenseExpiry(_prodCode : String);
/*
Purpose:	

Date		Who		Reason
06 January 2025	navab1	JIRA 33503
*/

vars
	licenseName: String;
	now, expDate : Date;
begin
	
	self.txtExpDate.text := ""; 
	licenseName := self.txtName.text; 
	expDate := app.myCheckerObject.sendMsgWithParams("getExpiryDate", licenseName, _prodCode).Date;
	if expDate.isValid() then
//		expDate := now + 30;
		self.txtExpDate.text := expDate.asStringJMT();
		if (expDate - now) &lt; 100 then
			self.txtExpDate.foreColor := Red;
			self.txtExpDate.enabled := true;
			self.txtExpDate.readOnly := true;
			self.txtExpDate.fontBold := true;
		else
			self.txtExpDate.foreColor := Black;
			self.txtExpDate.enabled := false;
			self.txtExpDate.readOnly := false;
			self.txtExpDate.fontBold := false;
	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_prodCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblDetails_contextMenu" id="48c23d0e-15cc-4755-aabf-ef36d876b91d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;

begin
	x1 := x;
	y1 := y;
	if not mouse then // if keyboard, use current listIndex value
		x1 := 20;
		if table.topRow &lt; 0 then
			y1 := 5;
		else
			y1 := table.positionTop();
		endif;
	endif;
	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1); // convert x, y relative to form
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false; // cancel further processing
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c497b60b-00f7-4e0d-bd6d-359d83593268">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 January 2025 10:09:21.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007781, locale);
	btnDelete.translateBubbleHelp(Xlat_0000510, locale);
	btnDelete.translateCaption(Xlat_0000512, locale);
	ckbTerminal.translateBubbleHelp(Xlat_0000511, locale);
	ckbTerminal.translateCaption(Xlat_0000513, locale);
	lblDescription.translateCaption(Xlat_0000514, locale);
	lblDetails.translateCaption(Xlat_0000515, locale);
	lblExpDate.translateCaption(Xlat_0027034, locale);
	lblKey.translateCaption(Xlat_0000516, locale);
	lblLicenseFor.translateCaption(Xlat_0000517, locale);
	lblName.translateCaption(Xlat_0000518, locale);
	mnuContext.translateCaption(Xlat_0007782, locale);
	mnuContextOutput.translateCaption(Xlat_0007783, locale);
	mnuContextPrint.translateCaption(Xlat_0007784, locale);
	mnuLegend.translateCaption(Xlat_0027035, locale);
end;</source>
    </JadeMethod>
</GUIClass>
