    <JadeMethod name="getFirstLocationImage" id="a9526020-bf56-4ae7-a1e1-ce78b86bf629">
        <source>getFirstLocationImage(): Binary;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	ica : CM_InterchangeArea;
	ta : CM_TerminalArea;
	photo : CM_Photo;
	job : CM_Job;
	terminal : CM_Terminal;
	height : Integer;
begin

	job := self.myRoadJob;
	if job = null then
		return null;
	endif;
	
	//lc := job.getFirstLocationByRequest();
	//26/08/2024	navkc1 CR 63588 Task 63589
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		terminal.findLocationFromString(job.plannedLocation, true, lc, height);
	endif;
	if lc &lt;&gt; null then
		ta := lc.getInterChangeArea();
		if ta = null then
			ta := lc.myTerminalArea;
		endif;
	endif;
	
	if ta &lt;&gt; null then
		photo := ta.getPhotoByIndex(1);
		if photo &lt;&gt; null then
			return photo.getPhotoContent();
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getFirstPreGateTime" id="b1d83d56-bcf8-4359-a3ec-faa729a81812">
        <source>getFirstPreGateTime():TimeStamp protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     Start time for first VVRD with record type VisitRecord_PreGate
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	detail	:CM_VehicleVisitRecordDetail;
begin
	detail := self.getFirstPreGateVVRD;
	
	if detail &lt;&gt; null then
		return detail.timeStart;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getFirstPreGateVVRD" id="1450d7de-e93e-4315-a9f9-ee36f8d83251">
        <source>getFirstPreGateVVRD():CM_VehicleVisitRecordDetail protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     First VVRD with record type VisitRecord_PreGate
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	detail	: CM_VehicleVisitRecordDetail;
begin
	foreach detail in self.allVehicleVisitRecordDetails do
		if detail.recordType = VisitRecord_Complete_AGate_In then
			// return first in-gate (complete a-gate (in)) that we find
			return detail;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="getFirstShipmentNumber" id="c882e479-616e-4ff3-bbfd-985a93e70708">
        <source>getFirstShipmentNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 April 2024		jlizm1	Initial creation TFS 62877 Add Shipment Number to reports

*/

vars

	ti 				: CM_TrackedItem;
	shipmentNumber 	: String;

begin

	foreach ti in self.allReleasedTrackedItems discreteLock do
		shipmentNumber := ti.shipmentNumber;
		if shipmentNumber &lt;&gt; null then
