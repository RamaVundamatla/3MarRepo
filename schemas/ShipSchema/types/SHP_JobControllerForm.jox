	btnRefresh.translateBubbleHelp(Xlat_0022772, locale);
	btnRefresh.translateCaption(Xlat_0022773, locale);
	btnResetSearch.translateCaption(Xlat_0022774, locale);
	btnSaveToolTips.translateCaption(Xlat_0022775, locale);
	btnShipDelays.translateCaption(Xlat_0022776, locale);
	btnShowSearch.translateCaption(Xlat_0022777, locale);
