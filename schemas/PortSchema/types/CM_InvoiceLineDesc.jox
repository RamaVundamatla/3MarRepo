    <JadeMethod name="addDILD" id="7c355bd8-07e9-4af4-b41a-a654b7d7e3ec">
        <updating/>
        <source>addDILD(_debtorILD : CM_DebtorInvoiceLineDesc input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.allConsolidatedDebtorInvLineD.addNoDuplicates(_debtorILD, false);
end;</source>
        <Parameter name="_debtorILD" type="CM_DebtorInvoiceLineDesc" usage="input"/>
    </JadeMethod>
    <JadeMethod name="amIMappedForDebtor" id="0e16aa9b-287e-4efb-859b-7c1e80874ee1">
        <source>amIMappedForDebtor(_debtor : CM_Debtor) : Boolean;

vars
	aDebtor : CM_Debtor;
	aMapping : CM_InvoiceLineDescMapping;
begin
	foreach aMapping in self.allInvoiceTypeMappingsByDebtor do
		if aMapping.myDebtor = _debtor then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
