    <JadeMethod name="translateForm" id="8269e47d-9384-42a7-91da-9c8ea310a189">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008035, locale);
	btnAdd.translateCaption(Xlat_0000763, locale);
	btnJRWConfigT.translateBubbleHelp(Xlat_0000757, locale);
	btnJRWConfigT.translateCaption(Xlat_0000759, locale);
	btnJRWDesignT.translateBubbleHelp(Xlat_0000758, locale);
	btnJRWDesignT.translateCaption(Xlat_0000760, locale);
	btnRemove.translateCaption(Xlat_0000764, locale);
	btnUpdate.translateCaption(Xlat_0000765, locale);
	lblFilterType.translateCaption(Xlat_0000761, locale);
	lblSelector.translateCaption(Xlat_0000766, locale);
	mnuJRW.translateCaption(Xlat_0008036, locale);
	mnuJRWDeleteRow.translateCaption(Xlat_0008037, locale);
	mnuJRWInsertRow.translateCaption(Xlat_0008038, locale);
	shtParameters.translateCaption(Xlat_0000762, locale);
	shtReportDetails.translateCaption(Xlat_0000756, locale);
end;</source>
    </JadeMethod>
