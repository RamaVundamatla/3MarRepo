    <JadeMethod name="showWorkingMovementForm" id="e93e6f10-b401-4841-9d4d-263b06cef3d6">
        <updating/>
        <source>showWorkingMovementForm(_doEdit : Boolean)updating;
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	movement : CMIF_HMS_WorkingMovement;
begin
	movement := self.tblMovements.currentMovement;
	if movement = null then
		return;
	endif;
	
	self.myAssistant.HMS_Assistant.showWorkingMovementForm(movement, movement.myWorkingVoyage, _doEdit, self.myMasterMenuAction, self.myViewController);
		
end;</source>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_contextMenu" id="1b4a77fd-fd6d-4976-8d2b-b8d1f99b2971">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars

	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_dblClick" id="2dd5f9c3-581f-4658-a545-b92a44e90d6a">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_dblClick(table: CM_DataTable input) updating;
// -------------------------------------------
// Created 17 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);
		return;
	endif;
	if self.btnEdit.enabled=true then
 		self.btnEdit.click(self.btnEdit);
 	endif;


end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_keyDown" id="d71d0c8e-2f5c-42e8-9729-cd08f0b4f381">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (keyCode=13 or keyCode=40) and tblMovements.row+1&lt;=tblMovements.rows then
  		// move selected row down one row
  		tblMovements.row:=tblMovements.row+1;
  	elseif (keyCode=38) and tblMovements.row&gt;2 then
  		// move selected row up one row
  		tblMovements.row:=tblMovements.row-1;
  	endif;
	tblMovements.rowColumnChg(tblMovements);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_rowColumnChg" id="c47cf38c-3b05-4953-b00c-ebf26eb2b09c">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_rowColumnChg(table: Table input) updating;

vars
	currRow					: Integer;
begin

	if self.tblMovements.row &gt; self.tblMovements.fixedRows then
		currRow := self.tblMovements.row;
		self.setSelectedMovement(self.tblMovements.accessRow(currRow).itemObject.CMIF_HMS_WorkingMovement);
	endif;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="ac774929-cd9d-4ea8-b49b-b97a6c93ea08">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;

vars

	theHeight,
	moved		: Real;


begin
	inheritMethod(_showCaptions);
	self.label1.top := self.topMargin + VerticalSpacing;
	self.optAllVoyages.top := self.label1.top;
	self.optSelectedVoyage.top := self.label1.top;
	theHeight := self.tblMovements.top;
	self.tblMovements.top := self.label1.top + self.label1.height + VerticalSpacing;
	moved := theHeight - self.tblMovements.top;
	self.tblMovements.height := self.tblMovements.height + moved;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="536fdd46-f56b-432b-86c2-dd8521442298">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
