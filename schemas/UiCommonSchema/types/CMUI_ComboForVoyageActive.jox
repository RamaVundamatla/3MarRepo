vars

begin
	self.endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="e37addce-16b1-4f5a-b9d3-a5d4fa98ea9c">
        <source>getDisplayString(_voy : CM_Voyage) : String;
// ---------------------------------------------------------------------------
// Created:     07 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _voy = null then
		return null;
	endif;
	
	if self.findObject(_voy) &gt; 0 then
		// Already added, use inward code instead
		if _voy.inwardCode &lt;&gt; null then
			return _voy.inwardCode &amp; Tab &amp; _voy.description;
		else
			return null; // PAR 11811, no inward code, don't show again
		endif;
	else
		//return _voy.code &amp; ' '&amp; _voy.description;
		return _voy.code  &amp; Tab &amp; _voy.description;
		
	endif;
end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="5938ee5a-5527-45fc-88dc-1213db19df5e">
        <source>includeObject(_voy : CM_Voyage) : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 26/07/2019	jlgdap1		TFS 45747 PEL1 Voyage not visible in web portal
vars
	dac : CM_DataAccessController;				// TFS 44554
	usedDac : CM_DataAccessController;			// TFS 45747

begin

	if _voy.archived then
		return false;
	endif;
	
	//if not _voy.canUserAccessForStevedore(app.getMyUser, app.myPassport, dac) then		// TFS 44554	// TFS 45747
	if not _voy.canUserAccessForStevedore(app.getMyUser, app.myPassport, usedDac, dac) then	// TFS 44554	// TFS 45747
		return false;																		// TFS 44554
	endif;																					// TFS 44554
	
	return true;

end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="3581002b-e6d6-4bf4-8d77-4e6bda39745e">
        <updating/>
        <source>init(_col : Collection; _terminal : CM_Terminal; _includeArchived : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 October 2003 by cnwrs2
//
// Parameters:	_col				the collection (CM_Terminal.allVoyageCodes)
//				_terminal			the terminal
//              _includeArchived 	true if we want to include voyages in the 
//									collection that have been archived.	
// ---------------------------------------------------------------------------
vars
	obj	: Any;
	voy	: CM_Voyage;
	str	: String;
	
begin
	self.clear();
	if _includeArchived then
		self.includeArchived := true;
		foreach obj in _col do
			voy := obj.CM_Voyage;
			str := self.getDisplayString(voy);
			if str &lt;&gt; null then
				self.addItemObject(str, voy);
			endif;
		endforeach;
	else
		self.includeArchived := false;
		foreach obj in _col where (not obj.CM_Voyage.archived) do
		
			if  obj.CM_Voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			
			voy := obj.CM_Voyage;
			str := self.getDisplayString(voy);
			if str &lt;&gt; null then
				self.addItemObject(str, voy);
			endif;
		endforeach;
	endif;
	
	self.armNotification(_terminal);

end;</source>
        <Parameter name="_col" type="Collection"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_includeArchived" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="bcbcb47d-ad93-42b3-a965-f567ca0b1de9">
        <updating/>
        <source>userNotify(combobox: ComboBox input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30/08/2012	cnwcs5	When unit tests are being run it is possible for a voyage to be deleted by the time the create/update
//						notification fires so I am arming an exception handler.
vars
	lstIdx, idx2, 
	idx				: Integer;
	str				: String;
	voyage			: CM_Voyage;
	gotException	: Boolean;		// cnwcs5 Aug 2012
begin
	if CM_Voyage.hasInstance(userInfo.Object) then
		voyage := userInfo.CM_Voyage;
	endif;

	if eventType = self.createEvent then
		on Exception do app.handleDeletedObject (exception, voyage, gotException);
		
		str := self.getDisplayString(voyage);
		
		if gotException then
			return;
		endif;
		
		if str &lt;&gt; null then
			idx := self.addItemObject(str, voyage);
		endif;

	elseif eventType = self.updateEvent then
		on Exception do app.handleDeletedObject (exception, voyage, gotException);
				
		if (not self.includeArchived) and (voyage.archived) then
			return;
		endif;

		if gotException then
			return;
		endif;

		// PAR11811 voyage may or may not be listed twice, once under code and once under inwardCode,
		// depending on form requirements, for more info refer CMUI_Assistant::setCurrentVoyageCodes();
		idx := self.findObject(voyage);
		if idx &gt; 0 then
			lstIdx := self.listIndex;
			// remove first item found then re-check
			self.removeItem(idx);
			// see if added twice
			idx2 := self.findObject(voyage);
			if idx2 &gt; 0 then
				self.removeItem(idx2);
			endif;						
			// redisplay first index found
			self.addItemAt(voyage.code &amp; Tab &amp; voyage.description, idx);
			self.itemObject[idx] := voyage;
			
			// second item found
			if idx2 &gt; 0 then
				if voyage.inwardCode &lt;&gt; null then
					// has inward code so redisplay it
					self.addItemAt(voyage.inwardCode &amp; Tab &amp; voyage.description, idx2);
					self.itemObject[idx2] := voyage;					
				endif;
			endif;
			// reset as selected item
			self.listIndex := lstIdx;
		endif;
				
	elseif eventType = self.deleteEvent then
		idx := self.findObject(voyage);
		
		if idx &lt; 1 and global.isValidObject(voyage) then
			idx := self.findString(1, self.getDisplayString(voyage));		
		endif;	
		
		if idx &gt; 0 then
			self.removeItem(idx);
		endif;
	endif;

	self.lostFocus(self);
	
	inheritMethod(combobox, eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
