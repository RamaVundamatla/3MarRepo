    <JadeMethod name="setIconRT" id="801ee77b-7c65-4f7c-aa46-6abf4ba29826">
        <source>setIconRT(yardTi : CM_TrackedItem; lPlannedLocn : String; lRT : String output);
//--------------------------------------------------------------
//Created: 20 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if yardTi.queueTaskStatus = TASK_UNACTIONED then
		lRT := "Q" ;
	elseif yardTi.queueTaskStatus = TASK_WORKING then
		lRT := "M" ;
	elseif yardTi.queueTaskStatus = TASK_OFFERED then
		lRT := "!" ;
	elseif yardTi.queueTaskStatus = TASK_ACCEPTED then
		lRT := "!" ;
	elseif yardTi.queueTaskStatus = TASK_ALLOCATED then
		lRT := "!" ;
	elseif yardTi.queueTaskStatus = TASK_PENDING then
		lRT := "!" ;
	elseif yardTi.queueTaskStatus = TASK_USER_HELD then
		lRT := "H" ;
	elseif yardTi.queueTaskStatus = TASK_SYS_HELD then
		lRT := "H" ;
	elseif lPlannedLocn &lt;&gt; "" then
		lRT := "P" ;
	endif;
		
end;</source>
        <Parameter name="yardTi" type="CM_TrackedItem"/>
        <Parameter name="lPlannedLocn" type="String"/>
        <Parameter name="lRT" type="String" usage="output"/>
    </JadeMethod>
