    <JadeMethod name="removeDeletedObject" id="452788c0-37ce-44cf-9b56-abf782c57c7d">
        <updating/>
        <source>removeDeletedObject(_object : Object)updating;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	//Check for object in docket table
	if self.tblDocketData.removeDeletedObject(_object) then
		self.resortColourTable(self.tblDocketData, 1);
		self.clearDocketEntry();
		//Reset current selected to null if it's the same as the deleted object		
		if self.myCurrentBOL = _object then
			self.setCurrentDocketEdition(null);
		endif;
	//not in docket table so check header table	
	elseif self.tblHeaderData.removeDeletedObject(_object) then
		self.resortColourTable(self.tblHeaderData, 1);
		self.clearHeaderEntry();
		//Reset current selected to null if it's the same as the deleted object
		if self.myCurrentBOLOutHdr = _object or
		   self.myCurrentScalingHdr = _object then
			self.setCurrentHeaderEdition(null);		
		endif;
	else

	endif;
	
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resetTableSelected" id="0e8d526c-436d-4027-9543-2b3cfd5ee3c6">
        <updating/>
        <source>resetTableSelected(_table : CM_DataTable input)updating;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx : Integer;
begin
	
	if _table = null then
		return;
	endif;
			
	if _table = self.tblDocketData then
		if self.myCurrentBOL &lt;&gt; null and 
		   _table.findObjectInRow(self.myCurrentBOL, rowIdx) then
			self.selectDocket(rowIdx);
		else
			self.clearDocketEntry();
		endif;
	elseif _table = self.tblHeaderData then
		if self.myCurrentBOLOutHdr &lt;&gt; null and 
		   _table.findObjectInRow(self.myCurrentBOL, rowIdx) then	
			self.selectHeader(rowIdx);
		elseif self.myCurrentScalingHdr &lt;&gt; null and 
		   _table.findObjectInRow(self.myCurrentBOL, rowIdx) then	
			self.selectHeader(rowIdx);
		else
			self.clearHeaderEntry();
		endif;
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resortColourTable" id="4c414130-3c5f-4f68-9491-b710d13c18c8">
        <source>resortColourTable(_table : CM_DataTable input; _col : Integer);
//--------------------------------------------------------------
//Created: 01 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_table.sortAscending := false;			
	_table.resortTableByColumn(_col);
	_table.colourRows(self.colorRow1, self.colorRow2);
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scaleDataAdd" id="ecb0d6e6-0406-49c9-be55-202efbed0e53">
        <updating/>
        <source>scaleDataAdd()updating;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myAssistant.LOG_Assistant.inputLogScalingData(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="scaleDataDelete" id="0c4a6ceb-2992-4498-af66-72d320ae7f32">
        <updating/>
        <source>scaleDataDelete() updating;
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	msgStr : String;
	tmpScaleHdr : CM_LogScalingHdr;
	result, edition		: Integer;

begin
	if self.myCurrentScalingHdr = null then
		app.msgBox('Please select from table the unmatched data to be deleted.','Select Unmatched Data', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;		
	endif;
	
	if self.tblHeaderData.allSelectedObjects.size &gt; 1 then 
		msgStr := 	'You have selected multiple Dockets. You can only delete one docket at a time.' &amp; CrLf &amp; 
					'Do you want to delete the last selected docket ' &amp; self.myCurrentScalingHdr.bolNumber.String &amp; ' ?';
	else 
		msgStr := 	'Are you sure you want to delete' &amp;CrLf &amp;
				'Ticket ' &amp; self.myCurrentScalingHdr.bolNumber.String &amp; ' ?';
	endif;
	
	if app.msgBox(msgStr, 'Ticket Delete', MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;

	// delete it here!!!
	app.mousePointer := MousePointer_HourGlass;		

	// par 16848 - AER 13/10/2008
	// self.myCurrentScalingHdr can be set to null by notification processing while msgBox is shown
	if self.myCurrentScalingHdr = null then
		return;		
	endif;
		
	exclusiveLock(self.myCurrentScalingHdr);
	
	tmpScaleHdr := self.myCurrentScalingHdr;
	
	while true do
		app.myTrxDA.trxDeleteLogScalingHdr(tmpScaleHdr, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.setCurrentHeaderEdition(null);
			self.clearHeaderEntry();		
			break;
		else
			result := app.showErrorWarningDialog('Delete Scale Data', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="scaleDataEdit" id="a7b762ab-8e46-42a1-bf3c-6871257cc59e">
        <updating/>
        <source>scaleDataEdit() updating;
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyTicket : CM_LogScalingHdr;
	ls	: Boolean;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.myCurrentScalingHdr = null then
		app.msgBox('Please select unmatched data to be edited.','Select Unmatched Data', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	pxyTicket := app.createUpdateProxy(self.myCurrentScalingHdr).CM_LogScalingHdr;
	self.myAssistant.LOG_Assistant.inputLogScalingData(pxyTicket);

	self.setCurrentHeaderEdition(self.myCurrentScalingHdr);
	
epilog
	delete pxyTicket;
end;</source>
    </JadeMethod>
    <JadeMethod name="scaleDataMerge" id="e2222947-7d1a-40d4-99dd-eae76447ab2a">
        <updating/>
        <source>scaleDataMerge() updating;

// cnwdvb1 02 December 2002 

vars

	first,
	second		: CM_Object;
	pxyFirst,
	pxySecond	: CM_LogScalingHdr;

begin

	if self.tblHeaderData.allSelectedObjects.size = 2 then
		first 	:= self.tblHeaderData.allSelectedObjects[1].CM_Object;
		second	:= self.tblHeaderData.allSelectedObjects[2].CM_Object;
		if first.isKindOf(CM_LogScalingHdr) and second.isKindOf(CM_LogScalingHdr) then
			pxyFirst 	:= app.createUpdateProxy(first).CM_LogScalingHdr;
			pxySecond	:= app.createUpdateProxy(second).CM_LogScalingHdr;
			if self.myAssistant.LOG_Assistant.doScalingDataMerge(pxyFirst, pxySecond) then
				self.clearErrorWarnings();
			else
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			// Stop par4380
			self.doRefresh();
			return;
		endif;
	endif;
	app.msgBox('Please select two unreconciled tickets of the same type to merge.','Select unreconciled tickets', MsgBox_Stop_Icon + MsgBox_OK_Only);
	return;
epilog
	delete pxyFirst;
	delete pxySecond;
end;</source>
    </JadeMethod>
    <JadeMethod name="scaleDataSave" id="cc1a609c-0ee8-49eb-8fcb-2fbf4a6d5f32">
        <updating/>
        <source>scaleDataSave() updating;
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	pxyScaleHdr : CM_LogScalingHdr;
	number, supplier : String;
	result		: Integer;
	invalidObj  : Boolean; 
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentScalingHdr, invalidObj); // AER 18/07/2008 Par16848
	
	app.mousePointer := MousePointer_HourGlass;
	
	if invalidObj or self.myCurrentScalingHdr = null  then
		return;
	endif;
	
	if self.myCurrentScalingHdr.edition &lt;&gt; self.headerEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Scaling Header', null, null);
		return;
	endif;
	
	if invalidObj then // AER 18/07/2008 Par16848
		return;
	endif;
	number := tblTicketEntry.getValueByName(ETRow_DocketNumber).String.toUpper();
	supplier := tblTicketEntry.getValueByName(ETRow_Supplier).String;
	
	//Check for any change, return if no change.
	if number = self.myCurrentScalingHdr.bolNumber and
	   supplier = self.myCurrentScalingHdr.operatorCode then
	   	return;
	endif;
	
	sharedLock(self.myCurrentScalingHdr);	
		
	pxyScaleHdr := app.createUpdateProxy(self.myCurrentScalingHdr).CM_LogScalingHdr;
	
	pxyScaleHdr.setProxy(number, supplier,
						 pxyScaleHdr.scalerCode,
						 pxyScaleHdr.inputDateTime,
						 pxyScaleHdr.myTerminal);

	while true do
		app.myTrxUA.trxUpdateLogScalingHdr(pxyScaleHdr, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.setCurrentHeaderEdition(self.myCurrentScalingHdr);
			break;
		else
			result := app.showErrorWarningDialog('Scaling Data', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete pxyScaleHdr;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="scaleDataSplit" id="880bcd8d-05b9-4997-a2d8-404de8534d2c">
        <updating/>
        <source>scaleDataSplit() updating;

// cnwdvb1 25 November 2002 

vars
	pxyTicket	: CM_LogScalingHdr;
	ls			: Boolean;
	
begin

	if self.myCurrentScalingHdr = null then
		app.msgBox('Please select unmatched data to be split.','Select Unmatched Data', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	app.cmsBeginLoad(ls);
	sharedLock(self.myCurrentScalingHdr);
	pxyTicket := app.createUpdateProxy(self.myCurrentScalingHdr).CM_LogScalingHdr;
	self.myAssistant.LOG_Assistant.doScalingDataSplit(pxyTicket);
	self.setCurrentHeaderEdition(self.myCurrentScalingHdr);
	
epilog

	delete pxyTicket;
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="selectDocket" id="8c4fe9c6-4c5b-4a57-a155-6b2b76f04190">
        <updating/>
        <source>selectDocket(_rowIdx : Integer) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	theObject : Object;
	logDocket : CM_BOL;
begin
	if _rowIdx &lt;= tblDocketData.fixedRows then
		return;
	endif;

	theObject := tblDocketData.accessRow(_rowIdx).itemObject;
	//CNWTH2 added - PAR #4784
	if theObject = null then
		tblDocketEntry.clearValues();
		self.txtDocket.text := null;	
		return;
	elseif theObject.isKindOf(CM_BOL) then
		logDocket := theObject.CM_BOL;
	else
		tblDocketEntry.clearValues();
		self.txtDocket.text := '';
		return;
	endif;

	tblDocketData.accessRow(_rowIdx).selected := true;	
	self.setCurrentDocketEdition(logDocket);
	// now display edit fields
	tblDocketEntry.setValueByName(ETRow_Supplier, logDocket.getOperatorCode);
	tblDocketEntry.setValueByName(ETRow_DocketNumber, logDocket.number);
	tblDocketEntry.setValueByName(ETRow_NoLogs, logDocket.numItems);
	self.showDocketDetail();

	if logDocket.isKindOf(CM_BOLOut) then
//		write 'GD ' &amp; class.name &amp; ' ' &amp; method.name &amp; ' Editing of Release Dockets not implemented.';
		self.btnEditDocket.enabled := false;
	elseif logDocket.isKindOf(CM_BOLIn) then
		self.btnEditDocket.enabled := true;	
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddReceipt.enabled:= false;
		self.btnAddRelease.enabled:= false;
		self.btnDeleteDocket.enabled:= false;
		self.btnDeleteTicket.enabled:= false;
		self.btnEditDocket.enabled:= false;
		self.btnEditTicket.enabled:= false;
		self.btnMatch.enabled:= false;
		self.btnMerge.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnSaveDocket.enabled:= false;
		self.btnSaveTicket.enabled:= false;
		self.btnSplit.enabled:= false;
		
	endif;
	
end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectHeader" id="f527cba8-3182-4377-ac6c-a6f6a5be0fdb">
        <updating/>
        <source>selectHeader(_rowIdx : Integer) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	theObject : Object;
begin

	if _rowIdx &lt;= tblHeaderData.fixedRows then
		return;
	endif;
	
	self.setCurrentHeaderEdition(null);
				
	theObject := tblHeaderData.accessRow(_rowIdx).itemObject;
	
	self.setCurrentHeaderEdition(theObject.CM_Object);
		
	// now display edit fields
	if self.myCurrentBOLOutHdr &lt;&gt; null then
		tblTicketEntry.setValueByName(ETRow_Supplier, self.myCurrentBOLOutHdr.operatorCode);
		tblTicketEntry.setValueByName(ETRow_DocketNumber, self.myCurrentBOLOutHdr.bolNumber);
	elseif self.myCurrentScalingHdr &lt;&gt; null then
		tblTicketEntry.setValueByName(ETRow_Supplier, self.myCurrentScalingHdr.operatorCode);
		tblTicketEntry.setValueByName(ETRow_DocketNumber, self.myCurrentScalingHdr.bolNumber);	
	else
		tblTicketEntry.clearValues();	
		txtTickets.text := null;
		return;
	endif;
	
	self.showHeaderDetail();
end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="26faf0ac-0fd8-4e5e-bca6-76da84926f88">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.tblDocketData.backColor := self.colorControlBack;
	self.tblHeaderData.backColor := self.colorControlBack;
	
	self.setColorsForEntryTable(self.tblDocketEntry);
	self.setColorsForEntryTable(self.tblTicketEntry);

	self.txtDocket.backColor := self.colorControlBack;
	self.txtTickets.backColor := self.colorControlBack;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setCurrentDocketEdition" id="9bcf4611-acaf-490b-8c34-06890ca79987">
        <updating/>
        <source>setCurrentDocketEdition(_theDocket : CM_BOL) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	ls : Boolean;
begin
	if _theDocket &lt;&gt; null then
		app.cmsBeginLoad(ls);
		sharedLock(_theDocket);
		self.docketEdition 	:= _theDocket.edition;
		self.myCurrentBOL	:= _theDocket;
	else
		self.docketEdition 	:= null;
		self.myCurrentBOL	:= null;
		self.txtDocket.text := '';
		self.tblDocketEntry.clearValues();				
	endif;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_theDocket" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setCurrentHeaderEdition" id="a6dc4c6f-edb6-43ab-9c7e-fcf1c8c7459a">
        <updating/>
        <source>setCurrentHeaderEdition(_theHeader : CM_Object) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
/*
Date		      Who		Reason
17 June 2008	cnwdz2	    Par16943 related to Par16807 - Use app.handleDeletedObject() to handle invalid object reference instead of isValidObject().
*/

vars
	invalidHeader  : Boolean; 
	ls : Boolean;
begin
	//To correct Par16943 related to Par16807
	//Use handleDeletedObject() to handle invalid object reference instead of isValidObject() 
	on Exception do app.handleDeletedObject(exception, _theHeader, invalidHeader);

	if _theHeader &lt;&gt; null then//and app.isValidObject(_theHeader) then//par 16807
		app.cmsBeginLoad(ls);
		sharedLock(_theHeader);
		//16848  -  AER 13/10/1008 
		//if invalid object then invaliHeader will be true -&gt; form is beeing cleared out.
		if not invalidHeader then
			self.headerEdition := _theHeader.edition;
			if _theHeader.isKindOf(CM_BOLOutHeader) then
				self.myCurrentBOLOutHdr	:= _theHeader.CM_BOLOutHeader;
			elseif _theHeader.isKindOf(CM_LogScalingHdr) then
				self.myCurrentScalingHdr := _theHeader.CM_LogScalingHdr;		
			endif;
		else
			self.headerEdition	 	 := null;
			self.myCurrentBOLOutHdr	 := null;
			self.myCurrentScalingHdr := null;
			self.txtTickets.text := '';	
			self.tblTicketEntry.clearValues();		
		endif;
	else		
		self.headerEdition	 	 := null;
		self.myCurrentBOLOutHdr	 := null;
		self.myCurrentScalingHdr := null;
		self.txtTickets.text := '';	
		self.tblTicketEntry.clearValues();			
	endif;
	
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_theHeader" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="983b397c-0dcc-4999-a55b-112081ee9cc9">
        <updating/>
        <source>setupForm() updating;
// -----------------------------------------------------------------------------
// Created:		25 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 05/11/2009	cnwmh5		PAR18688 - Add setting of tblTicketEntry's defaultRowHeight
//							attribute which is set as part of calling setEntTableDef
//							which tblTicketEntry doesn't now call.
// -----------------------------------------------------------------------------
vars
	docketTableControl, 
	ticketTableControl	: EntTableDef;
	idx					: Integer;
	terminal			: CM_Terminal;
	strTerminology		: String;
	row					: Integer;
	entRow				: EntTableRow;
	entRowTrans			: EntTableRowTransient;
	userWindow					: CM_UserWindow;
	hideRailTranfer : Boolean;
	xml , xmlValue 	: String;
begin

	inheritMethod();
	terminal := self.myTerminal;

	self.beginNotification(terminal, terminal.getTerminalEvent(BOLRecon_Create_Event), Response_Continuous, null);
	self.beginNotification(terminal, terminal.getTerminalEvent(BOLRecon_Update_Event), Response_Continuous, null);
	self.beginNotification(terminal, terminal.getTerminalEvent(BOLRecon_Matched_Event), Response_Continuous, null);
	self.beginNotification(terminal, terminal.getTerminalEvent(BOLRecon_Delete_Event), Response_Continuous, null);

	self.setupTable(self.tblDocketData);
	self.setupTable(self.tblHeaderData);
	self.tblHeaderData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblHeaderData.selectionType := CM_BaseTable.SelectionType_Row;
	
	//epr TFS 4157 28/4/17
	userWindow := app.getUserWindow(self.name, false);
	hideRailTranfer:=  true;
	
	if userWindow &lt;&gt; null then
		xml := userWindow.xmlInfo;
		xmlValue:= xml.cnEcGetTagValueOfName(self.XML_HideInterRailTransfer);
		if xmlValue &lt;&gt; null then
			hideRailTranfer:= xmlValue.Boolean;
		endif;
	endif;
	if hideRailTranfer then
		self.mnuHideRailTransfers.caption := app.getErrorString(Show_inter_termin_rail_transf );
	else
		self.mnuHideRailTransfers.caption :=app.getErrorString(Hide_inter_termin_rail_transf);
	endif;

	self.showDocketData();
	self.showHeaderData();
	
	docketTableControl := app.myController.getEntTableDef(ETDef_TALogSelection);
	self.tblDocketEntry.setEntTableDef(docketTableControl, null, 'entTableDefSetupWarning');
	self.tblDocketEntry.showHideRowsByViewName("ViewDocketRecon", CM_EntryTable.ShowHideRows, false); 
	self.tblDocketEntry.resetSize();
	self.tblDocketEntry.optimiseHeadingColumn();

	tblTicketEntry.defaultRowHeight := CM_EntryTable.EntryTableViewRowHeight;		// 05/11/2009 cnwmh5 PAR1868
	// 01/04/2011 cnwar2 #27319
	row := tblTicketEntry.addAttribute(ETRow_DocketNumber, 'Docket Number', Table.InputType_TextBox, 0, true);
	foreach entRow in tblDocketEntry.myEntTableDef.allEntTableRows do
		if entRow.name = ETRow_DocketNumber then
			// entRowTrans needs to have some params set from an entRow persistent object
			entRowTrans := tblTicketEntry.accessRow(row).itemObject.EntTableRowTransient;
			entRowTrans.setEntTableCellControl(entRow.myEntTableCellControl);
			entRowTrans.setSelf(entRow);
			break;
		endif;
	endforeach;
		
	strTerminology := app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	idx := tblTicketEntry.addAttribute(ETRow_Supplier, strTerminology, Table.InputType_TextBox, 0, true);
	tblTicketEntry.setControl(idx, self.cmbOperators2);
	self.tblTicketEntry.optimiseHeadingColumn();

	cmbSupplier.visible := false;
	cmbOperators2.visible := false;

	self.setNavigatorHeading('Unreconciled Dockets');

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddReceipt.enabled:= false;
		self.btnAddRelease.enabled:= false;
		self.btnDeleteDocket.enabled:= false;
		self.btnDeleteTicket.enabled:= false;
		self.btnEditDocket.enabled:= false;
		self.btnEditTicket.enabled:= false;
		self.btnMatch.enabled:= false;
		self.btnMerge.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnSaveDocket.enabled:= false;
		self.btnSaveTicket.enabled:= false;
		self.btnSplit.enabled:= false;
		self.tblDocketEntry.userInputEnabled := false; // TFS 2734
		self.tblTicketEntry.userInputEnabled := false; // TFS 2734
	endif;
	
	if (not app.isDevelopmentSystem) then
		app.writeStatement( class.name &amp; ' ' &amp; method.name &amp; ' Add Release button disabled for Production');
		self.btnAddRelease.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="ad527e6b-a462-486c-9d69-69047349bca0">
        <updating/>
        <source>setupTable(_table : CM_DataTable input) updating;
// -----------------------------------------------------------------------------
// Created:		25 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	table : CM_DataTable;
begin

	table := _table;
	
	table.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_DocketReconcilliation);
	table .rows := _table.fixedRows;
	table .setTblDataEntRowsFromDef(entTableDef);

	table .autoSize := Table.AutoSize_Column;
	table .alignment := Table.Alignment_Left_Middle;
	
	table .selectMode := Table.SelectMode_Row;
	table .accessMode := Table.AccessMode_Row;
	table .userInputEnabled := false;
	
	self.setColorsForTable(table);
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showDocketData" id="baa4cd2a-09d7-4fef-81e0-4cd7e7ca2717">
        <source>showDocketData();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	str : String;
	obj : Object;
	bolExt : CM_BOLExtLogIn;
	unmatchedBOLs	: CM_BOLSet;
	hideRailTranfer,
	loadStateSet : Boolean;
	backColour, idx : Integer;
begin

	hideRailTranfer:= self.mnuHideRailTransfers.caption = app.getErrorString(Show_inter_termin_rail_transf );
	
	create unmatchedBOLs transient;

	app.cmsBeginLoad(loadStateSet);	
	foreach bolExt in self.myTerminal.allLogBOLsUnmatched do
		unmatchedBOLs.add(bolExt.myBOL);
	endforeach;
	self.myTerminal.allBOLOutUnmatched.copy(unmatchedBOLs);	

	tblDocketData.rows := tblDocketData.fixedRows;
	
	foreach obj in unmatchedBOLs do
		if obj.isKindOf(CM_BOLIn) then
			if hideRailTranfer and obj.CM_BOLIn.getIsInterTermRailTransfer then
				continue;
			endif;
		endif;
		str := self.tableDataDisplayRow(tblDocketData, obj.CM_Object);
		idx := tblDocketData.addItem(str);
		tblDocketData.accessRow(idx).itemObject := obj;
	endforeach;
	tblDocketData.sortAscending := false;			
	tblDocketData.resortTableByColumn(1);
	tblDocketData.colourRows(self.colorRow1, self.colorRow2);

epilog
	app.cmsEndLoad(loadStateSet);
	delete unmatchedBOLs;
end;</source>
    </JadeMethod>
    <JadeMethod name="showDocketDetail" id="30ebfe74-ade4-4fb0-981c-3b09ea8661d2">
        <source>showDocketDetail();
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	detailStrArray 	: HugeStringArray;
	heading		 	: HugeStringArray;
	detailStr,blank 		: String;
	index,
	numRows,blankNeed			: Integer;
	ls				: Boolean;
begin

	txtDocket.text := '';
	blank:="                              ";
	if self.myCurrentBOL = null then
		return;
	endif;
	
	app.cmsBeginLoad(ls);
	sharedLock(self.myCurrentBOL);
	
	create detailStrArray transient;
	create heading transient;
	
	self.myCurrentBOL.showThumbnailData(heading, detailStrArray, self.myTerminal);

	numRows := detailStrArray.size;
	
	foreach index in 1 to numRows do
	    blankNeed := blank.length - heading[index].length;
		detailStr := detailStr &amp; heading[index] &amp; blank[1:blankNeed]&amp; Tab&amp; detailStrArray[index] &amp; CrLf;
	endforeach;
	
	txtDocket.text := detailStr;
	
epilog
	delete detailStrArray;
	delete heading;
	app.cmsEndLoad(ls);	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHeaderData" id="0374d010-db9c-45b6-b651-3b542796942a">
        <source>showHeaderData();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str 			: String;
	obj		 		: Object;
	unmatchedHdrs 	: CM_ObjectArray;
	loadStateSet 	: Boolean;
	backColour, idx : Integer;
begin

	app.cmsBeginLoad(loadStateSet);
	create unmatchedHdrs transient;
	self.myTerminal.allLogScalingHdrsUnmatched.copy(unmatchedHdrs);
	self.myTerminal.allBOLOutHeadersUnmatched.copy(unmatchedHdrs);
	
	tblHeaderData.rows := tblHeaderData.fixedRows;
		
	foreach obj in unmatchedHdrs do
		sharedLock(obj);
		str := self.tableDataDisplayRow(tblHeaderData, obj.CM_Object);
		if self.tblHeaderData.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;		
		idx := tblHeaderData.addItem(str);
		tblHeaderData.accessRow(idx).itemObject := obj;
		tblHeaderData.accessedRow.backColor := backColour;
	endforeach;

epilog
	app.cmsEndLoad(loadStateSet);
	delete unmatchedHdrs;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHeaderDetail" id="6596e452-31f3-4a70-ba99-0aec10b4bccb">
        <source>showHeaderDetail();
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	detailStrArray 	: HugeStringArray;
	detailStr 		: String;
begin
	create detailStrArray transient;
	txtTickets.text := '';
	
	if self.myCurrentScalingHdr &lt;&gt; null then
		self.myCurrentScalingHdr.setThumbnailStr(detailStrArray);
	elseif self.myCurrentBOLOutHdr &lt;&gt; null then
		self.myCurrentBOLOutHdr.getThumbnailData(detailStrArray);	
	else
		return;
	endif;
	
	foreach detailStr in detailStrArray do
		txtTickets.text := txtTickets.text &amp; CrLf &amp; detailStr;
	endforeach;

	if txtTickets.text &lt;&gt; null then
		txtTickets.text := txtTickets.text[3:end];
	endif;

epilog
	delete detailStrArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="splDockets_splitterMove" id="72928bc3-c416-4c35-a0fa-b51e7c5a5e1c">
        <controlMethod name="CMUI_SplitContainer::splitterMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splDockets_splitterMove(pSplitContainer: CMUI_SplitContainer input) updating;
//--------------------------------------------------------------
//Created: 09 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.resize();
end;</source>
        <Parameter name="pSplitContainer" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tableDataDisplayRow" id="216e6441-e251-4773-bd57-d8fe0b12ebdd">
        <source>tableDataDisplayRow(_table : CM_DataTable; _obj : CM_Object) : String;
//--------------------------------------------------------------
//Created: October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblDocketData_click" id="58ebc0a5-65a7-4f55-b717-d7efa024314d">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDocketData_click(table: Table input) updating;

vars

begin
	self.selectDocket(table.row);	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDocketData_contextMenu" id="aef7c3b9-45b5-4c06-a24d-ef80f836003a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDocketData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Date		Who		Reason
27 April 2017	cnwer1	Initial creation TFS

*/

vars
	x1, y1		: Real;
begin
	self.mnuHideRailTransfers.visible:=true;
	self.mnuInspect.visible := app.isDevelopmentSystem and app.isSpecial;
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDocketData_dblClick" id="51328a73-b55b-4f90-808a-4ada3dbd6cdf">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDocketData_dblClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	21 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if table.row &lt;= table.fixedRows then
		self.tblDocketData.resortTableByColumn(table.column);
		self.tblDocketData.colourRows(self.colorRow1, self.colorRow2);
		return;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
