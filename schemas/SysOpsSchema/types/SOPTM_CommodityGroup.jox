    <JadeMethod name="doSave" id="f87df540-aaa1-4d90-bfaa-8221ef914095">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj				:	CM_Error;
	idx					:	Integer;
	tmpListBox			:	ListBox;
	ignoreWarnings,
	isSpecialStow,
	rtnValue			:	Boolean;
	proxyCommodityGroup	:	CM_CommodityGroup;
	code,
	groupDescription	:	String;
	reeferAlerts		:	Boolean;
	timeAlert,timeMax	:	Integer;
	theForm 			: 	SOP_TableMaintForm;
	lColour				: 	Integer;
	theCommodities		:	CM_CommodityByCodeDict;
	availForEntry : Boolean;
begin
    theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	groupDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	reeferAlerts := theForm.tblInput1.getValueByName(ETRow_ReeferAlerts).Boolean;
	timeAlert := theForm.tblInput1.getValueByName(ETRow_TimeAlert).Integer;
	timeMax := theForm.tblInput1.getValueByName(ETRow_TimeMax).Integer;
	availForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean; // PAR 10008
	isSpecialStow := theForm.tblInput1.getValueByName(ETRow_IsSpecialStow).Boolean; 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CommodityGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	proxyCommodityGroup := theForm.myProxyObject.CM_CommodityGroup;
	
	create theCommodities transient;
	theForm.mulSelect1.getSelected(theCommodities);
	
	proxyCommodityGroup.setProxy(code, groupDescription, lColour, reeferAlerts, timeAlert, timeMax, theCommodities, isSpecialStow, availForEntry);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCommodityGroup( proxyCommodityGroup,theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCommodityGroup( proxyCommodityGroup,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
	
epilog
	delete theCommodities;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
