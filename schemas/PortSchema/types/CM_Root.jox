    <JadeMethod name="lookupContainerRange" id="417b59e3-c6cd-4c86-9904-cb59fe635f34">
        <source>lookupContainerRange(tiId	:	String)	:	CM_ContRange;
//Takes a tiId string, and returns a container range object == the id.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	cr	:	CM_ContRange;
	tmpStr : String;
begin

	cr := self.allContainerRanges.getAtKeyLeq(tiId);
	if cr = null then
		return null;
	endif;
	tmpStr := tiId.toUpper.trimBlanks;
  //------------------
  //Now, test that the passed in id is 
  //gt or == the LOWER value AND
  //lt or == the UPPER value
  //------------------
//	if not ((tiId.strCmpI(cr.lower) &gt;= 0) and (tiId.strCmpI(cr.upper) &lt;= 0)) then
  if (tiId &gt;= cr.lower.toUpper) and (tiId &lt;= cr.upper.toUpper) then
		return cr;
	endif;
	
	return null;

end;</source>
        <Parameter name="tiId" type="String"/>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="lookupScheduleDKPortCode" id="314ddc6f-9482-4581-bbaf-095ef0a0832d">
        <source>lookupScheduleDKPortCode( _portCodeString: String; _portDesc : String) : CM_Port;

/*

Purpose: Finding a port code for EDI from the numeric schedule D or Schedule K US port code information, we return a port object.
			we may have more than 1 port in the system with the same numeric code , if so we will try and match on the port name/desc

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2014	cnwrd1	Initial creation

*/

vars	
	aPort,
	matchedCode : CM_Port;	
	iter : Iterator;
	allPossiblePorts : CM_PortArray;
begin

	if _portCodeString = null then
		return null;
	endif;		
	
	if not _portCodeString.cnEcIsNumeric then
		return null;
	endif;
	
	create allPossiblePorts transient;
	
	iter := self.allPortsByUSLocationID.createIterator;
	

	self.allPortsByUSLocationID.startKeyGeq(_portCodeString, iter);
	
	while iter.next(aPort) do
		if aPort.usLocationID = _portCodeString then
			allPossiblePorts.add(aPort);		
		else
			// doesnt match;
			break;
		endif;
		
		
	endwhile;
	
	if allPossiblePorts.isEmpty then
		return null;
	endif;
		
	if allPossiblePorts.size = 1 then
		//found only 1 so thats great lets return that one
		return	allPossiblePorts.first.CM_Port;
	endif;

	// ok more than 1 we need to try match on port name string.
	
	foreach aPort in allPossiblePorts do
		if aPort.description.cnContains(_portDesc) then
		//is probably same.
			return aPort;
		endif;
	
	endforeach;
	
	return null;

epilog
	delete iter;
	delete allPossiblePorts;
end;</source>
        <Parameter name="_portCodeString" type="String"/>
        <Parameter name="_portDesc" type="String"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="lookupTrackedItem" id="eb2ff49e-06d6-4726-9d20-e0d12d04ad67">
        <source>lookupTrackedItem(pId : String; pCargoType : Integer; state : Integer; 
				pVoyage : String; _tryReversed : Boolean;
				pTerminal : CM_Terminal; _ignoreLocksInOtherTerminals : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     07 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTerm	: CM_Terminal;
	tmpTI	: CM_TrackedItem;
	inLoadState	: Boolean;
	
begin

	if process.isInLoadState then
		inLoadState := true;
		// release any locks to here
		endLoad;
	endif;

	if _ignoreLocksInOtherTerminals then
		on LockException do self.lookupTrackedItemLockExHandler(exception, pTerminal, tmpTerm);
	endif;

	foreach tmpTerm in self.allTerminals do
		beginLoad;
		tmpTI := tmpTerm.lookupTrackedItem(pId, pCargoType, state, pVoyage, _tryReversed);
		
		// release the locks on this terminal
		endLoad;
		if tmpTI &lt;&gt; null then
			break;
		endif;
	endforeach;

	return tmpTI;

epilog
	if inLoadState and (not process.isInLoadState) then
		beginLoad;
	else
		endLoad;
	endif;

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="state" type="Integer"/>
        <Parameter name="pVoyage" type="String"/>
        <Parameter name="_tryReversed" type="Boolean"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="_ignoreLocksInOtherTerminals" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTrackedItemLockExHandler" id="844fb2be-9a5b-4ead-b86d-546ab4c8e137">
        <source>lookupTrackedItemLockExHandler(exObj : Exception; _origTerminal, _currentTerminal : CM_Terminal) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	ObjectLocked	: Integer = 1027;
vars

begin

	if exObj.errorCode &lt;&gt; ObjectLocked then
		return Ex_Pass_Back;
	endif;

	if _origTerminal &lt;&gt; null and _origTerminal &lt;&gt; _currentTerminal then
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_origTerminal" type="CM_Terminal"/>
        <Parameter name="_currentTerminal" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="machineTypeDescription" id="7c881ad3-958d-442c-9350-0dc770f4e680">
        <source>machineTypeDescription(pType:Integer):String;

vars
	lDescription:String;
begin
	if pType = MACHINETYPE_STRADDLE then
		lDescription := "Straddle Carrier";
	elseif pType = MACHINETYPE_SIDE_LOADER then
		lDescription := "Side Loader";
	elseif pType = MACHINETYPE_FORK_LIFT then
		lDescription := "Fork Lift truck";
	elseif pType = MACHINETYPE_TOP_LIFT then
		lDescription := "Top Lifting truck";
	elseif pType = MACHINETYPE_PORTAINER_CRANE then
		lDescription := "Portainer Crane";
	elseif pType = MACHINETYPE_TRUCK_TRACTOR then
		lDescription := "Truck or Tractor";
	elseif pType = MACHINETYPE_RTG then
		lDescription := 'Rubber Tyred Gantry';
	elseif pType = MACHINETYPE_IMV then
		lDescription := 'Internal Move Vehicle';
	elseif pType = MACHINETYPE_WAGONRAIL then
		lDescription := 'Rail Wagon';
	elseif pType = MACHINETYPE_RMG then
		lDescription:= "Rail Mounted Gantry";
	endif;
	return lDescription;
end;</source>
        <Parameter name="pType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="numTerminalsAllowed" id="36ff0b97-0b8c-41e6-b19a-7e72ecdadb0a">
        <source>numTerminalsAllowed() : Integer;
// ---------------------------------------------------------------------------
// Created:     14 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	binNum	: String;

begin

	
	binNum := '0000000000';
	
	self.permCheckNum(PmNum01, binNum);
	self.permCheckNum(PmNum02, binNum);
	self.permCheckNum(PmNum03, binNum);
	self.permCheckNum(PmNum04, binNum);
	self.permCheckNum(PmNum05, binNum);
	self.permCheckNum(PmNum06, binNum);
	self.permCheckNum(PmNum07, binNum);
	self.permCheckNum(PmNum08, binNum);
	self.permCheckNum(PmNum09, binNum);
	self.permCheckNum(PmNum10, binNum);
	
	return binNum.binaryAsInteger;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="outputConfig" id="bbe929c4-2bb5-4874-8196-f11426b099df">
        <source>outputConfig( _file : File; _objArray:ObjectArray io; _exportReferences, _exportCollections, _outputEndTag : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2009	cnwjk3	Initial creation

*/

vars
	propColl	: PropertyNDict;
	terminal	: CM_Terminal;
begin

	// Next line probably belongs outside this class
	_file.writeLine("&lt;JMT_System_Config&gt;");
	
	_file.writeLine("&lt;CM_Root_file&gt;");	
	
	// output &lt;CM_Root&gt; and subfields
	inheritMethod(_file, _objArray, _exportReferences, _exportCollections, _outputEndTag);
	
	_file.writeLine("&lt;/CM_Root_file&gt;");

	_file.writeLine("&lt;CM_Terminal_file&gt;");	

	// output &lt;CM_Terminal_file&gt; and subfields
	foreach terminal in self.allTerminals do
		terminal.outputConfig(_file, _objArray, _exportReferences, _exportCollections, _outputEndTag);
	endforeach;
	
	_file.writeLine("&lt;/CM_Terminal_file&gt;");	
	
	// Next line probably belongs outside this class
	_file.writeLine("&lt;/JMT_System_Config&gt;");
	
epilog
	delete propColl;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
        <Parameter name="_outputEndTag" type="Boolean"/>
    </JadeMethod>
