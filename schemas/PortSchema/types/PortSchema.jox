        <source>auditTypeStringToEnum(_str: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin
	if _str = AuditCreated_str then
		return AuditCreated;
	elseif _str = AuditDeleted_str then
