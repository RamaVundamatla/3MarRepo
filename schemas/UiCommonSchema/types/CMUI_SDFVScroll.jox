    <JadeMethod name="scrolled" id="5e0958bb-42db-4749-9228-54413907ae25">
        <updating/>
        <source>scrolled(scroll: ScrollBar input; scrollBar: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.mySDF &lt;&gt; null then
		self.mySDF.scrollControl(ScrollBar_Vertical, scroll.value);
	endif;

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
