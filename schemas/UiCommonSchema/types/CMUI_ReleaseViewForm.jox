        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
