end;</source>
    </JadeMethod>
    <JadeMethod name="showChargesTaxTable" id="0418e275-2785-467b-bd45-668552b7767b">
        <updating/>
        <source>showChargesTaxTable(_obj:CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	frm : INV_ChargeTaxOverride;
	allInvLines : CM_InvoiceLineBySeqNumDict;
begin

	create allInvLines transient;
	self.getInvoiceLines(allInvLines);
	
	frm := app.loadForm(INV_ChargeTaxOverride, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_ChargeTaxOverride;	
	
	if frm = null then
		return;
	endif;
	
	frm.myCurrentBank  := _obj.CM_Bank;
	frm.myTerminal 		  := self.myTerminal;
	frm.initCollection(allInvLines);
	
	frm.createMyAssistant(INV_Assistant);
	frm.centreWindow();
	frm.showModal();

	// ### TFS BUG 62926 02APR2024 NAVAB1 - have turned off NOTES for big rate changes, for performance, quicker to refresh.
	if allInvLines.size &gt;= 1000 then
		self.doQuery();
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
