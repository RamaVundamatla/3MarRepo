    <JadeMethod name="getInvGroupString" id="503fe422-a304-45f5-bd40-9a5477e2bbdf">
        <source>getInvGroupString( _ti : CM_TrackedItem; _isMafi, _isTowc, _isRoro : Boolean ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

	cargoType : String;

begin

	if _isTowc then
		return "TOWC";
	endif;
	
	if _isRoro then
		return "RORO";
	endif;
	
	if _isMafi then
		if	_ti.getISOType.length &gt;= 1 then
			return "MAFI" &amp; _ti.getISOType[1:1] &amp; "0";
		endif;
	endif;

	if _ti.isContainer then
		return "CONT";
	endif;
	
	if _ti.isCar then
		return "VEH";
	endif;
		
	cargoType := _ti.cargoTypeDescr;	
	if cargoType = "BULK" then
		return "BULK";
		
	elseif cargoType = "GENERAL CARGO" then
		if _ti.getCommodityDesc = "J Pack" then
			return "JPACK";	
		else
			return "BBLK";	
		endif;
		
	endif;
	
	return null;
	
epilog

end;</source>
