    <JadeMethod name="userNotificationYardAllocLines" id="dd07fb10-371e-4381-a58f-05239fc2a00a">
        <updating/>
        <source>userNotificationYardAllocLines(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	Initial creation
28 September 2009	consw1	PAR 20063 - Invalid Object Reference Exception
*/

vars
	needRefresh	: Boolean;
	obj 		: Object;
	yalloc		: CM_YardAllocation;
	invalidYA	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, yalloc, invalidYA);
	yalloc := userInfo.CM_YardAllocation;

	if self.allYardAllocationsFilter.isEmpty
	or self.allYardAllocationsFilter.includes(yalloc) then
		if eventType = self.noteTAYardAllocationCreate
		or eventType = self.noteTAYardAllocationUpdate then
			if yalloc.allTerminalAreas.includes(self.myTerminalArea) then
				needRefresh := true;
			endif;
		endif;
		if not needRefresh then
			if eventType = self.noteTAYardAllocationDelete
			or eventType = self.noteTAYardAllocationUpdate then
				foreach obj in self.allYAObjects where obj = yalloc do
					needRefresh := true;
					break;
				endforeach;
			endif;
		endif;
	endif;
	
	if needRefresh or
	   invalidYA then
		self.drawFromNote := true;
		self.refreshYardAllocationLines();
	endif;

epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
