    <JadeMethod name="comboBoxVessel" id="bdd6a01b-2633-48bc-8955-500c36ebbd75">
        <source>comboBoxVessel(pCmb : ComboBox input; pVessel : CM_Vessel);
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	passportObj	: CM_Passport;
	vesselObj	: CM_Vessel;
	listPointer	: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	passportObj	:=	app.myPassport;
	
//	pCmb.listCollection(app.myRoot.allVessels, true, 0);
	foreach vesselObj in app.myRoot.allVessels do
		if not vesselObj.canUserAccessSelf(null, failedDAC, passportObj) then
			continue;
		endif;
		
		listPointer	:=	pCmb.addItem(self.displayEntryVessel(vesselObj));
		pCmb.itemObject[listPointer]	:=	vesselObj;
	endforeach;

	if pVessel &lt;&gt; null
	and pVessel.canUserAccessSelf(null, failedDAC, passportObj)
	and app.myRoot.allVessels.includes(pVessel)
	then
		pCmb.text		:=	self.displayEntryVessel(pVessel);
	   	pCmb.listObject	:=	pVessel;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselByName" id="eb999667-ff1e-4b33-a95d-6135f98c9732">
        <source>comboBoxVesselByName(pCmb : ComboBox input; pVessel : CM_Vessel);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 18 August 2004
//
//********************************************************************
vars
	passportObj	: CM_Passport;
	vesselObj	: CM_Vessel;
	listPointer	: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	passportObj	:=	app.myPassport;
	
	//pCmb.listCollection(app.myRoot.allVessels, true, 0);
	foreach vesselObj in app.myRoot.allVessels do
		if not vesselObj.canUserAccessSelf(null, failedDAC, passportObj) then
			continue;
		endif;
		
		listPointer	:=	pCmb.addItem(self.displayEntryVesselNameCode(vesselObj));
		pCmb.itemObject[listPointer]	:=	vesselObj;
	endforeach;
	
	pCmb.sorted	:=	true;
	
	if pVessel &lt;&gt; null
	and pVessel.canUserAccessSelf(null, failedDAC, passportObj)
	and app.myRoot.allVessels.includes(pVessel)
	then
		pCmb.text		:=	self.displayEntryVesselNameCode(pVessel);
	   	pCmb.listObject	:=	pVessel;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselSections" id="a3fe8592-773f-4279-b382-1ac720c187a8">
        <source>comboBoxVesselSections(	_cmb : CMUI_ComboBox input;
						_structure : CM_Object;
						_section : CM_VesselSection);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	section: CM_VesselSection;
	idx : Integer; 
	iter : Iterator;
begin
	_cmb.clear;
	_cmb.sorted:=false;
	
	if _structure.isKindOf(CM_VesselStructuralElements) then
		iter:=_structure.CM_VesselStructuralElements.allSections.createIterator;
	elseif _structure.isKindOf(CM_VoyageStructuralElements) then
		iter:=_structure.CM_VoyageStructuralElements.allSections.createIterator;
	endif;
	
	while iter.next(section) do
		idx:=_cmb.addItemObject(section.code,section);
	endwhile;
	
	if _section &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_section);
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_structure" type="CM_Object"/>
        <Parameter name="_section" type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselStructureType" id="40fa0e9b-eab5-4994-9f45-a73cac7c0672">
        <source>comboBoxVesselStructureType(_cmb : ComboBox input; _type : String);
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	_cmb.clear;
	
	// PAR 18023 (For NZL need to create Cellular Voyages so can pack containers and set voyage)
//	if app.getMyUser.canDo(self.myTerminal, PmShipPlanning) or
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	if app.getMyUser.canDo(self.myTerminal, Mod_CargoShip) or	//07 Oct 2019	NDL	TFS 46169
	if   app.getMyUser.canDo(self.myTerminal, Mod_CargoHandling) then
		_cmb.addItem(CellularStructureStr);
		_cmb.addItem(CellularStructureROROStr);		// PAR 21745 CCMS MES 1031
	endif;
/*
	if app.getMyUser.canDo(self.myTerminal, PmShipPlanning) then
		_cmb.addItem(CellularStructureStr);
	endif;
*/
	/* Port Everett
	if app.getMyUser.canDo(self.myTerminal, PmContainerMod) then
		_cmb.addItem(CellularStructureStr);
	endif;
	*/

	if app.getMyUser.canDo(self.myTerminal, Mod_GeneralCargo) then
		_cmb.addItem(GeneralCargoStructureStr);
	endif;
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	if app.getMyUser.canDo(self.myTerminal, Mod_Harbour) then
		_cmb.addItem(StructureTypeNullStr);
	endif;		
	
	_cmb.listIndex := _cmb.findString(0, _type);
	if _cmb.listIndex &lt; 1 and _cmb.listCount &gt; 0 then
		_cmb.listIndex := 1;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselTankContentType" id="d938ab50-13e1-4237-b70e-ca157f4d84e3">
        <source>comboBoxVesselTankContentType(	_cmb : CMUI_ComboBox input;
								_contentType : CM_VesselTankContentsType);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	contentType : CM_VesselTankContentsType;
	idx 	: Integer;
begin
	_cmb.clear;
	_cmb.sorted:=false;
	
	foreach contentType in app.myRoot.allVesselTankContentsTypes discreteLock do
		idx:=_cmb.addItemObject(contentType.code,contentType);
	endforeach;
	
	if _contentType &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_contentType);
	endif;
epilog
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_contentType" type="CM_VesselTankContentsType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselTanks" id="ea6f0b04-7d7f-4142-8870-b37783be466f">
        <source>comboBoxVesselTanks(_cmb : CMUI_ComboBox input;
					_structure : CM_Object;
					_tank : CM_VesselTank);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	vesselTank : CM_VesselTank;
	idx : Integer; 
	iter : Iterator;
begin
	_cmb.clear;
	_cmb.sorted:=false;
	
	if _structure.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
		iter:=_structure.CM_VesselStructuralElements.allTanks.createIterator;
	elseif _structure.isKindOf(CM_VoyageStructuralElements) then
		iter:=_structure.CM_VoyageStructuralElements.allTanks.createIterator;
	endif;
	
	while iter.next(vesselTank) do
		idx:=_cmb.addItemObject(vesselTank.code,vesselTank);
	endwhile;
	
	if _tank &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_tank);
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_structure" type="CM_Object"/>
        <Parameter name="_tank" type="CM_VesselTank"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVesselUnavailCode" id="ec66f4d2-6f9c-4112-bdff-ce869cfacdc7">
        <source>comboBoxVesselUnavailCode(_comboboxObj:ComboBox input; _code:String);
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	unavailabilityObj	: HMS_VesselUnavailCode;
	rootObj				: CM_Root;
	
begin
	rootObj	:=	app.myRoot;
	_comboboxObj.listCollection(rootObj.allVesselUnavailabilityCodes, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	if _code &lt;&gt; null then
		unavailabilityObj	:=	rootObj.allVesselUnavailabilityCodes[_code];
	
		if unavailabilityObj &lt;&gt; null then
			_comboboxObj.cnEcSetObjectIndex(unavailabilityObj);
		endif;
	endif;
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVisitType" id="0b62c568-f466-414d-a5ec-136352a032d9">
        <source>comboBoxVisitType(_comboboxObj:ComboBox input; _typeCode:String);
// --------------------------------------------------------------------------------
// Created:		06 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	visitTypeObj	: HMS_VisitType;
