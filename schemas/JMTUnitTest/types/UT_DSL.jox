        <Parameter name="_selectedCargoTypes" type="CM_ObjectSet"/>
        <ReturnType type="CM_DamageDefinitionCode"/>
    </JadeMethod>
    <JadeMethod name="addDamagePosition" id="11d68072-98ff-4086-a349-cf1cfaf3cdd8">
        <source>addDamagePosition(_code, _description : String; _cargoTypes, _machineTypes : ObjectSet) : CM_DamagePosition;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 23 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
vars
	pxyDamagePos,
	realDamagePos : CM_DamagePosition;
begin

	self.deleteDamagePosition(_code);								// 18/09/2012 cnwmh5
	
	create pxyDamagePos transient;
	pxyDamagePos.setProxy(_code, _description, false, _cargoTypes, _machineTypes);
	app.myTrxCA.trxCreateDamagePosition(pxyDamagePos, realDamagePos, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realDamagePos;										// 18/02/2016 cnwmh5
	
epilog
	delete pxyDamagePos;

end;</source>
