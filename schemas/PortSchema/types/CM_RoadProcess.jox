    <JadeMethod name="is1STOPVBS" id="fdded9d6-ee49-4263-8068-05a80b74686f">
        <source>is1STOPVBS():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	return self.code = self.ONESTOP_VBS;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
