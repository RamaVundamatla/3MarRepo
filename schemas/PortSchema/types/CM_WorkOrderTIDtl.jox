    <JadeMethod name="isDetailCompleted" id="e2f3ca2e-6799-4c77-ac40-aad84f156e46">
        <source>isDetailCompleted():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle : CM_WorkListEntry;
	job : CM_Job;
begin
	
	job := self.allJobs.first;
	
	if job = null then
		return false;
	endif;
	
	foreach wle in job.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.status &lt;&gt; JOB_COMPLETE then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
