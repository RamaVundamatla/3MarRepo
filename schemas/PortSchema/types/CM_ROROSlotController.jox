    <JadeMethod name="changeTrackedItemSize" id="f5abdfbc-dc5a-4de1-99a9-3e40c468f045">
        <updating/>
        <source>changeTrackedItemSize(_moveMode : Integer; _ti : CM_TrackedItem input; 
					_originalHeight, _originalLength : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2001 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newHeight, newLength: Real;
	control : CMIF_MoveController;
begin
	inheritMethod(_moveMode, _ti, _originalHeight, _originalLength, _passport);
	
	// PAR 16415 CCMS 1029
//	newLength := _ti.getLengthInUnits();
	newLength := _ti.getActualLength();
	newHeight := _ti.getHeightOfTI();
	//----------------------
	// If there is no height or length size change then ...nothing to do...
	//----------------------
	if ( (newHeight = _originalHeight) and (newLength = _originalLength) ) then
		return;
	endif;
	if self.isTIPrimaryLocation(_ti, _moveMode) = false then
		//Not primary location, quit now. They MUST change it from the primary slot
		app.raiseCMException3(Err_BackEndAlteration, _ti.id, app.getErrorString(Slot).toLower, app.getErrorString(Voyage).toLower, null, null);
		return;
	endif;
	//------------------
	//We need to create a moveController to do the work
	//------------------
	create control transient;
	control.setMyToPrimaryLocation(self);
	control.setMoveMode(_moveMode);
	control.setMyTrackedItem(_ti);
	control.setMyOriginatingLocation(self);
	control.isSystemMove := true;
	control.isResizing := true;
	//cnwth2a added this to ignore same position warning
	control.isForcedMove := true;
	//------------------------------
	// See if length attribute has changed...
	//------------------------------
	if newLength &lt;&gt; _originalLength then 
		// if extending OR retracting we need to determine how many slots.
		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_MORPH_NOT_40_FRONT, newLength.String, null, null); // PAR 21746
			return;	
		endif;
		//We dont care what happens to the height, at the end of the day you can have as many boxes as you want
	endif;
	//----------------
	//Do the move.	
	//----------------
	control.warningsHaveBeenAcknowledged := true;
	control.executeMove(_passport);
epilog
	//Cleanup
	delete control;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_originalHeight" type="Integer"/>
        <Parameter name="_originalLength" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="8656379f-a352-4fcb-ac15-ee559eac9c08">
        <updating/>
        <source>cloneMySelf(_newSlotDefn : CM_ROROSlotDefn; _copy : Boolean) : CM_ROROSlotController updating;
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars

	newMe : SelfType;
begin
	newMe := self.cloneSelfAs(CM_ROROSlotController,_copy).CM_ROROSlotController;

	newMe.mySlotDefn := _newSlotDefn.CM_ROROSlotDefnVoyage;

	return newMe;
epilog

end;</source>
        <Parameter name="_newSlotDefn" type="CM_ROROSlotDefn"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_ROROSlotController"/>
    </JadeMethod>
