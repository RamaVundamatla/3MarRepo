    <JadeMethod name="create" id="ed571d14-8e77-4022-8e6a-378921aac4a7">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	//View perm for external users - can only run pre-existing queries - no 'add-hock' queries
	//or save/update queries etc.
	self.permissionView  := PmAdmSelectorView;
	//Entry perm for normal users - can run pre-exisiting queries and create 'add-hock' queries
	//no save/update queries. Unable to specify 'unavailableAtRunTime':
	self.permissionEntry := PmAdmSelectorEntry;
	//Maint perm - can do anything they like.
	self.permissionMaint := PmAdmSelectorMaint;

	self.myQDef := app.myRoot.allQueryDefinitionObjects.first;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createAndAddCriteriaLine" id="ca30c478-642e-4ec2-9b19-610f7fef1542">
        <source>createAndAddCriteriaLine(_tblSheet : JadeTableSheet input;
						_propName : String; 
						_qOperatorStr : String; 
						_value : Any) protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	criteriaLine			: CM_SelectorCriteriaLine;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	idx						: Integer;
	
begin
	criteriaHolder := _tblSheet.itemObject.CM_QueryCriteriaLineHolder;
	criteriaLine := self.myQDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	
	if criteriaLine = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'An error occured while trying to create a criteria line for ' &amp; CrLf &amp;
																'the property (' &amp; _propName &amp; '), with operator =(' &amp; _qOperatorStr &amp; ') and value =(' &amp; _value.String &amp; ')');
		return;
	endif;
															
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	idx := _tblSheet.addItem(criteriaLine.getDescriptionString);
	_tblSheet.accessRow(idx).itemObject := criteriaLine;
	//_tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_AVAILABLE;
	_tblSheet.accessRow(idx).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891

end;</source>
        <access>protected</access>
        <Parameter name="_tblSheet" type="JadeTableSheet" usage="input"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="createDefaultCriteriaLines" id="2d2b80a6-8ccc-4dec-a3c0-04d6c1d518f8">
        <source>createDefaultCriteriaLines() protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 23/05/2013	cnwdap1		PAR #31486 Suppress Cargo Type default line for break-bulk generic queries
// 22 Dec 2022 	navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// 10 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars

	criteriaLine			: CM_SelectorCriteriaLine;
	tmpProp					: CM_QueryProperty;
	tmpOp					: CM_QueryOperator;
	parentForm				: CM_BaseForm;
	tblSheet				: JadeTableSheet;
	tbl						: CM_DataTable;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	idx						: Integer;
	invalidLine				: Boolean;
	propName				: String;
	operatorStr				: String;
	obj, obj2				: Object;
	any, value				: Any;
	ia						: IntegerArray;
	now						: Date;
	dateArray : DateArray;
begin
	parentForm := self.myParent;
	tbl := self.tblCriteria;
	tblSheet := tbl.accessSheet(tbl.topSheet);
	criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
	tblSheet.rows := tblSheet.fixedRows;
	criteriaHolder.allCriteriaByPropertyName.purge();
	now := self.systemToLocalTime(app.actualTimeServer()).date();	// 27/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	/*
		Date		Who		Reason
		11 Sep 2008	cnwdz2	Par17640 to avoid the deleted criteriaLine causing the error 4.
	*/
	on Exception do app.handleDeletedObject(exception, criteriaLine, invalidLine);
	//if the parent form that opened me has criteria lines in it's allSelectorCriteria collection, then I
	//must be "remebering" criteria previously entered by the user while the parent form has been open - so load
	//these lines instead of default criteria lines
	if (parentForm &lt;&gt; null) and (not parentForm.allSelectorCriteria.isEmpty) then
		foreach criteriaLine in parentForm.allSelectorCriteria do
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			idx := tblSheet.addItem(criteriaLine.getDescriptionString);
			tblSheet.accessRow(idx).itemObject := criteriaLine;
		//	if criteriaLine.isUnavailableAtRunTime then
		//		tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_UNAVAILABLE;
		//	else
				//tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_AVAILABLE;
				tblSheet.accessRow(idx).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
		//	endif; 
		endforeach;
		
		return;
	endif;

	if (self.myQDef.mode &gt; BOLType_Min) and (self.myQDef.mode &lt; BOLType_Max) then
		self.createAndAddCriteriaLine(tblSheet,CM_BOL::bolType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allBOLTypes[self.myQDef.mode]);
		self.createAndAddCriteriaLine(tblSheet, CM_BOL::isInward.name, CM_QueryOperator.Operator_Equal, true);
	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries		
	elseif self.myQDef.type = CM_QueryDefinition.Transaction_Query_Type then
		// somewhat arbitrary criteria - important to show that there should be some selection based on either transaction type or date
		if self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet, CM_TITransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allTransactionTypes[TRANS_TYPE_REC_SHIP]);
			self.createAndAddCriteriaLine(tblSheet, CM_TITransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet,CM_EventTransaction::myEventType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allEventTypesByType[EVT_VoyageArrival]);
			self.createAndAddCriteriaLine(tblSheet,CM_EventTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.HMSTransaction_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet,HMS_Transaction::transactionDT.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
			self.createAndAddCriteriaLine(tblSheet,CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TFS 50906
			self.createAndAddCriteriaLine(tblSheet,CMEVT_LocationActivity::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		//Start 22.12.2022 navhl20 #54350[54269]
		elseif self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet,CM_WOTransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TIPACK_CREATED]);
			self.createAndAddCriteriaLine(tblSheet,CM_WOTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		//End 22.12.2022 navhl20 #54350[54269]
		endif;
	//14 May 2014	NDL	Par 34142
	elseif self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
		// No extras for this one, terminal gets added further down.	
	//14 May 2014	NDL	Par 34142
	elseif self.myQDef.type = CM_QueryDefinition.Cash_Query_Type then
		create dateArray transient; dateArray.add(now.Date.cnEcAddMonths(-1)); dateArray.add(now.Date);
		if  self.myQDef.mode = CM_QueryDefinition.CashPayment_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet,CM_CashPayment::getReceiptDate.name, CM_QDateRange.Operator_Between, dateArray);
		elseif  self.myQDef.mode = CM_QueryDefinition.CashReceipt_Query_Mode then
			self.createAndAddCriteriaLine(tblSheet,CM_CashPayment::dateTime.name, CM_QDateRange.Operator_Between, dateArray);
		endif;
		delete dateArray;
	elseif self.myQDef.type = CM_QueryDefinition.Audit_Query_Type then // TFS 8390
		if  self.myQDef.mode = CM_QueryDefinition.Audit_Query_Mode then
		//	self.createAndAddCriteriaLine(tblSheet,CM_AuditObject::type.name, CM_QueryOperator.Operator_Equal, "Update");
			self.createAndAddCriteriaLine(tblSheet,CM_AuditObject::userCode.name, CM_QueryOperator.Operator_Equal, app.getMyUser);	//03 Sep 2019	NDL	TFS 45891 / 16 Oct 2019	NDL TFS 47013
			create dateArray transient; dateArray.add(now.Date - 1); dateArray.add(now.Date);
			self.createAndAddCriteriaLine(tblSheet,CM_AuditObject::timestamp.name, CM_QueryOperator.Operator_Between, dateArray);	//03 Sep 2019	NDL	TFS 45891
		endif;
	elseif self.myQDef.type = CM_QueryDefinition.VehicleBookingSlot_Query_Type then // 10/05/2023 navlw1 tfs 53902
		if self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
		create dateArray transient; dateArray.add(now.Date.cnEcAddMonths(-1)); dateArray.add(now.Date);
		self.createAndAddCriteriaLine(tblSheet,CM_VehicleBookingTimeSlot::bookingTSstart.name, CM_QueryOperator.Operator_Between, dateArray);
		delete dateArray;
		endif;
	else
		//if self.myQDef.mode &lt;&gt; null then																	// PAR #31486
		if self.myQDef.mode &lt;&gt; null and self.myQDef.mode &lt;&gt; self.myQDef.UserDefined_Query_Mode and not self.myQDef.isKindOf(CM_QDefTILC) and not self.myQDef.isKindOf(CM_QDefCar) then		//jlier1 TFS 64054 30/5/24
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allCargoTypesById[self.myQDef.mode]);
		endif;
		
		if self.defaultSiteStr &lt;&gt; null then
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, self.defaultSiteStr);
		else
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
		endif;
		
		if self.myDefaultVoyage &lt;&gt; null then
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, self.myDefaultVoyage);
		endif;
		
		if (not self.allDefaultBays.isEmpty) then
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::bayId.name, CM_QueryOperator.Operator_IsOneOf, self.allDefaultBays);
		endif;
		
		if (not self.allDefaultTerminalAreas.isEmpty) then 
			self.createAndAddCriteriaLine(tblSheet, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_IsOneOf, self.allDefaultTerminalAreas);
		endif;
	endif;
			
	if self.bolClass &lt;&gt; null then
		self.createAndAddCriteriaLine(tblSheet, 'isInwards', CM_QueryOperator.Operator_Equal, self.bolClass);
	endif;
		
	if self.myTerminal &lt;&gt; null then	
		if self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
			//14 May 2014	NDL	Par 34142, modified 34364 to add business unit under terminal
			if self.myQDef.mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
				self.createAndAddCriteriaLine(tblSheet, CM_InvoiceLine::getTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
				self.createAndAddCriteriaLine(tblSheet, CM_InvoiceLine::bank.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank());
			// 18/02/2023  navmv20  TFS 55649 Task 55689 - START
			elseif self.myQDef.mode = CM_QueryDefinition.Contract_Query_Mode then
				self.createAndAddCriteriaLine(tblSheet, CM_InvoiceContract::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
				self.createAndAddCriteriaLine(tblSheet, CM_InvoiceContract::myBusinessUnit.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank()); 
			// 18/02/2023  navmv20  TFS 55649 Task 55689 - END
			else
				self.createAndAddCriteriaLine(tblSheet, CM_Invoice::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
				self.createAndAddCriteriaLine(tblSheet, CM_Invoice::bank.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank());
			endif;
	
		elseif self.myQDef.type &lt;&gt; CM_QueryDefinition.Audit_Query_Type then // TFS 8390
			self.createAndAddCriteriaLine(tblSheet, 'myTerminal', CM_QueryOperator.Operator_Equal, self.myTerminal);
		endif;
	endif;
	
	// May 2011 cnwjre1 27097
	foreach idx in 1 to self.properties.size do
		propName := self.properties[idx];
		operatorStr := self.operators[idx];
		obj := self.values[idx];
		if obj.isKindOf(CM_Association) then
			value := obj.CM_Association.getValue();
			if obj.CM_Association.objectArray.size &gt; 0 then
				// extend as needed ...
				if propName = "availabilityGrade" then
					create ia transient;
				endif;
				foreach obj2 in obj.CM_Association.objectArray do
					any := obj2.CM_Association.getValue();
					if propName = "availabilityGrade" then
						ia.add(any.Integer);
					endif;
				endforeach;
				if propName = "availabilityGrade" then
					value := ia;
				endif;
			endif;
		else
			value := obj;
		endif;
		self.createAndAddCriteriaLine(tblSheet, propName, operatorStr, value);
	endforeach;
	
epilog
	delete dateArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createQueryForAllocation" id="2bdf4b13-5df8-4481-8474-3fe65e7d5d5e">
        <updating/>
        <source>createQueryForAllocation( _anAllocation : CM_YardAllocation) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2012	cnwrd1	Initial creation

*/

vars
	theAllocation 	: CM_YardAllocation;
	criteria : CM_YACriteria;
	qDef			: CM_QueryDefinition;
	tblSheet		: JadeTableSheet;
	aBool 			: Boolean;
	assoc 			: CM_Association;
	str				: String;
	aSet 			: CM_ObjectSet;
begin
	app.mousePointer := Busy;

	theAllocation := _anAllocation;
	
	create aSet transient;
	
	if theAllocation = null then
		return;
	endif;
	
	/*if br = null then
		app.msgBox('You must select a release to create a query for first', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;*/
	
/*	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	self.myQDef := qDef;
	*/
	self.resetForMode(null);
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);//there should be only one sheet at this stage
	
	// need to check a bunch of criteria and then set the querry from each. 
	
	//will be limited to what we can select for voyage allocations for now.
	
	// cargo type should be done BEFORE we get into here.
	/*criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_CargoType);
	if criteria &lt;&gt; null then				
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;*/
	
	if self.myQDef.isKindOf(CM_QDefContainer) then
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_ISO);
		if criteria &lt;&gt; null then		
			if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then			
				create aSet transient;
				criteria.myYAData.CM_YADataObjects.allObjects.copy(aSet);
				//self.addDefaultPropertyLine(CM_Container::isoType.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
				self.addDefaultPropertyLine(CM_Container::isoType.name, CM_QueryOperator.Operator_IsOneOf, aSet);
			else
				self.addDefaultPropertyLine(CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
			endif;
		endif;

		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_ISOGroup);
		if criteria &lt;&gt; null then		
			if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
				create aSet transient;
				criteria.myYAData.CM_YADataObjects.allObjects.copy(aSet);
				//self.addDefaultPropertyLine(CM_Container::isoGroup.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
				self.addDefaultPropertyLine(CM_Container::isoGroup.name, CM_QueryOperator.Operator_IsOneOf, aSet);
			else			
				self.addDefaultPropertyLine(CM_Container::isoGroup.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
			endif;
		endif;	
	
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsForty);
		if criteria &lt;&gt; null then
			if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				str := "Yes";
			else
				str := "No";
			endif;		
			create assoc transient;
			assoc.setValue(str);		
			self.addDefaultPropertyLine(CM_Container::is40.name, CM_QueryOperator.Operator_Equal, assoc);	
		endif;
		
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsOverDimension);
		if criteria &lt;&gt; null then			
			if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				str := "Yes";
			else
				str := "No";
			endif;		
			create assoc transient;
			assoc.setValue(str);		
			self.addDefaultPropertyLine(CM_Container::isOverDimensions.name, CM_QueryOperator.Operator_Equal, assoc);	
		endif;
		
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_RequiresPower);
		if criteria &lt;&gt; null then			
			if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				str := "Yes";
			else
				str := "No";
			endif;		
			create assoc transient;
			assoc.setValue(str);		
			self.addDefaultPropertyLine(CM_Container::requiresPower.name, CM_QueryOperator.Operator_Equal, assoc);	
		endif;	
	
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_WaterCooled);
		if criteria &lt;&gt; null then			
			//_combo.addItem(app.coolingTypeENumToString(ContainerAirCooled, false));			
			//_combo.addItem(app.coolingTypeENumToString(ContainerWaterCooled, false));			
			create assoc transient;		
			if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				assoc.setValue(ContainerWaterCooled);	
			else
				assoc.setValue(ContainerWaterCooled);	
			endif;
			self.createAndAddCriteriaLine(tblSheet, CM_Container::getCoolingType.name, CM_QueryOperator.Operator_Equal,assoc );		
		endif;		
	
		criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsEmpty);
		if criteria &lt;&gt; null then
			if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				str := "Yes";
			else
				str := "No";
			endif;		
			create assoc transient;
			assoc.setValue(str);		
			self.addDefaultPropertyLine( CM_Container::isEmpty.name, CM_QueryOperator.Operator_Equal, assoc);	
		endif;	
		
	endif;
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup);
	if criteria &lt;&gt; null then			
		//if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
		///	aSet.clear;
		//	criteria.myYAData.CM_YADataObjects.allObjects.copy(aSet);
			//self.addDefaultPropertyLine(CM_TrackedItem::commodityGroup.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		//	self.addDefaultPropertyLine(CM_TrackedItem::commodityGroup.name, CM_QueryOperator.Operator_IsOneOf,aSet);
		//else
		
		// commodity group can only be equal/not equal !!
			self.addDefaultPropertyLine(CM_TrackedItem::commodityGroup.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		//endif;
	endif;
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_DischargePort);
	if criteria &lt;&gt; null then			
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			create aSet transient;
			criteria.myYAData.CM_YADataObjects.allObjects.copy(aSet);
			//self.addDefaultPropertyLine(CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
			self.addDefaultPropertyLine(CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_IsOneOf, aSet);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	
		
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_Hazardous);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataString.value &lt;&gt; null then
			create assoc transient;
			assoc.setValue(criteria.myYAData.CM_YADataString.value);
			self.addDefaultPropertyLine(CM_TrackedItem::getHazardsAsString.name, CM_QueryOperator.Operator_Equal, assoc);
		endif;
/*
	
	
		if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
			str := "Yes";
		else
			str := "No";
		endif;		
		create assoc transient;
		assoc.setValue(str);		
		self.addDefaultPropertyLine(CM_TrackedItem::isHazardous.name, CM_QueryOperator.Operator_Equal, assoc);
		*/
	endif;


	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_TotalWeight);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::totalWeight.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::totalWeight.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);			
		endif;
	endif;

	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsTransShip);
	if criteria &lt;&gt; null then			
		if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
			str := "Yes";
		else
			str := "No";
		endif;		
		create assoc transient;
		assoc.setValue(str);		
		self.addDefaultPropertyLine(CM_TrackedItem::isTranshipItem.name, CM_QueryOperator.Operator_Equal, assoc);	
	endif;
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsHazardous);
	if criteria &lt;&gt; null then			
		if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
			str := "Yes";
		else
			str := "No";
		endif;		
		create assoc transient;
		assoc.setValue(str);		
		self.addDefaultPropertyLine(CM_TrackedItem::isHazardous.name, CM_QueryOperator.Operator_Equal, assoc);	
	endif;
	
	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive; *** no selector equivelant

	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_DestinationPort);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::destinationPort.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::destinationPort.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	
	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree; *** no selector equivelant
	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsThirty; *** no selector equivelant
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_BookingRef);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_Product);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	
	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_IsTwenty);*** no selector equivelant
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_TranshipToPort);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::getMyTranshipToPort.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::getMyTranshipToPort.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;

	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_SpecialStow);
	if criteria &lt;&gt; null then
		if  criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
			str := "Yes";
		else
			str := "No";
		endif;		
		create assoc transient;
		assoc.setValue(str);		
		self.addDefaultPropertyLine( CM_TrackedItem::isSpecialStow.name, CM_QueryOperator.Operator_Equal, assoc);	
	endif;
	
	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_Weight); ??

	//criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_TranshipDischPt);

	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_OperatorItem);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	
	criteria := theAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity);
	if criteria &lt;&gt; null then			
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			self.addDefaultPropertyLine(CM_TrackedItem::commodity.name, CM_QueryOperator.Operator_IsOneOf, criteria.myYAData.CM_YADataObjects.allObjects);
		else
			self.addDefaultPropertyLine(CM_TrackedItem::commodity.name, CM_QueryOperator.Operator_Equal, criteria.myYAData.CM_YADataObjects.allObjects.first);
		endif;
	endif;
	

epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="_anAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="createQueryForBulkRelease" id="db5c29c9-e174-4ba6-96d9-2589e401ce70">
        <updating/>
        <source>createQueryForBulkRelease() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2004	cnwth2
//
// Purpose:     Builds a query from the attributes of a bulk release in ISO container mode
//			 
// ----------   ----------  --------------------------------------------------
// 18/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request.
// 25/03/2024   navrv30		Bug 62640: MTN - Selector Translations
// ---------------------------------------------------------------------------
vars
	qDef			: CM_QueryDefinition;
	br				: CM_BulkRelease;
	reserve			: CM_ReserveSelection;
	tblSheet		: JadeTableSheet;
	tmpConsign		: CM_ConsigneeConsignor;
	tmpOperator		: CM_Operator;
	tmpISOType		: CM_ISOType;
	strArray		: StringArray;
begin
	app.mousePointer := Busy;

	br := self.cmbBulkRelease.listObject.CM_BulkRelease;
	reserve := self.cmbReserveDetail.listObject.CM_ReserveSelection;
	
	if br = null then
		// 25/03/2024   navrv30		Bug 62640
		app.msgBox(app.getErrorString(Must_selec_relea_creat_query_f), app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//put the whole shabang into ISO container mode first
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	self.myQDef := qDef;
	self.resetForMode(null);
	
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);//there should be only one sheet at this stage
	
	if br.myOperator &lt;&gt; null then
		self.createAndAddCriteriaLine(tblSheet, 'operatorCode', CM_QueryOperator.Operator_Equal, br.myOperator);
	endif;
	
	if br.carrierId &lt;&gt; null then
		self.createAndAddCriteriaLine(tblSheet, 'carrier', CM_QueryOperator.Operator_Equal, br.carrierId);
	endif;
	
	tmpConsign := app.myRoot.allConsigneeConsignors[br.consigneeCode];
	if tmpConsign &lt;&gt; null then
		self.createAndAddCriteriaLine(tblSheet, 'consignee', CM_QueryOperator.Operator_Equal, tmpConsign);
	endif;
	
	if reserve &lt;&gt; null then
		if reserve.myISOType &lt;&gt; null then
			self.createAndAddCriteriaLine(tblSheet, 'isoType', CM_QueryOperator.Operator_Equal, reserve.myISOType);
		elseif reserve.myISOGroup &lt;&gt; null then	//17 Apr 2012	NDL	Par 29390
			self.createAndAddCriteriaLine(tblSheet, 'isoGroup', CM_QueryOperator.Operator_Equal, reserve.myISOGroup);
		endif;
		if reserve.clean then
			self.createAndAddCriteriaLine(tblSheet, 'isClean', CM_QueryOperator.Operator_Equal, reserve.clean.getYes());
		endif;
		if not reserve.allAvailabilityGrades.isEmpty then//17 Apr 2012	NDL	Par 29390
			self.createAndAddCriteriaLine(tblSheet, 'availabilityGrade', CM_QueryOperator.Operator_IsOneOf, reserve.allAvailabilityGrades);
		endif;
		if reserve.getBOLNumber &lt;&gt; null then//17 Apr 2012	NDL	Par 29390
			self.createAndAddCriteriaLine(tblSheet, 'billOfLading', CM_QueryOperator.Operator_Equal, reserve.getBOLNumber);
		endif;
		
		
	endif;
	
	if br.consignorVoyageCode &lt;&gt; null then
		self.createAndAddCriteriaLine(tblSheet, 'consignorVoyageCode', CM_QueryOperator.Operator_Equal, br.consignorVoyageCode);
	endif;
	

	
epilog
	app.mousePointer := Idle;
	delete strArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createQueryForUnplannedLoads" id="51812007-fcc5-438f-84bb-64def7db3b3f">
        <updating/>
        <source>createQueryForUnplannedLoads( _voy : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	qDef			: CM_QueryDefinition;
	firstRequest	: CM_DeliveryRequest;
	br				: CM_BulkRelease;
	tblSheet		: JadeTableSheet;
	tmpConsign		: CM_ConsigneeConsignor;
	tmpOperator		: CM_Operator;
	tmpISOType		: CM_ISOType;
	strArray		: StringArray;
begin
	app.mousePointer := Busy;

	//put the whole shabang into ISO container mode first
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	self.myQDef := qDef;
	self.resetForMode(null);
	
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);//there should be only one sheet at this stage

//	self.createAndAddCriteriaLine(tblSheet, 'site', CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	self.createAndAddCriteriaLine(tblSheet, 'voyageCode', CM_QueryOperator.Operator_Equal, _voy);
	self.createAndAddCriteriaLine(tblSheet, 'planningState', CM_QueryOperator.Operator_NotEqual, "Planned to Load");
	
epilog
	app.mousePointer := Idle;
	delete strArray;
end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="criteriaCheck" id="10f6eb61-9772-4ece-bee8-a21fb1448779">
        <updating/>
        <source>criteriaCheck() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2022	navvt20	ChangeRequest 54937: MTN - Selector Property Auto Select
18 Aug 2023         navlc30 Bug 58329: MSL - Some properties under the selector do not get selected for use when using saved query with selector with large number of sheets
*/

vars
	idx 					: Integer;
	criteriaLine			: CM_SelectorCriteriaLine;
	queryProperty			: CM_QueryProperty;
	queryOperator			: CM_QueryOperator;
	tbl					    : CM_DataTable;
	tblSheet			    : JadeTableSheet;	
begin
	tbl 				:= self.tblCriteria;																//18.8.2023 navlc30 #58329
	tblSheet 			:= tbl.accessSheet(tbl.topSheet);													//18.8.2023 navlc30 #58329
//	foreach idx in 1 to self.tblCriteria.rows do															//18.8.2023 navlc30 #58329 
//		criteriaLine := self.tblCriteria.accessRow(idx).itemObject.CM_SelectorCriteriaLine;					//18.8.2023 navlc30 #58329
	foreach idx in 1 to tblSheet.rows do																	//18.8.2023 navlc30 #58329 
		criteriaLine := tblSheet.accessRow(idx).itemObject.CM_SelectorCriteriaLine;							//18.8.2023 navlc30 #58329
		if criteriaLine = null then
			continue;
		endif;
		queryProperty := self.myQDef.allQueryProperties[criteriaLine.myQueryProperty.propertyName];
		if queryProperty = null then
			continue;
		endif;
		queryOperator := queryProperty.allAllowedOperators[criteriaLine.myQueryOperator.description];
		if self.cmbAttr.listObject = queryProperty then
			self.tblCriteria.selectTheCurrentRow(idx);
			self.tblCriteria_click(self.tblCriteria);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
