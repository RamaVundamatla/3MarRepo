        <controlMethod name="CMUI_MoveableFrame::mouseEnter"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmSearch_mouseEnter(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	// if searcher is docked it should not be able to be moved.  relates to par9690
	if not self.isSearcherFloating then
		app.mousePointer := Window.MousePointer_Default;
		self.frmSearch.enableEvent('mouseDown', false);
	else
		app.mousePointer := Window.MousePointer_Size;
		self.frmSearch.enableEvent('mouseDown', true);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
