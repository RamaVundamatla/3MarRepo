<Class name="CM_StorageTrigger" id="d357d57d-3d55-4621-bdec-f579f2f4663d">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="attributeType" id="c1d40381-87a3-447f-a857-ba5977e458d0">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myStorageConfig" id="2d37acdd-9561-4bbe-9e64-7d885d20497b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_StorageConfig"/>
        <access>readonly</access>
        <Inverse name="CM_StorageConfig::allStorageTriggers"/>
    </ExplicitInverseRef>
    <PrimAttribute name="resetFreeStorageDays" id="d953b4a6-d1a1-4433-8d70-45cbb8112e1a">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getTriggerDescription" id="62cc2b9c-3c58-4238-8d1b-567bdb6e7384">
        <source>getTriggerDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	if self.attributeType = IMEX_EX_TO_IM then
		return IMEX_EX_TO_IM_Desc;
	elseif self.attributeType = IMEX_EX_TO_ST then
		return IMEX_EX_TO_ST_Desc;
	//08 May 2015	NDL	Par 36006
//	elseif self.attributeType = IMEX_EX_TO_TR then
//		return IMEX_EX_TO_TR_Desc;
	elseif self.attributeType = IMEX_IM_TO_EX then
		return IMEX_IM_TO_EX_Desc;
	elseif self.attributeType = IMEX_IM_TO_ST then
		return IMEX_IM_TO_ST_Desc;
	elseif self.attributeType = IMEX_IM_TO_TR then
		return IMEX_IM_TO_TR_Desc;
	elseif self.attributeType = IMEX_ST_TO_EX then
		return IMEX_ST_TO_EX_Desc;
	elseif self.attributeType = IMEX_ST_TO_IM then
		return IMEX_ST_TO_IM_Desc;
	//08 May 2015	NDL	Par 36006
//	elseif self.attributeType = IMEX_ST_TO_TR then
//		return IMEX_ST_TO_TR_Desc;
	elseif self.attributeType = IMEX_TR_TO_EX then
		return IMEX_TR_TO_EX_Desc;
	elseif self.attributeType = IMEX_TR_TO_IM then
		return IMEX_TR_TO_IM_Desc;
	elseif self.attributeType = IMEX_TR_TO_ST then
		return IMEX_TR_TO_ST_Desc;
	elseif self.attributeType = PackAsChild then
		return PackAsChild_Desc;
	elseif self.attributeType = PackAsParent then
		return PackAsParent_Desc;
	elseif self.attributeType = PackCompleteAsParent then
		return PackCompleteAsParent_Desc;
	elseif self.attributeType = StorageDebtor then
		return StorageDebtorDesc;
	elseif self.attributeType = SubTerminal then
		return SubTerminal_Desc;
	elseif self.attributeType = UnpackAsChild then
		return UnpackAsChild_Desc;
	elseif self.attributeType = VoyageChange then
		return VoyageChange_Desc;
	elseif self.attributeType = CargoSplitMerge then  	// PAR 36472
		return CargoSplitMerge_Desc;
	elseif self.attributeType = StorageTAGroup then  	// TFS 41427
		return StorageTAGroupDesc;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="546c7fc5-9467-4c58-bdef-706ab84b54d6">
        <updating/>
        <source>setForCreate(_proxyStorageTrigger : CM_StorageTrigger; 
				_realStorageConfig : CM_StorageConfig;
				_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.setForUpdate(_proxyStorageTrigger, _passport);
	self.myStorageConfig := _realStorageConfig;
epilog

end;</source>
        <Parameter name="_proxyStorageTrigger" type="CM_StorageTrigger"/>
        <Parameter name="_realStorageConfig" type="CM_StorageConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b82020d9-1fc1-4fd2-974a-8df3e4729421">
        <updating/>
        <source>setForUpdate(_proxyStorageTrigger : CM_StorageTrigger; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.attributeType := _proxyStorageTrigger.attributeType;
	self.resetFreeStorageDays := _proxyStorageTrigger.resetFreeStorageDays;
epilog

end;</source>
        <Parameter name="_proxyStorageTrigger" type="CM_StorageTrigger"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyStorageConfig" id="3f305634-a3b8-4aa5-98b6-b4628ffb0186">
        <updating/>
        <source>setMyStorageConfig(_storageConfig : CM_StorageConfig) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.myStorageConfig :=_storageConfig;
epilog

end;</source>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="438f7c6b-e9e8-488d-99c3-1cc698fb8acb">
        <updating/>
        <source>setProxy(	_attributeType : Integer; 
			_resetFreeStorageDays : Boolean; 
			_storageConfig : CM_StorageConfig) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.attributeType := _attributeType;
	self.resetFreeStorageDays := _resetFreeStorageDays;
	self.myStorageConfig := _storageConfig;
epilog

end;</source>
        <Parameter name="_attributeType" type="Integer"/>
        <Parameter name="_resetFreeStorageDays" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="toggleResetFreeStorageDays" id="2b8c0a55-5ccb-4a05-84ff-9c3d560dd743">
        <updating/>
        <source>toggleResetFreeStorageDays() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.resetFreeStorageDays:=not self.resetFreeStorageDays;
epilog

end;</source>
    </JadeMethod>
</Class>
