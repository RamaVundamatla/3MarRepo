    <JadeMethod name="contextMenu" id="0971d474-a062-4410-b3ca-5be585c62a62">
        <updating/>
        <source>contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	return self.doFrameMouseContextMenu(cntrl, conwin, mouse, x, y);
//	return inheritMethod(cntrl, conwin, mouse, x, y);
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
