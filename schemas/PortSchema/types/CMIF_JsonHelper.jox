    <JadeMethod name="formatJsonString" id="e15ea37d-1f49-43b3-bb04-52fd8fde5406">
        <source>formatJsonString(_json : String) : String;
/*

Purpose:			Format the the passed in Json string for logging

Parameters:			Json string

Return Value:		Formatted json string

Date		Who		Reason
22 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	excOccurred		: Boolean;
	returnVal		: String;
	
begin
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myJsonHelper.formatJsonString(_json.StringUtf8).String;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_json" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripStdFieldsAndFixDates" id="484f3e25-d2f8-471b-b393-c4eda8491c2d">
        <source>stripStdFieldsAndFixDates(json : String io);
/*

Purpose:			
	
	This method is used string the passed json of the base class fields which are not useful to us - ie. warningsHaveBeenAcknowledged and myTestRecordObject
	
Parameters:			

Return Value:		

Date		Who		Reason
21 February 2023	navra1	Initial creation for for TFS - 55859

*/
constants
	RegExQuotedValues = '"(.*?)"';
	//RegExDateValue = '\(\d+\)';
	RegExDateValue = 'Date\(.\d+\)';
vars	
	
	keyOrValueMatch : JadeRegexMatch;
	dateMatch : JadeRegexMatch;
	
	jsonStringLength : Integer;
	i : Integer;
	valuePortion : Boolean;
	quotesNumber    : Integer;
	
	insideValueQuotes :Boolean;
	quotedTextMatches : JadeRegexResult;
	dateMatches : JadeRegexResult;
	
	tagName, innerHtml : JadeRegexCapture;
	dateMatchCount :Integer;
	quotedTextMatchCount:Integer;
	dateValue:String;
	dateProperFormat : TimeStamp;
	secondsSinceUnixEpoch: Integer64;
	timeStampOff:TimeStampOffset;
	
begin
	
	//write "orig:" &amp; CrLf &amp;json &amp;CrLf &amp;CrLf;	
	
	//remove WarningsHaveBeenAcknowledged and MyTestRecordObject tags
	json:=json.replace__('"WarningsHaveBeenAcknowledged":false,','',false);
	json:=json.replace__('"WarningsHaveBeenAcknowledged":false','',false);
	json:=json.replace__('"MyTestRecordObject":null,','',false);
	json:=json.replace__('"MyTestRecordObject":null','',false);
	
	//write "stripped:" &amp; CrLf &amp;json &amp;CrLf &amp;CrLf;		
	
	//Get all quoted text(keys, values, etc) 
	quotedTextMatchCount := JadeRegex@findAll(json, RegExQuotedValues, true, true, quotedTextMatches);
									
    foreach i in 1 to quotedTextMatchCount do	
		keyOrValueMatch := quotedTextMatches.at(i);
		
		//if this value is a date, and specifically the value of a date, process it
		if keyOrValueMatch.value.pos('Date(',1) &lt;&gt; 0 then
			//write keyOrValueMatch.value;
			
			//get the millisecond value
			dateMatchCount := JadeRegex@findAll(keyOrValueMatch.value, RegExDateValue, true, true, dateMatches);
									
			if dateMatches.numMatches &gt;=1 then	//obviously there will be only one
				dateValue := dateMatches.at(1).value;
				
				//strip the "Date" from the match
				dateValue := dateValue.replace('Date','');				
				
				//strip the surrounding ( and )
				dateValue := dateValue.cnRemoveChars('()');				
				
				//dateValue.Integer64; --&gt; This will be the number of milliseconds from the UNIX epoch
				secondsSinceUnixEpoch := (dateValue.Integer64 / 1000).Integer64;
				dateProperFormat.setFromUnixEpoch(secondsSinceUnixEpoch);				
				
				if dateProperFormat.isValid then
					timeStampOff.setFromLocalTimeStamp(dateProperFormat,timeStampOff.getUTCBias());						
					json := json.replace__(keyOrValueMatch.value,'"' &amp; timeStampOff.asLocalTimeStamp().asJSONFormat() &amp; '"',false);				 
				else	
					//json := json.replace__(keyOrValueMatch.value,'"1970-01-01T00:00:00.000Z"',false);				 
					json := json.replace__(keyOrValueMatch.value,'null',false);				 
				endif;
				
			endif;
			
			delete dateMatches;
			
		endif;	
        
    endforeach;
	
	//write json;
epilog
	delete quotedTextMatches;
	delete dateMatches;
end;</source>
        <Parameter name="json" type="String" usage="io"/>
    </JadeMethod>
</Class>
