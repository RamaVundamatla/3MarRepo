    <JadeMethod name="sendOnePortVesselMovementReq" id="851b40a2-45eb-442a-a475-a99a13afdfe0">
        <updating/>
        <source>sendOnePortVesselMovementReq(_webService : CM_APIEndpointServiceDef; _type : String; _date :String; _port : String; _terminal : CM_Terminal): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jul 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev
09 Sep 2024	navdap1	TFS 66034 NSW OnePort Integration Post-Dev Demo Issues - correct activity creation / updating
*/
vars
	verb,
	endpoint,
	jsonPostData,
	url,
	resultString	: String;
	resultCode 		: Integer;
	pxyActivity 		: CM_EWSActivityQships;
	activity			: CM_EWSActivityQships;
begin
	self.createActivityHistory := false;
	url :=	 _webService.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	
	_webService.getEndpointMethodAndValue(_type, verb, endpoint);
	if verb = null or endpoint = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No verb or endpoint set up for " &amp; _type &amp; " messages", LogERROR);
		app.doRaiseAlert( _webService.name &amp; " is not set up correctly for " &amp; _type &amp; " messages");
		return resultString;
	endif;
	url := url &amp; endpoint &amp; "/" &amp; _date &amp; "/" &amp; _port;	
	
	resultString := self.doSendHTTPRequest(url, verb, self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	
	
	//Record the activity
	create pxyActivity transient;		
	pxyActivity.initialiseActivity(endpoint, _webService.getExternalWebServiceType(), _terminal, null, "G", QshipsInterface.name, null, null);
	pxyActivity.setRequest(url);
	pxyActivity.setMyExtWebServiceDef(_webService);
	
	if process.isInTransactionState then
		activity := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	else
		activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	endif;
	
	delete pxyActivity;
	
	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogERROR);
		
	elseif not resultCode.isOneOf(HttpResponseOK, HttpResponseCreated) then
		app.writeLog(method.qualifiedName &amp; "[" &amp; verb &amp; "] " &amp; url, LogINFO);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogERROR);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;		
		pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request failed", _webService.getExternalWebServiceType(), _terminal, null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		pxyActivity.setMyExtWebServiceDef(_webService);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity, app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogDEBUG);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;		
		pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request successful", _webService.getExternalWebServiceType(), _terminal, null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		pxyActivity.setMyExtWebServiceDef(_webService);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity, app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
	endif;
	
	return resultString;
epilog
	delete pxyActivity;
end;</source>
