    <JadeMethod name="displayMeasurementFields" id="528c1a59-d373-4721-b591-655bcae29dba">
        <updating/>
        <source>displayMeasurementFields() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2013	cnwndl1	Initial creation	Par 32172	

*/

vars

begin

	self.weightType := app.getDefaultMeasurementForType(Type_Weight);
	self.widthType := app.getDefaultMeasurementForType(Type_Width);
	self.heightType := app.getDefaultMeasurementForType(Type_Height);
	
	self.tblHeight.setup(Type_Height, self.backColor);
	self.tblHeight.tabKey := J_key_Tab;
	self.tblHeight.visible := true;
	
	self.tblWidth.setup(Type_Width, self.backColor);
	self.tblWidth.tabKey := J_key_Tab;
	self.tblWidth.visible := true;
	
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.tabKey := J_key_Tab;
	self.tblWeight.visible := true;

epilog

end;</source>
