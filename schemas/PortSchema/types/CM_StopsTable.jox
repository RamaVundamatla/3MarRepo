    <JadeMethod name="actionTI" id="bdb2efdf-58ba-458e-9c96-d95414ff1158">
        <updating/>
        <source>actionTI(_ti: CM_TrackedItem input; _actionType: String; _passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10 Sep 2018	jlgsl4	TFS 39133 - TSW - IM1 &amp; EX1 'all clear' message

vars
	stopIDs			: IntegerArray;
	before, after	: Integer;
begin
	//should have already established that this action is valid to perform on this TI
	create stopIDs transient;
	
	stopIDs.add(self.id);
	
	before := _ti.getAllActiveStopsSize;
	
	if _actionType = EDIAction_Add then
		//check to see if stop has already been added and cleared - if so, don't re-add
		if not _ti.hasHadStop(self.id) then
			_ti.createStops(stopIDs, false, false, _passport); //par15193 cnwrs1 oct 2007  //par 19389 cnwrs1 June 2009
		endif;
		
	elseif _actionType = EDIAction_Remove or _actionType = EDIAction_Complete then
		_ti.deleteStops(false, stopIDs, false, _passport);
	elseif _actionType = EDIAction_TSWImportAllClear or _actionType = EDIAction_TSWExportAllClear	// TFS 39133
		or _actionType = EDIAction_TSWClearance														// ### TFS 60682 (60705) 05Oct2023 NAVPW1
	then
		_ti.deleteTSWStops(stopIDs, _actionType, _passport); // TFS 39133
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid EDI Action ' &amp; _actionType);
		return false;
	endif;
	
	after := _ti.getAllActiveStopsSize;
	
	return before &lt;&gt; after;
	
epilog
	delete stopIDs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_actionType" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
