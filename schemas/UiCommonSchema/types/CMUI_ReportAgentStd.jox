    <JadeMethod name="doLoadAgeTypes" id="33b667a4-cc02-4c4c-8f33-52a64b408863">
        <source>doLoadAgeTypes(_cmb : CMUI_ComboBox input; _ageType : String) protected;
// ---------------------------------------------------------------------------
// Created:     16 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	
	_cmb.addItem(TI_AGE_FELLDATE);
	_cmb.addItem(TI_AGE_MATCHDATE);
	_cmb.addItem(TI_AGE_RECEIVEDDT);
	
	if _ageType &lt;&gt; null then
		_cmb.text := _ageType;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_AgeType, _cmb.text);
	
end;</source>
