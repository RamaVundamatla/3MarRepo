    <JadeMethod name="resolvePattern" id="276e4c22-2458-42fc-8866-7a76f35a590d">
        <source>resolvePattern(_pattern: String; _objectSet: ObjectSet input; _raiseException: Boolean); 
/*
Purpose:		PAR 35833	
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	nameDict: ObjectLongNameDict;
	name: String;
	obj: Object;
	tokens: StringArray;
	pattern: CMIF_YAPattern;
	dict : CM_TransactionTypeByDesc;
	
	type: CM_TransactionType;
begin

	if _pattern = null then
		return;
	endif;

	// If this there are wildcard patterns then just return.
	// This will need to be resolved during autoplanning
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Wildcard);
	if self.isPattern(pattern) then
		return;
	endif;

		
	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	foreach name in tokens do
		foreach type in app.myRoot.allTransactionTypesByDesc where type.description.toUpper = name do 
			if not _objectSet.includes(type) then
				_objectSet.add(type);
			endif;
		endforeach;
	endforeach;
epilog
	delete nameDict;
	delete tokens;
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
    </JadeMethod>
</Class>
