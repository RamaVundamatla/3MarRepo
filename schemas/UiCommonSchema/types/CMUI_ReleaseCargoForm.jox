    <JadeMethod name="consolidateCargo" id="d60b7837-ff14-4400-812c-65d8cfd17de8">
        <source>consolidateCargo(_originalColl : Collection; _dynaDict : DynaDictionary io);
/*

Purpose: Consolidate list of matching cargo excluding cargo assigned to specific Release request if not specified.

Parameters:			

Return Value:		

Date		Who		TFS		Reason
18 Mar 2019	jlgdi1	41721	Initial creation
27 Aug 2019	jlgdi1	46271	Removed the criteria (isOnsite, isAvailable, isChild, IMEX status) check
							as this is transfered to checkCargoAvailability method.
*/

vars
	iterator : Iterator;
	trackedItem : CM_TrackedItem;
	cmifCargo : CMIF_CargoAvailability;
	voyageCode : String;
	cargoType : Integer;
	cargoTypeDesc : String;
	commodity : String;
	operatorCode : String;
	consignee : String;
	cargoSubType : String;
	reserveForRelReq : Integer;
	reserveDetailsArray : CM_ReserveDetailArray;
	
begin
	create reserveDetailsArray transient;
	
	if _originalColl &lt;&gt; null then
		iterator := _originalColl.createIterator();
		while iterator.next(trackedItem) do 
			voyageCode := trackedItem.voyageCode;
			cargoType := trackedItem.cargoType;
			cargoTypeDesc :=  trackedItem.cargoBOLTypeDescr;
			commodity := trackedItem.commodity;
			operatorCode := trackedItem.operatorCode;
			consignee := trackedItem.consignee;
			if trackedItem.myProduct &lt;&gt; null then 
				cargoSubType := trackedItem.myProduct.code;
			endif;
			
			reserveForRelReq := getReserveCountNotForRelReq(trackedItem, reserveDetailsArray);
			
			cmifCargo := _dynaDict.getAtKey(voyageCode,
											operatorCode,
											cargoType,
											cargoSubType,
											consignee).CMIF_CargoAvailability;
			
			if cmifCargo = null then 
				create cmifCargo transient;
				cmifCargo.voyageCode := voyageCode;
				cmifCargo.cargoType := cargoType;
				cmifCargo.cargoTypeDesc := cargoTypeDesc;
				cmifCargo.cargoSubType := cargoSubType;
				cmifCargo.commodity := commodity;
				cmifCargo.operatorCode := operatorCode;
				cmifCargo.consignee := consignee;
				cmifCargo.showByType := getShowByType(trackedItem);					
				cmifCargo.totalWeight := trackedItem.totalWeight;
				cmifCargo.totalVolume := trackedItem.totalVolume;
				cmifCargo.totalQuantity := trackedItem.totalQuantity - reserveForRelReq;
				cmifCargo.myVoyage := trackedItem.myVoyage;	//21 Oct 2019	NDL	TFS 46911
				
				_dynaDict.add(cmifCargo);
			else

				cmifCargo.totalWeight := cmifCargo.totalWeight + trackedItem.totalWeight;
				cmifCargo.totalVolume := cmifCargo.totalVolume + trackedItem.totalVolume;
				cmifCargo.totalQuantity := cmifCargo.totalQuantity + (trackedItem.totalQuantity - reserveForRelReq);
			endif;
		endwhile;
	endif;
	
	getParameters(operatorCode,
				  cargoType,
				  cargoTypeDesc,
				  cargoSubType,
				  voyageCode,
				  consignee);
				  
	getCargoLeavingSite(_dynaDict,
						operatorCode,
						cargoType,
						cargoTypeDesc,
						cargoSubType,
						voyageCode);
epilog
	delete iterator;
	delete reserveDetailsArray;
end;</source>
        <Parameter name="_originalColl" type="Collection"/>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="constructErrorMsg" id="1a5488bb-a51a-4cac-8d1e-8793e597b7e0">
        <source>constructErrorMsg(_voyageCode : String;
				  _operatorCode : String;
				  _consignee : String;
				  _totalQuantity : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

vars
	errorMsg : String;
	
begin
	if _voyageCode &lt;&gt; null then 
		errorMsg := "Voyage " &amp; _voyageCode;
	endif;

	if _operatorCode &lt;&gt; null then 
		if errorMsg = null then 
			errorMsg := "Operator " &amp; _operatorCode;
		else
			errorMsg := errorMsg &amp; ", Operator " &amp; _operatorCode;
		endif;
	endif;

	if _consignee &lt;&gt; null then 
		if errorMsg = null then 
			errorMsg := "Consignee " &amp; _consignee;
		else
			errorMsg := errorMsg &amp; ", Consignee " &amp; _consignee;
		endif;
	endif;
	
	return errorMsg &amp; " is " &amp; _totalQuantity ;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_consignee" type="String"/>
        <Parameter name="_totalQuantity" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createCargoCollection" id="9cd0a805-b4f8-4199-ac3f-c2e8d32a4fc3">
        <source>createCargoCollection(_cargoCollection : DynaDictionary io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2019	jlgdi1	Initial creation

*/

begin
	_cargoCollection.setMembership(CMIF_CargoAvailability);
	_cargoCollection.addMemberKey("voyageCode", false, false);
	_cargoCollection.addMemberKey("operatorCode", false, false);
	_cargoCollection.addMemberKey("cargoType", false, false);
	_cargoCollection.addMemberKey("cargoSubType", false, false);
	_cargoCollection.addMemberKey("consignee", false, false);
	_cargoCollection.endKeys(false);
end;</source>
        <Parameter name="_cargoCollection" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createGeneratorFromTI" id="2a80d592-e43f-474e-ad8a-9a048b8fdb3f">
        <source>createGeneratorFromTI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	pxyAttachedGen      : CMGTE_Entity;
	attachedGenCont     : CMIF_FlexiGateController;
	genGte,foundGte : CMGTE_Entity;
	generator : CM_TrackedItem;
begin

	generator := self.myTI.getGenerator;
	if generator &lt;&gt; null then
		if self.myPxyGTEEntity.allChildren.isNotEmpty then
			foreach genGte in self.myPxyGTEEntity.allChildren do
				 if genGte.id = generator.id  and genGte.CMGTE_Release.cargoType = generator.cargoType then
					foundGte := genGte;
					break;
				endif;
			endforeach;	
			delete foundGte;
		endif;
	
		create pxyAttachedGen as CMGTE_Release transient;
		create attachedGenCont transient;	
		
		attachedGenCont.id := generator.id;
		attachedGenCont.description := generator.description;
		attachedGenCont.cargoType := generator.cargoType;
		attachedGenCont.operatorCode := generator.myOperator.code;
		attachedGenCont.myTerminal := self.myTerminal;
		attachedGenCont.myGeneratorType := generator.CM_Generator.myGeneratorType;		
		attachedGenCont.isoTypeCode := generator.getISOType;
		attachedGenCont.weightTotal := generator.getTareWeight;
		attachedGenCont.weightTare := generator.getTareWeight;
		attachedGenCont.myVehicle := self.myCurrentVehicleVisit.vehicle;
		attachedGenCont.myCarrier := self.myCurrentVehicleVisit.getMyCarrier;
				
		if self.myCurrentVehicleVisit.myInCMGTE_Chassis &lt;&gt; null then
			
			attachedGenCont.imexStatus := self.myCurrentVehicleVisit.myInCMGTE_Chassis.imexStatus;
			attachedGenCont.voyageCode := self.myCurrentVehicleVisit.myInCMGTE_Chassis.voyageCode;
			
			pxyAttachedGen.setPXYFromController(attachedGenCont);
			pxyAttachedGen.setParentObject(self.myCurrentVehicleVisit.myInCMGTE_Chassis);
		elseif  self.myPxyGTEEntity &lt;&gt; null then
			attachedGenCont.voyageCode := self.myPxyGTEEntity.voyageCode;
			attachedGenCont.imexStatus := self.myPxyGTEEntity.CMGTE_Release.imexStatus;
			pxyAttachedGen.CMGTE_Release.setMyVehicleVisit( self.myCurrentVehicleVisit);
			pxyAttachedGen.setPXYFromController(attachedGenCont);
			
			pxyAttachedGen.setParentObject(self.myPxyGTEEntity);	
		endif;
	endif;
epilog

	delete attachedGenCont;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearReleaseItems" id="688bc39e-725e-4bf5-bba8-7c0ae06a9ea8">
        <updating/>
        <source>doClearReleaseItems() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwjk3	Initial creation

*/

vars
	selectedCargoType : CM_CargoType;
begin
	self.myBulkRelease := null;
	self.myReserveDetail := null;
			
	self.cmbReleaseItem.clear();
	
	selectedCargoType:=self.cmbType.getObject.CM_CargoType;
	self.doBuildCargoTypes(self.cmbType);
	if selectedCargoType &lt;&gt; null then
		self.cmbType.setForObject(selectedCargoType);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadReleaseItems" id="ce85b6d0-a81f-4d6b-bbb3-d8d937a71f42">
        <source>doLoadReleaseItems(_bulkRelease: CM_BulkRelease; _reserve : CM_ReserveDetail) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwjk3	Initial creation

*/

vars
	cmb		: CMUI_FieldComboBox;
	brItem	: CM_BookingRefItem;
begin
	inheritMethod(_bulkRelease, _reserve);
	
	cmb := self.cmbReleaseItem;

	// don't reload if the release request has not changed
	if cmb.listIndex &lt;&gt; -1 and _reserve &lt;&gt; null and _bulkRelease.code &lt;&gt; self.txtRelease.getString() then  
		return;
	endif;
	cmb.clear;
	if _reserve &lt;&gt; null and _bulkRelease &lt;&gt; null then
		cmb.listCollection(_bulkRelease.allReserveDetails, true, 0);
		cmb.setForObject(_reserve);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="7bc2ab4c-7349-4614-97ad-a02e6b24894f">
        <updating/>
        <source>doNext() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2009	cnwjk3	Initial creation
04/09/2013	cnwdap1	PAR #32379 Restore cargo ID list
4/11/2022 	navvt20 Bug 55317: MTN - Save next when "Any ID" Checkbox is selected on road gate causes screen to revert to previous state with the checkbox still selected
*/
vars

begin
	if self.doSave() then
		self.resetForm();
		self.txtCargoID.setValue(null);
		self.txtNumItemsBB.setValue(null);
		self.enableByTypeFields(true);
		
		self.chkAnyId.setValue(false); //4 November 2022 navvt20 TFS 55317
		
		//epr par  32483 13/9/13
		if self.hasBulkRelease() then
			self.setFieldsFromBulkRelease();
		endif;
		//self.setAvailableTIs(self.myBulkRelease);			// PAR #32379
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenCloseSection" id="b9ba9a4c-d198-4a8e-a2c3-8c05c81e59b8">
        <updating/>
        <source>doOpenCloseSection(_sectionFrame: CMUI_FieldFrame; _nextSectionFrame: CMUI_FieldFrame; _button : CMUI_Button input; _opening : Boolean io) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2009	cnwdap1	Initial creation
*/
vars

begin
	// are we opening or closing
	if _sectionFrame = self.lblReleaseById then
		_opening := self.closedReleaseById;
		self.closedReleaseById := not _opening;
	elseif _sectionFrame = self.lblReleaseByType then
		_opening := self.closedReleaseByType;
		self.closedReleaseByType := not _opening;
	elseif _sectionFrame = self.lblUpdateCargo then
		_opening := self.closedUpdateCargo;
		self.closedUpdateCargo := not _opening;
	endif;
	inheritMethod(_sectionFrame, _nextSectionFrame, _button, _opening);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_nextSectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_button" type="CMUI_Button" usage="input"/>
        <Parameter name="_opening" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="abeb3bd7-f28b-4b13-a6e4-268a5562afc7">
        <updating/>
        <source>doSave(): Boolean updating, protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
10 Aug 2009	cnwjk3				Initial creation
15/10/2009 	cnwas3  PAR 21170
23/08/2013	cnwdap1	PAR #32331 	Description and Colour now on this screen, not Additional Details screen
15/10/13	cnwer1	PAR 32445 	removed container lengths
25/03/2014	cnwdap1	PAR #33606 	CCMS SFW 1366 Bulk
28/10/2014	cnwma1  PAR #35088  Delivery Release Reason for terminal receive and release
13/04/2015	cnwdap1	PAR #35805 	Do not append remarks for cargo types that allow duplicate ID
30/04/2015	cnwdap1	PAR #36094 	CCMS SFW 1413 TFS 313 Cold Store Enhancements
29/05/2015	cnwdap1	PAR #36357 	Prevent 1090 in cargo Checks form for release by type (that doesn't have a TI)
08/12/2016	cnwdap1	TFS 3039 	SNO Empty Container Pool Management
28/05/2017  cnwma1	TFs #4254	Unable to update consignee details when releasing cargo by id
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
22 May 2018 jlggb1 	TFS 36933 	PEN Release only to specified Carrier
16 Aug 2018	jlgrs1	TFS 39619 	PEN - Approved Carriers For Operator 
29/08/2018	JLGNS1	Bug 40008: 	PEN - Restrict Operator Issue - removed TFS2749
18 Mar 2019 jlgdi1	TFS 41721 	Cargo availability check
02 Apr 2019 jlgka1	TFS 41721	Address stack dump when doing any id any amount conflict with releaseCargoByType flag for check availability.
19 Aug 2019	jlgdap1	TFS 45836	PEN Aprroved Carrier for ISO Type and Trailer Type
29 Nov 2019	jlgdi1	47771		Added a method call on isCargoAvailCheckEnabled to determine if releasing a cargo requires availability check
02 Oct 2020 cnwma1 				ChangeRequest 50112: ASPA - GCI Stevedores
11 Jan2022	navdap1	TFS 52268	AAT 1-Stop VBS Integration
22 Apr 2024	jlizm1	TFS 62856	Shipment Number field
19 Jul 2024	navpw1	TFS: 61525 (61527) - Added Vbsti field so it can be set on the gate entity
09/09/2024	navcs2	Bug 65612: EUP - Error when creating a VBS slot using the release by weight request
22 Nov 2024 navma1  MTN-33459 STWO - Missing Consignee Details when Released by any ID in Road operations
22 Mar 2025	navcs2	MTN-34172	CUX - Additional Remarks of cargo does not pop up in Road Gate Screen during Cargo Release
============================================================================*/
vars
	arrayOfProxies		: CMGTE_EntityArray;
	controller 			: CMIF_FlexiGateController;
	obj 				: Object;
	oldContainerId 		: String;
	pxyRelease			: CMGTE_Release;
	saveObject			: Object;
	idx					: Integer;	//cnwas3 PAR 21170
	isForBB				: Boolean;
	isForBulk			: Boolean;							// PAR #33606
	cargoType			: CM_CargoType;						// PAR #33606
	cargoSubType		: CM_Product;						// PAR #33606
	density				: Decimal [22,10];					// PAR #33606
	appendRemarks		: Boolean;							// PAR #35805
	cargoChecksForm		: CMUI_CargoChecksForm;				// PAR #36094
	msg 				: String;
	carrier				: CM_Carrier;
	operator			: CM_Operator;
	dac					: CM_DataAccessController;
	operatorStr			: String;
	release				: CM_BulkRelease;
	releaseCargoByType 	: Boolean;
	totalQuantity 		: Integer;
	totalWeight 		: Decimal[16, 4];
	totalVolume 		: Decimal[16, 4];
	measureByQuantity 	: Boolean;
	totalAvailable 		: String;
	cargoSubTypeCode	: String;				
	reason 				: String;
	relReqValInt 		: Integer;	
	isAnyId				: Boolean;
	isAnyAmount			: Boolean;
begin

	//14 Feb 2017	NDL	TFS 3368
	if self.myBulkRelease &lt;&gt; null then
		if not self.myBulkRelease.validateExpiryDateNow( msg ) then
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		if msg &lt;&gt; null then
			if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	endif;
	
	isAnyId 	:= self.chkAnyId.getBoolean;			//22.11.2024 navma1 #MTN-33459
	isAnyAmount	:= self.chkAnyAmount.getBoolean;		//22.11.2024 navma1 #MTN-33459
	
	create controller transient;
	
	controller.myTerminal 			:= self.myTerminal;
	controller.cargoType 			:= TI_CargoType_Container;
	controller.myVehicleVisitRecord := self.myCurrentVehicleVisit;

	if self.isFullContainer() then
		controller.jobType := CMGTE_Entity.JobType_FullOUT;
		controller.mtOnly := false;	
	elseif self.isEmptyContainer() then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;
		controller.mtOnly := true;
	else
		controller.jobType := CMGTE_Entity.JobType_GeneralOUT;
		controller.mtOnly := false;	
	endif;
	
	/*
		+++ Main Details +++
	*/
	controller.numItems := self.txtNumItems.getInteger();
	/*
		+++ Release by ID +++
	*/
	controller.id 			 := self.txtCargoIDvalue.text.trimBlanks[1:30];	//14 Jul 2015	NDL	Par 36482
	controller.myTrackedItem := self.myTI;  // Break-bulk

	if self.myTI  &lt;&gt; null then
		controller.id := self.myTI.id;
	endif;

	if self.updateMode = self.Mode_Add and not self.lstCargoIDvalues.allSelectedObjects.isEmpty() then
		controller.id := self.lstCargoIDvalues.allSelectedObjects.first.CM_TrackedItem.id;
	endif;
	
	if self.myTerminal.roadProcessIsASPA then	//20 Oct 2020	NDL	TFS 49189
		if controller.id.trimBlanks = null and self.myBOLDtl = null then
			msg := app.getErrorString(Relea_type_witho_recei_type_no);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			self.txtCargoIDvalue.setFocus();
			return false;
		endif;
	endif;

	if self.txtNumItemsBB.enabled then
		controller.numItems := self.txtNumItemsBB.getInteger;
	endif;
	
	if self.myPxyGTEEntity = null then
		create self.myPxyGTEEntity as CMGTE_Release transient;
		oldContainerId:=null;
	else
		oldContainerId:=self.myPxyGTEEntity.getID();	
	endif;	

	
	//epr par 32330 29/8/13
	controller.myBulkRelease := self.myBulkRelease;
	
	if self.myBulkRelease &lt;&gt; null and self.myTI &lt;&gt; null then											// 22 Mar 2025	navcs2	MTN-34172
		self.showAdditionalRemarks(self.myTI.remarksAdditional1, self.myTI.remarksAdditional2);			// 22 Mar 2025	navcs2	MTN-34172
	endif;																								// 22 Mar 2025	navcs2	MTN-34172
	
	if self.myBulkRelease &lt;&gt; null and not self.myBulkRelease.releaseByType then
		controller.myReserveDetail :=self.myBulkRelease.getReserveTIforTI(self.myTI);
	else	
		controller.myReserveDetail := self.myReserveDetail;
		//17 May 2021	NDL	TFS 51199
		if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) and self.myTI  &lt;&gt; null then
		
			//17 Aug 2021	NDL	TFS 51785 - new rules
			relReqValInt := self.myTerminal.getConfig( RoadGateRelReqVal ).Integer;	
			if relReqValInt = 2 then
				//They don't care if the selected cargo doesn't match the release request, and don't want to know, do nothing.
			else
				//perform the check.
				if not self.myTI.testAgainstReserveSelection( self.myReserveDetail.CM_ReserveSelection, reason, false, null ) then
					if relReqValInt = 1 then
						//They do care but only want a warning
						msg := app.getErrorString2( Warn_Request_Line_Match, reason, self.myTI.id ) &amp; CrLf &amp; app.getErrorString(Continue);
						if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
							return false;
						endif;
					elseif relReqValInt = 0 then
						//They want to stop cargo that doesn't match being released, so raise an error.
						app.raiseCMException2(Warn_Request_Line_Match, reason, self.myTI.id, null, self.myTI);
					endif;
				endif;
			endif;
		endif;
	endif;
	// Placed here incase the proxy already exists, but the user has decided they want to release
	// by id, rather than by type.
	if controller.id &lt;&gt; null or (controller.myBulkRelease &lt;&gt; null and not controller.myBulkRelease.releaseByType) then   // PAR 26482
		self.myPxyGTEEntity.CMGTE_Release.setIsReleaseById(true);
	else
		self.myPxyGTEEntity.CMGTE_Release.setIsReleaseById(false);	
	endif;
	
	//Set VBS Slot Item from form if there is one. Does not matter if this is null
	controller.myVbtsi := self.myVbsti;	// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	
	/*
		+++ Release by Type +++
	*/
	obj := self.cmbOperatorCode.listObject;
	if obj &lt;&gt; null then
		controller.operatorCode := obj.CM_Operator.code;
	endif;
	
	isForBB:=false;
	isForBulk := false;															// PAR #33606
	// Get the cargoType which is used when a release by ID has been indicated
	if controller.id &lt;&gt; null then
		obj := self.cmbType.getObject();
	else
		obj := self.cmbTiType.getObject();
		if obj &lt;&gt; null and isAnyId then	// jlgka1 TFS 41708 
			releaseCargoByType := true;	// TFS# 41721
		endif;							// jlgka1 TFS 41708
	endif;
		
	measureByQuantity := true;  // TFS# 41721
	
	if obj &lt;&gt; null then
		cargoType := obj.CM_CargoType;											// PAR #33606
		controller.cargoType := cargoType.id;		
		//epr par 16/10/13 32445
		if cargoType.isBreakBulkMulti then
			isForBB:=true;
			if controller.id = null then
				controller.numItems := self.txtNumItems.getInteger();
			else
				controller.numItems := self.txtNumItemsBB.getInteger;
			endif;
		elseif cargoType.isBulkMulti then									// PAR #33606
			isForBulk := true;	
			// PAR #33606
			//epr par 34406 26/6/14
			if cargoType.isBulkByVolume then
				cargoSubType := self.cmbSubCargo.getObject().CM_Product;						// PAR #33606
				if cargoSubType = null and cargoType.mySystemProductType &lt;&gt; null then			// PAR #33606
					cargoSubType := cargoType.mySystemProductType;								// PAR #33606
				endif;		
				if cargoSubType &lt;&gt; null then													// PAR #33606
					density := cargoSubType.getDensityValue;
				endif;
				
				if controller.id &lt;&gt; null then											// PAR #33606
					controller.weight := self.tblTotalVolume.getConvertedValue() * density;	// PAR #33606
				else																	// PAR #33606
					controller.weight := self.tblVolume.getConvertedValue() * density;		// PAR #33606
				endif;			
			else
				if controller.id &lt;&gt; null then											// PAR #33606
					controller.weight := self.tblTotalWeight.getConvertedValue();	// PAR #33606
				else																	// PAR #33606
					controller.weight := self.tblWeight.getConvertedValue();		// PAR #33606
				endif;
			endif;	
			measureByQuantity := false;  // TFS# 41721
		endif;
	endif;
	
	obj := self.cmbSubCargo.getObject();
	if obj &lt;&gt; null then
		controller.myProduct := obj.CM_Product;
	endif;
		
	controller.mark := self.txtMark.getString();
	
	obj := self.cmbISOGroup.getObject();
	if obj &lt;&gt; null then
		controller.isoGroup := obj.CM_ISOTypeGroup.code;
	endif;

	obj := self.cmbISOType.getObject();
	if obj &lt;&gt; null then
		controller.isoTypeCode := obj.CM_ISOType.code;
	endif;
	obj := self.cmbImexStatus.getObject();
	if obj &lt;&gt; null then
		controller.imexStatus := obj.CM_IMEXStatus.code;
	endif;

	// Checkboxes
	controller.heavyRated 		:= self.chkHeavyDuty.getBoolean();
	controller.clean 			:= self.chkClean.getBoolean();	
	controller.doISOGroupCheck  := self.isBestPick;  			// cnwrd1 par 24169 9.6.2010
	controller.isFIFO 			:= self.isFIFO;					// cnwrd1 par 24169 9.6.2010
	
	//epr par 36919 24/11/15
	if controller.mtOnly then
		controller.commodity:=self.myTerminal.getDefaultEmptyCommodity;
	else
		obj := self.cmbCommodity.getObject();
		if obj &lt;&gt; null then
			controller.commodity := obj.CM_Commodity.code;
		endif;
	endif;
		
	obj := self.cmbVoyageCode.listObject;
	if obj &lt;&gt; null then
		controller.voyageCode := obj.CM_Voyage.code;
	endif;
	
	// This is a textbox for now, but may become a combo in the future. 
	controller.billOfLading := self.txtHouseBOL.getString(); 
	if self.myTerminal.roadProcessIsASPA then	//08 Oct 2020	NDL	TFS 49189
		controller.myBOLDtl := self.myBOLDtl;
	endif;


	if self.cmbConsignee.enabled then			 //17/6/19	MAP	TFS45112
		obj := self.cmbConsignee.getObject();	//18 Jan 2016	NDL	Par 37393
		if obj = null then 						//22.11.2024 navma1 #MTN-33459
			if isAnyId  and isAnyAmount then
				obj := self.cmbUpdateConsign.getObject();
			endif;
		endif;
		if obj &lt;&gt; null then
			controller.consigneeCode := obj.CM_ConsigneeConsignor.code;
		endif;
	endif;

	if self.cmbSubTerminal.enabled then		//	17/6/19	MAP	TFS45112
		obj := self.cmbSubTerminal.getObject();
		if obj &lt;&gt; null then
			controller.subTerminalCode := obj.CM_SubTerminal.code;
		endif;
	endif;

	controller.allAvailabilityGrades.clear;
	foreach obj in self.lstMTGrade.allSelectedObjects do
		controller.allAvailabilityGrades.add(obj.CM_MTGrade.code);
	endforeach;

	controller.idMask := self.idMask;
	
	controller.colour 		:= self.myAssistant.getColourString(self.lstColourList, self.txtColourList);	// PAR #32331
	controller.description 	:= self.txtDescription.getString();												// PAR #32331
	
	/* 
		+++ Additional Release Types (General Cargo) +++ 
	*/ 

	// Note tha the following controls are declared on this form, but are never associated with an EntTableDef thingy.
	controller.description := self.txtDescription.getString();
	if self.myBulkRelease &lt;&gt; null then						// cnwma1 PAR #35088 28/10/2014
		appendRemarks := true;																	// PAR #35805
		if self.myTI &lt;&gt; null then
			cargoType := self.myTI.myCargoType;	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
			if self.myTI.myCargoType &lt;&gt; null and self.myTI.myCargoType.isAllowDuplicates then	// PAR #35805
				appendRemarks := false;															// PAR #35805
			endif;																				// PAR #35805
			//if self.myTI.remarks &lt;&gt; null then													// PAR #35805
			if self.myTI.remarks &lt;&gt; null and appendRemarks then									// PAR #35805
				controller.remarks := self.myTI.remarks &amp; ' '&amp; self.txtRemarks.getString();
			else
				controller.remarks :=self.txtRemarks.getString();
			endif;
		else	//18 Sep 2015	NDL	Par 36839
			controller.remarks :=self.txtRemarks.getString();
		endif;
	else
		controller.remarks :=self.txtRemarks.getString();
	endif;
	controller.length 			:= self.txtLength.getString().asCastDecimalJMT();
	controller.width 			:= self.txtWidth.getString().asCastDecimalJMT();
	controller.quantity 		:= self.txtQuantity.getString().asIntegerJMT();
	controller.density 			:= self.txtDensity.getString().asDecimalJMT();							// ### TFS 52193 22Nov2021 NAVPW1
	controller.height 			:= self.txtHeight.getString().asCastDecimalJMT();
	controller.markNumber 		:= self.txtMarkNumber.getString();
	controller.yardInstructions := self.txtYardInstruct.getString();
	controller.widthString 		:= self.txtWidthText.getString();
	controller.lengthString 	:= self.txtLengthText.getString();
	controller.heightString	    := self.txtHeight.getString();
	controller.clientRef 		:= self.txtClientRef.getString(); //cnwrd1 par 23337 20-5-2010
	
	if self.myProductAttributeCode &lt;&gt; null then
		controller.type := self.myProductAttributeCode.code;
	endif;
	
	/* 
		+++ Update Released Cargo With +++ 
	*/ 
	
	obj := self.cmbUpdateConsign.getObject();
	if obj &lt;&gt; null then
		controller.updateConsigneeCode := obj.CM_ConsigneeConsignor.code;
		if controller.updateConsigneeCode &lt;&gt; null
		and controller.consigneeCode = null							//22 Aug 2019	NDL	TFS 46229
		and self.myTerminal.getConfig(GateOutConsigneeReqd).Boolean	//22 Aug 2019	NDL	TFS 46229
		then
			controller.consigneeCode :=controller.updateConsigneeCode; //29/05/2017 cnwma1	TFS #4254
		endif;
	endif;
	
	if app.myRoot.isInterTerminalTransferEnabled then	//09 Jul 2012	NDL	Par 29703
		obj := self.cmbDestTerminal.getObject();
		if obj &lt;&gt; null then
			controller.myTransferToTerminal := obj.CM_Terminal;
		endif;
	endif;
	
	if  self.cmbStevedore.getObject() &lt;&gt; null then   //02.10.2020 cnwma1 TFS #50112
		controller.stevedoreCode := self.cmbStevedore.getObject().CM_Stevedore.code;
	endif;

	controller.deliveryReason 	   := self.cmbDelReason.getString();
	controller.customEntryNumber   := self.txtCustomsRelNo.getString();	
	controller.deliveryRelease	   := self.txtDeliveryRelNo.getString();			//+cnwml2 PAR25757
	controller.consignorVoyageCode := self.txtConsignVoy.getString();
	controller.eirNumber 		   := self.txtEquipXchg.getString();
	controller.importReleasePIN    := self.txtOpImportPIN.getString();
	controller.remarksAdditional1  := self.txtAddRemarks1.getString();			// 5/2/19 MAP TFS40701
	controller.remarksAdditional2  := self.txtAddRemarks2.getString();
	controller.shipmentNumber	   := self.txtShipmentNumber.getString();

	// 05/03/2010 cnwjre1 CCMS1101 specify terminal area: par 22634 change text box to combo 
	obj := self.cmbTermArea.getObject();
	if obj &lt;&gt; null then
		controller.yardLocationTxt := obj.CM_TerminalArea.getID();
	endif;
	
	self.allSelectedTAs.copy ( controller.allSourceTAs ); //cnwrd1 par 24169 9.6.2010
	self.allSelectedTAGridObjs.copy( controller.allSourceTAGridObjs ); //cnwrd1 28628 5.12.2011
	
	// TFS 3039 If we have a release request, and the release request has a pooling partner,		// TFS 3039
	// update the TI with the release's operator and booking 										// TFS 3039
	if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.myPoolingParty &lt;&gt; null then				// TFS 3039
		controller.operatorCode := self.myBulkRelease.myOperator.code;								// TFS 3039
		if self.myBulkRelease.myBookingRefStock &lt;&gt; null then										// TFS 3039
			controller.bookingNumber := self.myBulkRelease.myBookingRefStock.bookingReference;		// TFS 3039
		endif;																						// TFS 3039
	endif;																							// TFS 3039

	self.validateByTypeByWeightByQty();												//13.Dec.2023 navsp1 TFS 61547
	if self.txtReleaseWeight.visible and self.txtReleaseWeight.enabled then
		controller.releaseWeight := self.txtReleaseWeight.getConvertedValue();		//13.Dec.2023 navsp1 TFS 61547	09/09/2024	navcs2	Bug 65612 (added convertedWeightMethod)
	else
		controller.releaseWeight := 0;
	endif;
	
	if self.txtReleaseQty.visible and self.txtReleaseQty.enabled then
		controller.releaseQuantity  := self.txtReleaseQty.getString().asIntegerJMT();	//13.Dec.2023 navsp1 TFS 61547
	else
		controller.releaseQuantity := 1;
	endif;
	
	if self.hasBulkRelease() then 
		// set proxy from bulk release first and allow overwrite from GUI
		self.myPxyGTEEntity.CMGTE_Release.setPXYFromBulkRelease(self.myBulkRelease, self.myReserveDetail);
	endif;

	self.myPxyGTEEntity.setPXYFromController(controller);
	
	//01 Aug 2014	NDL	Par 34675
	if self.hasBulkRelease() then 
		if isAnyId then
			self.myPxyGTEEntity.CMGTE_Release.setIsAnyId( isAnyId );
			if self.myBulkRelease.myOperator &lt;&gt; null then	//19 Aug 2019	NDL	TFS 46077
				self.myPxyGTEEntity.setOperator( self.myBulkRelease.myOperator.code );
			endif;
			self.myPxyGTEEntity.CMGTE_Release.setIsAnyAmount( isAnyAmount );//21 Mar 2016	NDl	TFS 3813
		else
			//jlier1 TFS 53678 28/6/22
			if not self.tblWeightRequested.isHidden then
				self.myPxyGTEEntity.CMGTE_Release.setWeightRequested(self.tblWeightRequested.getString().asCastDecimalJMT()); //jlier1	TFS 53678 20/6/22
			endif;
		endif;
	endif;
	
	
	
	if self.cmbPackTo.isHidden = false then
		obj :=self.cmbPackTo.getObject();
		self.myPxyGTEEntity.setParentObject(obj.CMGTE_Entity);	

	else
		self.myPxyGTEEntity.setParentObject(null);
	endif;
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if self.myPxyGTEEntity &lt;&gt; null  then
		if  self.myTI &lt;&gt; null 
			and self.myTI.getGenerator &lt;&gt; null  then
			self.createGeneratorFromTI();
		endif;
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	
	// TFS# 41721
	// Note : The '(controller.operatorCode &lt;&gt; null)' is added because there was an instance
	// 		  the user can click the Save button leaving both the 'Release By ID' and 'Release By Type' portion blank
	if (self.isCargoAvailCheckEnabled()) and (controller.operatorCode &lt;&gt; null) then
		self.getAvailableItemCountByType(controller.voyageCode,
										 totalQuantity,
										 totalVolume,
										 totalWeight);
										 
		if self.isMoreThanTheAvailable(releaseCargoByType,
									   measureByQuantity,
									   totalQuantity,
									   totalWeight,
									   controller)
		then
			if measureByQuantity then 
				totalAvailable := totalQuantity.asStringJMT() ;
			else
				totalAvailable := totalWeight.asStringJMT();
			endif;
			
			app.raiseCMException1(More_Than_Available, 
								  constructErrorMsg(controller.voyageCode, 
													controller.operatorCode, 
													controller.consigneeCode, 
													totalAvailable),
								  null, null);
		endif;	
	endif;
	
	saveObject := self.myPxyGTEEntity;
	
	if not self.do1StopVBSCheck(self.myPxyGTEEntity) then	// TFS 52268
		return false;										// TFS 52268
	endif;													// TFS 52268

	if self.updateMode = self.Mode_Add and self.lstCargoIDvalues.allSelectedObjects.size &gt; 1 then

		// need to create release entities for multiple items
		create arrayOfProxies transient;
		foreach obj in self.lstCargoIDvalues.allSelectedObjects do
			create pxyRelease transient;
			pxyRelease.setIsReleaseById(true);
			if self.hasBulkRelease() then 
				pxyRelease.setPXYFromBulkRelease(self.myBulkRelease, self.myReserveDetail);
			endif;
			controller.id := obj.CM_TrackedItem.id;
			controller.myTrackedItem := obj.CM_TrackedItem; //cnwrd1 par 32343
			cargoType := obj.CM_TrackedItem.myCargoType;	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
			controller.numItems := 1;
			if self.myBulkRelease &lt;&gt; null then			// cnwma1 PAR #35088 28/10/2014
				appendRemarks := true;																				// PAR #35805
				if obj.CM_TrackedItem.myCargoType &lt;&gt; null and obj.CM_TrackedItem.myCargoType.isAllowDuplicates then	// PAR #35805
					appendRemarks := false;																			// PAR #35805
				endif;																								// PAR #35805
				//if obj.CM_TrackedItem.remarks &lt;&gt; null then														// PAR #35805
				if obj.CM_TrackedItem.remarks &lt;&gt; null and appendRemarks then										// PAR #35805
					controller.remarks := obj.CM_TrackedItem.remarks &amp; ' '&amp; self.txtRemarks.getString();
				else
					controller.remarks :=self.txtRemarks.getString();
				endif;
			else
				controller.remarks :=self.txtRemarks.getString();
			endif;
			
			pxyRelease.setPXYFromController(controller);
			pxyRelease.setJobQueueNum(self.myPxyGTEEntity.jobQueueNum + arrayOfProxies.size);
			arrayOfProxies.add(pxyRelease);
		endforeach;
		saveObject := arrayOfProxies;
	elseif self.updateMode = self.Mode_Add and  controller.id = null and self.lstCargoIDvalues.allSelectedObjects.size &lt; 1 and self.txtNumItems.getInteger() &gt; 1 and not isForBB and not isForBulk then // cnwjk3 PAR 23214 25/03/2010
		// need to create release entities for multiple items
		create arrayOfProxies transient;
		foreach idx in 1 to self.txtNumItems.getInteger() do
			create pxyRelease transient;
			pxyRelease.setIsReleaseById(false);
			if self.hasBulkRelease() then 
				pxyRelease.setPXYFromBulkRelease(self.myBulkRelease, self.myReserveDetail);
			endif;

			controller.numItems := 1;
			pxyRelease.setPXYFromController(controller);
			pxyRelease.setJobQueueNum(self.myPxyGTEEntity.jobQueueNum + arrayOfProxies.size);
			arrayOfProxies.add(pxyRelease);
		endforeach;
		saveObject := arrayOfProxies;																										//cnwas3 PAR 21170 end
	endif;	
	
	release := self.myBulkRelease;
	if release &lt;&gt; null then		// 14/9/17 MAP TFS2749
		carrier := self.myCarrier;
		operator := self.myBulkRelease.myOperator;
		if carrier &lt;&gt; null then	//21 dec 2017	NDL	TFS 8272
			if not carrier.canCarrierAccessForOperator(operator, dac, true) then
				if operator &lt;&gt; null then
					operatorStr := operator.description;
				endif;
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
				return false;
			endif;
		
			foreach obj in self.lstCargoIDvalues.allSelectedObjects do
				operatorStr := null;
				operator := obj.CM_TrackedItem.myOperator;
				if not carrier.canCarrierAccessForOperator(operator, dac, true) then
					if operator &lt;&gt; null then
						operatorStr := operator.description;
					endif;
					app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
					return false;
				endif;
			endforeach;

			// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
			if cargoSubType &lt;&gt; null then						// TFS 45836
				cargoSubTypeCode := cargoSubType.code;			// TFS 45836
			endif;												// TFS 45836
			if carrier &lt;&gt; null and
			   operator &lt;&gt; null and
			   cargoType &lt;&gt; null and
			   not operator.canOpAccessCarrierForCargoType(carrier, cargoType.id, cargoSubTypeCode, release.getISOCode, null) then	// TFS 45836
				app.raiseCMWarning3(Opera_denie_carri_acces_cargo_, operator.description, carrier.description, cargoType.description, null, null, null);
			endif;
		endif;
	endif;
		
	if self.myAssistant.saveFlexiGateEntity(self.myMainForm, (self.updateMode = self.Mode_Update), saveObject, false, null) then
		// PAR #36094 Check if we have a cargo chek context for gate release
		if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_ROAD_REL) then
			// nothing to do here
		elseif self.myCurrentVehicleVisit &lt;&gt; null and self.myTI &lt;&gt; null then		// PAR #36357
			if app.myPassport.noErrors then
				create cargoChecksForm transient;
				cargoChecksForm.myTerminal := self.myTerminal;
				cargoChecksForm.setBaseDetails(self.myTI,null,CARGO_CHECK_CONTEXT_ROAD_REL);
				cargoChecksForm.setParentForm(self);
				cargoChecksForm.showModal;
				delete cargoChecksForm;
			endif;
		endif;
		// PAR #36094 end
		
		//epr changes for CCMS 1386 ROB gate cargo now done on flexi gate form when trx is completed successfully
		return true;
	endif;	
	
	return false; 
epilog
	delete controller;
	if arrayOfProxies &lt;&gt; null then
		arrayOfProxies.purge();
		delete arrayOfProxies;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectYardSource" id="28e9dc5e-771b-44ac-95c4-622abe6f1dc1">
        <updating/>
        <source>doSelectYardSource() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwrd1	Initial creation

*/

vars
	sourceForm	: CMUI_SelectISOSourceMulti;
	desc : String;
begin
	
	
	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;
	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);

	sourceForm.setDescription( self.getYardSourceDesc() ); 
	sourceForm.setSelectedValues( self.allSelectedTAs,self.allSelectedTAGridObjs, self.isFIFO, self.isBestPick  ) ; //grid objects

	sourceForm.showModal;
	
	if sourceForm.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	//update  entity
	self.allSelectedTAs.clear();
	sourceForm.getAreasWithGridObjs(self.allSelectedTAs, self.allSelectedTAGridObjs);
	self.isFIFO := sourceForm.optFIFO.value;	
	self.isBestPick := sourceForm.chkBestPick.value;
	
	self.yardSourcetxt := self.getYardSourceText(self.isBestPick);				//+cnwml2 PAR25817
	self.lblYardSourcMask.caption :=  self.truncateDisplayString(self.yardSourcetxt, MAX_IDMASK_DISPLAY_LEN);
epilog
	delete sourceForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetCaption" id="a24327f5-0c42-4be2-8d0b-5781474dba3e">
        <updating/>
        <source>doSetCaption() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwjk3	Initial creation

*/

vars
	cap		: String;	
begin
	
	if self.currentEntTableDef = ETDef_ReleaseContainerFull then
		cap := 'Release Full Container ';
	elseif self.currentEntTableDef = ETDef_ReleaseContainerEmpty then
		cap := 'Release Empty Container ';
	elseif self.currentEntTableDef = ETDef_ReleaseGeneralCargo then
		cap := 'Release General Cargo ';
		//08 Oct 2020	NDL	TFS 49189
		if self.myTerminal.roadProcessIsASPA and self.myVoyage &lt;&gt; null and self.myBOL &lt;&gt; null and self.myBOLDtl &lt;&gt; null then
			cap := 'Release General Cargo by BOL ';
		endif;
	endif;
	self.setCaption(cap);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowAdditionalReleaseTypes" id="a0d3dabb-7076-461e-a020-25359bbd37f9">
        <source>doShowAdditionalReleaseTypes(_enable : Boolean) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwjk3	Initial creation
27/03/2014	cnwdap1	PAR #33660 CCMS SFW 1366 Bulk - changed txtWeight and txtVolume to measurement tables
*/

vars
	form : CMUI_AdditionalReleaseTypes;
	typeCode,
	length,
	volume,
	height,
	width : String;
	productAttribute : CM_ProductAttributeCode;
begin
	form := app.loadForm(	CMUI_AdditionalReleaseTypes,
							self.myAssistant.class,
							false,
							false,
							true,
							self.myTerminal, null).CMUI_AdditionalReleaseTypes;
							
	form.setColumnsAndControlWidth(2, 200);
	
	// Remove the decimal points from these ones (yuck)
	width := self.txtWidth.getString().Integer.String;
	if width = "0" then
		width := null;
	endif;
	length := self.txtLength.getString().Integer.String;
	if length = "0" then
		length := null;
	endif;

	height := self.txtHeight.getString().Integer.String;
	if height = "0" then
		height := null;
	endif;
	
	productAttribute := self.cmbDimType.getObject().CM_ProductAttributeCode;
	if productAttribute &lt;&gt; null then
		typeCode := productAttribute.code;
	endif;
	form.setDetailsFromParentForm(	self.txtDescription.getString(),
									self.txtRemarks.getString(),
									//self.txtWeight.getString(),					// PAR #33606
									self.tblWeight.getConvertedValue().String,		// PAR #33606
									length,
									//volume,										// PAR #33606
									self.tblVolume.getConvertedValue().String,		// PAR #33606
									width,
									height,
									self.txtQuantity.getString(),
									self.txtColour.getString(),
									self.txtMarkNumber.getString(),
									self.txtYardInstruct.getString(),
									self.txtWidthText.getString(), 
									self.txtHeightText.getString(),
									self.txtLengthText.getString(),
									self.txtDensity.getString(),
									self.myProductAttributeCode, 
									self.cmbTiType.getObject().CM_CargoType, self.cmbSubCargo.getObject().CM_Product);
	form.enableAllControls(_enable);
	form.setParentForm(self);
	form.showModal;							
									
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowPicture" id="2062c73a-a816-4f56-9b6e-8581de9b3de8">
        <source>doShowPicture() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
		self.picTitleOther.visible := false;
		self.picTitleFull.visible := false;	
		self.picTitleEmpty.visible := false;

	return; // JLGAB1 TOOLBAR NOPIX


	if self.currentEntTableDef = ETDef_ReleaseContainerEmpty then
		self.picTitleOther.visible := false;
		self.picTitleFull.visible := false;	
		self.picTitleEmpty.visible := true;
		self.lblMainDetails.left := self.picTitleEmpty.left + self.picTitleEmpty.width;
	elseif self.currentEntTableDef = ETDef_ReleaseContainerFull then
		self.picTitleOther.visible := false;
		self.picTitleFull.visible := true;	
		self.picTitleEmpty.visible := false;
		self.lblMainDetails.left := self.picTitleFull.left + self.picTitleFull.width;
	elseif self.currentEntTableDef = ETDef_ReleaseGeneralCargo then	
		self.picTitleOther.visible := true;
		self.picTitleFull.visible := false;	
		self.picTitleEmpty.visible := false;
		self.lblMainDetails.left := self.picTitleOther.left + self.picTitleOther.width;
	endif;
	
	self.showChkAnyId();	//06 Aug 2014	NDL	Par 34675
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateAdditionalReleaseTypes" id="c89b1f9f-abd5-4767-a7a8-07c1eb7430af">
        <updating/>
        <source>doUpdateAdditionalReleaseTypes(_description, _remarks,
						  _weight, _length, _volume, _width, _height, 
						  _quantity, _colour, _markNumber, _yardInstructions,
						   _widthText, _heightText, _lenText, _density : String;
						   _productAttributeCode : CM_ProductAttributeCode
						  ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26/08/2009	cnwjk3	Initial creation
23/08/2013	cnwdap1	PAR #32331 Description and Colour now on this form, not the Additional Details form
12/10/2015	cnwma1  PAR #36621 Error 1216 Cannot Invoke Abstract Method in Road Gate
*/

vars
	typeCode			: String;
	productAttribute 	: CM_ProductAttributeCode;
	volumeType 		: CM_MeasurementType;	
begin

	//self.txtDescription.setValue(_description);			// PAR #32331
	self.txtRemarks.setValue(_remarks);
	//self.tblWeight.setValue(_weight); 			//12/10/2015 cnwma1 PAR #36621
	self.tblWeight.setValues(_weight);				//12/10/2015 cnwma1 PAR #36621
	self.txtLength.setValue(_length);
	//self.tblVolume.setValue(_volume);				//12/10/2015 cnwma1 PAR #36621
	self.tblVolume.setValues(_volume);				//12/10/2015 cnwma1 PAR #36621
	self.txtWidth.setValue(_width);
	self.txtHeight.setValue(_height);
	self.txtQuantity.setValue(_quantity);
	//self.txtColour.setValue(_colour);						// PAR #32331
	self.txtMarkNumber.setValue(_markNumber);
	self.txtYardInstruct.setValue(_yardInstructions);
	self.txtWidthText.setValue(_widthText);
	self.txtHeightText.setValue(_heightText);
	self.txtLengthText.setValue(_lenText);
	self.txtDensity.setValue(_density);
	self.myProductAttributeCode := _productAttributeCode;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_weight" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_volume" type="String"/>
        <Parameter name="_width" type="String"/>
        <Parameter name="_height" type="String"/>
        <Parameter name="_quantity" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_yardInstructions" type="String"/>
        <Parameter name="_widthText" type="String"/>
        <Parameter name="_heightText" type="String"/>
        <Parameter name="_lenText" type="String"/>
        <Parameter name="_density" type="String"/>
        <Parameter name="_productAttributeCode" type="CM_ProductAttributeCode"/>
    </JadeMethod>
    <JadeMethod name="enableByTypeFields" id="1d5efb28-9bf2-4449-98a8-6372bd994bb0">
        <updating/>
        <source>enableByTypeFields(_enable : Boolean) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		TFS		Reason
12 August 2009	cnwjk3	Initial creation
12/03/2010	cnwmh5	PAR22693 - add imex and Terminal Area
23/08/2013	cnwdap1	PAR #32331 - added Description and Colour fields
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
18 Mar 2019	jlgdi1	TFS# 41721 Added btnCargoAvailabilityCheck
29 Nov 2019	jlgdi1	47771	Used the method isCargoAvailCheckEnabled to enable the cargo availability check button
*/

begin
	self.cmbOperator.enabled := _enable;
	self.cmbISOGroup.enabled := _enable;
	self.cmbISOType.enabled := _enable;
	self.cmbCommodity.enabled := _enable;
	self.cmbVoyage.enabled := _enable;
	self.txtHouseBOL.enabled := _enable;
	self.cmbConsignee.enabled := _enable;
	self.cmbSubTerminal.enabled := _enable;
	self.lblIDs.enabled := _enable;
	self.lblYardSource.enabled:=_enable; // epr par 36674 1/9/15
	self.lstMTGrades.enabled := _enable;
	self.chkClean.enabled := _enable;
	self.chkHeavyDuty.enabled := _enable;
	self.chkHiLoCube.enabled := _enable;
	self.cmbTiType.enabled := _enable;
	self.cmbSubCargo.enabled := _enable;
	self.txtMark.enabled := _enable;
	self.cmbImexStatus.enabled := _enable;		// 12/03/2010 cnwmh5 #22693
	self.cmbTermArea.enabled := _enable;	// 12/03/2010 cnwmh5 #22693
	self.txtDescription.enabled := _enable;		// PAR #32331
	self.lstColour.enabled := _enable;			// PAR #32331
	self.txtNumItems.enabled:=_enable; //epr par 32445 16/10/13
	self.txtExtra.enabled := false;	//16 Jan 2019	NDL	TFS 42921
	self.btnCargoAvailCheck.enabled := self.isCargoAvailCheckEnabled();
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAvailableItemCountByType" id="7b01caa6-77cd-419d-857f-b6ea421146e5">
        <source>getAvailableItemCountByType(_voyageCode : String;
							_totalQuantity : Integer io;
							_totalVolume : Decimal io;
							_totalWeight : Decimal io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Deduct the unmatching leaving on site.
27 Oct 2023 navlc30 Bug 60197: PEN | Road Gate Cargo Check error
*/

constants
	BY_QUANTITY : Integer = 0;
	BY_VOLUME : Integer = 1;
	BY_WEIGHT : Integer = 2;
	NA : String = "N/A";
	
vars
	dynaDict : DynaDictionary;
	originalColl : Collection;
	trackedItems : CM_TISet;
	iterator : Iterator;
	cmifCargo : CMIF_CargoAvailability;	
	operatorCode : String;
	cargoType : Integer;
	cargoTypeDesc : String;
	cargoSubType :  String;
	voyageCode : String;
	consignee : String;
	
begin
	create dynaDict transient;
	create trackedItems transient;

	createCargoCollection(dynaDict);
	originalColl := checkCargoAvailability(trackedItems);	
	consolidateCargo(originalColl, dynaDict);
	
	getParameters(operatorCode,
				  cargoType,
				  cargoTypeDesc,
				  cargoSubType,
				  voyageCode,
				  consignee);
	
	iterator := dynaDict.createIterator();
	while iterator.next(cmifCargo) do 
		
		if (cmifCargo.operatorCode = operatorCode) and 
			(cmifCargo.cargoType = cargoType) 
		then
			/*if ((cmifCargo.showByType = BY_WEIGHT) and (cmifCargo.totalWeight &gt; 0)) or			//27.10.2023 navlc30 #60197
			   ((cmifCargo.showByType = BY_VOLUME) and (cmifCargo.totalVolume &gt; 0)) or 
			   ((cmifCargo.showByType = BY_QUANTITY) and (cmifCargo.totalQuantity &gt; 0))*/
			if ((cmifCargo.showByType = BY_WEIGHT) and (cmifCargo.totalWeight &gt;= 0)) or 			//27.10.2023 navlc30 #60197
			   ((cmifCargo.showByType = BY_VOLUME) and (cmifCargo.totalVolume &gt;= 0)) or 
			   ((cmifCargo.showByType = BY_QUANTITY) and (cmifCargo.totalQuantity &gt;= 0))    
			then
				if (cargoSubType &lt;&gt; null) and 
				   (cmifCargo.cargoSubType &lt;&gt; cargoSubType) then 
					continue;
				endif;
				
				if (voyageCode &lt;&gt; null) and 
				   (cmifCargo.voyageCode &lt;&gt; voyageCode) then 
					continue;
				endif;
				
				if (consignee &lt;&gt; null) and 
				   (cmifCargo.consignee &lt;&gt; null) and 
				   (cmifCargo.consignee &lt;&gt; consignee) 
				then 
					continue;
				endif;
			endif;
			
			if cmifCargo.showByType = BY_WEIGHT then
				_totalWeight := _totalWeight + 
					(cmifCargo.totalWeight - cmifCargo.totalWeightLeaving);
			elseif cmifCargo.showByType = BY_VOLUME then
				_totalVolume := _totalVolume + 
					(cmifCargo.totalVolume - cmifCargo.totalVolumeLeaving);
			else
				_totalQuantity := _totalQuantity + 
					(cmifCargo.totalQuantity - cmifCargo.totalQuantityLeaving);
			endif;
		endif;
	endwhile;

	if _totalQuantity &lt; 0 then 
		_totalQuantity := 0;
	endif;
	
	if _totalVolume &lt; 0 then
		_totalVolume := 0;
	endif;
	
	if _totalWeight &lt; 0 then
		_totalWeight := 0;
	endif;
	
epilog
	delete iterator;
	delete trackedItems;
	delete dynaDict;	
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_totalQuantity" type="Integer" usage="io"/>
        <Parameter name="_totalVolume" type="Decimal" usage="io"/>
        <Parameter name="_totalWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoLeavingSite" id="b0a41649-715a-4f40-b7ad-709b9774c144">
        <source>getCargoLeavingSite(_dynaDict : DynaDictionary io;
					_operatorCode : String;
					_cargoType :Integer;
					_cargoTypeDesc :String;
					_cargoSubType: String;
					_voyageCode : String) : Integer;
/*

Purpose: Get total count of Cargo Leaving Site based on Road Jobs (not cargo on truck)

Parameters:	

Return Value:		

Date		Who		Reason
20 Mar 2019	jlgdi1	TFS# 41721

*/

constants
	NA : String = "N/A";
	
vars
	terminal : CM_Terminal;
	roadJobSheet : CM_RoadJobSheet;
	roadJob : CM_Job;
	workListEntry : CM_WorkListEntry;
	deliveryRequest : CM_Request;
	operatorCode : String;
	cmCargoType : CM_CargoType;
	cargoType : Integer;
	cargoTypeDesc :String;
	cmProduct : CM_Product;	
	cargoSubType: String;
	cmVoyage : CM_Voyage;
	voyageCode : String;
	cmConsignee : CM_ConsigneeConsignor;
	consignee : String;
	commodity : String;
	leavingOnSite : Integer;
	cmifCargo : CMIF_CargoAvailability;
	
begin
	terminal := self.myTerminal;
	roadJobSheet := terminal.myRoadJobSheet;
	foreach roadJob in roadJobSheet.allJobsByOrder do
		foreach workListEntry in roadJob.workListEntries do
			operatorCode := "";
			cargoType := 0;
			cargoSubType := "";
			voyageCode := "";
			consignee := "";
			commodity := "";
			leavingOnSite := workListEntry.quantity;
		
			if workListEntry.myTrackedItem &lt;&gt; null then
				operatorCode := workListEntry.myTrackedItem.operatorCode;
				cargoType := workListEntry.myTrackedItem.cargoType;
				cargoTypeDesc := workListEntry.myTrackedItem.cargoTypeDescr;
				cargoSubType := workListEntry.myTrackedItem.getCargoSubTypeCode();
				voyageCode := workListEntry.myTrackedItem.voyageCode;
				cmVoyage := workListEntry.myTrackedItem.myVoyage;	//21 Oct 2019	NDL	TFS 46911
				consignee := workListEntry.myTrackedItem.consignee;
				commodity := workListEntry.myTrackedItem.commodity;
			else
				// get details in myRequest
				deliveryRequest := workListEntry.myRequest;
				
				operatorCode := deliveryRequest.getOperatorCode();
				cmCargoType := deliveryRequest.getCargoType();				
				if cmCargoType &lt;&gt; null then 
					cargoType := cmCargoType.id;
					cargoTypeDesc := cmCargoType.description;
				endif;
				cmProduct := deliveryRequest.getCargoSubType();
				if cmProduct &lt;&gt; null then
					cargoSubType := cmProduct.code;
				endif;
				
				cmVoyage := deliveryRequest.getVoyage();
				if cmVoyage &lt;&gt; null then
					voyageCode := cmVoyage.code;
				else
					voyageCode := NA;
				endif;
								
				consignee := deliveryRequest.consigneeCode;
				
				leavingOnSite := deliveryRequest.getTotalRequested();
			endif;
			
			if leavingOnSite = 0 then 
				continue;
			endif;
			
			if (operatorCode = _operatorCode) and 
			   (cargoType = _cargoType) 
			then
				if (_cargoSubType = null) or 
				   (cargoSubType = _cargoSubType) then 
				
					cmifCargo := _dynaDict.getAtKey(voyageCode,
												   operatorCode,
												   cargoType,
												   cargoSubType,
												   consignee).CMIF_CargoAvailability;
					
					if cmifCargo = null then 
						create cmifCargo transient;
						cmifCargo.voyageCode := voyageCode;
						cmifCargo.operatorCode := operatorCode;
						cmifCargo.cargoType := cargoType;
						cmifCargo.cargoSubType := cargoSubType;
						cmifCargo.commodity := commodity;
						cmifCargo.consignee := consignee;
						cmifCargo.cargoTypeDesc := cargoTypeDesc;
						cmifCargo.totalQuantityLeaving := leavingOnSite;
						cmifCargo.myVoyage := cmVoyage;	//21 Oct 2019	NDL	TFS 46911
						
						_dynaDict.add(cmifCargo);
					else
						cmifCargo.totalQuantityLeaving := cmifCargo.totalQuantityLeaving + 
							leavingOnSite;
					endif;
				endif;
			endif;
		endforeach;	
	endforeach;
	
	return leavingOnSite;
end;</source>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="io"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_cargoTypeDesc" type="String"/>
        <Parameter name="_cargoSubType" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParameters" id="b4b527aa-46ec-4536-bbbe-c88ebea82972">
        <source>getParameters(_operatorCode : String io;
			  _cargoType : Integer io;
			  _cargoTypeDesc : String io;
			  _cargoSubType :  String io;
			  _voyageCode : String io;
			  _consignee : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

vars
	object : Object;
	
begin						
	object := self.cmbOperatorCode.myObject;
	if object &lt;&gt; null then
		_operatorCode := object.CM_Operator.code;
	endif;
	
	// Get the cargoType which is used when a release by ID has been indicated
	object := self.cmbTiType.getObject();	
	if object &lt;&gt; null then		
		_cargoType := object.CM_CargoType.id;
		_cargoTypeDesc := object.CM_CargoType.description;
	endif;

	object := self.cmbSubCargo.getObject();
	if object &lt;&gt; null then
		_cargoSubType := object.CM_Product.code;
	endif;
	
	object := self.cmbVoyageCode.myObject;
	if object &lt;&gt; null then
		_voyageCode := object.CM_Voyage.code;
	endif;
	
	object := self.cmbConsignee.getObject();
	if object &lt;&gt; null then
		_consignee := object.CM_ConsigneeConsignor.code;
	endif;
end;</source>
        <Parameter name="_operatorCode" type="String" usage="io"/>
        <Parameter name="_cargoType" type="Integer" usage="io"/>
        <Parameter name="_cargoTypeDesc" type="String" usage="io"/>
        <Parameter name="_cargoSubType" type="String" usage="io"/>
        <Parameter name="_voyageCode" type="String" usage="io"/>
        <Parameter name="_consignee" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getReserveCountNotForRelReq" id="9c2fbfec-22ab-4233-9892-50a07dd2e772">
        <source>getReserveCountNotForRelReq(_trackedItem : CM_TrackedItem; _reserveDetailsArray : CM_ReserveDetailArray io) : Integer;
/*

Purpose: Get all reserve count that are not assigned to specific Release Request

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

vars
	reserveDetail : CM_ReserveDetail;
	totalRequested : Integer;
	releaseRequestID : String;
	
begin
	releaseRequestID := self.txtRelease.getString();
	
	foreach reserveDetail in _trackedItem.allReserveDetails do
		if not _reserveDetailsArray.includes(reserveDetail) then 
			if releaseRequestID = null then 
				totalRequested := totalRequested + (reserveDetail.getTotalRequested() - reserveDetail.getTotalReleased());
				
			else
				if reserveDetail.myReserveHeader.code &lt;&gt; releaseRequestID then 
					totalRequested := totalRequested + (reserveDetail.getTotalRequested() - reserveDetail.getTotalReleased());
				endif;
			endif;
			
			_reserveDetailsArray.add(reserveDetail);
		endif;
	endforeach;
	
	return totalRequested;
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_reserveDetailsArray" type="CM_ReserveDetailArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getShowByType" id="a1e44ada-93e2-4362-b546-41cec0a0911c">
        <source>getShowByType(trackedItem : CM_TrackedItem) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

constants
	BY_QUANTITY : Integer = 0;
	BY_VOLUME : Integer = 1; 
	BY_WEIGHT : Integer = 2;

begin
	if trackedItem.isBulkByWeight() then 
		return BY_WEIGHT;
	elseif trackedItem.isBulkByVolume() then
		return BY_VOLUME;
	else
		return BY_QUANTITY;
	endif;
end;</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceDesc" id="1f2ed933-456e-40ef-af22-a58e92ff00b3">
        <source>getYardSourceDesc() : String ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwrd1	Initial creation

*/
vars
	msgStr 		: String;
	isISOType	: Boolean;
	isEmpty		: Boolean;
	imex	: CM_IMEXStatus;
	obj		 	: Object;
	sep 		: String;
begin


	
	obj := self.cmbOperatorCode.listObject;
	if obj &lt;&gt; null then
		msgStr := msgStr &amp; sep &amp; 'Oper: ' &amp; obj.CM_Operator.code;
		sep := ', ';
	endif;
	
	if self.txtNumItems.getInteger() &gt; 0 then
		msgStr := msgStr &amp; sep &amp;' Total requested: ' &amp; self.txtNumItems.getInteger().String;
		sep := ', ';
	endif;
	
	if self.cmbISOGroup.getObject() &lt;&gt; null then	
		msgStr := msgStr &amp; sep &amp;'ISO Group: ' &amp; self.cmbISOGroup.getObject().CM_ISOTypeGroup.code;
		sep := ', ';
	endif;
	
	
	if self.cmbISOType.getObject() &lt;&gt; null then	
		msgStr := msgStr &amp; sep &amp;'ISO Type: ' &amp; self.cmbISOType.getObject().CM_ISOType.code;
		sep := ', ';
	endif;

	return msgStr;
/*
		obj := self.cmbType.getObject();
	if obj &lt;&gt; null then
		isISOType := rqst.myCargoType.isISOType();
	endif;
	
	
	if isISOType then
	// container
		isEmpty := (rqst.commodity = self.myTerminal.getDefaultEmptyCommodity());
		if rqst.isoType &lt;&gt; null then
			msgStr := addString(msgStr, "ISO : " &amp; rqst.isoType.trimBlanks);
		endif;
		if rqst.isoGroup &lt;&gt; null then
			msgStr := addString(msgStr, "ISO Group : " &amp; rqst.isoGroup.trimBlanks);
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL then
			imex:= app.myRoot.allImexStatuses[rqst.imexStatus];
			if imex &lt;&gt; null then
				msgStr := addString(msgStr, "IMEX : " &amp; imex.description);
			endif;
		endif;
		if isEmpty then
			msgStr := addString(msgStr, rqst.commodity);
			if rqst.clean then
				msgStr := addString(msgStr, "Clean");
			endif;
			if rqst.heavyRated then
				msgStr := addString(msgStr, " Heavy Duty");
			endif;
		else
			if rqst.commodity &lt;&gt; null then
				msgStr := addString(msgStr, "Commodity : " &amp; rqst.commodity);
			endif;
			if rqst.voyageCode &lt;&gt; null then
				msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
			endif;
			if rqst.consignee &lt;&gt; null then
				msgStr := addString(msgStr, " Deliver To : " &amp; rqst.consignee.trimBlanks);
			endif;
			if rqst.billOfLading &lt;&gt; null then
				msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
			endif;
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
		// Also get mt grade &amp; target location
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;
			msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	else
		// general cargo
		if rqst.myCargoType &lt;&gt; null then
			msgStr := addString(msgStr, "Cargo : "&amp; rqst.myCargoType.description);
			if rqst.mySubCargoType &lt;&gt; null then
				msgStr := addString(msgStr, rqst.mySubCargoType.description);
			endif;
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.mark &lt;&gt; null then
			msgStr := addString(msgStr, "Mark : " &amp; rqst.mark);
		endif;
		if rqst.voyageCode &lt;&gt; null then
			msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
		endif;
		if rqst.billOfLading &lt;&gt; null then
			msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;
			msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	endif;
*/
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceText" id="be32ec45-2cb3-40b2-8667-c1fce32b75ad">
        <source>getYardSourceText(_bestPick : Boolean) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwrd1	Initial creation

*/

vars
	ta 		: CM_TerminalArea;
	aGO		: CM_GridObject;
	sep 	: String;
	result 	: String;
	count	: Integer;
begin	

	count := 1;
	foreach ta in self.allSelectedTAs do
		if self.allSelectedTAGridObjs &lt;&gt; null and self.allSelectedTAGridObjs.size &gt;= count then
			aGO := self.allSelectedTAGridObjs[count];
		else
			aGO := null;
		endif;
			
		if aGO = null then
			result := result &amp; sep &amp; ta.id;
		else
			result := result &amp; sep &amp; ta.id &amp; '(' &amp; aGO.label &amp; ')';
		endif;
		
		sep := ', ';
		count := count +1;
	endforeach;
	
	/*if self.isBestPick and
	   result &lt;&gt; "" then
		result := result &amp; " (" &amp; app.getErrorString(Best_pick) &amp; ")";
	endif;*/
	
	return result;
epilog

end;</source>
        <Parameter name="_bestPick" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="grpAdditionalRel_doAlignCtrls" id="d412fa53-8bc9-4609-9c6d-34a2c3eecb97">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>grpAdditionalRel_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwjk3	Initial creation

*/

vars

begin
	// put button on the right hand side, and stretch the label to fit 
	self.btnAdditionalRel.move(_fieldGeneric.width - self.btnAdditionalRel.width, 0, self.btnAdditionalRel.width, _fieldGeneric.height);
	self.lblAdditionalRel.move(self.grpAdditionalRel.width - self.defaultControlWidth, 0, self.defaultControlWidth - self.btnAdditionalRel.width, _fieldGeneric.height);
	self.lblAdditionalRel.borderStyle := self.lblAdditionalRel.BorderStyle_None;
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="grpAdditionalRel_doTabOrder" id="810e428d-2d5d-46b1-a6d6-6434a7e7743a">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>grpAdditionalRel_doTabOrder(_startTab: Integer):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwjk3	Initial creation

*/

vars
	tabOrder	: Integer;

begin
	tabOrder 						:= _startTab;
	tabOrder 						:= tabOrder + 1;
	self.btnAdditionalRel.tabIndex	:= tabOrder;
	return tabOrder;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideReleaseByControls" id="b1c5bbf9-dfe2-4a18-856d-8b62e5e0e51d">
        <source>hideReleaseByControls(_isByType : Boolean; _cargoType : CM_CargoType) protected;
/*

Date		Who		Reason
17 November 2014	cnwer1	Initial creation PAR 35154

*/

vars

begin
	
	if  _isByType then	
		self.txtNumItemsBB.isHidden 		:= true;
		self.tblTotalVolume.isHidden:=true;
		self.tblTotalWeight.isHidden:= true;
		if _cargoType &lt;&gt; null then
			self.txtNumItems.isHidden 		:= true;
			self.tblWeight.isHidden:=true;
			self.tblVolume.isHidden :=true;
			if _cargoType.isBulkMulti then			// PAR #33606			
				self.tblWeight.isHidden :=  _cargoType.isBulkByVolume;					
				self.tblVolume.isHidden :=  _cargoType.isTrackByWeight;					
			elseif  _cargoType.isBreakBulkMulti then
				self.txtNumItems.isHidden 		:= false;		
			endif;															
		endif;		
	else	
		self.txtNumItems.isHidden := true;
		self.tblWeight.isHidden:= true;
		self.tblVolume.isHidden:=true;
		if _cargoType &lt;&gt; null then
			self.txtNumItemsBB.isHidden := true;
			self.tblTotalVolume.isHidden:=true;
			self.tblTotalWeight.isHidden:= true;
			
			if _cargoType.isBulkMulti then			// PAR #33606	
				self.tblTotalWeight.isHidden :=  _cargoType.isBulkByVolume;					
				self.tblTotalVolume.isHidden := _cargoType.isTrackByWeight;					
			elseif  _cargoType.isBreakBulkMulti then
				self.txtNumItemsBB.isHidden := false;
			endif;															
		endif;	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isByType" type="Boolean"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedControls" id="727b2e45-4b05-4f46-a4bb-cf12d897be9e">
        <updating/>
        <source>hideSelectedControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		7 April 2010 by cnwjo3
//
// Purpose:		Hide controls here so everything is positioned nicely on the form
//				par 23536
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 11/02/2011	cnwdap1		PAR #26929 Avoid using an invalid bulk release (there is no inverse between CMGTE_Release.myBulkRelease
//							and CM_BulkRelease class, so if a bulk release is deleted, we're left with an invalid reference on CMGTE_Release)
// 04/09/2012	cnwcs5		par 30172 - operator import release PIN security.  Field is hidden if no access
// 06 Sep 2013	cnwer1		par 32408 - hidden break bulk quantity field if not needed
// 25/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - hide/show ttoal weight / total quantity as appropriate
//26/6/14 		cnwer1		par 34406 bulk changes 
vars
	bulk 		: CM_BulkRelease;
	gteRelease : CMGTE_Release;
	cargoType	: CM_CargoType;							// PAR #33606
	allROBContainers : ObjectSet;
begin
	bulk := self.myBulkRelease;
	
	if bulk = null then
		if self.myRealGTEEntity &lt;&gt; null then
			if self.myRealGTEEntity.isKindOf(CMGTE_Release) then
				gteRelease:=self.myRealGTEEntity.CMGTE_Release;
			endif;
		endif;
	endif;
	
	self.cmbPackTo.isHidden:=true;
	if self.isGeneralCargo and self.myCurrentVehicleVisit &lt;&gt; null then
		create allROBContainers transient;
		self.myCurrentVehicleVisit.getAllReleaseContainerEntities(allROBContainers);
		
		if not allROBContainers.isEmpty then
			self.cmbPackTo.isHidden:=false;
		endif;
	endif;
	
	
	if gteRelease &lt;&gt; null then
		//release by ID
		if gteRelease.isReleaseById  then
			//self.cmbReleaseItem.isHidden 	:= true; // epr par 36674 1/9/15
			if self.updateMode = self.Mode_Update and self.myReserveDetail = null then
				self.cmbType.isHidden 	:= true;
			endif;
			
			if gteRelease.myTrackedItem &lt;&gt; null then	//25 Feb 2016	NDL	Par 37591
				cargoType :=gteRelease.myTrackedItem.myCargoType;
			endif;
			if cargoType &lt;&gt; null then
				self.hideReleaseByControls(false,cargoType);	
			endif;	
		else		
			//par 23614
			self.lblReleaseById.isHidden := true;
			self.cmbType.isHidden 		:= true;
			self.txtCargoID.isHidden 	:= true;	
			cargoType := gteRelease.myCargoType;
			if cargoType &lt;&gt; null then
				self.hideReleaseByControls(true,cargoType);	
			endif;	
		endif;		
	endif;
	
	//09 Jul 2012	NDL	Par 29703
	if not app.myRoot.isInterTerminalTransferEnabled then
		self.cmbDestTerminal.isHidden := true;
	endif;
	
	//epr CCMS 1409 355553 22/1/14
	if self.myTerminal.getConfig(UseReceiveReleaseEIR).Boolean then
		self.txtEquipXchg.isHidden:=true;
	endif;
	
	self.txtExtra.isHidden := not app.isCargoGroupEnabled;	//16 Jan 2018	NDL	TFS 42921
	
	//jlier1 TFS 53678 28/6/22
	if bulk = null or bulk.context &lt;&gt; RelReqContext_CargoGroupReview then
		if bulk &lt;&gt; null then
			if bulk.context &lt;&gt; RelReqContext_CargoGroupReview then
				self.tblWeightRequested.isHidden:=true;
			endif;
		else
			if gteRelease = null or gteRelease.myBulkRelease = null or gteRelease.myBulkRelease.context &lt;&gt; RelReqContext_CargoGroupReview then
				self.tblWeightRequested.isHidden:=true;
			endif;
		endif;
	elseif bulk &lt;&gt; null and bulk.context = RelReqContext_CargoGroupReview then
		if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.getMyCargoType &lt;&gt; null and self.myReserveDetail.getMyCargoType.isBulkByWeight then
			self.tblWeightRequested.isHidden:=true;
		endif;
	endif;
	
	inheritMethod();
epilog
	delete allROBContainers;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initDetailsForByTypeByWeight" id="7a90c1a8-9a6b-426c-bbcb-de441bc4ba16">
        <updating/>
        <source>initDetailsForByTypeByWeight() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 December 2023	navsp1	Initial creation TFS 61547
26 January	2024    navsp1  ChangeRequest 62064: EUP | Release Request by Weight - Road Gate Default Values
24 July 2024		navpw1	TFS: 61525 (61527) - Release by Type by Weight will now populate the release weight with the vbs items max weight/quantity if it has one
10/08/2024			navcs2  MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
04/12/2024			navbs1  Bug MTN-33546: MTN - Road Gate - Release Empty / Full unknown textbox issue
25 February 2025	navpw1	JIRA: MTN-33961 - Added support for a myRealGTEEntity so that the correct fields are enabled disabled and set to the correct values.
19/02/2025			navcs2  MTN-34062 - EUP | Release by Weight - further issues

*/

vars
	vbsProcess		: CM_VBSProcess;
	gteRelease		: CMGTE_Release;
	totalRequested	: Integer;
	totalWeight 	: Decimal[14,4];
	
begin
	if not self.isGeneralCargo then 				//04.12.2024  navbs1  #33546
		//releaseQty and releaseWeight are applicable only for General cargo
		return;
	endif;
	vbsProcess := self.myTerminal.getMyVBSProcess();
	
	//if self.isGeneralCargo and self.myBulkRelease &lt;&gt; null and self.myBulkRelease.releaseByType and self.myReserveDetail &lt;&gt; null then	//01.Feb.24 navsp1 TFS 62206 		//04.12.2024  navbs1  #33546
	if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.releaseByType and self.myReserveDetail &lt;&gt; null then																//04.12.2024  navbs1  #33546
		if self.myCurrentVehicleVisit &lt;&gt; null and self.myCurrentVehicleVisit.myVehicleBookingTimeslot = null then
			if self.isByTypeByWeight then 				
				self.chkAnyId.setValue(true);
				self.chkAnyAmount.setValue(true);
				self.chkAnyId.enabled := false;
				self.chkAnyAmount.enabled := false;
				self.chkAnyIdChanged();	
				self.cmbReleaseItem.visible	:= true;																	//10.Jan.24 navsp1 TFS 61547 / Task 61999
				if self.myRealGTEEntity = null then																		//29.Jan.24 navsp1 TFS 62064
					self.txtReleaseWeight.setValue(self.myReserveDetail.weightRequested);								//TFS 62064
					// ### TFS 61525 (61527) 15Jul2024 NAVPW1
					if vbsProcess &lt;&gt; null and																			// ### TFS 65399 26Jul2024 NAVPW1
						vbsProcess.isVbsSlotValidation and self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0
					then
						self.txtReleaseWeight.setValue(self.myVbsti.maxWeight);
					endif;
					// ### TFS 61525 (61527) 15Jul2024 NAVPW1
					self.txtReleaseQty.setValue(null);																	//01.Feb.24 navsp1 TFS 62206
				endif;
			else//Release by quantity																					//TFS 62064
				if self.myRealGTEEntity = null then
					self.txtReleaseQty.setValue(self.myReserveDetail.totalRequested);									//TFS 62064
					if vbsProcess &lt;&gt; null and																			// ### TFS 65399 26Jul2024 NAVPW1
						vbsProcess.isVbsSlotValidation and self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0
					then																								// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						self.chkAnyId.setValue(true);																	// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						self.chkAnyAmount.setValue(true);																// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						self.chkAnyIdChanged();																			// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						self.txtReleaseWeight.setValue(self.myVbsti.maxWeight);											// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						self.txtReleaseQty.enabled := false;															// 10/08/2024	navcs2  MTN-14819
					else																								// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and 									// ### TFS 65686 19Aug2024 NAVPW1
							self.myVbsti &lt;&gt; null and self.myVbsti.quantity &gt; 0
						then
							self.txtReleaseQty.setValue(self.myVbsti.quantity);
						endif;
						self.txtReleaseWeight.setValue(null);															//01.Feb.24 navsp1 TFS 62206
					endif;																								// ### TFS 61525 (61527) 15Jul2024 NAVPW1
				// ### JIRA: MTN-33961 25Feb2025 NAVPW1
				else
					gteRelease :=  self.myRealGTEEntity.CMGTE_Release;
					if gteRelease.totalQuantity &gt; 1 then
						totalRequested := gteRelease.totalQuantity;
					else
						totalRequested := self.myReserveDetail.totalRequested;
					endif;
					
					if vbsProcess &lt;&gt; null and																			// ### TFS 65399 26Jul2024 NAVPW1
						vbsProcess.isVbsSlotValidation and self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0
					then
						self.txtReleaseQty.setValue(totalRequested);
						
						if gteRelease.getIsAnyId then
							self.chkAnyId.setValue(true);
						endif;
						
						if gteRelease.getIsAnyAmount then
							self.chkAnyAmount.setValue(true);
							self.chkAnyIdChanged();
						endif;
						
						if gteRelease.releaseWeight &lt;&gt; null then
							totalWeight := gteRelease.releaseWeight;
						endif;
						
						//self.txtReleaseWeight.setValue(totalWeight);
						//self.txtReleaseQty.enabled := false;
					else																								// ### TFS 61525 (61527) 15Jul2024 NAVPW1
						
						if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and 									// ### TFS 65686 19Aug2024 NAVPW1
							self.myVbsti &lt;&gt; null and self.myVbsti.quantity &gt; 0
						then
							if gteRelease.totalQuantity &gt; 1 then
								totalRequested := gteRelease.totalQuantity;
							else
								totalRequested := self.myVbsti.quantity;
							endif;
							self.txtReleaseQty.setValue(totalRequested);
						endif;
						//self.txtReleaseWeight.setValue(null);
						//self.txtReleaseWeight.visible := false;
					endif;
					//19/02/2025			navcs2  MTN-34062
					if gteRelease &lt;&gt; null and gteRelease.releaseQuantity &gt; 1 then
						self.txtReleaseQty.visible := true;
						self.txtReleaseWeight.visible := false;
					else
						self.txtReleaseQty.visible := false;
						self.txtReleaseWeight.visible := true;
					endif;
					//19/02/2025			navcs2  MTN-34062
				// ### JIRA: MTN-33961 25Feb2025 NAVPW1
				endif;
			endif;
		endif;
	else
		self.setByTypeByWeight();
	endif;
epilog

end;</source>
    </JadeMethod>
