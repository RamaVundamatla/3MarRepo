    <JadeMethod name="trxUpdateToDoTaskTimeStamp" id="21e74fba-5786-4e7c-9e73-2a97288e3eea">
        <updating/>
        <source>trxUpdateToDoTaskTimeStamp(_toDoTaskCode : Integer; _ts : TimeStamp; _ti : CM_TrackedItem io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	22 January 2009 By Graeme Black cnwgb1
// Purpose:	Update a todo task's timestamp. This may involve other timestamps 
//          including transactions and some timestamps on a tracked item
// Note:This is a version of 
//		MobileServerSchema::CM_TrxControlRTAgent::trxUpdateToDoTasksTs
// 		When created, this method was designed to be used by Handhelds as part
//      of PNL CCMS 1658 (PAR 18787 )
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	beginTransaction;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	app.myUtilityUA.utlUpdateToDoTaskTimeStamp(_ti, _toDoTaskCode, _ts, _passport);
	
	return;
	
epilog

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateToDoTasksWarehouse" id="4720cab6-c55b-4711-bed0-e2c47f91f56d">
        <updating/>
        <source>trxUpdateToDoTasksWarehouse(	_tasksToAdd, _tasksToComplete : IntegerArray;
								_ti : CM_TrackedItem input;
								_resourceUsageProxies : CM_ResourceTypeUsageSet input;
								_passport : CM_Passport input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2015	cnwdap1		Initial creation PAR #36231 New for this PAR
//
vars
	toDoTask : Integer;
	toDoTaskDesc : CM_ToDoTaskDesc;
	resources : CM_ResourceTypeUsageSet;
	obj : CM_Object;
	resource : CM_ResourceType;
	resourceUsage : CM_ResourceTypeUsage;
	tiSet : CM_TISet;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	// DVB change trx to use defered updates. 05/04/05
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	create resources transient;
	create tiSet transient;
	tiSet.add(_ti);
	
	beginTransaction;
	
	// add tasks
	foreach toDoTask in _tasksToAdd do
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[toDoTask];
		if toDoTaskDesc = null then
			continue;
		endif;
		
		// check if we have any resources for this to do task
		resources.clear;
		foreach obj in toDoTaskDesc.allResourceTypes discreteLock do
			resource := obj.CM_ResourceType;
			foreach resourceUsage in _resourceUsageProxies where resourceUsage.myResourceType = resource do
				resources.add(resourceUsage);
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateTIToDoTasksWarehouse(toDoTaskDesc, tiSet, STATUS_TODO, resources, _passport);
	endforeach;
	
	// complete tasks
	foreach toDoTask in _tasksToComplete do
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[toDoTask];
		if toDoTaskDesc = null then
			continue;
		endif;
		
		// check if we have any resources for this to do task
		resources.clear;
		foreach obj in toDoTaskDesc.allResourceTypes discreteLock do
			resource := obj.CM_ResourceType;
			foreach resourceUsage in _resourceUsageProxies where resourceUsage.myResourceType = resource do
				resources.add(resourceUsage);
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateTIToDoTasksWarehouse(toDoTaskDesc, tiSet, STATUS_COMPLETE, resources, _passport);
	endforeach;
	
	_passport.doDeferredUpdates();
		
epilog
	delete resources;
	delete tiSet;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tasksToAdd" type="IntegerArray"/>
        <Parameter name="_tasksToComplete" type="IntegerArray"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_resourceUsageProxies" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
