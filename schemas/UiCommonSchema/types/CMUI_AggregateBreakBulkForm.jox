    <JadeMethod name="translateForm" id="d9ffd022-d615-4826-bab3-3556e1a75a89">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 02 May 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019627, locale);
	lblCargoType.translateCaption(Xlat_0019628, locale);
	lblId.translateCaption(Xlat_0019629, locale);
	lblNewLocation.translateCaption(Xlat_0019630, locale);
	lblPkgingWeight.translateCaption(Xlat_0019631, locale);
	lblSelectBBs.translateCaption(Xlat_0019632, locale);
	lblSelectBulk.translateCaption(Xlat_0019633, locale);
	lblSubCargoType.translateCaption(Xlat_0019634, locale);
end;</source>
    </JadeMethod>
