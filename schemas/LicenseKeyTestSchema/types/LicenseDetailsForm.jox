<GUIClass name="LicenseDetailsForm" id="a806c6dc-1470-4536-a941-0454cbc603f1">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="aMyLicenseInfo" id="b04d480c-e091-46da-a9a6-6d4fb4116434">
        <embedded/>
        <type name="LicenseInfo"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnCancel" id="d0bfd650-0dd0-45d0-8968-320fc382480f">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="83a95f3a-5be0-46cc-a6da-4954e0af3fde">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblKey" id="e59e06d3-428c-4308-9f6a-aac42ceac21c">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblName" id="76f20c5c-1969-4a58-93c5-798231a5285a">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtKey" id="266a5460-0982-4797-b6f5-2dd8834d90ee">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtName" id="7fd581fa-f2ba-4f0e-9065-1a92dbdd4ab3">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="28488ed7-d283-4162-8ee4-c35d9b3480aa">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="b590cf19-e749-49ed-9e1e-0db7899ec709">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate() then
		self.modalResult	:=	self.JSS_MODAL_UPDATE;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="2a7ab206-9e78-4fce-b7c4-a294ee9a77a9">
        <updating/>
        <source>doFormUpdate():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Update the license details.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseInfo	: LicenseInfo;
	customerName	: String;
	productCode		: String;
	licenseKey		: String;
	
begin
	theLicenseInfo	:=	self.aMyLicenseInfo;
	customerName	:=	txtName.jssString();
	licenseKey		:=	txtKey.jssString();
	
	// Update the license details in the peer schema.
	
	productCode	:=	app.myLicense.enterLicenseKey(customerName, licenseKey);
	
	// Now update the license details locally.
	
	if productCode &lt;&gt; null then
		if theLicenseInfo = null then
			theLicenseInfo	:=	app.myTestData.createLicenseInfo(customerName, productCode, licenseKey);
			self.aMyLicenseInfo	:=	theLicenseInfo;
		else
			app.myTestData.updateLicenseInfo(theLicenseInfo, customerName, productCode, licenseKey);
		endif;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="b6cacc4d-fa9b-4780-96b7-5ca866e00ab3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		28 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseInfo	: LicenseInfo;
	
begin
	centreWindow();
	theLicenseInfo	:=	self.aMyLicenseInfo;
	
	if theLicenseInfo &lt;&gt; null then
		txtName.text	:=	theLicenseInfo.customerName;
		txtKey.text		:=	theLicenseInfo.licenseKey;
	endif;
	
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setLicenseInfo" id="975aa446-3736-4da7-9b11-b991ea2df539">
        <updating/>
        <source>setLicenseInfo(pTheLicenseInfo:LicenseInfo) updating;
// --------------------------------------------------------------------------------
// Created:		28 March 2003 by cnwdad1
//
// Purpose:		Sets a local reference to the license info object being updated.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyLicenseInfo	:=	pTheLicenseInfo;
end;</source>
        <Parameter name="pTheLicenseInfo" type="LicenseInfo"/>
    </JadeMethod>
</GUIClass>
