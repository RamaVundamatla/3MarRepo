    <JadeMethod name="setupForm" id="c5609eb3-96dc-4b39-9a7d-9c3e63b3414d">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//2/10/2017			jlgns1			TFS 6865 PKT - Weighbridge Connection Issue
//24/10/17			jlgns1			TFS 7308 PKT - Road Job Cancellation Issue	
//20/11/2017		jlgmd1			TFS 7610 PKT - REQUIRED FIELD FOR REPORTING
//19/04/2018		jlgns1 			Bug 38134: PKT - Weight Discrepancy
//02/06/2022		navhl20			TFS 52777 EUP - INT - Generic API: record-scan
//12/07/2022		navmd1			TFS 52777 Tidy up/review code
// ---------------------------------------------------------------------------

vars
	hideBat 				: Boolean;
	securityGate			: Boolean;					
	measure 				: CM_MeasurementType;	
	hasSerialWeighBridge	: Boolean;
	myLane 					: CM_GateAreaLaneController;
	weighBridge 			: CM_WeighBridgeObj;			//19 Jul 2021	NDL	TFS 51575
	hasOtherWeighBridge 	: Boolean;						//19 Jul 2021	NDL	TFS 51575
	laneCont 				: CM_GateAreaLaneController;	//19 Jul 2021	NDL	TFS 51575
	gate 					: CM_Gate;						//19 Jul 2021	NDL	TFS 51575
	detailsChangedVehicle	: Boolean;
begin
	inheritMethod();
	
	self.weighbridgeLblValue := self.lblWeibridge.caption;
	self.allowManualWeight := app.getMyUser.canDo(self.myTerminal,PmGteBulkWeighMan);
	
	create self.myBulkGateAgent transient;	
	self.myBulkGateAgent.myTerminal := self.myTerminal;
		
	hasSerialWeighBridge := self.myBulkGateAgent.setSerialWeighbridge(OUT_YO);//TFS 6865
	
	//19 Jul 2021	NDL	TFS 51575
	if not hasSerialWeighBridge then
		weighBridge := self.myTerminal.allWeighBridges.getMyDefaultWeighBridge();
		if weighBridge &lt;&gt; null then
			self.myBulkGateAgent.setMyWeighBridge( weighBridge );
			hasOtherWeighBridge := true;
			laneCont := weighBridge.myGateLane;
			if laneCont &lt;&gt; null then
				self.myBulkGateAgent.setGateAreaLaneController( laneCont );
				gate :=	laneCont.getGate;
				if gate &lt;&gt; null then
					self.myBulkGateAgent.setGate( gate );
				endif;
			endif;
		else
			// Moved to later, as we need the Gate first before we can work out which Generic Weighbridge or Scan Reader to use													// TFS 52777
			//app.msgBox( app.getErrorString1(NoAssoc_weigh_bridg_check_term, app.computerName), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );	// TFS 52777
		endif;
	endif;
	
	self.myBulkGateAgent.getGateFromSetup;
	
	if hasSerialWeighBridge then				//TFS 6865
		self.setupWeightInterface(); 
		self.cmbGate.listIndex := self.cmbGate.findObject(self.myBulkGateAgent.myGate);
		
		self.cmbGateLanes.listIndex := self.cmbGateLanes.findObject(self.myBulkGateAgent.myGateAreaLaneController);
		self.lblWeibridge.caption := app.getErrorString(Connection_starting);	//Bug 38134
		self.btnGetWeight.visible := false;										//Bug 38134
	
	//16 Jul 2021	NDL	TFS 51575
	elseif hasOtherWeighBridge then
		self.setupOtherWeightInterface();
		self.cmbGate.listIndex := self.cmbGate.findObject(self.myBulkGateAgent.myGate);				
		self.cmbGateLanes.listIndex := self.cmbGateLanes.findObject(self.myBulkGateAgent.myGateAreaLaneController);
		self.lblWeibridge.caption := weighBridge.name;
		self.btnGetWeight.visible := true;	
	
	else
		self.setWeighbridgeLabel(false);		//TFS 6865						//Bug 38134
	endif;								//TFS 6865
	
	self.doBuildGateCombo();	
			
	self.setNavigatorHeading(self.caption);
	
	if self.myBulkGateAgent.myWeighBridge = null then
		app.msgBox( app.getErrorString1(NoAssoc_weigh_bridg_check_term, app.computerName), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );	// TFS 52777 moved down
	endif;
	
	self.initTable();	
	self.loadDataForFirstTime();

	//self.loadPrinterCombo();				// called by doBuildGateCombo above in onGateChange
	//self.setupGenericWeightInterface();	// called by doBuildGateCombo above in onGateChange
		
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.enableActionButtons(false);
		self.enableFields(false);
		self.txtRegno.setFocus();
	endif;
		
	if not app.myCurrentUserCan(self.myTerminal, PmGteCanPrintFlexiGate) then
		self.cmbPrinter.enabled := false;
		self.cmbPrinter.bubbleHelp := "You do not have permission to print. See your administrator.";
	endif;
	 
	if not app.myCurrentUserCan(self.myTerminal, PmGteBulkOutMaint) then
		self.btnSave.enabled := false;
		self.btnSave.bubbleHelp := "You do not have permission to create a road job. See your administrator.";
		//self.btnCancel.enabled := false;											//TFS 7308
	endif;
		
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then	//TFS 7308
		self.btnCancel.enabled := false;											//TFS 7308
	endif;																			//TFS 7308
		
	self.setupChkAutoComplete();
	self.txtWeightOUT.setup(Type_Weight, self.backColor);		
	self.txtWeightOUT.selectMode := Table.SelectMode_None;	
	measure := app.getDefaultMeasurementForType(Type_Weight);														
	self.txtWeightOUT.setValues(app.convertMeasurementForDisplay(measure.shortName,0) &amp; Space &amp; measure.shortName);
		
	hideBat := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	securityGate := self.myTerminal.getConfig(SiteHasSecurityGate).Boolean;
	if not hideBat  and not securityGate then								
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	endif;
	
	if self.grpTop.isInPainter() then
	 	self.grpTop.zOrder(1);
	else
		self.grpTop.transparent := true;
	endif;
	
	//19 Apr 2017	NDL	TFS 4126
	if  self.mySerialWeightIntController &lt;&gt; null and self.mySerialWeightIntController.hasValidConnection then
		self.txtWeightOUT.setFieldsEnabled( self.allowManualWeight );	
	else
		//self.txtWeightOUT.setFieldsEnabled( app.getMyUser.canDo(self.myTerminal,PmGteBulkInMaint) );
		self.txtWeightOUT.setFieldsEnabled( self.allowManualWeight ); // After confirmation from Salman
	endif;
	
	// 20 Nov 2017 jlgmd1 TFS 7610
	if self.myBulkGateAgent.myGateAreaLaneController = null then
		self.myBulkGateAgent.setGateAreaLaneController(cmbGateLanes.listObject.CM_GateAreaLaneController);
	endif;
	
	//21 Jul 2021	NDL	TFS 51575
	self.txtWeightOUT.setFieldsEnabled( self.allowManualWeight );
	self.lblWeighbridgeMessage.visible := app.getMyUser.isSuperUser;
	
	self.myAssistant.populateScanData(false, false, detailsChangedVehicle, self.txtRegno,
		null, null, null, null, null, null, self.txtWeightOUT, self.myAssistant.myCurrentGateScanRecord);		// TFS 52777
	
	//self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATESCAN_CREATE), Response_Continuous, null); // ### TFS 54311 18Oct2022 NAVPW1 // ### TFS N/A 22Nov2023 NAVPW1 - Commented for Major Release
	//self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATESCAN_UPDATE), Response_Continuous, null); // ### TFS 54311 18Oct2022 NAVPW1 // ### TFS N/A 22Nov2023 NAVPW1 - Commented for Major Release
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupGenericWeightInterface" id="5135ff08-d04a-4516-ba17-46b5bc5857c7">
        <updating/>
        <source>setupGenericWeightInterface() protected, updating;
/*

Purpose:			Choose a relevant GenericAPI Weighbridge or Scan Reader for our current Gate/Lane combo

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navmd1	Initial creation TFS 52777 Generic Interface API Weighbridge/ScanReaders

*/

vars
	gateLane				: CM_GateAreaLaneController;
	weighBridge				: CM_WeighBridgeObj;
	reader					: CM_ScanReaderObj;
	usingGenericWeighBridge	: Boolean;
begin
	if self.myBulkGateAgent.myGate = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Bulk Gate Agent doesn't have a Gate assigned, unable to continue");
		return;
	endif;
	
	// Only act as the weigh bridge if nothing else is connected
	weighBridge := self.myBulkGateAgent.myWeighBridge;
	if weighBridge = null then
		usingGenericWeighBridge := true;
	else
		usingGenericWeighBridge := weighBridge.isGenericScanAPI;
	endif;
	
	if self.cmbGateLanes.visible then
		gateLane := self.cmbGateLanes.listObject.CM_GateAreaLaneController;
	else
		// Just use the first lane and see what we get
		gateLane := self.myBulkGateAgent.myGate.getFirstPGateLane_OUT.CM_GateAreaLaneController;
	endif;
		
	if gateLane = null then
		return;
	endif;
	
	self.myAssistant.allAssociatedDevices.clear();
	self.myAssistant.clearCurrentGateScanRecord();
	
	// Add a weighbridge if we have one
	if usingGenericWeighBridge then
		self.myBulkGateAgent.setMyWeighBridge(null);	// Clear the old one
		self.lblWeibridge.caption := self.weighbridgeLblValue;
		self.btnGetWeight.visible := false;
		
		weighBridge := gateLane.getWeighBridge();
		if weighBridge &lt;&gt; null then
			self.myBulkGateAgent.setMyWeighBridge(weighBridge);
			self.myAssistant.allAssociatedDevices.putAtKey(weighBridge.deviceId, weighBridge);
			
			// Special just for these weighbridges and this form, update the caption
			self.lblWeibridge.caption := weighBridge.name;
		endif;
	endif;
	
	// Add a reader if we have one
	reader := gateLane.getScanReader();
	if reader &lt;&gt; null then
		self.myAssistant.allAssociatedDevices.putAtKey(reader.deviceId, reader);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOtherWeightInterface" id="aa9659c8-c6e1-4e97-970f-0cba613e0788">
        <updating/>
        <source>setupOtherWeightInterface() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

	weighBridge	: CM_WeighBridgeObj;
	weightIntefaceClass : Class;

begin

	if self.myOtherWeightIntController &lt;&gt; null then
		delete self.myOtherWeightIntController;
	endif;

	weighBridge := self.myBulkGateAgent.myWeighBridge;
	
	if weighBridge = null then
		return;
	endif;
		
	weightIntefaceClass := weighBridge.myWeighBridgeType.getWeightInterfaceClass;
		
	if weightIntefaceClass &lt;&gt; null then
		create self.myOtherWeightIntController as weightIntefaceClass transient;
		self.myOtherWeightIntController.setWeightCallerInterface( self.IF_TCPWeightCallerInterface );
		self.myOtherWeightIntController.initializeWithWeighbridge( weighBridge );
		executeWhen JMTDevelopmentEnvironment;
			if app.msgBox("Dev only NON-PKT weigh bridge simulation" &amp; CrLf &amp; "Click YES to auto-generate a weight on time-out" &amp; CrLf &amp;	
				"Click NO to continue as normal", "Weighing Simulation", MsgBox_Yes_No) = MsgBox_Return_Yes then
				self.myOtherWeightIntController.testMode := 1;
			endif;	
		endExecuteWhen;
	endif;	
		
	self.hasWeightInterfaceError := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupWeightInterface" id="26ae641d-f6f0-41d1-8ae0-002a0dc588d5">
        <updating/>
        <source>setupWeightInterface()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

constants

vars
	lWeighBridge	: CM_WeighBridgeObj;
	profileString	: String;
	iniFileName		: String;
	
begin
	lWeighBridge:= self.myBulkGateAgent.myWeighBridge;
	
	if lWeighBridge = null or lWeighBridge.mySerialDetails = null then
		return;
	endif;
	// In development only, check ini file for dummy weighing interface
	executeWhen JMTDevelopmentEnvironment;																							//Bug 38134
		if app.msgBox("Dev only PKT weigh bridge simulation" &amp; CrLf &amp; "Click YES then run app DevSchema MachineWeighSimulator to activate" &amp; CrLf &amp;	//Bug 38134
			"Click NO to continue as normal", "Weighing Simulation", MsgBox_Yes_No) = MsgBox_Return_Yes then						//Bug 38134
			create self.mySerialWeightIntController as CM_SerialWeightIntControllerXX transient;									//Bug 38134
		endif;																														//Bug 38134
	endExecuteWhen;																													//Bug 38134
		
	if self.mySerialWeightIntController = null then
		create self.mySerialWeightIntController transient;
	endif;
	
	self.mySerialWeightIntController.initializeWithSerialDetails(lWeighBridge.mySerialDetails);
		
	self.mySerialWeightIntController.setWeightCallerInterface(self.IF_TCPWeightCallerInterface);
	
	if self.mySerialWeightIntController &lt;&gt; null then
		self.mySerialWeightIntController.startListening;		
	endif;
		
	self.hasWeightInterfaceError:=false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
