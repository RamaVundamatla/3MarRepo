    <JadeMethod name="addToolbarControls" id="e008c1ff-a1a1-4c0b-b888-89ab2e304bf4">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmLineConvertOp,CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkInvoiceLines" id="d2b3351a-99ae-4e83-9bb5-1d18ed2c10d7">
        <source>checkInvoiceLines(): Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceLine:        CM_InvoiceLine;
	countBUs:           Integer;
	countLineDescs:     Integer;
	countVoid:          Integer;
	countPosted:        Integer;
	msgString:          String;
	value:              Boolean;
	invLineDescs : CM_InvoiceLineDescByNarrDict;
begin
	create invLineDescs transient;
	foreach invoiceLine in self.allInvoiceLines do
		if not invLineDescs.includes(invoiceLine.invoiceLineDesc) then
			invLineDescs.add(invoiceLine.invoiceLineDesc);
		endif;
		if invoiceLine.bank &lt;&gt; self.myCurrentBank then
			countBUs := 2;
			break;
		endif;

		if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
			countVoid := countVoid + 1;
		elseif invoiceLine.invoice.isPosted then
			countPosted := countPosted + 1;
		endif;
	endforeach;

	self.frmLineConvertOp.enabled := invLineDescs.size &gt; 1;
	
	if countBUs &gt; 1 then
		msgString := "There are lines belonging to different business units in the in the current collection." &amp;
			CrLf &amp; CrLf &amp; "Only lines from the same business unit can be changed in a group!";
		app.msgBox(msgString, "Multiple business unit error!", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if countVoid &lt;&gt; 0 then
		if countPosted &lt;&gt; 0 then
			msgString := "There are " &amp; countVoid.String &amp; " voided invoice lines and " &amp; 
						 countPosted.String &amp; " posted invoice lines in the current collection." &amp;
						 CrLf &amp; CrLf &amp; "These will be ignored.  Do you wish to continue?";
		else
			msgString := "There are " &amp; countVoid.String &amp; " voided invoice lines in the current collection." &amp;
						 CrLf &amp; CrLf &amp; "These will be ignored.  Do you wish to continue?";
		endif;
	elseif countPosted &lt;&gt; 0 then
		msgString := "There are " &amp; countPosted.String &amp; " posted invoice lines in the current collection." &amp;
					 CrLf &amp; CrLf &amp; "These will be ignored.  Do you wish to continue?";
	endif;

	value := true;

	if msgString &lt;&gt; "" then
		if app.msgBox(msgString, "Ignore invoice lines?", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			value := false;
		endif;
	endif;

	return value;
epilog
	delete invLineDescs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="866e4cd5-a97c-4508-9bd2-3b3227294267">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmInvoicelistView;
