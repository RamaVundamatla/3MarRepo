    <JadeMethod name="checkSelected" id="7c260a97-ce55-426b-ae37-cfc2cc16c410">
        <source>checkSelected();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	lastSelected : Object;
begin
	
	if self.canOnlySelectOne then
		lastSelected:=self.tblAvailable.allSelectedObjects.last;
		if lastSelected &lt;&gt; null then
			self.tblAvailable.clearSelected;
			self.tblAvailable.addSelectedObject(lastSelected);
		endif;
	endif;
	
	
	if self.tblAvailable.allSelectedObjects.size &gt; 0 then
		self.chkSelect.value:=true;
		self.chkSelect.caption:=Space &amp; app.getErrorString(None);
	else
		self.chkSelect.value:=false;
		self.chkSelect.caption:=Space &amp; app.getErrorString(CM_LIT_ALL);
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
