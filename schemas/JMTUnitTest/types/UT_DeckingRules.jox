    <JadeMethod name="tYA_RTG" id="62672f37-9f11-49cc-904f-bc97bbf6ba1d">
        <source>tYA_RTG();
// cnwndl1
//31 December 2008	cnwdw1	
// Test the correct decking rules are picked up by a YA on a RTG
vars
	rtg: CM_RTGArea;
	lanes, rows, stacks, tiers: Integer;
	stack, row, tier: Integer;
	locations: CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	msg: String;
	index: Integer;
	locationCell: CM_YALocationCell;
	yaLocationCells: CM_YALocationCellArray;
begin
	self.deleteTerminalArea("UTRTG01");
	self.deleteTerminalArea("UTRTG02");
	self.deleteTerminalArea("UTRTG03");
	lanes := 3;
	rows := 4;
	stacks := 5;   // columns
	tiers := 4;
	rtg := self.addRTGArea("UTRTG01",  rows, stacks, tiers);
	assertNotNull(rtg);
	
	rtg := self.addRTGArea("UTRTG02",  rows, stacks, tiers);
	assertNotNull(rtg);
	
	rtg := self.addRTGArea("UTRTG03",  rows, stacks, tiers);
	assertNotNull(rtg);
	
	self.deleteYA("UT");
	
	create locations transient;
	locations.add(rtg.allGridControllersByRowColumn[1,1]);
	locations.add(rtg.allGridControllersByRowColumn[4,5]);

	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	self.updateDeckingRulesYA("UT", IN, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Decreasing, DeckingRule_Columnwise, 0);

	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach stack in 1 to stacks do
		foreach row in rows to 1 step -1 do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	self.updateDeckingRulesYA("UT", IN, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach stack in 1 to stacks do
		foreach row in 1 to rows do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;

	self.updateDeckingRulesYA("UT", IN, DeckingRule_ByStack, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Tierwise, 0);
	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach tier in 1 to tiers do
		foreach stack in 1 to stacks do
			foreach row in 1 to rows do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
epilog
	delete locations;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYA_Straddle" id="9739e39f-600c-4644-a663-16c76a76d454">
        <source>tYA_Straddle();
// cnwndl1
//31 December 2008	cnwdw1	
// Test the correct decking rules are picked up by a YA on a Straddle Stack
vars
	straddleStack: CM_StraddleStack;
	rows, stacks, tiers: Integer;
	stack, row, tier: Integer;
	locations: CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	msg: String;
	index: Integer;
	locationCell: CM_YALocationCell;
	yaLocationCells: CM_YALocationCellArray;
	customOrder: IntegerArray;
begin
	create customOrder transient;
	
	self.deleteTerminalArea("UTSTRD");
	
	rows := 2;
	stacks := 2;
	tiers := 2;
	straddleStack := self.addStraddleStack("UTSTRD", rows, stacks, tiers);
	assertNotNull(straddleStack);
	
	self.deleteYA("UT");
	// Set a YA on all locations

	create locations transient;
	locations.add(straddleStack.allGridControllersByRowColumn[1,1]);
	locations.add(straddleStack.allGridControllersByRowColumn[2,2]);

	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, rows*stacks*tiers);
	assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut.size, rows*stacks*tiers);
	assertTrue(ya.allYABlocksIn.first.myDeckingOptions.useReverseOfIn);
	
	self.updateDeckingRulesYA("UT", IN, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	assertTrue(ya.allYABlocksIn.first.myDeckingOptions.useReverseOfIn);
	// Validate order of cells
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach row in 1 to rows do
		foreach stack in 1 to stacks do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Validate order of Out - should be reverse of In
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut;
	foreach row in rows to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in tiers to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// Check that location cells are in both collections
	foreach locationCell in ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn do
		assertTrue(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;

	// reverse the order for custom IN
	customOrder.clear;
	foreach index in rows*tiers*stacks to 1 step -1 do
		customOrder.add(index);
	endforeach;
	self.updateDeckingRulesCustomYA("UT", IN, customOrder);
	assertTrue(ya.allYABlocksIn.first.myDeckingOptions.useReverseOfIn);
	assertTrue(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.isCustom);

	// Check that location cells are in both collections
	foreach locationCell in ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn do
		assertTrue(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;

	// Validate order of IN - should now be reversed
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach row in rows to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in tiers to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// validate order of Out - reverse of in
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut;
	foreach row in 1 to rows do
		foreach stack in 1 to stacks do
			foreach tier in 1 to tiers do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	

	// Reverse the order for custom OUT
	customOrder.clear;
	foreach index in rows*tiers*stacks to 1 step -1 do
		customOrder.add(index);
	endforeach;
	self.updateDeckingRulesCustomYA("UT", OUT, customOrder);
	assertFalse(ya.allYABlocksIn.first.myDeckingOptions.useReverseOfIn);
	assertTrue(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesOut.first.isCustom);

	// Check that location cells are in both collections
	foreach locationCell in ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn do
		assertTrue(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut.includes(locationCell));
	endforeach;

	// Validate order of IN - should be unchanged
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn;
	foreach row in rows to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in tiers to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
	// validate order of Out 
	index := 1;
	yaLocationCells := ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsOut;
	foreach row in rows to 1 step -1 do
		foreach stack in stacks to 1 step -1 do
			foreach tier in tiers to 1 step -1 do
				locationCell := yaLocationCells[index];
				msg := "Index:"&amp;index.String&amp;" Stack:"&amp;stack.String&amp;" Row:"&amp;row.String&amp;" Tier:"&amp;tier.String;
				assertEqualMsg(locationCell.column, stack, "S "&amp;msg);
				assertEqualMsg(locationCell.height, tier, "T "&amp;msg);
				assertEqualMsg(locationCell.row, row, "R "&amp;msg);
				index := index + 1;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete customOrder;
	delete locations;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uDisplayDeckingSequence" id="4d7ff856-f711-4f9b-8656-b470b180c269">
        <source>uDisplayDeckingSequence();
//05 January 2009	cnwdw1	
//
vars
	taName: String;
	ta: CM_TerminalArea;
	location: CM_LocationsController;
	yaLocationCell: CM_YALocationCell;
	i: Integer;
begin
	taName := "TA name";
	read taName;
	ta := self.getTerminalArea(taName);
	if ta &lt;&gt; null and ta.myYADeckingOptions &lt;&gt; null then
		foreach yaLocationCell in ta.myYADeckingOptions.allYALocationCellsIn do
			i := i + 1;
			
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupDeckingOptionLocnCells" id="052d21e8-a8fb-4024-a26b-05e0286fc195">
        <source>uFixupDeckingOptionLocnCells();
//05 January 2009	cnwdw1	
//
vars
	taName: String;
	ta: CM_TerminalArea;
	location: CM_LocationsController;
	yardLocation: CM_YardController;
	yaLocationCell: CM_YALocationCell;
	h, i, addedCount: Integer;
	yaBlock: CM_YABlock;
begin
	taName := "TA name";
	read taName;
	ta := self.getTerminalArea(taName);
	beginTransaction;
	if ta &lt;&gt; null and ta.myYADeckingOptions &lt;&gt; null then
		ta.myYADeckingOptions.allYALocationCellsIn.purge;
		ta.myYADeckingOptions.allYALocationCellsOut.purge;
		foreach location in ta.allLocationsControllers where location.isKindOf(CM_YardController) do
			yardLocation := location.CM_YardController;
			foreach yaBlock in yardLocation.allYABlocks do
				if yaBlock.myDeckingOptions &lt;&gt; null then
					yaBlock.myDeckingOptions.allYALocationCellsIn.purge;
					yaBlock.myDeckingOptions.allYALocationCellsOut.purge;
				endif;
			endforeach;
		endforeach;
	endif;
	ta.myYADeckingOptions.allDeckingRulesIn.first.setPropertyValue(CM_YADeckingRule::deckingRuleType.name, Height_Then_Next_Row_Pos);
	ta.myYADeckingOptions.allDeckingRulesOut.first.setPropertyValue(CM_YADeckingRule::deckingRuleType.name, DeckingRule_ReverseOfOther);
	
	ta.applyDeckingRulesToCellOrder();

	commitTransaction;
	
epilog
	abortTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="uValidateTADeckingRules" id="d2025953-3365-468a-95bf-d8b4ff0f351f">
        <source>uValidateTADeckingRules();
//05 January 2009	cnwdw1	
//
vars
	ta: CM_TerminalArea;
begin
	foreach ta in self.getTerminal.allTerminalAreas do
		if ta.myYADeckingOptions &lt;&gt; null then
			if ta.myYADeckingOptions.allYALocationCellsIn.size &lt;&gt; ta.myYADeckingOptions.allYALocationCellsOut.size then
				logMessage(ta.id &amp; " location cells different");
			endif;
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
</Class>
