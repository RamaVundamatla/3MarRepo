// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	op		: CM_Operator;
begin
	op := combobox.listObject.CM_Operator;
	self.myOperator := op;

	self.myReportAgent.doCmbOperatorClick(op, self.cmbLogOperation);
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_lostFocus" id="371a41c1-e165-4241-be28-569f1273de5a">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/05/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------
vars
	op		: CM_Operator;
begin
	op := combobox.listObject.CM_Operator;
	
	if op &lt;&gt; null then
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then				// TFS 53362
			tblParameter.setValueByControlName(combobox.name, op.description);	// TFS 53362
		else																	// TFS 53362
			tblParameter.setValueByControlName(combobox.name, op.code);
		endif;																	// TFS 53362
	else
		tblParameter.setValueByControlName(combobox.name, Any_String);
	endif;
	self.myOperator := op;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
