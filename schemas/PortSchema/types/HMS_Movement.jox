    <JadeMethod name="getWorkOrder" id="d9f1d09c-584f-447d-b552-7a666d170267">
        <source>getWorkOrder() : CM_WorkOrder;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/04/2019	jlgdap1		Initial creation TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars
	voyage : CM_Voyage;
	workOrder : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;

begin
	voyage := self.getMyVoyage;
	if voyage &lt;&gt; null then
		foreach workOrder in voyage.allWorkOrders discreteLock do
			if self.moveType = HMSMovementTypeShift and workOrder.isWorkOrderForShift then
				woDtl := workOrder.allWoDtls.first;
				if woDtl.CM_WodShiftMovement.myHMSVoyageMovement = self then
					return workOrder;
				endif;
			
			elseif self.moveType = HMSMovementTypeArrival and workOrder.isWorkOrderForIMSR then
				return workOrder;
				
			elseif self.moveType = HMSMovementTypeDeparture and workOrder.isWorkOrderForExtension then
				return workOrder;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
