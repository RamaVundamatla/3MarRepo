    <JadeMethod name="cloneForCopy" id="28474387-5f97-4697-8b86-9b870c8dc2c0">
        <source>cloneForCopy(_transient : Boolean; _validOnly : Boolean; _todayDate : Date) : SelfType;
/*

Purpose:			

Parameters:			
		_validOnly : If this is true, then this method will only clone object that has "toTS" greater than _todayDate. Otherwise, clone everything.
Return Value:		

Date		Who		Reason
21 February 2023	navkc1	Initial creation CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	clonedRate		: CM_InvoiceContractRate;
	rateEntry,
	clonedRateEntry	: CM_InvoiceContractRateEntry;
	allRateEntryByTo: CM_InvoiceContractRteEntByTo;
	iter			: Iterator;
begin
	
	clonedRate := self.cloneSelf(_transient);
	clonedRate.myService := self.myService;
	
	if allInvoiceContractRteEntByFrom.isEmpty() then
		return clonedRate;
	endif;
	
	create allRateEntryByTo transient;
	self.allInvoiceContractRteEntByFrom.copy(allRateEntryByTo);
	
	rateEntry := allRateEntryByTo.last();
	
	iter := allRateEntryByTo.createIterator();
	iter.startAtObject(rateEntry);
	
	while iter.back(rateEntry) do
		if _validOnly and rateEntry.toTS.date() &lt; _todayDate then
			break;
		endif;
		
		clonedRateEntry := rateEntry.cloneForCopy(_transient);
		clonedRateEntry.setMyInvoiceContractRate(clonedRate);
	endwhile;
	
	return clonedRate;
	
epilog
	delete allRateEntryByTo;
	delete iter;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_validOnly" type="Boolean"/>
        <Parameter name="_todayDate" type="Date"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="convertAmountForCalcType" id="c4a9b4d8-f7c2-44ee-bd87-1c37cd700c71">
        <source>convertAmountForCalcType(_calcType : CM_CalculationType; _amount : Decimal io);
/*
Purpose:			

Date		Who		Reason
 // ### TFS BUG 57505 19APR2023 NAVAB1
*/

vars
	blockUnit : Integer;
	convRate : Real;
begin
	if _calcType = null then
		return;
	endif;
	
	blockUnit := INV_CALC_TYPE_UNITY; // value of 1

	if _amount = 0 then // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
		return; // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
	endif;
	
	if _calcType.calculationType = INV_CALC_TYPE_UNITY then
		_amount := 1.0;
	elseif _calcType.calculationType = INV_CALC_TYPE_WEIGHT_TON then
		_amount := _amount/1000;
	elseif _calcType.calculationType = INV_CALC_TYPE_QUANTITY
	or _calcType.calculationType = INV_CALC_TYPE_TRANSQUANTITY 
	or _calcType.calculationType = INV_CALC_TYPE_WEIGHT 
	or _calcType.calculationType = INV_CALC_TYPE_VOLUME 
	or _calcType.calculationType = INV_CALC_TYPE_REVENUE_TONS 
	or _calcType.calculationType = INV_CALC_TYPE_DAYS_SINCE_RECVL 
	or _calcType.calculationType = INV_CALC_TYPE_DAYSINCE_SUBTERM
	or _calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU 
	or _calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT 
	or _calcType.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_ST 
	or _calcType.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_EN 
	or _calcType.calculationType = INV_CALC_TYPE_DAYS_ONSITE_AT 
	or _calcType.calculationType = INV_CALC_TYPE_DAYS_CONNECTED 
	or _calcType.calculationType = INV_CALC_TYPE_DISCREPANCYVALUE
	or _calcType.calculationType = INV_CALC_TYPE_DISCREPANCYABS 
	or _calcType.calculationType = INV_CALC_TYPE_DAYS_WEIGHT 
	or _calcType.calculationType = INV_CALC_TYPE_DAYS_VOLUME then
	// do nothing
	elseif _calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT 
	or _calcType.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT 
	or _calcType.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then
	
		if _calcType.theCalcTypeUnit = INV_CALC_TYPE_QUANTITY then
			blockUnit := INV_CALC_TYPE_QUANTITY;
		endif;
		
		if _calcType.myMeasurementType &lt;&gt; null then
			convRate := _calcType.myMeasurementType.conversionRate;
		else
			convRate := 1;
		endif;
		_amount := blockUnit * (_amount / convRate);
	endif;

epilog

end;</source>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <Parameter name="_amount" type="Decimal" usage="io"/>
    </JadeMethod>
