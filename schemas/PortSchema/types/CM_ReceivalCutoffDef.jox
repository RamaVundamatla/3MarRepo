    <JadeMethod name="getCutoffsForVoyage" id="cfa8b9a2-39be-408f-b163-adc917bbc933">
        <source>getCutoffsForVoyage(_voyage :CM_Voyage; _earlyTS, _cutoffTS :TimeStamp output);
/*
Purpose		Work out actual cutoff date/times for a given voyage

Date		Who		Reason
06/03/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
15/03/2012	cnwcs5	par 29279
*/
vars
	targetTS	:TimeStamp;
	relTo		:Decimal[7,2];
begin
	targetTS	:= _voyage.getCutoffRelativeToTS (self.defaultRelativeTo);			
	relTo 		:= self.defaultEarliestReceival;
	
	if self.isEDIType then
		// earliest receival does not make sense for EDI cutoffs
		_earlyTS 	:= null;
		
	elseif targetTS &lt;&gt; null and relTo &lt;&gt; 0 then
		// for CARGO cutoffs, only calculate cutoff date/time if they have specified earliest receival hours
		_earlyTS	:= targetTS.subtractHoursAndMinutes (relTo);	
	else
		// no cutoff TS if CARGO and earliest hours is 0 or if targetTS is null
		_earlyTS := null;	// par 29279
	endif;
	
	relTo := self.defaultCutoff;
	
	if targetTS &lt;&gt; null and relTo &lt;&gt; null then
		// calculate cutoff 
		_cutoffTS	:= targetTS.subtractHoursAndMinutes (relTo);		
	elseif self.isEDIType then	// par 29279
		// for EDI cutoffs a cutoff hours of 0 still means the cutoff is calculated (could be null though)
		_cutoffTS	:= targetTS;
	else
		// CARGO cutoff with either null targetTS or 0 cutoff hours
		_cutoffTS 	:= null;	// par 29279
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_earlyTS" type="TimeStamp" usage="output"/>
        <Parameter name="_cutoffTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCutoffsPNForVoyage" id="17e8ada0-7460-4143-975a-c95199fe23d3">
        <source>getCutoffsPNForVoyage(_voyage :CM_Voyage; _earlyTSPN, _cutoffTSPN :TimeStamp output);
/*
Purpose		Work out actual cutoff date/times Pre Note for a given voyage

Date		Who		Reason
//04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs
*/
vars
	targetTS	:TimeStamp;
	relTo		:Decimal[7,2];
begin
	targetTS	:= _voyage.getCutoffRelativeToTS (self.defaultRelativeTo);			
	relTo 		:= self.defaultEarliestReceivalPN;
	
	if self.isEDIType then
		// earliest receival does not make sense for EDI cutoffs
		_earlyTSPN 	:= null;
		
	elseif targetTS &lt;&gt; null and relTo &lt;&gt; 0 then
		// for CARGO cutoffs, only calculate cutoff date/time if they have specified earliest receival hours
		_earlyTSPN	:= targetTS.subtractHoursAndMinutes (relTo);	
	else
		// no cutoff TS if CARGO and earliest hours is 0 or if targetTS is null
		_earlyTSPN := null;
	endif;
	
	relTo := self.defaultCutoffPN;
	
	if targetTS &lt;&gt; null and relTo &lt;&gt; null then
		// calculate cutoff 
		_cutoffTSPN	:= targetTS.subtractHoursAndMinutes (relTo);		
	elseif self.isEDIType then
		// for EDI cutoffs a cutoff hours of 0 still means the cutoff is calculated (could be null though)
		_cutoffTSPN	:= targetTS;
	else
		// CARGO cutoff with either null targetTS or 0 cutoff hours
		_cutoffTSPN 	:= null;
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_earlyTSPN" type="TimeStamp" usage="output"/>
        <Parameter name="_cutoffTSPN" type="TimeStamp" usage="output"/>
    </JadeMethod>
