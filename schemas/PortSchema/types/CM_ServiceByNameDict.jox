<CollClass name="CM_ServiceByNameDict" id="df781d5a-c156-4d1a-a758-af5bc2d3b54b">
    <memberType name="CM_Service"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_ServiceObject::name"/>
    </MemberKey>
    <JadeMethod name="getServiceList" id="c6cde467-4d42-4a6f-a050-c6cfe9a993e1">
        <source>getServiceList() : String;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	calc : CM_Service;
	tmpStr : String;
begin
	foreach calc in self  discreteLock do
		if tmpStr = null then
			tmpStr := "'" &amp; calc.name &amp; "'";
		else
			tmpStr := tmpStr &amp; ", '" &amp; calc.name &amp; "'";
			endif;
	endforeach;
 
 
	return tmpStr &amp; ".";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
