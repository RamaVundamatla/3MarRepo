    <JadeMethod name="tblData_dblClick" id="8e6806b4-14f3-4094-9cf3-9083e6dbab1d">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58238: UI - Notifications
07 August 2023 navmv20 CR 59391 Task 59392: COO Maint Show Sub Details
*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.doBtnUpdate(); //07/08/2023 navmv20 CR 59391 Task 59392
		return;
	endif;
	//07/08/2023 navmv20 CR 59391 Task 59392 - start
	if self.chkShowSubDtls.value then 
		return;
	endif;
	//07/08/2023 navmv20 CR 59391 Task 59392 - end
	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
