    <JadeMethod name="getVoyageQueueVoyages" id="b0a63a15-5a62-4e6a-af58-76a2053ba4b9">
        <source>getVoyageQueueVoyages()	:	CM_VoyageArray;
//Returns the current voyages in the master Queue's collection of Voyage queues.
vars
	voyages	:	CM_VoyageArray;
	aQueue	:	CM_RadioTelemetryQueue;
begin
	create voyages transient;
	foreach aQueue in self.allSubQueuesByOrder do	//&lt;-- Work in their order.
		if aQueue.isKindOf(CM_VoyageQueue) then
			if not voyages.includes(aQueue.CM_VoyageQueue.myVoyage) then
				voyages.add(aQueue.CM_VoyageQueue.myVoyage);
			endif;
		endif;
	endforeach;
	return voyages;
end;</source>
        <ReturnType type="CM_VoyageArray"/>
    </JadeMethod>
    <JadeMethod name="hasVoyageQueue" id="4f640db5-0205-4237-b03a-1ab5768d77ec">
        <source>hasVoyageQueue(voy : CM_Voyage input) : Boolean;
// Is there a voyage queue for this voyage.
vars
	voyageQueue : CM_VoyageQueue;
begin
	voyageQueue := self.allSubQueuesById[voy.code.trimBlanks].CM_VoyageQueue;
	return voyageQueue &lt;&gt; null;
epilog
end;</source>
        <Parameter name="voy" type="CM_Voyage" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
