    <JadeMethod name="mjwtest" id="5156f184-f410-42e2-b65d-523900a00081">
        <source>mjwtest();

vars
proc :Process;
begin
foreach proc in Process.instances do
			if proc.persistentApp.name = "AtcgControlApp" then //proc &lt;&gt; process then
			//write proc.persistentApp.name = "AtcgControlApp";
			write "we have a winner";
			proc.causeEvent(1148, true, null);
			endif;
endforeach;
end;</source>
