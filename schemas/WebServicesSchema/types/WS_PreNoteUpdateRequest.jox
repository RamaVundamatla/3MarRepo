        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allDischargePorts(set: Boolean; _value: String io) mapping, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/
vars

begin
	if set then
		self.allDischargePortsArray.clear();
		_value.getTokensForDelimiter("|", self.allDischargePortsArray);
	endif;	
	

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allTIHazards" id="e329cbe1-0296-49b6-898f-bd0d2eb34978">
        <methodInvocation>mapping</methodInvocation>
        <source>allTIHazards(set : Boolean; _value : String io) mapping;

/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
14 June 2010	#cnwdz2	 23027
//17/09/2010 cnwdz2 par25439
*/
constants
	PACKINGI 	: String = "I";
	PACKINGII 	: String = "II";
	PACKINGIII 	: String = "III";
vars
	tiHazardsDescArray,
	tiHazardProptyArray  : StringArray;
	tiHazardDesc,
	tiHazardCode,
	tiHazardUNDGCodes,
    tiHazardLtdQty,
	tiHazardPackingGrp	 : String;
	
	tmpTIHazard	: CM_TIHazard;
	hazClass	: CM_HazardClass;
begin
	if set then
		create tiHazardsDescArray transient;
		create tiHazardProptyArray transient;
		
		self.allTIHazardDict.clear();
		_value.getTokensForDelimiter(";", tiHazardsDescArray);
		foreach tiHazardDesc in tiHazardsDescArray do
			tiHazardDesc := tiHazardDesc.trimLeft();
			tiHazardProptyArray.clear();
			tiHazardDesc.getTokensForDelimiter(" ", tiHazardProptyArray);
		    tiHazardCode := tiHazardProptyArray[1];
			hazClass := app.myRoot.allHazardClasses.getAtKey(tiHazardCode);
			if hazClass &lt;&gt; null then
				create tmpTIHazard transient;
				tmpTIHazard.setFromHazardClass(hazClass);
				
				//29/11/2011 cnwdz2 28077
				if tiHazardProptyArray.size &gt;= 2 then
					tiHazardUNDGCodes := tiHazardProptyArray[2];
					if tiHazardUNDGCodes.containsOneOf("()") and not tiHazardUNDGCodes = "()" then
						tiHazardUNDGCodes := tiHazardUNDGCodes.replaceString("(", "");
						tiHazardUNDGCodes := tiHazardUNDGCodes.replaceString(")", "");
						tiHazardUNDGCodes := tiHazardUNDGCodes.replaceString("|", ",");
						tmpTIHazard.setUNDGCodes(tiHazardUNDGCodes);
					elseif tiHazardUNDGCodes = PACKINGI or tiHazardUNDGCodes = PACKINGII or tiHazardUNDGCodes = PACKINGIII then
						tmpTIHazard.setPackingGroup(tiHazardUNDGCodes);
					endif;
					
					if tiHazardProptyArray.size &gt;= 3 then
						tiHazardLtdQty := tiHazardProptyArray[3];
						if tiHazardLtdQty = "L" then
							tmpTIHazard.setLimitedQuantity(true);
						elseif tiHazardLtdQty = PACKINGI or tiHazardLtdQty = PACKINGII or tiHazardLtdQty = PACKINGIII then
							tmpTIHazard.setPackingGroup(tiHazardLtdQty);
						endif;
						
						if tiHazardProptyArray.size &gt;= 4 then
							tiHazardPackingGrp := tiHazardProptyArray[4];
							tmpTIHazard.setPackingGroup(tiHazardPackingGrp);
						endif;
					endif;
				endif;
				
				self.allTIHazardDict.add(tmpTIHazard);
				//app.raiseCMException1(VB_DUPLICATED_ITEM, allTIHazardDict.size.String,null,null);
			endif;
			
		endforeach;
	endif;	

epilog
	delete tiHazardsDescArray;			// PAR #28731
	delete tiHazardProptyArray;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3030242a-4f45-47c4-941c-22ed8e41f9ec">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	#cnwdz2	 

*/

vars

begin
	self.allAttachments.purge();
	self.allTIHazardDict.purge();//16/06/2010 cnwdz2 23027
	self.allCargoSeals.purge();
	self.allDamages.purge; //epr TFS 7744 webportal 27/11/17
	self.allHazards.purge; //epr TFS 7744 webportal 27/11/17
	self.allDimensions.purge; //epr TFS 7744 webportal 12/2/18
	self.allSpecialLifts.purge; //epr TFS 7744 webportal 12/2/18
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hasAttachments" id="b2110415-e404-4bd5-a017-0e9ed3d9f6aa">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>hasAttachments(set : Boolean; _value : String io) mapping, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	#cnwdz2	 
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	attachmentRequest,   
	attachmentDefArray,	
	attachmentArray	: StringArray;
	
	attachmentDef,
	attachment    : String;
	
	intFaceAttach 	: CMIF_InOutAttachment;
	
	cargoType,
	weightTotal : Integer;
	cargoId,
	isoType    	: String;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	productCode		: String;
	cargoTypeObj	: CM_CargoType;
	
	ti, child:CM_TrackedItem;
	
begin
	if set then
		self.allAttachments.clear();
		create attachmentRequest transient;
		_value.getTokensForDelimiter(";", attachmentRequest);
		if attachmentRequest.size &gt; 0 then
			create attachmentDefArray transient;
			create attachmentArray transient;
			attachmentRequest.removeAt(1).getTokensForDelimiter("|", attachmentDefArray);
			//cnwmc5 - PAR 32458 - 10 Sep 2013
			if attachmentDefArray.size = 1 then
				attachmentDefArray.copy(attachmentRequest);
			endif;
			foreach attachment in attachmentRequest do
				attachment.getTokensForDelimiter("|", attachmentArray);
				create intFaceAttach transient;
				//cnwmc5 - PAR 32458 - 10 Sep 2013
				if attachmentArray.size = 1 then
					//ti := self.cmObjectId.asOid.CM_TrackedItem;		//12.08.2022 navtnr20 52451
					ti := app.myPassport.getObjectOfTypeFromOid(self.cmObjectId,CM_TrackedItem).CM_TrackedItem;		//12.08.2022 navtnr20 52451
					foreach child in ti.allChildren do
						if child.id = attachmentArray.first.replace(' ', '') then
							intFaceAttach.set(null, child.cargoType, child.id, child.getISOType(), child.weightTare);
							
							//cnwmc5 - 19 Feb 2015 - PAR 34346
							intFaceAttach.myProduct := child.myProduct;
							break;
						endif;
					endforeach;
					attachmentArray.removeAt(1);
				else
					foreach attachmentDef in attachmentDefArray do
						if attachmentDef = "cargoType" then
							cargoType := attachmentArray.removeAt(1).Integer;
						endif;
						if attachmentDef = "weightTotal" then						
							weightTotal := attachmentArray.removeAt(1).Integer;
						endif;
						if attachmentDef = "idTextBox" then
							cargoId := attachmentArray.removeAt(1);
						endif;
						if attachmentDef = "isoType" then
							isoType := attachmentArray.removeAt(1);
						endif;
						//cnwmc5 - 19 Feb 2015 - PAR 34346
						if attachmentDef = "productType" then
							productCode := attachmentArray.removeAt(1);
						endif;
					endforeach;
					
					intFaceAttach.set(null,cargoType,cargoId,isoType,weightTotal);
					
					//cnwmc5 - 19 Feb 2015 - PAR 34346
					cargoTypeObj := app.myRoot.allCargoTypesById[cargoType];
					if cargoTypeObj &lt;&gt; null then
						intFaceAttach.myProduct := cargoTypeObj.getProductFromCode(productCode);
					endif;
				endif;
				self.allAttachments.add(intFaceAttach);
			endforeach;				
		endif;
	endif;	
epilog
	delete attachmentRequest;
	delete attachmentDefArray;	
	delete attachmentArray;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setCMIF_Prenote" id="ae365734-9605-48f3-a876-88a8f055884b">
        <source>setCMIF_Prenote(_cmifPrenote : CMIF_PreNote input);
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
14/11/2017	jlger1	7744		Initial creation 
27/04/2018 	JLGNS1	Bug 38204 	POL - Fwd: ##RE-7661## : Pre-Note error for Niagara using RIA
03/10/2019  jlgka1 	TFS 46794 	JMT - Web Portal - Can't save trailer prenotes
04/11/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
01/06/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 28.06.2022 navsrk20 Task 53924: Fix bug with shipping line in WS_PreNoteUpdateReques
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
18/11/2022  navlw1	TFS 55417 EUP - Country of Origin
20/04/2023	navpw1	TFS: 55787 - Added support for No Info Voyage
============================================================================*/

vars
	tmpAttach 		: Object;
	cargoTypeObj    : CM_CargoType;
	product 		: CM_Product;
	isoType 		: CM_ISOType;
	weightType		: CM_MeasurementType;
	wsSeal 			: WS_CargoSeal;
	sealType 		: CM_SealType;
	wsTIHazard 		: WS_TIHazard;
	tiHazard 		: CM_TIHazard;	
	wsDamage 		: WS_Damage;
	damageItem 		: CM_DamageInstance;
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	wsSpecialLift 	: WS_SpecialLift;
	specialLift 	: CM_SpecialLift;
	voyage			: CM_Voyage;				// ### TFS 55787 20Apr2023 NAVPW1
	voyageCode		: String;					// ### TFS 55787 20Apr2023 NAVPW1
	user			: CM_User;
begin
	
	if _cmifPrenote = null then
		return;
	endif;
	
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType.Integer];
	if cargoTypeObj = null then
		app.raiseCMException1(Cargo_Type_Invalid, self.cargoType.String, null, null);
	
		return;
	endif;
	
	_cmifPrenote.myTerminal			:= app.myPassport.myTerminal;
	_cmifPrenote.id					:= self.idTextBox[1:20]; 							//Bug 38204
	_cmifPrenote.cargoType			:= self.cargoType.Integer;
	_cmifPrenote.bookingReference	:= self.bookingReference;
	_cmifPrenote.billOfLading      	:= self.billOfLading; //epr TFS 7744 21/02.18
	_cmifPrenote.consigneeCode		:= self.consignee[1:5];//*							//Bug 38204
	_cmifPrenote.consignorCode		:= self.consignor[1:5];//*							//Bug 38204
	_cmifPrenote.customsAgentCode	:= self.customsAgentCode;   //epr TFS 7744 21/02.18
	_cmifPrenote.freightForwarderCode :=self.freightForwarder; //epr TFS 7744 28/11/17
	_cmifPrenote.destinationPort	:= self.destinationPort[1:5];//*					//Bug 38204
	_cmifPrenote.dischargePort		:= self.dischargePort;//*							
	_cmifPrenote.myTranshipToPort	:= app.myRoot.allPorts[self.transhipPort]; //epr TFS 7744 14/11/17 webportal
	_cmifPrenote.trailerType		:= self.trailerType; 	// jlgka1 TFS 46794
	self.allDischargePortsArray.copy(_cmifPrenote.allDischargePorts);
	if self.imexStatusString &lt;&gt; null then
		_cmifPrenote.imexStatus		:= self.imexStatusString.Integer;
		_cmifPrenote.imExStatus		:= app.myRoot.allImexStatuses[_cmifPrenote.imexStatus];
	endif;
	_cmifPrenote.isoType			:= self.isoType;
	_cmifPrenote.operatorCode		:= self.operatorCode[1:4];							//Bug 38204
	_cmifPrenote.shippingLineCode   := self.shippingLineCode;		// 28.06.2022 navsrk20 TFS 53924
	_cmifPrenote.countryOfOriginCode := self.countryOfOriginCode; // 18/11/2022 navlw1 TFS 55417

	_cmifPrenote.mark				:= self.mark[1:150];	
	
	if self.allCargoSeals.isEmpty then
		_cmifPrenote.setSealNum(self.sealNum);	//20 Sep 2010	NDL	Par 25608		
		//cnwmc5 - 22/01/2013 - CCMS 2238 - PAR #30765
		_cmifPrenote.setSealNumCustoms(self.sealNumCustoms.replaceString("|", ","));
		_cmifPrenote.setSealNumShippers(self.sealNumShippers);
		_cmifPrenote.setSealNumVent(self.sealNumVent);	
	else	
		foreach wsSeal in self.allCargoSeals do
			sealType := app.myRoot.getSealType( wsSeal.sealType );
			if sealType &lt;&gt; null and not sealType.notAvailableForEntry then
				if sealType.allCargoTypes.includes( cargoTypeObj ) then
					_cmifPrenote.setSealNumberValueDirect( sealType,  wsSeal.sealNumber, null );
				endif;
			endif;
		endforeach;
	endif;
	
	// ### TFS 55787 20Apr2023 NAVPW1
	if self.voyageCode = null then
		//get no info voyage from terminal config
		voyage := _cmifPrenote.myTerminal.getConfig(DefVoyage).CM_Voyage;
		if voyage &lt;&gt; null then
			voyageCode := voyage.code;
		endif;
	else
		voyageCode := self.voyageCode[1:20]; //cnwmc5 - 4 July 2014 - PAR 34503
	endif;
	// ### TFS 55787 20Apr2023 NAVPW1
	
	_cmifPrenote.voyageCode			:= voyageCode;
	_cmifPrenote.transportMode		:= self.transportMode;
	_cmifPrenote.cargoGroupId 		:= self.cargoGroupId;			//15 Feb 2016	NDL	Par 37544
	_cmifPrenote.commodity			:= self.commodity[1:4];			//cnwmc5 - 4 July 2014 - PAR 34503
	_cmifPrenote.coolingType		:= self.coolingType.Integer;
	_cmifPrenote.carrier			:= self.carrier[1:10];			//cnwmc5 - 4 July 2014 - PAR 34503
	_cmifPrenote.stevedoreCode      := self.stevedoreCode;           //04.11.2020 cnwma1 TFS #50112
	
	if cargoTypeObj.isBreakBulkMulti then
		_cmifPrenote.numberOfItems		:= self.numItems;	//Total Quantity
	endif;
	
	if cargoTypeObj.isBreakBulk then
		_cmifPrenote.diameter 		:= self.diameter.Decimal;
		_cmifPrenote.grade 			:= self.grade;
		_cmifPrenote.grammage 		:= self.grammage.Decimal;
		_cmifPrenote.rollingLength 	:= self.rollingLength.Decimal;
	endif;
	
	_cmifPrenote.remarks			:= self.remarks;
	_cmifPrenote.directDelivery	:= self.directDelivery;
	_cmifPrenote.myProduct			:= cargoTypeObj.getProductFromCode(self.myProduct); 	//18/03/2010 cnwdz2 23232
	_cmifPrenote.mySubTerminal     := _cmifPrenote.myTerminal.allSubTerminals.getAtKey(self.mySubTerminal); //22/04/2009 cnwdz2 ccms1735
		
	_cmifPrenote.expectedArrivalDate := self.expectedArrivalDate.asDateFromWebInterface();	//26 Oct 2012	NDL	Par 30622	
	_cmifPrenote.expectedArrivalTime := self.expectedArrivalTime.asTimeFromWebInterface();	//26 Oct 2012	NDL	Par 30622
	
	//16/06/2010 cnwdz2 par23027
	_cmifPrenote.allTIHazards.clear;								
	self.allTIHazardDict.copy(_cmifPrenote.allTIHazards);
	
	if self.allTIHazardDict.isEmpty and not self.allHazards.isEmpty then
		//epr TFS 7744 14/11/17 webportal
			foreach wsTIHazard in self.allHazards do
				create tiHazard transient;
				
				tiHazard.setProxy(	wsTIHazard.code,									
									wsTIHazard.description,	
									wsTIHazard.undgCodes,
									null,
									wsTIHazard.limitedQuantity.asBooleanJMT,	
									wsTIHazard.packingGroup,		
									wsTIHazard.flashpointTemperature,	
									wsTIHazard.marinePollutant,			
									wsTIHazard.acidsBases	);						
				_cmifPrenote.allTIHazards.add(tiHazard);
			endforeach;
	endif;
	
	foreach wsDamage in self.allDamages do
		damPos:=null;
		damType:=null;
		if wsDamage.myDamagePosition &lt;&gt; null then
			damPos := app.myRoot.allDamagePositionsByCode[wsDamage.myDamagePosition.code].CM_DamagePosition;
		endif;
		if wsDamage.myDamageCode &lt;&gt; null then
			damType := app.myRoot.allDamageDefinitionCodes[wsDamage.myDamageCode.code].CM_DamageDefinitionCode;
		endif;
		create damageItem transient;
		//damageItem.setProxy(null,null,damType,damPos,wsDamage.remarks,wsDamage.isNewDamage,wsDamage.quantity,wsDamage.severity,wsDamage.isRepaired,null);
		damageItem.setProxy(null,null,damType,damPos,wsDamage.remarks,wsDamage.isNewDamage,wsDamage.quantity,
							_cmifPrenote.myTerminal.allDamageSeverities[wsDamage.severity.String],	// 11.07.2022 navak20 TFS 53862
							null,
							null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
							);
		
		_cmifPrenote.allDamageInstancesByPos.add(damageItem);
		
	endforeach;
	
	
	_cmifPrenote.alternativeId	:= self.alternativeId;				// PAR #31800
	_cmifPrenote.clientRef		:= self.clientRef;					// PAR #31800
	_cmifPrenote.colour		:= self.colour[1:30];				// PAR #31800	//cnwmc5 - 4 July 2014 - PAR 34503
	_cmifPrenote.description	:= self.itemDesc;					// PAR #31800
	_cmifPrenote.markNumber	:= self.markNumber[1:150];			// PAR #31800	// TFS 4449
			
	if cargoTypeObj.isVehicle then
		
		_cmifPrenote.make				:= self.make;						// PAR #32215
		_cmifPrenote.model				:= self.model;						// PAR #32215
		_cmifPrenote.carType			:= self.vehicleType;				// PAR #32215
		_cmifPrenote.year				:= self.year;						// PAR #32215
		_cmifPrenote.trackingNumber1	:= self.trackingNumber1;			// PAR #32215
		_cmifPrenote.trackingNumber2	:= self.trackingNumber2;			// PAR #32215
		_cmifPrenote.docsReceived.setDate(self.docsReceived.asDateFromWebInterface);	// PAR #32215
		_cmifPrenote.docsSent.setDate(self.docsSent.asDateFromWebInterface);			// PAR #32215
		_cmifPrenote.docsCleared.setDate(self.docsCleared.asDateFromWebInterface);		// PAR #32215
		_cmifPrenote.docsReturned.setDate(self.docsReturned.asDateFromWebInterface);	// PAR #32215
		_cmifPrenote.selfPropelled		:= self.isSelfPropelled;			// PAR #32215
		_cmifPrenote.nbrDoors			:= self.doors;						// PAR #32215
		_cmifPrenote.isNewVehicle		:= self.newVehicle;					// PAR #32215
	endif;
	
	_cmifPrenote.purchaseOrder		:= self.purchaseOrder.toUpper;		// PAR #33193
	_cmifPrenote.serviceOrder		:= self.serviceOrder.toUpper;
	
	
	
	_cmifPrenote.wagon				:= self.wagon.toUpper;				// 35603;
	if self.wagonClass.trimBlanks &lt;&gt; null then
		_cmifPrenote.myWagonClass := app.myRoot.allWagonClasses[self.wagonClass.trimBlanks];
	else
		_cmifPrenote.myWagonClass := _cmifPrenote.myTerminal.getWagonClass(_cmifPrenote.wagon, _cmifPrenote.myTerminal.getWagonClassFromId(_cmifPrenote.wagon));
	endif;
	
	foreach tmpAttach in self.allAttachments do
		if tmpAttach.isKindOf(CMIF_InOutAttachment) then
			tmpAttach.CMIF_InOutAttachment.myTerminal := _cmifPrenote.myTerminal;
			tmpAttach.CMIF_InOutAttachment.setMasterItem(_cmifPrenote);						
		endif;		
	endforeach;

	_cmifPrenote.setEmailDefaults();
	
	//epr TFS 7744 webportal over dimensions for containers and for every thing else the rest
	// needs to be done before setting the total weight for bulk by volume
	if cargoTypeObj.isContainer then
		_cmifPrenote.overHeight:=self.overHeight.asDecimalJMT;
		_cmifPrenote.overLengthFront:=self.overLenghtFront.asDecimalJMT;
		_cmifPrenote.overLengthRear:=self.overLengthRear.asDecimalJMT;
		_cmifPrenote.overWidthLeft:=self.overWidthLeft.asDecimalJMT;
		_cmifPrenote.overWidthRight:=self.overWidthRight.asDecimalJMT;
	else
		if self.allDimensions.isEmpty then
			_cmifPrenote.quantity			:= self.quantity;				// cnwmc5 - 1 July 2015 - creation of new web portal
			if self.heightRaw &lt;&gt; null then
				_cmifPrenote.height		    := self.heightRaw.asDecimalJMT;
			else
				_cmifPrenote.height		    := app.convertMeasurementForStorage(app.getDefaultMeasurementForType(Type_Height).shortName, self.height.asDecimalJMT);		// PAR #31754
			endif;
			if self.widthRaw &lt;&gt; null then
				_cmifPrenote.width		   		:= self.widthRaw.asDecimalJMT;
			else
				_cmifPrenote.width		   		:= app.convertMeasurementForStorage(app.getDefaultMeasurementForType(Type_Width).shortName, self.width.asDecimalJMT);		// PAR #31754
			endif;
			if self.lengthRaw &lt;&gt; null then
				_cmifPrenote.length			:= self.lengthRaw.asDecimalJMT;
			else
				_cmifPrenote.length		    := app.convertMeasurementForStorage(app.getDefaultMeasurementForType(Type_Length).shortName, self.length.asDecimalJMT);		// PAR #31754
			endif;		
			if self.volumeRaw &lt;&gt; null then
				_cmifPrenote.volume			:= self.volumeRaw.asDecimalJMT;
			else
				_cmifPrenote.volume			:= app.convertMeasurementForStorage(app.getDefaultMeasurementForType(Type_Volume).shortName, self.volume.asDecimalJMT);		// PAR #31754
			endif;	
		else
			self.setCMIF_PrenoteDimensions(_cmifPrenote);
			if self.volumeRaw &lt;&gt; null then
				_cmifPrenote.volume:=self.volumeRaw.asDecimalJMT;
			endif;
		endif;
	endif;
	
	
	if self.weightTotalRaw &lt;&gt; null then
		_cmifPrenote.weightTotal		:= self.weightTotalRaw.asDecimalJMT;
	else
		weightType := app.getDefaultMeasurementForType(Type_Weight);
		_cmifPrenote.weightTotal		:= app.convertMeasurementForStorage(weightType.shortName, self.weightTotal.asDecimalJMT);	// PAR #31754
	endif;
		
	//cnwmc5 - 13 March 2015 - PAR 35864
	if cargoTypeObj.isBulkByVolume then
		if _cmifPrenote.myProduct &lt;&gt; null then
			product := _cmifPrenote.myProduct;
		else
			product := cargoTypeObj.mySystemProductType;
		endif;
			
		_cmifPrenote.weightTotal := _cmifPrenote.volume * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	
	if cargoTypeObj.useTareCargoWeight then
		if self.tareWeightRaw &lt;&gt; null then
			_cmifPrenote.weightTare :=self.tareWeightRaw.asDecimalJMT;
		endif;
		if self.cargoWeightRaw &lt;&gt; null then
			_cmifPrenote.weightCargo :=self.cargoWeightRaw.asDecimalJMT;
		endif;	
		//epr TFS 7744 14/11/17 webportal lets users enter weight and tare
		if _cmifPrenote.weightCargo = null  then
			//cnwmc5 - 8 April 2015 - PAR 35987
			if _cmifPrenote.isoType &lt;&gt; null and _cmifPrenote.weightTare = null then
				isoType := app.myRoot.allISOTypes[_cmifPrenote.isoType];
				if isoType &lt;&gt; null then
					_cmifPrenote.weightCargo := _cmifPrenote.weightTotal - isoType.tareKilos;
				endif;
			else
				_cmifPrenote.weightCargo := _cmifPrenote.weightTotal - _cmifPrenote.weightTare;
			endif;
			if _cmifPrenote.weightCargo &lt; 0 then
				_cmifPrenote.weightCargo := 0;
			endif;
		endif;
	endif;
	//epr TFS 1882 18/5/16
	if  cargoTypeObj.canWeightBeCertified then
		_cmifPrenote.isWeightCertified:=self.isWeightCertified;
		if cargoTypeObj.isContainer then
			_cmifPrenote.weightCertifiedName:=self.weightCertifiedName;
			_cmifPrenote.weightCertifiedReference:=self.weightCertifiedReference;
		endif;
	endif;
	
	
	foreach wsSpecialLift in self.allSpecialLifts do
		specialLift := app.myRoot.allSpecialLifts[wsSpecialLift.code];
		if specialLift=null then
			continue;
		endif;
		_cmifPrenote.allSpecialLifts.add(specialLift);
	endforeach;
	
	
	self.setCMIF_PrenoteReeefer(_cmifPrenote);
	
		
	_cmifPrenote.customExportEntryNumber:=self.customExportEntryNumber;
	//jlier1 TFS 53030 5/9/22
	//jlier1 MTN-12621 8/10/24 - only if the user had permission to update/view it otherwise this would null the value if there was one
	user := app.getMyUser();
	//only if the user could view the operator export release number set it
	if user &lt;&gt; null and user.canViewOperatorExpReleaseNum(_cmifPrenote.myTerminal) then
		_cmifPrenote.operatorExportReleaseNumber:=self.operatorExportReleaseNumber;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCMIF_PrenoteDimensions" id="2b336e8a-d465-475a-bb9a-db9cd5bd14f8">
        <source>setCMIF_PrenoteDimensions(_cmifPrenote : CMIF_PreNote input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2018	jlger1	Initial creation tfs 7744 webportal

*/

vars
	wsDimension : WS_Dimension;
begin

	foreach wsDimension in self.allDimensions do
		if wsDimension.type = ETRow_MyLength then
			_cmifPrenote.length:=wsDimension.value.asDecimalJMT;
		elseif  wsDimension.type = ETRow_MyWidth then				
			_cmifPrenote.width:=wsDimension.value.asDecimalJMT;				
		elseif wsDimension.type = ETRow_MyHeight then				
			_cmifPrenote.height:=wsDimension.value.asDecimalJMT;							
		elseif wsDimension.type= ETRow_MyWeight then													
			_cmifPrenote.weight:=wsDimension.value.asDecimalJMT;			
		elseif wsDimension.type = ETRow_MyVolume then
			_cmifPrenote.volume:=wsDimension.value.asDecimalJMT;		
		elseif wsDimension.type = ETRow_MyWidthString then	
			_cmifPrenote.widthString:=wsDimension.value;		
		elseif wsDimension.type = ETRow_MyHeightString then	
			_cmifPrenote.heightString:=wsDimension.value;	
		elseif wsDimension.type = ETRow_MyLengthString then
			_cmifPrenote.lengthString:=wsDimension.value;
		elseif wsDimension.type = ETRow_MyQuantity then
			_cmifPrenote.quantity:=wsDimension.value.Integer;
		elseif wsDimension.type = ETRow_MyDensity then
			_cmifPrenote.density:=wsDimension.value.asDecimalJMT;
		elseif wsDimension.type = ETRow_MyType then
			_cmifPrenote.type:=wsDimension.value;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCMIF_PrenoteReeefer" id="2be9eef2-e94a-48ef-b31a-c3fb3af81724">
        <source>setCMIF_PrenoteReeefer(_cmifPrenote : CMIF_PreNote input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 November 2017	jlger1	Initial creation tfs 7744 took most out of WS_WebServiceAgent setReeferDetails
10 Oct      2019    cnwma1	Bug 46793: Web Portal - Prenotes for non container cargo that has a commodity that requires temperature does not show reefer section
03 August 2023		jlizm1	TFS 56935 Web Portal issues with null vs 0 reefer props
*/

vars
	commodityObj : CM_Commodity;
	cargoTypeObj : CM_CargoType;
begin
	
	cargoTypeObj := app.myRoot.allCargoTypesById[_cmifPrenote.cargoType];
	
	if cargoTypeObj = null then
		return;
	endif;
	
	if  not cargoTypeObj.isContainer and not cargoTypeObj.isCommodityRequired then
		return;
	endif;
	
	commodityObj:= app.myRoot.allCommodities[self.commodity];
	
	if commodityObj = null then
		return;
	endif;
	
	if not commodityObj.requiresPower and not commodityObj.hasTemp then   // 10.10.2019 cnwma1 #46793
		return;
	endif;
	
	if self.carriageTempC = null then  
		_cmifPrenote.carriageTempC	 := NULL_TEMPERATURE;
	else
		if self.carriageTempC.asRealFromWebInterface() &gt; NULL_TEMPERATURE then
			_cmifPrenote.carriageTempC	 := self.carriageTempC.asRealFromWebInterface();
		endif;
	endif;
				
	//26 Oct 2012	NDL	Par 30622
	if self.packTempC = null then  
		_cmifPrenote.packTempC	 := NULL_TEMPERATURE;
	else		
		if self.packTempC.asRealFromWebInterface() &gt; NULL_TEMPERATURE then
			_cmifPrenote.packTempC	 := self.packTempC.asRealFromWebInterface();	
		endif;
	endif;
	
	if self.allowableTimeOffPower &gt; NULL_ALLOWABLE_TIME_OFF_POWER then 
		_cmifPrenote.allowableTimeOffPower	 := self.allowableTimeOffPower;
	endif;
			
	if self.oxygen = null or self.oxygen.asDecimalJMT() =  NULL_OXYGEN then
		_cmifPrenote.setOxygen( NULL_OXYGEN );
	else
		if self.oxygen.asDecimalJMT() &gt;  NULL_OXYGEN then
			_cmifPrenote.setOxygen( self.oxygen.asDecimalFromWebInterface );
		endif;
	endif;
				
	if self.carbonDioxide = null or self.carbonDioxide.asDecimalJMT() = NULL_CARBON_DIOXIDE then
		_cmifPrenote.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	else
		if self.carbonDioxide.asDecimalJMT() &gt; NULL_CARBON_DIOXIDE then
			_cmifPrenote.setCarbonDioxide( self.carbonDioxide.asDecimalFromWebInterface );
		endif;
	endif;
				
	if self.humidity = null or self.humidity.asDecimalJMT() = NULL_HUMIDITY then
		_cmifPrenote.setHumidity( NULL_HUMIDITY );
	else
		if self.humidity.asDecimalJMT() &gt; NULL_HUMIDITY then					
			_cmifPrenote.setHumidity( self.humidity.asDecimalFromWebInterface );
		endif;
	endif;
	
	if self.ventilation = null or self.ventilation.asDecimalJMT() = NULL_VENTILATION then
		_cmifPrenote.ventilation	 := NULL_VENTILATION;
	else
		if self.ventilation.asIntegerJMT() &gt; NULL_VENTILATION then		
			_cmifPrenote.ventilation	 := self.ventilation.asDecimalFromWebInterface();	//26 Oct 2012	NDL	Par 30622
		endif;
	endif;
	
	//epr TFS 7744 28/11/17 all added for webportal
	_cmifPrenote.expiryDate 			:= self.expiryDate.asDateFromWebInterface(); // PAR #36682
	_cmifPrenote.packDate 				:= self.packDate.asDateFromWebInterface();	 //26 Oct 2012	NDL	Par 30622
	_cmifPrenote.packTime 				:= self.packTime.asTimeFromWebInterface();	 //26 Oct 2012	NDL	Par 30622
	_cmifPrenote.curtainsIn 			:= self.curtainsIn;
	_cmifPrenote.coolingType 			:= self.coolingType.asIntegerJMT;
	_cmifPrenote.voltageType 			:= self.voltageType.asIntegerJMT;
	_cmifPrenote.onPowerDuringTransit 	:= self.onPowerDuringTransit;
	_cmifPrenote.transitOnPowerRemarks	:= self.transitOnPowerRemarks;
	_cmifPrenote.transitOnPowerDate		:= self.transitOnPowerDate.asDateFromWebInterface;
	_cmifPrenote.transitOnPowerTime		:= self.transitOnPowerTime.asTimeFromWebInterface;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDimensions" id="1586a858-c1dc-4ca2-aed2-044c9190bc56">
        <source>validateDimensions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlger1	Initial creation tfs 7744 refactored out of createPrenote updatePrenote webservice methods

*/

vars
	lengthType,
	widthType,
	heightType			: CM_MeasurementType;		// PAR #31754
begin
	
	lengthType := app.getDefaultMeasurementForType(Type_Length);							// PAR #31754
	widthType := app.getDefaultMeasurementForType(Type_Width);
	heightType := app.getDefaultMeasurementForType(Type_Height);
	// if linear type is feet and inches, check that valid feet and inches values hav been 	// PAR #31754
	// entered for length, height and width													// PAR #31754
	if heightType.isFeetAndInches and self.height &lt;&gt; null then														// PAR #31754
		if not self.height.isValidFeetAndInches then							// PAR #31754
			app.raiseCMException2(ERR_INVALID_VALUE, "Height (" &amp; heightType.shortName &amp; ")", self.height, null, null);	// PAR #31754
		endif;																				
	endif;
	if lengthType.isFeetAndInches and self.length &lt;&gt; null then
		if not self.length.isValidFeetAndInches then							// PAR #31754
			app.raiseCMException2(ERR_INVALID_VALUE, "Length (" &amp; lengthType.shortName &amp; ")", self.length, null, null);	// PAR #31754															// PAR #31754
		endif;																				
	endif;
	if widthType.isFeetAndInches and self.width &lt;&gt; null then
		if not self.width.isValidFeetAndInches then								// PAR #31754
			app.raiseCMException2(ERR_INVALID_VALUE, "Width (" &amp; widthType.shortName &amp; ")", self.width, null, null);	// PAR #31754

		endif;																				// PAR #31754
	endif;			
epilog

end;</source>
    </JadeMethod>
</Class>
