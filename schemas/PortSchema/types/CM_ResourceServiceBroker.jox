    <JadeMethod name="shouldAuditProperty" id="726bad94-477d-46c2-80aa-8a23179b4b98">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_ResourceServiceBroker::myChildQuantityMap.name or
		propName = CM_ResourceServiceBroker::myResource.name or
		propName = CM_ResourceServiceBroker::myTransMap.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d0843e8b-c74b-4c89-ab24-21efc18731e9">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCT : CM_CalculationType;
	ild : CM_InvoiceLineDesc;
	aResType : HMS_ResourceType;
	qrm : CM_QuantityRangeMap;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	inheritMethod();

	if self.myResource &lt;&gt; null then
		aResType := self.myResource.myResourceType;
		if aResType = null then
			return;
		endif;

		foreach qrm in self.myChildQuantityMap.allQuantityRanges discreteLock do
	
			// TFS 40620foreach	ild in qrm.allInvoiceLineMaps discreteLock do
			foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
				ild := mapping.myTMInvoiceLineDesc; // TFS 40620
				
				if ild.isVoid then
					continue;
				endif;
	
				aCT := ild.getCalcType();
				
				if aCT &lt;&gt; null then
					if aCT.requiresQuantity then
						if aCT.requiresQuantity &lt;&gt; aResType.isQuantityRequired then
							app.raiseCMWarning4(ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; self.myResource.description &amp; "'","quantity",null,null,null,self );
						endif;
					endif;
					if aCT.requiresADate then
						if aCT.requiresADate &lt;&gt; aResType.isActionDateTimeRequired then
							app.raiseCMWarning4(ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; self.myResource.description &amp; "'","date",null,null,null,self );
						
						endif;
					endif;		
					if aCT.requiresDateRange then
						if aCT.requiresDateRange &lt;&gt; aResType.isFromToDateTimeRequired then
							app.raiseCMWarning4(ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; self.myResource.description &amp; "'","date range",null,null,null,self );
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
</Class>
