    <JadeMethod name="translateForm" id="49ace876-3644-4d79-9023-92993ba9a96b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:43:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008110, locale);
	btnPrint.translateBubbleHelp(Xlat_0008111, locale);
	btnPrint.translateCaption(Xlat_0008112, locale);
	btnQuery.translateBubbleHelp(Xlat_0008113, locale);
	btnQuery.translateCaption(Xlat_0008114, locale);
	btnReset.translateBubbleHelp(Xlat_0008115, locale);
	btnReset.translateCaption(Xlat_0008116, locale);
	btnShowNonPlan.translateBubbleHelp(Xlat_0008117, locale);
	btnShowNonPlan.translateCaption(Xlat_0008118, locale);
	btnShowPlanning.translateBubbleHelp(Xlat_0008119, locale);
	btnShowPlanning.translateCaption(Xlat_0008120, locale);
	btnUnplan.translateBubbleHelp(Xlat_0005233, locale);
	btnUnplan.translateCaption(Xlat_0005234, locale);
	chkColReversed.translateBubbleHelp(Xlat_0014614, locale);
	chkColReversed.translateCaption(Xlat_0014615, locale);
	chkIgnoreWarning.translateCaption(Xlat_0008121, locale);
	chkNoPlanIfStops.translateCaption(Xlat_0005237, locale);
	chkRowEnd.translateBubbleHelp(Xlat_0023297, locale);
	chkRowEnd.translateCaption(Xlat_0008123, locale);
	chkSplitTopHight.translateBubbleHelp(Xlat_0008124, locale);
	chkSplitTopHight.translateCaption(Xlat_0008125, locale);
	chkTwinPlan.translateBubbleHelp(Xlat_0010041, locale);
	chkTwinPlan.translateCaption(Xlat_0010042, locale);
	chkUseWieights.translateCaption(Xlat_0008126, locale);
	grpOther.translateCaption(Xlat_0005238, locale);
	grpWeight.translateCaption(Xlat_0005239, locale);
	grpYard.translateCaption(Xlat_0005240, locale);
	grpYardBot.translateBubbleHelp(Xlat_0008127, locale);
	grpYardBot.translateCaption(Xlat_0008128, locale);
	grpYardTop.translateBubbleHelp(Xlat_0008129, locale);
	grpYardTop.translateCaption(Xlat_0008130, locale);
	lblHeight.translateBubbleHelp(Xlat_0008131, locale);
	lblHeight.translateCaption(Xlat_0008132, locale);
	lblPC.translateCaption(Xlat_0008133, locale);
