    <JadeMethod name="chkClear_click" id="0eb775bc-e689-47d2-bdd6-7da73b84a760">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkClear_click(checkbox: CheckBox input) updating;

vars

begin
	self.doCheckClearClick();
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="a446f749-5636-4742-b82e-35d596130449">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnwrs1 ccms 1022
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView := PmAdmEdiopersView;
	self.permissionMaint := PmAdmEdiopersMaint;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckClearClick" id="6cd4b07e-5364-49b0-85dd-40b579391eac">
        <source>doCheckClearClick();
// ---------------------------------------------------------------------------
// Created:		June 2006 cnwrs1 ccms 1022
// ---------------------------------------------------------------------------
vars

begin
	if self.chkClear.value then
		self.optRetnManCargo.enabled 	:= false;
		self.optRetnEDICargo.enabled := false; //July 2008 cnwrs1 Par 17595 
		self.optRetnAllCargo.enabled 	:= false;
		self.optRetnNoCargo.enabled := false; //July 2008 cnwrs1 Par 17595 
		self.optRemovePlann.enabled 	:= false;
		self.optRetainPlannin.enabled 	:= false;
		self.optRetnNoCargo.value 		:= true;
		self.optRemovePlann.value		 := true;
		self.btnOk.caption 				:= "Replace";
	else
		self.optRetnManCargo.enabled		:= true;
		self.optRetnEDICargo.enabled := true; //July 2008 cnwrs1 Par 17595 
		self.optRetnAllCargo.enabled		:= true;
		self.optRetnNoCargo.enabled := true; //July 2008 cnwrs1 Par 17595 
		self.optRemovePlann.enabled		:= true;
		self.optRetainPlannin.enabled 	:= true;
		self.optRetnNoCargo.value 		:= true; //par 14015
		self.optRetainPlannin.value 	:= true;
		self.btnOk.caption 				:= "Merge";
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0231c6b5-f26a-47dd-8568-f123c892c2ff">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnwrs1 ccms 1022
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.chkClear.value := false;
	self.modalResult := IDCANCEL;
	self.doCheckClearClick();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="01474032-09eb-44bc-b663-cd66346e7d0b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007363, locale);
	chkClear.translateBubbleHelp(Xlat_0009841, locale);
	chkClear.translateCaption(Xlat_0014546, locale);
	groupBox1.translateCaption(Xlat_0000338, locale);
	groupBox2.translateCaption(Xlat_0000339, locale);
	label1.translateCaption(Xlat_0000340, locale);
	optRemovePlann.translateBubbleHelp(Xlat_0009842, locale);
	optRemovePlann.translateCaption(Xlat_0000335, locale);
	optRetainPlannin.translateBubbleHelp(Xlat_0009843, locale);
	optRetainPlannin.translateCaption(Xlat_0000333, locale);
	optRetnAllCargo.translateBubbleHelp(Xlat_0009844, locale);
	optRetnAllCargo.translateCaption(Xlat_0009845, locale);
	optRetnEDICargo.translateBubbleHelp(Xlat_0009846, locale);
	optRetnEDICargo.translateCaption(Xlat_0009847, locale);
	optRetnManCargo.translateBubbleHelp(Xlat_0009848, locale);
	optRetnManCargo.translateCaption(Xlat_0009849, locale);
	optRetnNoCargo.translateBubbleHelp(Xlat_0009850, locale);
	optRetnNoCargo.translateCaption(Xlat_0009851, locale);
end;</source>
    </JadeMethod>
</GUIClass>
