// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 June 2021	navmd1	Initial creation TFS 51320
// ---------------------------------------------------------------------------
vars
	entTableRowProxy : EntTableRow;
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then
		self.endTimer(self.Timer_TableData_Filter);
	endif;

	self.endNotificationForSubscriber(self);
	self.zClearProxyDetails();
	self.exitForm();
	
	inheritMethod;

	foreach entTableRowProxy in self.allTblDataTransientRows do
		if self.tblData.allTblDataEntRows.includes(entTableRowProxy) then
			self.tblData.allTblDataEntRows.remove(entTableRowProxy);
		endif;
	endforeach;
	self.allTblDataTransientRows.purge;	
		
end;</source>
    </JadeMethod>
