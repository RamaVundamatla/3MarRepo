    <JadeMethod name="setControlsForAddEdit" id="ce53af92-4c8f-4d6b-b089-54327896e47a">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	theForm : SOP_TableMaintForm;

begin
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		
		theForm.tblInput1.setValueByName(ETRow_IsActive, false);
		theForm.tblInput1.setValueByName(ETRow_LastNotified, null);
		theForm.tblInput1.setValueByName(ETRow_MaxLevel, 0);
		theForm.tblInput1.setValueByName(ETRow_MinLevel, 0);
		theForm.tblInput1.setValueByName(ETRow_MyISOGroup, app.getErrorString(AnyString) );
		theForm.tblInput1.setValueByName(ETRow_MyMTGrade, app.getErrorString(AnyString) );
		theForm.tblInput1.setValueByName(ETRow_MyOperator, app.getErrorString(AnyString) );
		theForm.tblInput1.setValueByName(ETRow_Priority, 0);
		theForm.tblInput1.setValueByName(ETRow_ReNotifyMins, 0);
	
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_MTThreshold);
		
	endif;

    theForm.tblInput1.disableRowByName(ETRow_LastNotified);
	
	

epilog

end;</source>
    </JadeMethod>
