    <JadeMethod name="setComboValues" id="1f911e9d-0dc5-42c0-b693-30e4a5d42021">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	_combo.clear;
	_combo.addItem(app.siteEnumToString(TI_SITE_ONSITE));
	_combo.addItem(app.siteEnumToString(TI_SITE_ONSHIP));
	_combo.addItem(app.siteEnumToString(TI_SITE_OFFSITE));
	_combo.addItem(app.siteEnumToString(TI_SITE_TBA));
	_combo.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));	//15 Jun 2015	NDL	Par 36347
	_combo.addItem(app.siteEnumToString(SEL_QUERYSITE_PLACEHOLDER));	//31 Mar 2020	NDL	TFS 47004
	

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.siteEnumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.siteEnumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ae31a5cd-1f7b-4239-8925-19602cf1be55">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/10/2017	jlgdap1		TFS 7523 SNO Selector and Notified Site
// ---------------------------------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_SITE_ONSITE);
	intArray.add(TI_SITE_ONSHIP);
	intArray.add(TI_SITE_OFFSITE);
	intArray.add(SEL_QUERYSITE_NOTIFIED);				// TFS 7523
	intArray.add(TI_SITE_TBA);
	intArray.add(SEL_QUERYSITE_PLACEHOLDER);	//31 Mar 2020	NDL	TFS 47004
	
	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_SITE_Constant);	

epilog
	delete intArray;
end;

</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="48491155-1272-4377-b50f-06bbc7535ad3">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="2e9a1809-6385-4946-9210-7413226ae0a0">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 09 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	intSite	: Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	intSite := app.siteStringToEnum(_value.String);
	
	if intSite = TI_SITE_UNDEFINED and _value &lt;&gt; null then	 //Par 17092	cnwvu1, June 2008
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return intSite;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="94aafb7b-b828-4fbf-aa37-5ba00272686e">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return app.siteEnumToString(_value.Integer);

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="5ab98563-a74c-43d0-9aef-aee638b91369">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	//21 Jan 2014	NDL
		return _value.String;
	endif;
	
	return app.siteStringToEnum(_value.String);
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d253e159-4bb8-4ff1-967d-9163130bc5b6">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	returnVal, str, collStr : String;
	coll : IntegerArray;
	strArray : StringArray;

begin
	if _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			returnVal := returnVal &amp; int.String &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				coll.add(str.Integer);
			endforeach;
			return coll;
			
		elseif _value.String.isInteger then
			return _value.Integer;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
