    <JadeMethod name="buildEntireForeground" id="380a7aa2-32ca-4810-ae12-33a3dea0fa12">
        <updating/>
        <source>buildEntireForeground() updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	movement : CMIF_HMS_WorkingMovement;
begin

	if self.myViewController &lt;&gt; null then
		movement := self.myViewController.myCurrentWorkingMovement;
	endif;

	self.tblMovements.ofViewController := self.myViewController;	
	self.setSelectedMovement(movement);
	
	//Already done above in self.setSelectedMovement(movement);
	/*if movement &lt;&gt; null then
	 	self.setCurrentVoyage(movement.myWorkingVoyage);
	else
		self.setCurrentVoyage(null);				
	endif;*/

	self.tblMovements.showAllVoyages := true;
	self.tblMovements.loadFullTable(self.colorRow1, self.colorRow2);

	if optAllVoyages.value then
		self.tblMovements.showMovementsForAllVoyages;
	else
		self.tblMovements.showMovementsForCurrentVoyage;	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="920b6151-0348-4cef-96c2-621b8b8ed1e0">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars

	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;


end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
