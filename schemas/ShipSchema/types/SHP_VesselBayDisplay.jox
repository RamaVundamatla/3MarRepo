    <JadeMethod name="initSelectVoyVesselCombo" id="4e62ab16-bd15-4030-93a4-393b55d64bb2">
        <updating/>
        <source>initSelectVoyVesselCombo(_combo: CMUI_ComboBox input; _isDisplayByName : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	inheritMethod(_combo,_isDisplayByName);
	
	_combo.listCollection(app.myRoot.allVesselCellularStructures, true, 0);
	
	if _combo.findObject(self.myCellularVesselStructure) &gt; 0 then
		_combo.listObject := self.myCellularVesselStructure;
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_isDisplayByName" type="Boolean"/>
    </JadeMethod>
