    <JadeMethod name="attachGenerator" id="aadf1e5a-9ea6-4a1e-b262-7b8012989810">
        <updating/>
        <source>attachGenerator(theGenerator: CM_Generator input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 30 Aug 2012		cnwcs5			par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------

vars
	lTask : CM_ToDoTaskDesc;
	lDesc : String;
	tmpPriorLocation	: CM_LocationsController;

begin
	exclusiveLock(self);
	
	if self.isTransient and self.myGenerator = theGenerator then
		return;
	endif;

	// Check that we don't already have a generator...
	if self.myGenerator &lt;&gt; null and self.myGenerator &lt;&gt; theGenerator then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_ATTACHED, self.id, "generator " &amp; self.myGenerator.id, null, null);
	endif;

	exclusiveLock(theGenerator);
	
	tmpPriorLocation := theGenerator.myPrimaryActualLocation; // we have to save prior location for the generator

	//Set links between items
	self.myGenerator := theGenerator;
  	//Update location strings. Note that a generator is not known to
  	//the location controller in which the parent is held, so this
  	//code will suffice
	theGenerator.locationId := self.locationId;
	theGenerator.plannedLocnId := self.plannedLocnId;
	theGenerator.rehandleLocnId := self.rehandleLocnId;
	
	// Par 17775. ccms1045. APM - Yard Ops, new generator Types. 28/08/2008
	self.attachGeneratorUnderSlung( theGenerator, tmpPriorLocation, _passport );
	
	if (not self.isTransient) then		//Don't add transients to terminal dicts
		//Update Voyage of COU
		if theGenerator.myVoyage &lt;&gt; self.myVoyage and self.myVoyage &lt;&gt; null then
			theGenerator.changeVoyage(self.myVoyage, _passport);
		endif;

		theGenerator.changeState(self.state, _passport);
		self.updateObjectEdition(self);		// par 30292
	else								//Just set the properties directly
		theGenerator.myVoyage := self.myVoyage;
		theGenerator.state 	:= self.state;
	endif;
end;</source>
        <Parameter name="theGenerator" type="CM_Generator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="attachGeneratorUnderSlung" id="28c7d15d-3645-4fb8-b54f-15932b1e70ef">
        <updating/>
        <source>attachGeneratorUnderSlung( _generator : CM_Generator input; _priorLocation : CM_LocationsController; _passport : CM_Passport input ) updating, protected;
/* ---------------------------------------------------------------------------
Created:	01 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	desc : String;
	task : CM_ToDoTask;
	control : CMIF_MoveController;
	
begin

	if _generator.isTransient then
		return;
	endif;

	if not _generator.isUnderSlung() then
		return;
	endif;
	
	// when attaching a generator Nose-mounted, we should complete the To Do Task "Detach Generator Set" automatically
	desc := null;
	foreach task in self.allToDoTasksToDo do
		if task.toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator then
			desc	:= task.toDoTaskDesc.description.trimBlanks;
			break;
		endif;
	endforeach;
	if desc &lt;&gt; null then
		self.completeToDoTaskForBulk( task.toDoTaskDesc, null, _passport);	
	endif;
	
	//_generator.moveToLocation(_toLocation, null, null, null, REAL_MODE, true/*false*/, true, false, false, false,  0, app.myPassport);
	_generator.myPrimaryActualLocation	:= self.myPrimaryActualLocation;
	_generator.myPrimaryPlannedLocation	:= self.myPrimaryPlannedLocation;
	_generator.myPrimaryQueuedLocation	:= self.myPrimaryQueuedLocation;
	_generator.allLocations.clear();
	//_generator.locationId 	:= self.locationId;		//it has been changed in the attachGenerator()
	//_generator.plannedLocnId 	:= self.plannedLocnId;	//it has been changed in the attachGenerator()
	//_generator.rehandleLocnId	:= self.rehandleLocnId;	//it has been changed in the attachGenerator()

	//setting prior location
	create control transient;
	control.setMoveMode(REAL_MODE);
	control.setMyOriginatingLocation( _priorLocation );
	_generator.setPriorLocation(control);
	
epilog
	if control &lt;&gt; null then
		delete control;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_generator" type="CM_Generator" usage="input"/>
        <Parameter name="_priorLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoCreateTIMaster" id="4f49c7de-b914-41e3-94dc-5529d10bc84a">
        <updating/>
        <source>autoCreateTIMaster() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
// 29/05/2025 navcs2 MTN-34844
*/
vars
//	tiMaster : CM_TIMaster;
	proxyTiMaster, realTiMaster : CM_TIMasterTILC;
	isotype : CM_ISOType;
	tareWeight : Decimal[23,2];
	tilcType : CM_TILCType;
	cargoType : Integer;
begin

	return; //As of 26 July 2021 rule change in TFS 51570, we no longer auto create TILC masters

	//21 Jul 2021	NDL	TFS 51570 - already checked in caller
//	if not app.myRoot.getConfig(AutoLinkRefTraGen).Boolean then
//		return;
//	endif;
	
	tilcType := self.myTILCType;
	if tilcType &lt;&gt; null then 
		cargoType := tilcType.myCargoType.id; // use tilcType's cargo type if it's available
	else
		cargoType := self.cargoType;
	endif;
	realTiMaster := app.myRoot.findTIMasterByCargoType(cargoType, self.id).CM_TIMasterTILC;
	if realTiMaster = null then 
		isotype := self.getISOTypeObject();
		if isotype &lt;&gt; null then
			tareWeight := isotype.maxTareWeight;
		else
			isotype := self.myCargoType.allISOTypes.first;
			if isotype &lt;&gt; null then
				tareWeight := isotype.maxTareWeight;
			endif;
		endif;
		
		create proxyTiMaster transient;
		proxyTiMaster.setForProxyMasterTILC(self.id,
				"AUTOGENERATED",
				app.myRoot,
				null, null,
				0,
				self.myTILCType,
				self.myOperator,
				null, null, null, null, null, null, null, self.floorType);						// 29/05/2025 navcs2 MTN-34844
		app.myUtilityCA.utlCreateTiMasterTILC(proxyTiMaster, realTiMaster, app.myPassport);
//		tiMaster := realTiMaster;
	endif;

	if realTiMaster &lt;&gt; null then
		self.myTiMaster := realTiMaster;
	endif;
epilog
	delete proxyTiMaster;
end;</source>
    </JadeMethod>
    <JadeMethod name="autoQueueMAFIToVoyage" id="73018419-b431-4ea1-955a-28eae475ffc3">
        <source>autoQueueMAFIToVoyage();
/*

Purpose:			Queues self to voyage block stack if suitable to do so

Parameters:			

Return Value:		

Date				Who		Reason
22 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars

	tiSet 	: CM_TISet;
	ti		: CM_TrackedItem;
	moveController: CMIF_MoveController;
	
begin

	if not self.isMAFI then
		return;
	endif;
	
	if not self.isExport or not self.isOnSite then
		return;
	endif;
	
	if self.allPlannedFutureMoves.size &gt; 0 or self.allQueuedFutureMoves.size &gt; 0 then
		return;
	endif;
	
	if self.hasStopsForOnboardTIs then
		return;
	endif;
	
	if self.myVoyage = null or self.myVoyage.isNullVoyage then
		return;
	endif;
	
	if not self.myVoyage.status = Voyage_Status_Arrived 
	and not self.myVoyage.status = Voyage_Status_Loading then
		return;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem(self);
	moveController.setMyToPrimaryLocation(self.myVoyage.myShipBlockStack);
	moveController.setMoveMode(QUEUE_MODE);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
	
epilog

	delete moveController;
	
end;</source>
    </JadeMethod>
