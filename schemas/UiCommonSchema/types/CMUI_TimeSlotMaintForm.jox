    <JadeMethod name="userNotify" id="8747fb86-f346-4f0d-9d96-fd60fd3a5b05">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpEvent : Integer;
	tmpTerminal : CM_Terminal;
begin
	tmpTerminal := self.myTerminal;
	tmpEvent := tmpTerminal.getEventFromTerminalEvent(eventType);

	if tmpEvent = Event_TimeSlotStd_Add or 
			tmpEvent = Event_TimeSlotStd_Update or 
			tmpEvent = Event_TimeSlotStd_Delete then
		self.doTblUserNotify(theObject.CM_TimeSlotEntity);
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
