    <JadeMethod name="convertFromContRange" id="85d77b0c-bfac-4cc0-951d-98b1c48a682a">
        <updating/>
        <source>convertFromContRange(_id : String ; _contRange : CM_ContRange) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2008	cnwrd1	Initial creation

*/

vars

begin
	self.id := _id;
	self.coolingType := _contRange.coolingType;
	//self.volume := _contRange.cubicMetres;
	self.extHeight := _contRange.extHeight;
	self.extLength := _contRange.extLength;
	self.extWidth := _contRange.extWidth;
	self.isHeavyLift := _contRange.heavyLift;
	self.intHeight := _contRange.intHeight;
	self.intWidth := _contRange.intWidth;
	self.intLength := _contRange.intLength;
	self.isoType := _contRange.isoType;
	self.maxKilos := _contRange.maxKilos;
	self.myRoot := _contRange.myRoot;
	self.tWeight := _contRange.tareKilos;
	self.voltageType := _contRange.voltageType;
	self.cargoType := TI_CargoType_Container;

	

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_contRange" type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="convertFromEDIFleetTi" id="1b05f3d0-4087-4423-85ce-61944c523fc3">
        <updating/>
        <source>convertFromEDIFleetTi( _ediFleet : CM_EDIFleetTI; _operator : CM_Operator) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	cnwrd1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	genMaster : CM_TIMaster;
	genCargoType : CM_CargoType;
begin
	inheritMethod( _ediFleet , _operator );
	

	self.isoType := _ediFleet.isoType;
	self.isoGroup := _ediFleet.isoGroup;	
	self.maxKilos := _ediFleet.weight;
	
	self.coolingType := _ediFleet.coolingType;
	self.isCommunicating := ( _ediFleet.isCommunicating = 'Y');
	self.isHeavyLift :=  ( _ediFleet.isHeavyLift = 'Y');
	self.voltageType := _ediFleet.voltageType;
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if _ediFleet.attachedCargoId  &lt;&gt; null and _ediFleet.attachedCargoType &lt;&gt; null then
		genCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_ediFleet.attachedCargoType);
		if genCargoType &lt;&gt; null then
			genMaster := app.myRoot.allTiMasters[genCargoType.id, _ediFleet.attachedCargoId];
		endif;
		if genMaster &lt;&gt; null and self.canHaveGeneratorAttached then  
			self.allTIMasterAttachees.add(genMaster);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ediFleet" type="CM_EDIFleetTI"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
