    <JadeMethod name="clearInwardInfo" id="31a1eab2-9ff6-4f54-bf08-b65565342a91">
        <updating/>
        <source>clearInwardInfo() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pos : Integer;
	posStr : String;
begin
	if self.myDTOWagonIn &lt;&gt; null then
		if self.myDTOWagonIn.myRailLine &lt;&gt; null then
			pos := app.myHandHeldRailGuiAgent.getNextRakePosition(self.myDTOWagonIn.myRailLine);
			
			posStr := pos.padLeadingWith("0", 2);
		endif;
	endif;

	delete self.myDTOWagonIn;
	create self.myDTOWagonIn transient;
	self.maxCloneButtonsIn := 1;
	self.txtWagonPos.text := posStr;
	self.lblJobInfoIn.caption := null;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearOutwardInfo" id="3da75498-49e1-43dc-a2f5-2eee6a3dab5c">
