// -------------------------------------------
vars

begin

	return 5;	//per terminal// SFW 1121 cnwrs1  Sept 2011


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initDatabasePurge" id="d1672a17-7c7e-4f36-9fcf-d0067ca36798">
        <updating/>
        <source>
initDatabasePurge(	_user					: CM_User;
					_term					: CM_Terminal;
					_date					: Date;
					_voyage,
					_location,
					_docket,
					_offsite,
					_prenote,
					_bookingRef,
					_nsActivity, 						// ### TFS 50669 06AUG2021 NAVAB1
					_discrep,
					_machine,
					_sundry,
					_xlation,
					_ddExtractHistory,
					_lockTransactions,
					_ediData,
					_yardAllocationLogs,
					_menuUserItems,
					_logCheckScaleHdr,
					_vehicleVisit,
					_cargoPhoto,
					_eventRequests			: Boolean;
					_dutyDocs				: Boolean;
					_vehicleBookingSlots	: Boolean;	//15 Apr 2013
					_cargoGroups			: Boolean;	//22 Jun 2015	NDL	Par 36338
					_interTerminalRailBOLs	: Boolean;	//28/4/17 TFS 4157 28/4/17
					_truncateEDIInfoXML		: Boolean;	//13 Sep 2021	NDL	TSF 51718
					_maxDurationMinutes 	: Integer;	//TFS 6960
					_purgeSecGateUnknTrucks : Boolean;	// ### TFS 51994 01Oct2021 NAVPW1
					_purgeReleaseRequests   : Boolean;   // 16/09/2022 navmv20 TFS 53403
					_purgeAttachCargoTypes   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
					_purgeAttachContracts   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
					_purgeAttachInvoices   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
					_purgeAttachVoyages   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
					_purgeAttachWorkOrders   : Boolean;   // 13/02/2023 navhl20 #54900[56518]
					_purgeWorkOrderJobSheet	 : Boolean;		//21.7.2023 navhl20 #58158
					_purgeVisitPhotos		: Boolean;	//11.08.2025 navhl20 #35650
					_purgeAgGatewayMessages : Boolean	//navra1 - MTN-35875- 5th Sep 2025-2
					) updating;
	
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
//23/05/2012	cnwrs1	Par 29613
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
//20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//13 Feb 2023 		navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 		navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025		navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin
	self.myUser							:= _user;
	self.myTerminal 					:= _term;
	self.archiveDate					:= _date;
//	self.sleepInterval					:= _sleepInterval;
	
	self.purgeArchivedVoyages			:= _voyage;
	self.purgeArchivedLocations			:= _location;
	self.purgeEmptyBOLIns				:= _docket;
	self.purgeOffsiteTis				:= _offsite;
	self.purgePrenotedTis				:= _prenote;
	self.purgeBookingRefTis				:= _bookingRef;
	self.purgeNavisSmartActivity		:= _nsActivity;				// ### TFS 50669 06AUG2021 NAVAB1
	self.purgeNonContainerDiscrepancies	:= _discrep;
	self.purgeMachineHistory			:= _machine;
	self.purgeSundry					:= _sundry;
	self.purgeXlations					:= _xlation;
	self.purgeDDExtractHistory			:= _ddExtractHistory;
	self.purgeLockTransactions			:= _lockTransactions;
	self.purgeEDIData					:= _ediData;
	self.purgeYardAllocationLogTrans	:= _yardAllocationLogs;
	self.purgeMenuUserItems				:= _menuUserItems;
	self.purgeLogCheckScaleHdr			:= _logCheckScaleHdr;
	self.purgeVehicleBookings			:= _vehicleBookingSlots;	//15 Apr 2013	NDL	Par 31393
	self.purgeVehicleVisit				:= _vehicleVisit;
	self.purgeCargoPhotos				:= _cargoPhoto;				//01/12/2009 cnwdz2 par21808
	self.purgeEventRequests				:= _eventRequests;			//23/05/2012	cnwrs1	Par 29613
	self.purgeDutyDocs					:= _dutyDocs;				//21 dec 2012	NDL	Par 30901
	self.purgeReleasedCargoGroups		:= _cargoGroups;			//22 Jun 2015	NDL	Par 36338
	self.purgeInterTerminalRailBOLs		:=_interTerminalRailBOLs;	//28/4/17 TFS 4157 28/4/17
	self.maxDurationMinutes				:= _maxDurationMinutes;		//TFS 6960
	self.truncateEDIInfoXML				:= _truncateEDIInfoXML;		//13 Sep 2021	NDL	TFS 51718
	self.purgeSecGateUnknTrucks			:= _purgeSecGateUnknTrucks;	// ### TFS 51994 01Oct2021 NAVPW1
	self.purgeReleaseRequests           := _purgeReleaseRequests;   //16/09/2022 navmv20 TFS 53403
	self.purgeAttachmentCargoTypes      := _purgeAttachCargoTypes;  //14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentContract        := _purgeAttachContracts;   //14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentInvoices        := _purgeAttachInvoices;   	//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentVoyages         := _purgeAttachVoyages;  	//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentWorkOrders      := _purgeAttachWorkOrders;  //14/02/2023 navhl20 #54900[56518]
	self.purgeWorkOrderJobSheets		:= _purgeWorkOrderJobSheet;	//21.7.2023 navhl20 #58158
	self.purgeVisitPhotos				:= _purgeVisitPhotos;		//11.08.2025 navhl20 #35650
	self.purgeAgGatewayMessages			:= _purgeAgGatewayMessages;	//navra1 - MTN-35875- 5th Sep 2025-2
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_voyage" type="Boolean"/>
        <Parameter name="_location" type="Boolean"/>
        <Parameter name="_docket" type="Boolean"/>
        <Parameter name="_offsite" type="Boolean"/>
        <Parameter name="_prenote" type="Boolean"/>
        <Parameter name="_bookingRef" type="Boolean"/>
        <Parameter name="_nsActivity" type="Boolean"/>
        <Parameter name="_discrep" type="Boolean"/>
        <Parameter name="_machine" type="Boolean"/>
        <Parameter name="_sundry" type="Boolean"/>
        <Parameter name="_xlation" type="Boolean"/>
        <Parameter name="_ddExtractHistory" type="Boolean"/>
        <Parameter name="_lockTransactions" type="Boolean"/>
        <Parameter name="_ediData" type="Boolean"/>
        <Parameter name="_yardAllocationLogs" type="Boolean"/>
        <Parameter name="_menuUserItems" type="Boolean"/>
        <Parameter name="_logCheckScaleHdr" type="Boolean"/>
        <Parameter name="_vehicleVisit" type="Boolean"/>
        <Parameter name="_cargoPhoto" type="Boolean"/>
        <Parameter name="_eventRequests" type="Boolean"/>
        <Parameter name="_dutyDocs" type="Boolean"/>
        <Parameter name="_vehicleBookingSlots" type="Boolean"/>
        <Parameter name="_cargoGroups" type="Boolean"/>
        <Parameter name="_interTerminalRailBOLs" type="Boolean"/>
        <Parameter name="_truncateEDIInfoXML" type="Boolean"/>
        <Parameter name="_maxDurationMinutes" type="Integer"/>
        <Parameter name="_purgeSecGateUnknTrucks" type="Boolean"/>
        <Parameter name="_purgeReleaseRequests" type="Boolean"/>
        <Parameter name="_purgeAttachCargoTypes" type="Boolean"/>
        <Parameter name="_purgeAttachContracts" type="Boolean"/>
        <Parameter name="_purgeAttachInvoices" type="Boolean"/>
        <Parameter name="_purgeAttachVoyages" type="Boolean"/>
        <Parameter name="_purgeAttachWorkOrders" type="Boolean"/>
        <Parameter name="_purgeWorkOrderJobSheet" type="Boolean"/>
        <Parameter name="_purgeVisitPhotos" type="Boolean"/>
        <Parameter name="_purgeAgGatewayMessages" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="4cc0a081-eadf-4539-8dd9-7a231d4301d7">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskGarbageCollection) updating;
//
// SFW 1121 cnwrs1  Sept 2011
//
//23/05/2012	cnwrs1	Par 29613
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
//18/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	today : Date;
begin
	self.archiveDate					:= today.addDays(_task.daysToKeep*-1);	//back that number of days
	self.purgeArchivedLocations			:= _task.archivedLocations;
	self.purgeArchivedVoyages			:= _task.archivedVoyages;
	self.purgeBookingRefTis				:= _task.bookingRefTis;
	self.purgeCargoPhotos				:= _task.cargoPhotos;
	self.purgeDDExtractHistory			:= _task.dDExtractHistory;
	self.purgeEDIData					:= _task.eDIData;
	self.purgeEmptyBOLIns				:= _task.emptyBOLIns;
	self.purgeEventRequests				:= _task.eventRequests;
	self.purgeLockTransactions			:= _task.lockTransactions;
	self.purgeLogCheckScaleHdr			:= _task.logCheckScaleHdr; 
	self.purgeMachineHistory			:= _task.machineHistory;
	self.purgeMenuUserItems				:= _task.menuUserItems; 
	self.purgeNonContainerDiscrepancies	:= _task.nonContainerDscrp;
	self.purgeOffsiteTis 				:= _task.offsiteTis;
	self.purgePrenotedTis 				:= _task.prenotedTis;
	self.purgeNavisSmartActivity 		:= _task.navisSmartActivity; 			// ### TFS 50669 06AUG2021 NAVAB1
	self.purgeSundry 					:= _task.sundry;						//25 Jul 2013	NDL	Par 31691
	self.purgeVehicleBookings 			:= _task.vehicleBookings;				//15 Apr 2013	NDL	Par 31393
	self.purgeVehicleVisit 				:= _task.vehicleVisit; 
	self.purgeXlations 					:= _task.xlations;
	self.purgeYardAllocationLogTrans 	:= _task.yardAllocationLogTrans;
	self.purgeDutyDocs 					:= _task.dutyDocs;						//21 Dec 2012	NDL	Par 30901
	self.maxDurationMinutes 			:= _task.maxDurationMinutes;			//TFS 6960
	if app.isCargoGroupEnabled then												//22 Jun 2015	NDL	Par 36338
		self.purgeReleasedCargoGroups 	:= _task.purgeReleasedCargoGroups;
	endif;
	self.truncateEDIInfoXML 			:= _task.truncateEDIInfoXML;			//13 Sep 2021	NDL	TFS 51718
	
	self.purgeInterTerminalRailBOLs 	:= _task.purgeInterTerminalRailBOLs;	//epr TFS 4157 28/4/17
	self.purgeSecGateUnknTrucks 		:= _task.purgeSecGateUnknTrucks;		// ### TFS 51994 01Oct2021 NAVPW1
	self.purgeReleaseRequests           := _task.releaseRequests;               //18/11/2022 navmv20 TFS 55001
	self.purgeAttachmentCargoTypes      := _task.purgeAttachmentCargoTypes;               // 14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentContract        := _task.purgeAttachmentContract;               // 14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentInvoices        := _task.purgeAttachmentInvoices;               // 14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentVoyages         := _task.purgeAttachmentVoyages;               // 14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentWorkOrders      := _task.purgeAttachmentWorkOrders;               // 14/02/2023 navhl20 #54900[56518]
	self.purgeWorkOrderJobSheets		:= _task.purgeWorkOrderJobSheets;				//21.7.2023 navhl20 #58158
	self.purgeVisitPhotos				:= _task.purgeVisitPhotos;						//11.08.2025 navhl20 #35650
	self.purgeAgGatewayMessages			:= _task.purgeAgGatewayMessages;				//navra1 - MTN-35875- 5th Sep 2025-2
	
	inheritMethod(_task);
end;
</source>
        <Parameter name="_task" type="CM_AutoTaskGarbageCollection"/>
    </JadeMethod>
    <JadeMethod name="runDBPurge" id="e21e418f-e68c-4a77-bd21-6a6c3027f3cb">
        <source>runDBPurge() : Boolean protected;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT

vars

	dbPurgeAgent : CM_DBPurgeAgent;

begin
	
	app.setMyTerminal(self.myTerminal);
	create dbPurgeAgent transient;
	return dbPurgeAgent.purgeDatabase(self, self.myTerminal, self.archiveDate);
	
epilog

	delete dbPurgeAgent;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
