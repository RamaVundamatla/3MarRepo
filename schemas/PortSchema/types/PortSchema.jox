    <JadeMethod name="isAllowedToInspect" id="99fe8a45-4afa-41d1-9cbc-c34adeb4f6f5">
        <source>isAllowedToInspect():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2021	navndl1	Initial creation	TFS 50505

*/

vars

	tmpUser : CM_User;

begin

	if app.isSpecial() then
		return true;
	endif;
	
	tmpUser := self.getMyUser;
	if tmpUser = null then
		return false;
	endif;
	
	if tmpUser.isSuperUser then
		return true;
	elseif tmpUser.isJmtSupportUser then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAltKeyDown" id="f45d6e29-5925-4015-8ac2-b4fc36026a85">
        <source>isAltKeyDown() : Boolean;
constants
	VK_ALT    = #0012;  // alt key
	HIGH       = 2^15;
vars
	state:               Integer;
begin
	state := call getKeyState(VK_ALT);
	return (state.bitAnd(HIGH) = HIGH);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAppropriateBGPConfigured" id="58b86971-933c-431d-899f-4a31fba06c50">
        <source>isAppropriateBGPConfigured(_requestName : String; _bgpController : BGP_Controller) : Integer;
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
19 Feb 2010	cnwkpd1	PAR #22434 - Background Application performance - rework to 
					replace Class.allInstances
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
*/

vars
	controller		: BGP_Controller;
	manager			: BGP_Manager;
	count			: Integer;
begin
	foreach manager in app.myRoot.allBGPManagers discreteLock do
		foreach controller in manager.allBGPControllers discreteLock do
			// Ignore passed in controller if necessary. Being in transaction state
			// will pickup the new controller
			if _bgpController &lt;&gt; null and _bgpController = controller then
				continue;
			endif;
			if controller.allRequestClassesToProcess.includes(_requestName) then
				if _requestName = BGP_CamsRequest.name then
					if (_bgpController.BGP_GenericController.myTerminal &lt;&gt; null and
						controller.BGP_GenericController.myTerminal &lt;&gt; null) and
					   _bgpController.BGP_GenericController.myTerminal &lt;&gt; controller.BGP_GenericController.myTerminal then
						continue;
					endif;
				endif;
				count := count + 1;
			endif;
		endforeach;
	endforeach;

	return count;
epilog

end;</source>
        <Parameter name="_requestName" type="String"/>
        <Parameter name="_bgpController" type="BGP_Controller"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isAppropriateBGPRunning" id="a33b2cc0-b7d2-4416-b2f6-10a0c127d29c">
        <source>isAppropriateBGPRunning(_requestName : String) : Boolean;
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
19 Feb 2010	cnwkpd1	PAR #22434 - Background Application performance - rework to 
					replace Class.allInstances

*/

vars
	controller		: BGP_Controller;
	manager			: BGP_Manager;
	
begin
	foreach manager in app.myRoot.allBGPManagers discreteLock do
		foreach controller in manager.allBGPControllers discreteLock do
			if controller.allRequestClassesToProcess.includes(_requestName) and
			   controller.isRunning() then
				return true;
			endif;
		endforeach;
	endforeach;
	
/*	Old code replaced

	create objArray transient;
	BGP_Controller.allInstances(objArray, 100, true);
	foreach controller in objArray do
		if controller.BGP_Controller.allRequestClassesToProcess.includes(_requestName) and 
		   controller.BGP_Controller.isRunning() then
			return true;
		endif;
	endforeach;
*/
	return false;

epilog

end;</source>
        <Parameter name="_requestName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCallingFromForm" id="8e640d8e-2568-4bd0-b145-79c1de941de7">
        <source>isCallingFromForm(_formName : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/11/2023	navkc1 Bug 61103: EUP | CustDocs - Summary Issues

*/

vars
	
	control	: Control;
	
begin
	
	if app.isBackGroundApp then
		return false;
	endif;
	
	control := app.activeControl();
	
	if control &lt;&gt; null then
		return control.form.name = _formName;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_formName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
