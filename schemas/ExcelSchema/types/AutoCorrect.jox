    <JadeMethod name="addReplacement" id="e43fc887-b119-45f0-a7a2-89486685044f">
        <updating/>
        <source>addReplacement(what:String; replacement:String):Any updating;
	// 


begin

	return _jadeActiveXInvoke('AddReplacement', 1, '0.12,1.8,1.8', what, replacement).Any;

end;
</source>
