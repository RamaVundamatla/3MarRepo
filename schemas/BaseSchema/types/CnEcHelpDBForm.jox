    <JadeMethod name="btnStoreAll_SFlag_click" id="37335521-13c1-4404-81f7-679799a8299d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStoreAll_SFlag_click(btn: Button input) updating;

vars
	index			: Integer;
	flag1, flag2	: String;
	updateOccurred	: Boolean;
	error			: String;
	
begin
	updateOccurred := false;

	flag1 := txtFlag1.text.trimBlanks();
	flag2 := txtFlag1_1.text.trimBlanks();

	if (flag1 &lt;&gt; aMyHelp.flag1Text) or (flag2 &lt;&gt; aMyHelp.flag2Text) then
		updateOccurred := true;

		beginTransaction;
		error := aMyHelp.updateFlagText(flag1, flag2);
		
		if error.length = 0 then
			commitTransaction;
		else
			abortTransaction;
			app.msgBox(error, "Error saving flag details", 0);
			return;
		endif;
	endif;

	if not chkFlag1.value and not chkFlag2.value then
		return;
	endif;

	table.accessMode := Table.AccessMode_Cell;
	
	foreach index in 2 to table.rows do
		table.row := index;

		if chkFlag1.value then
			table.column := 7;

			if optSet.value then
				table.text := "1";
			else
				table.text := "0";
			endif;
		endif;
		if chkFlag2.value then
			table.column := 8;

			if optSet.value then
				table.text := "1";
			else
				table.text := "0";
			endif;
		endif;
	endforeach;
epilog
	if updateOccurred then
		self.populateAllDetails();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
