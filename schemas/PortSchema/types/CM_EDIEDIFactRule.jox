    <JadeMethod name="doBookingIgnoreText" id="2f4b1057-95ad-4214-811c-765cdd93e93a">
        <source>doBookingIgnoreText(_text :String io);
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars

begin
	if self.item &lt;&gt; self.Item_FTX_4_1 or self.function &lt;&gt; self.Function_FTX_4_1_BookingIgnore then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Invalid item/function ");
	endif;
epilog

end;</source>
        <Parameter name="_text" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="76f0ea4f-26ae-48a8-93c8-e824828467ec">
        <source>getAuditText(): String;
/*
Date		Who		Reason
09 May 2012	cnwcs5	Initial creation - CCMS POL 2122 - 8.1.1 add auditing for 8.1.1
*/
vars
	txt, str	:String;
begin
	str := "Action " &amp; self.getFunctionDescription;
	
	txt := txt &amp; self.formatAuditText(str, self.item &amp; '+' &amp; self.value);
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFTXBookingIgnoreText" id="d9985977-cc6d-425a-b95b-27f0811d30d9">
        <source>getFTXBookingIgnoreText(_ftxArray :StringArray512; _ignoreSegment :Boolean output):String;
/*
Date		Who		Reason
09 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	WILDCARD = '*';
vars
	ruleArray	:StringArray512;
	ruleElement	:String;
begin
	if self.item &lt;&gt; self.Item_FTX_4_1 or self.function &lt;&gt; self.Function_FTX_4_1_BookingIgnore then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid item/function');
	endif;
	
	create ruleArray transient;
	
	// get rule values for all segments
	self.value.getTokensForDelimiter ('+', ruleArray);
	
	if ruleArray.isEmpty or _ftxArray[1] &lt;&gt; ruleArray[1] then
		// 010 - text subject qualifier does not match
		return null;
	endif;
	
	if ruleArray.size &lt; 4 then
		ruleArray[4] := null;
	endif;
			
	ruleElement	:= ruleArray[2];
	
	if ruleElement &lt;&gt; WILDCARD then	// anything matches
		if ruleElement &lt;&gt; _ftxArray[2] then 
			// 020 - text function does not match
			return null;	
		endif;
	endif;
	
	ruleElement	:= ruleArray[3];
	
	if ruleElement &lt;&gt; WILDCARD then	// anything matches
		if ruleElement &lt;&gt; _ftxArray[3] then 
			// 030 - text reference does not match (only matching whole element not sub-elements)
			return null;	
		endif;
	endif;
	
	ruleElement	:= ruleArray[4];		

	if ruleElement = WILDCARD or ruleElement = _ftxArray[4] then 
		// the entire 040 segment matches the rule so we will never record remarks for this segment
		_ignoreSegment := true;		
	endif;
	
	// rule element will be used later to determine which sub-elements to ignore
	return ruleElement.toUpper;
epilog
	delete ruleArray;
end;</source>
        <Parameter name="_ftxArray" type="StringArray512"/>
        <Parameter name="_ignoreSegment" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFTXBookingRemarks" id="9825c95a-34cf-4198-b791-091e9fc3229b">
        <source>getFTXBookingRemarks(_ftxValue :String; _ignoreColl :StringArray512):String;
/*
Parameters	_ftxValue	- contents of FTX040 element
			_ignoreColl	- values from all Booking - Ignore text rules

Date		Who		Reason
09 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	WILDCARD = '*';
vars
	ftxArray, ruleArray		:StringArray512;
	ruleElement, ruleValue, 
	ftxValue, remarks		:String;
	int						:Integer;
begin
	if self.item &lt;&gt; self.Item_FTX_1_1 or self.function &lt;&gt; self.Function_FTX_1_1_BookingRemark then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid item/function');
	endif;

	if _ftxValue = null then
		return null;
	endif;
	
	// create array to hold FTX4 sub-elements
	create ftxArray transient;

	_ftxValue.getTokensForDelimiter (':', ftxArray);
		
	if ftxArray.size &lt; 5 then
		ftxArray [5] := null;
	endif;

	create ruleArray transient;
	
	// now strip out any sub-elements that should be ignored
	foreach ruleElement in _ignoreColl do :foreachLoop
		ruleArray.clear;

		ruleElement.getTokensForDelimiter (':', ruleArray);
		
		if ruleArray.size &lt; 5 then
			ruleArray[5] := WILDCARD;
		endif;
		
		foreach int in 1 to 5 do
			ruleValue 	:= ruleArray[int].toUpper;
			
			if ruleValue = WILDCARD or ruleValue = null then
				// anything OK in this segment
				continue;
			endif;
			
			ftxValue 	:= ftxArray[int].toUpper;
			
			if ftxValue = ruleValue then
				// we have some text to ignore - clear out that sub-element (all or nothing)
				ftxArray[int] := null;
			endif;
		endforeach;
	endforeach;
	
	// now get what is left of the remarks
	foreach int in 1 to 5 do
		ftxValue := ftxArray[int];
		
		if ftxValue &lt;&gt; null then
			if remarks = null then
				remarks := ftxValue;
			else
				remarks := remarks &amp; ' ' &amp; ftxValue;
			endif;
		endif;
	endforeach;
	
	return remarks;
epilog
	delete ftxArray;
	delete ruleArray;
end;</source>
        <Parameter name="_ftxValue" type="String"/>
        <Parameter name="_ignoreColl" type="StringArray512"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFTXBookingVentilation" id="13be6a36-f5f3-4379-9453-8efda8a4bdaa">
        <source>getFTXBookingVentilation(_ftxArray :StringArray512):Decimal;
/*
Date		Who		Reason
09 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	WILDCARD 			= '*';
	VENT_TAG			= '%VENT';
	UNITS_TAG			= '%UNITS';
	VENT_TAG_LENGTH		= 5;
	UNITS_TAG_LENGTH	= 6;
vars
	ruleValue, ruleElement, ftxElement, vent, ventUnits, ruleToken, ftxToken, 
	tag			:String;
	ruleArray	:StringArray512;
	int, pos, startPos, endPos, count, 
	tagLength	:Integer;
	result		:Decimal[14,4];	
	type		:CM_MeasurementType;
begin 
	if self.item &lt;&gt; self.Item_FTX_4_1 or self.function &lt;&gt; self.Function_FTX_4_1_BookingVent then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid item/function');
	endif;

	ruleValue 	:= self.value.toUpper;
	
	if not ruleValue.pos (VENT_TAG, 1) &gt; 0 then
		// no point continuing - we dont know where to look for the ventilation value
		return NULL_VENTILATION;
	endif;
	
	create ruleArray transient;
	
	ruleValue.getTokensForDelimiter ('+', ruleArray); 
		
	if ruleArray.isEmpty or _ftxArray[1] &lt;&gt; ruleArray[1] then
		// 010 - text subject qualifier does not match
		return NULL_VENTILATION;
	endif;
	
	foreach int in 2 to 4 do
		ruleElement := ruleArray[int];			// already uppercase 
		ftxElement	:= _ftxArray[int].toUpper;
		
		while true do
			count := count + 1;
			
			if count &gt; 10 then 
				break;
			endif;
			
			if ruleElement = VENT_TAG then
				// simple case
				vent := ftxElement;	
				break;
				
			elseif ruleElement = UNITS_TAG then
				// simple case
				ventUnits	:= ftxElement;	
				break;
			else
				// look for a tag
				pos := ruleElement.pos ('%', 1);
				
				if pos = 0 then
					// rule element does not contain tag so must be text to match
					if ruleElement &lt;&gt; WILDCARD and ruleElement &lt;&gt; ftxElement then
						return NULL_VENTILATION;
					else
						// a match so go onto next element
						break;
					endif;
				else
					// we have a tag in there 
					if pos &gt; 1 then
						// strip off everything before the first %
						ruleToken := ruleElement[1:pos-1];
						
						if ftxElement.startsWith (ruleToken) then
							// strip off token 
							ftxElement 	:= ftxElement [pos:end];
							ruleElement	:= ruleElement [pos:end];
						else 
							// does not match text
							return NULL_VENTILATION;
						endif;
					endif;
					
					tag 		:= null;
					tagLength	:= null;
					
					if ruleElement.startsWith (VENT_TAG) then 
						tag 		:= VENT_TAG;
						tagLength	:= VENT_TAG_LENGTH;
					elseif ruleElement.startsWith (UNITS_TAG) then 
						tag 		:= UNITS_TAG;
						tagLength	:= UNITS_TAG_LENGTH;
					endif;
					
					if tag &lt;&gt; null and ruleElement.startsWith (tag) then
						if ruleElement.length &gt; tagLength then
							// we have something after the ventilation value - need to find that 
							// part of the ftx element that is the ventilation value
							startPos	:= tagLength + 1;
							endPos		:= ruleElement.pos ('%', startPos);	
							
							if endPos = null then
								// no more tags - ruleToken will be constant value that must match remainder of ftxSegment
								ruleToken 	:= ruleElement [startPos :end];
								ruleElement	:= null;
							else
								// ruleToken is text between ventialtion and next tag
								ruleToken 	:= ruleElement [startPos :endPos-startPos];
								ruleElement	:= ruleElement [endPos:end];
							endif;
							
							startPos := ftxElement.pos  (ruleToken, 1);
							
							if startPos &gt; 0 then
								// ftx element contains the token
								if endPos = null then
									// token was the last thing in the rule
									ftxToken := ftxElement[startPos:end];
									
									if ftxToken &lt;&gt; ruleToken then 
										// there must be some extra stuff in the FTX segment - no match
										return NULL_VENTILATION;
									endif;
								endif;
								
								if tag = VENT_TAG then
									vent := ftxElement [1:startPos-1];
								elseif tag = UNITS_TAG then
									ventUnits := ftxElement [1:startPos-1];
								endif;
								
								if endPos &gt; 0 then
									// there is anther tag in the rule
									ftxElement 	:= ftxElement[startPos + ruleToken.length:end];
								endif;
							else 
								// no match on token
								return NULL_VENTILATION;
							endif;
						else
							// will be handled next iteration
						endif;
					endif;
				endif;
			endif;
			// nothing more to process
			if ruleElement = null then
				break;
			endif;
		endwhile;
	endforeach;
	
	if vent &lt;&gt; null then 
		if ventUnits &lt;&gt; null then
			// this is a temporary kludge due to shortName being a caseInsensitive key 
			// in the dictionary so we can't just do getAtKey
			foreach type in app.myRoot.allMeasurementTypesByShortName do
				if type.measurementType &lt;&gt; Type_Displacement then	
					continue;
				endif;
				
				if type.shortName.toUpper = ventUnits then
					break;
				endif;
				
				type := null;
			endforeach;
			
			if type &lt;&gt; null and  type.measurementType = Type_Displacement then
				result := app.convertMeasurementForStorage (type.shortName, vent.Decimal);
			else
				result := vent.Decimal;
			endif;
		else
			result := vent.Decimal;
		endif;
	else
		return NULL_VENTILATION;
	endif;
	
	return result;
epilog
	delete ruleArray;
end;</source>
        <Parameter name="_ftxArray" type="StringArray512"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getFTXSpecialStowage" id="bb74554d-b151-45d6-b917-871486104ba8">
        <source>getFTXSpecialStowage(_ftxArray :StringArray512):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2017	cnwndl1	Initial creation	TFS 4454

*/

vars

	defaultString : String;
	subStringArray : StringArray512;
	pos : Integer;

begin

	if _ftxArray = null or _ftxArray.size &lt; 3 then
		return null;
	endif;
	
	defaultString :=  _ftxArray[3];
	if defaultString = null then
		return null;
	endif;
	
	pos := defaultString.pos(':',1);
	if pos &lt; 1 then
		return defaultString;
	else
		create subStringArray transient;
		defaultString.getTokensForDelimiter (':', subStringArray);
		if not subStringArray.isEmpty then
			return subStringArray[1];
		endif;
	endif;
	
	return null;

epilog

	delete subStringArray;

end;</source>
        <Parameter name="_ftxArray" type="StringArray512"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFunction" id="22fdac6c-f3cc-4dfe-9ebc-4f184d675069">
