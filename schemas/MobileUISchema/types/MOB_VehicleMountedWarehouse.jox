    <JadeMethod name="doPickupDirectorTask" id="a3da7c92-5a97-477a-8b86-06cdc1df87be">
        <source>doPickupDirectorTask() protected;
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars	
	task : CM_RTQueueTask;
	result : Boolean;
	ti : CM_TrackedItem;
begin
	
	task:=self.frmDirector.userObject.CM_RTQueueTask;
	ti:=self.getSelectedDirectorCargo;
	result :=app.myVMAgent.doPickupDirectorSingleTask(task,	ti,self.getCargoQuantity(),self.getCargoWeight());
	
	if result then
		self.enableAllControls();
		self.frmDirector.visible:=false;
	endif;
		
epilog

end;</source>
