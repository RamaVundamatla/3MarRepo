    <JadeMethod name="delete" id="f7cf2f94-9c9e-4117-8cb1-8472f891f09e">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		14 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/

begin
	//self.allCMIF_HMS_Movements.purge(); jlgka1 TFS 45620
	delete self.myHMSVoyageData;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCopy" id="bcc7e2f3-d69a-447b-9ae6-a4adb97a436d">
        <updating/>
        <source>setForCopy(_voyageCode : String; _arrivalDT : TimeStamp; _priorVoyageGlobal : CM_VoyageGlobal) updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     Copy data from the passed in _priorVoyageGlobal
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	tmpVoyage	: CM_Voyage;
	pxyHMSData,
	tmpHMSData	: HMS_VoyageData;
	
begin

	tmpVoyage := _priorVoyageGlobal.allVoyages.first;
	tmpHMSData := tmpVoyage.myHMSVoyageData;

	self.callSign			:=	tmpVoyage.callSign;
	self.colour 			:=	tmpVoyage.colour;	
	self.craneClearence		:=	tmpVoyage.craneClearance;
	self.arrivalDT			:= _arrivalDT;
	self.laycanDateFrom 	:= null;
	self.laycanDateTo 		:= null;
	self.noHatches	 		:= _priorVoyageGlobal.numHatches;
	self.laycanTimeBegins 	:= null;
	self.lloydsNumber		:=	tmpVoyage.lloydsNumber;
	self.remarksGeneral 	:=	tmpHMSData.remarksGeneral;
	self.remarksVoyage 		:=	tmpVoyage.remarks;

	self.vesselName 			:= _priorVoyageGlobal.vesselName;
	self.vesselCode 			:= _priorVoyageGlobal.vesselCode;
	self.voyageCode			:=	_voyageCode;

	self.myOperator 		:=	tmpVoyage.myOperator;
	self.myPriorVoyageGlobal	:= _priorVoyageGlobal;
	self.mySubsVoyageGlobal	:= null;
	self.myTrade 			:=	tmpVoyage.myTrade;
	self.myShippingLine 	:=	tmpVoyage.myShippingLine;
	self.myShippingAgent 	:=	tmpHMSData.myShippingAgent;
	self.myVessel 			:=	_priorVoyageGlobal.getMyVessel();
	self.myVesselType		:=	tmpHMSData.myVesselType;

	beginLoad;
	pxyHMSData := tmpHMSData.pxyCreateUpdateProxy();
	endLoad;
	
	self.myHMSVoyageData		:=	pxyHMSData;
	
	self.myPriorVoyageGlobal	:=	_priorVoyageGlobal;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_arrivalDT" type="TimeStamp"/>
        <Parameter name="_priorVoyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistent" id="49aa2bbf-33be-4f90-bdbf-a13fec09aefc">
        <updating/>
        <source>setFromPersistent(_voyageGlobal : CM_VoyageGlobal) updating;
// ---------------------------------------------------------------------------
// Created:     18 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;
	pxyHMSData,
	tmpHMSData	: HMS_VoyageData;
	
begin

	self.myRealVoyageGlobal	:= _voyageGlobal;

	tmpVoyage := _voyageGlobal.allVoyages.first;
	tmpHMSData := tmpVoyage.myHMSVoyageData;

	self.callSign			:=	tmpVoyage.callSign;
	self.colour 			:=	tmpVoyage.colour;	
	self.craneClearence		:=	tmpVoyage.craneClearance;
	self.arrivalDT			:= _voyageGlobal.arrivalDT;
	self.laycanDateFrom 	:= _voyageGlobal.laycanDateFrom;
	self.laycanDateTo 		:= _voyageGlobal.laycanDateTo;
	self.noHatches	 		:= _voyageGlobal.numHatches;
	self.laycanTimeBegins 	:= _voyageGlobal.laycanTimeBegins;
	self.lloydsNumber		:=	tmpVoyage.lloydsNumber;
	self.remarksVoyage 		:=	tmpVoyage.remarks;

	self.vesselName 		:= _voyageGlobal.vesselName;
	self.vesselCode 		:= _voyageGlobal.vesselCode;
	self.voyageCode			:= _voyageGlobal.code;
	// 22038 June 2012 many voyageGlobals with null code - used as non-dup dictionary key
	//		use the voyage code instead
	if _voyageGlobal.code = null then
		self.voyageCode := tmpVoyage.code;
	endif;

	self.myOperator 		:=	tmpVoyage.myOperator;
	self.myPriorVoyageGlobal	:= _voyageGlobal.myPriorVoyageGlobal;
	self.mySubsVoyageGlobal		:= _voyageGlobal.mySubsVoyageGlobal;
	self.myTrade 			:=	tmpVoyage.myTrade;
	self.myShippingLine 	:=	tmpVoyage.myShippingLine;
	self.myVessel 			:=	_voyageGlobal.getMyVessel();
//par 16326  
	if tmpHMSData &lt;&gt; null then
		self.remarksGeneral 	:=	tmpHMSData.remarksGeneral;
		self.myShippingAgent 	:=	tmpHMSData.myShippingAgent;
		self.myVesselType		:=	tmpHMSData.myVesselType;
	
		self.myHMSVoyageData := tmpHMSData.cloneSelf(true).HMS_VoyageData;
		self.myHMSVoyageData.cloneReferences(tmpHMSData);
	endif;
	
end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
</Class>
