        <source>isIntendedRelMode_Match(_yaData: CM_YADataInteger): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwmd1	Initial creation

*/

vars

	yaData : CM_YAData;
	yaDataInteger : CM_YADataInteger;
	int : Integer;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IntendedRelMode );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataInteger) then
		yaDataInteger := yaData.CM_YADataInteger;
		if yaDataInteger &lt;&gt; null then
			if not yaDataInteger.allValues.isEmpty then
				int := yaDataInteger.allValues.first;
				return _yaData.allValues.includes(int);
			endif;
		endif;
	endif;
		
	return true;

epilog

end;</source>
