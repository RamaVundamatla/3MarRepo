    <JadeMethod name="wsBgpRun" id="20e2ff15-43f8-4a37-9639-2d7641c0b728">
        <source>wsBgpRun();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgma1	Initial creation

*/

constants
	//TaskDescription = "EDI - PROCESS NEW FILES (T01)";
	//TaskDescription = "MA FUTURE STORAGE";
	TaskDescription = "ZA111";
	
vars
	task : CM_AutoTask;
	tmpClass : Class;
	request	: BGP_Request;
	terminal : CM_Terminal;
	bgpController : BGP_TimerController;
	toDay : TimeStamp;
	found : Boolean;
begin
	app.initialize();
	terminal := CM_Root.firstInstance.allTerminals['CASH'];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	foreach task in app.myRoot.allAutoTasks do
		if task.description = TaskDescription then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		write 'Task (' &amp; TaskDescription &amp; ') not found.';
		return;
	endif;
	app.setIsBackGroundApp(true);
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write 'Request class ('&amp;task.requestClassName&amp;') not found.';
		return;
	endif;
	bgpController := BGP_AutoTimerController.firstInstance;

	app.myTrxCA.trxCreateBGPRequestFromTask(tmpClass, request, task, null, app.myPassport);
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, request, app.myPassport);
	process.profiler.methodCount := 50;
	process.profiler.start();
	request.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog	
	self.unlock(task);
	app.setIsBackGroundApp(false);
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	beginTransaction;
	delete request;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="xlatPreDeployStep1" id="c25c91be-2d0b-4bf0-ac93-55077371c107">
        <source>xlatPreDeployStep1();

