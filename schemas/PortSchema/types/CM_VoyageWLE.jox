end;</source>
    </JadeMethod>
    <JadeMethod name="areAllEntryTasksEqStatus" id="88723fec-c254-46ff-b9b0-9db2e62efdb7">
        <source>areAllEntryTasksEqStatus(statusToTest: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     &lt;3 - 14 February 2012 by cnwab1 
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//06 Mar 2025 		navma1 			 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------

vars
	rtqe : CM_RTQueueEntry;
	rtqt : CM_RTQueueTask;
	ti : CM_TrackedItem;
	voyQ : CM_VoyageQueue;
begin
	//epr par 35702 5/3/15
	if not inheritMethod(statusToTest) then
		return false;
	endif;
	rtqe := self.allRTQueueEntries.last;
	// PAR 29093
	// If this LOAD VoyageWLE is to be made complete then check whether the RT queue is set to use the ship lander to move to the ship
	// if it is and the TI is not yet on the ship, then we are not complete
	if statusToTest = WLE_COMPLETED and self.isForLoadJob() and rtqe &lt;&gt; null then	//06.03.2025 navma1 #MTN-34179
		rtqt := rtqe.allTasks.first();
	
		if rtqt &lt;&gt; null then
			voyQ := rtqt.getVoyageSubQueue();
			if voyQ &lt;&gt; null and voyQ.getLoadMachinesMode() = CM_VoyageCraneQueue.UseShipLanderApp then
				ti := self.myTrackedItem;
				if ti &lt;&gt; null and not ti.myPrimaryActualLocation.isVoyageController() then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="statusToTest" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeQueueForEntry" id="69dec21e-a2ff-441d-a70c-3e6d6d529ed8">
        <source>changeQueueForEntry();
// -------------------------------------------
// Created 13 February 2004 by cnwdvb1
// -------------------------------------------
vars

	theQueue		: CM_RadioTelemetryQueue;
	theQueueEntry	: CM_RTQueueEntry;
	workPoint			: CM_Object;
	retQueue		: CM_VoyageQueue;
	voyage	: CM_Voyage;
	
begin
	//no queue entries don't bother with validation of crane queue
	if self.allRTQueueEntries.size = 0 then
		return;
	endif;

	workPoint := self.job.CM_VoyageJob.getMyWorkPointObject;
	if workPoint &lt;&gt; null then
		voyage:=self.job.CM_VoyageJob.myVoyage;
		theQueue := workPoint.IF_VoyageWorkPoint.getWorkPointQueueForVoyage(voyage);
		
		// PAR 11144
		if theQueue = null then
			// PAR 26945
			if  self.job.myJobSheet = null then
				app.raiseCMException2(ERR_VOY_QUEUE_CRANE, workPoint.IF_VoyageWorkPoint.getID, voyage.code, null, null);
				return;
			endif;
			
			retQueue := voyage.myQueue;
			if retQueue &lt;&gt; null then
				app.raiseCMException2(ERR_VOY_QUEUE_CRANE, workPoint.IF_VoyageWorkPoint.getID, retQueue.id, null, null);
				return;
			else
				app.raiseCMException2(ERR_VOY_QUEUE_CRANE, workPoint.IF_VoyageWorkPoint.getID, voyage.code, null, null);
				return;
			endif;
		endif;

		if theQueue &lt;&gt; null then
			foreach theQueueEntry in self.allRTQueueEntries do
				theQueueEntry.switchJob(self.job);
				theQueueEntry.shiftEntry(theQueue);
				
			//	theQueue.addQueueEntry(theQueueEntry);
			endforeach;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="checkNullSubSeqNum" id="5500e6c9-b194-4b03-a570-2b360fab2d80">
        <updating/>
        <source>checkNullSubSeqNum() updating;
//
// Purpose:			subSeqNum records the original hold job planned amount
//					Set this to null when a new WLE has been cloned from this WLE
//					(but not if the subSeqNum equals the original job planned amount,
//					because we rely on this still being present to adjust cross-job WLEs
//					in CM_VoyageWLE::setStatus)
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Laoding - Marking Job as Direct Delivery
//
vars

begin
	if self.job = null or not self.job.isKindOf(CM_VoyageHoldJob) then
		return;
	endif;
	//if not self.job.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
	if not self.job.isDirectDeliveryJob then										// TFS 52293
		return;
	endif;
	if self.job.CM_VoyageHoldJob.originalJobAmount = self.subSeqNum then
		return;
	endif;
	self.subSeqNum := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpFMsWhenComplete" id="db79fca7-9207-4459-a3f5-42666a983833">
        <source>cleanUpFMsWhenComplete();
// ---------------------------------------------------------------------------
// Created:		MARCH 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.status = WLE_COMPLETED 
	and self.myFutureMove &lt;&gt; null then
		self.myFutureMove.erase(NORMAL_ERASE);
		if self.myFutureMove &lt;&gt; null then // if it was planned, then queued. Deleting the queued FM moves the planned FM to us so test again
			self.myFutureMove.erase(NORMAL_ERASE);
		endif;
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="completeBulkRelease" id="2987f29c-ba28-4166-8bb1-0f0ca4f16b39">
        <updating/>
        <source>completeBulkRelease(trackedItem : CM_TrackedItem io) updating;
// Update the WLE with the actual tracked item that has been used. The tracked item
// should now be sitting in the crane transfer area. From this point
// the WLE should act like a normal load
vars
	newRequest, 
	oldRequest 			: CM_Request;
	otherWLE 			: CM_WorkListEntry;
	craneTransAreaLC	: CM_LocationsController;
	tiActualLocation    : CM_LocationsController;
begin

	self.myTrackedItem := trackedItem;

	craneTransAreaLC := self.job.CM_VoyageJob.getCraneTransAreaLC();
	if craneTransAreaLC &lt;&gt; null then								//20 Aug 2014	NDL	Par 33700
		self.locationSource := craneTransAreaLC.getID;
	endif;
	
	self.job.changeStatus(JOB_UNACTIONED);
	self.setStatus(WLE_UNACTIONED);
	
	//cnwrd1 par 30363 if we are loaded to a different location than the one our request has then go find the right request and switcheroo. 11.9.2012
	tiActualLocation := self.myTrackedItem.myPrimaryActualLocation;
	
	if tiActualLocation &lt;&gt; self.myRequest.getVoyageLoadController then
	//we've switched slots so we need to shift the wle.
	// job-&gt; allrequests 
	// i need to find the (slot)request with the matching location and switch wle's
		oldRequest := self.myRequest;	
		foreach newRequest in self.myRequest.myJob.allRequests do
			if newRequest.getVoyageLoadController = tiActualLocation then
				otherWLE 			:= newRequest.allWorkListEntries.first;
				self.myRequest 		:= newRequest;
				otherWLE.myRequest  := oldRequest;
				break;
			endif;
		endforeach;
	endif;
	
	// we wil plan if we are dropped into a cta. cnwrd1 par 30735 21.11.2011
	if trackedItem.myPrimaryActualLocation.isCraneLaneController or trackedItem.myPrimaryActualLocation.isWorkPointLaneController then
		trackedItem.moveToLocation(
			self.myRequest.getVoyageLoadController,
			self.job,
			self,
			self.getCrane,
			PLANNING_MODE,
			false, true, false, false, false,  false, null,null,null,null,null,app.myPassport);	// TFS 2651
	endif;
end;
</source>
        <Parameter name="trackedItem" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="completeOutOfOrderLoad" id="170a86ac-05b3-4bb7-a75e-abd6c113ff62">
        <updating/>
        <source>completeOutOfOrderLoad(_ti: CM_TrackedItem io) updating;

/*

Purpose:	 //cnwrd1 par 30626 ccms 2209 23.10.12		

Parameters:			

Return Value:		


Date		Who		Reason
25 October 2012	cnwrd1	Initial creation

*/

vars
	newRequest, 
	oldRequest 			: CM_Request;
	otherWLE 			: CM_WorkListEntry;
	theMoveController 	: CMIF_MoveController;
	qFM,
	switchQFM			: CM_FutureMoveQueued;
	pFM,
	switchPFM			: CM_FutureMovePlanned;
	otherTi				: CM_TrackedItem;
	switchLocation 		: CM_LocationsController;
	aCrane				: CM_Crane;
	
begin

	self.myTrackedItem := _ti;
	if self.locationSource  = null then
		aCrane := self.getCrane();
		if aCrane &lt;&gt; null then
			self.locationSource := aCrane.transferAreaId;
		endif;
	endif;
	//self.job.changeStatus(JOB_UNACTIONED);
	//self.setStatus(WLE_UNACTIONED);
	
	//cnwrd1 par 30363 if we are loaded to a different location than the one our request has then go find the right request and switcheroo. 11.9.2012
//	if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myRequest.getVoyageLoadController then
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myRequest.getVoyageLoadController then	//19 Mar 2020	NDL	TFS 47004
	//we've switched slots so we need to shift the wle.
	// job-&gt; allrequests 
	// i need to find the (slot)request with the matching location and switch wle's
		oldRequest := self.myRequest;	
		foreach newRequest in self.myRequest.myJob.allRequests do
			if newRequest.getVoyageLoadController = self.myTrackedItem.myPrimaryActualLocation then
				otherWLE := newRequest.allWorkListEntries.first;
				self.myRequest := newRequest;
				otherWLE.myRequest := oldRequest;
				break;
			endif;
		endforeach;
	endif;
	
//	if _ti.myPrimaryPlannedLocation &lt;&gt; self.myRequest.getVoyageLoadController then
	if _ti &lt;&gt; null and _ti.myPrimaryPlannedLocation &lt;&gt; self.myRequest.getVoyageLoadController then//19 Mar 2020	NDL	TFS 47004
		switchLocation := _ti.myPrimaryPlannedLocation ;
		create theMoveController transient;
		theMoveController.allToLocations.add(self.myRequest.getVoyageLoadController);
		
		if self.myFutureMove &lt;&gt; null then
			if self.myFutureMove.isKindOf(CM_FutureMoveQueued) then
				qFM := self.myFutureMove.CM_FutureMoveQueued;
				if qFM &lt;&gt; null then
					qFM.resetLocations(theMoveController);
					_ti.refreshMyFutureLocations(QUEUE_MODE,null);
				
					pFM := qFM.myFutureMovePlanned;
					if pFM &lt;&gt; null then
						pFM.resetLocations(theMoveController);			
						_ti.refreshMyFutureLocations(PLANNING_MODE,null);
					endif;
				endif;
			else
				pFM := self.myFutureMove.CM_FutureMovePlanned;
				if pFM &lt;&gt; null then
					pFM.resetLocations(theMoveController);			
					_ti.refreshMyFutureLocations(PLANNING_MODE,null);
				endif;
			endif;		
		endif;
		
		if _ti.myPrimaryActualLocation = _ti.myPrimaryPlannedLocation then
			if pFM &lt;&gt; null then
				pFM.erase(NORMAL_ERASE);	
			endif;
		endif;
	endif;
	
	if otherWLE &lt;&gt; null and otherWLE.myTrackedItem &lt;&gt; null then
	//we need to replan the other ti to the right slot
		otherTi := otherWLE.myTrackedItem; 
		
		switchPFM := otherTi.getFutureMovePlanned(true).CM_FutureMovePlanned;
		if switchPFM &lt;&gt; null then
			switchQFM := switchPFM.myFutureMoveQueued;
		endif;
				
		theMoveController.allToLocations.clear;
		theMoveController.allToLocations.add(switchLocation);
		
		if switchPFM &lt;&gt; null then
			switchPFM.resetLocations(theMoveController);			
			otherTi.refreshMyFutureLocations(PLANNING_MODE,null);
		endif;
		
		if switchQFM &lt;&gt; null then
			switchQFM.resetLocations(theMoveController);			
			otherTi.refreshMyFutureLocations(QUEUE_MODE,null);
		endif;
		
		if switchLocation &lt;&gt; null then
			switchLocation.executeDisplayNotesForMove(theMoveController);
		endif;
	endif;

	
epilog
	delete theMoveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="defaultCraneLoadLane" id="9e867459-d66f-4379-9717-f6bbc76cd53c">
        <methodInvocation>mapping</methodInvocation>
        <source>defaultCraneLoadLane(_set: Boolean; _value: Integer io) mapping;
// -------------------------------------------
// Created 29 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _set then
		return;
	endif;
	
	if self.job = null then
		_value := 0;
		return;
	endif;
	
	if self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_SlotRequest) then
		if self.job.CM_VoyageJob.myVoyage.starboardBerthed then
			_value := self.myRequest.CM_SlotRequest.defaultCraneLoadLaneStarboard;
		else
			_value := self.myRequest.CM_SlotRequest.defaultCraneLoadLanePort;
		endif;
	else
		_value := 0;
	endif;



end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doIZeroFillSeqNum" id="2739f02e-e51e-47ff-a8eb-0b6b2c68bbfc">
        <source>doIZeroFillSeqNum() : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	zeroFillSeqNum : Boolean;
	aTerm : CM_Terminal;
begin
	// PAR 21903
	if app.myPassport &lt;&gt; null then
		return app.myPassport.configDoIZeroFillSeqNum;
	else
		if self.myRequest &lt;&gt; null then
			aTerm := self.myRequest.myTerminal;
			if aTerm &lt;&gt; null then
				zeroFillSeqNum := not aTerm.getConfig(ShipRemoveLeadingZeros).Boolean;
			endif;
		endif;
		return zeroFillSeqNum;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLEDelivery" id="fc882416-2c10-483b-a1c9-a3f233994020">
        <updating/>
        <source>enqueueWLEDelivery(arbiter: CM_RTQueueArbiter io) updating, protected;
/*
Purpose:	// PAR 37122		
Date		Who		Reason
19 November 2015	cnwab1	Initial creation
*/

vars
	voyage : CM_Voyage;
	term : CM_Terminal;
begin
	inheritMethod(arbiter);

	
	if self.isBulkRelease() then // PAR 37122 ship release request
		voyage := self.getVoyage(); // PAR 37122
		term := self.getMyTerminal(); // PAR 37122
		
		if term &lt;&gt; null and voyage  &lt;&gt; null then // PAR 37122
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(WLE_Update_Event), self);	 // PAR 37122
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b13e4a79-e022-41c3-8d8b-afa63054488f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;


vars
	//ti	:	CM_TrackedItem;
	//vJob : CM_VoyageJob;
begin

	exclusiveLock(self);
	//----------------
	//Unqueue if required
	//----------------
	self.unQueueWLE(app.myPassport); // PAR 26699 add passport as param;
	//--------------------------
  // WLE - TI Links via Job
	//-------------------------
	self.job := null;
	//--------------------------
	// WLE - Request Links
	//-------------------------
	self.myRequest := null;
	//------------------
	// Tidy up any assocciatedRequest links (inversed)
	//------------------
	self.associatedRequest := null;
	//---------------------
	// Finally delete self
  //---------------------
  	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGradeCode" id="fb82a88c-2f67-4193-80b0-b74b51e0fb6a">
        <source>getAvailabilityGradeCode() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	gradeCode	: String;
	bulkRelease 	   : CM_ReserveDetail;
	reserveSelection	: CM_ReserveSelection;
	grade 	: CM_MTGrade;
begin

	if self.myTrackedItem &lt;&gt; null then
		gradeCode := self.myTrackedItem.getAvailabilityGradeDesc();
	else
		if self.isBulkRelease then
			bulkRelease :=self.myRequest.getBulkReleaseReserveDetail;
			if bulkRelease.isKindOf(CM_ReserveSelection) then
				reserveSelection := bulkRelease.CM_ReserveSelection;
				if reserveSelection &lt;&gt; null and reserveSelection.allAvailabilityGrades.size &gt; 0 then
					gradeCode := reserveSelection.allAvailabilityGrades[1].String;
				else
					gradeCode := 0.String;
				endif;
			endif;
		endif;
	endif;
	
	return gradeCode;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBay" id="eaa83b7e-33f5-4c06-8a64-8fb39f79e274">
        <source>getBay() : CM_BayVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS MES 1241 par 28101

*/

vars

begin
	if self.myRequest.isKindOf(CM_SlotRequest) then
		return self.myRequest.CM_SlotRequest.myBay;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="getBayID" id="c7057054-8294-4114-b3ae-b90124a02281">
        <source>getBayID() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	bay : CM_BayVoyage;
begin
	bay:= self.getBay;
	if bay &lt;&gt; null then
		return bay.id;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCandHStats" id="5ab3a076-43da-409b-ba80-ab7f9f340107">
        <source>getCandHStats(_aCandHRpt : CMIF_CandHRpt input; progress: CMS_Progress io);

vars

begin
	if self.myTrackedItem = null then
		return;
	endif;

	// PAR 2711 AJA 8/3/99 When using wle's to calculate c&amp;h stats, rehandles are counted twice
	// as there is a wle for the discharge and load operations.
	// This fix ensures only the discharge job is counted. To ensure the total crane moves still increments
	// properly, 2 crane moves are added when the discharge job is processed. See trackedItem.getCandHStats
	if self.myTrackedItem.isRehandle and self.myRequest.getAttrIsLoad() then
		return;		// don't count the load side of the DLR operation
	endif;

	if self.myTrackedItem.isSOB and self.myRequest.getAttrIsLoad() then
		return;		// don't count the load side of the SOB operation
	endif;

	if _aCandHRpt.myOperator &lt;&gt; null
	and  _aCandHRpt.myOperator &lt;&gt; self.myTrackedItem.myOperator then
		return;	
	endif;

	if _aCandHRpt.usePRE_CCMS1468 then
		self.myTrackedItem.getCandHStatsOLD(_aCandHRpt, progress);
	else
		self.myTrackedItem.getCandHStats(_aCandHRpt);
	endif;
	
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
        <Parameter name="progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="d1b8c000-6bd7-485c-b2c3-5a6296f8ac83">
        <source>getCommodity() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	commodity	: String;
	terminal	: CM_Terminal;
begin

	if self.myTrackedItem &lt;&gt; null then
		commodity := self.myTrackedItem.commodity;
	else
		if self.isBulkRelease then
			terminal := self.myRequest.getBulkReleaseReserveDetail.getMyTerminal();
			if terminal &lt;&gt; null then
				commodity := terminal.getDefaultEmptyCommodity();
			endif;
		endif;
	endif;
	
	return commodity;
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCrane" id="8a9e448b-5df3-4e0b-8c7e-8225b3a6cdba">
        <source>getCrane() : CM_Crane;

// Created by cnwdvb1 on 03 April 2007

vars

begin

	if self.job = null then
		return null;
	endif;
	
	return self.job.CM_VoyageJob.getJobCrane();

end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getDischargePort" id="4a967baf-630a-46cd-bc9d-a94b93f1403b">
        <source>getDischargePort() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	port	: CM_Port;
	dischargePort : String;
begin

	if self.myTrackedItem &lt;&gt; null then
		dischargePort := self.myTrackedItem.dischargePort;
	else
		if self.isBulkRelease then
			port := self.myRequest.getBulkRelease.myDischargePort;
			
			if port &lt;&gt; null then
				dischargePort := port.code;
			endif;
		endif;
	endif;
	
	return dischargePort;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b60c9d58-b6a0-487b-9f1f-706792d08932">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 10/02/2017	cnwdap1		TFS 3220 LNX Voyge Operations Enhancements
// 22/08/2017   cnwma1		TFS #5625 CPL - Error - Release Carrier Job Operations
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 17/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07/12/2021	navdap1		TFS 52293 SAL Direct Laodng - Marking Job as Direct Delivery
// 21/06/2022   navsj20     TFS 53911 MTN - Hold Job Ops Moved Quantity
// 22/09/2022   navmv20     Bug 54686: MTN - Quantity values don't seem to be correct in Hold Job Operations for break-bulk cargo
// 09 Dec 2024	navhl20 	Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
// ---------------------------------------------------------------------------

vars
	myTI 		: CM_TrackedItem;
	zeroFillSeqNum : Boolean;
	laneExtra	: String;
	terminal	: CM_Terminal;
	cargoType 	: CM_CargoType;
	allocation 	: CM_VoyageAllocation;
	type 		: String;					// PAR #31155
	str			: String;					// PAR #31155
	value		: Decimal [23,10];			// PAR #31155
	ddPrenote	: Boolean;				// TFS 52360
	
begin

	if self.myRequest.myOriginatingBulkRelease = null and self.myTrackedItem = null then
		allocation := self.myRequest.getFirstAllocation();
	endif;

	myTI := self.myTrackedItem;
	// TFS 52360 is this a WLE for a direct prenote load?							// TFS 52293
	//if myTI &lt;&gt; null then															// TFS 52293
	//	ddPrenote := myTI.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;		// TFS 52293
	//else																			// TFS 52293
	//	ddPrenote := self.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean;	// TFS 52293
	//endif;																		// TFS 52293
	ddPrenote := self.job &lt;&gt; null and self.job.isDirectDeliveryJob;					// TFS 52293
	// TFS 52360 end of this bit
	if _attrName = ETRow_SeqNumCustomPort then
		zeroFillSeqNum := self.doIZeroFillSeqNum();
		if self.job.CM_VoyageJob.isTwinLift then
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.numSeqPortTwinCustom);
		else
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.seqNumCustomPort);
		endif;
	elseif _attrName = ETRow_AvailabilityGradeCode then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		elseif allocation &lt;&gt; null then //cnwrd1 1303
			return allocation.getDisplayStringForAttribute(ETRow_AvailabilityGrade, _short);
		else
			return getAvailabilityGradeCode();		// 09/06/2010 cnwmh5 #20661
			//return null;
		endif;
	elseif _attrName = ETRow_PlannedLocnSS  then
		if myTI = null then
			return self.getPlannedLocation();		// 09/06/2010 cnwmh5 #20661
		else
			return self.locationTarget;
		endif;
	elseif _attrName = ETRow_PlannedLocnOps  then
		if self.status = WLE_COMPLETED then
			return null;
		elseif self.isDirectDelivery then	//12 Feb 2013	NDL	Par 31102
			return self.getDDTargetLocationStr();
		elseif self.myFutureMoveDR &lt;&gt; null then	// 22/05/2019 jlgzm1 tfs42840
			return self.myFutureMoveDR.getPrimaryLocationId();
		elseif allocation &lt;&gt; null then //cnwrd1 1303
			return self.getPlannedLocation();
		else
			return self.locationTarget;
		endif;
	elseif _attrName = ETRow_LocationIdOps then
		//29 Jul 2013	NDL	Par 31421 - refer to Developer notes in this Par before being tempted to change this back.
		if myTI &lt;&gt; null then	
			return myTI.locationId;
		endif;
		
		if self.status = WLE_COMPLETED then
			return self.locationTarget;
		else
			return self.locationSource;
		endif;
	elseif _attrName = ETRow_LocationSS then 
		return self.locationSource;
	elseif _attrName = ETRow_Location and myTI &lt;&gt; null then
		return self.myRequest.CM_SlotRequest.mySlotController.getStowageId(myTI); 
	elseif _attrName = ETRow_CraneLane then
		if self.defaultCraneLoadLane &lt;&gt; null then
			terminal := self.getMyTerminal();
			if terminal &lt;&gt; null then
				laneExtra := app.extrapolateBayDirection(self, terminal.getConfig(CraneLaneDescription).Integer); 
			endif;
			// CCMS 1036
			if laneExtra = null then
				return self.defaultCraneLoadLane.String;	
			else
				return self.defaultCraneLoadLane.String &amp; ' ' &amp; laneExtra;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_DefaultCraneLoadLane then
		if self.defaultCraneLoadLane &lt;&gt; null then
			terminal := self.getMyTerminal();
			if terminal &lt;&gt; null then
				laneExtra := app.extrapolateBayDirection(self, terminal.getConfig(CraneLaneDescription).Integer); 
			endif;
			// CCMS 1036
			if laneExtra = null then
				return self.defaultCraneLoadLane.String;	
			else
				return self.defaultCraneLoadLane.String &amp; ' ' &amp; laneExtra;
			endif;
		endif;
		return null;		
	elseif _attrName = ETRow_SeqNumCustomStarboard then
		zeroFillSeqNum := self.doIZeroFillSeqNum();
		if self.job.CM_VoyageJob.isTwinLift then
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.numSeqStarboardTwinCustom);
		else
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.seqNumCustomStarboard);
		endif;
	elseif _attrName = ETRow_SeqNumPort then
		zeroFillSeqNum := self.doIZeroFillSeqNum();
		if self.job.CM_VoyageJob.isTwinLift then
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.numSeqPortTwin);
		else
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.seqNumPort);
		endif;
	elseif _attrName = ETRow_SeqNumStarboard then
		zeroFillSeqNum := self.doIZeroFillSeqNum();
		if self.job.CM_VoyageJob.isTwinLift then
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.numSeqStarboardTwin);
		else
			return self.getSeqNumZeroFill(zeroFillSeqNum,self.seqNumStarboard);
		endif;
	elseif _attrName = ETRow_SeqNumWorkOrder then
		zeroFillSeqNum := self.doIZeroFillSeqNum();
		return self.getSeqNumZeroFill(zeroFillSeqNum,self.seqNumWorkOrder);
	elseif _attrName = ETRow_SeqNumAsString then
		return self.seqNumAsString;
	elseif _attrName = ETRow_SeqNumAsDisplayString then
		//This is for the hidden sort column
		return self.seqNumAsString.padLeadingZeros(3);	
	elseif _attrName = ETRow_IsTwinLift then
		if self.isTwinLift then
			return 'T';
		else
			return null;
		endif;
	elseif _attrName = ETRow_BayId then
		return getBayID;
	elseif _attrName = ETRow_CompletedDT then  //cnwjo3 CCMS 1178
		return self.systemToLocalTime(self.completedDate).asStringJMT();	// 10/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif myTI = null and 
		   (   _attrName = ETRow_WeightTotal or
				_attrName = ETRow_MyOperator) and 
				self.myRequest.isBulkRelease() then
		// This is a bulk release that has not yet been actioned	
		return self.myRequest.getBulkRelease.getDisplayStringForAttribute(_attrName, _short);
	// 09/06/2010 cnwmh5 #20661 - Start
	elseif myTI = null and _attrName = ETRow_Commodity then
		if allocation &lt;&gt; null then //cnwrd1 1303
			return allocation.getDisplayStringForAttribute(ETRow_Commodity, _short);
		else
			return self.getCommodity();
		endif;
	elseif myTI = null and _attrName.toUpper = ETRow_ISOType.toUpper then
		if allocation &lt;&gt; null then
			return allocation.getDisplayStringForAttribute(ETRow_ISO, _short);	
		else
			return self.getISOType();	
		endif;
	elseif allocation &lt;&gt; null and _attrName.toUpper = ETRow_ISOType.toUpper then //cnwrd1 1303		
		return allocation.getDisplayStringForAttribute(ETRow_ISO, _short);	
		
	// 25/11/2015 cnwar2 #37151
	elseif _attrName.toUpper = ETRow_ISOGroup.toUpper then
		if allocation &lt;&gt; null then
			return allocation.getDisplayStringForAttribute(ETRow_ISOGroup, _short);
		else
			return self.getISOGroup();
		endif;
		
	elseif myTI = null and _attrName = ETRow_OperatorCode then
		if allocation &lt;&gt; null then
			return allocation.getDisplayStringForAttribute(ETRow_OperatorItem, _short);	
		else
			return self.getOperator();
		endif;
	elseif myTI = null and _attrName = ETRow_DischargePort then
		if allocation &lt;&gt; null then
			return allocation.getDisplayStringForAttribute(ETRow_DischargePort, _short);	
		else	
			return self.getDischargePort();
		endif;
	elseif myTI = null and _attrName = ETRow_Id then
		if allocation &lt;&gt; null then
			return allocation.code;
		endif;
		return self.getTIId();
	elseif myTI = null and _attrName = ETRow_Status then
		return self.getStatusDescr();
	
	elseif _attrName = ETRow_RadioTelemetry and self.isDirectDelivery() then
		return "DD";

	elseif _attrName.pos(ETRow_MovedWeight, 1) &lt;&gt; null then									// TFS 3220
		if self.status &lt;&gt; WLE_COMPLETED then												// TFS 3220
			return null;																	// TFS 3220
		else																				// TFS 3220
			_attrName.getRowNameMeasureType(str, type);										// TFS 3220
			return app.convertMeasurementForDisplay(type, self.weight);						// TFS 3220
		endif;																				// TFS 3220
	elseif _attrName.pos(ETRow_MovedVolume, 1) &lt;&gt; null then									// TFS 3220
		if self.status &lt;&gt; WLE_COMPLETED then												// TFS 3220
			return null;																	// TFS 3220
		else																				// TFS 3220
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.getDensity &lt;&gt; null then	// TFS 3220
				_attrName.getRowNameMeasureType(str, type);									// TFS 3220
				value := self.weight / self.myTrackedItem.getDensity;						// TFS 3220
				return app.convertMeasurementForDisplay(type, value);						// TFS 3220
			endif;																			// TFS 3220
		endif;																				// TFS 3220
	// start 21/06/2022 navsj20 TFS 53911
	elseif _attrName = ETRow_MovedQuantity then		
		if job &lt;&gt; null and job.isKindOf(CM_VoyageHoldJob) then
			//22/09/2022 navmv20 TFS 54686 - START
		    if self.status = WLE_UNACTIONED then 
				return null; 	
			else 
				return self.quantity.String;
			endif;
			//22/09/2022 navmv20 TFS 54686 - END
			//return self.quantity.String;  //22/09/2022 navmv20 TFS 54686
		endif;
	// end 21/06/2022 navsj20 TFS 53911
	elseif _attrName =  ETRow_CarrierId then												// 13/6/17 MAP TFS4209
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_Carrier, _short);
		else
			inheritMethod(_attrName, _short);
		endif;
	elseif _attrName = ETRow_ReleaseCarrier then //22.08.2017 cnwma1 TFS #5625
		if myTI &lt;&gt; null then
			return myTI.releaseCarrier;
		else
			return null;
		endif;
	elseif _attrName = ETRow_HasCargoGroupStops then  //22.08.2017 cnwma1 TFS #5625
		if myTI &lt;&gt; null then
			return app.getYesNo(myTI.hasCargoGroupStops);	
		else
			return null;
		endif;
	
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(str, type);								// TFS 51935
		//if self.myTrackedItem &lt;&gt; null then											// 32503 show total weight etc	// TFS 51935
		//if self.myTrackedItem &lt;&gt; null and str &lt;&gt; ETRow_TotalWeight then		// TFS 51935	// TFS 52360
		if self.myTrackedItem &lt;&gt; null and not ddPrenote and self.weight = null then					// TFS 51935	// TFS 52360	//09.12.2024 navhl20 #33643
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);	// 32503
		else
			// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
			_attrName.getRowNameMeasureType(str, type);									// PAR #31155
			return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
		endif;
			
	else
		if allocation &lt;&gt; null then //cnwrd1 ccms 1303
			if _attrName = ETRow_CargoTypeDescr then	 // cargoTypeDescr
				return allocation.getDisplayStringForAttribute(ETRow_CargoType, _short);	
			elseif _attrName = ETRow_CargoSubType then	
				return allocation.getDisplayStringForAttribute(ETRow_CargoSubtype, _short);	
			elseif _attrName = ETRow_MyOperator then	
				return allocation.getDisplayStringForAttribute(ETRow_OperatorItem, _short);	
			elseif _attrName = ETRow_ImexStatus then	
				return allocation.getDisplayStringForAttribute(ETRow_ImexStatus, _short);					
			elseif _attrName = ETRow_Consignee then	
				return allocation.getDisplayStringForAttribute(ETRow_Consignee, _short);	
			elseif _attrName = ETRow_TranshipDischPort then	
				return allocation.getDisplayStringForAttribute(ETRow_TranshipDischPort, _short);	
			elseif _attrName = ETRow_IsOverDimensional then	
				return allocation.getDisplayStringForAttribute(ETRow_IsOverDimensional, _short);	
			elseif _attrName = ETRow_IsHazardous then	
				return allocation.getDisplayStringForAttribute(ETRow_Hazardous, _short);	
			endif;
		endif;
		
		//if _attrName = ETRow_PlannedLocnFull and self.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean then// TFS 51935	// TFS 52293
		if _attrName = ETRow_PlannedLocnFull and ddPrenote then														// TFS 51935	// TFS 52293
			if self.status &lt;&gt; WLE_COMPLETED then																	// TFS 51935
				return self.locationTarget;																			// TFS 51935
			endif;																									// TFS 51935
		endif;																										// TFS 51935
		
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="0360f3c1-ef34-4897-bee7-8bc6f3305776">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	aString : String;
	aVoyage : CM_Voyage;
	aComm : CM_Commodity;
	aLocation : CM_LocationsController;
	aSubTerminal : CM_SubTerminal;
	anOperator : CM_Operator;
	anOperatorGroup : CM_OperatorGroup;
	dischgPort : CM_Port;
	obj : CM_Object;
	theAttrib : CMIF_GridAttributes;
	block : CM_DataContainerBlock;
	root : CM_Root;
	clashTIs 	: CM_TIByIdDict;
	invalidObject : Boolean;
	loadPort 	: CM_Port;
	imexStatus  : CM_IMEXStatus;
begin

	if (self.isBulkRelease and self.myTrackedItem &lt;&gt; null) or ( not self.isBulkRelease or (self.isBulkRelease and self.status = WLE_COMPLETED)) then //cnwrd1 par 30222
		inheritMethod(_dataContainer);			// 21/07/2010 cnwmh5 #25092
		
		if self.myRequest.isVoyageAllocDirector then //cnwrd1 1303
			self.myRequest.getFirstAllocation().getExtraInfo(_dataContainer);
		endif;
		return;
	endif;
	
	root := app.myRoot;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.getTIId, DC_Data, 1, self);
	
	imexStatus := root.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	if imexStatus &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, imexStatus);
		block.addNewItem(imexStatus.description, DC_Data, 1, imexStatus);
	endif;
	
	if self.getOperator() &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Operator_GC), DC_Label, 1, anOperator);
		block.addNewItem(self.getOperator() &amp; " - " &amp; root.allOperators[self.getOperator].description, DC_Data, 1, null);
	elseif self.getOperatorGroup() &lt;&gt; null then	//12 Mar 2012	NDL	Par 29248
		anOperatorGroup := self.getOperatorGroup();
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Operator_Group), DC_Label, 1, anOperatorGroup);
		block.addNewItem(anOperatorGroup.code &amp; " - " &amp; anOperatorGroup.description, DC_Data, 1, null);
	endif;
	
	//22/06/2009 cnwdz2  par20027
	if self.isBulkRelease then
		if app.isSubTerminalsOn(self.myRequest.getBulkReleaseReserveDetail.getMyTerminal()) then
			aSubTerminal := self.getSubTerminal();
			block := _dataContainer.addNewBlock;
			if aSubTerminal &lt;&gt; null  then
				on Exception do app.handleDeletedObject(exception, aSubTerminal, invalidObject);
				block.addNewItem(app.getErrorString(SubTerminal_GC), DC_Label, 1, aSubTerminal);
				block.addNewItem(aSubTerminal.code, DC_Data, 1, aSubTerminal);
			endif;
		endif;
	endif;
	
	aVoyage := self.getVoyage; 
	
	// changed 11/9/2006 by cnwmo1
	if app.isValidObject(aVoyage) then
		if aVoyage &lt;&gt; null then
			aString := aVoyage.code;
		endif;
		if aVoyage.description &lt;&gt; null then
			aString := aString &amp; " - " &amp; aVoyage.description;
		endif;
		if aString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, aVoyage);
			block.addNewItem(aString, DC_Data, 1, aVoyage);
		endif;
	else
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, null);
		block.addNewItem("N/A", DC_Data, 1, null);
	endif;
	
	aComm := root.allCommodities[self.getCommodity()];
	if aComm &lt;&gt; null then
		if self.getCommodity() &lt;&gt; null then
			aString := self.getCommodity();
		endif;
		if aComm.description &lt;&gt; null then
			aString := aString &amp; " - " &amp; aComm.description;
		endif;
		if aString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Commodity_GC), DC_Label, 1, aComm);
			block.addNewItem(aString, DC_Data, 1, aComm);
		endif;
	endif;

	loadPort := self.getLoadPort();
	if loadPort &lt;&gt; null then
		aString := loadPort.code;
		if loadPort &lt;&gt; null then
			if loadPort.description &lt;&gt; null then
				aString := aString &amp; " - " &amp; loadPort.description;
			endif;
		endif;
		if aString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Load_Port), DC_Label, 1, loadPort);
			block.addNewItem(aString, DC_Data, 1, loadPort);
		endif;
	endif;
	
	
	if self.getDischargePort() &lt;&gt; null then
		aString := self.getDischargePort();
		if aString &lt;&gt; null then
			dischgPort := root.allPorts[self.getDischargePort().trimBlanks];
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Discharge_Port), DC_Label, 1, dischgPort);
			block.addNewItem(aString &amp; " - " &amp; dischgPort.description, DC_Data, 1, dischgPort);
		endif;
	endif;
	
	if self.getISOType() &lt;&gt; null then
		if self.getISOType() &lt;&gt; null then
			aString := self.getISOType;
			obj := root.allISOTypes[self.getISOType()];
		else
			obj := null;
		endif;
		if obj &lt;&gt; null then
			aString := aString &amp; " - " &amp; obj.CM_ISOType.description;
		endif;
		if aString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_ISO), DC_Label, 1, obj);
			block.addNewItem(aString, DC_Data, 1, obj);
		endif;
	endif;

	aString := self.getPlannedLocation();
		
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Planned_Location), DC_Label, 1, aLocation);
	block.addNewItem(aString, DC_Data, 1, aLocation);

	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Weight), DC_Label, 1, null);
	block.addNewItem(self.getWeight.String, DC_Data, 1, null);
	
epilog
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getISOGroup" id="7244dfb2-f7eb-4f0f-9d54-2b7efb4508a7">
        <source>getISOGroup(): String;

/*
Date		Who		Reason
10 December 2015	cnwar2	Initial creation

*/

vars
	isoType				: CM_ISOType;
	isoGroup 			: CM_ISOTypeGroup;
	isoGroupStr			: String;
	bulkReserveDetail 	: CM_ReserveDetail;
	
begin
	if self.myTrackedItem &lt;&gt; null then
		isoGroup := self.myTrackedItem.getISOTypeGroup();
	else
		if self.isBulkRelease() then
			bulkReserveDetail := self.myRequest.getBulkReleaseReserveDetail;
			isoGroup := bulkReserveDetail.getISOGroup();
		endif;
	endif;
	
	if isoGroup &lt;&gt; null then
		isoGroupStr := isoGroup.code;
	endif;
	
	return isoGroupStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getISOType" id="1e3e0a2a-3f23-42f5-8d95-a9c2519535d3">
        <source>getISOType() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	isoType		: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	isoTypeStr	: String;
	bulkReserveDetail : CM_ReserveDetail;
begin
	if self.myTrackedItem &lt;&gt; null then
		isoTypeStr := self.myTrackedItem.getISOType();
	else
		if self.isBulkRelease() then
			bulkReserveDetail:=self.myRequest.getBulkReleaseReserveDetail;
			isoType := bulkReserveDetail.getISOType();
			if isoType = null then
				isoGroup := bulkReserveDetail.getISOGroup();
				if isoGroup &lt;&gt; null then
					isoType := isoGroup.allISOTypes.first;
				endif;
			endif;
			if isoType &lt;&gt; null then
				isoTypeStr := isoType.code;
			endif;
		endif;
	endif;
	
	return isoTypeStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
