		self.doSortTask(self.MoveDirection_Down, self.lstTasks.listObject.CM_WorkOrderVoyageDtl);	//26 May 2022 navsrk20 TFS 52351
	else 	
		self.doSortTask(self.MoveDirection_Down, self.lstTasks.listObject.CM_WorkOrderToDoDtl); 	// 15/12/2022	navcs2	#56840:[54265]
	endif;																							//26 May 2022 navsrk20 TFS 52351
epilog

end;</source>
