    <JadeMethod name="flipVertical" id="d38b9180-26ca-43d0-8f46-1931d849bd93">
        <updating/>
        <source>flipVertical(_recenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myDisplayBuilder = null then
		return;
	endif;
	
	if  self.myTargetLocation = null then
		return;
	endif;
	
	if not self.myDisplayBuilder.canFlipV(self.drawMode) then
		return;
	endif;
		
	self.flipV := not self.flipV;
	
	if self.flipV then
		self.topOffset := 0;
	else
		self.bottomOffset := 0;
	endif;

	if _recenterLocation then
		
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.reDrawAreaFromLocation(self.myTargetLocation, self.drawMode);	
	else			
		// Code for flipping without re-centering on location
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.calcViewSizes();	
		self.reCalcRowsForFlip();
		self.calcDrawRows();
		self.calcDrawCols();
		self.drawEverything();
	endif;

epilog

end;</source>
        <Parameter name="_recenterLocation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="genHighlightedLCKey" id="f9689a5c-024b-4c50-9d55-d056c0461d39">
        <source>genHighlightedLCKey(_lc : CM_LocationsController; _height : Integer) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := _lc.getFullId().toUpper();
	if _height &gt; 0 then
		key := key &amp; '_' &amp; _height.String;
	endif;
	return key;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawModeDescription" id="807fa9c7-59a8-4b94-b81e-1148a840188e">
        <source>getDrawModeDescription() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2010	cnwjk3	Initial creation

*/

vars
	_desc	: String;
begin
	if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		_desc := app.getErrorString(TopDownView);
	elseif self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
		_desc := app.getErrorString(FaceView);
		//21/04/2011 cnwdz2 par27313
		if self.isDrawForkLiftStack(self.myTargetLocation) then
			if self.lookForkLiftStackFromBottom then
				_desc := _desc &amp; "; " &amp; app.getErrorString(FaceView_LookFromBottom);
			else
				_desc := _desc &amp; "; " &amp; app.getErrorString(FaceView_LookFromTop);
			endif;
		endif;
	elseif self.drawMode = CMIF_RDTDrawElement.MODE_END then
		_desc := app.getErrorString(EndView);	
	endif;
	
	return _desc;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGapColumns" id="cbf64ef3-2366-4be7-83e7-67f29656a351">
        <source>getGapColumns(_gapCols : IntegerArray input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2010	#cnwdz2	 25671

*/

vars
	isGridArea,
	finishedCols : Boolean;
	i,
	rowStart,
	col,
	row 	 : Integer;
	lcDraw		 : CMIF_RDTLocationDrawElement;
	lc			 : CM_LocationsController;
begin
	if self.flipV then
		row := self.bottomGridRowDraw;	
	else
		row := self.topGridRowDraw;
	endif;
	rowStart := row;
	
	if self.flipH then
		col := self.rightGridColDraw;
	else
		col := self.leftGridColDraw;
	endif;	
	
	isGridArea := self.isLocationInGriddedArea(self.myTargetLocation);
	i := 0;
	finishedCols := false;
	while not finishedCols do		
		if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END)  and isGridArea then	
			lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(row, col, self.gridRowToStackHeight(row, self.myGridArea));
		else
			lcDraw := self.myDisplayBuilder.getLocationDraw(row, col);
		endif;
		if lcDraw &lt;&gt; null then 
			lc := lcDraw.getLocationController();
			if lc &lt;&gt; null and lc.isGap() then
				if i &lt; self.numGridRowsToDraw then
					row := row + 1;
					i:=i+1;	
					if i &gt;= self.numGridRowsToDraw then
						_gapCols.add(col);
					endif;
					continue;
				endif;
			endif;
		endif;
		
		
		col := col + 1;
		row := rowStart;
		i := 0;
		
		if self.flipH then
			finishedCols := col &gt; self.leftGridColDraw;
		else
			finishedCols := col &gt; self.rightGridColDraw;
		endif;					
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gapCols" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGapRows" id="c21fd134-85f3-46d9-a8bc-4794ee5c226d">
        <source>getGapRows(_gapRows : IntegerArray input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2010	#cnwdz2	 25671

*/

vars
	finishedRows : Boolean;
	i,
	colStart,
	colIndex,
	rowIndex 	 : Integer;
	lcDraw		 : CMIF_RDTLocationDrawElement;
	lc			 : CM_LocationsController;
begin
	if self.flipH then	
		colIndex := self.rightGridColDraw;
	else
		colIndex := self.leftGridColDraw;
	endif;
	colStart := colIndex;
	
	if self.flipV then
		rowIndex := self.bottomGridRowDraw;
	else
		rowIndex := self.topGridRowDraw;
	endif;
	
	finishedRows := false;	
	i := 0;
	while not finishedRows do			
		lcDraw := self.myDisplayBuilder.getLocationDraw(rowIndex, colIndex);
		if lcDraw &lt;&gt; null then 
			lc := lcDraw.getLocationController();
			if lc &lt;&gt; null and lc.isGap() then
				if i &lt; self.numGridColsToDraw then
					colIndex := colIndex + 1;
					i:=i+1;	
					if i &gt;= self.numGridColsToDraw then
						_gapRows.add(rowIndex);
					endif;
					continue;
				endif;
			endif;
		endif;
		
		
		rowIndex := rowIndex + 1;
		colIndex := colStart;
		i := 0;
		
		if self.flipV then
			finishedRows := rowIndex &gt; self.topGridRowDraw;
		else
			finishedRows := rowIndex &gt; self.bottomGridRowDraw;
		endif;				
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gapRows" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGridHeight" id="f120c520-7bfd-465f-b459-f18c226bb414">
