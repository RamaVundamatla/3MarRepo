    <JadeMethod name="resortTblData" id="b1ce3d82-289c-43e0-96f2-89d90c33875b">
        <source>resortTblData();
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 17 September 2003
//
//-----------------------------------------------------------------------

vars
	rowTotal,
	fixedRows,
	sortColNo	: Integer;
	sortColName	: String;
	theTable	: CM_DataTable;
begin
	theTable 	:= self.tblData;
	rowTotal 	:= theTable.rows;
	fixedRows	:= theTable.fixedRows;
	sortColNo 	:= theTable.column;
	
	if sortColNo &lt;= 0 then
		return;
	endif;
	
	if theTable.allTblDataColPropertyNames.size &gt;= sortColNo then	
		// look in the data table collection
		sortColName := theTable.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	theTable.resortTableByColumn(sortColNo);

	self.colorRows();	
end;</source>
    </JadeMethod>
