    <JadeMethod name="doLockAll" id="6ae3e9e8-8a50-4b30-aab3-e9381edff601">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doLockAll(_lock : Boolean) updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.usage = LIGHT_TOWER_USE or self.usage = BUILDING_USE or self.availability = PAD_UNAVAILABLE then
		self.locked := true;
		return;
	endif;

	self.locked := _lock;
end;</source>
        <Parameter name="_lock" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLockHazard" id="80050549-5c99-4ca4-ad5e-625018eca89b">
        <updating/>
        <source>doLockHazard(_hazardDetails : CM_TerminalAreaHazDetails) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	if not self.isGap and (self.usage = LIGHT_TOWER_USE or self.usage = BUILDING_USE or self.availability = PAD_UNAVAILABLE) then
		self.locked := true;
		return;
	endif;
	
	self.locked := false;
epilog

end;</source>
        <Parameter name="_hazardDetails" type="CM_TerminalAreaHazDetails"/>
    </JadeMethod>
    <JadeMethod name="doLockHeight" id="1b63d2e7-d920-4a23-90c2-962faf8578af">
