		self.tblCost.setFocus();
		self.tblCost.moveFirst();
	endif;
end;
</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickRateOption" id="dfb2ddf9-b42b-4bb0-87db-0d8989bb5079">
        <source>clickRateOption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2012	cnwndl1	Initial creation	Par 30375
Oct 2012	cnwjre1	30456 change the formatting to not have separators to avoid 14074 excp
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 26 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

*/

vars

	re : CM_RateEntry;
	ts : TimeStamp;
	// 32672 handle max rate of 6 decimals
//	cpu : Decimal [16,6];
//	rate : Decimal [16,6];
	cpu : Decimal [23,6];	//10 May 2018	NDL	TFS 38528
	rate : Decimal [23,6];	//10 May 2018	NDL	TFS 38528
	zero : Real;
	dpl : Integer;

begin

	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	re := self.myCurrentRateEntry;
	if re = null then
		ts.setDate(self.effectiveDate);
		ts.setTime(self.txtRateTime.getTime);
		ts := self.systemToLocalTime(ts);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if self.myCurrentDebtor &lt;&gt; null then
			re := self.myCurrentDebtor.getServiceTimeRate(self.myCurrentService, ts);
		elseif self.myCurrentLineGroupDebtor &lt;&gt; null then
			re := self.myCurrentLineGroupDebtor.getServiceTimeRate(self.myCurrentBank, self.myCurrentService, ts);
		endif;
	endif;

	if self.optRateCPU.value then
		self.tblCost.enabled := true;
		cpu := 0.00;
		if re &lt;&gt; null then
			if re.isCostPerUnitBased then
				cpu := re.getDerivedCostPerUnit( ts );
			endif;
		endif;
		self.txtCostPerUnit.dataType := TextBox.DataType_SignedNumeric; //26/04/2017 cnwma1 TFS #3852
		//self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostPercent.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostAdjust.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostPercent.text := zero.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostAdjust.text := zero.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostPerUnit.enabled := true;
		self.txtCostPercent.enabled := false;
		self.txtCostAdjust.enabled := false;
		
	elseif self.optRatePercent.value then
		self.tblCost.enabled := false;
		cpu := 0.00;
		rate := 0.00;
		if re &lt;&gt; null then
			if re.isPercentBased then
				rate := re.percentageOfBase - 100;	// 31732
				cpu := re.getDerivedCostPerUnit( ts );
			endif;
		endif;
		//self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostPercent.text := rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostAdjust.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostPercent.text := rate.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostAdjust.text := zero.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostPerUnit.enabled := false;
		self.txtCostPercent.enabled := true;
		self.txtCostAdjust.enabled := false;
		
		
	elseif self.optRateAdjust.value then
		self.tblCost.enabled := false;
		//self.txtCostPercent.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		self.txtCostPercent.text := zero.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		rate := 0.00;
		cpu := 0.00;
		if re &lt;&gt; null then
			if re.isAdjustmentBased then
				rate := re.adjustmentToBase;
				cpu := re.getDerivedCostPerUnit( ts );
			endif;
		endif;
		//self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostAdjust.text := rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostAdjust.text := rate.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		self.txtCostPerUnit.enabled := false;
		self.txtCostPercent.enabled := false;
		self.txtCostAdjust.enabled := true;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbBank_click" id="2084429a-e2bd-4d8f-8612-c451518b03ac">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBank_click(combobox: ComboBox input) updating;

vars
	bank	: CM_Bank;
begin
	bank := self.cmbBank.listObject.CM_Bank;			// 35872
	if bank &lt;&gt; self.myCurrentBank then
		self.myCurrentBank := bank;
		self.doComboServicesBuild();			// refresh the services available
		self.myCurrentService := null;
	endif;

end;
</source>
