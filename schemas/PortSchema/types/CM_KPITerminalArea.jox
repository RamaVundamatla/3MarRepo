    <JadeMethod name="addLocation" id="0aa204dd-7af9-40ea-a52d-c78a67b6ffb2">
        <updating/>
        <source>addLocation(_locn : CM_KPILocation input) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	_locn.setParent(self);
end;</source>
