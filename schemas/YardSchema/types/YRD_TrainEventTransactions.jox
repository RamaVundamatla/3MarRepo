    <JadeMethod name="loadTblEvents" id="60e0b1d3-df85-431f-b432-29fe1b66a55c">
        <source>loadTblEvents() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	event : CM_EventTransaction;
	eventDict : CM_EventTransByDateTime;
	
begin

	self.tblEvents.rows := self.tblEvents.fixedRows;
	self.tblEvents.allSelectedObjects.clear();
	
	if self.myTrain = null then
		return;
	endif;
	
	create eventDict transient;
	foreach event in self.myTrain.allTransactions do
		eventDict.add(event);
	endforeach;
	
	foreach event in eventDict do
		self.addEventRow(event);
	endforeach;
	
	self.tblEvents.selectMode := Table.SelectMode_None;
		
epilog

	delete eventDict;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
