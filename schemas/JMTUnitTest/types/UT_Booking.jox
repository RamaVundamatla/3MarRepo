    <JadeMethod name="tAddBooking" id="c567483d-27e4-4f5d-bed0-60a5dcd77182">
        <updating/>
        <source>tAddBooking()updating;
// jlgmp6
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking: CM_BookingRef;
begin
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	assertNotNull(booking);
end;</source>
