    <JadeMethod name="utlCreateWorkOrderMani" id="95e86ccb-b7a5-4251-a97e-537067621da5">
        <source>utlCreateWorkOrderMani(_proxyWorkOrder : CM_WorkOrder; _workOrder:CM_WorkOrder output;	_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
*/

vars
	voyageProformaTrxAction  : CMIF_TrxActionWOProforma;
	voyageProcess : CM_VoyageProcess;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valWorkOrder(_proxyWorkOrder);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _workOrder as _proxyWorkOrder.class persistent;		
	_workOrder.setForCreateShipMani(_proxyWorkOrder);

	if _passport.noErrors then
		if not app.isInProformaMode then
			voyageProcess := _passport.myTerminal.getDefaultVoyageProcess();			
			if voyageProcess = null or not voyageProcess.isEUPDefaultProcess then		
				create voyageProformaTrxAction transient;
				voyageProformaTrxAction.setMyWorkOrder(_workOrder,CM_TrxControlAgent.Trx_Create);
				_passport.addTrxPostAction(voyageProformaTrxAction);
				
			endif;																		
		endif;
	endif;
	
	if _passport.noErrors then										
		self.myCreateAuditAgent.audCreateGeneric(_workOrder);
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
