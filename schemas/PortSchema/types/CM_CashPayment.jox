    <JadeMethod name="getDescription" id="28cf1d91-9d09-4bb7-b678-401a366149f2">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2019 cnwma1	Bug 46586: New Cash collection form showing Tax codes rather than Description
09 Sep 2020 cnwma1  Bug 50002: MTN - Cash transaction enquiry shows proforma charges as invoice
*/

vars
	creditDetail	: CM_CashCreditDetail;
	typeString 	    : String;
	terminal 		: CM_Terminal;
	proformaStr     : String;
	isCancelled		: Boolean; //24/02/2025	navkc1 JIRA Bug MTN-34043
	cr				: CM_CashReceipt; //24/02/2025	navkc1 JIRA Bug MTN-34043
	invline : CM_InvoiceLine;
	invoice : CM_Invoice;
	seqnum, lineSeqnum : Integer;
begin

	terminal 	:= self.myTerminal;
	proformaStr := self.getProformaString();
	
	cr := self.myCashReceipt;	//24/02/2025	navkc1 JIRA Bug MTN-34043
	isCancelled := cr &lt;&gt; null and cr.isCancelled();	//24/02/2025	navkc1 JIRA Bug MTN-34043
	
	// TFS 39236
	if terminal &lt;&gt; null then 
		if not terminal.isUsingDefaultProcessJMT() then
			if self.isProformaPayment() and 
				not self.isTaxPaymentForReceipt() //20/01/2025	navkc1 JIRA Bug MTN-33463
				then
				if self.isMerged() then // TFS 45301
					typeString := app.getErrorString(Cargo_been_merged).toUpper()  &amp; Space &amp; proformaStr; // TFS 45301
				elseif isCancelled then //24/02/2025	navkc1 JIRA Bug MTN-34043
					typeString := app.getErrorString(Cancelled).toUpper() &amp; Space &amp; proformaStr; //24/02/2025	navkc1 JIRA Bug MTN-34043
				elseif self.voided then // TFS 45301
					typeString := app.getErrorString(PaymentStatus_Void).toUpper() &amp; Space &amp; proformaStr; // TFS 45301   // 20.02.2020 cnwma1 #48513
				else
					typeString := app.getErrorString(Proforma) 					   &amp; Space &amp; proformaStr;
				endif;
				return typeString;
			endif;
		endif;
	endif;
	
	invoice := self.myInvoice;
	invline := self.myInvoiceLine;
	if invoice = null then
		if invline &lt;&gt; null then
			invoice := self.myInvoiceLine.invoice;
			lineSeqnum := invline.sequenceNum;
		endif;
	endif;
	
	if self.isProformaPayment() and 
		not self.isTaxPaymentForReceipt() //20/01/2025	navkc1 JIRA Bug MTN-33463
		then
		if self.isMerged() then // TFS 45301
			typeString := app.getErrorString(Cargo_been_merged).toUpper()  &amp; Space &amp; proformaStr; // TFS 45301
		elseif isCancelled then //24/02/2025	navkc1 JIRA Bug MTN-34043
			typeString := app.getErrorString(Cancelled).toUpper() &amp; Space &amp; proformaStr; //24/02/2025	navkc1 JIRA Bug MTN-34043
		elseif self.voided then
			typeString := app.getErrorString(PaymentStatus_Void).toUpper() &amp; Space &amp; proformaStr; // TFS 45301  // 20.02.2020 cnwma1 #48513
		else
			typeString := app.getErrorString(Proforma) 					   &amp; Space &amp; proformaStr;
		endif;
	
//	elseif self.myInvoice &lt;&gt; null then
	elseif invoice &lt;&gt; null then
		seqnum := invoice.sequenceNum;
		
		if self.isMerged() then // TFS 45301
			typeString := app.getErrorString(Cargo_been_merged).toUpper()  &amp; Space &amp; seqnum.String; // TFS 45301
		elseif isCancelled then //24/02/2025	navkc1 JIRA Bug MTN-34043
			typeString := app.getErrorString(Cancelled).toUpper() &amp; Space &amp; seqnum.String; //24/02/2025	navkc1 JIRA Bug MTN-34043
			if invline &lt;&gt; null then
				typeString := typeString &amp; " " &amp; lineSeqnum.String;
			endif;
		elseif self.voided then // TFS 45301
			typeString := app.getErrorString(PaymentStatus_Void).toUpper() &amp; Space&amp; seqnum.String;  // TFS 45301 // 20.02.2020 cnwma1 #48513
		else
			typeString := app.getErrorString(INV_Invoice) &amp; " " &amp; seqnum.String;
			if invline &lt;&gt; null then
				typeString := typeString &amp; " " &amp; lineSeqnum.String;
			endif;
		endif;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		typeString := app.getErrorString1(Applied_to, self.myTrackedItem.id &amp; " - " &amp; typeString);
		if self.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357
			typeString := typeString &amp; " Tax (" &amp; self.myCashPaymentForInvoice.getTaxCodeForPayment(false) &amp; " " &amp; self.myCashPaymentForInvoice.getTaxRateForPayment().asStringJMT &amp; "%)"; // TFS 7357 / 20.09.2019.cnwma1 #46586
		endif;
	elseif invline &lt;&gt; null then	// manual payment or tax
		typeString := self.myInvoiceLine.invoiceLineDesc.narration &amp; " " &amp; typeString;
	endif;

	if self.myCashReceipt &lt;&gt; null then
		typeString := self.myCashReceipt.getExternalInvoiceNumber() &amp; " " &amp; typeString;
	endif;
	// 37141
	foreach creditDetail in self.allCashCreditDetails where creditDetail.myAppliedToCashCredit &lt;&gt; null do
		typeString := typeString &amp; " from credit " &amp; creditDetail.myAppliedToCashCredit.externalId;
		break;
	endforeach;
	
	return typeString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="48cb0688-23af-4eb6-bcd9-ef2f8996e866">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
30 Jan 2020 cnwma1  Bug 48416: ADP - Invoice lines not going to expected cash invoice
03 Jun 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
28 Oct 2021 navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
28 Apr 2023 navmk20	Bug 57588: MTN - Various properties not initialised on invoice line screen when there are cash payments

*/




	// #########################################################
	// ###### WHEN ADDING ANY NEW ETROWS 
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_INVOICELINE
	// ######
	// ###### THIS MIGHT BE TO ADD TO THE LIST TO GET FROM CM_TRACKEDITEM
	// ###### THIS MIGHT MEAN ADDING THE NEW ROW TO THE PART THAT RETURNS NULL
	// ###### THIS MIGHT MEAN ADDING TO GET THE SIMILAR VALUE FROM THE INVOICE LINE
	// #########################################################			







vars
	aCon 	      : CM_ConsigneeConsignor;
	operator      : CM_Operator;
	ff 	          : CM_ConsigneeConsignor;
	receipt		  : CM_CashReceipt;
	returnStr     : String;
	invalidObject : Boolean;
	type		  : String;
	str			  : String;
	debtor		  : CM_Debtor;
	debtorType	  : CM_DebtorType;
	paymentMethod : CM_PaymentMethod;
	service		  : CM_Service;
	glCode		  : CM_GLCode;
	serviceGroup  : CM_ServiceGroup;
	cargoType	  : CM_CargoType;
	customsAgent  : CM_CustomsAgent;
	terminal	  : CM_Terminal;
begin
	if _attrName = ETRow_Status  then
		return self.getStatusDescription(self.status);
	elseif _attrName = ETRow_LineTotal then
		return (-self.cashValue).asStringJMTWithPrecision(2, true);   //30.01.2020 cnwma1 #48416
	elseif _attrName = ETRow_Rate then
		return "0";
	elseif _attrName = ETRow_Narration  then
		//08 Aug 2019	NDL	TFS 44261
		if  self.myInvoiceLine &lt;&gt; null then
			return self.myInvoiceLine.invoiceLineDesc.narration;
		elseif self.proformaDesc.trimBlanks &lt;&gt; null then
			return self.proformaDesc.trimBlanks;
		elseif ( self.myProformaDetail &lt;&gt; null and self.myProformaDetail.remarks.trimBlanks &lt;&gt; null ) then
			self.myProformaDetail.remarks.trimBlanks;
		else
			return "Cash Payment";
		endif;
	elseif _attrName = ETRow_Narration200 or  _attrName = ETRow_Narration300  then	//28.10.2021 navma1 #52163	
		return "Cash Payment";
		
	elseif _attrName = ETRow_Quantity then
		return null;
	elseif _attrName = ETRow_SequenceNum then
	// 33885 show cash receipt number in invoice list as well as transaction charges
		receipt := self.myCashReceipt;
		if receipt = null then
			return null;
		else
			return receipt.getExternalInvoiceNumber();
		endif;
	elseif _attrName = ETRow_QuantityNoMinMax then
		return null;
	elseif _attrName = ETRow_Bank then
		if self.myInvoice &lt;&gt; null then
			return  self.myInvoice.bank.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Items  then
		return null;
	elseif _attrName = ETRow_InvoiceTypeCode  then
		if self.myInvoice &lt;&gt; null then
			if self.myInvoice.invoiceType &lt;&gt; null then
				return self.myInvoice.invoiceType.description;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_Ti  then
		if not manual then
			if self.myTrackedItem &lt;&gt; null then
				return self.myTrackedItem.id;
			else
				return null;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Remarks then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.remarks.removeTabCrLfs();
		else
			return null;
		endif;
	elseif _attrName = ETRow_Terminal  then
		/* //04/09/2025	navkc1 JIRA 35574
		if self.myDebtorTerminal &lt;&gt; null then
			return  self.myDebtorTerminal.myTerminal.code;
		else
			return "";
		endif;
		*/
		//04/09/2025	navkc1 JIRA 35574 Make it same as selector query
		terminal := self.myTerminal;
		
		if terminal &lt;&gt; null then
			str := self.myTerminal.code;
		endif;
		
		return str;
	elseif _attrName = ETRow_EscalatingDays then
		return null;
	elseif _attrName = ETRow_TranDeleted  then
		return null;
	elseif _attrName = ETRow_Transaction  then
		return "Payment";
	elseif _attrName = ETRow_Description  then
		return "Cash Payment";
	elseif _attrName = ETRow_DebtorCode  then
		if self.myDebtorTerminal &lt;&gt; null then
			return  self.myDebtorTerminal.myDebtor.name;
		else
			return "";
		endif;
	elseif _attrName = ETRow_EndDT  then
		return null;
	elseif _attrName = ETRow_Overridden  then
		return null;
	elseif _attrName = ETRow_SeqNumInvoice  then
		if self.myInvoice &lt;&gt; null then
			return self.myInvoice.sequenceNum.String;
		else
			return null;
		endif;
	elseif _attrName = ETRow_RecMode  then
		if self.myTrackedItem &lt;&gt; null then
			return app.transModeToString(self.myTrackedItem.receiptTransportMode);
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_DebtorConsol  then
		return null;
	elseif _attrName = ETRow_Operator  then
		returnStr := null;
		if self.myTrackedItem &lt;&gt; null then
			operator := self.myTrackedItem.myOperator;
			if operator &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, operator, invalidObject);
				returnStr := operator.description;
			endif;
		endif;
		return returnStr;
	elseif _attrName = ETRow_FreightForwarder  then
		if self.myTrackedItem &lt;&gt; null then
			ff := self.myTrackedItem.myFreightForwarder;
			if ff &lt;&gt; null then
				return ff.description;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_Consignor  then
		if self.myTrackedItem &lt;&gt; null then
			aCon := self.myTrackedItem.getConsignorObject();
			if aCon  &lt;&gt; null then
				return aCon.description;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Consignee  then
		if self.myTrackedItem &lt;&gt; null 
		and self.myTrackedItem.myConsignee &lt;&gt; null then
			return self.myTrackedItem.myConsignee.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_OperatorShip  then
		if self.myTrackedItem &lt;&gt; null 
		and self.myTrackedItem.myVoyage &lt;&gt; null 
		and self.myTrackedItem.myVoyage.myOperator &lt;&gt; null then
			return self.myTrackedItem.myVoyage.myOperator.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CustomsAgent  then
		/*
		if self.myTrackedItem &lt;&gt; null 
		and self.myTrackedItem.myCustomsAgent &lt;&gt; null then
			return self.myTrackedItem.myCustomsAgent.name;
		else
			return null;
		endif;
		*/
		
		//04/09/2025	navkc1 JIRA 35574 - Make it same as selector query
		customsAgent := self.getTrackedItemCustomsAgent();
		
		if customsAgent &lt;&gt; null then
			str := customsAgent.code;
		endif;
		
		return str;
		
	elseif _attrName = ETRow_Voyage then
		if self.myInvoice &lt;&gt; null and
		   self.myInvoice.myVoyage &lt;&gt; null then
			return self.myInvoice.myVoyage.code;
		elseif self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.voyageCode;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_ImexStatus then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getImExStatusStringDesc(not _short);
		else
			return null;
		endif;

	elseif _attrName = ETRow_ReceivedDT or
		   _attrName = ETRow_ReleasedDT or
		   _attrName = ETRow_DischargePort or
		   _attrName = ETRow_IsoType then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_ReleaseDT then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_ReleasedDT, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_StatusInvoiceManual then
		if self.myInvoice &lt;&gt; null then
			return self.myInvoice.getDisplayStringForAttribute(ETRow_Status, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_InvoiceTypeCode then
		if self.myInvoice &lt;&gt; null then
			return self.myInvoice.getDisplayStringForAttribute(ETRow_InvoiceTypeCode, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoIsTranship or
		   _attrName = ETRow_ImportVoyageCode or
		   _attrName = ETRow_ClientRef then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoDescription then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.description;
		else
			return null;
		endif;
	// TFS 2084 new rows for invoice lines
	elseif _attrName = ETRow_StatusChangeReason or
		   _attrName = ETRow_StatusChangeReasonCode then
		return null;
	elseif _attrName = ETRow_ToDoTaskComplete then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getToDoTasksDisplay(self.myTrackedItem.allToDoTasksCompleted, false);
		endif;
	elseif _attrName = ETRow_Exported        or              //18.09.2019 cnwma1 TFS #46582
		   _attrName = ETRow_ExportCount     or 
		   _attrName = ETRow_TransactionBOL  or              //30.01.2020 cnwma1 #48416
		   _attrName = ETRow_VoyageGroupCode or              //03/06/2020 cnwma1 Tfs #49400
		   _attrName = ETRow_VesselName      or              //03/06/2020 cnwma1 Tfs #49400
		   _attrName = ETRow_VesselCode      or             //03/06/2020 cnwma1 Tfs #49400
		   _attrName = ETRow_LineTotalRounded    or       //19.03.2020 cnwma1 TFS #50925
		    // ### JIRA 36051 23SEP2025 NAVAB1 From Here 
			_attrName = ETRow_ExternalReference1 or
			_attrName = ETRow_ExternalReference2 or
			_attrName = ETRow_ExternalReference3 or
			_attrName = ETRow_ExternalReference4 or  // ### JIRA 36051 01OCT2025 NAVAB1 this was missed by JIRA 35575
			_attrName = ETRow_UsedContractCalcType or
			_attrName = ETRow_UsedContractRate  then
 			return null;
	// #########################################################
	// ###### WHEN ADDING ANY NEW ETROWS THAT GET DATA FROM TRACKEDITEM
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_INVOICELINE
	// #########################################################			
	elseif _attrName = ETRow_RadioTelemetryState or
		   _attrName = ETRow_CustomExportStop or
		   _attrName = ETRow_TransferTerminalFrom or
		   _attrName = ETRow_TransferTerminalTo or
		   _attrName = ETRow_TimeInTransit or
		   _attrName = ETRow_Id or
		   _attrName = ETRow_MySubTerminal or
		   _attrName = ETRow_Mark or
		   _attrName = ETRow_MarkNumber or
		   _attrName = ETRow_LocationId or
		   _attrName = ETRow_Photos or
		   _attrName = ETRow_OperatorCode or
		   _attrName = ETRow_MyVoyage or
		   _attrName = ETRow_HasToDoTasks or
		   _attrName = ETRow_HasRemarks or
		   _attrName = ETRow_Damaged or
		   _attrName = ETRow_DamageDetail or
		   _attrName = ETRow_IsClean or
		   _attrName = ETRow_PreTripDate or
		   _attrName = ETRow_AvailabilityGradeCode or
		   _attrName = ETRow_AvailabilityGradeDescr or
		   _attrName = ETRow_MyPlannedLocation or
		   _attrName = ETRow_MyPrimaryQueuedLocation or
		   _attrName = ETRow_LoadOrderStr or
		   _attrName = ETRow_CargoTypeDescr or
		   _attrName = ETRow_FreightForwarderCode or
		   _attrName = ETRow_MyProduct or
		   _attrName = ETRow_TotalQuantity or
		   _attrName = ETRow_TotalWeight or
		   _attrName = ETRow_Volume or
		   _attrName = ETRow_MyTranshipToPort or
		   //_attrName = ETRow_DestinationPort or //04/09/2025	navkc1 JIRA 35574 make it same as selector query, done below
		   _attrName = ETRow_BookingReference or
		   //_attrName = ETRow_VoyageArrivalDate or //04/09/2025	navkc1 JIRA 35574 make it same as selector query, done below
		   _attrName = ETRow_IsControlledAtmosphere or
		   _attrName = ETRow_Oxygen or
		   _attrName = ETRow_CarbonDioxide or
		   //_attrName = ETRow_CustomsEntryNumber or //04/09/2025	navkc1 JIRA 35574 make it same as selector query, done below
		   _attrName = ETRow_CustomExportEntryNumber or
		   _attrName = ETRow_ImportReleasePIN or
		   _attrName = ETRow_ExportReleaseNumber or
		   _attrName = ETRow_Humidity or
		   _attrName = ETRow_Ventilation or
		   _attrName = ETRow_SealNum or
		   _attrName = ETRow_SealNumShippers or
		   _attrName = ETRow_ReceiptTransportMode or
		   _attrName = ETRow_ReleasedTransportMode or
		   _attrName = ETRow_CutoffTS or
		   _attrName = ETRow_EarliestRecTS or
		   _attrName = ETRow_Commodity or
		   _attrName = ETRow_CommodityGroup or
		   _attrName = ETRow_IsoTypeGroup or
		   _attrName = ETRow_TransitStatus or
		   _attrName = ETRow_IsHazardous or
		   _attrName = ETRow_IsOverDimensions or
		   _attrName = ETRow_CouType or
		   _attrName = ETRow_CompanyCode or
		   _attrName = ETRow_Length or
		   _attrName = ETRow_Height or
		   _attrName = ETRow_Width or
		   _attrName = ETRow_Site or
		   _attrName = ETRow_PlannedSite or
		   _attrName = ETRow_PlannedState or
		   _attrName = ETRow_State or
		   _attrName = ETRow_IsSecureExport or
		   _attrName = ETRow_ConsignorVoyageCode or
		   _attrName = ETRow_Carrier or
		   _attrName = ETRow_Wagon or
		   _attrName = ETRow_ReleasedDT or
		   _attrName = ETRow_DeliveryRelease or
		   _attrName = ETRow_ReleaseCarrier or
		   _attrName = ETRow_ReleaseWagon or
		   _attrName = ETRow_MyCustomsAgent or
		   _attrName = ETRow_AlternativeId or
		   _attrName = ETRow_HouseBillOfLading or
		   _attrName = ETRow_IsAvailable or
		   _attrName = ETRow_ContentsStatus or
		   _attrName = ETRow_WashDT or
		   _attrName = ETRow_IsHeavyDuty or
		   _attrName = ETRow_PackedDT or
		   _attrName = ETRow_SealNumCustoms or
		   _attrName = ETRow_UnpackedDT or
		   _attrName = ETRow_MyBulkReleaseAssigned or
		   _attrName = ETRow_IsReefer or
		   _attrName = ETRow_IsConnected or
		   _attrName = ETRow_Temperature or
		   _attrName = ETRow_MonitorConnection or
		   _attrName = ETRow_RequiresPower or
		   _attrName = ETRow_RequiresTemperature or
		   _attrName = ETRow_LastConnectDT or
		   _attrName = ETRow_CoolingType or
		   _attrName = ETRow_VoltageType or
		   _attrName = ETRow_CurtainsIn or
		   _attrName = ETRow_PlanningState or
		   _attrName = ETRow_ReadyToShip or
		   _attrName = ETRow_IsTranshipItem or
		   _attrName = ETRow_DischargeJobNum or
		   _attrName = ETRow_DischSeqNumber or
		   //_attrName = ETRow_LoadPort or //04/09/2025	navkc1 JIRA 35574 make it same as selector query, done below
		   _attrName = ETRow_LoadSeqNumber or
		   _attrName = ETRow_LoadJobNum or
		   //_attrName = ETRow_BillOfLading or //04/09/2025	navkc1 JIRA 35574 make it same as selector query, done below
		   _attrName = ETRow_AllSpecialLifts or
		   _attrName = ETRow_MyTrainAssigned or
		   _attrName = ETRow_IntendedReleaseMode or
		   _attrName = ETRow_CustomsReference or
		   _attrName = ETRow_ReceiveVoyage or
		   _attrName = ETRow_ReleaseVoyage or
		   _attrName = ETRow_IsWeightCertified or
		   _attrName = ETRow_WeightDeclared or
		   _attrName = ETRow_SpecialStow or
		   _attrName = ETRow_ReceiveStevedore    or     //02.10.2020 cnwma1 TFS #50112
		   _attrName = ETRow_ReleaseStevedore    or     //02.10.2020 cnwma1 TFS #50112
		    // ### JIRA 36051 23SEP2025 NAVAB1 From Here 
			_attrName = ETRow_BillOfLading or
			_attrName = ETRow_CargoIsTranship or
			_attrName = ETRow_CargoShippingLineCode or
			_attrName = ETRow_CargoShippingLineDesc or
			_attrName = ETRow_ClientRef or
			_attrName = ETRow_RemarksCargo or
			_attrName = ETRow_CustomsEntryNumber or
			_attrName = ETRow_CustomsReference    or
			_attrName = ETRow_DestinationPort or
			_attrName = ETRow_ImportVoyageCode or
			_attrName = ETRow_IsoType or
			_attrName = ETRow_Itemised or
			_attrName = ETRow_LoadPort or
			_attrName = ETRow_ReceivedDT or
			_attrName = ETRow_ReleaseDT or
			_attrName = ETRow_SecondaryBarcodeId or
			_attrName = ETRow_SpecialStow         or
			_attrName = ETRow_VoyageArrivalDate or
			_attrName = ETRow_SortingMethod then		   
		    // ### JIRA 36051 23SEP2025 NAVAB1 To Here 
	// #########################################################
	// ####### 
	// ###### WHEN ADDING ANY NEW ETROWS THAT GET DATA FROM TRACKEDITEM
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_INVOICELINE
	// #########################################################			
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	// ### START TFS 55751 06DEC2022 NAVAB1
	elseif _attrName = ETRow_TaxCode then
		return null;
	elseif _attrName = ETRow_TaxDescription then
		return null;
	elseif _attrName = ETRow_TaxGLCode then
		return null;
	elseif _attrName = ETRow_TaxExtRef then
		return null;
	elseif _attrName = ETRow_TaxRate then
		return null;
	elseif _attrName = ETRow_TaxValue then
		return null;
	elseif _attrName = ETRow_TaxTotal then
		return null;
	elseif _attrName = ETRow_TaxOverridden then
		return null;
	elseif _attrName = ETRow_TaxOverriddenCount then
		return null;
	// ### END TFS 55751 06DEC2022 NAVAB1
	elseif _attrName = ETRow_WorkOrders then			//16.12.2021 navma1 #52580
		if self.myCashReceipt &lt;&gt; null then
			if self.myCashReceipt.myWorkOrder &lt;&gt; null then
				return self.myCashReceipt.myWorkOrder.id;
			endif;
		endif;
		return null;
	// Start - 28.4.2023 navmk20 TFS 57588
	elseif _attrName = ETRow_InvoiceContractId then
		return null;
	elseif _attrName = ETRow_CargoShippingLineCode then
		return null;
	elseif _attrName = ETRow_CargoShippingLineDesc then
		return null;
	elseif _attrName = ETRow_UomCode then
		return null;
	elseif _attrName = ETRow_UomDescription then
		return null;
	elseif _attrName = ETRow_Locale then
		return null;
	elseif _attrName = ETRow_Currency then
		return null;
	elseif _attrName = ETRow_PaymentValue then //04/09/2025	navkc1 JIRA 35574
		return self.cashValue.asStringJMT();
	elseif _attrName = ETRow_PaymentActualValue then //04/09/2025	navkc1 JIRA 35574
		return self.getActualCashValue().asStringJMT();
	elseif _attrName = ETRow_BillOfLading then //04/09/2025	navkc1 JIRA 35574
		return self.getBOLNumber();
	elseif _attrName = ETRow_BusinessUnit then //04/09/2025	navkc1 JIRA 35574
		return self.getBankCode();
	elseif _attrName = ETRow_ChequeBankName then //04/09/2025	navkc1 JIRA 35574
		return self.getChequeBank();
	elseif _attrName = ETRow_ChequeBranch then //04/09/2025	navkc1 JIRA 35574
		return self.getChequeBranch();
	elseif _attrName = ETRow_ChequeDate then //04/09/2025	navkc1 JIRA 35574
		return self.getChequeDate().asStringJMT();
	elseif _attrName = ETRow_ChequeNumber then //04/09/2025	navkc1 JIRA 35574
		return self.getChequeNumber();
	elseif _attrName = ETRow_CustomsEntryNumber then //04/09/2025	navkc1 JIRA 35574
		return self.getCustomsEntryNumber();
	elseif _attrName = ETRow_Debtor then //04/09/2025	navkc1 JIRA 35574
		debtor := self.getDebtor();
		
		if debtor &lt;&gt; null then
			str := debtor.name;
		endif;
		
		return str;
	elseif _attrName = ETRow_DebtorAccount then //04/09/2025	navkc1 JIRA 35574
		return self.getDebtorAccountCode();
	elseif _attrName = ETRow_DebtorExternalReference then //04/09/2025	navkc1 JIRA 35574
		return self.getDebtorExtRef();
	elseif _attrName = ETRow_DebtorType then //04/09/2025	navkc1 JIRA 35574
		debtorType := self.getDebtorType();
		
		if debtorType &lt;&gt; null then
			str := debtorType.description;
		endif;
		
		return str;
	elseif _attrName = ETRow_ReceiptNumber then //04/09/2025	navkc1 JIRA 35574
		return self.getExternalInvoiceNumber();
	elseif _attrName = ETRow_PosNumber then //04/09/2025	navkc1 JIRA 35574
		return self.getExternalReceiptNumber();
	elseif _attrName = ETRow_InvoiceNumber then //04/09/2025	navkc1 JIRA 35574
		return self.getInvoiceNumber().asStringJMT();
	elseif _attrName =  ETRow_PaymentMethod then
		paymentMethod := self.getMyPaymentMethod();
		
		if paymentMethod &lt;&gt; null then
			str := paymentMethod.description;
		endif;
		
		return str;
	elseif _attrName = ETRow_ReceiptDate then //04/09/2025	navkc1 JIRA 35574
		return self.getReceiptDate().asStringJMT();
	elseif _attrName = ETRow_PaymentService then //04/09/2025	navkc1 JIRA 35574
		service := self.getService();
		
		if service &lt;&gt; null then
			str := service.name &amp; "  [" &amp; service.bank.code &amp; "/" &amp; service.bank.terminal.code &amp; "]";
		endif;
		
		return str;
	elseif _attrName = ETRow_PaymentServiceGL then //04/09/2025	navkc1 JIRA 35574
		glCode := self.getServiceGL();
		
		if glCode &lt;&gt; null then
			str := glCode.code &amp; "  [" &amp; glCode.bank.code &amp; "/" &amp; glCode.bank.terminal.code &amp; "]";
		endif;
		
		return str;
	elseif _attrName = ETRow_PaymentServiceGroup then //04/09/2025	navkc1 JIRA 35574
		serviceGroup := self.getServiceGroup();
		
		if serviceGroup &lt;&gt; null then
			str := serviceGroup.name &amp; "  [" &amp; serviceGroup.bank.code &amp; "/" &amp; serviceGroup.bank.terminal.code &amp; "]";
		endif;
		
		return str;
	elseif _attrName = ETRow_PaymentTaxCode then //04/09/2025	navkc1 JIRA 35574
		return self.getTaxCodeForPaymentShort();
	elseif _attrName = ETRow_CargoType then //04/09/2025	navkc1 JIRA 35574
		cargoType := app.myRoot.allCargoTypesById[self.getTrackedItemCargoType()];
		
		if cargoType &lt;&gt; null then
			str := cargoType.description;
		endif;
		
		return str;
	elseif _attrName = ETRow_CargoConsignee then //04/09/2025	navkc1 JIRA 35574
		aCon := self.getTrackedItemConsignee();
		
		if aCon &lt;&gt; null then
			str := aCon.code;
		endif;
		
		return str;
	elseif _attrName = ETRow_CargoConsignor then //04/09/2025	navkc1 JIRA 35574
		aCon := self.getTrackedItemConsignor();
		
		if aCon &lt;&gt; null then
			str := aCon.code;
		endif;
		
		return str;
	elseif _attrName = ETRow_DestinationPort then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemDestPort();
	elseif _attrName = ETRow_FreightForward then //04/09/2025	navkc1 JIRA 35574
		ff := self.getTrackedItemFreightForwarder();
		
		if ff &lt;&gt; null then
			str := ff.code;
		endif;
		
		return str;
	elseif _attrName = ETRow_CargoId then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemId();
	elseif _attrName = ETRow_Is20 then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIs20().getYesNo();
	elseif _attrName = ETRow_Is30 then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIs30().getYesNo();
	elseif _attrName = ETRow_Is40 then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIs40().getYesNo();
	elseif _attrName = ETRow_Is45 then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIs45().getYesNo();
	elseif _attrName = ETRow_Is53 then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIs53().getYesNo();
	elseif _attrName = ETRow_IsDirectDelivery then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemIsDD().getYesNo();
	elseif _attrName = ETRow_LoadPort then //04/09/2025	navkc1 JIRA 35574
		return self.getTrackedItemLoadPort();
	elseif _attrName = ETRow_UserName then //04/09/2025	navkc1 JIRA 35574
		return self.getUserName();
	elseif _attrName = ETRow_Vessel then //04/09/2025	navkc1 JIRA 35574
		return self.getVesselName();
	elseif _attrName = ETRow_VoyageArrivalDate then //04/09/2025	navkc1 JIRA 35574
		return self.getVoyageArrivalDate().asStringJMT();
	elseif _attrName = ETRow_VoyageGeneral then //04/09/2025	navkc1 JIRA 35574
		return self.getVoyageCode();
	elseif _attrName = ETRow_VoyageDepartureDate then //04/09/2025	navkc1 JIRA 35574
		return self.getVoyageSailingDate().asStringJMT();
	elseif _attrName = ETRow_PaymentIsMinimumCharge then //04/09/2025	navkc1 JIRA 35574
		return self.isMinimumCharge.getYesNo();
	elseif _attrName = ETRow_PaymentIsManual then //04/09/2025	navkc1 JIRA 35574
		return self.manual.getYesNo();
	elseif _attrName = ETRow_InvoiceIsStorage then //04/09/2025	navkc1 JIRA 35574
		return self.isStorage().getYesNo();
	elseif _attrName = ETRow_PaymentVoided then //04/09/2025	navkc1 JIRA 35574
		return voided.getYesNo();
    // ### JIRA 36051 23SEP2025 NAVAB1 From Here 
	elseif _attrName = ETRow_CalcTypeDesc then 
		return self.getCalculationTypeDesc();
	elseif _attrName = ETRow_CalculationType then
		return self.getCalculationTypeCode();
	elseif _attrName = ETRow_Remarks300 then
		return self.getLineRemarks();

	// #########################################################
	// ###### DO NOT PUT ANY NEW ETROWS AFTER THE FOLLOWING MEASUREMENT TYPE CODE
	// ###### ADD NEW ETROWS ABOVE THIS MEASUREMENT TYPE STATEMENT
	// #########################################################
	elseif _attrName.isMeasurementType then             //03/06/2020 cnwma1 TFS #49400
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
