    <JadeMethod name="asRealJMT" id="6b1042eb-361e-415d-99b8-34fec7033e6a">
        <source>asRealJMT() : Real;
// ---------------------------------------------------------------------------
// Created:     07 August 2007 by cnwrs2
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	tmpStr	: String;
	
begin
// cnwdad1 31/08/2010 - PAR #20064.
//	decimalSeperator := app.currentLocaleInfo.numericInfo.decimalSeparator;
	decimalSeperator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	tmpStr := self;
	tmpStr.replaceChar(decimalSeperator.Character, JMTDecimalSeperator);
	
	return tmpStr.Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asReportDateFromWebInterface" id="47f24452-73de-4344-a077-d6cdaf4e77dd">
        <source>asReportDateFromWebInterface() : Date;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/01/2020	jlgdap1		Initial creation TFS 47456 SNO Web portal report issues
//
vars
	date : Date;
	dd : String;
	mm : String;
	yy : String;
	df : DateFormat;

begin
	if self.length &lt;&gt; 10
	and self.length &lt;&gt; 16 then
		return null;
	endif;
	
	// If the length of the date here is 16, it's come from the web portal as a timestamp and is already in dd/mm/yyyyy
	// If it's only length 10, then it's a (hidden) report parameter date and will be in whatever format the server locale is
	create df transient;
	currentSchema.getLocaleDateInfo(0, df);
	if df.shortFormatOrder = df.MonthDayYear and self.length = 10 then
		mm := self[1:2];
		dd := self[4:2];
		yy := self[7:4];
	else
		dd := self[1:2];
		mm := self[4:2];
		yy := self[7:4];
	endif;
	
	if dd.isInteger and mm.isInteger and yy.isInteger then
		date.setDate( dd.Integer, mm.Integer, yy.Integer );
		if date.isValid then
			return date;
		endif;
	endif;
	
	return null;

epilog
	delete df;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="asString200ArrayByDelimiter" id="1938120f-00ad-4c3d-8cea-9c6a7f88950f">
        <source>asString200ArrayByDelimiter(sta: String200Array input; delimiter: String);
// ---------------------------------------------------------------------------
// Created:      21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------

vars
	ix : Integer;
	iy : Integer;
	len : Integer;
	tmpStr	: String;

begin
	ix := 1;
	iy := 1;
	len := delimiter.length;

	while iy &lt; self.length do
		iy := self.pos(delimiter, ix);
		if iy = 0 then
			break;
		endif;
		if iy - ix &gt; 0 then
			tmpStr := self[ix : iy - ix];
			if tmpStr.length &gt; 200 then
				sta.add(tmpStr[1:200]);
			else
				sta.add(tmpStr);
			endif;
		else
			sta.add(null);
		endif;
		ix := iy + len;
	endwhile;

	if ix &lt;= self.length then
		tmpStr := self[ix : end];
		if tmpStr.length &gt; 200 then
			sta.add(tmpStr[1:200]);
		else
			sta.add(tmpStr);
		endif;
	endif;
end;</source>
        <Parameter name="sta" type="String200Array" usage="input"/>
        <Parameter name="delimiter" type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringArrayByDelimiter" id="da565332-d838-4b10-896e-2c760c9c734a">
        <source>asStringArrayByDelimiter(sta: StringArray input; delimiter: String);
// ---------------------------------------------------------------------------
// Created:      16 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------

vars
	ix : Integer;
	iy : Integer;
	len : Integer;
	strLen : Integer;
	memberShipSize : Integer;
begin
	ix := 1;
	iy := 1;
	len := delimiter.length;
	//epr 17/9/18 if a huge string array of string array with different membership size is passed in they truncate to the size of the membership not 60
	//memberShipSize:=sta.class.CollClass.memberTypeSize-1;
	memberShipSize := sta.getMaxLength();	// 27/04/21 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values
	
	while iy &lt; self.length do
		iy := self.pos(delimiter, ix);
		if iy = 0 then
			break;
		endif;
		if iy - ix &gt; 0 then
			strLen :=  iy - ix;
			
			if strLen &gt; memberShipSize then // StringArrays cannot have strings &gt; 60 in length
				strLen := memberShipSize;
			endif;
			
			sta.add(self[ix :strLen]);
		else
			sta.add(null);
		endif;
		ix := iy + len; // do not include the delimiter
	endwhile;

	if ix &lt;= self.length then
		strLen :=  (self.length - ix) + 1;
		if strLen &gt; memberShipSize then // StringArrays cannot have strings &gt; 60 in length
			strLen := memberShipSize;
		endif;
		sta.add(self[ix :strLen]);
//		sta.add(self[ix : end]);
	endif;
end;</source>
        <Parameter name="sta" type="StringArray" usage="input"/>
        <Parameter name="delimiter" type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringHugeArrayByDelimiter" id="e9b8c9e9-b5d7-44da-ab80-6861e72cf6e5">
        <source>asStringHugeArrayByDelimiter(sta: HugeStringArray  input; delimiter: String);
// ---------------------------------------------------------------------------
// Created:      16 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// TFS 50669
vars
	ix : Integer;
	iy : Integer;
	len : Integer;
	strLen : Integer;
	memberShipSize : Integer;
begin
	ix := 1;
	iy := 1;
	len := delimiter.length;
	//epr 17/9/18 if a huge string array of string array with different membership size is passed in they truncate to the size of the membership not 60
	//memberShipSize:=sta.class.CollClass.memberTypeSize-1;
	memberShipSize := sta.getMaxLength();	// 27/04/21 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values
	
	while iy &lt; self.length do
		iy := self.pos(delimiter, ix);
		if iy = 0 then
			break;
		endif;
		if iy - ix &gt; 0 then
			strLen :=  iy - ix;
			
			if strLen &gt; memberShipSize then // StringArrays cannot have strings &gt; 60 in length
				strLen := memberShipSize;
			endif;
			
			sta.add(self[ix :strLen]);
		else
			sta.add(null);
		endif;
		ix := iy + len; // do not include the delimiter
	endwhile;

	if ix &lt;= self.length then
		strLen :=  (self.length - ix) + 1;
		if strLen &gt; memberShipSize then // StringArrays cannot have strings &gt; 60 in length
			strLen := memberShipSize;
		endif;
		sta.add(self[ix :strLen]);
//		sta.add(self[ix : end]);
	endif;
end;</source>
        <Parameter name="sta" type="HugeStringArray" usage="input"/>
        <Parameter name="delimiter" type="String"/>
    </JadeMethod>
