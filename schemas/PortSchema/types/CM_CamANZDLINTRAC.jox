<Class name="CM_CamANZDLINTRAC" id="d845ec07-dfd9-469f-aaa9-3619e7b2b23f">
    <superclass name="CM_CamINTRACDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <JadeMethod name="create" id="15a27810-6bdb-4b7d-89dc-3df81c81ed3c">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "Anzdl INTRACON";
	self.type := EDIFileTypeCams_ANZDLIntracon;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMessageType" id="1563ba7f-e3e0-4431-8628-885b481c0caa">
        <source>getMessageType(_transaction : CM_TITransaction;
				_messageTypeArray : IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars
	theTI : CM_TrackedItem;

begin

	theTI := _transaction.myTrackedItem;

	_messageTypeArray.clear;
	if _transaction.isCamsShipReceiveType() then
		_messageTypeArray.add(INTRACON_SHIPIN);
	elseif _transaction.isCamsShipReleaseType() then
		_messageTypeArray.add(INTRACON_SHIPOUT);
	elseif _transaction.isCamsRoadReceiveType() or
		   _transaction.isCamsPackType() then
		if (self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "F" or
			self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "L") and
		   theTI.isExport then
			_messageTypeArray.add(INTRACON_ROADRCV);
		else
			_messageTypeArray.add(INTRACON_ROADIN);
		endif;
	elseif _transaction.isCamsRailReceiveType() then
		if (self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "F" or
			self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "L") and
		   theTI.isExport then
			_messageTypeArray.add(INTRACON_RAILRCV);
		else
			_messageTypeArray.add(INTRACON_RAILIN);
		endif;
	elseif _transaction.isCamsRoadReleaseType() or
		   _transaction.isCamsUnpackType() then
		if theTI.deliveryReleaseReason = DEL_SNT then
			_messageTypeArray.add(INTRACON_ROADSNT);
		elseif (self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "F" or
			self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "L") and
		   theTI.isImport then
			_messageTypeArray.add(INTRACON_ROADSNC);
		elseif self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "E" and
			   theTI.deliveryReleaseReason = DEL_NIB then
			_messageTypeArray.add(INTRACON_ROADNIB);
		elseif self.getContentsStatusString(_transaction.contentsStatus).trimBlanks = "E" and
			   theTI.deliveryReleaseReason = DEL_IST then
			_messageTypeArray.add(INTRACON_ROADIST);
		else
			_messageTypeArray.add(INTRACON_ROADOUT);
		endif;
	elseif _transaction.isCamsRailReleaseType() then
		if (getContentsStatusString(_transaction.contentsStatus).trimBlanks = "F" or
			getContentsStatusString(_transaction.contentsStatus).trimBlanks = "L") and
		   theTI.isImport then
			_messageTypeArray.add(INTRACON_RAILSNC);
		elseif getContentsStatusString(_transaction.contentsStatus).trimBlanks = "E" and
			   theTI.deliveryReleaseReason = DEL_NIB then
			_messageTypeArray.add(INTRACON_RAILNIB);
		elseif getContentsStatusString(_transaction.contentsStatus).trimBlanks = "E" and
			   theTI.deliveryReleaseReason = DEL_IST then
			_messageTypeArray.add(INTRACON_RAILIST);
		elseif getContentsStatusString(_transaction.contentsStatus).trimBlanks = "E" and
			   theTI.deliveryReleaseReason = DEL_SNT then
			_messageTypeArray.add(INTRACON_RAILSNT);
		else
			_messageTypeArray.add(INTRACON_RAILOUT);
		endif;
	elseif _transaction.type = TRANS_TYPE_DAIRY or
	   _transaction.type = TRANS_TYPE_DAMAGED or
	   _transaction.type = TRANS_TYPE_HIDE or
	   _transaction.type = TRANS_TYPE_PRETRIP or
	   _transaction.type = TRANS_TYPE_REPAIR or
	   _transaction.type = TRANS_TYPE_WASH then
		_messageTypeArray.add(INTRACON_STA);
	else
		//do nothing
		//epr TFS 2387 19/7/16 more logging
		if _camAgent &lt;&gt; null then
			_camAgent.logReasonForExclusion(_transaction,"transaction not supported");
		endif;
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMessageTypeString" id="04b73e5f-36f6-4a96-9df1-d6f86aca3b28">
        <source>getMessageTypeString(_messageType: Integer): String;

vars

begin

	if _messageType = INTRACON_SHIPIN then
		return "Vessel Discharge";
	elseif _messageType = INTRACON_SHIPOUT then
		return "Vessel Load";
	elseif _messageType = INTRACON_ROADIN then
		return "Road Gate-In";
	elseif _messageType = INTRACON_ROADOUT then
		return "Road Gate-Out";
	elseif _messageType = INTRACON_RAILIN then
		return "Rail Gate-In";
	elseif _messageType = INTRACON_RAILOUT then
		return "Rail Gate-Out";
	elseif _messageType = INTRACON_SHIPRCV then
		return "Vessel Received Export";
	elseif _messageType = INTRACON_ROADRCV then
		return "Road Received Export";
	elseif _messageType = INTRACON_RAILRCV then
		return "Rail Received Export";
	elseif _messageType = INTRACON_ROADSNC then
		return "Road Send Consignee(Import)";
	elseif _messageType = INTRACON_RAILSNC then
		return "Rail Send Consignee(Import)";
	elseif _messageType = INTRACON_ROADSNT then
		return "Road Sent to Shipper";
	elseif _messageType = INTRACON_RAILSNT then
		return "Rail Sent to Shipper";
	elseif _messageType = INTRACON_ROADIST then
		return "Road Inter-Storage Transport";
	elseif _messageType = INTRACON_RAILIST then
		return "Rail Inter-Storage Transport";
	elseif _messageType = INTRACON_ROADNIB then
		return "Road National Imbalance";
	elseif _messageType = INTRACON_RAILNIB then
		return "Rail National Imbalance";
	elseif _messageType = INTRACON_STA then
		return "Status Change";
	else
		return "Unknown Intracon Message!";
	endif;
end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusCode" id="a0931077-9c1f-4da1-924f-c4977c719578">
        <source>getStatusCode(_type : Integer; _ti : CM_TrackedItem) : String;
//
// 15/12/2009	cnwdap1		CMMS MES 1007 Any tracked item can now be a reefer, not just containers
//
vars
	status : String;
begin
	if _type = TRANS_TYPE_DAIRY then
		status := "DB";
	elseif _type = TRANS_TYPE_DAMAGED then
		status := "DM";
	elseif _type = TRANS_TYPE_HIDE then
		status := "AH";
	elseif _type = TRANS_TYPE_PRETRIP then
		status := "PW";
	elseif _type = TRANS_TYPE_REPAIR then
		//if _ti.CM_Container.isReefer then		// CCMS 1007
		if _ti.isReefer then					// CCMS 1007
			status := "AW";
		else
			status := "AV";
		endif;
	elseif _type = TRANS_TYPE_WASH then
		status := "AV";
	endif;
	return status;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="9fc64db6-329d-4a49-9e65-41330715508c">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
vars
	strLoc	: String;
	code	: String;
	xlDischargePort : String;
	theTI	: CM_TrackedItem;

begin

	theTI := _transaction.myTrackedItem;

	if theTI.dischargePort &lt;&gt; null then
		//translate the dischargePort code
		code := theTI.dischargePort.trimBlanks;
	else
		code := theTI.destinationPort.trimBlanks;
	endif;
	if code &lt;&gt; null then
		xlDischargePort := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
		if xlDischargePort = "" then
			xlDischargePort := code;
		endif;
		xlDischargePort := xlDischargePort.trimRight;
	endif;
	_camMessage.group5.add("EQD+CN+" &amp; theTI.id.trimRight &amp; "+" &amp;
	theTI.getISOType &amp; ":102:5+++" &amp; self.getContentsStatusString(_transaction.contentsStatus) &amp; "'");
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	_camMessage.group5.add("DTM+7:" &amp; _transaction.dateTime.date.shortYearEDI() &amp; _transaction.dateTime.time.shortFormatEDI() &amp; ":201" &amp; "'");
	// Full Containers
	if self.getContentsStatusString(_transaction.contentsStatus) = "F"  or
	   self.getContentsStatusString(_transaction.contentsStatus) = "L" then
		if _transaction.isCamsRoadReceiveType() or
		   _transaction.isCamsPackType() then
			if theTI.bookingReference.trimRight &lt;&gt; "" then
				_camMessage.group5.add("RFF+BN:" &amp; theTI.bookingReference.trimRight &amp; "'");
			endif;
		endif;
		if _transaction.isCamsRoadReleaseType() or
		   _transaction.isCamsUnpackType() then
			_camMessage.group5.add("RFF+HLR:" &amp; theTI.releaseCarrier.trimBlanks &amp; "'");
			_camMessage.group5.add("RFF+VCL:" &amp; theTI.releaseVehicle.trimBlanks &amp; "'");
			if _camMessage.activity = INTRACON_ROADSNT then
				_camMessage.group5.add("RFF+REL:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if _camMessage.activity = INTRACON_ROADSNC then
				_camMessage.group5.add("RFF+CMR:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if xlDischargePort &lt;&gt; null then
				_camMessage.group5.add("LOC+8:" &amp; xlDischargePort &amp; "'");
			endif;
		endif;
		if _transaction.isCamsRailReceiveType() then
			if theTI.bookingReference.trimRight &lt;&gt; "" then
				_camMessage.group5.add("RFF+BN:" &amp; theTI.bookingReference.trimRight &amp; "'");
			endif;
		endif;
		if _transaction.isCamsRailReleaseType() then
			_camMessage.group5.add("RFF+HLR:" &amp; theTI.carrier.trimRight &amp; "'");
			_camMessage.group5.add("RFF+WGN:" &amp; theTI.wagon.trimRight &amp; "'");
			if _camMessage.activity = INTRACON_RAILSNT then
				_camMessage.group5.add("RFF+REL:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if _camMessage.activity = INTRACON_RAILSNC then
				_camMessage.group5.add("RFF+RCN:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if xlDischargePort &lt;&gt; null then
				_camMessage.group5.add("LOC+8:" &amp; xlDischargePort &amp; "'");
			endif;
		endif;
		_camMessage.group5.add("MEA+TI:206:" &amp; theTI.totalWeight.asStringWeightJMT() &amp; "'");
		if _transaction.isCamsShipReleaseType() then
			if theTI.myPrimaryActualLocation &lt;&gt; null then
				strLoc := theTI.myPrimaryActualLocation.getStowageId(theTI);	
			else
				strLoc := self.stripLocationId(theTI.locationId);
			endif;
			_camMessage.group5.add("RFF+CLL:" &amp; strLoc &amp; "'");
		
		endif;
	// emtpy containers
	elseif self.getContentsStatusString(_transaction.contentsStatus) = "E" then
		if _transaction.isCamsRoadReleaseType() then
			_camMessage.group5.add("RFF+HLR:" &amp; theTI.releaseCarrier.trimBlanks &amp; "'");
			_camMessage.group5.add("RFF+VCL:" &amp; theTI.releaseVehicle.trimBlanks &amp; "'");
			if theTI.deliveryRelease.trimRight &lt;&gt; "" then
				_camMessage.group5.add("RFF+REL:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if xlDischargePort &lt;&gt; null then
				_camMessage.group5.add("LOC+8:" &amp; xlDischargePort &amp; "'");
			endif;
		endif;
		if _transaction.isCamsRailReleaseType() then
			_camMessage.group5.add("RFF+HLR:" &amp; theTI.carrier.trimRight &amp; "'");
			_camMessage.group5.add("RFF+WGN:" &amp; theTI.wagon.trimRight &amp; "'");
			if theTI.deliveryRelease.trimRight &lt;&gt; "" then
				_camMessage.group5.add("RFF+REL:" &amp; theTI.deliveryRelease.trimRight &amp; "'");
			endif;
			if xlDischargePort &lt;&gt; null then
				_camMessage.group5.add("LOC+8:" &amp; xlDischargePort &amp; "'");
			endif;
		endif;
		if _transaction.isCamsShipReleaseType() then
			if theTI.myPrimaryActualLocation &lt;&gt; null then
				strLoc := theTI.myPrimaryActualLocation.getStowageId(theTI);	
			else
				strLoc := self.stripLocationId(theTI.locationId);
			endif;
			_camMessage.group5.add("RFF+CLL:" &amp; strLoc &amp; "'");
		endif;
		if _transaction.isCamsRailReceiveType() or
		   _transaction.isCamsRoadReceiveType() then
			_camMessage.group5.add("RFF+STA:AV'");
		endif;
	endif;
	if _transaction.type = TRANS_TYPE_DAIRY or
	   _transaction.type = TRANS_TYPE_DAMAGED or
	   _transaction.type = TRANS_TYPE_HIDE or
	   _transaction.type = TRANS_TYPE_PRETRIP or
	   _transaction.type = TRANS_TYPE_REPAIR or
	   _transaction.type = TRANS_TYPE_WASH then
		_camMessage.group5.add("RFF+STA:" &amp; self.getStatusCode(_transaction.type, theTI) &amp; "'");
	endif;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="054e662e-b977-48e2-a20e-f439e0c1fe47">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
// 25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// 06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
// 09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camMessage 				: CM_CamMessage;
	totalSegments 			: Integer;
	previousMessageActivity : Integer;
	previousMessageVoyage 	: CM_CamVoyage;
	unh, unb, bgm, tdt, loc	: String;
	strLine : String;
begin

	app.writeLog("===================================", LogWARN);
	
	//UNH header
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, _camAgent.endDateTime, null);
	strLine := strLine &amp; unb;
	//UNH
	unh := self.outputHeader_UNH (_camTaskHistory, _seqNumber, null);
	strLine := strLine &amp; unh;
	// BGM
	bgm := self.outputHeader_BGM (_camTaskHistory, _camAgent.endDateTime, null);
	strLine := strLine &amp; bgm;								
	if _camFile.camMessageByActivityVoyage.size &gt; 0 then
		foreach camMessage in _camFile.camMessageByActivityVoyage do						
			if previousMessageActivity &lt;&gt; camMessage.activity  or previousMessageVoyage &lt;&gt; camMessage.camVoyage    then
				//TDT header
				tdt := self.outputHeader_TDT(camMessage, _camTaskHistory, camMessage.camVoyage, _protocol, null);
				strLine := strLine &amp; tdt;
				_camFile.incrementMessageCount();
				
				//LOC1 header
				loc := self.outputHeader_LOC (_protocol, _camTaskHistory, camMessage, _terminal, null);
				strLine := strLine &amp; loc;
			endif;
			
			previousMessageActivity := camMessage.activity;
			previousMessageVoyage 	:= camMessage.camVoyage;
			
			self.updateHeaderColl (camMessage.header, unb, unh, bgm, tdt, loc);

			//now give them all of the messages
			strLine := strLine &amp; self.outputMessages (camMessage, _camTaskHistory);
			
			totalSegments := totalSegments + camMessage.segmentCount;
		endforeach;
	endif;
	
	// UNT segement for file
	strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, (totalSegments + 3), _seqNumber, null);
	
	// UNZ
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, 1, _seqNumber, null);
	
	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="6a84b3fa-ca78-465e-9bbd-f2ee9ce7c835">
        <updating/>
        <source>outputHeader_LOC(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _terminal :CM_Terminal; _coll :HugeStringArray input) : String updating, protected;
/* 
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
*/
vars
	site, result :String;
begin
	site := _protocol.camGroup.senderCode.trimBlanks;

	if site = null then
		site := _terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;

	result := self.outputFileMessage(_camTaskHistory, "LOC+90:" &amp; site &amp; ":160:143'", _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;

	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="a44e0986-bde2-4949-b7a1-c3fdaaed7557">
        <updating/>
        <source>outputHeader_TDT(camMessage: CM_CamMessage input; camTaskHistory: CM_CamTaskHistory input; camVoyage: CM_CamVoyage; 
				camProtocol : CM_CamProtocol; _coll :HugeStringArray input) : String updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage/_camTaskHistory parameter usage from io to input
// 20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	voyageCode 			: String;
	vesselCode 			: String;
	vesselLloydsNumber 	: String;
	result				: String;
begin
	voyageCode := camVoyage.getSanitisedVoyageCode();

	if camVoyage.voyageOid &lt;&gt; null and camVoyage.voyageOid.vesselCode &lt;&gt; null then
		vesselCode 			:= camVoyage.voyageOid.vesselCode.trimBlanks;
		vesselLloydsNumber 	:= camVoyage.voyageOid.lloydsNumber;
	endif;

	if camMessage.activity = INTRACON_STA then
		result := self.outputFileMessage(camTaskHistory, "TDT+STA+++++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_SHIPIN then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "+1+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILIN then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "+8+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADIN then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "+10+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_SHIPOUT then
		result := self.outputFileMessage(camTaskHistory, "TDT+DEP+" &amp; voyageCode &amp; "+1+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILOUT then
		result := self.outputFileMessage(camTaskHistory, "TDT+DEP+" &amp; voyageCode &amp; "+8+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADOUT then
		result := self.outputFileMessage(camTaskHistory, "TDT+DEP+" &amp; voyageCode &amp; "+10+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_SHIPRCV then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "W" &amp; "+1+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
	
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILRCV then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "W" &amp; "+8+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADRCV then
		result := self.outputFileMessage(camTaskHistory, "TDT+ARR+" &amp; voyageCode &amp; "W" &amp; "+10+" &amp; vesselLloydsNumber &amp; "++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILSNC then
		result := self.outputFileMessage(camTaskHistory, "TDT+DEP+" &amp; voyageCode &amp; "E" &amp; "+8+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADSNC then
		result := self.outputFileMessage(camTaskHistory, "TDT+DEP+" &amp; voyageCode &amp; "E" &amp; "+10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADSNT then
		result := self.outputFileMessage(camTaskHistory, "TDT+SNT+" &amp; voyageCode &amp; "+10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILSNT then
		result := self.outputFileMessage(camTaskHistory, "TDT+SNT+" &amp; voyageCode &amp; "+8+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADSNT then
		result := self.outputFileMessage(camTaskHistory, "TDT+SNT+" &amp; voyageCode &amp; "+10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILIST then
		result := self.outputFileMessage(camTaskHistory, "TDT+IST++8+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADIST then
		result := self.outputFileMessage(camTaskHistory, "TDT+IST++10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_RAILNIB then
		result := self.outputFileMessage(camTaskHistory, "TDT+NIB++8+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	elseif camMessage.activity = INTRACON_ROADNIB then
		result := self.outputFileMessage(camTaskHistory, "TDT+NIB++10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
		
	else
		result := outputFileMessage(camTaskHistory, "TDT+AAA+" &amp; voyageCode &amp; "+10+++" &amp; camProtocol.camGroup.recipient &amp; "+REP'", _coll);
		
		camMessage.segmentCount := camMessage.segmentCount + 1;
	endif;
	
	return result;
end;</source>
        <Parameter name="camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="camVoyage" type="CM_CamVoyage"/>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="6f2dd5b0-7a86-477d-b231-8c790d361e17">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; 
					_ts :TimeStamp; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
*/
vars
	site :String;
begin
	site := _protocol.camGroup.senderCode.trimBlanks;
	
	if site = null then
		site := _protocol.terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	return self.outputFileMessage(_camTaskHistory, 
									"UNB+UNOA:2+" &amp; site &amp; "+" &amp;
									_protocol.camGroup.recipient.trimBlanks &amp; "+" &amp;
									_ts.date.shortYearEDI() &amp; ":" &amp; _ts.time.shortFormatEDI() &amp; "+" &amp;
									_seqNumber.String &amp;
									"++SNECS'",
									null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="5ec0e296-f8e7-483a-8c33-3d9c2c85c7ff">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage : CM_CamMessage;
	voyageOid : CM_Voyage;
	xlVoyage : String;
	messageTypeArray : IntegerArray;
	messageType : Integer;
	theTI : CM_TrackedItem;
	term : CM_Terminal;
	vesselName : String; //par18987 cnwrs1 Mar 2009
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	term := _camProtocol.terminal;
	theTI := _transaction.myTrackedItem;
	voyageOid := theTI.myVoyage;
	create messageTypeArray transient;

	if theTI.isRehandle or theTI.isSOB then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for a rehandle or SOB and they are not set to be included.");
		endif;
		return;
	endif;

	self.getMessageType(_transaction, messageTypeArray, _camProtocol, _camAgent);
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			camMessage := self.setCamMessage(messageType, _camProtocol, _camFile, _transaction, xlVoyage, vesselName, voyageOid, term);

			if camMessage &lt;&gt; null then
				if camMessage.camVoyage.voyageOid = null and
				   voyageOid &lt;&gt; null then
					camMessage.camVoyage.voyageOid := voyageOid; //theTI.voyage;
					camMessage.camVoyage.vesselName := vesselName; //par18987 cnwrs1 Mar 2009
				endif;

				camMessage.tiId := theTI.id.trimRight;
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyage, _camProtocol.terminal, null);
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCamMessage" id="b9bedd2d-d7b0-4f81-9156-28000d2e4a1d">
        <updating/>
        <source>setCamMessage(_messageType:Integer; _camProtocol: CM_CamProtocol; _camFile: CM_CamFile input; _transaction: CM_TITransaction;
			 _voyageCode, _vesselName: String output; _voyageOid: CM_Voyage output; _terminal : CM_Terminal): CM_CamMessage updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
vars
	camMessage : CM_CamMessage;
	fCode : String;
	theTI : CM_TrackedItem;
begin

	theTI := _transaction.myTrackedItem;

	//get the voyage code
	_voyageOid := null;
	if _messageType = INTRACON_STA then
		_voyageCode := "ZZZZZZZZ";
		_voyageOid := null;
	elseif _messageType = INTRACON_RAILNIB or
		   _messageType = INTRACON_ROADNIB then
		_voyageCode := "ZZZZZZZH";
		_voyageOid := null;
	elseif _messageType = INTRACON_RAILIST or
		   _messageType = INTRACON_ROADIST then
		_voyageCode := "ZZZZZZZO";
		_voyageOid := null;
	elseif _messageType = INTRACON_RAILSNT or
		   _messageType = INTRACON_ROADSNT then
		_voyageCode := theTI.consignorVoyageCode;
		_voyageOid := _terminal.lookupVoyage(_voyageCode, null, false);
	elseif _messageType = INTRACON_RAILSNC or
		   _messageType = INTRACON_ROADSNC then
		_voyageCode := "";
		_voyageOid := null;
		if theTI.voyageCode &lt;&gt; "" then
			_voyageOid := _terminal.lookupVoyage(theTI.voyageCode, null, false);
			if _voyageOid &lt;&gt; null then
				if _voyageOid.inwardCode &lt;&gt; "" then
					_voyageCode := _voyageOid.inwardCode;
					_voyageOid := _terminal.lookupVoyage(_voyageCode, null, false);
				endif;
			endif;
		endif;
	else
		fCode := theTI.voyageCode.trimRight;
		_voyageOid := theTI.myVoyage;
		//translate the voyage Code
		if fCode = "HOLD" then
			_voyageCode := fCode;
		elseif fCode = NULL_VOYAGE_CODE then
			_voyageCode := null;
		else
			_voyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, fCode, XLATION_TYPE_VOYAGETERMINAL, _terminal);
		endif;
	endif;
	if _voyageOid &lt;&gt; null then
		_vesselName := _voyageOid.vesselName; //par18987 cnwrs1 Mar 2009
	endif;

// setup the cam message for this transaction
	camMessage := self.getCamMessageById(_camFile, _voyageCode, _vesselName, _messageType, theTI.id); //par18987 cnwrs1 Mar 2009
	return camMessage;
end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
        <Parameter name="_vesselName" type="String" usage="output"/>
        <Parameter name="_voyageOid" type="CM_Voyage" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
</Class>
