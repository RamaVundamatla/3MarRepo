        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbImExStatus_click(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2009	cnwas3	Initial creation
20/05/2010	cnwdap1	CCMS 1116 Tranship changes
*/
vars
	editTable	: CM_EntryTable;
begin
	editTable := self.getTableForRow(ETRow_MyTranshipToPort);
	if combobox.listObject &lt;&gt; null and 
	   combobox.listObject.CM_IMEXStatus.code.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_TRANSHIP) and 
	   self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then	// PAR #23645 CCMS 1116
	   if editTable &lt;&gt; null then
			editTable.showRowByName(ETRow_MyTranshipToPort, false);
		endif;
		self.tblData.showColumnByColName(ETRow_MyTranshipToPort);
	else
		if editTable &lt;&gt; null then
			editTable.hideRowByName(ETRow_MyTranshipToPort, false);
		endif;
		self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
