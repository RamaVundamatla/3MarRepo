    <JadeMethod name="getMenuUserDtl" id="3e1f0877-55de-4f74-8c17-96de082fc592">
        <source>getMenuUserDtl(_userTerminal : CM_UserTerminal) : CM_MenuUserItem;
// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ut			: CM_UserTerminal;
	userDtl		: CM_MenuUserItem;
	menuRoot	: CM_MenuRoot;
begin
	
	if _userTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User terminal object was null');
		return null;
	endif;
	
	
	foreach	userDtl in self.allMenuUserItems do
		menuRoot := userDtl.getMyMenuRoot();
		if menuRoot = null then
			continue;
		endif;
		
		if menuRoot.isKindOf(CM_MenuRootUserTerminal) then
			if menuRoot.CM_MenuRootUserTerminal.myUserTerminal = _userTerminal then
				return userDtl;
			endif;
		endif;
		
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_userTerminal" type="CM_UserTerminal"/>
        <ReturnType type="CM_MenuUserItem"/>
    </JadeMethod>
    <JadeMethod name="getMenuUserDtlSystem" id="17851104-bfbd-4bc8-80d5-570932e9c26b">
        <source>getMenuUserDtlSystem(_user : CM_User): CM_MenuUserItem;
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     Get the user menu item for a system menu item 
//			 
// ----------   ----------  --------------------------------------------------
vars
	ut			: CM_UserTerminal;
	userDtl		: CM_MenuUserItem;
	menuRoot	: CM_MenuRoot;
	
begin
	foreach	userDtl in self.allMenuUserItems do
		menuRoot := userDtl.getMyMenuRoot();
		if menuRoot = null then
			continue;
		endif;
		
		if menuRoot.isKindOf(CM_MenuRootForUser) then
			if menuRoot.CM_MenuRootForUser.myUser = _user then
				return userDtl;
			endif;
		endif;
	endforeach;		

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="CM_MenuUserItem"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ca78aa2a-c62c-438e-907f-640c1d137bb4">
        <updating/>
        <source>setForUpdate(_proxy : SelfType) updating;

vars

begin
	self.isSystemDtl		:= _proxy.isSystemDtl;
	self.attr1				:= _proxy.attr1;
	self.classNameToCreate	:= _proxy.classNameToCreate;
	_proxy.parameterAttribute.copy(self.parameterAttribute);
	_proxy.parameterValue.copy(self.parameterValue);
	self.param1				:= _proxy.param1;
	self.schemaName			:= _proxy.schemaName;
	self.windowClassName	:= _proxy.windowClassName;
	self.menuId					:= _proxy.menuId;
	
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="0154ba8a-23da-4a0f-b8fa-9b1c3f31f033">
        <updating/>
        <source>setFromXML(_str : String; _root : CM_MenuRoot; _constValue : Integer; _childValues : IntegerArray; _systemOnly : Boolean; _passedInMenuId : String) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpValue	: Integer;

begin
/*
&lt;MenuDtl&gt;
&lt;Heading&gt;Pre-Notes&lt;/Heading&gt;
&lt;ActionClass&gt;CMUI_MenuAction&lt;/ActionClass&gt;
&lt;Id&gt;GTE123&lt;/Id&gt;
&lt;SchemaName&gt;GateSchema&lt;/SchemaName&gt;
&lt;WindowClass&gt;GTE_PreNoteForm&lt;/WindowClass&gt;
&lt;/MenuDtl&gt;
*/
	
	self.isSystemDtl := _systemOnly;

	if _childValues &lt;&gt; null and (not _childValues.isEmpty) then
		//self.childValue			:= _childValues.first;
		//if self.childValue &gt; 0 then
		//	self.childValue := self.childValue + PmAdmBaseView;
		//endif;
		self.allChildValues.clear();
		_childValues.copy(self.allChildValues);
//		foreach tmpValue in _childValues do
//			self.allChildValues.add(tmpValue + PmAdmBaseView);
//		endforeach;
	else
		self.allChildValues.clear();
		//self.childValue := 0;
	endif;
	
	self.attr1				:= _str.cnEcGetTagValueOfName(XMLTag_Attr1);
	self.classNameToCreate	:= _str.cnEcGetTagValueOfName(XMLTag_ActionClass);
	self.extraTableDef		:= _str.cnEcGetTagValueOfName(XMLTag_ExtraTableDef);
	self.mainTableDef		:= _str.cnEcGetTagValueOfName(XMLTag_MainTableDef);
	self.param1				:= _str.cnEcGetTagValueOfName(XMLTag_Param1);
	self.schemaName			:= _str.cnEcGetTagValueOfName(XMLTag_SchemaName);
	self.windowClassName	:= _str.cnEcGetTagValueOfName(XMLTag_WindowClass);
	
	inheritMethod(_str, _root, _constValue, _childValues, _systemOnly, _passedInMenuId);

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_childValues" type="IntegerArray"/>
        <Parameter name="_systemOnly" type="Boolean"/>
        <Parameter name="_passedInMenuId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyMenuDtl" id="5d873fd6-385b-41f9-83af-85e5ef46516e">
        <updating/>
        <source>setProxyMenuDtl(_heading, _menuId, _classNameToCreate, 
		_pictureButton, _pictureButtonDown, _pictureIcon,
		_schemaName, _windowClassName : String;
		_constValue : Integer;
		_isSystemDetail : Boolean) updating;

vars

begin
	self.isSystemDtl		:= _isSystemDetail;
	self.classNameToCreate	:= _classNameToCreate;
	self.constantValue		:= _constValue;
	self.schemaName			:= _schemaName;
	self.windowClassName	:= _windowClassName;

	self.setProxyMenuItem(_constValue, _menuId, _heading, _pictureButton,_pictureButtonDown, _pictureIcon);
	
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_menuId" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_windowClassName" type="String"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_isSystemDetail" type="Boolean"/>
    </JadeMethod>
</Class>
