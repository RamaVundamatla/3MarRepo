epilog
	delete wleArray;
	delete wlesWithWarnings;
end;
</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="updateAutoSchedule" id="ba6f8b1d-df59-4408-828a-66a60ddca72c">
        <source>updateAutoSchedule(_autoSchedule : CM_AutoSchedule);
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#	Description
============================================================================
14/04/2014	cnwma1			Initial creation
16/04/2019	jlgka1	43863	Added Recurring value.
============================================================================*/
vars
	pxyAutoSchedule : CM_AutoSchedule;
	runTS			: Time;
begin

	runTS := "11:30".Time;
	beginLoad;
	pxyAutoSchedule := _autoSchedule.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoSchedule.setForDate(_autoSchedule.description,
							  "21",
							  runTS,
							  _autoSchedule.recurValue); // jlgka1 TFS 43863
	app.myTrxUA.trxUpdateAutoSchedule(pxyAutoSchedule,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyAutoSchedule;
end;</source>
        <Parameter name="_autoSchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="updateAvailabilityGrade" id="69b7fdd5-326c-4f92-a4e8-02539f0342c8">
        <source>updateAvailabilityGrade(_availabilityGrade : CM_MTGrade);
/*

Purpose:	Update AvailabilityGrade		

Date		Who		Reason
27/02/2014	cnwma1	Initial creation

*/

vars
	pxyAvailabilityGrade  :CM_MTGrade;
	terminalSet			  : CM_TerminalSet;
	selectedSubTerminal   : CM_SubTerminalByCodeDict;
	availDesc		 	  : String;
	

begin

	
	beginLoad;
	pxyAvailabilityGrade := _availabilityGrade.pxyCreateUpdateProxy();
	endLoad;
	
	availDesc := _availabilityGrade.description.asStringJMT();
	
	if self.opts.includesKey("availDesc") then
		availDesc := self.opts.str("availDesc");

	endif;
	
	

	pxyAvailabilityGrade.setProxy(_availabilityGrade.code,
								  availDesc,
								  true,
								  true,
								  Green,
								  null,
								  null );
								  
	app.myTrxUA.trxUpdateAvailabilityGrade(pxyAvailabilityGrade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();							  
									

epilog
