    </JadeMethod>
    <JadeMethod name="initializeTables" id="001cbdb3-8e11-48b4-811d-5d9d05d581a1">
        <updating/>
        <source>initializeTables() protected, updating;
//15 August 2008	cnwdw1	
//epr par 26189 only update tables if visible
//02/12/2016	cnwma1	TFS #3012:PAR38429 QNS - Slow performance on Satellite
vars

begin
	if self.tblYAM.visible then
		self.tblYAM.setForm(self);
		self.IF_CMUI_Progress.updateProgress("Loading YAM table data..",0,0);
		self.tblYAM.initialise(false, self.fraPictures, self.pic1, self.pic2, self.pic3);
	endif;
	
	if self.tblLocnStats.visible then
		self.tblLocnStats.setForm(self);
		self.IF_CMUI_Progress.updateProgress("Loading Location Stats table data..",0,0);
		self.tblLocnStats.initialise(self.allTerminalAreas, self.fraPictures, self.pic1, self.pic2, self.pic3);
	endif;
	if self.dkbCargoPic.visible then
		self.tblFailAutoPlan.setForm(self);
		self.IF_CMUI_Progress.updateProgress("Loading Failed 'Cargo' to Plan table data..",0,0);
		//self.tblFailAutoPlan.initialise();   //cnwma1 02/1/2016 TFS #3012
		//10 Jan 2012	NDL	Par 28953
		self.tblFailRequest.setForm(self);
		self.IF_CMUI_Progress.updateProgress("Loading Failed 'Request' to Plan table data..",0,0);
		//self.tblFailRequest.initialise();    //cnwma1 02/1/2016 TFS #3012
	endif;
	self.showSearchParameters();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="61a41d6c-8545-47e0-a0ff-4be06d5e2b85">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
09 September 2008	consw1	Initial creation

*/

vars

begin
	if keyCode = CMUI_Key_F3 then
		self.doShowSearch( true );
		return;
	endif;
		
	// TFS 49959 JLGAB1 
	if keyCode = J_key_C 
	and shift.isShiftKeyPressed() // SHIFT
	and shift.isControlKeyPressed() then // CONTROL
		self.doMnuCapacityClick();
	endif;
		
	inheritMethod(keyCode, shift);

epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="77834e4d-c32e-45b3-8b3e-c5e87312535a">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars
	regKeys : IntegerArray;
	taView : CM_TerminalAreaView;
begin

	self.dkbMacro.visible := true;
	self.dkbCargoPic.visible := true;
	self.dkbGridArea.isForOverview := true;
	
	//epr par 33594 24/3/15
	self.doHideShowYAM();
	self.doHideShowFailToPlan();
	
	self.tblYAM.rows:=0;
	self.tblYAM.columns:=0;
	
	self.positionScaleX := 10;
	self.positionScaleY := 10;
	
	self.isSelectorCapable := true;
	self.btnViewYardAlloc.value := true;

	self.defYardBackColUnselected := self.myTerminal.getConfig(DefYardBackColUnselected).Integer;
	self.defYardBackColSelected := self.myTerminal.getConfig(SatelliteViewBackColour).Integer;
	
	taView := self.getFirstAvailTAV();										// 14/09/2012 cnwmh5 #30333
	
	if taView &lt;&gt; null and taView.myTerminal=self.myTerminal then
		self.setMyTerminalAreaView(taView);
	else
		self.setMyTerminalAreaView(self.myTerminal.allTerminalAreaViews.first);
	endif;
	
	self.tblYAM.visible				:=	true;
	self.tblFailAutoPlan.visible:=true;
	self.tblFailRequest.visible:=true;	//11 Jan 2012	NDL	Par 28953
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	self.initializeDrawing();
	
	self.drawTerminalAreaView();
	self.allTerminalAreas.clear;
	self.myCurrentDrawingController.allTerminalAreas.copy(self.allTerminalAreas);
	
	self.initializeTables();
	
	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_Delete);
	self.addRegisteredKeys(regKeys);

	self.dkbCargoPic.ignoreSkin := true;
	self.dkbCargoPic.backColor := White;
	self.picCargo.ignoreSkin := true;
	
epilog

	app.mousePointer := Window.MousePointer_Default;
	delete regKeys;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuAllReport1_click" id="ee935238-0d18-47da-b676-4f13f9eebec2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAllReport1_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	termAreaObj : Object;
	termArea : CM_TerminalArea;
	cm_ObjectArray	: CM_ObjectArray;
	
begin
	
	create cm_ObjectArray transient;
	
	foreach termAreaObj in self.allTerminalAreas discreteLock do
	
		termArea := termAreaObj.CM_TerminalArea;
		self.findCargoFromObject( termArea, cm_ObjectArray );
	
	endforeach;
	
	self.myAssistant.sendItemsToReport( cm_ObjectArray );
		
epilog

	delete cm_ObjectArray;

end;</source>
