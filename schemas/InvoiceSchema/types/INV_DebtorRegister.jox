    <JadeMethod name="addToolbarControls" id="6a5a4e34-b5e3-4e98-b959-1df0a2e8d10c">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
//	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnPrintList, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);  //MES 1010 JMN
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myCurrentUserCan(self.myTerminal, PmAdmDebtorgroupView) then
		frm.addButton(self.btnNewGroup, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	frm.addButton(self.btnProperties, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnInvoices, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnInvoiceItems, CMUI_Toolbar.Control_Alignment_Left);
	//08 Aug 2012	NDL	Par 29968
	if app.isCashOnlyEnabled then
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnCashTrans, CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnCashBals, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// ### TFS 51912 20Sep2021 NAVPW1
	frm.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);			// ### TFS 51912 20Sep2021 NAVPW1
	frm.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);	// ### TFS 51912 20Sep2021 NAVPW1
	
	frm.positionToolbarControls();
	frm.visible := true;

	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

	frm := self.frmSeachToolbar;
	frm.addButton(self.btnSearchSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//17 Jul 2018	NDL	TFS 39254
	frm.addFrame(self.frmPartial, CMUI_Toolbar.Control_Alignment_Left);	//17 Jul 2018	NDL	TFS 39254
	frm.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
