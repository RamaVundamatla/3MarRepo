begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_SiteState);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	_siteArray.clear();
	
	if str.length &gt; 0 then
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
