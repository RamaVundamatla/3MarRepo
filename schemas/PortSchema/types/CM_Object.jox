    <JadeMethod name="getXMLString" id="82a0680b-2c03-4156-9938-8747f42c2ae8">
        <source>getXMLString() : String;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property:Property;
	popColl:PropertyNDict;
	object: Object;
	str,message: String;
begin
	create popColl transient;
	self.class.getPropertiesAllSuperclass(popColl);
	message := "&lt;"&amp;self.class.name&amp;"&gt;";
	message := message&amp;"&lt;oid="&amp;self.getOidString&amp;"/&gt;";
	foreach property in popColl do
		if (not property.isKindOf(Attribute)) or
		   (not self.shouldAuditProperty(self.class, property)) or
		   (property.virtual) then
			continue;
		endif;
		
		if property.type = StringArray or
		   property.type = IntegerArray or
		   property.type = BinaryArray or
		   property.type = BooleanArray then
		elseif property.type = String then
			message := message&amp;("&lt;"&amp;property.getName&amp;"='"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"'&gt;");
		elseif (property.type = Date or
		        property.type = Time or
		        property.type = TimeStamp) and 
		       self.getPropertyValue(property.name) = null then
			message := message&amp;("&lt;"&amp;property.getName&amp;"=&gt;");
		else
			message := message&amp;("&lt;"&amp;property.getName&amp;"="&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&gt;");
		endif;	
	endforeach;
	message := message&amp;("&lt;/"&amp;self.class.name&amp;"&gt;");
	return message;
epilog
	delete popColl;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleUnknownPropertyValue" id="eb7a16f1-d817-4858-a0c2-3ce8b36fcdc4">
        <source>handleUnknownPropertyValue(_exc : Exception; _attr : String; _obj : Object) : Integer;

// ---------------------------------------------------------------------------
// Created:     22 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

//Date			Who		Reason
//13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
//15 Nov 2023	navma	ChangeRequest 61117: MTN - Add JMTTestEnvironment Initialisation Flag

constants
	InvalPropertyValue	= 1011;
vars
	returnVal		: Integer;
	aForm 			: Form;
	msg				: String;
begin
	returnVal   := Ex_Pass_Back;
	aForm 		:= app.activeForm;
	
	//18 May 2018	NDL	TFS 38746 //06 Dec 2016	NDL	TFS 3008 / 2638
	if aForm &lt;&gt; null and ( aForm.name = "MOB_HHCargoFind" or aForm.name = "MOB_HHCargoEnquiryForm" 	or aForm.name = "MOB_HandHeldMenuForm") then	
		returnVal := Ex_Pass_Back;
	
	elseif aForm &lt;&gt; null and  aForm.name = 'CMUI_Picker' and aForm.getPropertyValue('hideEntTableException').Boolean then //cnwrd1 par 33096 
		returnVal := Ex_Resume_Next;
	
	else
		if app.name = "JMTDataExtract" then
			if _exc.errorCode = InvalPropertyValue then
				if _exc.resumable then
					returnVal := Ex_Resume_Next;
				endif;
			endif;
		else
			if _exc.errorCode = InvalPropertyValue then
				if not process.isInTransactionState and not process.isInLoadState then
					msg := "Invalid property value '" &amp; _attr &amp; "', does not exist for class " &amp; _obj.String;   //15.11.2023 navma1 #61117
					
					executeWhen JMTDevelopmentEnvironment;														//15.11.2023 navma1 #61117
						app.msgBox(msg, "Invalid Property", MsgBox_Exclamation_Mark_Icon);
					endExecuteWhen;
					
					executeWhen JMTTestEnvironment;																//15.11.2023 navma1 #61117
						app.msgBox(msg, "Invalid Property", MsgBox_Exclamation_Mark_Icon);
					endExecuteWhen;
				endif;
				
				if _exc.resumable then
					returnVal := Ex_Resume_Next;
				endif;
			endif;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
