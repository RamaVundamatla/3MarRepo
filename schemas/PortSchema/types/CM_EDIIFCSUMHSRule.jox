    <JadeMethod name="validate" id="cbb2b791-0cfe-414f-8308-c5fd67654895">
        <source>validate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars
	cargo : CM_CargoType;
begin
	
	if self.cargoType = null then
		app.raiseCMException(Input_required_field_cargoType, null, null);
	else
		cargo := app.myRoot.allCargoTypesById[self.cargoType];
		if cargo = null then
			app.raiseCMException1(Cargo_Type_Invalid, cargoType.asStringJMT, null, null);
		endif;
	endif;
	if self.cargoSubType = null and self.cargoType &lt;&gt; null and cargo.isSubCargoTypeRequired then
		app.raiseCMException(Cargo_subtype_not_selected, null, null);
	endif;
	if self.hsCode = null then
		app.raiseCMException(EDI_HSCode_Mandatory, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="395e87bc-a6f1-4d6a-9144-c69516257874">
