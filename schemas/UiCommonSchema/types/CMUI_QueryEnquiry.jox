    <JadeMethod name="btnPopupEnq_click" id="d54dc397-154c-40b9-a72d-2679f0c37b63">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPopupEnq_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTI : CM_TrackedItem;
	theObject : Object;
begin
	theObject := self.frmPopupInfo.userObject;
	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;


end;</source>
