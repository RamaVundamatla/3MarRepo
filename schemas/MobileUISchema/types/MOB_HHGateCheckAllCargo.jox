    <JadeMethod name="setupControls" id="f769420f-9279-4bd6-9501-9ee87dbd34a2">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	size : Integer;

	recReqInfo : CM_ReceivalRequestInfo;
	infoSet : CM_ReceivalRequestInfoSet;
	cargoTypeString : String;
	
	qty : Integer;
	qtyAdvised : Integer;
	qtyUnloaded : Integer;
	buttonHeight : Integer;
	cHeight : Real;
	cTop : Real;

begin

	self.setResizeableMarginAndFontSize();
	buttonHeight := self.getScrollingButtonHeight();
	
	cTop := self.resizedMargin;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	
	self.frmCargo.move(	self.resizedMargin,
						cTop,
						self.clientWidth,
						cHeight
						);
						
	self.lblNoCargo.move(	self.resizedMargin,
							self.resizedMargin,
							self.frmCargo.width - self.resizedMargin - self.resizedMargin,
							buttonHeight - self.resizedMargin - self.resizedMargin
							);
	self.lblNoCargo.visible := false;

	tiArray := self.myMobileGenericAgent.allTruckTis;
	size := tiArray.size;
	
	create infoSet transient;
	self.myMobileGenericAgent.getAllReceivalRequestInfos( infoSet );

	size := size + infoSet.size;

	buttonWidth := getButtonWidthSetScrollBar( self.numButtons, self.frmCargo, buttonHeight, self.scrCargo );
	
	if size = 0 then
		lblNoCargo.visible := true;
	else
		lblNoCargo.visible := false;
	endif;

	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnMenuTemplate.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if self.myMobileGenericAgent.tiIsConfirmed(ti) then
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")"
							&amp; CrLf &amp; app.getErrorString(Confirmed);
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"
							&amp; CrLf &amp; app.getErrorString(Confirmed);
			else
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; app.getErrorString(Confirmed);
			endif;
		
		else
			// flip flop add the id - 24 Mar 2010	NDL	Par 23316
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")"
							&amp; CrLf &amp; app.getErrorString(Not_Confirmed);
			elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"
							&amp; CrLf &amp; app.getErrorString(Not_Confirmed);
			else
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; app.getErrorString(Not_Confirmed);
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	foreach recReqInfo in infoSet do
	
		//24 Mar 2010	NDL	Par 23316
		if self.myMobileGenericAgent.inward then
			qty := recReqInfo.quantity;

		else
			qtyAdvised := recReqInfo.quantity;
		//	qtyUnloaded := recReqInfo.allTrackedItems.size;
			qtyUnloaded := recReqInfo.getTotalQuantityUnloaded;	//07 Mar 2014	NDL	Par 33554
			if qtyUnloaded &gt;= qtyAdvised then
				continue;
			endif;
			qty := qtyAdvised - qtyUnloaded;
			
		endif;
		// end of 23316
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnMenuTemplate.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := recReqInfo;
		if recReqInfo.myCargoType = null then
			cargoTypeString := app.getErrorString(Undeclared_cargo_type);
		else
			cargoTypeString := recReqInfo.myCargoType.description;
		endif;
		
		//menuButton.caption := app.getErrorString(CMQF_GeneralCargo) &amp; " - " &amp; recReqInfo.quantity.String &amp; " x " &amp; cargoTypeString;
		//24 Mar 2010	NDL	Par 23316
		if self.myMobileGenericAgent.inward then
			menuButton.caption := app.getErrorString(CMQF_GeneralCargo) &amp; " - " &amp; qty.String &amp; " x " &amp; cargoTypeString;
		else
			menuButton.caption := app.getErrorString(CMQF_GeneralCargo) &amp; " - " &amp; qty.String &amp; " x " &amp; cargoTypeString &amp; CrLf
									&amp; "( x " &amp; qtyUnloaded.String &amp; " " &amp; app.getErrorString(Unloaded) &amp; " )";
		endif;
		// end of 23316
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		menuButton.enabled := false;
	endforeach;
	
	self.btnMenuTemplate.visible := false;
	self.frmCargo.caption := null;
	
	if self.myMobileGenericAgent.cargoIsAllConfirmed then
		self.btnOne.enabled := true;
	endif;
	
	self.numButtons := buttonNumber;
	
epilog

	delete infoSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f3245eeb-d03a-43fa-b26d-ca3c65ec0f49">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	truck : CM_Vehicle;
	
begin


	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	truck := self.myMobileGenericAgent.myTruck;

	self.caption := self.caption &amp; " " &amp; truck.getDisplayDetails(true);

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	self.btnOne.enabled := false;
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c8585cb0-177c-4763-8d46-a003ea212f6f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013944, locale);
	btnMenuTemplate.translateCaption(Xlat_0013945, locale);
	frmCargo.translateCaption(Xlat_0013946, locale);
	lblNoCargo.translateCaption(Xlat_0014237, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
