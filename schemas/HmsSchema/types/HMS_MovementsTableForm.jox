    <JadeMethod name="keyDown" id="41d4878e-3082-49c5-889a-aaf3eb28da35">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

constants
	Esc_Key = 27;
vars

begin
 	if keyCode = Esc_Key then
 		self.unloadForm;
 	else
 		inheritMethod(keyCode, shift);
 	endif;	
end;</source>
