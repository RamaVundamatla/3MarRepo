    <JadeMethod name="tStatsAgentCalcTotals45s" id="ddaa2888-3f5c-4a55-9505-ae70261634ba">
        <source>tStatsAgentCalcTotals45s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
begin
	create statsAgent transient;
	create locations transient;
	
	///// 45 footers
	
	// No locations
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 0);
	
	
	// 1 row * 7 columns * 2 high
	numColumns := 7;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();
	
		
	// 2 rows * 7 columns * 2 high
	numColumns := 7;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();

	// 6 rows * 1 columns * 6 high
	numColumns := 1;
	numRows := 6;
	height := 6;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 0);
	locations.clear();

	// 2 rows * 7 columns * 2 high, with one LC restricted in height
	numColumns := 7;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	commitTransaction;
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 11);
	locations.clear();

	// 2 rows * 7 columns * 3 high, with two LC restricted otdifferent heights 
	// Note that the height restriction to location 5 spans over two container spaces, which
	// accounts for the resulting total
	numColumns := 7;
	numRows := 2;
	height := 3;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	// This LC can only go 1 high
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	// This LC can only go 2 high
	stradStack.allGridControllersByRowColumn[2, 5].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;	
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 14);
	locations.clear();
	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotals53s" id="d95f122d-2b1b-44a5-a06a-d0d9d17f78ea">
        <source>tStatsAgentCalcTotals53s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
begin
	create statsAgent transient;
	create locations transient;
	
	///// 53 footers
	
	// No locations
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 0);
	
	
	// 1 row * 8 columns * 2 high
	numColumns := 8;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();
	
	// 2 rows * 8 columns * 2 high
	numColumns := 8;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();

	// 6 rows * 1 columns * 6 high
	numColumns := 1;
	numRows := 6;
	height := 6;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 0);
	locations.clear();

	
	// 2 rows * 8 columns * 2 high, with one LC restricted in height
	numColumns := 8;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	commitTransaction;
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 11);
	locations.clear();
	
	// 1 rows * 8 columns * 3 high, with two LC restricted otdifferent heights 
	numColumns := 8;
	numRows := 1;
	height := 3;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	// This LC can only go 1 high
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	// This LC can only go 2 high
	stradStack.allGridControllersByRowColumn[1, 8].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;	
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();


	// 1 rows * 8 columns * 3 high, with two LC restricted otdifferent heights 
	// NOTE - The height restriction to column 6 affects a location which is shared by two
	// containers, which is why the result of this test is one less than the result
	// of the previous test
	numColumns := 8;
	numRows := 1;
	height := 3;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	// This LC can only go 1 high
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	// This LC can only go 2 high
	stradStack.allGridControllersByRowColumn[1, 6].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;	
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 5);
	locations.clear();

		
	// 2 rows * 8 columns * 3 high, with two LC restricted otdifferent heights 
	numColumns := 8;
	numRows := 2;
	height := 3;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	// This LC can only go 1 high
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	// This LC can only go 2 high
	stradStack.allGridControllersByRowColumn[2, 8].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;	
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 15);
	locations.clear();
	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotalsStrict20s" id="0b049de6-0296-495d-a615-f6bbdee8411c">
        <source>tStatsAgentCalcTotalsStrict20s();
// cnwer1
// cnwjk3
/*

Purpose: Tests for calculating totals for 20's when different strict grids are in place. 

The basic rule is, a container should only ever span one strict grid. For example, if it starts on a grid marked as 53', then any other
LCs it spans must all be 53' 		

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
begin
	create statsAgent transient;
	create locations transient;
		
	// 1 row * 6 columns * 2 high
	// |30|30|30|30|30|30|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs30ft(true);
			commitTransaction;	
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();


	// 1 row * 6 columns * 2 high
	// |  |30|30|30|30|20|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs30ft(true);
			commitTransaction;	
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].setIs30ft(false);
	commitTransaction;	

	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();
	
	// 1 row * 6 columns * 2 high
	// |20|53|53|53|53|53|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs53ft(true);
			commitTransaction;	
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].setIs53ft(false);
	stradStack.allGridControllersByRowColumn[1, 1].setIs20ft(true);
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();
	

	// 1 row * 6 columns * 2 high
	// |30.53|30.53|30.53|30.53|30.53|30.53|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs30ft(true);
			stradStack.allGridControllersByRowColumn[row, column].setIs53ft(true);
			commitTransaction;	
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();	
	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotalsStrict30s" id="16c5f24f-cf53-41ee-895d-da6d6e9b0ea0">
        <source>tStatsAgentCalcTotalsStrict30s();
// cnwer1
// cnwjk3
/*

Purpose: Tests for calculating totals for 30's when different strict grids are in place.

The basic rule is, a container should only ever span one strict grid. For example, if it starts on a grid marked as 53', then any other
LCs it spans must all be 53' 		

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	gridLCDict: CM_RTGControllerBySeqRowCol;
begin
	create statsAgent transient;
	create locations transient;
	create gridLCDict transient;

	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	self.deleteContainer("TESTJK00005");
	self.deleteContainer("TESTJK00006");
	self.deleteContainer("TESTJK00007");
	self.deleteContainer("TESTJK00008");
	self.deleteContainer("TESTJK00009");
	self.deleteContainer("TESTJK00010");
	self.deleteContainer("TESTJK00011");
	self.deleteContainer("TESTJK00012");
	self.deleteContainer("TESTJK00013");
	self.deleteContainer("TESTJK00014");
	self.deleteContainer("TESTJK00015");
	
	
	// 1 row * 6 columns * 2 high
	// |  |  |  |  |  |  |
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 8);
	locations.clear();

		
	// 1 row * 6 columns * 2 high
	// |  |30|30|30|  |  |
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 2].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 3].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 4].setIs30ft(true);

	stradStack.allGridControllersByRowColumn[1, 2].setOffset30ft(0);
	stradStack.allGridControllersByRowColumn[1, 3].setOffset30ft(10);
	stradStack.allGridControllersByRowColumn[1, 4].setOffset30ft(-1);

	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();


	// 1 row * 6 columns * 2 high
	// |53|30|30|30|45|45|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].setIs53ft(true);
	stradStack.allGridControllersByRowColumn[1, 2].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 3].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 4].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 5].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 6].setIs45ft(true);

	stradStack.allGridControllersByRowColumn[1, 1].setOffset53ft(0);
	stradStack.allGridControllersByRowColumn[1, 2].setOffset30ft(0);
	stradStack.allGridControllersByRowColumn[1, 3].setOffset30ft(10);
	stradStack.allGridControllersByRowColumn[1, 4].setOffset30ft(-1);
	stradStack.allGridControllersByRowColumn[1, 5].setOffset45ft(0);
	stradStack.allGridControllersByRowColumn[1, 6].setOffset45ft(-1);
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();

	
	// 1 row * 6 columns * 2 high
	// |53|30|45|45|45|45|
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].setIs53ft(true);
	stradStack.allGridControllersByRowColumn[1, 2].setIs30ft(true);
	stradStack.allGridControllersByRowColumn[1, 3].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 4].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 5].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 6].setIs45ft(true);

	stradStack.allGridControllersByRowColumn[1, 1].setOffset53ft(0);
	stradStack.allGridControllersByRowColumn[1, 2].setOffset30ft(0);
	stradStack.allGridControllersByRowColumn[1, 3].setOffset45ft(0);
	stradStack.allGridControllersByRowColumn[1, 4].setOffset45ft(-1);
	stradStack.allGridControllersByRowColumn[1, 5].setOffset45ft(5);
	stradStack.allGridControllersByRowColumn[1, 6].setOffset45ft(-1);	
	
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();

	
	// 1 row * 8 columns * 1 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	numColumns := 8;
	numRows := 1;
	height := 1;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 5);
	locations.clear();
	gridLCDict.clear();
	

	// 1 row * 8 columns * 1 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	
	// This time we start from column 2 to check offsets (in this case the start offset will be 10)
	numColumns := 8;
	numRows := 1;
	height := 1;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
			if column &gt;= 2 then
				locations.add(stradStack.allGridControllersByRowColumn[row, column]);
			endif;
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();
	gridLCDict.clear();	

	// 1 row * 8 columns * 1 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	
	// This time we start from column 3 and end at column 4
	numColumns := 8;
	numRows := 1;
	height := 1;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	locations.add(stradStack.allGridControllersByRowColumn[1, 3]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 4]);	
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 0);
	locations.clear();
	gridLCDict.clear();	
	

	// 1 row * 8 columns * 1 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	
	// This time we start from column 3 and end at column 3
	numColumns := 8;
	numRows := 1;
	height := 1;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	locations.add(stradStack.allGridControllersByRowColumn[1, 3]);
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 0);
	locations.clear();
	gridLCDict.clear();	
	

	// 1 row * 8 columns * 1 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	
	// This time we start from column 3 and end at column 5
	numColumns := 8;
	numRows := 1;
	height := 1;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	locations.add(stradStack.allGridControllersByRowColumn[1, 3]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 4]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 5]);
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 1);
	locations.clear();
	gridLCDict.clear();	


	// 2 row * 8 columns * 2 high
	//
	// |30|30|30|30|30|30|30|30|
	//
	// 30' offsets for each loaction will be as follows
	//
	// |00|10|-1|00|10|-1|00|10|
	
	// This time we start from column 3 and end at column 5
	numColumns := 8;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			gridLCDict.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	locations.add(stradStack.allGridControllersByRowColumn[1, 3]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 4]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 5]);
	locations.add(stradStack.allGridControllersByRowColumn[2, 3]);
	locations.add(stradStack.allGridControllersByRowColumn[2, 4]);
	locations.add(stradStack.allGridControllersByRowColumn[2, 5]);
	beginTransaction;
	stradStack.set30ftControllers(gridLCDict);
	commitTransaction;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();
	gridLCDict.clear();	

	
	
	
epilog
	delete gridLCDict;
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotalsStrict45s" id="4da38d31-4a63-4f3b-9539-89757c56e7ce">
        <source>tStatsAgentCalcTotalsStrict45s();
// cnwer1
// cnwjk3
/*

Purpose: Tests for calculating totals for 30's when different strict grids are in place.

The basic rule is, a container should only ever span one strict grid. For example, if it starts on a grid marked as 53', then any other
LCs it spans must all be 53' 		

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;

begin
	create statsAgent transient;
	create locations transient;
	
	
	// 1 row * 6 columns * 2 high
	// |  |  |  |  |  |  |
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();

		
	// 1 row * 8 columns * 2 high
	// |  |45|45|45|  |45|  |  |
	numColumns := 8;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 2].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 3].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 4].setIs45ft(true);
	stradStack.allGridControllersByRowColumn[1, 6].setIs45ft(true);

	stradStack.allGridControllersByRowColumn[1, 2].setOffset45ft(0);
	stradStack.allGridControllersByRowColumn[1, 3].setOffset45ft(-1);
	stradStack.allGridControllersByRowColumn[1, 4].setOffset45ft(5);
	stradStack.allGridControllersByRowColumn[1, 6].setOffset45ft(0);
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();


epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotalsStrict53s" id="13fd20e3-35ba-45dc-b34e-871f2d3275a1">
        <source>tStatsAgentCalcTotalsStrict53s();
// cnwer1
// cnwjk3
/*

Purpose: Tests for calculating totals for 30's when different strict grids are in place.

The basic rule is, a container should only ever span one strict grid. For example, if it starts on a grid marked as 53', then any other
LCs it spans must all be 53' 		

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;

begin
	create statsAgent transient;
	create locations transient;
	
	
	// 1 row * 6 columns * 2 high
	// |  |  |  |  |  |  |
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();
	
	// 1 row * 8 columns * 2 high
	// |  |53|53|53|  |53|  |  |
	numColumns := 8;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 2].setIs53ft(true);
	stradStack.allGridControllersByRowColumn[1, 3].setIs53ft(true);
	stradStack.allGridControllersByRowColumn[1, 4].setIs53ft(true);
	stradStack.allGridControllersByRowColumn[1, 6].setIs53ft(true);

	stradStack.allGridControllersByRowColumn[1, 2].setOffset53ft(0);
	stradStack.allGridControllersByRowColumn[1, 3].setOffset53ft(-1);
	stradStack.allGridControllersByRowColumn[1, 4].setOffset53ft(13);
	stradStack.allGridControllersByRowColumn[1, 6].setOffset53ft(0);
	commitTransaction;	
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, height);
	assertEqual(total, 4);
	locations.clear();


epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcUsed20s" id="da3ebe90-2587-4631-b533-2170dcd22753">
        <source>tStatsAgentCalcUsed20s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;

begin
	create locations transient;
	create statsAgent transient;

	// 1 row * 6 columns * 2 high
	numColumns := 6;
	numRows := 1;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	
	// Test 1  - No TIs
	total := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1, 2); //cnwjo3 par 20470
	self.assertEqual(total, 0);

	// Test 2			
	// |20(*2)|  |  |  |  |  |20|
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	container1 := self.addContainerOpts("TESTJK00001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 6]);
	
	total := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1,2); //cnwjo3 par 20470
	self.assertEqual(total, 3);
	

	// Test 3			
	// |20(*2)| 30|  |  |  |  |20|
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	container1 := self.addContainerOpts("TESTJK00001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 6]);
	move(container4,  stradStack.allGridControllersByRowColumn[1, 2]);
	
	total := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1,2);  //cnwjo3 par 20470
	self.assertEqual(total, 3);

	
	
	// Test 4  - 2 rows
	//|20(*2)|  |  |  |  |  |
	//|30    |  |  |  |  |20|
	locations.clear();
	numColumns := 6;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	container1 := self.addContainerOpts("TESTJK00001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container3,  stradStack.allGridControllersByRowColumn[2, 6]);
	move(container4,  stradStack.allGridControllersByRowColumn[2, 1]);
	
	total := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1,2);  //cnwjo3 par 20470
	self.assertEqual(total, 3);

	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentFindSpace" id="d76e4bc5-00d0-42da-9e74-1d42e64b0838">
        <source>tStatsAgentFindSpace();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	ti: CM_TrackedItem;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	locations: CM_LCSet;
	row,
	column,
	numColumns,
	numRows,
	height,
	spaceFound,
	nextColumn,
	maxHeight,
	size,
	offset	: Integer;
	nextLC : CM_GridController;
	
begin
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", 1, 5, 2);
	create statsAgent transient;
	
	size := CMIF_StatisticsAgent.ContainerSize_20;
	
	// 20' in first column
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 2);
	
	// 20' in last column
	nextColumn := 5;
	nextLC := stradStack.allGridControllersByRowColumn[1,nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 6);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 2);

	//////////////////////////////
	size := CMIF_StatisticsAgent.ContainerSize_30;
	
	// 30' in first column
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 2);

	// 30' in first column, but offest by 11  (11-20 first LC, 1-20 next LC)
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 11;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 3);
	assertEqual(offset, 1);
	assertEqual(maxHeight, 2);

	// 30' in last column
	nextColumn := 5;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, 20);

	
	// 30' in penultimate column
	nextColumn := 4;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertTrue(spaceFound = size);
	assertEqual(nextColumn, 5);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 2);
	
	
	//////////////////////////////

	size := CMIF_StatisticsAgent.ContainerSize_53;
	
	// 53' in first column
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 3);
	assertEqual(offset, 13);
	assertEqual(maxHeight, 2);

	// 53' in first column, but offest by 14  (14-20 first LC, 1-20 next 2 LCs, 1-6 last LC)
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 14;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 4);
	assertEqual(offset, 7);
	assertEqual(maxHeight, 2);

	// 53' in last column
	nextColumn := 5;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, 20);

	// 53' in penultimate column, offset by 5
	nextColumn := 4;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 5;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, 35);
	
	// 53' in second column, offset by 7
	nextColumn := 2;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 7;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 5);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 2);

	
	// Decrease one of the LC's heights and ensure that the max height involved in the set of LCs is equal to this
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, nextColumn + 1 ].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	commitTransaction;
	assertEqual(stradStack.allGridControllersByRowColumn[1, nextColumn + 1 ].getMaxStackingHeight(), 1);
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(size, nextLC, nextColumn, offset, maxHeight, false, 5); 
	assertEqual(spaceFound, size);
	assertEqual(nextColumn, 3);
	assertEqual(offset, 13);
	assertEqual(maxHeight, 1);
	
	
	///////////////////////////////////////////
	// Tests for stopping once a TI is found
	
	
	// TEST SET 1
	
	// 1 row * 6 columns * 1 high
	numColumns := 6;
	numRows := 1;
	height := 1;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			//locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	
	//  Add some TIs
	// |20|30(10)|30(20)|20|20|20|
	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 2]);
	
	
	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 0);
	assertEqual(nextColumn, 1);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 1);

	
	self.deleteContainer("TESTJK00001");

	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 30);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 1);

	nextColumn := 2;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 10);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 1);

	nextColumn := 2;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 11;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 0);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 1);

	
	// TEST SET 2

	
	/////
	//  Add some TIs
	// |20|20|20|20|30(10)|30(20)|	
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 4]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 5]);
	self.deleteContainer("TESTJK00001");

	
	
	nextColumn := 4;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 30);
	assertEqual(nextColumn, 5);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 1);

	
	nextColumn := 5;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 10);
	assertEqual(nextColumn, 5);
	assertEqual(offset, 10);
	assertEqual(maxHeight, 1);

	nextColumn := 5;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 11;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 0);
	assertEqual(nextColumn, 5);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 1);

	// TEST SET 3
	/////
	//  Add some TIs
	// |53(20)|53(20)|53(13)|20|20|20|	
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);

	nextColumn := 1;
	nextLC := stradStack.allGridControllersByRowColumn[1, nextColumn];
	maxHeight := 0;
	offset := 0;
	spaceFound := statsAgent.findSpace(30, nextLC, nextColumn, offset, maxHeight, false, numColumns); 
	assertEqual(spaceFound, 0);
	assertEqual(nextColumn, 1);
	assertEqual(offset, 0);
	assertEqual(maxHeight, 1);

	
	
epilog
	delete locations;
	delete statsAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentGetNextColOffset" id="e0ff436a-b9a8-4bc8-83d1-2d35eb5aae2c">
        <source>tStatsAgentGetNextColOffset();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	ti: CM_TrackedItem;
	container1 : CM_TrackedItem;
	locations: CM_LCSet;
	row,
	column,
	numColumns,
	numRows,
	height,
	spaceFound,
	nextColumn,
	maxHeight,
	size,
	offset	: Integer;
	nextLC : CM_GridController;

begin

	// Note that it doesn't matter where I shove the containers for these tests.  All we are interseted in are the
	// nextColumn and offset values being computed correctly.
	numColumns := 6;
	numRows := 1;
	height := 1;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	create statsAgent transient;
	
	// 30' Tests
	
	//  Add a 30' TI
	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	
	// Test 1
	nextColumn := 2;
	offset := 10;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 4);
	assertEqual(offset, 0);

	// Test 2
	nextColumn := 1;
	offset := 0;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 10);

	// Test 3
	nextColumn := 1;
	offset := 15;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 3);
	assertEqual(offset, 5);

	/////
	
	// 53' Tests
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	//  Add a 53' TI
	self.deleteContainer("TESTJK00001");
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	
	// Test 1
	nextColumn := 1;
	offset := 10;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 4);
	assertEqual(offset, 3);
	
	// Test 2
	nextColumn := 4;
	offset := 2;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 6);
	assertEqual(offset, 15);
	
	/////
	
	// 20' tests
	self.deleteContainer("TESTJK00001");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	//  Add a 20' TI
	container1 := self.addContainerOpts("TESTJK00001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);

	// Test 1
	nextColumn := 1;
	offset := 0;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 0);

	
	// Test 2
	nextColumn := 1;
	offset := 2;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 2);
	assertEqual(offset, 2);
	
	// Test 3
	nextColumn := 2;
	offset := 19;
	statsAgent.getNextColumnAndOffset(stradStack.allGridControllersByRowColumn[1, 1], nextColumn, offset);
	assertEqual(nextColumn, 3);
	assertEqual(offset, 19);


epilog
	delete statsAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentGetSpareHeight" id="f9fc11d7-973d-46c5-b867-52c619d1b98d">
        <source>tStatsAgentGetSpareHeight();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	container2,
	container1 : CM_TrackedItem;
	numColumns,
	numRows,
	height,
	spareHeight,
	size,
	offset	: Integer;
	nextLC : CM_GridController;
begin
	
	create statsAgent transient;

	// 30' Tests

	numColumns := 6;
	numRows := 1;
	height := 1;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 0 );
	
	move(container2,  stradStack.allGridControllersByRowColumn[1, 2]);	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 0 );
	
	
	numColumns := 6;
	numRows := 1;
	height := 6;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 5 );

	// restrict max height
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height-1);
	self.assertEqual(spareHeight, 4 );

	// restrict min height
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 2, height);
	self.assertEqual(spareHeight, 4 );

	// restrict min and max height
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 2, height-1);
	self.assertEqual(spareHeight, 3 );

	
	move(container2,  stradStack.allGridControllersByRowColumn[1, 2]);	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 5 );
	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 2], 1, height);
	self.assertEqual(spareHeight, 5 );

	move(container2,  stradStack.allGridControllersByRowColumn[1, 1]);	
	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 4 );
	

	// A test for one of the LC's being restricted in height
	
	// |      |            | XXXX |  |  |  |
	// |      |            |      |  |  |  |
 	// |30(20)|30(10)30(10)|30(20)|  |  |  |
	
	numColumns := 6;
	numRows := 1;
	height := 3;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 3 ].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;

	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);	
	move(container2,  stradStack.allGridControllersByRowColumn[1, 2]);	
	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 1], 1, height);
	self.assertEqual(spareHeight, 2 );
	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 2], 1, height);
	self.assertEqual(spareHeight, 1 );
	

	// |      |            | XXXX |  |  |  |
	// |      |            | XXXX |  |  |  |
 	// |30(20)|30(10)30(10)|30(20)|  |  |  |
	
	numColumns := 6;
	numRows := 1;
	height := 3;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 3 ].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	commitTransaction;

	container1 := self.addContainerOpts("TESTJK00001", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);	
	move(container2,  stradStack.allGridControllersByRowColumn[1, 2]);	
	
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 2], 1, height);
	self.assertEqual(spareHeight, 0 );
	spareHeight := statsAgent.getSpareHeight(stradStack.allGridControllersByRowColumn[1, 2], 1, height-2);
	self.assertEqual(spareHeight, 0 );
	
epilog
	delete statsAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentHaveSameGridTypes" id="a97342f8-67f6-482b-99de-4ef07a035959">
        <source>tStatsAgentHaveSameGridTypes();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;

begin
	numColumns := 6;
	numRows := 1;
	height := 2;
	create locations transient;
	create statsAgent transient;

	self.assertFalse(statsAgent.haveSameGridTypes(1,6, locations));
	
	
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	self.assertTrue(statsAgent.haveSameGridTypes(1,6, locations));
	self.assertFalse(statsAgent.haveSameGridTypes(0,6, locations));
	self.assertFalse(statsAgent.haveSameGridTypes(6,1, locations));	
	locations.clear();

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs30ft(true);
			stradStack.allGridControllersByRowColumn[row, column].setIs40ft(true);
			commitTransaction;
		endforeach;
	endforeach;
	self.assertTrue(statsAgent.haveSameGridTypes(1,6, locations));
	locations.clear();	

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
			beginTransaction;
			stradStack.allGridControllersByRowColumn[row, column].setIs30ft(true);
			stradStack.allGridControllersByRowColumn[row, column].setIs40ft(true);
			commitTransaction;
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1,6].setIs53ft(true);
	commitTransaction;
	self.assertFalse(statsAgent.haveSameGridTypes(1,6, locations));
	locations.clear();		
	
epilog
	delete locations;
	delete statsAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyTARowStats" id="126e58db-b3ad-497b-ab46-c0307342264e">
        <source>tVerifyTARowStats();
// cnwndl1
//01 September 2008	cnwdw1	
//
vars
	stradStack: CM_StraddleStack;
	ti: CM_TrackedItem;
	locations: CM_LCSet;
begin
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 2, 2, 3);
	
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[1, 1]);
	updateLocationContainerLength(stradStack, locations, true, false, false, false, false);
	self.assertTrueMsg(stradStack.allGridControllersByRowColumn[1, 1].is30ft, "location not 30ft capable");
	
	calculateTerminalAreaStats(stradStack);
	assertStat(stradStack.allGridRows[1].myLocationStatistics, "c20Total", 6);
	assertStat(stradStack.allGridRows[1].myLocationStatistics, "c20Free", 6);
	
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	move(ti, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti);
	calculateTerminalAreaStats(stradStack);
	assertStat(stradStack.allGridRows[1].myLocationStatistics, "c20Total", 6);
	assertStat(stradStack.allGridRows[1].myLocationStatistics, "c20Free", 5);

epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyYABlockStats1" id="b5fd91cf-6d20-4816-9c2a-94911f1b882e">
        <source>tVerifyYABlockStats1();
// cnwndl1
//01 September 2008	cnwdw1	
//Simple 
vars
	stradStack: CM_StraddleStack;
	ti, ti2: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
begin
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 2, 2, 3);
	
	self.deleteYA("UT");
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[1, 1]);
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, "20", locations);

	calculateYABlockStats(ya);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Total.name, 3);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 3);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Total.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Total.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Total.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Total.name, 0);
	
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	move(ti, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);
	
	move(ti2, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 1);  //curently failing
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 2);

	move(ti, stradStack.allGridControllersByRowColumn[1, 2]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 2], ti);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);

epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyYABlockStats2" id="471f4380-9489-40ea-b02d-25049d42b633">
        <source>tVerifyYABlockStats2();
// cnwndl1
//01 September 2008	cnwdw1	
//
vars
	stradStack: CM_StraddleStack;
	ti20_1, ti20_2: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	operatorName: String;
begin
	deleteContainer("TEST2010001");
	deleteContainer("TEST2010002");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 2, 10, 2);
	operatorName := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	
	self.deleteYA("UT");
	// Add a range that is 5 slots long
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[2, 2]);
	locations.add(stradStack.allGridControllersByRowColumn[2, 6]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorName, locations);

	calculateYABlockStats(ya);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Total.name,10);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 10);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Total.name, 6);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Free.name,  6);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Total.name, 4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Free.name,  4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Total.name, 4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Free.name,  4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Total.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Free.name,  2);
	
	ti20_1 := self.addContainerOpts("TEST2010001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti20_2 := self.addContainerOpts("TEST2010002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	move(ti20_1, stradStack.allGridControllersByRowColumn[2, 2]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[2, 2], ti20_1);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Total.name,10);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name,  1);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name,  9);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Total.name, 6);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c30Free.name,  4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Total.name, 4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Free.name,  4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Total.name, 4);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c45Free.name,  2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Total.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Used.name,  0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c53Free.name,  2);
	
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYABlockStatsWithHeightRange1" id="a3f99db7-498f-4900-9707-a23cfacf0305">
        <source>tYABlockStatsWithHeightRange1();
// cnwndl1
//01 September 2008	cnwdw1	
// Verify the stats for a YA that has a height range of Min:1 Max:1 on the locations
vars
	stradStack: CM_StraddleStack;
	ti, ti2, ti3: CM_TrackedItem;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	locations : CM_LCArray;

begin
	
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteContainer("TEST0000003");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 2, 2, 3);
	
	self.deleteYA("UT");
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[1, 1]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 2]);
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, "20", locations);
	self.opts.purge();
	self.opts.addAssociation("MinHeight", 1);
	self.opts.addAssociation("MaxHeight", 1);
	yaBlock := ya.allYABlocksIn.first;
	self.updateYABlock(yaBlock);


	assertEqual(yaBlock.CM_YABlockGridArea.maxHeight, 1);
	assertEqual(yaBlock.CM_YABlockGridArea.minHeight, 1);
	
	
	calculateYABlockStats(ya);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Total.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Total.name, 1);


	
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti3 := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Move in a ti
	move(ti, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 1);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);

	
	
	// Move in another ti - totals should not change as ti is not in range
	move(ti2, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 1);  //currently failing
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);


	
	// Move ti - YA block should now be full
	move(ti3, stradStack.allGridControllersByRowColumn[1, 2]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 2], ti3);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 2);

epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYABlockStatsWithHeightRange2" id="0c709632-eb9c-4862-9b54-c62f9973aa74">
        <source>tYABlockStatsWithHeightRange2();
// cnwndl1
//01 September 2008	cnwdw1	
// Verify the stats for a YA that has a height range of Min:2 Max:2 on the locations
vars
	stradStack: CM_StraddleStack;
	ti, ti2, ti3: CM_TrackedItem;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	locations : CM_LCArray;

begin
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteContainer("TEST0000003");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 2, 2, 3);
	
	self.deleteYA("UT");
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[1, 1]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 2]);
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, "20", locations);
	self.opts.purge();
	self.opts.addAssociation("MinHeight", 2);
	self.opts.addAssociation("MaxHeight", 2);
	yaBlock := ya.allYABlocksIn.first;
	self.updateYABlock(yaBlock);

	calculateYABlockStats(ya);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Total.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 0);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c40Total.name, 1);
	
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti3 := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Move in a ti - no change as ti is outside range
	move(ti, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 0);
	
	// Move in another ti 
	move(ti2, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti2);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 1);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);

	// Move in a ti - no change as ti is outside range
	move(ti3, stradStack.allGridControllersByRowColumn[1, 1]);
	assertLocationHasTI(stradStack.allGridControllersByRowColumn[1, 1], ti3);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Free.name, 1);
	assertStat(ya.allYABlocksIn.first.myLocationStatistics, CM_LocationStatistics::c20Used.name, 1);

epilog
	delete locations;
end;</source>
    </JadeMethod>
