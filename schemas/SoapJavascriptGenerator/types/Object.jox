<Class name="Object">
    <JadeMethod name="generateRIAModule" id="9571e032-25c1-4058-be00-aafd6b6845f7">
        <updating/>
        <source>generateRIAModule(moduleNamespace : String; hsa : LargeStringArray io; style : Integer) updating;

vars

begin
	hsa.add("//This code is based on a singleton pattern developed by Douglas Crockford (commonly referred");
	hsa.add("//to as the 'module pattern').");
	hsa.add("//This pattern keeps your code out of the global namespace, provides publically addressable");
	hsa.add("//API methods, and supports protected or 'private' data and methods.");
	hsa.add("//");
	hsa.add("//     Usage Overview:");
	hsa.add("//     * Import the RIA scripts into all relevant html pages.");
	if style = RIA_MODULE_TYPES then
		hsa.add("//     * This module acts as a factory to create proxy objects that represent");
		hsa.add("//       non-primitive parameter types - used when calling the web service api methods.");
	else
		hsa.add("//     * Call the public web service api methods that are defined in the methods");
		hsa.add("//       module to initiate a web service call.");
		hsa.add("//     * Perform any action on the response via the callback _RESPONSE method.");
	endif;
	hsa.add("");
	hsa.add("//Setup the module's namespace (typically, the module namespace will be your domain name)");
	hsa.add("/*global JMT*/");
	hsa.add("if (!" &amp; moduleNamespace &amp; ") {");
		hsa.add(("var " &amp; moduleNamespace &amp; " = {};").itab(1));
	hsa.add("}");	
end;
</source>
        <Parameter name="moduleNamespace" type="String"/>
        <Parameter name="hsa" type="LargeStringArray" usage="io"/>
        <Parameter name="style" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRootClass" id="9bf1a575-fd6d-4121-851c-e66ca8a2d76e">
        <source>getRootClass(c : Class):Class;

vars

begin
	if c.rootType.schema = rootSchema then
		return c.rootType.Class;
	else
		return getRootClass(c.rootType.getSuperclass);
	endif;
end;
</source>
        <Parameter name="c" type="Class"/>
        <ReturnType type="Class"/>
    </JadeMethod>
</Class>
