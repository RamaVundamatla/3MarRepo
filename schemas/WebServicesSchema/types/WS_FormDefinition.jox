    <JadeMethod name="buildMyFormDefinition" id="0c5bd55e-c942-433c-a96e-046fb4a7c438">
        <updating/>
        <source>buildMyFormDefinition() updating;

/*

Purpose:			Complete the build of the receiver from the formName

Parameters:			None

Return Value:		Self updated with all required build information


Date		Who		Reason
01 Sep 2008	cnwkao1	Initial creation - reworked old approach
26 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Add in setting of permissions
					
*/

vars
	viewPermission,
	addPermission,
	updatePermission,
	deletePermission	: Integer;
	user				: CM_User;
	terminal			: CM_Terminal;
	
begin
	// Set up permission related fields
	app.getJMTPermissionsForFormName(self.formName,
									 viewPermission,
									 addPermission,
									 updatePermission,
									 deletePermission);
									 
	user := app.getMyUser();
	terminal := app.getMyTerminalDO_NOT_USE();
	
	// Check User has access
	if viewPermission &lt;&gt; null and not user.canDo(terminal, viewPermission) then
		app.raiseCMException2(ERR_USER_NO_PERMISSION,
							user.code, 
							   app.getPermissionName(viewPermission),
							   null, 
							   null);
		return;
	endif;
		
	self.allowCreate := (addPermission = null) or user.canDo(terminal, addPermission);
	self.allowUpdate := (updatePermission = null) or user.canDo(terminal, updatePermission);
	self.allowDelete := (deletePermission = null) or user.canDo(terminal, deletePermission);
	
	//06/07/2009 cnwdz2 par 20233
	self.mandatoryIndicator := MandatoryFieldIndicator;
	
	if self.formName = Cargo_QuickView_Form then
		self.buildCargoQuickViewFormDef();
	elseif self.formName = Cargo_QuickView_Search_Form then
		self.buildCargoQuickViewSearchDef();
	elseif self.formName = Cargo_Notification then
		self.buildCargoNoteFormDefinition();
	elseif self.formName = Cargo_Notification_Search then
		self.buildCargoNoteSearchFormDef();
	elseif self.formName = BookingRefItem_Select_Form then
		self.buildBookRefItemSelectFormDef();
	elseif self.formName = PreNotes then
		self.buildPreNoteFormDefinition();
	elseif self.formName = PreNotes_Search then	
		self.buildPreNoteSearchFormDef();
	elseif self.formName = Cargo_Update_Request then
		self.buildUpdateRequestFormDef();
	elseif self.formName = Cargo_Update_Search then
		self.buildUpdateRequestSearchForm();
	elseif self.formName = Cargo_Rel_Import then
		self.buildReleaseImportFormDef();
	elseif self.formName = Cargo_Rel_Import_Search then
		self.buildReleaseImportSrchFormDef();
	elseif self.formName = Cargo_Enq_Form then
		self.buildCargoEnquiryFormDef();
	elseif self.formName = Cargo_Enq_Search_Form then
		self.buildCargoEnquirySearchFormDef();
	elseif self.formName = Release_Request then
		self.buildReleaseRequestFormDef();
	elseif self.formName = Release_Request_Search then
		self.buildReleaseRequestSrchFormDef();
	elseif self.formName = Report_Selection then
		self.buildReportSelectionFormDef();
	elseif self.formName = Add_Attachments then
		self.buildAttachmentsFormDef();
	elseif self.formName = Preferences_Form then
		self.buildPreferencesFormDef();
	elseif self.formName = VehicleBooking_Search then	//08 May 2013	NDL	Par 31393
		self.buildVehicleBookingSrchFormDef();
	elseif self.formName = VehicleBooking then //08 May 2013	NDL	Par 31393
		self.buildVehicleBookingFormDef(false);			//cnwmc5 - 31 Oct 2014 - PAR 35008
	elseif self.formName = VehicleBookingEnquiry then	//cnwmc5 - 31 Oct 2014 - PAR 35008
		self.buildVehicleBookingFormDef(true);			//cnwmc5 - 31 Oct 2014 - PAR 35008
	elseif self.formName = VehicleBookingEnquirySearch then	//cnwmc5 - 29 Oct 2014 - PAR 35008
		self.buildVehicleBookingEnqSrchForm();
	elseif self.formName = Release_Request_Items_ID then		//cnwmc5 - 24 Nov 2014 - CCMS 2429
		self.buildReleaseReqItemsIDForm();						//cnwmc5 - 24 Nov 2014 - CCMS 2429
	elseif self.formName = Release_Request_Items_Type then		//cnwmc5 - 24 Nov 2014 - CCMS 2429
		self.buildReleaseReqItemsTypeForm();					//cnwmc5 - 24 Nov 2014 - CCMS 2429
	else
		self.handleOtherForms();
	endif;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="buildMyFormLayout" id="07b985ca-90fc-4044-9506-16a6f3a8267f">
