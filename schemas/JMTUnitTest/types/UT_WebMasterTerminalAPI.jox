  "releaseItems": [
    {
      "cargoTypeId": "STEEL COIL",
	  "cargoSubTypeId": "TIEWIRE10G",
      "quantityRequested": 100,
      "weightRequested": 0,
      "volumeRequested": 0,
	  "piecesRequested": 50
    },
	{
      "cargoTypeId": "CONT",
	  "cargoSubTypeId": "",
	  "isoTypeId": "2200",
      "quantityRequested": 1,
      "weightRequested": 0,
      "volumeRequested": 0
    }
  ]
}]';
ReleaseWithBooking='[
  {
  "id": "'&amp;RelWithBooking&amp;'",
  "requestType": "Road",
  "bookingId": "UT61852",
  "carrierId": "",
  "consigneeId": "63F3",
  "consignorId": "LA-CO",
  "consignorVoyageId": "",
  "deliveryReleaseNumber": "",
  "destinationTerminalId": "",
  "dischargePortId": "",
  "estimatedRequiredDateTime": "2024-01-24T22:11:37.611Z",
  "freightForwarderId": "",
  "fullRelease": true,
  "subTerminalId": "",
  "operatorId": "LAUR",
  "releaseByType": true,
  "remarks": "Test",
  "requestDateTime": "2024-01-30T22:11:37.611Z",
  "status": "1",
  "voyageExternalId": "",
  "voyageId": "'&amp;VoyageUT&amp;'",
  "releaseItems": [
	{
      "cargoTypeId": "CONT",
	  "cargoSubTypeId": "",
	  "isoTypeId": "2200",
      "quantityRequested": 1,
      "weightRequested": 0,
      "volumeRequested": 0
    }
  ]
}]';
ReleaseWithInvalidType='[
  {
  "id": "'&amp;RelWithInvalidType&amp;'",
  "requestType": "'&amp;BR_TYPE_UNKNOWN_STR&amp;'",
  "bookingId": "",
  "carrierId": "",
  "consigneeId": "63F3",
  "consignorId": "LA-CO",
  "consignorVoyageId": "",
  "deliveryReleaseNumber": "",
  "destinationTerminalId": "",
  "dischargePortId": "",
  "estimatedRequiredDateTime": "2024-01-24T22:11:37.611Z",
  "freightForwarderId": "",
  "fullRelease": true,
  "subTerminalId": "",
  "operatorId": "LAUR",
  "releaseByType": true,
  "remarks": "Test",
  "requestDateTime": "2024-01-30T22:11:37.611Z",
  "status": "1",
  "voyageExternalId": "",
  "voyageId": "'&amp;VoyageUT&amp;'"
}]';
vars
	incomingJsonString,
	terminalCode				: String;
	expectFailure				: Boolean;
	root						: CM_Root;
	cargo1,
	cargoId2,
	cargoId3,
	cargoId4					: String;
	vessel 						: CM_Vessel;
	voyage						: CM_Voyage;
	ti,
	ti2,
	ti3,
	ti4,
	ti5							: CM_TrackedItem;
	operator 					: CM_Operator;
	dischargePort 				: CM_Port;
	releaseRequest 				: CM_BulkRelease;
	reserverDetail				: CM_ReserveDetail;
	cargoType 					: CM_CargoType;
	terminal 					: CM_Terminal;
	blockStack					: CM_BlockStack;
	booking						: CM_BookingRef;
	reserveSelection			: CM_ReserveSelection;
	count						: Integer;
	logLevel					: Integer;
begin
	logLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);
	
	cargo1 := UTCargoId;
	cargoId2 := UTCargoId1;
	cargoId3 := UTCargoId2;
	cargoId4 := UTCargoId3;
	
	root := self.getRoot();
	self.setTerminalConfig(IsSubTerminalsOn, false);
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	self.deleteTrackedItem(cargo1, false);
	self.deleteTrackedItem(cargoId2, false);
	self.deleteTrackedItem(cargoId3, false);
	self.deleteTrackedItem(cargoId4, false);
		
	self.deleteReleaseRequest(RelId);
	self.deleteReleaseRequest(RelById);
	self.deleteReleaseRequest(RelRailById);
	self.deleteReleaseRequest(RelTypeId);
	self.deleteReleaseRequest(RelByType);
	self.deleteReleaseRequest(RelByTypeMulti);
	self.deleteReleaseRequest(RelWithBooking);
	
	self.deleteVessel(VesselUT);
	self.deleteVoyage(VoyageUT);
	
	// Create the TrackItem one 
	self.opts.purge();
	self.opts.addAssoc("CargoType", TI_CargoType_Container);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// create the vessel and voyage
	vessel := addVesselCellular(VesselUT,operator);
	self.assertTrueMsg(vessel &lt;&gt; null, "No Vessel Created");
	voyage := addVoyageWithContainerStructur(VoyageUT, VesselUT, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, "No Voyage Created");
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	ti := self.addContainerForExport(cargo1, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertTrueMsg(ti &lt;&gt; null, "No TrackedItem Created");
	ti2 := self.addContainerForExport(cargoId2, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertTrueMsg(ti2 &lt;&gt; null, "No TrackedItem Created");
	ti4 := self.addContainerForExport(cargoId3, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertTrueMsg(ti4 &lt;&gt; null, "No TrackedItem Created");
	ti5 := self.addContainerForExport(cargoId4, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertTrueMsg(ti5 &lt;&gt; null, "No TrackedItem Created");
	
	terminal := root.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "Terminal is null");
	
	// bulk
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	
	self.deleteCargo(BulkCargo1, cargoType);
	self.deleteCargo(BulkCargo2, cargoType);
	self.deleteTerminalArea(BlockStack);
	self.deleteTerminalArea("UTBS"&amp;Ref);
	
	blockStack := self.addBlockStack(BlockStack, 10, null);
	
	ti3 := self.addCargoBreakBulkAtLocation(BulkCargo1, cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertNotNullMsg(ti3, "Bulk Cargo");
	
	// create the booking
	self.deleteBooking("UT"&amp;Ref);
	self.addBookingForContainer("UT"&amp;Ref,operator,voyage,dischargePort.code,"2200","MT");
	booking := terminal.allBookingRefsByRef["UT"&amp;Ref];
	self.assertNotNullMsg(booking, "Booking not created");
	
	// release road by id
	incomingJsonString := ReleaseById;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	releaseRequest := self.getReleaseRequest(RelById);
	self.assertNotNullMsg(releaseRequest, "Release request not created");
	self.assertEqualMsg(releaseRequest.type, BR_TYPE_ROAD, "Release type should be Road");
	self.assertEqualMsg(releaseRequest.status,BR_ACTIVE, "Release status should be Active");
	self.assertEqualMsg(releaseRequest.consigneeCode,"63F3", "Consignee not set correctly");
	self.assertEqualMsg(releaseRequest.carrierId, "F8E3", "Carrier should match F8E3");
	self.assertEqualMsg(releaseRequest.fullRelease,true,"Full release should be true");
	
	// release Rail by Id
	incomingJsonString := ReleaseRailById;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	
	releaseRequest := self.getReleaseRequest(RelRailById);
	self.assertNotNullMsg(releaseRequest, "Release request not created");
	self.assertEqualMsg(releaseRequest.type, BR_TYPE_RAIL, "Release type should be Rail");
	self.assertEqualMsg(releaseRequest.status,BR_PENDING, "Release status should be pending");
	self.assertEqualMsg(releaseRequest.consigneeCode,"63F3", "Should match");
	self.assertEqualMsg(releaseRequest.consignorCode,"LA-CO", "Should match");
	self.assertEqualMsg(releaseRequest.getTotalRequested, 1, "Should be 1 requested");
	self.assertEqualMsg(releaseRequest.fullRelease,true,"Full release should be true");
	
	reserverDetail := releaseRequest.getReserveDetail();
	foreach reserverDetail in releaseRequest.allReserveDetails do
		self.assertNotNullMsg(reserverDetail,"Reserve detail has not been created");
		self.assertEqualMsg(reserverDetail.totalRequested,1, "Total requested should be 1");//TFS 65496
		foreach ti in reserverDetail.allTrackedItems do
			self.assertEqualMsg(ti.id,UTCargoId1, "TrackItem should match");
		endforeach;
	endforeach;
	
	// create a release by type
	incomingJsonString := ReleaseByTypeWire;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	releaseRequest := self.getReleaseRequest(RelByType);
	self.assertNotNullMsg(releaseRequest, "Release request not created");
	self.assertEqualMsg(releaseRequest.status,BR_ACTIVE, "Release status should be Active");
	reserverDetail := releaseRequest.getReserveDetail();
	foreach reserverDetail in releaseRequest.allReserveDetails do
		self.assertNotNullMsg(reserverDetail,"Reserve detail has not been created");
	endforeach;
	self.assertEqualMsg(releaseRequest.allReserveDetails.size,1,"There should be two reserve details");
	
	// create a release by type multi items
	incomingJsonString := ReleaseByTypeMulti;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	releaseRequest := self.getReleaseRequest(RelByTypeMulti);
	self.assertNotNullMsg(releaseRequest, "Release request not created");
	self.assertEqualMsg(releaseRequest.allReserveDetails.size,2,"There should be two reserve details");
	count := 0;
	foreach reserverDetail in releaseRequest.allReserveDetails do
		count += 1;
		self.assertTrueMsg(reserverDetail.isReserveSelection, "Release Request by Type Detail not created as CM_ReserveSelection");
		reserveSelection := reserverDetail.CM_ReserveSelection;
		if count = 1 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "First Release Request Detail has invalid Cargo Type");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "STEEL COIL", "First Release Request Detail Cargo Type");
			self.assertNotNullMsg(reserveSelection.myProduct, "First Release Request Detail has invalid Cargo Sub-Type");
			self.assertEqualMsg(reserveSelection.myProduct.code, "TIEWIRE10G", "First Release Request Detail Cargo Sub-Type");
			self.assertEqualMsg(reserveSelection.totalRequested, 100, "First Release Request Detail Total Quantity Requested");
			self.assertEqualMsg(reserveSelection.quantitySelection, 50, "First Release Request Detail Quantity (Pieces) Requested");
		elseif count = 2 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Second Release Request Detail has invalid Cargo Type");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "CONT", "Second Release Request Detail Cargo Type");
			self.assertNotNullMsg(reserveSelection.myISOType, "Second Release Request Detail has invalid ISO Type");
			self.assertEqualMsg(reserveSelection.myISOType.code, "2200", "Second Release Request Detail ISO Type");
			self.assertEqualMsg(reserveSelection.totalRequested, 1, "Second Release Request Detail Total QUantity Requested");
		else
			self.assertTrueMsg(false, "Unit Test not updated correctly to handle more than 2 Release Request Details");
		endif;
	endforeach;
	
	
	// create a release by type with booking
	incomingJsonString := ReleaseWithBooking;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	releaseRequest := self.getReleaseRequest(RelWithBooking);
	self.assertNotNullMsg(releaseRequest, "Release request not created");
	self.assertNotNullMsg(releaseRequest.myBookingRefStock, "Booking ref is null");
	
	// release already exists
	/*incomingJsonString := ReleaseById;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :88815. Bulk Release REL61852 for requested date time 31 January 2024, 11:11:37 already exists.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	*/
	
	// release request has no cargo ids
	incomingJsonString := IncomingJsonString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", app.getErrorString(At_Least_One_CargoItem));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	
	// No id Test
	incomingJsonString := JsonNoIdString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", app.getErrorString(Input_req_release_number));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	
	// No release type
	incomingJsonString := JsonReleaseTypeString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", app.getErrorString(Input_required_field_reqtype));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	
	// No voyage test
	incomingJsonString := JsonNoVoyageString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", app.getErrorString(Input_required_field_voyage));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	
	// Release Request with invalid type
	incomingJsonString := ReleaseWithInvalidType;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", app.getErrorString1(Invalid_Release_Request_Type, BR_TYPE_UNKNOWN_STR));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
epilog
	self.setTerminalConfig(IsSubTerminalsOn, true);
	app.changeLogLevel(logLevel);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestDupCGIDs" id="7399cf23-9cae-46a9-ab31-2b9ffeced744">
        <updating/>
        <source>tPostSendEDIManifestDupCGIDs() updating;
/*

Purpose: 		

Parameters:			

Return Value:		

Date		Who		Reason
28.Sep.2023	navsp1 Initial creation TFS 60518
15.Nov.2023 navsp1 ChangeRequest 61127: EUP Voyage Operation screen showing incorrect cargo grouping 
---------------------------------------(scope changed - Unable to create duplicate CG's with different operator, reverting the duplicate CG's changes)

*/

constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "60518";
	VBSID2					= "605181";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON15";
	OperatorCode 			= "UT16";
	OperatorCode2			= "UT17";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "605186051801";
	EDIClientRef2 			= "605186051802";
	CargoGroup_ID           = "60518601.1";
	Bol_Ref1				= "UT60518";
	Bol_Ref2				= "UT60519";
	Container1				= "CNTU6051901";
	Container2				= "CNTU6051902";
	Container3				= "CNTU6051903";
	Container4				= "CNTU6051904";
vars
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, ediFile2,
	queuedEdiFile,
	ediFileItem  		: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata, edidata2	: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot, 
	vbs				 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator, operator2	: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	cgStrArray			: StringArray;
	workOrder 			: CM_WorkOrder;
	cgId, cgId2			: String;
	iter, iter2	, iter3	: Iterator;
	currentProcess 		: CM_VBSProcess;
	terminal 			: CM_Terminal;
	ti 					: CM_TrackedItem;
	binaryStringUpdate,
	incomingJsonStringUpdate: String;
	vbsTerminal 		: CM_VehicleBookingTerminal;
	vbsType 			: CM_VehicleBookingTimeSlotType;
	driverRequired 		: Boolean;
begin
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	vbsTerminal := terminal.myVehicleBookingTerminal;	
	
	//Set 'Driver required' to false
	driverRequired := self.setTerminalConfig(VsTruckDriverMand, false).Boolean;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	beginTransaction;
	terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);
	commitTransaction;

	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	//cleanup edi data2
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef2, iter);
	while iter.next(ediFile2) do
		if ediFile2.ediClientRef &lt;&gt; EDIClientRef2 then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile2.ediData, passport);
	endwhile;
	
	//Add Operator
	operator := self.getOperator(OperatorCode);
	if operator = null then
		operator := self.addOperatorSimple(OperatorCode, "Test Operator "&amp;OperatorCode);
	endif;	
	
	operator2 := self.getOperator(OperatorCode2);
	if operator2 = null then
		operator2 := self.addOperatorSimple(OperatorCode2, "Test Operator "&amp;OperatorCode);
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;

	// Delete the VBS Timeslot Type and any vehicle booking slots
	vbsType := terminal.allTerminalVBSSlotTypes[VBSID];
	if vbsType &lt;&gt; null then
		foreach vbs in vbsType.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById do
			if vbs.myVBTimeSlotType = vbsType then
				self.deleteVbsTimeSlotAdv(vbs.id);
			endif;
		endforeach;
		self.deleteVbsTimeslotType(VBSID);
	endif;
	
	vbsType := terminal.allTerminalVBSSlotTypes[VBSID2];
	if vbsType &lt;&gt; null then
		foreach vbs in vbsType.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById do
			if vbs.myVBTimeSlotType = vbsType then
				self.deleteVbsTimeSlotAdv(vbs.id);
			endif;
		endforeach;
		self.deleteVbsTimeslotType(VBSID2);
	endif;
	
	self.addVehicleBookingAdv(VBSID);
	self.addVehicleBookingAdv(VBSID2);
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel 1
	self.deleteVessel(Bol_Ref1);	
	vessel := self.addVesselCellularWithCode( Bol_Ref1, "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage 1
	self.deleteVoyage(Bol_Ref1);
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur(Bol_Ref1, Bol_Ref1, OperatorCode, shippingLineCode);	
	
	//Add vessel 2
	self.deleteVessel(Bol_Ref2);	
	vessel := self.addVesselCellularWithCode( Bol_Ref2, "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage 2
	self.deleteVoyage(Bol_Ref2);
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur(Bol_Ref2, Bol_Ref2, OperatorCode2, shippingLineCode);	
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	//Initialise EDI controller agent
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );
	
	//  1. Send message
	
	/////////////////
	
	//Send an update request
	binaryStringUpdate := self.zManifestDupCG("Create", EDIClientRef, OperatorCode, CargoGroup_ID ,Container1, Container2, Bol_Ref1, VBSID).Binary.base64EncodeNoCrLf;
	
	//Build JSON String
	incomingJsonStringUpdate := IncomingJsonStart &amp; EDIClientRef &amp; IncomingJsonMiddle &amp; binaryStringUpdate &amp; IncomingJsonTrailer;
	
	//Webservice call
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonStringUpdate, testScenarioName);	
	
	iter2 := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter2);
	while iter2.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; EDIClientRef then
			//self.assert
			return;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter2;
	self.assertNotNull(queuedEdiFile);	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);	
	ediFile := queuedEdiFile;
	
	
	/////////////////
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load DB failed" );	
	self.assertEqual(edidata.guid, "4d891511-76c7-4e06-86d2-2bf7f59c2e35");
	self.assertEqual(edidata.manifestNumber, EDIClientRef);
	self.assertNotNull(edidata.myGateDocument);
	self.assertEqual(edidata.receiver, "EBTA");
	self.assertEqual(edidata.statusString, "Create");
	self.assertEqual(edidata.type, "Manifest");
	self.assertNotNull(ediDataGateDoc);
	self.assertTrue(ediDataGateDoc.allEDITrackedItems.size &gt; 0);
	self.assertEqual(edidata.fileVersion, app.getErrorString(TransportManifest));
	self.assertEqual(edidata.operatorCode, OperatorCode);
	delete cgStrArray;
	create cgStrArray transient;
	
	//Verify TI Count
	foreach ediTi in ediDataGateDoc.allEDITrackedItems do
		
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			prenoteCount += 1;
		endif;
		
		if ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazCount += 1;
		endif;
		
		cgId := ediTi.getCargoGroupId;
		if cgId &lt;&gt; null and not cgStrArray.includes(cgId) then
			cgStrArray.add(cgId);
		endif;
		
		self.deleteCargo(ediTi.id, ediTi.cargoType);
		
	endforeach;
	
	//Erase cargo group, work order
	foreach cgId2 in cgStrArray do
		self.deleteCargoGroup(cgId2);		
	endforeach;
	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[edidata.manifestNumber];
	if workOrder &lt;&gt; null then
		beginTransaction;
			workOrder.erase(0);
		commitTransaction;
	endif;
	
	
	self.assertEqual(prenoteCount, 2);

	self.assertNotNullMsg(ediDataGateDoc, "No edidata has been created.");	
	
	self.assertEqualMsg(ediDataGateDoc.allEDITrackedItems.size, 2, "Number of tracked items created is unmatched");	
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(ediDataGateDoc.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	
	//2. Check load new message with same cargo group and different operator/ sender
	
	binaryStringUpdate := self.zManifestDupCG("Create", EDIClientRef2, OperatorCode2, CargoGroup_ID, Container3, Container4, Bol_Ref2, VBSID2).Binary.base64EncodeNoCrLf;
	
	//Build JSON String
	incomingJsonStringUpdate := IncomingJsonStart &amp; EDIClientRef2 &amp; IncomingJsonMiddle &amp; binaryStringUpdate &amp; IncomingJsonTrailer;
	
	//Webservice call
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonStringUpdate, testScenarioName);	
	
	iter3 := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef2, iter3);
	while iter3.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; EDIClientRef2 then
			//self.assert
			return;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter3;
	self.assertNotNull(queuedEdiFile);	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);	
	ediFile2 := queuedEdiFile;
	
	//Verify Data	
	self.assertEqualMsg( ediFile2.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata2	:= ediFile2.ediData.CM_EDIDataTransManifest;
	
	//EDI gate data
	ediDataGateDoc := edidata2.myGateDocument.CM_EDIDataGateDoc;
	self.assertEqualMsg( ediFile2.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load DB failed" );	
	self.assertEqual(edidata2.guid, "4d891511-76c7-4e06-86d2-2bf7f59c2e35");
	self.assertEqual(edidata2.manifestNumber, EDIClientRef2);
	self.assertNotNull(edidata2.myGateDocument);
	self.assertEqual(edidata2.receiver, "EBTA");
	self.assertEqual(edidata2.statusString, "Create");
	self.assertEqual(edidata2.type, "Manifest");
	self.assertNotNull(ediDataGateDoc);
	self.assertTrue(ediDataGateDoc.allEDITrackedItems.size &gt; 0);
	self.assertEqual(edidata2.fileVersion, app.getErrorString(TransportManifest));
	self.assertEqual(edidata2.operatorCode, OperatorCode2);
	delete cgStrArray;
	create cgStrArray transient;
	
	//Verify TI Count
	prenoteCount := 0;
	foreach ediTi in ediDataGateDoc.allEDITrackedItems do
		
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			prenoteCount += 1;
		endif;
		
		if ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazCount += 1;
		endif;
		
		cgId2 := ediTi.getCargoGroupId;
		if cgId2 &lt;&gt; null and not cgStrArray.includes(cgId2) then
			cgStrArray.add(cgId2);
		endif;
		
		self.deleteCargo(ediTi.id, ediTi.cargoType);
		
	endforeach;
	
	//Erase work order
	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[edidata2.manifestNumber];
	if workOrder &lt;&gt; null then
		beginTransaction;
			workOrder.erase(0);
		commitTransaction;
	endif;
	
	self.assertEqual(prenoteCount, 2);

	self.assertNotNullMsg(ediDataGateDoc, "No edidata has been created.");	
	
	self.assertEqualMsg(ediDataGateDoc.allEDITrackedItems.size, 2, "Number of tracked items created is unmatched");	
	
	self.ediVerify(ediFile2);
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "New file should be verified errors");			//15.Nov.2023 navsp1 TFS 61127 - Scope changed - Unable to create duplicate CG's with different operator
	self.assertExceptionRaised(Already_exists, null);
	/*  																																//15.Nov.2023 navsp1 TFS 61127
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(ediDataGateDoc.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile2);
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;*/
	
epilog
	self.setTerminalConfig(VsTruckDriverMand, driverRequired);
	// Set the VBS process back again
	beginTransaction;
	terminal.setMyVBSProcess(currentProcess);
	commitTransaction;
	delete ediControllerAgent;
	delete vbsTimeSlotItem;
	delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestOnsiteProc" id="a710cd6b-71cb-4b63-a6dd-26fcf66670c1">
        <updating/>
        <source>tPostSendEDIManifestOnsiteProc() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2023	navsp1	Initial creation TFS 58058

*/
constants
	IncomingJsonStart = '{
	"clientRef": "';
	
	IncomingJsonMiddle = '",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
	
	IncomingJsonTrailer = '"}';
	
	EDIClientRef = "ONSITE5805806";
	OperatorCode : String = "ZMMR";
	VesselId : String = "VESS_5805801";
	VoyageId : String = "VOY_5805801";
	ShipLine : String = "CMA";
	BlockStack : String = "BS580581";
	Cargo1 : String = "F308658059--A";
	Cargo2 : String = "F308658059--B";
	CargoGroupId : String = "58058-1-206";
	
vars
	cargoId1, 
	cargoId2, 
	cargoGroupId 			: String;
	ediFile 		: CM_EDIFile;
	operator 				: CM_Operator;
	vessel 					: CM_Vessel;
	voyage 					: CM_Voyage;
	bs 						: CM_BlockStack;
	ediConfig 				: CM_EDIConfig;
	iter					: Iterator;
	passport				: CM_Passport;
	edidata				: CM_EDIDataTransManifest;
	queuedEdiFile			: CM_EDIFile;
	ediDataOnsite			: CM_EDIDataCargoOnSite;
	terminal 				: CM_Terminal;
	existEdiData			: CM_EDIData;
begin
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	//create data for unit test
    operator := self.getOperator(OperatorCode);
	self.assertNotNullMsg(operator, "ZMMR Operator");
	
	//Delete Vessel/Voyage if exist
	self.deleteVoyage(VoyageId);
	self.deleteVessel(VesselId);
	// Create Vessel/Voyage
	vessel := self.addVesselGeneralCargo(VesselId, operator, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageId, VesselId,operator.code, ShipLine, 2);
	
	// create a block stack
	self.deleteTerminalArea(BlockStack);
	bs := self.getTerminalArea(BlockStack).CM_BlockStack;
	self.assertNullMsg(bs, "Block Stack " &amp; BlockStack &amp; " not deleted");
	bs := self.addBlockStack(BlockStack, null, null);
	self.assertNotNullMsg(bs, "Block Stack " &amp; BlockStack &amp; " not created");
	
	// delete the cargo group and cargo items
	cargoId1 := Cargo1;
	cargoId2 := Cargo2;
	cargoGroupId := CargoGroupId;
	self.deleteTrackedItem(cargoId1, true);
	self.deleteTrackedItem(cargoId2, true);
	self.deleteCargoGroup(cargoGroupId);
	
	self.opts.addAssoc("CargoGroupID", CargoGroupId);
	self.opts.addAssoc("CargoID1", Cargo1);
	self.opts.addAssoc("CargoID2", Cargo2);
	//  1. create new and check not db loaded case
	
	self.sendEDIRequestAndGetLoadedFile("Create", 	queuedEdiFile, BlockStack, EDIClientRef, VoyageId, "OnSite");
	self.opts.purge();
	
	//Verify Data	
	self.assertNotNull(queuedEdiFile);
	self.assertEqualMsg( queuedEdiFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	existEdiData := ediFile.ediData;
	self.assertNotNullMsg(edidata.myCargoOnSite, "Error, Onsite EDI data not created");
		
	//EDI gate data
	ediDataOnsite := edidata.myCargoOnSite.CM_EDIDataCargoOnSite;		
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataOnsite := edidata.myCargoOnSite;
	self.assertEqualMsg(ediDataOnsite.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	
	
	//2. Update Request
	queuedEdiFile := null;ediDataOnsite := null;ediFile := null; edidata := null;queuedEdiFile := null;
	
	self.opts.addAssoc("CargoGroupID", CargoGroupId);
	self.opts.addAssoc("CargoID1", Cargo1);
	self.opts.addAssoc("CargoID2", Cargo2);
	self.sendEDIRequestAndGetLoadedFile("Replace", 	queuedEdiFile, BlockStack, EDIClientRef, VoyageId, "OnSite");
	self.opts.purge();
	
	//Verify Data	
	self.assertNotNull(queuedEdiFile);
	self.assertEqualMsg( queuedEdiFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile 	:= queuedEdiFile;
	
	self.assertNotNullMsg(edidata.myCargoOnSite, "Error, Onsite EDI data not created");
		
	//EDI gate data
	ediDataOnsite := edidata.myCargoOnSite.CM_EDIDataCargoOnSite;		
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataOnsite := edidata.myCargoOnSite;
	self.assertEqualMsg(ediDataOnsite.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myCargoOnSite.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Existing file should be DB canceled");
	existEdiData := ediFile.ediData;
	
	//2. Cancel Request
	queuedEdiFile := null;ediDataOnsite := null;ediFile := null; edidata := null;queuedEdiFile := null;
	
	self.opts.addAssoc("CargoGroupID", CargoGroupId);
	self.opts.addAssoc("CargoID1", Cargo1);
	self.opts.addAssoc("CargoID2", Cargo2);
	self.sendEDIRequestAndGetLoadedFile("Cancel", 	queuedEdiFile, BlockStack, EDIClientRef, VoyageId, "OnSite");
	self.opts.purge();
	
	//Verify Data	
	self.assertNotNull(queuedEdiFile);
	self.assertEqualMsg( queuedEdiFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile 	:= queuedEdiFile;
	
	self.assertNotNullMsg(edidata.myCargoOnSite, "Error, Onsite EDI data not created");
		
	//EDI gate data
	ediDataOnsite := edidata.myCargoOnSite.CM_EDIDataCargoOnSite;		
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataOnsite := edidata.myCargoOnSite;
	self.assertEqualMsg(ediDataOnsite.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB Loaded");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myCargoOnSite.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Existing file should be DB canceled");
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRailCance" id="9c0538ea-3d8f-4684-8ded-0d398f4492f3">
        <source>tPostSendEDIManifestRailCance();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 June 2023	navra1	Initial creation for TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
28/02/2024		navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
13/03/2024		navlw1	Bug 62785: Added an assert for required by date to make sure its been set correctly
03 Feb 2025 	navlc30 JIRA 33862 Unit test UT_WebMasterTerminalAPI::tPostSendEDIManifestRailCance needs to be fixed

*/

constants
	
	IncomingJsonStart = '{
	"clientRef": "';
	
	IncomingJsonMiddle = '",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
	
	IncomingJsonTrailer = '"}';

	TrainCode : String = "UT-TR001";
	WagonCode1 : String = "UT-WAG-01";
	WagonClassCode : String = "00001";
	RailAreaId : String = "UT_RA1";
	OperatorCode : String = "UT97";
	CarrierCode : String = "UTCA1";
	VesselId			: String = "AOR";
	VoyageId			: String = "UT_VOY1";
	ShipLine			: String = "CMA";
	EDIClientRef = "REF-1";
vars
	incomingJsonString,
	testScenarioName	: String;	
	ediFile			: CM_EDIFile;
	operator : CM_Operator;
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;	
	wagonMaster : CM_WagonMaster;
	cargoType : CM_CargoType;
	carrier : CM_Carrier;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	voyage :CM_Voyage;
	arrivalTS :  TimeStamp;
	depTS :  TimeStamp;
	arrivalDate : Date;
	arrivalTime : Time;
	depDate : Date;
	depTime : Time;
	trainConsist : CM_EDIDataTrainConsist;
	transManifest : CM_EDIDataTransManifest;
	clientRef : String;
	now : TimeStamp;
	ediConfig : CM_EDIConfig;
	ediControllerAgent : CM_EDIControllerAgent;
	iter : Iterator;
	queuedEdiFile		: CM_EDIFile;
	ediFileItem			: CM_EDIFile;
	cancelMsgEdidata 			: CM_EDIDataTransManifest;
	cancelMsgEdiDataTrainCon : CM_EDIDataTrainConsist;
	cancelMsgEdiFile : CM_EDIFile;
	ediAgent : CM_EDIControllerAgent;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	woTiIds : StringArray;
	ti : CM_TrackedItem;
	initialIsCommodityRequired: Boolean;	
	
begin	
	///
	/// CLEAN UP and SETUP
	///

	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	ediConfig := self.getMyTerminal.myEdiConfig;

	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;

	//Erase cargo group, work order	
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);		//28/02/2024	navcs2	ChangeRequest 62250
	
	//create data for unit test
	operator  := self.getOperator(OperatorCode);
	if operator = null then
		operator := self.addOperatorSimple(OperatorCode, "Test Operator");		
	endif;	
	
	//create carrier
	carrier := self.getCarrier(CarrierCode);
	if carrier = null then
		create emailCarrierAddresses transient;
		carrier := self.addCarrier(CarrierCode, "Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
		self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
	endif;	
	
	//Delete Voyage if exist
	self.deleteVoyage(VoyageId);
	voyage := self.getVoyage(VoyageId);
	if voyage = null then
		voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);			
	endif;
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::estimatedDepartureDT.name, now);		 		
	commitTransaction;	

	//remove wagon if it exists
	foreach train in app.myPassport.myTerminal.allTrainsArrival do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;
	
	
	foreach train in app.myPassport.myTerminal.allTrainsOnTerminal do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;	
	
	train := app.myPassport.myTerminal.getNullTrain();
	wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
	if wagon = null then
		wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
	endif;
	if wagon &lt;&gt; null then
		self.deleteWagonAndAssociatedObjs(wagon);
	endif;			
	
	cargoType := self.getCargoType("Paper"); 											//03.02.2025 navlc30 #33862
	assertNotNull(cargoType);
	initialIsCommodityRequired := cargoType.isCommodityRequired;
	if initialIsCommodityRequired then 
		self.setCargoTypeCommodityRequired(cargoType, false);
	endif;	
	
	/**********************************************************/
	//TEST 1:  DBLOaded not loaded case		
	/**********************************************************/

	
	testScenarioName := "ManifestRail|SunnyDay";	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
		
	self.assertNotNull(ediFile);
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;	

	//TEST1: Cancel the loaded/non-db verified case
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCancel(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//EDI manifest data
	cancelMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	cancelMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	cancelMsgEdiDataTrainCon := cancelMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;
	
	cancelMsgEdidata.verifyEDIDataTIs(app.myPassport);
	cancelMsgEdidata.loadDB(true, app.myPassport);
	cancelMsgEdiDataTrainCon := cancelMsgEdidata.myTrainConsist;
	
	self.assertEqualMsg(cancelMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	//original message shoule be cancelled
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should be cancelled");

	//delete the existing edi data
	app.myTrxDA.trxDeleteEDIData(queuedEdiFile.ediData, app.myPassport);
	
	
	/**********************************************************/
	//TEST 2:  DBLOaded case		
	/**********************************************************/	
	
	//clean up last test data
	ediConfig := self.getMyTerminal.myEdiConfig;
	
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;
	
	//create new clientRef with updated time stamp
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
	
	self.assertNotNull(ediFile);
	
	//Reload the file
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;		
	
	//Verify EDI file and check status
	transManifest.verifyEDIDataTIs(app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_VERIFIED, "transManifest Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_VERIFIED, "trainConsist Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after verifyEDIDataTIs");	
	
	//Load DB EDI file and check status
	transManifest.loadDB(true, app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_DBLOADED, "transManifest Status is not DB Loaded after loadDB");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_DBLOADED, "trainConsist Status is not DB Loaded after loadDB");			
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after loadDB");		
	
	//check the WO created
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		// 28/02/2024	navcs2	ChangeRequest 62250
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR002"), "The WO all selected TIs does not have TR002");
	self.assertTrueMsg(woTiIds.includes("TR003"), "The WO all selected TIs does not have TR003");
	
	// navlw1 #62785
	self.assertTrueMsg(wo.requiredByDT &lt;&gt; null, "the required by date should not be null");
	
	delete woTiIds;
	
	//cancel the db loaded file 
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCancel(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//EDI manifest data
	cancelMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	cancelMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	cancelMsgEdiDataTrainCon := cancelMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;
	
	cancelMsgEdidata.verifyEDIDataTIs(app.myPassport);
	cancelMsgEdidata.loadDB(true, app.myPassport);
	cancelMsgEdiDataTrainCon := cancelMsgEdidata.myTrainConsist;
	
	self.assertEqualMsg(cancelMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	//original message shoule be cancelled
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should be cancelled");	

	/**********************************************************/
	//TEST3: Cancel a file which has received an item
	/**********************************************************/
	
	//clean up last test data
	ediConfig := self.getMyTerminal.myEdiConfig;	
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;
	
	//create new clientRef with updated time stamp
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
	
	self.assertNotNull(ediFile);
	
	//Reload the file
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;		
	
	//Verify EDI file and check status
	transManifest.verifyEDIDataTIs(app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_VERIFIED, "transManifest Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_VERIFIED, "trainConsist Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after verifyEDIDataTIs");	
	
	//Load DB EDI file and check status
	transManifest.loadDB(true, app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_DBLOADED, "transManifest Status is not DB Loaded after loadDB");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_DBLOADED, "trainConsist Status is not DB Loaded after loadDB");			
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after loadDB");		
	
	//check the WO created
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];			
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR002"), "The WO all selected TIs does not have TR002");
	self.assertTrueMsg(woTiIds.includes("TR003"), "The WO all selected TIs does not have TR003");	
	
	delete woTiIds;
	
	//cancel the db loaded file 
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCancel(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus = CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//make the train have an arrivalDT indicating that the train has arrived
	beginTransaction;
		train.setPropertyValue(CM_Train::arrivalDT.name, now);
	commitTransaction;
	
	//EDI manifest data
	cancelMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	cancelMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	cancelMsgEdiDataTrainCon := cancelMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;	
	
	self.ediDBLoad(cancelMsgEdiFile);	
	
	//expect error in the passport on verify
	self.assertTrueMsg(app.myPassport.allErrorWarnings.size() = 0, "There were errors in the passport");

	self.assertEqualMsg(cancelMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB Loaded");	
	
	//original message should NOT be cancelled, it should still be DB Loaded
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should Cancelled");	
	
	//clean up the WO created previously	
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		//28/02/2024	navcs2	ChangeRequest 62250
	if wo &lt;&gt; null then
		self.deleteWorkOrder(wo.id);
	endif;	

	app.myPassport.allTrxPostActions.purge();	// jlirs1 02 Apr 2024 this is just termporary till new deleteManifestData is loaded into wmast, I think that will fixit (05/03/2024	navcs2	ChangeRequest 58059[58497]: EUP | Manifest - Change of Transport Mode)
	
epilog
	delete emailCarrierAddresses;
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);			//28/02/2024	navcs2	ChangeRequest 62250
	delete ediControllerAgent;
	delete iter;
	delete ediAgent;
	delete woTiIds;
	if cargoType &lt;&gt; null and cargoType.isCommodityRequired &lt;&gt; initialIsCommodityRequired then					//03.02.2025 navlc30 #33862 
		self.setCargoTypeCommodityRequired(cargoType, initialIsCommodityRequired);
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRailCreat" id="a4f20016-0ba3-4d22-aee1-1184a7177f1c">
        <source>tPostSendEDIManifestRailCreat();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 June 2023	navra1	Initial creation for TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
28/02/2024		navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
13/03/2024		navlw1	Bug 62785: Added an assert for required by date to make sure its been set correctly
31/01/2025 		navec1	Unit test UT_WebMasterTerminalAPI::tPostSendEDIManifestRailCreat needs to be fixed - MTN-33864
*/

constants
	
	IncomingJsonStart = '{
	"clientRef": "';
	
	IncomingJsonMiddle = '",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
	
	IncomingJsonTrailer = '"}';

	TrainCode : String = "UT-TR001";
	WagonCode1 : String = "UT-WAG-01";
	WagonClassCode : String = "00001";
	RailAreaId : String = "UT_RA1";
	OperatorCode : String = "UT97";
	CarrierCode : String = "UTCA1";
	VesselId			: String = "AOR";
	VoyageId			: String = "UT_VOY1";
	ShipLine			: String = "CMA";
	EDIClientRef = "REF-1";	
vars
	incomingJsonString,
	testScenarioName	: String;	
	ediFile			: CM_EDIFile;
	operator : CM_Operator;
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;	
	wagonMaster : CM_WagonMaster;
	cargoType : CM_CargoType;
	carrier : CM_Carrier;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	voyage :CM_Voyage;
	arrivalTS :  TimeStamp;
	depTS :  TimeStamp;
	arrivalDate : Date;
	arrivalTime : Time;
	depDate : Date;
	depTime : Time;
	trainConsist : CM_EDIDataTrainConsist;
	transManifest : CM_EDIDataTransManifest;
	clientRef : String;
	now : TimeStamp;
	ediConfig : CM_EDIConfig;
	ediControllerAgent : CM_EDIControllerAgent;
	iter : Iterator;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	woTiIds : StringArray;
	ti : CM_TrackedItem;
	myCarrier : CM_Carrier;
	initialIsCommodityRequired: Boolean;
begin
	//new stuff
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	ediConfig := self.getMyTerminal.myEdiConfig;

	//make sure there is no WO with that name
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		// 28/02/2024	navcs2	ChangeRequest 62250
	if wo &lt;&gt; null then
		self.deleteWorkOrder(wo.id);	
	endif;
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;

	//Erase cargo group, work order	
	self.deleteCargoGroup("B003.00153");	
	self.deleteWorkOrder("B003.00153");
	
	//create data for unit test
	operator  := self.getOperator(OperatorCode);
	if operator = null then
		operator := self.addOperatorSimple(OperatorCode, "Test Operator");		
	endif;	
	
	//create carrier	
	carrier := self.getCarrier(CarrierCode);
	if carrier = null then
		create emailCarrierAddresses transient;
		carrier := self.addCarrier(CarrierCode, "Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
		self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
	endif;	
	
	//Delete Voyage if exist
	self.deleteVoyage(VoyageId);
	voyage := self.getVoyage(VoyageId);
	if voyage = null then
		voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);			
	endif;
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::estimatedDepartureDT.name, now);		 		
	commitTransaction;
	
	//remove wagon if it exists
	foreach train in app.myPassport.myTerminal.allTrainsArrival do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;
	
	
	foreach train in app.myPassport.myTerminal.allTrainsOnTerminal do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;		
	
	deleteCarrier("100E");
	myCarrier := self.addCarrier("100E", "carrier", null, false, true, true, null);
	self.assertNotNull(myCarrier);
	
	
	train := app.myPassport.myTerminal.getNullTrain();
	wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
	if wagon = null then
		wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
	endif;
	if wagon &lt;&gt; null then
		self.deleteWagonAndAssociatedObjs(wagon);
	endif;			
	
	// 31/Jan/2025 - navec1 - MTN-33864
	cargoType := self.getCargoType("Paper"); // "Paper" to be used in EDI test data created from self.zMinimalRailExampleCreate
	assertNotNull(cargoType);
	initialIsCommodityRequired := cargoType.isCommodityRequired;
	if initialIsCommodityRequired then 
		self.setCargoTypeCommodityRequired(cargoType, false);
	endif;
	
	testScenarioName := "ManifestRail|SunnyDay";	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
		
	self.assertNotNull(ediFile);
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;	
	
	//Verify EDI file and check status
	transManifest.verifyEDIDataTIs(app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_VERIFIED, "transManifest Status is not Verified after verifyEDIDataTIs" &amp; CrLf &amp; app.myPassport.getErrorsAndWarningsAsString());	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_VERIFIED, "trainConsist Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after verifyEDIDataTIs");	
	
	//Load DB EDI file and check status
	transManifest.loadDB(true, app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_DBLOADED, "transManifest Status is not DB Loaded after loadDB");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_DBLOADED, "trainConsist Status is not DB Loaded after loadDB");			
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after loadDB");	
	
	//check the WO created
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		// 28/02/2024	navcs2	ChangeRequest 62250
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR002"), "The WO all selected TIs does not have TR002");
	self.assertTrueMsg(woTiIds.includes("TR003"), "The WO all selected TIs does not have TR003");		
	
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	// navlw1 #62785
	self.assertTrueMsg(wo.requiredByDT &lt;&gt; null, "the required by date should not be null");
	
	self.deleteWorkOrder(wo.id);	
epilog

	//delete emailCarrierAddresses;
	//self.deleteCargoGroup("B003.00153");
	//self.deleteWorkOrder("B003.00153");
	delete ediControllerAgent;
	delete iter;
	delete woTiIds;
	// 31/Jan/2025 - navec1 - MTN-33864
	if cargoType &lt;&gt; null and cargoType.isCommodityRequired &lt;&gt; initialIsCommodityRequired then 
		self.setCargoTypeCommodityRequired(cargoType, initialIsCommodityRequired);  // rollback to initial value
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRailRepla" id="32d2f231-737b-467c-90bf-8fb410490851">
        <source>tPostSendEDIManifestRailRepla();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 June 2023	navra1	Initial creation for TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
28/02/2024		navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
13/03/2024		navlw1	Bug 62785: Added an assert for required by date to make sure its been set correctly
03 Feb 2025 	navtr3  Bug MTN-33863: Unit test UT_WebMasterTerminalAPI::tPostSendEDIManifestRailRepla needs to be fixed
*/

constants
	
	IncomingJsonStart = '{
	"clientRef": "';
	
	IncomingJsonMiddle = '",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
	
	IncomingJsonTrailer = '"}';

	TrainCode : String = "UT-TR001";
	WagonCode1 : String = "UT-WAG-01";
	WagonClassCode : String = "00001";
	RailAreaId : String = "UT_RA1";
	OperatorCode : String = "UT97";
	CarrierCode : String = "UTCA1";
	VesselId			: String = "AOR";
	VoyageId			: String = "UT_VOY1";
	ShipLine			: String = "CMA";
	EDIClientRef = "REF-1";
vars
	incomingJsonString,
	testScenarioName	: String;	
	ediFile			: CM_EDIFile;
	operator : CM_Operator;
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;	
	wagonMaster : CM_WagonMaster;
	cargoType : CM_CargoType;
	carrier : CM_Carrier;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	voyage :CM_Voyage;
	arrivalTS :  TimeStamp;
	depTS :  TimeStamp;
	arrivalDate : Date;
	arrivalTime : Time;
	depDate : Date;
	depTime : Time;
	trainConsist : CM_EDIDataTrainConsist;
	transManifest : CM_EDIDataTransManifest;
	clientRef : String;
	now : TimeStamp;
	ediConfig : CM_EDIConfig;
	ediControllerAgent : CM_EDIControllerAgent;
	iter : Iterator;
	queuedEdiFile		: CM_EDIFile;
	ediFileItem			: CM_EDIFile;
	replaceMsgEdidata 			: CM_EDIDataTransManifest;
	replaceMsgEdiDataTrainCon : CM_EDIDataTrainConsist;
	replaceMsgEdiFile : CM_EDIFile;
	ediAgent : CM_EDIControllerAgent;
	prenoteArrayIds : StringArray;
	ediTi : CM_EDITrackedItem;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	woTiIds : StringArray;
	ti : CM_TrackedItem;
	_estimatedDateTimeOfDeparture : String;
	prenoteUniqBookingSetting : Boolean;
	initialIsCommodityRequired: Boolean; //03.02.2025 navtr3 #33863
	
begin	
	///
	/// CLEAN UP and SETUP
	///

	create prenoteArrayIds transient;
	
	prenoteUniqBookingSetting := self.getTerminalConfig(PrenoteUniqBooking).Boolean;
	
	self.setTerminalConfig(PrenoteUniqBooking, false);
	
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	ediConfig := self.getMyTerminal.myEdiConfig;

	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;

	//Erase cargo group, work order	
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);		//28/02/2024	navcs2	ChangeRequest 62250
	
	//create data for unit test
	operator  := self.getOperator(OperatorCode);
	if operator = null then
		operator := self.addOperatorSimple(OperatorCode, "Test Operator");		
	endif;	
	
	//create carrier
	carrier := self.getCarrier(CarrierCode);
	if carrier = null then
		create emailCarrierAddresses transient;
		carrier := self.addCarrier(CarrierCode, "Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
		self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
	endif;	
	
	//Delete Voyage if exist
	self.deleteVoyage(VoyageId);
	voyage := self.getVoyage(VoyageId);
	if voyage = null then
		voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);			
	endif;
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::estimatedDepartureDT.name, now);		 		
	commitTransaction;	

	//remove wagon if it exists
	foreach train in app.myPassport.myTerminal.allTrainsArrival do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;
	
	
	foreach train in app.myPassport.myTerminal.allTrainsOnTerminal do
		wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
		if wagon = null then
			wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
		endif;
		if wagon &lt;&gt; null then
			self.deleteWagonAndAssociatedObjs(wagon);
		endif;		
	endforeach;	
	
	train := app.myPassport.myTerminal.getNullTrain();
	wagon := train.allWagonsByIdInward.getAtKeyGeq(WagonCode1);	
	if wagon = null then
		wagon := train.allWagonsByIdOutward.getAtKeyGeq(WagonCode1);	
	endif;
	if wagon &lt;&gt; null then
		self.deleteWagonAndAssociatedObjs(wagon);
	endif;
	
	//03.02.2025 navtr3 #33863
	cargoType := self.getCargoType("Paper");
	assertNotNull(cargoType);
	initialIsCommodityRequired := cargoType.isCommodityRequired;
	if initialIsCommodityRequired then 
		self.setCargoTypeCommodityRequired(cargoType, false);
	endif;
	
	/**********************************************************/
	//TEST 1:  DBLOaded not loaded case		
	/**********************************************************/
	
	testScenarioName := "ManifestRail|SunnyDay";	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;	
	
	self.assertNotNull(ediFile);
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;	

	//TEST1: Replace the loaded/non-db verified case
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleReplace(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//EDI manifest data
	replaceMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	replaceMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	replaceMsgEdiDataTrainCon := replaceMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;
	
	replaceMsgEdidata.verifyEDIDataTIs(app.myPassport);
	replaceMsgEdidata.loadDB(true, app.myPassport);
	replaceMsgEdiDataTrainCon := replaceMsgEdidata.myTrainConsist;
	
	self.assertEqualMsg(replaceMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	//original message shoule be cancelled
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should be cancelled");

	//make sure that the new items appear on the replaced edi data
	foreach ediTi in replaceMsgEdiDataTrainCon.allEDITrackedItems where ediTi.isKindOf(CM_EDIPrenoteTI)do
		prenoteArrayIds.add(ediTi.CM_EDIPrenoteTI.id);
	endforeach;
	
	self.assertTrueMsg(prenoteArrayIds.size() = 3, "The replaced EDI Data size is not 3 as expected in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR001"), "The replaced EDI Data does not have EDITI - TR001 in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR004"), "The replaced EDI Data does not have EDITI - TR004 in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR005"), "The replaced EDI Data does not have EDITI - TR005 in TEST1");		
	
	prenoteArrayIds.purge();
	
	//delete the existing edi data
	app.myTrxDA.trxDeleteEDIData(queuedEdiFile.ediData, app.myPassport);	
	
	//Erase cargo group, work order	
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);			//28/02/2024	navcs2	ChangeRequest 62250
	
	/**********************************************************/
	//TEST 2:  DBLOaded case		
	/**********************************************************/	
	
	//clean up last test data
	ediConfig := self.getMyTerminal.myEdiConfig;	
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;	
	
	//create new clientRef with updated time stamp
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
	
	self.assertNotNull(ediFile);
	
	//Reload the file
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);	
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;		
	
	//Verify EDI file and check status
	transManifest.verifyEDIDataTIs(app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_VERIFIED, "transManifest Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_VERIFIED, "trainConsist Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after verifyEDIDataTIs");	
	
	//Load DB EDI file and check status
	transManifest.loadDB(true, app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_DBLOADED, "transManifest Status is not DB Loaded after loadDB");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_DBLOADED, "trainConsist Status is not DB Loaded after loadDB");			
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after loadDB");
	
	//check the WO created
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		// 28/02/2024	navcs2	ChangeRequest 62250
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR002"), "The WO all selected TIs does not have TR002");
	self.assertTrueMsg(woTiIds.includes("TR003"), "The WO all selected TIs does not have TR003");	
	
	delete woTiIds;
	
	//replace the db loaded file 
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleReplace(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus =CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//EDI manifest data
	replaceMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	replaceMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	replaceMsgEdiDataTrainCon := replaceMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;
	
	replaceMsgEdidata.verifyEDIDataTIs(app.myPassport);
	replaceMsgEdidata.loadDB(true, app.myPassport);
	replaceMsgEdiDataTrainCon := replaceMsgEdidata.myTrainConsist;
	
	self.assertEqualMsg(replaceMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	//original message shoule be cancelled
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should be cancelled");
	
	//make sure that the new items appear on the replaced edi data
	foreach ediTi in replaceMsgEdiDataTrainCon.allEDITrackedItems where ediTi.isKindOf(CM_EDIPrenoteTI)do
		prenoteArrayIds.add(ediTi.CM_EDIPrenoteTI.id);
	endforeach;
	
	self.assertTrueMsg(prenoteArrayIds.size() = 3, "The replaced EDI Data size is not 3 as expected in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR001"), "The replaced EDI Data does not have EDITI - TR001 in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR004"), "The replaced EDI Data does not have EDITI - TR004 in TEST1");
	self.assertTrueMsg(prenoteArrayIds.includes("TR005"), "The replaced EDI Data does not have EDITI - TR005 in TEST1");		
	
	prenoteArrayIds.purge();	
	
	//check the WO has been replaced with the new items
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		//28/02/2024	navcs2	ChangeRequest 62250
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR004"), "The WO all selected TIs does not have TR002");
	self.assertTrueMsg(woTiIds.includes("TR005"), "The WO all selected TIs does not have TR003");	
	
	delete woTiIds;
	
	//delete the existing edi data
	app.myTrxDA.trxDeleteEDIData(queuedEdiFile.ediData, app.myPassport);	
	
	
	//Erase cargo group, work order	
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);		//28/02/2024	navcs2	ChangeRequest 62250

	/**********************************************************/
	//TEST3: Replace a file which has received an item
	/**********************************************************/
	
	//clean up last test data
	ediConfig := self.getMyTerminal.myEdiConfig;
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; clientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
	endwhile;	
	
	//create new clientRef with updated time stamp
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;	
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleCreate(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
	
	self.assertNotNull(ediFile);
	
	//Reload the file
	ediControllerAgent.reloadEDIFileForTerminal(ediFile, ediFile.ediData, app.myPassport);
	
	//Verify Data
	self.assertNotNull(ediFile);
	
	self.assertEqualMsg(ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );	
	
	self.verifyCntsOfTrnCnstEDIFile(ediFile);		
	
	transManifest := ediFile.ediData.CM_EDIDataTransManifest;
	trainConsist := ediFile.ediData.CM_EDIDataTransManifest.myTrainConsist;		
	
	//Verify EDI file and check status
	transManifest.verifyEDIDataTIs(app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_VERIFIED, "transManifest Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_VERIFIED, "trainConsist Status is not Verified after verifyEDIDataTIs");	
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after verifyEDIDataTIs");	
	
	//Load DB EDI file and check status
	transManifest.loadDB(true, app.myPassport);
	self.assertEqualMsg(transManifest.status, CM_EDIFile.EDI_STATUS_DBLOADED, "transManifest Status is not DB Loaded after loadDB");	
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_DBLOADED, "trainConsist Status is not DB Loaded after loadDB");			
	self.assertEqualMsg(app.myPassport.allErrorWarnings.size, 0, "Errors/Warnings present in passport after loadDB");		
	
	//check the WO has created properly
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR002"), "The WO all selected TIs does not have TR004");
	self.assertTrueMsg(woTiIds.includes("TR003"), "The WO all selected TIs does not have TR005");	
	
	delete woTiIds;
	
	//Replace the db loaded file 
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zMinimalRailExampleReplace(clientRef).Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);		
	
	//Reload the file
	ediFile := null;

	delete iter;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(clientRef, iter);
	
	while iter.next(ediFileItem) do
		if ediFileItem.ediClientRef &lt;&gt; clientRef then			
			break;
		elseif ediFileItem.fileStatus = CM_EDIFile.EDI_WEB_STATUS_QUEUED then
			queuedEdiFile := ediFileItem;
			break;			
		endif;
	endwhile;
	delete iter;
	self.assertNotNull(queuedEdiFile);
	
	//re-load file
	ediControllerAgent.reloadEDIFileForTerminal(queuedEdiFile, queuedEdiFile.ediData, app.myPassport);
	
	//make the train have an arrivalDT indicating that the train has arrived
	beginTransaction;
		train.setPropertyValue(CM_Train::arrivalDT.name, now);
	commitTransaction;
	
	//EDI manifest data
	replaceMsgEdidata := queuedEdiFile.ediData.CM_EDIDataTransManifest;
	replaceMsgEdiFile := queuedEdiFile;
	//EDI train consist data
	replaceMsgEdiDataTrainCon := replaceMsgEdidata.myTrainConsist.CM_EDIDataTrainConsist;
	
	self.ediDBLoad(replaceMsgEdiFile);	
	
	//dont expect error in the passport on verify
	self.assertTrueMsg(app.myPassport.allErrorWarnings.size() = 0, "There were  errors in the passport while trying to cancel a file");
	
	self.assertEqualMsg(replaceMsgEdiDataTrainCon.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be db loaded");	
	
	//original message should NOT be cancelled, it should still be DB Loaded
	self.assertEqualMsg(trainConsist.status, CM_EDIFile.EDI_STATUS_CANCELLED, "Original consist should still be cancelled");	
	
	//check the WO has not been affected, and is what it was before
	wo := app.myPassport.myTerminal.allWorkOrders[WagonCode1];		//28/02/2024	navcs2	ChangeRequest 62250
	//check if the WO had all what was expected
	woDtl := wo.allWoDtls.first();
	self.assertTrueMsg(woDtl.isKindOf(CM_WodReceive), "WODtl is not CM_WodReceive as expected");
	self.assertTrueMsg(woDtl.CM_WodReceive.myTrain.isKindOf(CM_NullTrain), "WODtl train is not null train as expected");
	create woTiIds  transient;
	foreach ti in woDtl.CM_WodReceive.allSelectedTIs do
		woTiIds.add(ti.id);		
	endforeach;
	self.assertTrueMsg(woTiIds.size() = 3, "The WO does not have 3 TIs as expected");
	self.assertTrueMsg(woTiIds.includes("TR001"), "The WO all selected TIs does not have TR001");
	self.assertTrueMsg(woTiIds.includes("TR004"), "The WO all selected TIs does not have TR004");
	self.assertTrueMsg(woTiIds.includes("TR005"), "The WO all selected TIs does not have TR005");	
	
	// navlw1 #62785
	self.assertTrueMsg(wo.requiredByDT &lt;&gt; null, "the required by date should not be null");
	
	delete woTiIds;	
	
epilog
	delete emailCarrierAddresses;
	self.deleteCargoGroup("B003.00153");
	self.deleteWorkOrder(WagonCode1);		//28/02/2024	navcs2	ChangeRequest 62250
	delete ediControllerAgent;
	delete iter;
	delete ediAgent;
	delete prenoteArrayIds;
	delete woTiIds;
	self.setTerminalConfig(PrenoteUniqBooking, prenoteUniqBookingSetting);				//set the terminal config back to what it was
	if cargoType &lt;&gt; null and cargoType.isCommodityRequired &lt;&gt; initialIsCommodityRequired then					//03.02.2025 navtr3 #33863 
		self.setCargoTypeCommodityRequired(cargoType, initialIsCommodityRequired);
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRoad" id="3f4b2df5-a5bc-4955-8540-ba4235ed009e">
        <updating/>
        <source>tPostSendEDIManifestRoad() updating;
//
// Purpose:	Common UT for CR's - 57807, 57805
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09 Jun 2023	navsp1		Initial creation TFS 57807
// 22 Jun 2023  navsp1      ChangeRequest 57805: EUP - Manifest Processing - Truck - Create
// 12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UT5701";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "136079402";
	HazardClassID			= "HAZRD";
vars
	binaryString 		: String;
	incomingJsonString,
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile				: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata				: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	clientRef 			: String;
	now 				: TimeStamp;
	cgStrArray			: StringArray;
	cgStr				: String;
	workOrder 			: CM_WorkOrder;
	workOrderDtl		: CM_WorkOrderDtl;
	cgObjArr , woObjArray: CM_ObjectArray;
	cgId				: String;
	iter				: Iterator;
	vbsProcess, currentProcess : CM_VBSProcess;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	hazardClass						: CM_HazardClass;
	driverRequired : Boolean;
	prof : JadeProfiler;
	ts : TimeStamp;
begin

	self.startProfiler(method.name, prof);   //for testing
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	//Set 'Driver required' to false
	driverRequired := self.setTerminalConfig(VsTruckDriverMand, false).Boolean;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;

	//Add Hazard
	hazardClass := self.addHazardClass(HazardClassID, "DO NOT USE - UNIT TEST", null, false); 
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	//Add Operator
	operator := self.getOperator("UT57");
	if operator = null then
		operator := self.addOperatorSimple("UT57", "Test Operator");
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel
	self.deleteVessel("UT57805");	
	vessel := self.addVesselCellularWithCode( "UT57805", "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage
	self.deleteVoyage("UT57805");
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur("UT57805", "UT57805", OperatorCode, shippingLineCode);		
	self.assertNotNullMsg(voyage, "Voyage has not been created"); // navlw1
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	//  1. create new and check not db loaded case
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "Road");
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load DB failed" );	
	self.assertEqual(edidata.guid, "4d891511-76c7-4e06-86d2-2bf7f59c2e35");
	self.assertEqual(edidata.manifestNumber, EDIClientRef);
	self.assertNotNull(edidata.myGateDocument);
	self.assertEqual(edidata.receiver, "EBTA");
	self.assertEqual(edidata.statusString, "Create");
	self.assertEqual(edidata.type, "Manifest");
	self.assertNotNull(ediDataGateDoc);
	self.assertTrue(ediDataGateDoc.allEDITrackedItems.size &gt; 0);
	self.assertEqual(edidata.fileVersion, app.getErrorString(TransportManifest));
	self.assertEqual(edidata.operatorCode, "UT57");
	
	delete cgStrArray;
	create cgStrArray transient;
	
	//Verify TI Count
	prenoteCount := 0;
	foreach ediTi in ediDataGateDoc.allEDITrackedItems discreteLock do
		
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			prenoteCount += 1;
		endif;
		
		if ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazCount += 1;
		endif;
		
		cgId := ediTi.getCargoGroupId;
		if cgId &lt;&gt; null and not cgStrArray.includes(cgId) then
			cgStrArray.add(cgId);
		endif;
		
		self.deleteCargo(ediTi.id, ediTi.cargoType);
		
	endforeach;
	
	
	//Erase cargo group, work order
	foreach cgId in cgStrArray do
		self.deleteCargoGroup(cgId);		
	endforeach;
	
	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[edidata.manifestNumber];
	if workOrder &lt;&gt; null then
		beginTransaction;
			workOrder.erase(0);
		commitTransaction;
	endif;
	
	
	self.assertEqual(prenoteCount, 37);
	self.assertEqual(hazCount, 4);

	self.assertNotNullMsg(ediDataGateDoc, "No edidata has been created.");	
	
	self.assertEqualMsg(ediDataGateDoc.allEDITrackedItems.size, 41, "Number of tracked items created is unmatched");	
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(ediDataGateDoc.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
epilog
	//self.setTerminalConfig(VsTruckDriverMand, driverRequired);
	// Set the VBS process back again
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
		commitTransaction;
	endif;
	delete ediControllerAgent;
	//delete vbsTimeSlotItem;
	//delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
	self.endProfiler(prof);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRoadCan" id="818eccac-1b5b-439b-b997-a8e776ff3202">
        <updating/>
        <source>tPostSendEDIManifestRoadCan() updating;
//
// Purpose:	To check the Road Cancel(Delete) message

//	Test Below scenarios :
//	1. Cancel an existing EDI Data (Loaded but not DB loaded)
//  2. Cancel an existing DB loaded EDI Data
 
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03 Jul 2023  navsp1      ChangeRequest 58055: EUP - Manifest Processing - Truck - Update/Cancel
// 12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UT5702";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "136079402";//Same as the manifest number
	VehicleId				= "58055";
vars
	binaryString,
	binaryStringUpdate	: String;
	incomingJsonString,
	incomingJsonStringUpdate,
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, 
	ediFileItem,
	existEdiFile,
	queuedEdiFile		: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata 			: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot, vbsTS: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	cgStrArray			: StringArray;
	workOrder 			: CM_WorkOrder;
	cgId				: String;
	existEdiData		: CM_EDIData;
	iter				: Iterator;
	vvr					: CM_VehicleVisitRecord;
	config 				: Integer;
    terminal 			: CM_Terminal;
	dualGate 			: CM_Gate;
	verifyCount			: Integer;
	bookingRequired		: Integer;
	vbsProcess, currentProcess : CM_VBSProcess;
	driverRequired : Boolean;
	prof : JadeProfiler;
begin
	//self.startProfiler(method.name, prof);   //for testing
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	//Set 'Driver required' to false
	driverRequired := self.setTerminalConfig(VsTruckDriverMand, false).Boolean;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;

	bookingRequired := self.setTerminalConfig(BookingRefRequired, BookingRequired_None).Integer;
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;

	//Add Operator
	operator := self.getOperator("UT57");
	if operator = null then
		operator := self.addOperatorSimple("UT57", "Test Operator");
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel
	self.deleteVessel("UT57805");	
	vessel := self.addVesselCellularWithCode( "UT57805", "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage
	self.deleteVoyage("UT57805");
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur("UT57805", "UT57805", OperatorCode, shippingLineCode);		
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	//  1. create new and check not db loaded case
	
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "Road");
	
	//Verify Data
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	existEdiData := ediFile.ediData;
	existEdiFile := ediFile;
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load DB failed" );	
	self.assertEqual(edidata.guid, "4d891511-76c7-4e06-86d2-2bf7f59c2e35");
	self.assertEqual(edidata.manifestNumber, "136079402");
	self.assertNotNull(edidata.myGateDocument);
	self.assertEqual(edidata.receiver, "EBTA");
	self.assertEqual(edidata.statusString, "Create");
	self.assertEqual(edidata.type, "Manifest");
	self.assertNotNull(ediDataGateDoc);
	self.assertTrue(ediDataGateDoc.allEDITrackedItems.size &gt; 0);
	self.assertEqual(edidata.fileVersion, app.getErrorString(TransportManifest));
	self.assertEqual(edidata.operatorCode, "UT57");
	create cgStrArray transient;
	//Verify TI Count
	foreach ediTi in ediDataGateDoc.allEDITrackedItems do
		
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			prenoteCount += 1;
		endif;
		
		if ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazCount += 1;
		endif;
		
		cgId := ediTi.getCargoGroupId;
		if cgId &lt;&gt; null and not cgStrArray.includes(cgId) then
			cgStrArray.add(cgId);
		endif;
		
		self.deleteCargo(ediTi.id, ediTi.cargoType);
		
	endforeach;
	
	//Erase cargo group, work order
	foreach cgId in cgStrArray do
		self.deleteCargoGroup(cgId);		
	endforeach;
	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[edidata.manifestNumber];
	if workOrder &lt;&gt; null then
		beginTransaction;
			workOrder.erase(0);
		commitTransaction;
	endif;
	
	self.assertEqual(prenoteCount, 37);
	self.assertEqual(hazCount, 4);

	self.assertNotNullMsg(ediDataGateDoc, "No edidata has been created.");	
	
	self.assertEqualMsg(ediDataGateDoc.allEDITrackedItems.size, 41, "Number of tracked items created is unmatched");	
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//  2. send request to "cancel" the just loaded/ not db loaded edi data
	
	self.sendEDIRequestAndGetLoadedFile("Cancel", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataGateDoc := edidata.myGateDocument;
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	self.assertEqualMsg(ediDataGateDoc.status, edidata.status, "1. Gate Doc has different status from TransManifest");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_CANCELLED, "New file should be DB loaded");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, existEdiData.status, "2. Gate Doc has different status from TransManifest");

	//delete the existing edi data
	app.myTrxDA.trxDeleteEDIData(queuedEdiFile.ediData, passport);
	
	
	// 3. Test cancel DB loaded EDI data 
	
	//Revoke cancelled existing edi data
	app.myTrxUA.trxSetEDIDataStatus(existEdiData, CM_EDIFile.EDI_STATUS_REVOKED);
	
	// Load DB exist edi data
	
	edidata	:= existEdiData.CM_EDIDataTransManifest;
	ediFile := existEdiFile;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataGateDoc := edidata.myGateDocument;
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	self.assertEqualMsg(ediDataGateDoc.status, edidata.status, "3. Gate Doc has different status from TransManifest");

	//Call delete the db loaded edi file
	
	self.sendEDIRequestAndGetLoadedFile("Cancel", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataGateDoc := edidata.myGateDocument;
	
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	self.assertEqualMsg(ediDataGateDoc.status, edidata.status, "4. Gate Doc has different status from TransManifest");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_CANCELLED, "New file should be DB loaded");
	
	//4. Check if an item already received
	
	// gate in the container with no carrier
	// set up the vehicle
	
	//Revoke cancelled existing edi data
	app.myTrxUA.trxSetEDIDataStatus(existEdiData, CM_EDIFile.EDI_STATUS_REVOKED);
	
	// Load DB exist edi data
	
	edidata	:= existEdiData.CM_EDIDataTransManifest;
	ediFile := existEdiFile;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataGateDoc := edidata.myGateDocument;
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	self.assertEqualMsg(ediDataGateDoc.status, edidata.status, "5. Gate Doc has different status from TransManifest");
	
	self.deleteVehicle(VehicleId);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.gateInPrenote(VehicleId, null, null, edidata.myGateDocument.allEDITrackedItems.first.id, dualGate);
	self.assertNotNull(vvr);
	queuedEdiFile := null;
	self.sendEDIRequestAndGetLoadedFile("Cancel", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	self.ediVerify(ediFile);
	self.assertTrue(app.myPassport.allErrors.size &gt; 0); //This will true if any errors
	
	ediDataGateDoc := edidata.myGateDocument;	
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "New file should be verified errors");
	self.assertEqualMsg(ediDataGateDoc.status, edidata.status, "6. Gate Doc has different status from TransManifest");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Existing file should be DB loaded");		
	
epilog
	self.setTerminalConfig(VsTruckDriverMand, driverRequired);
	// Set the VBS process back again
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
		commitTransaction;
	endif;
	self.setTerminalConfig(BookingRefRequired, bookingRequired);
	delete ediControllerAgent;
	delete vbsTimeSlotItem;
	delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
	//self.endProfiler(prof);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRoadRep" id="866e32cc-a7ee-4326-bb9d-11f615d80bc5">
        <updating/>
        <source>tPostSendEDIManifestRoadRep() updating;
//
// Purpose:	To check the Road Replace(Update) message

//	Test Below scenarios :
//	1. Replace an existing EDI Data (Loaded but not DB loaded)
//  2. Replace an existing DB loaded EDI Data
 
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03 Jul 2023  navsp1      ChangeRequest 58055: EUP - Manifest Processing - Truck - Update/Cancel
// 12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UT5703";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "136079402";//Same as the manifest number
	VehicleId				= "58055";
vars
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, 
	existEdiFile,
	queuedEdiFile		: CM_EDIFile;
	edidata 			: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	cgStrArray			: StringArray;
	workOrder 			: CM_WorkOrder;
	cgId				: String;
	existEdiData		: CM_EDIData;
	iter				: Iterator;
	vvr					: CM_VehicleVisitRecord;
	config 				: Integer;
    terminal 			: CM_Terminal;
	dualGate 			: CM_Gate;
	verifyCount			: Integer;
	vbsProcess, currentProcess : CM_VBSProcess;
	driverRequired : Boolean;
	prof     : JadeProfiler;
	folder   : String;
begin
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 20;
		prof.fileName := folder&amp;"\SP" &amp; '\'  &amp;" - tPostSendEDIManifestRoadRep - " &amp; app.actualTimeServer.getNumeralString() &amp; ".log";
		prof.clearMethodCache();
		prof.start;
	
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	//Set 'Driver required' to false
	driverRequired := self.setTerminalConfig(VsTruckDriverMand, false).Boolean;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;
	
	config:=  terminal.getConfig(BookingRefRequired).Integer;
	setTerminalConfig(BookingRefRequired, BookingRequired_None);
	
	self.deleteVehicle(VehicleId);
		
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;

	//Add Operator
	operator := self.getOperator("UT57");
	if operator = null then
		operator := self.addOperatorSimple("UT57", "Test Operator");
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel
	self.deleteVessel("UT57805");	
	vessel := self.addVesselCellularWithCode( "UT57805", "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage
	self.deleteVoyage("UT57805");
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur("UT57805", "UT57805", OperatorCode, shippingLineCode);		
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	//  1. create new and check not db loaded case
	
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "Road");
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	existEdiData := ediFile.ediData;
	existEdiFile := ediFile;
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, "Load DB failed" );	
	self.assertEqual(edidata.guid, "4d891511-76c7-4e06-86d2-2bf7f59c2e35");
	self.assertEqual(edidata.manifestNumber, "136079402");
	self.assertNotNull(edidata.myGateDocument);
	self.assertEqual(edidata.receiver, "EBTA");
	self.assertEqual(edidata.statusString, "Create");
	self.assertEqual(edidata.type, "Manifest");
	self.assertNotNull(ediDataGateDoc);
	self.assertTrue(ediDataGateDoc.allEDITrackedItems.size &gt; 0);
	self.assertEqual(edidata.fileVersion, app.getErrorString(TransportManifest));
	self.assertEqual(edidata.operatorCode, "UT57");
	create cgStrArray transient;
	//Verify TI Count
	foreach ediTi in ediDataGateDoc.allEDITrackedItems do
		
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			prenoteCount += 1;
		endif;
		
		if ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazCount += 1;
		endif;
		
		cgId := ediTi.getCargoGroupId;
		if cgId &lt;&gt; null and not cgStrArray.includes(cgId) then
			cgStrArray.add(cgId);
		endif;
		
		//self.deleteCargo(ediTi.id, ediTi.cargoType);
		
	endforeach;
	
	//Erase cargo group, work order
	//foreach cgId in cgStrArray do
	//	self.deleteCargoGroup(cgId);		
	//endforeach;
	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[edidata.manifestNumber];
	if workOrder &lt;&gt; null then
		beginTransaction;
			//workOrder.erase(0);
		commitTransaction;
	endif;
	
	self.assertEqual(prenoteCount, 37);
	self.assertEqual(hazCount, 4);

	self.assertNotNullMsg(ediDataGateDoc, "No edidata has been created.");	
	
	self.assertEqualMsg(ediDataGateDoc.allEDITrackedItems.size, 41, "Number of tracked items created is unmatched");	
	
	//edidata.verifyEDIDataTIs(passport);
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//  2. send request to "Replace" the just loaded/ not db loaded edi data
	
	//Send an update request
	self.sendEDIRequestAndGetLoadedFile("Replace", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	//EDI manifest data
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;		
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	ediDataGateDoc := edidata.myGateDocument;
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_CANCELLED, "New file should be DB loaded");

	existEdiData := edidata;
	existEdiFile := edidata.myEDIFile;
	return;
	// 3. Call Replace the db loaded edi file
	
	//Send an update request
	queuedEdiFile := null;
	self.sendEDIRequestAndGetLoadedFile("Replace", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	//EDI manifest data
	edidata := null; ediFile := null;
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);
	
	//EDI gate data
	ediDataGateDoc := edidata.myGateDocument.CM_EDIDataGateDoc;
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_DBLOADED, "New file should be DB loaded");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_CANCELLED, "New file should be DB loaded");
	
	existEdiData := edidata;
	
	
	//4. Check if an item already received
	
	// gate in the container with no carrier
	// set up the vehicle
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.gateInPrenote(VehicleId, null, null, edidata.myGateDocument.allEDITrackedItems.first.id, dualGate);
	self.assertNotNull(vvr);
	
	
	queuedEdiFile := null;
	self.sendEDIRequestAndGetLoadedFile("Replace", queuedEdiFile, VBSID, EDIClientRef, null, "Road");
	
	
	edidata	:= queuedEdiFile.ediData.CM_EDIDataTransManifest;
	ediFile := queuedEdiFile;
	
	self.ediVerify(ediFile);

	self.assertTrue(app.myPassport.allErrors.size &gt; 0); //This will true if any errors
	
	ediDataGateDoc := edidata.myGateDocument;	
	
	self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "New file should be verified errors");
	self.assertEqualMsg(existEdiData.CM_EDIDataTransManifest.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Existing file should be DB loaded");		
	
epilog
	//self.setTerminalConfig(VsTruckDriverMand, driverRequired);
	//setTerminalConfig(BookingRefRequired, config);	

	if prof &lt;&gt; null then
		prof.report;
	endif;
	
	// Set the VBS process back again
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
		commitTransaction;
	endif;
	
	//delete ediControllerAgent;
	delete vbsTimeSlotItem;
	delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestRoadVBS" id="21bebfe1-325f-409e-84a8-bd1e8e3ddf42">
        <updating/>
        <source>tPostSendEDIManifestRoadVBS() updating;
//
// Purpose:	Make sure the VBS items not deleting while updating multiple manifest messages.
//			Cargo removes from VBS with multiple manifest messages
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05 Mar 2024	navsp1		Initial creation TFS 61039

constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UTSP43";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "MANRD27MAY2024001";
	EDIClientRef2			= "MANRD27MAY2024002";
	HazardClassID			= "HAZRD";
	ItemID_1 				= "SP27MAY2401";
	ItemID_2 				= "SP27MAY2402";
	ItemID_3 				= "SP27MAY2403";
	ItemID_4 				= "SP27MAY2404";
vars
	binaryString 		: String;
	incomingJsonString,
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, ediFile2	: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata, edidata2	: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	clientRef 			: String;
	now 				: TimeStamp;
	cgStrArray			: StringArray;
	cgStr				: String;
	workOrder 			: CM_WorkOrder;
	workOrderDtl		: CM_WorkOrderDtl;
	cgObjArr , woObjArray: CM_ObjectArray;
	cgId				: String;
	iter				: Iterator;
	vbsProcess, currentProcess : CM_VBSProcess;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	hazardClass						: CM_HazardClass;
	vbs	: CM_VehicleBookingTimeSlot;
	slot : CM_VehicleBookingTimeSlot;
	slotItem : CM_VehicleBookingTimeSlotItem;
	itemsArray : StringArray;
	prenoteUniqBooking : Boolean;//UT fix navsp1 24.May.24
	driverRequired : Boolean;
begin
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;

	//Set 'Driver required' to false
	driverRequired := self.setTerminalConfig(VsTruckDriverMand, false).Boolean;
	
	prenoteUniqBooking := terminal.getConfig( PrenoteUniqBooking ).Boolean; //UT fix navsp1 24.May.24
	beginTransaction;														//UT fix navsp1 24.May.24
	terminal.setConfig(PrenoteUniqBooking, false);							//UT fix navsp1 24.May.24
	commitTransaction;														//UT fix navsp1 24.May.24
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;
	
	//Delete VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	if slot &lt;&gt; null then
		self.deleteVbsTimeSlotAdv(slot.id);
	endif;
	
	//Add Hazard
	//hazardClass := self.addHazardClass(HazardClassID, "DO NOT USE - UNIT TEST", null, false); 
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef2, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef2 then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	//Add Operator
	operator := self.getOperator("UT57");
	if operator = null then
		operator := self.addOperatorSimple("UT57", "Test Operator");
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel
	self.deleteVessel("UTSP001");	
	vessel := self.addVesselCellularWithCode( "UTSP001", "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage
	self.deleteVoyage("UTSP001");
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur("UTSP001", "UTSP001", OperatorCode, shippingLineCode);		
	self.assertNotNullMsg(voyage, "Voyage has not been created"); // navlw1
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	//  1. create new and check not db loaded case
	self.opts.addAssoc("FirstItem",ItemID_1);
	self.opts.addAssoc("SecondItem", ItemID_2);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "RoadVBSItems");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 2, "This Vehicle booking Should have 2 items");
	
	//  2. create new and check not db loaded case
	self.opts.addAssoc("FirstItem",ItemID_3);
	self.opts.addAssoc("SecondItem", ItemID_4);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile2, VBSID, EDIClientRef2, null, "RoadVBSItems");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile2.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata2	:= ediFile2.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile2);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata2.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile2);
	self.assertEqualMsg(edidata2.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	//3.Call update for the first manifest
	self.opts.addAssoc("FirstItem",ItemID_1);
	self.opts.addAssoc("SecondItem", ItemID_2);
	self.sendEDIRequestAndGetLoadedFile("Replace", ediFile, VBSID, EDIClientRef, null, "RoadVBSItems");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	create itemsArray transient;
	foreach slotItem in slot.allVehicleBookingItems do
		itemsArray.add(slotItem.myTrackedItem.id);
	endforeach;
	
	self.assertTrue(itemsArray.includes(ItemID_1));
	self.assertTrue(itemsArray.includes(ItemID_2));
	self.assertTrue(itemsArray.includes(ItemID_3));
	self.assertTrue(itemsArray.includes(ItemID_4));
	
epilog	
	self.setTerminalConfig(VsTruckDriverMand, driverRequired);
	delete itemsArray;
	// Set the VBS process back again
	beginTransaction;
		terminal.setMyVBSProcess(currentProcess);
		terminal.setConfig(PrenoteUniqBooking, prenoteUniqBooking);//UT fix navsp1 24.May.24
	commitTransaction;
	
	delete ediControllerAgent;
	//delete vbsTimeSlotItem;
	//delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostSendEDIManifestSea" id="a25b6a04-2126-4e8b-be1a-858755d648c0">
        <source>tPostSendEDIManifestSea();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2023	jlirs1	Initial creation

*/

vars
	prof : JadeProfiler;
begin
	//self.startProfiler(method.name, prof);
//	app.setPassBackExceptions(true, true);
	self.ediManifestSeaCreate(true);
	self.ediManifestSeaCancel(true);
	self.ediManifestSeaReplace1(true);
	self.ediManifestSeaReplace2(true);
	//self.ediManifestSeaCreate(false);
	//self.ediManifestSeaCancel(false);
	//self.ediManifestSeaReplace1(false);
	//self.ediManifestSeaReplace2(false);
epilog
