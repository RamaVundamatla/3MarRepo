<Class name="CM_KPIShipVisitDtl" id="29bf4f71-db4e-4e4c-8671-bc034c04b6b5">
    <superclass name="CM_KPIVisitDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <PrimAttribute name="berth" id="9315b476-35c3-4d82-b524-aae0b9ae6497">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="voyage" id="20672ab6-6a2a-4fe5-bc0a-4989ad4279d3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayString" id="cf8f4f20-584c-47fa-b95d-83abdbb8a0a2">
        <source>displayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2012	cnwdw1	Initial creation
*/
vars

begin
	return inheritMethod() &amp; " Berth: " &amp; berth &amp; " Voyage: " &amp; voyage ;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyage" id="24497e70-752f-4c58-b650-c32102c3876e">
        <updating/>
        <source>setFromVoyage(_voyage: CM_Voyage) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2012	cnwdw1	Initial creation
*/
vars

begin
	self.startTime := _voyage.shipExchangeDate;
	//self.finishTime := _voyage.departedDT;
	self.voyage := _voyage.code;
	self.berth := _voyage.vesselName;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
