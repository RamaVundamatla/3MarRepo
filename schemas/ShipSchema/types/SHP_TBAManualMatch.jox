    <JadeMethod name="doTBlDataClick" id="3b4d02a8-b4dc-4209-834b-19646d3b7ade">
        <source>doTBlDataClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars

	ti : CM_TrackedItem;
begin
	self.highlightDifferent(null);
	
	if self.tblData.row &gt; self.tblData.fixedRows then
		ti := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
		
		if ti &lt;&gt; null then
			self.highlightDifferent(ti);
		endif;
	endif;
	
	
epilog

end;</source>
