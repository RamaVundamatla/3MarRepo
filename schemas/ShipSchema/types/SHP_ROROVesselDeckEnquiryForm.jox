    <JadeMethod name="initDetails" id="3ad99bca-d438-4d56-a6d1-74fd46ccd4fb">
        <updating/>
        <source>initDetails(_roroStructure: CM_Object input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	self.myROROVesselStructure:=_roroStructure.CM_ROROVesselStructure;
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDeckSorting.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="_roroStructure" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="64277ad0-ba6b-47de-b030-795eb3680084">
