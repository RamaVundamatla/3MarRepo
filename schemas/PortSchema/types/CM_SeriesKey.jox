    <JadeMethod name="createNext" id="1c1d2a53-a9a3-4ff4-934d-108f08e0d46a">
        <updating/>
        <source>createNext():CM_SeriesKey updating;
// Creates a clone of existing CM_SeriesKey object
// and returns this to caller, incrementing root by 1.
vars
	newSk:CM_SeriesKey;
begin
	create newSk;
	newSk.setForUpdate(self.parent, self.prefix, self.root + 1, self.suffix, null);
	return newSk;
end;</source>
        <ReturnType type="CM_SeriesKey"/>
    </JadeMethod>
    <JadeMethod name="isMatch" id="632a4380-5964-4966-a944-a093d3585122">
        <source>isMatch(keyMask : CM_SeriesKey) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			Returns true if the values in the VB_CM_SeriesKey matches the instance variables
							in the SeriesKey object.  Blank or 0 is treated as a wildcard. Converted from C++ proxy code
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	isMatch : Boolean;
begin
	// Conditionally test each key value...
	if keyMask.internetCode.trimBlanks &lt;&gt; null then
		if (self.internetCode &lt;&gt; keyMask.internetCode) then
    		return false;
		endif;
	endif;


	if keyMask.prefix.trimBlanks &lt;&gt; null then
		if (self.prefix &lt;&gt; keyMask.prefix) then
    		return false;
		endif;
	endif;

	if keyMask.root &gt; 0 then
		if self.root &lt;&gt; keyMask.root then
    		return false;
		endif;
	endif;

	if keyMask.suffix.trimBlanks &lt;&gt; null then
		if (self.suffix &lt;&gt; keyMask.suffix) then
    		return false;
		endif;
	endif;

	if keyMask.userCode.trimBlanks &lt;&gt; null then
		if (self.userCode &lt;&gt; keyMask.userCode) then
    		return false;
		endif;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="keyMask" type="CM_SeriesKey"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReserved" id="c8327831-0467-46e8-9338-954dc62fc3d8">
        <source>isReserved():Boolean;
begin
	return internetCode &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="release" id="3b999f3f-f1de-481a-a18c-49af8627cfc6">
        <updating/>
        <source>release() updating;
begin
	internetCode := null;
	userCode := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="reserve" id="a4de6d6d-5480-4ff8-b741-938c1af299eb">
        <updating/>
        <source>reserve(compStr : String; keySeries : CM_KeySeries; userStr:String) updating;
/*
 ------------------------------------------------------------------------
Created:			13 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	self.internetCode := compStr;
	self.parent := keySeries;
	self.userCode := userStr;
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="keySeries" type="CM_KeySeries"/>
        <Parameter name="userStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="372679f4-5fa3-46a2-8378-d3ee62688476">
        <updating/>
        <source>set(_prefix : String; _root : Integer)updating;
//--------------------------------------------------------------
//Created: 20 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.prefix := _prefix;
	self.root	:= _root;
end;</source>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_root" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="81843428-57af-4430-ad0d-309ae586e4a0">
        <updating/>
        <source>setForCreate(keySeries : CM_KeySeries) updating;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			Basically init the root.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.root := 1;
	self.parent := keySeries;
end;</source>
        <Parameter name="keySeries" type="CM_KeySeries"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="92613fb8-6216-4221-b7dd-48bd8724bd99">
        <updating/>
        <source>setForUpdate(_parent: CM_KeySeries; _prefix: String; _root : Integer; _suffix : String; _userCode : String) updating;
/*
------------------------------------------------------------------------
Created:			07 July 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	self.prefix := _prefix;
	self.suffix := _suffix;
	self.root   := _root;
	self.parent := _parent;
end;</source>
        <Parameter name="_parent" type="CM_KeySeries"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_root" type="Integer"/>
        <Parameter name="_suffix" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setParent" id="9964be1d-f03d-40a0-867f-a967e6e306b9">
        <updating/>
        <source>setParent(_parent: CM_KeySeries) updating;
/*
------------------------------------------------------------------------
Created:			07 July 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	self.parent := _parent;
end;</source>
        <Parameter name="_parent" type="CM_KeySeries"/>
    </JadeMethod>
