    <JadeMethod name="setupForm" id="0fe0a165-f851-4b63-90e9-ac6e2c86863c">
        <updating/>
        <source>setupForm() updating;
/*
	Created on 04 February 2008
	
	by Debby Hutchison
	
	Purpose:
 04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
*/
begin
	
	inheritMethod();

	if self.useBookingSumView then
		self.allowNext :=false;
		self.allowUpdate:=true;
		self.allowAdd:=true;
		//self.allowMultiSelectEdit:=false;						//-cnwml2 PAR20173 SFW CCMS 1091
		//self.allowMultiSelectDelete:=false;					//-cnwml2 PAR20173 SFW CCMS 1091
		self.allowMultiSelectEdit := true;
		self.allowMultiSelectDelete := true;
	endif;
	
	self.setupTextTable();
	self.setFilterDefaults();
	self.frmSearch.height := self.tblSearch.height + 40;  //for toolbar
	self.btnInstruction.enabled := false;		//04.10.2022 navtnr20 TFS 54967
end;</source>
