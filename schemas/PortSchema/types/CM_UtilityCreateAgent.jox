    <JadeMethod name="utlCreateCreditFromInvoice" id="2472db45-92e9-49d8-ab2c-16e386a7dec9">
        <source>utlCreateCreditFromInvoice(_allInvoice : CM_InvoiceSet; _pxyCreditNote : CM_Invoice input; _pNewCreditNote : CM_Invoice output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navkc1	Initial creation TFS CR 55305 Task 55533: Jade - Invoice Credit Note Jade Code
24/01/2023		navkc1	TFS CR 55305 Task 55535: Jade - Invoice Credit Note Audits
20/07/2023		navkc1	Bug 58995: EUP - Inv Maint Credit Notes
*/

vars
	invoice 			: CM_Invoice;
	firstInvDone, isTAS		: Boolean;
	invoiceLine,
	newInvoiceLine		: CM_InvoiceLine;
	pendingStatus		: Integer;
	allInvoiceToLink	: CM_InvoiceSet;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	foreach invoice in _allInvoice do
		app.myValCA.valCreditNoteFromInvoice(invoice);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	pendingStatus := CM_InvoiceLine.STATUS_NORMAL;
	
	create allInvoiceToLink transient;
	
	foreach invoice in _allInvoice do
		// ### TFS CR 58085 TASK 61349 11JAN2024 NAVAB1 - auto void all lines on a TAS invoice being linked to a new credit note
		isTAS := invoice.isTASInvoice();
		if isTAS then
			foreach invoiceLine in invoice.invoiceLines discreteLock do
				invoiceLine.setStatus(CM_InvoiceLine.STATUS_VOIDED);
			endforeach;		
		endif;
		// When processing the first invoice, we want to copy the invoice details as well as the invoice line details.
		if not firstInvDone then
			_pNewCreditNote := invoice.cloneForCopy();
			firstInvDone := true;
			
		// For other invoices, we only want to invoice line details.
		else
			foreach invoiceLine in invoice.invoiceLines discreteLock do
				newInvoiceLine := invoiceLine.cloneForReturn(_pNewCreditNote, false);
				newInvoiceLine.invoice := _pNewCreditNote;
				
				// ### TFS CR 58085 TASK 61349 11JAN2024 NAVAB1 - auto void all lines on a TAS invoice being linked to a new credit note
				if isTAS then
					newInvoiceLine.setStatus(CM_InvoiceLine.STATUS_VOIDED);
				endif;
			endforeach;
		endif;
		
		//	24/01/2023	navkc1	TFS CR 55305 Task 55535
		if _passport.noErrors() then
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, true);
		endif;
		
		if _passport.noErrors() then
			//invoice.setMyOtherInvoice(_pNewCreditNote); //16/10/2024	navkc1	JIRA Bug MTN-12541
			//16/10/2024	navkc1	JIRA Bug MTN-12541 - When creating credit Note from invoice, it now do the "link" but adding it to allCreditInvoices collection
			//16/10/2024	navkc1	JIRA Bug MTN-12541 - CM_Invoice.myOtherInvoice is now set only when copying invoices/credit notes
			_pNewCreditNote.allCreditInvoices.tryAdd(invoice);
		endif;
		
		//	24/01/2023	navkc1	TFS CR 55305 Task 55535
		if _passport.noErrors() then
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
			invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
		endif;
	endforeach;
	
	_pNewCreditNote.setCategory(InvoiceCategory_CreditNote);
	if _pxyCreditNote &lt;&gt; null then
		//20/07/2023		navkc1	Bug 58995
		_pNewCreditNote.setCreditNoteFromInvoice(_pxyCreditNote.debtor, _pxyCreditNote.invoiceType, _pxyCreditNote.status, _pxyCreditNote.myBillingAddress, _pxyCreditNote.fromDT);
	endif;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	_pNewCreditNote.setTaxDetailsFromLines();
	_pNewCreditNote.setTotalAmountFromLines();
	
	
	//	24/01/2023	navkc1	TFS CR 55305 Task 55535
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_pNewCreditNote);
	endif;
	
	if _passport.noErrors() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceCreate), false, _pNewCreditNote);
	endif;
	
epilog
	delete allInvoiceToLink;
end;</source>
        <Parameter name="_allInvoice" type="CM_InvoiceSet"/>
        <Parameter name="_pxyCreditNote" type="CM_Invoice" usage="input"/>
        <Parameter name="_pNewCreditNote" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCreditNoteManual" id="298e59ef-d9de-460d-b8cb-349947c1a5d2">
        <source>utlCreateCreditNoteManual(_allInvoice : CM_InvoiceSet; _pxyCreditNote : CM_Invoice input; _pNewCreditNote : CM_Invoice output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	invoice 			: CM_Invoice;
	invoiceLine,
	newInvoiceLine		: CM_InvoiceLine;
	isTAS : Boolean;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	foreach invoice in _allInvoice do
		app.myValCA.valCreditNoteFromInvoice(invoice);
	endforeach;
	
	app.myValCA.valInvoiceManual(_pxyCreditNote);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _pNewCreditNote persistent;
	
	foreach invoice in _allInvoice do
		isTAS := invoice.isTASInvoice();
		foreach invoiceLine in invoice.invoiceLines discreteLock do
			newInvoiceLine := invoiceLine.cloneForReturn(_pNewCreditNote, false);
			newInvoiceLine.invoice := _pNewCreditNote;
			
			// ### TFS CR 58085 TASK 61349 11JAN2024 NAVAB1 - auto void all lines on a TAS invoice being linked to a new credit note
			if isTAS then
				invoiceLine.setStatus(CM_InvoiceLine.STATUS_VOIDED);
			endif;
		endforeach;
		
		if _passport.noErrors() then
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, true);
		endif;
		
		if _passport.noErrors() then
			//invoice.setMyOtherInvoice(_pNewCreditNote); //16/10/2024	navkc1	JIRA Bug MTN-12541
			//16/10/2024	navkc1	JIRA Bug MTN-12541 - When creating credit Note manually and linking it to invoice, it now do the "link" but adding it to allCreditInvoices collection
			//16/10/2024	navkc1	JIRA Bug MTN-12541 - CM_Invoice.myOtherInvoice is now set only when copying invoices/credit notes
			_pNewCreditNote.allCreditInvoices.tryAdd(invoice); //16/10/2024	navkc1	JIRA Bug MTN-12541
		endif;
		
		if _passport.noErrors() then
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
			invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
		endif;
	endforeach;
	
	_pNewCreditNote.setForCreate(_pxyCreditNote);

	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	_pNewCreditNote.setTaxDetailsFromLines();
	_pNewCreditNote.setTotalAmountFromLines();
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_pNewCreditNote);
	endif;
	
	if _passport.noErrors() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceCreate), false, _pNewCreditNote);
	endif;
epilog

end;</source>
        <Parameter name="_allInvoice" type="CM_InvoiceSet"/>
        <Parameter name="_pxyCreditNote" type="CM_Invoice" usage="input"/>
        <Parameter name="_pNewCreditNote" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
