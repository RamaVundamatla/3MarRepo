    </JadeMethod>
    <JadeMethod name="getTerminalRTDeviceFromIniFile" id="6d3bb45b-0a2d-4d17-9257-24693ba9d14f">
        <updating/>
        <source>getTerminalRTDeviceFromIniFile() updating;

/*

Purpose:		Get the values from the ini file	

Parameters:			

Return Value:		


Date			Who		Reason
30 August 2011	cnwmh5	Initial creation #28091

*/

vars

	machine 				: CM_Machine;

begin
	
	self.myTerminal := app.myRoot.allTerminals[app.terminalIdFromIniFile];
	if self.myTerminal &lt;&gt; null then
		if app.isRTApp then
			if app.rtDeviceIdFromIniFile &lt;&gt; null then
				// 29099 Mar 2012 machines are now unique by terminal, not across the system			
				///machine := app.myRoot.allMachines[app.rtDeviceIdFromIniFile];
				machine := self.myTerminal.machines[app.rtDeviceIdFromIniFile];
				if machine &lt;&gt; null then
					self.myRTDevice := machine.myRTDevice;
				endif;
			endif;
		else
			if app.rtDeviceIdFromIniFile &lt;&gt; null then
				self.myRTDevice := self.myTerminal.radioTelemetry.allRTDevices[app.rtDeviceIdFromIniFile];
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWhoAmIInfo" id="2488bf7d-5b7c-437e-8282-4c138e63530e">
        <source>getWhoAmIInfo() : String;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess : String;
	aMach : CM_Machine;
	osDescription : String;
begin
	
	if user &lt;&gt; null then
		mess := "User :" &amp; self.user.code &amp; CrLf;
	endif;
	
	if self.myRTDevice &lt;&gt; null then
		mess := mess &amp; "Device :" &amp; self.myRTDevice.id &amp; " " &amp; self.myRTDevice.computerName &amp; CrLf;
		aMach := self.myRTDevice.getMachine();
		if aMach &lt;&gt; null then
			mess := mess &amp; "Machine :"  &amp; aMach.id &amp;  CrLf;
		
		endif;
	endif;
	
	mess := mess &amp; "Time :" &amp; app.actualTimeServer.time.String &amp; CrLf;
	
	osDescription:=process.getOSDescription;

	mess := mess &amp; "OS : "  &amp; osDescription;
	
	
	return mess;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initWithDevice" id="fea30c6a-0e3f-431e-acc7-8c0996ce7f17">
        <updating/>
        <source>initWithDevice(_rtDevice : CM_RadioTelemetryDevice) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation

*/

vars
	sectionName		: String;
begin

	if _rtDevice = null then
		self.myRTDevice:=self.getRTDeviceForSelf(app.computerName);
	else
		self.myRTDevice:=_rtDevice;
	endif;
	
	if  self.myRTDevice &lt;&gt; null then
		self.myTerminal:=self.myRTDevice.myRadioTelemetry.myTerminal;
	else
		self.getTerminalRTDeviceFromIniFile();
	endif;
	
	if self.myTerminal &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
epilog

end;</source>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
