    <JadeMethod name="addMvmntPilotDetailsToTable" id="c2424b22-ac8c-425c-a057-0431ca68c602">
        <updating/>
        <source>addMvmntPilotDetailsToTable(_movementPilotDetails : HMS_MovementPilotDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
27 Feb 2020	jlgdap1	TFS 48708 PNL Adding Movement Resource Error
*/

vars
	tmpTable : CM_DataTable;
	rowIndex,
	backColour : Integer;
	newCombo : CMUI_ComboBox;
begin
	if (not self.shtMarineService.visible) then
		return;
	endif;	
	tmpTable := self.tblPilotLaunch;
	if _movementPilotDetails = null then
		return;
	endif;
	rowIndex := tmpTable.rows + 1;
	tmpTable.addItemAt(_movementPilotDetails.getAttributeStringForDefArray(tmpTable.allTblDataEntRows), rowIndex);
	tmpTable.accessRow(rowIndex).itemObject := _movementPilotDetails;
	if rowIndex mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	tmpTable.accessRow(rowIndex).backColor := backColour;

	//self.aNewIndex := self.aNewIndex + 1;																				// TFS 48708
	self.aNewPilotIndex := self.aNewPilotIndex + 1;																		// TFS 48708
	//newCombo := self.cmbSetPilotLaunch.loadControl(self.aNewIndex).CMUI_ComboBox; // set up pilot launch combo		// TFS 48708
	newCombo := self.cmbSetPilotLaunch.loadControl(self.aNewPilotIndex).CMUI_ComboBox; // set up pilot launch combo		// TFS 48708
	self.aAllClonedControls.add(newCombo);
	tmpTable.accessCell(rowIndex, self.aColPilotLaunch).cellControl := newCombo;
	newCombo.CMUI_ComboPilotLaunch.setObjectAndHarbour(_movementPilotDetails.myPilotLaunch, self.myTerminal.myHarbour);
	tmpTable.accessCell(rowIndex, self.aColPilotLaunch).text := newCombo.text;	

	//newCombo := self.cmbPilot.loadControl(self.aNewIndex).CMUI_ComboBox; // set up pilot combo						// TFS 48708
	newCombo := self.cmbPilot.loadControl(self.aNewPilotIndex).CMUI_ComboBox; // set up pilot combo						// TFS 48708
	self.aAllClonedControls.add(newCombo);
	tmpTable.accessCell(rowIndex, self.aColPilot).cellControl := newCombo;
	newCombo.CMUI_ComboPilot.setObjectAndHarbour(_movementPilotDetails.myPilot, self.myTerminal.myHarbour);
	tmpTable.accessCell(rowIndex, self.aColPilot).text := newCombo.text;	
epilog

end;</source>
        <Parameter name="_movementPilotDetails" type="HMS_MovementPilotDetails"/>
    </JadeMethod>
    <JadeMethod name="addResourceUsedToTable" id="9cb33adb-a60b-4551-9b94-0cbca955e6e5">
        <updating/>
        <source>addResourceUsedToTable(_resourceUsed : CMIF_HMS_ResourceUsed)updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//09 May 2024     navbs1  Bug 64079: SAL- Error code : 91008 Your locale setting is different from the application server locale setting.
//11 Aug 2025	  navhn30 MTN-35592: 14050 Error when adding Resources on the Movement Maintenance form in Harbour Management
//--------------------------------------------------
vars
	tmpStr : String;
	backColour,
	rowIdx : Integer;
	tmpTable : CM_DataTable;
//	newDateCntrl : CMUI_DateMask;
//	newTimeCntrl : CMUI_TimeMask;
	newTxtBox : CMUI_TextBox;
	newCombo : CMUI_ComboBox;
	assist : CMUI_Assistant;
	cell : JadeTableCell;
begin

	if (not self.shtResources.visible) then
		return;
	endif;
		
	tmpTable := self.tblResources;
		
	if _resourceUsed = null then
		return;
	endif;

	// ### this stops marine service resources used being shown, unless they have been charged.
	if _resourceUsed.myResourceType &lt;&gt; null 
	and _resourceUsed.myResourceType.isMarineService then // CCMS 1350
		return;
	endif;
				
	if _resourceUsed.myPersistentResourceUsed &lt;&gt; null then
		if _resourceUsed.myPersistentResourceUsed.myVTMISTransaction = null then
			if _resourceUsed.myResourceType &lt;&gt; null 
			and _resourceUsed.myResourceType.isMarineService then // CCMS 1350
				return;
			endif;
		endif;
	endif;	
	
	assist := self.myAssistant;
	
	rowIdx := tmpTable.rows+1;
	tmpStr := _resourceUsed.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);

	tmpTable.addItemAt(tmpStr, rowIdx);
	tmpTable.accessRow(rowIdx).itemObject := _resourceUsed;

	if _resourceUsed.myPersistentResourceUsed &lt;&gt; null then
		if _resourceUsed.myPersistentResourceUsed.myVTMISTransaction &lt;&gt; null then
			//Already invoiced, disable row as cannot change once invoiced
			tmpTable.accessRow(rowIdx).enabled := false;
			tmpTable.accessRow(rowIdx).backColor := Gray;	
			return;
		endif;
	endif;
	
	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	tmpTable.accessRow(rowIdx).backColor := backColour;	

	//Add controls for update mode
				
	aNewIndex := aNewIndex + 1;
	//Load from date control
//rs	newDateCntrl := self.txtDateFromRU.loadControl(newIndex).CMUI_DateMask;
//rs	self.allClonedControls.add(newDateCntrl);
//rs	tmpTable.accessCell(rowIdx, self.colDateFrom).cellControl := newDateCntrl;
//rs	newDateCntrl.setDate(_resourceUsed.fromDateTime.date);
	cell := tmpTable.tryAccessCell(rowIdx, self.aColDateFrom);	//11.08.2025	navhn30 	MTN-35592
	if cell &lt;&gt; null then
		cell := tmpTable.accessCell(rowIdx, self.aColDateFrom);
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getDateEditMaskForShortFormat();
		cell.text := _resourceUsed.fromDateTime.date.shortFormatJMT();
	endif;
		
	//Load from time control
//rs	newTimeCntrl := self.txtTimeFromRU.loadControl(newIndex).CMUI_TimeMask;
//rs	self.allClonedControls.add(newTimeCntrl);
//rs	tmpTable.accessCell(rowIdx, self.colTimeFrom).cellControl := newTimeCntrl;
//rs	newTimeCntrl.setTime(_resourceUsed.fromDateTime.time);
	cell := tmpTable.tryAccessCell(rowIdx, self.aColTimeFrom);	//11.08.2025	navhn30 	MTN-35592
	if cell &lt;&gt; null then
		cell.inputType := Table.InputType_EditMask;
		//cell.editMask := CM_BaseTable.EditMask_Time;				// cnwdad1 16/06/2009 - PAR #19942.
		cell.editMask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
		cell.text := _resourceUsed.fromDateTime.Time.shortFormatJMT();
	endif;
		
	//Load to date control
//rs	newDateCntrl := self.txtDateToRU.loadControl(newIndex).CMUI_DateMask;
//rs	self.allClonedControls.add(newDateCntrl);
//rs	tmpTable.accessCell(rowIdx, self.colDateTo).cellControl := newDateCntrl;
//rs	newDateCntrl.setDate(_resourceUsed.toDateTime.date);			
// cnwdad1 21/12/2005 - This should be the "Date To" column, not "Date From".
//	cell := tmpTable.accessCell(rowIdx, self.colDateFrom);
	cell := tmpTable.tryAccessCell(rowIdx, self.aColDateTo);	//11.08.2025	navhn30 	MTN-35592
	if cell &lt;&gt; null then
		cell.inputType := Table.InputType_EditMask;
		cell.editMask := app.getDateEditMaskForShortFormat();
	//	cell.text := _resourceUsed.fromDateTime.Date.shortFormatJMT();
		cell.text := _resourceUsed.toDateTime.date.shortFormatJMT();
	endif;
		
	//Load to time control
//rs	newTimeCntrl := self.txtTimeToRU.loadControl(newIndex).CMUI_TimeMask;
//rs	self.allClonedControls.add(newTimeCntrl);
//rs	tmpTable.accessCell(rowIdx, self.colTimeTo).cellControl := newTimeCntrl;
//rs	newTimeCntrl.setTime(_resourceUsed.toDateTime.time);
	cell := tmpTable.tryAccessCell(rowIdx, self.aColTimeTo);	//11.08.2025	navhn30 	MTN-35592
	if cell &lt;&gt; null then
		cell.inputType := Table.InputType_EditMask;
		//cell.editMask := CM_BaseTable.EditMask_Time;				// cnwdad1 16/06/2009 - PAR #19942.
		cell.editMask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
		cell.text := _resourceUsed.toDateTime.Time.shortFormatJMT();
	endif;

	//Load myResourceType control
	newCombo := self.cmbResourceType.loadControl(aNewIndex).CMUI_ComboBox;
	newCombo.filterIgnore := true;		//09.05.2024 navbs1 #64079
	self.aAllClonedControls.add(newCombo);
	
	cell := tmpTable.tryAccessCell(rowIdx, self.aColResourceType);
	if cell &lt;&gt; null then	//11.08.2025	navhn30 	MTN-35592
		cell.cellControl := newCombo;
		cell.text := newCombo.text;	
	endif;

//	assist.comboBoxHMSResourceType(newCombo, _resourceUsed.myResourceType);
	newCombo.CMUI_ComboResourceTypes.setObject(_resourceUsed.myResourceType);

	//Load myResource control
	newCombo := self.cmbResource.loadControl(aNewIndex).CMUI_ComboBox;
	newCombo.filterIgnore := true;		//09.05.2024 navbs1 #64079
	self.aAllClonedControls.add(newCombo);
	
	cell := tmpTable.tryAccessCell(rowIdx, self.aColResource);
	if cell &lt;&gt; null then	//11.08.2025	navhn30 	MTN-35592
		cell.cellControl := newCombo;
		cell.text := newCombo.text;	
	endif;
//	assist.comboBoxHMSResource(newCombo, _resourceUsed.myResource, _resourceUsed.myResourceType, self.myTerminal.myHarbour);			
	newCombo.CMUI_ComboResources.setObjectAndResourceType(_resourceUsed.myResource,_resourceUsed.myResourceType,self.myTerminal.myHarbour);
		
	//Load units used control
	newTxtBox := self.txtUnitsUsed.loadControl(aNewIndex).CMUI_TextBox;
	self.aAllClonedControls.add(newTxtBox);
	
	cell := tmpTable.tryAccessCell(rowIdx, self.aColUnitsUsed);
	if cell &lt;&gt; null then	//11.08.2025	navhn30 	MTN-35592
		cell.cellControl := newTxtBox;
	endif;

	/*if _resourceUsed.myResourceType &lt;&gt; null then
		newTxtBox.decimals := _resourceUsed.myResourceType.numDecimalPlaces; 
	endif;*/
	newTxtBox.text := _resourceUsed.unitsUsed.String;
	
	tmpTable.accessedRow.height := newTxtBox.height.Integer;

	self.setTblResourceCells(rowIdx, _resourceUsed, _resourceUsed.myResourceType);
end;</source>
        <access>protected</access>
        <Parameter name="_resourceUsed" type="CMIF_HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="202fef5d-511c-4161-91df-0a15f4f3f79f">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
//	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnClose, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnApply, CMUI_Toolbar.Control_Alignment_Left);
	
	// PAR 16389 - remove from toolbar as not used for Voy Comod Planning
	if app.myCurrentUserCan(self.myTerminal, PmHMSVoyResUsedView) then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	// 19 Jun 2018	NDL	TFS 39215
	toolbar.addButton(self.btnTimings, CMUI_Toolbar.Control_Alignment_Left);
	
	//20 Nov 2018	NDL	TFS 42043
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCancelMove, CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustMarksFromBollards" id="1435e02f-52b5-41c7-89d9-82a9ede09e39">
        <updating/>
        <source>adjustMarksFromBollards(_cmbBollard : ComboBox; _textbox : TextBox) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/10/2022	navdap1		Initial creation TFS 54739 EUP - PLAN - Berth planning by bollards
// 22/03/2023	navdap1		TFS 56593 EUP - Show Bollard+Meters in all instances
// 05/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
// 10/07/2024	navcs2		Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
// 30/10/2024	navdap1		MTN-12358 EUP* | FR 54107 - Berth planning by bollards - part II
//
vars
	oldBowMark, newBowMark, oldSternMark, newSternMark, oldBridgeMark, newBridgeMark : Decimal [12,2];
	oldBowMeters, newBowMeters, oldSternMeters, newSternMeters, oldBridgeMeters, newBridgeMeters : Decimal [12,2];
	loa, bowToBridge : Decimal [12,2];
	orientation : Integer;
	waterOnLeft, bowMarkHigh : Boolean;
	berth : HMS_Berth;											// TFS 56593
	sternBollard, bridgeBollard, bowBollard : HMS_Resource;		// TFS 56593
	wharf : HMS_Wharf;					// TFS 59472

begin
	// some basic stuff first - orientation and water side to
	orientation := self.cmbOrientTo.listIndex;
	berth := self.cmbToBerth.listObject.HMS_Berth;		// TFS 56593
	waterOnLeft := berth.myWharf.waterOnLeft;			// TFS 56593
	wharf := berth.myWharf;							// TFS 59472
	loa := self.aMySelectedVoyage.myHMSVoyageData.dim_LengthOverall;
	bowToBridge := aMySelectedVoyage.myHMSVoyageData.dist_BridgeToBow;
	// water on left, ship is port side to - bow mark is min, stern mark is max
	// water on right, ship is starboard side to - bow mark is min, stern mark is max
	if (waterOnLeft and orientation = OrientPortSideTo) or (not waterOnLeft and orientation = OrientStarboardSideTo) then
		bowMarkHigh := false;
	// water on left, ship is starboard side to - bow mark is max, stern mark is min
	// water on right, ship is port side to - bow mark is max, stern mark is min
	elseif (waterOnLeft and orientation = OrientStarboardSideTo) or (not waterOnLeft and orientation = OrientPortSideTo) then
		bowMarkHigh := true;
	endif;
	
	oldBowMark := self.txtBowMarkTo.text.asDecimalJMT;
	oldSternMark := self.txtSternMarkTo.text.asDecimalJMT;
	oldBridgeMark := self.txtBridgeMarkTo.text.asDecimalJMT;
	oldBowMeters := self.txtBowMarkMeter.text.asDecimalJMT;
	oldSternMeters := self.txtSternMarkMeter.text.asDecimalJMT;
	oldBridgeMeters := self.txtBridgeMarkMeter.text.asDecimalJMT;
	
	// if bow bollard or bow meters change
	if _cmbBollard = self.cmbBowMarkBollard or _textbox = self.txtBowMarkMeter then
		// adjust the bow, stern and bridge marks to suit
		newBowMeters := _textbox.text.asDecimalJMT;
		if _cmbBollard.listObject = null then													// 25/07/2024	navcs2		Bug 64769
			return;																				// 25/07/2024	navcs2		Bug 64769
		endif;																					// 25/07/2024	navcs2		Bug 64769
		newBowMark := _cmbBollard.listObject.HMS_Resource.startPosnAlongWharf + newBowMeters;
		
		if bowMarkHigh then
			newSternMark := newBowMark - loa;
			newBridgeMark := newBowMark - bowToBridge;
		else
			newSternMark := newBowMark + loa;
			newBridgeMark := newBowMark + bowToBridge;
		endif;
		
		// TFS 56593 bollard marks are always bollard + metres, never bollard - metres. So find the closest bollard
		// for the new stern and bridge positions, and the metres to those new bollard(s)
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
	endif;
	
	// if stern bollard or stern meters change
	if _cmbBollard = self.cmbSternMarkBollard or _textbox = self.txtSternMarkMeter then
		if _cmbBollard.listObject = null then													// 25/07/2024	navcs2		Bug 64769
			return;																				// 25/07/2024	navcs2		Bug 64769
		endif;																					// 25/07/2024	navcs2		Bug 64769
		// adjust the bow, stern and bridge mark text boxes to suit 
		newSternMeters := _textbox.text.asDecimalJMT;																// 10/07/2024	navcs2		Bug 64769
		newSternMark := _cmbBollard.listObject.HMS_Resource.startPosnAlongWharf + newSternMeters;
		
		if bowMarkHigh then
			newBowMark := newSternMark + loa;
			newBridgeMark := newBowMark - bowToBridge;
		else
			newBowMark := newSternMark - loa;
			newBridgeMark := newBowMark + bowToBridge;
		endif;
		
		// TFS 56593 bollard marks are always bollard + metres, never bollard - metres. So find the closest bollard
		// for the new bow and bridge positions, and the metres to those new bollard(s)
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
	endif;
	
	// If the bridge bollard / meters are changed, change the bridge mark text box, but leave the other mark, bollard and meter fields as they are
	if _cmbBollard = self.cmbBridgeMarkBollard or _textbox = self.txtBridgeMarkMeter then
		if _cmbBollard.listObject = null then													// 25/07/2024	navcs2		Bug 64769
			return;																				// 25/07/2024	navcs2		Bug 64769
		endif;																					// 25/07/2024	navcs2		Bug 64769
		newBridgeMark := self.cmbBridgeMarkBollard.listObject.HMS_Resource.startPosnAlongWharf + self.txtBridgeMarkMeter.text.asDecimalJMT;		// 10/07/2024	navcs2		Bug 64769

		newBridgeMeters := self.txtBridgeMarkMeter.text.asDecimalJMT;												// 10/07/2024	navcs2		Bug 64769
		
		// TFS 56593 allow bridge changes to change bow and stern as well
		if bowMarkHigh then
			newBowMark := newBridgeMark + bowToBridge;
			newSternMark := newBowMark - loa;
		else
			newBowMark := newBridgeMark - bowToBridge;
			newSternMark := newBowMark + loa;
		endif;
		
		wharf.getBollardForMark(newBowMark.Integer, newBowMeters, bowBollard);				// TFS 59472
		wharf.getBollardForMark(newBridgeMark.Integer, newBridgeMeters, bridgeBollard);		// TFS 59472
		wharf.getBollardForMark(newSternMark.Integer, newSternMeters, sternBollard);		// TFS 59472
		// TFS 56593 end of this bit
	endif;
	
	self.txtBowMarkTo.text := newBowMark.asStringJMT;
	self.txtSternMarkTo.text := newSternMark.asStringJMT;
	self.txtBridgeMarkTo.text := newBridgeMark.asStringJMT;
	
	if _textbox &lt;&gt; self.txtBowMarkMeter or (bowBollard &lt;&gt; null and bowBollard &lt;&gt; self.cmbBowMarkBollard.listObject) then				// MTN-12358
		self.txtBowMarkMeter.text := self.stringOrNull(newBowMeters);														// 10/07/2024	navcs2		Bug 64769
	endif;
	if _textbox &lt;&gt; self.txtSternMarkMeter or (sternBollard &lt;&gt; null and sternBollard &lt;&gt; self.cmbSternMarkBollard.listObject) then		// MTN-12358
		self.txtSternMarkMeter.text := self.stringOrNull(newSternMeters);													// 10/07/2024	navcs2		Bug 64769
	endif;
	if _textbox &lt;&gt; self.txtBridgeMarkMeter or (bridgeBollard &lt;&gt; null and bridgeBollard &lt;&gt; self.cmbBridgeMarkBollard.listObject) then	// MTN-12358
		self.txtBridgeMarkMeter.text := self.stringOrNull(newBridgeMeters);													// 10/07/2024	navcs2		Bug 64769
	endif;
	
	// TFS 56593 also update the bollard combos if required
	if bowBollard &lt;&gt; null and bowBollard &lt;&gt; self.cmbBowMarkBollard.listObject then
		self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(bowBollard);
	elseif bowBollard = null then												// TFS 59472
		self.cmbBowMarkBollard.listIndex := -1;									// TFS 59472
	endif;
	if sternBollard &lt;&gt; null and sternBollard &lt;&gt; self.cmbSternMarkBollard.listObject then
		self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(sternBollard);
	elseif sternBollard = null then												// TFS 59472
		self.cmbSternMarkBollard.listIndex := -1;								// TFS 59472
	endif;
	if bridgeBollard &lt;&gt; null and bridgeBollard &lt;&gt; self.cmbBridgeMarkBollard.listObject then
		self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(bridgeBollard);
	elseif bridgeBollard = null then											// TFS 59472
		self.cmbBridgeMarkBollard.listIndex := -1;								// TFS 59472
	endif;
	// TFS 56593 end of this bit
	
	// TFS 59472 Adjust To Berth combo if required
	if bowBollard &lt;&gt; null and bowBollard.myBerth &lt;&gt; self.cmbToBerth.listObject then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(bowBollard.myBerth);
	endif;
	// TFS 59472 end of this bit
	
epilog

end;</source>
        <Parameter name="_cmbBollard" type="ComboBox"/>
        <Parameter name="_textbox" type="TextBox"/>
    </JadeMethod>
