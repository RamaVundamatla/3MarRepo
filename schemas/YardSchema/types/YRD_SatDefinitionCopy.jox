    <JadeMethod name="setMyTAViewInterface" id="5d71de0f-9a09-4cb4-b56f-e7a018f799fe">
        <updating/>
        <source>setMyTAViewInterface(_taViewInterface : IF_CM_TerminalAreaViews) updating, protected;
/*

Purpose:			

Parameters:			

