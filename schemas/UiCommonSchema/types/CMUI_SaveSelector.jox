    <JadeMethod name="doMakeNewFolder" id="7bd705ef-12f7-469b-9775-1b8ee3d65160">
        <updating/>
        <source>doMakeNewFolder() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	selectedHeader		: CM_MenuEntity;
	newHeader,
	pxyHeader			: CM_MenuUserHdr;
	inputBox			: CMUI_InputBox;
	folderName			: String;
	subScript,
	theResult			: Integer;
begin
	
	if self.cmbFolder.listIndex &gt; 0 then
		selectedHeader := self.cmbFolder.listObject.CM_MenuUserHdr;
	endif;
	
	if selectedHeader = null then
		selectedHeader := app.myRoot.myQueryMenuRoot;
	endif;
	
	create inputBox transient;
	
	inputBox.init(	app.getErrorString(LBLCreateHeader), app.getErrorString(LBLEnterFolderName),
					null, 20, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.showModal;
	
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	folderName := inputBox.txtInput.text;
	
	if folderName = null then
		return;
	endif;
	
	create pxyHeader transient;
	pxyHeader.setProxy(folderName, null, null, null, null, null, null);
	
	subScript := 1;
	
	while true do
		app.myTrxCA.trxCreateMenuUserHdr(pxyHeader, 
									selectedHeader,
									newHeader,
									subScript,
									app.myPassport);
									
		if app.myPassport.trxCompletedOK then
			self.myFolderFromParent := newHeader;
			self.doPopulateFolder();
			break;
		else
			theResult := app.showErrorWarningDialog('Create Folder', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete pxyHeader;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateFolder" id="5cbcd8b1-b8af-4b93-ba52-dcc55b5419ab">
        <source>doPopulateFolder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	qryMenuRoot		: CM_MenuRootQuery;
	menuEntity		: CM_MenuEntity;
	menuUserItem	: CM_MenuUserItem;
	menuUserHdr		: CM_MenuUserHdr;
	menuUserSubHdr	: CM_MenuUserHdr;
	menuUserSubHdrs	: CM_MenuUserHdrSet;
begin
	qryMenuRoot := app.myRoot.myQueryMenuRoot;
	
	if qryMenuRoot = null then
		return;
	endif;
	
	create menuUserSubHdrs transient;
	
	self.cmbFolder.clear();
	self.cmbFolder.addItem(null);
	
	foreach menuEntity in qryMenuRoot.allChildren discreteLock where menuEntity.isMenuUserItem() do 
		menuUserItem := menuEntity.CM_MenuUserItem;
		// Header/Folder
		if menuUserItem.isHeader() then
			menuUserHdr := menuUserItem.CM_MenuUserHdr;
			self.cmbFolder.addItemObject(menuUserHdr.heading, menuUserHdr);
			menuUserHdr.getAllChildHeaders(menuUserSubHdrs);
			// Sub headers
			foreach menuUserSubHdr in menuUserSubHdrs do 
				self.cmbFolder.addItemObject(menuUserSubHdr.heading, menuUserSubHdr);
			endforeach;
		endif;
	endforeach;
	
	if self.myFolderFromParent &lt;&gt; null then
		self.cmbFolder.listIndex := self.cmbFolder.findObject(self.myFolderFromParent);
	endif;
	
epilog
	delete menuUserSubHdrs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateQuery" id="8cf46160-37bf-40d7-b3ba-1d60ac187555">
        <source>doPopulateQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	menuEntityParent,
	menuEntity		: CM_MenuEntity;
	menuUserItem	: CM_MenuUserItem;
	menuUserQry		: CM_MenuUserQuery;
begin
	self.cmbQuery.clear();
	
	self.txtQueryName.text := null;
	self.txtQueryDesc.text := null;
	
	if self.cmbFolder.listIndex &gt; 1 then
		menuEntityParent := self.cmbFolder.listObject.CM_MenuUserHdr;
	endif;
	
	if menuEntityParent = null then
		menuEntityParent := app.myRoot.myQueryMenuRoot;
	endif;
	
	foreach menuEntity in menuEntityParent.allChildren discreteLock where menuEntity.isMenuUserItem() do
		menuUserItem := menuEntity.CM_MenuUserItem;
		
		if not menuUserItem.isQuery() then
			continue;
		endif;
		
		menuUserQry := menuUserItem.CM_MenuUserQuery;
		// Only want TI
		if menuUserQry.queryMode &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Mode then
			continue;
		endif;
		self.cmbQuery.addItemObject(menuUserQry.heading, menuUserQry);
	endforeach;
	
	if self.myQueryFromParent &lt;&gt; null then
		self.cmbQuery.listIndex := self.cmbQuery.findObject(self.myQueryFromParent);
	endif;
	
	if self.cmbQuery.listIndex &gt; 0 then
		menuUserQry := self.cmbQuery.listObject.CM_MenuUserQuery;
		
		if menuUserQry &lt;&gt; null then
			self.txtQueryName.text := menuUserQry.heading;
			self.txtQueryDesc.text := menuUserQry.description;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveQuery" id="614dca05-6ce0-4a78-a05e-d88b863dedf5">
        <updating/>
        <source>doSaveQuery(_isSaveAs : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes
26/10/2023	navkc1	CR 60974 Task 60976: UI - Cargo Review Selector Columns Used
*/

vars
	pxyUserQuery,
	realUserQuery 		: CM_MenuUserQuery;
	ls					: Boolean;
	visibleColums		: StringArray;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	menuRootQuery		: CM_MenuRootQuery;
	theResult			: Integer;
	menuEntity			: CM_MenuEntity;
	parentForm			: CM_BaseForm;
	cargoReview			: CMUI_CargoReview;
	success				: Boolean;
	
begin
	if self.cmbQuery.listIndex &gt; 0 then
		realUserQuery := self.cmbQuery.listObject.CM_MenuUserQuery;
	endif;
	
	// Save(Update)
	if not _isSaveAs and realUserQuery = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(Query), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), 0);
		return;
	endif;
	
	create visibleColums transient;
	
	// Save As 
	if _isSaveAs then
		create pxyUserQuery transient;
	// Save(Update)
	else
		app.cmsBeginLoad(ls);
		pxyUserQuery := realUserQuery.pxyCreateUpdateProxy();
		realUserQuery.allVisibleColumns.copy(visibleColums);
	endif;
	
	// Set the Parent folder
	if self.cmbFolder.listIndex &gt; 0 then
		menuEntity := self.cmbFolder.listObject.CM_MenuUserHdr;
	// No folder selected, use the Root query menu
	else
		menuRootQuery := app.myRoot.myQueryMenuRoot;
		menuEntity := menuRootQuery;
	endif;
	
	pxyUserQuery.setProxy(self.txtQueryName.text, self.txtQueryDesc.text, app.getMyUser().code, self.myQDef.mode, menuRootQuery, self.myTerminal, visibleColums);
	criteriaHolder := self.myCriteriaLineHolder;
	pxyUserQuery.allCriteriaLineHolders.purge();
	pxyUserQuery.allCriteriaLineHolders.add(criteriaHolder);
	
	while true do
		// Save As
		if _isSaveAs then
			app.myTrxCA.trxCreateSelectorQuery(pxyUserQuery, 0, menuEntity, realUserQuery, app.myPassport);
		// Save(Update)
		else
			app.myTrxUA.trxUpdateSelectorQuery(pxyUserQuery, menuEntity, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			success := true; //11/06/2024	navkc1 Bug 64543
			// Save As
			if _isSaveAs then
				app.msgBox(app.getErrorString1(Query_successfully, "saved"), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
			// Save(Update)
			else
				app.msgBox(app.getErrorString1(Query_successfully, "updated"), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				realUserQuery := pxyUserQuery.pxyGetRealObject();
			endif;
			self.myQueryFromParent := realUserQuery;
			if menuEntity.isMenuUserItem() then
				self.myFolderFromParent := menuEntity.CM_MenuUserHdr;
			endif;
			parentForm := self.myParentForm;
			
			// Refresh the parent form comboboxes
			if parentForm.isKindOf(CMUI_CargoReview) then
				cargoReview := parentForm.CMUI_CargoReview;
				cargoReview.doInitQueryFolder();
				cargoReview.cmbFolder.listIndex := cargoReview.cmbFolder.findObject(self.myFolderFromParent);
				cargoReview.doPopulateQueryCmb(self.myFolderFromParent);
				cargoReview.cmbQuery.listIndex := cargoReview.cmbQuery.findObject(self.myQueryFromParent);
				self.doSaveTableColumns(cargoReview); //26/10/2023	navkc1	CR 60974 Task 60976
				self.unloadForm();
			endif;
			break;
		else
			if _isSaveAs then
				theResult := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_Update);
			else
				theResult := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	//11/06/2024	navkc1 Bug 64543 - remove the criteriaHolder so it doesn't get "deleted". 
	if not success then
		pxyUserQuery.allCriteriaLineHolders.tryRemove(criteriaHolder);
	endif;
	delete pxyUserQuery;
end;
</source>
        <Parameter name="_isSaveAs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTableColumns" id="580ce4b2-f040-48fe-91e6-3225949a9ec4">
        <source>doSaveTableColumns(_parentForm : CM_BaseForm);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/10/2023	navkc1	CR 60974 Task 60976: UI - Cargo Review Selector Columns Used

*/

vars
	cargoReview		: CMUI_CargoReview;
	cargoTable		: CM_DataTable;
	groupingRowsXML,
	addtionalRowXML,
	xml				: String;
	entTableRow 	: EntTableRow;
begin
	if _parentForm.isKindOf(CMUI_CargoReview) then
		cargoReview := _parentForm.CMUI_CargoReview;
		
		// Cargo Table columns
		cargoTable := cargoReview.tblCargo;
		xml := xml &amp; cargoTable.getXmlStrForColumns(true);
		
		// Group By Columns
		foreach entTableRow in cargoReview.allGroupingRows do
			groupingRowsXML := groupingRowsXML &amp; global.formatAsXML(CM_DataTable.XMLTag_Column, entTableRow.name);
		endforeach;
		xml := xml &amp; global.formatAsXML(cargoReview.XMLTag_Grouping, groupingRowsXML);
		
		// Additional columns
		foreach entTableRow in cargoReview.allAdditionalRows do
			addtionalRowXML := addtionalRowXML &amp; global.formatAsXML(CM_DataTable.XMLTag_Column, entTableRow.name);
		endforeach;
		xml := xml &amp; global.formatAsXML(cargoReview.XMLTag_Additional, addtionalRowXML);
		
		// Save
		while true do
			app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_ExtraData, self.myQueryFromParent.heading, xml, app.myPassport);
			break;
		endwhile;
	endif;
epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="doSelectFolder" id="c8341a2d-3351-454f-9eed-cea0e4b58431">
        <updating/>
        <source>doSelectFolder() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

begin
	
	self.myFolderFromParent := null;
	
	if self.cmbFolder.listIndex &gt; 0 then
		self.myFolderFromParent := self.cmbFolder.listObject.CM_MenuUserHdr;
	endif;

	self.doPopulateQuery();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectQuery" id="628ef8f8-0d03-4bb2-944a-98984a4f2a4d">
        <source>doSelectQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	menuUserQry : CM_MenuUserQuery;
begin
	if self.cmbQuery.listIndex &gt; 0 then
