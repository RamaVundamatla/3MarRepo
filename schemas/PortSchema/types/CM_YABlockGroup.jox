    <JadeMethod name="pxyCreateUpdateProxy" id="d06f6aed-0c7f-44c8-aa63-774baf6273b4">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		11 May 2006 by cnwdad1
//
// Purpose:		Creates a proxy version of the receiver, and returns a reference to it.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin
	if self.isTransient() then
		completedOK := true;			// 20/04/2011 cnwmh5 #27401
		return null;
	endif;
	
	proxyObj				:=	inheritMethod();		// Clones the receiver.
	proxyObj.description	:=	self.description;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="searchAlternating" id="b744a95f-e75d-46c0-a52a-7595790e461b">
        <updating/>
        <source>searchAlternating(	_yaAgent : CM_YAAutoplanAgent input; 
					_isIn : Boolean;
					_terminalArea : CM_TerminalArea) : Boolean updating;

// Created by cnwdvb1 on 16 June 2006

vars

begin

	return self.searchAlternatingInternal(_yaAgent, _isIn,_terminalArea);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchAlternatingInternal" id="14cfe649-ed0d-41a7-831a-f1bf8d7711b1">
        <updating/>
        <source>searchAlternatingInternal(	_yaAgent : CM_YAAutoplanAgent input; 
							_isIn : Boolean;
							_terminalArea : CM_TerminalArea) : Boolean updating, protected;

// Created by cnwdvb1 on 04 May 2006

vars
	isFound,
	hasRecursed,
	doUpdate			: Boolean;
	block				: CM_YABlock;
	toBeSearchedArray	: CM_YABlockArray;

begin
	doUpdate	:=	_yaAgent.agentUsage = CM_YAAutoplanAgent.Normal_Usage;

	create toBeSearchedArray transient;	
	
	if _isIn then
		foreach block in self.allYABlocksIn discreteLock do
			//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
			// Haven't got a last to use.
			if 	self.myLastYABlockIn = null then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'No information about last move', false);
				if block.searchForLocationIn(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(block, true);
					endif;
					return true;
				endif;
				if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
					if doUpdate then
						self.updateLastYABlock(block, true);
					endif;
					return true;
				endif;
			// Haven't found one we last used until now.
			elseif not isFound and self.myLastYABlockIn = block then
				toBeSearchedArray.add(block);
				isFound := true;
				continue;
			// Go for it.
			elseif isFound then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Found last used block', false);
				if block.searchForLocationIn(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(block, true);
					endif;
					return true;
				endif;
				if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
					if doUpdate then
						self.updateLastYABlock(block, true);
					endif;
					return true;
				endif;
			else
				// We'll get back to these
				toBeSearchedArray.add(block);
			endif;
		endforeach;
		
		// If we get here then we need to search passed over ones.
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Searching passed over blocks', false);
		foreach block in toBeSearchedArray do
			if block.searchForLocationIn(_yaAgent) then
				if doUpdate then
					self.updateLastYABlock(block, true);
				endif;
				return true;
			endif;
			if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
				if doUpdate then
					self.updateLastYABlock(block, true);
				endif;
				return true;
			endif;
		endforeach;
	else
		foreach block in self.allYABlocksOut discreteLock do
			//epr par 35377 22/12/14 
			if _terminalArea &lt;&gt; null and block.myTerminalArea &lt;&gt; _terminalArea then
				continue;
			endif;
			
			if 	self.myLastYABlockOut = null then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'No information about last move', false);
				if block.searchForLocationOut(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(block, false);
					endif;
					return true;
				endif;
				if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
					if doUpdate then
						self.updateLastYABlock(block, false);
					endif;
					return true;
				endif;
			elseif not isFound and self.myLastYABlockOut = block then
				toBeSearchedArray.add(block);
				isFound := true;
				continue;
			elseif isFound then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Found last used block', false);
				if block.searchForLocationOut(_yaAgent) then
					if doUpdate then
						self.updateLastYABlock(block, false);
					endif;
					return true;
				endif;
				if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
					if doUpdate then
						self.updateLastYABlock(block, false);
					endif;
					return true;
				endif;
			else
				toBeSearchedArray.add(block);
			endif;	
		endforeach;
		
		// If we get here then we need to search passed over ones.
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Searching passed over blocks', false);
		foreach block in toBeSearchedArray do
			if block.searchForLocationOut(_yaAgent) then
				if doUpdate then
					self.updateLastYABlock(block, false);
				endif;
				return true;
			endif;
			if self.searchRecursively(_yaAgent, _isIn, hasRecursed) then
				if doUpdate then
					self.updateLastYABlock(block, false);
				endif;
				return true;
			endif;
		endforeach;
	endif;

	return false;
epilog
	delete toBeSearchedArray;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchRecursively" id="8dacfd42-e964-443b-a56b-33d08af2aa66">
        <updating/>
        <source>searchRecursively(_yaAgent : CM_YAAutoplanAgent input; _isIn : Boolean; _hasRecursed : Boolean io) : Boolean protected, updating;

// Created by cnwdvb1 on 04 May 2006

vars
	nextGroup			: CM_YABlockGroup;
	
begin
	if _hasRecursed then
		return false;
	endif;
	
	_hasRecursed := true;

	nextGroup := self.getNextGroup(self.myYardAllocationIn.allYABlockGroupsIn);
	
	if nextGroup &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Unable to locate position in current group. Searching group ' &amp; nextGroup.description, false);
		return nextGroup.searchAlternatingInternal(_yaAgent, _isIn,null);
	endif;

	_yaAgent.addLogEntry(AP_Log_YA_Default,'No next group', false);	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_hasRecursed" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
