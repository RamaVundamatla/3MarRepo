    <JadeMethod name="getVesselServiceTimeRate" id="fbdfca44-d016-4fba-9c63-cfd2c155cad1">
        <source>getVesselServiceTimeRate(_service : CM_Service; _ts : TimeStamp) : CM_RateEntry;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
// 23 Oct 2024  navlw1 		JIRA-33107: Invoice Logging Use Levels
//
vars
	serviceRate : CM_VesselRate;
	rateEntry : CM_RateEntry;

begin
	serviceRate := self.allServiceRates[_service];
	if serviceRate &lt;&gt; null then
		rateEntry := serviceRate.getTimeRate(_service.bank, _ts);
		if rateEntry &lt;&gt; null then
			app.invLog("Rate for " &amp; _service.name &amp; " derived from vessel '" &amp; self.name &amp; "' found", LogTRACE.String);
		else
			app.invLog("Rate for " &amp; _service.name &amp; " derived from vessel '" &amp; self.name &amp; "' NOT found", LogTRACE.String);
		endif;
		
		return rateEntry;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getVesselTerminalData" id="b56123be-0b4e-4b33-8542-43d52962e15f">
        <source>getVesselTerminalData(_terminal : CM_Terminal; _createIfNotPresent : Boolean) : CM_VesselTerminalData;
// ---------------------------------------------------------------------------
// Created:     02 June 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVesselTerminal	: CM_VesselTerminalData;
begin
	if _terminal = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_terminal', null, null);
		return null;
	endif;
	
	tmpVesselTerminal := self.allTerminalDatas[_terminal];
	if tmpVesselTerminal = null and _createIfNotPresent then
		if process.isInTransactionState and (not self.isTransient) then
			create tmpVesselTerminal persistent;
			tmpVesselTerminal.setVesselAndTerminal(self, _terminal);
		elseif self.isTransient then
			create tmpVesselTerminal transient;
			tmpVesselTerminal.setVesselAndTerminal(self, _terminal);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Method called for persistent when not in transaction state');
		endif;
	endif;
	
	return tmpVesselTerminal;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_createIfNotPresent" type="Boolean"/>
        <ReturnType type="CM_VesselTerminalData"/>
    </JadeMethod>
    <JadeMethod name="getVesselTypeDescr" id="f7bd8354-b224-4e4c-b5cd-67da5cd7ee3a">
        <source>getVesselTypeDescr() : String;
// ---------------------------------------------------------------------------
// Created:     14 May 2008 by cnwrs2
//
// Purpose:     PAR-16751 - required for report writer
// ---------------------------------------------------------------------------
vars

begin
	return app.vesselAccessTypeEnumToStr(self.vesselType);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionExport" id="ed084c8c-b6b3-45c0-aba0-28fc2a6c4741">
        <source>getXMLDefinitionExport(_mode: Integer): Binary ;
/*--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
// 03 Mar 2008	conks1a		PAR #16047 - remove unnecessary serverExecution for performance
16 April 2012 cnwer1		CCMS 1035 - just exporting as XML - not compressed
//----------------------------------------------------------------------------*/
vars
	xml : String;
begin

	xml := self.getXMLDefinitionString();
	
	if self.myHMSVesselData &lt;&gt; null then
		xml := xml &amp; self.myHMSVesselData.getXMLDefinitionString();
	endif;

	if self.myCellularVesselStructure &lt;&gt; null then
		xml := xml &amp; self.myCellularVesselStructure.getXMLDefinitionString();
	endif;	

	//cnwrd1 par 31874
	if self.myStructuralElements &lt;&gt; null then
		xml := xml &amp; self.myStructuralElements.getXMLDefinitionString();
	endif;	

	if self.myGeneralCargoVesselStructure &lt;&gt; null then
		xml := xml &amp; self.myGeneralCargoVesselStructure.getXMLDefinitionString();
	endif;		

	// #### CCMS 1031 RORO DECKS are done seperately. See CM_ROROVesselStructure Export XML methods
	
// cnwdad1 25/02/2009 - PAR #18366.
//	return xml.compress;
	return xml.compressToBinary(Binary.Compression_ZLib);
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="7a421145-7a0a-4d63-9ea2-640feacd55cd">
        <source>getXMLDefinitionString(): String protected;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	hms	: String;
	xml	: String;
	
begin
	xml	:=	"&lt;class&gt;" &amp;  self.class.name &amp;
			"&lt;/class&gt;&lt;cv&gt;" &amp; self.canCreateVoyages.Integer.String &amp;
			"&lt;/cv&gt;&lt;cd&gt;" &amp;  self.code.trimBlanks &amp;
			"&lt;/cd&gt;&lt;nm&gt;" &amp; self.name.trimBlanks &amp;
			"&lt;/nm&gt;&lt;op&gt;" &amp; self.myOperator.code &amp;
			"&lt;/op&gt;&lt;cl&gt;" &amp; self.classLabel &amp;
			"&lt;/cl&gt;&lt;cs&gt;" &amp; self.callSign &amp;
			"&lt;/cs&gt;&lt;ln&gt;" &amp; self.lloydsNumber &amp;
			"&lt;/ln&gt;&lt;dc&gt;" &amp; self.dailyCost.String &amp;
			"&lt;/dc&gt;&lt;dr&gt;" &amp; self.despatchRate.String &amp;
			"&lt;/dr&gt;&lt;cc&gt;" &amp; self.craneClearance.String &amp;
			"&lt;/cc&gt;&lt;rm&gt;" &amp; self.remarks &amp;
			"&lt;/rm&gt;&lt;vt&gt;" &amp; self.vesselType.String &amp;
			"&lt;/vt&gt;&lt;hms&gt;" &amp; (self.myHMSVesselData &lt;&gt; null).Integer.String &amp;
			"&lt;/hms&gt;&lt;cell&gt;" &amp; (self.myCellularVesselStructure &lt;&gt; null).Integer.String &amp;
			"&lt;/cell&gt;&lt;gcv&gt;" &amp; (self.myGeneralCargoVesselStructure &lt;&gt; null).Integer.String &amp; 
			"&lt;/gcv&gt;";
			
			// 31232 - structuretype no longer relevant
			//&lt;vst&gt;" &amp;  self.structureType.String &amp;
			//"&lt;/vst&gt;";
	xml := xml &amp; 
	"&lt;ADRFT&gt;" &amp; self.airDraft.String &amp; "&lt;/ADRFT&gt;" &amp; 
	"&lt;BLINE&gt;" &amp; self.buildingLine.String &amp; "&lt;/BLINE&gt;" &amp; 
	"&lt;DRBOW&gt;" &amp; self.draftBow.String &amp; "&lt;/DRBOW&gt;" &amp; 
	"&lt;DMID&gt;" &amp; self.draftMid.String &amp; "&lt;/DMID&gt;" &amp; 
	"&lt;DSTRN&gt;" &amp; self.draftStern.String &amp; "&lt;/DSTRN&gt;" &amp; 
	"&lt;YRBLD&gt;" &amp; self.yearOfBuild.String &amp; "&lt;/YRBLD&gt;" &amp; 
	"&lt;LOARMP&gt;" &amp; self.loaWithRampsDown.String &amp; "&lt;/LOARMP&gt;";
	
	
	return xml;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasHarbourDetails" id="4c8bc714-cbca-43d0-a8b9-4d79936e7468">
        <source>hasHarbourDetails() : Boolean;
/*
Purpose:	PAR 36959. ALL vessels have an HMS_VesselData object whether they want to use HMS or not;
									This is because the HMS_VesselData object stores all the dimensions of the vessel
									The vessel is only really using HMS if it has harbour data.
Date		Who		Reason
17 November 2015	cnwab1	Initial creation
09 Apr 2021	NDL	TFS 50858 - removed double de-reference, to get small performance improvement 'getAllCurrentVoyages' call
*/

vars

	vesselData : HMS_VesselData;

begin
	vesselData := self.myHMSVesselData;
	if vesselData = null then
		return false;
	endif;
	
	return vesselData.hasHarbourDetails();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRemarks" id="a08225cb-b2d8-4c07-94fe-d43cbd6a5de6">
