    </JadeMethod>
    <JadeMethod name="getOnsiteLocationsController" id="9efefe05-8155-4547-8ee3-8750b134325c">
        <source>getOnsiteLocationsController() : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
07 Feb 2017	cnwab1	Initial creation
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	listObject : CM_Object;
	ta : CM_TerminalArea; 
	targetLocn : CM_LocationsController;
	gridObject : CM_GridObject;
	
begin
	listObject := self.cmbTerminalArea.listObject.CM_Object;
	if CM_TerminalArea.hasInstance(listObject) then
		ta := listObject.CM_TerminalArea; 
	elseif CM_LocationsController.hasInstance(listObject) then
		targetLocn := listObject.CM_LocationsController;
	elseif CM_Wagon.hasInstance(listObject) then
		targetLocn := self.cmbTARow.listObject.CM_LocationsController;
	endif;
	

	if targetLocn = null then
	
		if ta &lt;&gt; null then
			if ta.isGridArea() then
				gridObject := self.cmbTARow.listObject.CM_GridObject;
				if gridObject = null then 
					return null;
				endif;
				targetLocn := gridObject.getNextAvailableLocation(self.moveModeForm); 
				if targetLocn = null then
					return null;
				endif;
			elseif ta.isIrregularBlockArea()  or ta.type=TA_TYPE_RORO_LANE_AREA 
			or ta.isGeneralCargoAllocArea then										// TFS 49453
				targetLocn := self.cmbTARow.listObject.CM_LocationsController;
				if targetLocn = null then
					return null;
				endif;
			else
				targetLocn := ta.getLocationsController();		
			endif;
		endif;
	endif;
		
	return targetLocn;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForMove" id="d195f10e-973c-4716-aec8-35fdc40d7dc7">
        <source>getQuantityForMove( _moveController : CMIF_MoveController input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/09/2013	cnwndl1	Initial creation	Par 32479
02/12/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
17/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars

	ti : CM_TrackedItem;
	lForm : CMUI_GetData;
	quantity : Integer;
	form : CMUI_MoveAmountForm;
	weight : Decimal[14,4];
	wle : CM_WorkListEntry;
	lc : CM_LocationsController;
	fm : CM_FutureMove;				// TFS 52360
	fmp :  CM_FutureMovePlanned;	// TFS 52360
	useThisFm : CM_FutureMove;		// TFS 52360
begin

	ti := _moveController.myTrackedItem;
	
	if ti = null or _moveController = null then
		return true;
	endif;
	
	
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		return true;
	endif;
	
	app.mousePointer := MousePointer_Default;
	
	//directMove := ti.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;	// TFS 52360	// TFS 52293
	create form transient;
	form.myTrackedItem:= ti;
	if _moveController.myToPrimaryLocation &lt;&gt; null then
		form.targetLocation:=_moveController.myToPrimaryLocation.getFullId;
	elseif _moveController.isMoveToPlanned then			// 25/7/17 MAP TFS4719
	
		/* WAS TFS 43424 test team got a 1090 whilst testing 43424, this is not part of the changes.
		if ti.myCargoType.isBreakBulkMulti then
			form.txtQuantity.text := (ti.totalQuantity.min(_moveController.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry.quantity)).String;
		elseif ti.myCargoType.isTrackByWeight then
			form.txtQuantity.text := (ti.totalWeight.min(_moveController.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry.weight)).String;
		elseif ti.myCargoType.isTrackByVolume and ti.getDensity() &lt;&gt; 0 then
			form.txtQuantity.text := (ti.totalVolume.min(_moveController.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry.weight / ti.getDensity())).String;
		endif;
		if _moveController.myTrackedItem.allPlannedFutureMoves.size &gt; 0 and _moveController.myTrackedItem.allPlannedFutureMoves[1].getLocationsArray().size &gt; 0 then
			form.targetLocation := _moveController.myTrackedItem.allPlannedFutureMoves[1].getLocationsArray().first().getFullId();
		else
			form.targetLocation := app.getErrorString(Planned_location);
		endif;
		NOW */
		// TFS 52360 For direct moves, there may be more than 1 future planned move
		//if directMove then																					// TFS 52293
			foreach fm in ti.allPlannedFutureMoves do
				fmp := fm.CM_FutureMovePlanned;
				if fmp.myWorkListEntry &lt;&gt; null and fmp.myWorkListEntry.isKindOf(CM_VoyageWLE) and fmp.myWorkListEntry.CM_VoyageWLE.subSeqNum &lt;&gt; null then
					if fmp.myWorkListEntry.job &lt;&gt; null and fmp.myWorkListEntry.job.isDirectDeliveryJob then		// TFS 52293
						wle := fmp.myWorkListEntry;
						useThisFm := fmp;
						break;
					endif;																						// TFS 52293
				endif;
			endforeach;
		//else																									// TFS 52293
		// TFS 52360 end of this bit
		if useThisFm = null then																				// TFS 52293
			wle := _moveController.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry;
		endif;
		if wle &lt;&gt; null then
			if ti.myCargoType.isBreakBulkMulti then
			form.txtQuantity.text := (ti.totalQuantity.min(wle.quantity)).String;
			elseif ti.myCargoType.isTrackByWeight then
				form.txtQuantity.text := (ti.totalWeight.min(wle.weight)).String;
			elseif ti.myCargoType.isTrackByVolume and ti.getDensity() &lt;&gt; 0 then
				form.txtQuantity.text := (ti.totalVolume.min(wle.weight / ti.getDensity())).String;
			endif;
		endif;
		if _moveController.myTrackedItem.allPlannedFutureMoves.size &gt; 0 then
			if useThisFm = null then							// TFS 52360
				lc := _moveController.myTrackedItem.allPlannedFutureMoves[1].getLocationsArray().first();
			else												// TFS 52360
				lc := useThisFm.getLocationsArray().first();	// TFS 52360
			endif;												// TFS 52360
		
			if lc &lt;&gt; null then
				form.targetLocation := lc.getFullId();
			else
				form.targetLocation := app.getErrorString(Planned_location);
			endif;
		else
			form.targetLocation := app.getErrorString(Planned_location);
		endif;
		
	else
		form.targetLocation:="Off Site";
	endif;
		
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	if form.byQuantity then
		_moveController.setQuantity (form.getQuantity);
	else
		_moveController.setWeight( form.getWeightMovedKgs);
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRRPWles" id="706b8d61-9666-4633-b35b-93ca60efd096">
        <source>getRRPWles(_tiSet : CM_TISet io; _wles : Collection input; _mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2025	jlier1	Initial creation JIRA# 36738

*/

vars
	ti : CM_TrackedItem;
	tiToRemove : CM_TISet;
	wle : CM_WorkListEntry;
begin
	if _tiSet = null then
		return;
	endif;
	
	create tiToRemove transient;
	
	foreach ti in _tiSet discreteLock do
		if ti.isRRPforVoyage then
			wle := ti.allWorklistEntries.getFirstUnactionedWLE();
			if wle &lt;&gt; null and wle.isKindOf(CM_VoyageWLE) and wle.CM_VoyageWLE.getMyVoyageObject = self.myCurrentVoyage then
				if _mode = QUEUE_MODE then
					if not wle.allRTQueueEntries.isEmpty then
						_wles.tryAdd(wle);
						tiToRemove.tryAdd(ti);
					endif;
				elseif _mode = PLANNING_MODE then
					if wle.myFutureMove &lt;&gt; null then
						_wles.tryAdd(wle);
						tiToRemove.tryAdd(ti);
					endif;
				endif;
			endif;
		endif;
	
	endforeach;
	
	foreach ti in tiToRemove do
		_tiSet.tryRemove(ti);
	endforeach;	
	
epilog
	delete tiToRemove;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_wles" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="baca3985-91bd-49f1-a978-cc4b7c08c554">
        <source>getRowColour( _int : Integer; _table : CM_DataTable input ) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

constants
	PaleBlueRow : Integer = 16772055;
	PaleRedRow : Integer = 15522303;
	PaleGreenRow : Integer = 12058551;
vars

begin

	if _int = 2 then
		return self.colorRow1;
	endif;
	
	if _table = tblOnship then
		if displayModeOnShip = DISPLAY_MODE_ACTUAL then
			return PaleBlueRow;
		elseif displayModeOnShip = DISPLAY_MODE_QUEUE then
			return PaleRedRow;
		elseif displayModeOnShip = DISPLAY_MODE_PLAN then
			return PaleGreenRow;
		endif;
	elseif _table = tblOnsite then
		if displayModeOnSite = DISPLAY_MODE_ACTUAL then
			return PaleBlueRow;
		elseif displayModeOnSite = DISPLAY_MODE_QUEUE then
			return PaleRedRow;
		elseif displayModeOnSite = DISPLAY_MODE_PLAN then
			return PaleGreenRow;
		endif;
	elseif _table = tblOffsite then
		if displayModeOffSite = DISPLAY_MODE_ACTUAL then
			return PaleBlueRow;
		elseif displayModeOffSite = DISPLAY_MODE_QUEUE then
			return PaleRedRow;
		elseif displayModeOffSite = DISPLAY_MODE_PLAN then
			return PaleGreenRow;
		endif;
	elseif _table = tblPreNote then
		if displayModePreNote = DISPLAY_MODE_ACTUAL then
			return PaleBlueRow;
		elseif displayModePreNote = DISPLAY_MODE_QUEUE then
			return PaleRedRow;
		elseif displayModePreNote = DISPLAY_MODE_PLAN then
			return PaleGreenRow;
		endif;
	endif; 
	
	//default
	return self.colorRow2;
	
epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSiteForTable" id="b6044886-ac74-42f3-b02c-87c10e70de06">
        <source>getSiteForTable(_table : CM_DataTable) : Integer protected;

/*

Purpose:			
		This method returns the Site of the table we are interested in
		
Parameters:			

Return Value:		

Date		Who		Reason
28/11/2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
12/04/2023	navmd1	TFS 56062 Fix Cargo Group Detail headers not updating correctly. Moved up from SHP_VoyageOpsCargoGroupForm

*/

vars

begin
	if _table = self.tblOnship then
		return TI_SITE_ONSHIP;
	elseif _table = self.tblOnsite then
		return TI_SITE_ONSITE;
	elseif _table = self.tblOffsite then
		return TI_SITE_OFFSITE;
	elseif _table = self.tblPreNote then
		return TI_SITE_UNDEFINED;
	endif;
	
	return TI_SITE_UNDEFINED;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVoyJobTransferType" id="61b0e472-b94d-48b6-a1f9-52e9586eb371">
        <source>getVoyJobTransferType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	voyTfrType : CM_VoyageJobTransferType;

begin

	if self.cmbTransferType.listIndex &gt; 0 then
		voyTfrType := self.cmbTransferType.listObject.CM_VoyageJobTransferType;
	endif;
	
	if voyTfrType &lt;&gt; null then
		return voyTfrType.id;
	endif;

	return VESSEL_TYPE_RORO;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVoyageWLE" id="efe7921b-b98c-4028-8e4b-08a75d23a6d1">
        <source>getVoyageWLE() : CM_VoyageWLE;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	wle	: CM_WorkListEntry;
	
begin
	if self.myCurrentTrackedItem = null then
		return null;
	endif;
	foreach wle in self.myCurrentTrackedItem.allWorklistEntries do
		if wle.isKindOf (CM_VoyageWLE) then
			return wle.CM_VoyageWLE;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e60d1f6a-9ca0-494e-85bc-f06c54c82c4f">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 16/03/2015	cnwmh5		Tranisent Leaks
// 08/12/2022	navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
//
vars
	xmlStr	: String;
	strArray : StringArray;
	layout : Integer;

begin
	xmlStr := inheritMethod();
	xmlStr := xmlStr &amp; self.tblOnship.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblOffsite.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblOnsite.getXmlStrForColumns(true);	
	xmlStr := xmlStr &amp; self.tblPreNote.getXmlStrForColumns(true);	
	
	//cnwrd1 par 25465 24.8.2010	
	create strArray transient;
	strArray.add('id');
	//stmp := self.lstCargoTypes.getXMLStringForSelected(strArray);
	//xmlStr := xmlStr &amp; stmp;
		
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourPlanned, self.xmlColourPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourNonPlanned, self.xmlColourNonPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourOnShip, self.xmlColourOnShip.String);
	
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagIncludeDD, self.chkDirDel.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourTableCells, self.chkColourCells.value.String);

	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagShowOffSite, self.chkShowOffsite.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagShowPrenotes, self.chkPreNote.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagConfirmAllMoves, self.chkConfirmAllMoves.value.String);	// 28/6/17 MAP TFS4719
	
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagRememberSettings, self.chkRemember.value.String);
	
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagVoyageLOLO, self.chkLOLOBays.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagVoyageRORO, self.chkRORODecks.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagVoyageHold, self.chkHolds.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagVoyageBlockStack, self.chkBlockStack.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagVoyageCurrent, self.chkCurrentVoyages.value.String); // TFS 50012
	
	if self.btnNormal.value then
		layout := 1;
	elseif self.btnVertical.value then
		layout := 2;
	elseif self.btnHorizontal.value then
		layout := 3;
	endif;
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagLayout, layout.String);
	
	xmlStr := xmlStr &amp; self.getXMLStrForTablePositions;
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkTableCount.name, self.chkTableCount.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkAllowFilter.name, self.chkAllowFilter.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkAllowMore20.name, self.chkAllowMore20.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkNumOfRowPerTable.name, self.chkNumOfRowPerTable.value.String); // 08/12/2022	navkc1	#55409
	xmlStr := xmlStr &amp; global.formatAsXML(self.txtNumOfRow.name, self.txtNumOfRow.text);					 // 08/12/2022	navkc1	#55409
	
	return xmlStr;
epilog
	delete strArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForTablePositions" id="bce4eb52-87b2-464c-82b5-3ddbddf7f188">
        <source>getXMLStrForTablePositions() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	tmpStr, xmlStr : String;

begin
	tmpStr := self.dkcTop.parent.name &amp; Comma &amp; self.dkcTop.left.String &amp; Comma &amp; self.dkcTop.top.String &amp; Comma &amp; self.dkcTop.width.String &amp; Comma &amp; self.dkcTop.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcTop.name, tmpStr);
	
	tmpStr := self.dkcBottom.parent.name &amp; Comma &amp; self.dkcBottom.left.String &amp; Comma &amp; self.dkcBottom.top.String &amp; Comma &amp; self.dkcBottom.width.String &amp; Comma &amp; self.dkcBottom.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcBottom.name, tmpStr);
	
	tmpStr := self.dkcOnShip.parent.name &amp; Comma &amp; self.dkcOnShip.left.String &amp; Comma &amp; self.dkcOnShip.top.String &amp; Comma &amp; self.dkcOnShip.width.String &amp; Comma &amp; self.dkcOnShip.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcOnShip.name, tmpStr);
	
	tmpStr := self.dkcOnTerminal.parent.name &amp; Comma &amp; self.dkcOnTerminal.left.String &amp; Comma &amp; self.dkcOnTerminal.top.String &amp; Comma &amp; self.dkcOnTerminal.width.String &amp; Comma &amp; self.dkcOnTerminal.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcOnTerminal.name, tmpStr);
			
	tmpStr := self.dkcOffSite.parent.name &amp; Comma &amp; self.dkcOffSite.left.String &amp; Comma &amp; self.dkcOffSite.top.String &amp; Comma &amp; self.dkcOffSite.width.String &amp; Comma &amp; self.dkcOffSite.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcOffSite.name, tmpStr);
			
	tmpStr := self.dkcPreNotes.parent.name &amp; Comma &amp; self.dkcPreNotes.left.String &amp; Comma &amp; self.dkcPreNotes.top.String &amp; Comma &amp; self.dkcPreNotes.width.String &amp; Comma &amp; self.dkcPreNotes.height.String;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_TagTablePosition &amp; self.dkcPreNotes.name, tmpStr);
	
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleDDlocationNotes" id="d76f2ec8-73ec-4854-9729-12afaa5de990">
        <source>handleDDlocationNotes( _object : CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	selectedObj : CM_Object;
	idx : Integer;
	wagon : CM_Wagon;
	vehicle : CM_Vehicle;
	roadJob	:CM_RoadJob;
	vehicleLC : CM_LocationsController;
	cmbObject : CM_Object;

begin

	if _object.isKindOf( CM_Wagon ) then
		wagon := _object.CM_Wagon;
		cmbObject := wagon;
	elseif _object.isKindOf( CM_Vehicle ) then
		vehicle := _object.CM_Vehicle;
		vehicleLC := vehicle.locationsController;
		cmbObject := vehicleLC;
	else
		return;
	endif;

	if self.chkDirDel.value = true then
		if wagon &lt;&gt; null then
			if wagon.confirmed and self.myTerminal.allTrainsOnTerminal.includes(wagon.myTrainOutwards) then
				//its confirmed and belongs to a current train, it should be listed.
				if self.cmbTerminalArea.findObject( cmbObject ) = -1 then
					//its not so add it.
					idx := self.cmbTerminalArea.addItem( wagon.id &amp; " " &amp; app.getErrorString(Rail) );
					self.cmbTerminalArea.itemObject[idx] := cmbObject;
				else
					//it is, so nothing to do
				endif;
				return;
			endif;
		elseif vehicle &lt;&gt; null then
			roadJob	:= vehicle.allRoadJobs.first.CM_RoadJob;
			if roadJob &lt;&gt; null and self.myTerminal.myRoadJobSheet.allJobsByOrder.includes(roadJob) then
				//its confirmed and belongs to a current train, it should be listed.
				if self.cmbTerminalArea.findObject( cmbObject ) = -1 then
					//its not so add it.
					idx := self.cmbTerminalArea.addItem( vehicleLC.getFullId );
					self.cmbTerminalArea.itemObject[idx] := cmbObject;
				else
					//it is, so nothing to do
				endif;
				return;
			endif;
		endif;
	endif;
	
	// we are either not showing direct delivery locations or the wagon should not be included. 
	if self.cmbTerminalArea.findObject( cmbObject ) &lt; 1 then
		//Its not, all is good
		return;
	endif;
	
	selectedObj := self.cmbTerminalArea.listObject.CM_Object;
	if selectedObj = cmbObject then
		// its selected, deselect it
		self.cmbTerminalArea.listIndex := -1;
		self.cmbTARow.listIndex := -1;
	endif;
			
	self.cmbTerminalArea.removeObject(cmbObject);	
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedTI" id="7775f060-0658-4d06-9d6f-e7436a439a18">
        <source>handleDeletedTI(_ti : CM_TrackedItem);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2015	cnwdap1		Initial creation PAR #35397 CCM SSFW 1394 Voyage Rationalisation
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
//
vars
	idx : Integer;

begin
	// a deleted object could have come from the onship table, or the prenote table
	// or since adding RRP items for assigning release; the onsite table too
	idx := 1;
	if self.tblOnship.findObjectInRow(_ti, idx) then
		self.tblOnship.removeItem(idx);
	elseif self.tblPreNote.findObjectInRow(_ti, idx) then
		self.tblPreNote.removeItem(idx);
	elseif self.tblOnsite.findObjectInRow(_ti, idx) then
		self.tblOnsite.removeItem(idx);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionTI" id="3cbaa288-83cd-435f-8723-6ebd4dc3be50">
        <source>handleExceptionTI(exObj : Exception; _ti : CM_TrackedItem io) : Integer protected;
//--------------------------------------------------
// Created:	28 June 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_ti := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionVoyage" id="7b1a8c7a-f30a-4497-877d-1f32c8fd7d31">
        <updating/>
        <source>handleExceptionVoyage(exObj : Exception; _voyage : CM_Voyage io) : Integer updating, protected;
//--------------------------------------------------
// Created:	22 October 2003 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_voyage := null;
		app.msgBox(app.getErrorString(VoyageRemoved), 'Voyage Not Found', MsgBox_Stop_Icon + MsgBox_OK_Only);		
	//	Do not attempt to remove from dict as this dereferences the object
	//  and causes another exception.
		self.doRefresh();
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleInterruptExceptions" id="daa4da1b-dd59-4fb0-a419-60c274910dd7">
        <source>handleInterruptExceptions(_exc : Exception) : Integer protected;

/*

Purpose:			Local exception handler to be armed any time we are refreshing the tables so we can cancel and bail early
					

Parameters:			Exception object

Return Value:		Standard JADE exception return code


Date					Who			Reason
08 November 2022		navmd1		TFS 55379 Refactor VoyageOpsCG Form

*/

constants
	InterruptEx	= 4035;
	
vars
	
begin	
	// Not an Interrupt request ? Then not for us
	if not _exc.errorCode = InterruptEx then
		return Ex_Pass_Back;
	endif;
	
	return Ex_Abort_Action;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasMultiSelectedQueuedItems" id="ae8f9e56-5ab5-49e5-a8cc-b29e4b121add">
        <source>hasMultiSelectedQueuedItems(_table : CM_FilterTable) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	obj : Object;
	ti : CM_TrackedItem;
	count : Integer;

begin
	if _table.allSelectedObjects.size &lt; 2 then
		return false;
	endif;
	
	foreach obj in _table.allSelectedObjects do
		if CM_TrackedItem.hasInstance( obj ) then
			ti := obj.CM_TrackedItem;
			if not ti.isQueued then
				continue;
			endif;
			count := count + 1;
			if count &gt; 1 then
				break;
			endif;
		endif;
	endforeach;
	
	return ( count &gt; 1 );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_FilterTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="432ddf72-e391-444a-b636-b2b9fae989ca">
        <source>includeObject(_ti : CM_TrackedItem) : Boolean protected;
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 12/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	failedDAC : CM_DataAccessController;			// TFS 44554

begin
	
	if _ti = null then
		return false;
	endif;
	
	//if not self.allCargoTypes.includes(_ti.myCargoType) then //+ cnwmd1 Par 22803
	//	return false;
	//endif;
	
	if _ti.isChild then	//30 Jun 2010	NDL Par 24602 don't show children individually, you can't move them...
		return false;
	endif;
	
	if not _ti.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then		// TFS 44554
		return false;																// TFS 44554
	endif;																			// TFS 44554
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
