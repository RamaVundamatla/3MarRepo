<Class name="CMIF_EntTableLikeFormDecorator" id="6cceeaba-f1b6-466a-81e1-d8825bd80303">
    <superclass name="CMIF_EntTableDecorator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
