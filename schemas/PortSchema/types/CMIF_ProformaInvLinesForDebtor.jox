    <JadeMethod name="addAdditionalCharges" id="1c0e3978-2de4-4f6b-9d47-c5baf03a5ebf">
        <source>addAdditionalCharges(_addtionalCharges : CM_InvoiceLineBySeqNumDict input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlger1	Initial creation	TFS 44651

*/

vars

	invLineType : CM_InvoiceLineDesc;
	invLine, proInvLine : CM_InvoiceLine;
	obj : Object;
	agent : CM_CashProformaWorkOrderAgent;

begin
	if _addtionalCharges = null or _addtionalCharges.first = null then
		return;
	endif;
	
	foreach invLine in _addtionalCharges	discreteLock do
			if not self.allInvoiceLines.includes(invLine) then
				self.allInvoiceLines.add(invLine);
			endif;
	endforeach;
	
	foreach obj in self.allProformaAgents	discreteLock do
		agent := obj.CM_CashProformaWorkOrderAgent;
		
		foreach invLine in _addtionalCharges	discreteLock do
			if not agent.allProformaInvLines.includes(invLine) then
					agent.allProformaInvLines.add(invLine);
			endif;
		endforeach;
		agent.setEstimatedCashCharges();
	endforeach;
	
epilog

end;</source>
        <Parameter name="_addtionalCharges" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSurcharges" id="6770663e-ac30-4f25-8c4a-f7df56e599e1">
        <source>addSurcharges();
/*

Purpose:			TFS 41684

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2018	jlgab1	Initial creation

*/

vars
	invLineType : CM_InvoiceLineDesc;
	invLine, proInvLine : CM_InvoiceLine;
	obj : Object;
	agent : CM_CashProformaWorkOrderAgent;

begin

	foreach obj in self.allProformaAgents	discreteLock do
		agent := obj.CM_CashProformaWorkOrderAgent;
		
		foreach invLine in self.allInvoiceLines	discreteLock do
			if not agent.allProformaInvLines.includes(invLine) then
					agent.allProformaInvLines.add(invLine);
			endif;
		endforeach;
	
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cleanupProformaReferences" id="08b5f7ac-3424-4cd8-a7b0-dad349f3086a">
        <source>cleanupProformaReferences();
/*

Purpose:			TFS 39349

Parameters:			

Return Value:		

Date		Who		Reason
01 August	jlgab1	Initial creation

*/

vars
	agent : CM_CashProformaWorkOrderAgent;
	obj : Object;

begin
	foreach obj in self.allProformaAgents	discreteLock do
		agent := obj.CM_CashProformaWorkOrderAgent;
		
		if agent.myTrackedItem &lt;&gt; null then
			if not global.isValidObject(agent.myTrackedItem) then
				agent.nullMyTrackedItem();
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateAllTransients" id="433d3d57-3f76-4055-abe2-d9a2a225318d">
        <updating/>
        <source>populateAllTransients(_allPxyCashPays : CM_CashPaymentSet) updating;
/*
Purpose:	TFS 45953		
Date				Who			Reason
OCTOBER 2019		JLGAB1 initial creation
*/


vars
	obj : Object;
	pxyCashPayment, pxyTaxCashPayment : CM_CashPayment;
begin
	foreach obj in _allPxyCashPays	discreteLock do
		if not obj.isTransient then
			continue;
		endif;
		
		pxyCashPayment := obj.CM_CashPayment;
		self.allTransientsToDelete.add(pxyCashPayment);
		
		pxyTaxCashPayment := pxyCashPayment.myCashPaymentForTax;
		if pxyTaxCashPayment &lt;&gt; null and pxyTaxCashPayment.isTransient() then
			self.allTransientsToDelete.add(pxyTaxCashPayment);
			
			if pxyTaxCashPayment.allCashCreditDetails &lt;&gt; null 
			and not pxyTaxCashPayment.allCashCreditDetails.isEmpty then
				pxyTaxCashPayment.allCashCreditDetails.copy(self.allTransientsToDelete);
			endif;
			if pxyTaxCashPayment.myProformaDetail &lt;&gt; null 
			and pxyTaxCashPayment.myProformaDetail.isTransient then
				self.allTransientsToDelete.add(pxyTaxCashPayment.myProformaDetail);
			endif;
		endif;
		if pxyCashPayment.allCashCreditDetails &lt;&gt; null 
		and not pxyCashPayment.allCashCreditDetails.isEmpty then
			pxyCashPayment.allCashCreditDetails.copy(self.allTransientsToDelete);
		endif;
		if pxyCashPayment.myProformaDetail &lt;&gt; null 
		and global.isValidObject(pxyCashPayment.myProformaDetail) //30/04/2025	navkc1 JIRA Bug MTN-34734/34800
		and pxyCashPayment.myProformaDetail.isTransient then
			self.allTransientsToDelete.add(pxyCashPayment.myProformaDetail);
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_allPxyCashPays" type="CM_CashPaymentSet"/>
    </JadeMethod>
    <JadeMethod name="proformaAddMinChargesForWhole" id="c1b78557-d06d-4b0f-bd60-c74cf262c5e8">
        <source>proformaAddMinChargesForWhole(_proxyCashReceipt : CM_CashReceipt; _allPxyCashPays : ObjectArray input);
/*
Purpose:	TFS 45953		
Date				Who			Reason
SEPTEMBER 2019		JLGAB1 initial creation
*/


// ########## UNTIL 871 THIS IS DMAST ONLY





vars
	pxyCashPayment 		: CM_CashPayment;
	proformaDetail, 
	minAmount 			: CM_ProformaDetails;
	allMinimumAmounts   : CM_ProformaDetailsByInvType;
	newLine 			: CM_InvoiceLine;
	seqNum			    : Integer;
	now 			    : TimeStamp;
	charge 				: CM_Charge;
	bank 				: CM_Bank;
	debtor 				: CM_Debtor;
	drterm 				: CM_DebtorTerminal;
	tempAgent 			: CM_CashInvoiceProformaAgent;
	invCashPayment, 
	taxCashPayment, 
	totalAllocated 		: Real;
	localProxyCashReceipt : CM_CashReceipt;
	
	lineType : CM_InvoiceLineDesc;
	firstTI : CM_TrackedItem;
begin
	now := app.actualTimeServer();	

	if _proxyCashReceipt = null then
		return;
	endif;
	
	
	if _proxyCashReceipt.allCashPayments.isEmpty() then
		return;
	endif;
	
	// TFS 47852 already has min charge 
	foreach pxyCashPayment in _proxyCashReceipt.allCashPayments do
		if pxyCashPayment.isMinimumCharge then
			return;
		endif;
	endforeach;
	
	
	localProxyCashReceipt := _proxyCashReceipt;
	
	totalAllocated := _proxyCashReceipt.cashValue;
	
	create tempAgent transient;
	
	foreach pxyCashPayment in _proxyCashReceipt.allCashPayments do
		lineType := null; // TFS 47852
		if pxyCashPayment.myProformaDetail &lt;&gt; null then // TFS 47852
			lineType := pxyCashPayment.myProformaDetail.myInvoiceLineType; // TFS 47852
		elseif pxyCashPayment.myInvoiceLine &lt;&gt; null then // TFS 47852
			lineType := pxyCashPayment.myInvoiceLine.invoiceLineDesc; // TFS 47852
		else	
			continue; // TFS 47852
		endif;
		
		if firstTI = null then // TFS 47852
			firstTI := pxyCashPayment.myTrackedItem; // TFS 47852
		endif;
			
		/*First Type of Minimum Charge By Invoice */
		if lineType.minimumChargeGroupBy = CM_InvoiceLineDesc.GROUP_BY_INVOICE then
			if allMinimumAmounts = null then
				create allMinimumAmounts transient;
			endif;
			
			minAmount := allMinimumAmounts[lineType];
			if minAmount= null then
				create minAmount transient;
				minAmount.setPropertyValue(CM_ProformaDetails::myInvoiceLineType.name, lineType);
				allMinimumAmounts.add(minAmount);
			endif;
			
			minAmount.setValue(minAmount.lineTotal + pxyCashPayment.cashValue);
			
			if bank= null then
				bank := pxyCashPayment.getBank();
			endif;
			if drterm = null then
				drterm := pxyCashPayment.myDebtorTerminal;
				debtor := drterm.myDebtor;
			endif;		
		endif;
	endforeach;
	
	if allMinimumAmounts = null then
		return;
	endif;
	
	foreach minAmount in allMinimumAmounts discreteLock do
		if minAmount.myInvoiceLineType.minimumChargeAmount &gt; minAmount.lineTotal then
			invCashPayment := minAmount.myInvoiceLineType.minimumChargeAmount - minAmount.lineTotal;
			
			
			
			
			create newLine transient;
			seqNum := seqNum + 1;
		    newLine.setForCreate(seqNum, false, null, minAmount.myInvoiceLineType.minimumChargeInvoiceLineType, null, debtor, bank, 1, now);
			newLine.createChargesProforma(seqNum);
			foreach charge in newLine.charges do
				charge.total := invCashPayment;
				charge.setOverriden();
				charge.setRateForMinMax(invCashPayment);
			endforeach;
			
			newLine.setTotalAmount(); //29/09/2025	navkc1 JIRA 35917
			
			taxCashPayment := newLine.getTaxAmountForLine();                                       //23.09.2019 cnwma1 #46673
			tempAgent.setMyTrackedItem(firstTI); //TFS 47985
			pxyCashPayment := tempAgent.createProxyPaymentForList(true,                            //23.09.2019 cnwma1 #46673  
																false, // TFS 45953
																localProxyCashReceipt,
																newLine, 
																invCashPayment, 
																taxCashPayment, 
																totalAllocated,
																now,
																drterm,
																null);
			
			pxyCashPayment.setCashReceipt(_proxyCashReceipt);
			_allPxyCashPays.add(pxyCashPayment);
			pxyCashPayment.setIsMinimumCharge(true);
			
			// TFS 47852 need to attach the payment to a TI (any TI on the receipt) so that if re calc in cash collection it will be shown. 
			//					Re-calc means calcuate, save and re calculate
			//					These min charge by Invoice are other wise only linked to a cash receipt.
			//					Cash Collection always starts with cargo, so must link this to a TI on the receipt
			pxyCashPayment.setMyTrackedItem(firstTI); 
			
			delete newLine;
		endif;
	endforeach;
	
	
epilog
	delete tempAgent;
	delete newLine;
	if allMinimumAmounts&lt;&gt; null then
		allMinimumAmounts.purge();
		delete allMinimumAmounts;
	endif;
end;</source>
        <Parameter name="_proxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_allPxyCashPays" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="proformaProxyCashPayments" id="399b3b6f-6c2f-4cbd-885b-8647f927f099">
        <source>proformaProxyCashPayments(_pxyCashReceipt : CM_CashReceipt io; _allAgents : CM_CashProformaAgentSet; _includeUpdatesToPayments : Boolean);
/*
Purpose:	TFS 45953		
Date				Who			Reason
SEPTEMBER 2019		JLGAB1 initial creation
27/11/2019			jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
*/


// ########## UNTIL 871 THIS IS DMAST ONLY


vars

	pxyObj 					: Object;
	cashCredit				: CM_CashCredit;
	pxyCashPay              : CM_CashPayment;
	allPxyCashPays 			: ObjectArray;
	allPxyCreditDetails 	: ObjectArray;
	availableCredits		: ObjectArray;
	availableCreditAmounts	: DecimalArray;	
	proformaAgent 			: CM_CashInvoiceProformaAgent;
	voyageAgent 			: CM_CashProformaVoyageAgent;
	drTerm					: CM_DebtorTerminal;
	now						: TimeStamp;
	totalToPay,				
	totalCreditApplied,		
	creditAvailable			: Decimal[23,6];//[16,4]; // TFS 47529
	invalidObject			: Boolean;
	edition					: Integer;

begin

	create allPxyCashPays transient;	// TFS 37454
	create allPxyCreditDetails transient;// TFS 37454
	
	now := app.actualTimeServer;
	
	if _pxyCashReceipt = null then		// something wrong, stop here
	
		app.invLog(method.qualifiedName &amp; " Cash Receipt not created! ", LogTRACE.String); // LOG CASH
		return;
	else
		edition := _pxyCashReceipt.edition;		// TFS4389 MAP 19/5/17 object not found was occurring when object got deleted during validation
		if invalidObject then
			_pxyCashReceipt := null;
			app.invLog(method.qualifiedName &amp; " Cash Receipt not created INVALID OBJECT ", LogTRACE.String); // LOG CASH
			return;
		endif;
	endif;
	
	drTerm     := _pxyCashReceipt.myDebtorTerminal;
	now 	   := _pxyCashReceipt.dateTime;
	totalToPay := _pxyCashReceipt.cashValue;

	create availableCredits transient;
	create availableCreditAmounts transient;
	
	foreach cashCredit in drTerm.allCashCredits reversed do
		creditAvailable := cashCredit.getCreditAvailable();
		if creditAvailable &gt; 0 then
			availableCredits.add(cashCredit);
			availableCreditAmounts.add(creditAvailable.roundedTo(2)); // jlgka1 TFS 44724
		endif;
	endforeach;

	foreach pxyObj in _allAgents do
		if pxyObj.isKindOf(CM_CashProformaVoyageAgent) then
			voyageAgent := pxyObj.CM_CashProformaVoyageAgent;
			voyageAgent.createProxyPaymentsForList(totalToPay, now, drTerm, allPxyCashPays, allPxyCreditDetails, availableCredits, availableCreditAmounts, _pxyCashReceipt, _includeUpdatesToPayments);
			totalCreditApplied := totalCreditApplied + voyageAgent.totalCreditApplied;
		else
			proformaAgent := pxyObj.CM_CashInvoiceProformaAgent;
			proformaAgent.createProxyPaymentsForList(totalToPay, now, drTerm, allPxyCashPays, allPxyCreditDetails, availableCredits, availableCreditAmounts, _pxyCashReceipt, _includeUpdatesToPayments);
			totalCreditApplied := totalCreditApplied + proformaAgent.totalCreditApplied;
		endif;
	endforeach;
	
	//if got errors would of aborted then _pxyCashReceipt will be invalid and get error 4 epr TFS 2423 26/6/17
	if app.myPassport.hasErrors then
		app.invLog(method.qualifiedName &amp; " ERRORS 111 ", LogTRACE.String); // LOG CASH
		return;
	endif;
	
	_pxyCashReceipt.setCashAllocated(totalCreditApplied);
	
	if not allPxyCashPays.isEmpty then
		
		foreach pxyObj in allPxyCashPays do
			pxyCashPay := pxyObj.CM_CashPayment;
			// set payment link to receipt
			pxyCashPay.setCashReceipt(_pxyCashReceipt);		// populates receipt.allCashPayments
		endforeach;

		self.proformaAddMinChargesForWhole(_pxyCashReceipt, allPxyCashPays);
	
	endif;
	
epilog


	delete availableCredits;
	delete availableCreditAmounts;
	delete allPxyCashPays;	// TFS 45953
	
	delete allPxyCreditDetails;// TFS 45953
end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt" usage="io"/>
        <Parameter name="_allAgents" type="CM_CashProformaAgentSet"/>
        <Parameter name="_includeUpdatesToPayments" type="Boolean"/>
    </JadeMethod>
</Class>
