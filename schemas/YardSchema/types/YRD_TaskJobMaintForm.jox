    <JadeMethod name="hasWorkOrderBooking" id="6bbccbe1-5c95-4a1d-b3b0-008b4e1b74c4">
        <source>hasWorkOrderBooking() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 29/09/2021   navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	row 	 : Integer;
	woDetail : Object;

begin
	if self.tbTasks.visible then
		foreach row in self.tbTasks.fixedRows + 1 to self.tbTasks.rows do
			woDetail := self.tbTasks.accessRow(row).itemObject;
			if woDetail &lt;&gt; null and woDetail.isKindOf(CM_WodReceive) then
				return true;
			endif;
		endforeach;
	elseif self.cmbTask.visible then
		woDetail := self.cmbTask.listObject;
		if woDetail &lt;&gt; null and woDetail.isKindOf(CM_WodReceive) then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
