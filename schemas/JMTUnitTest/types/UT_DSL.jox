    <JadeMethod name="deleteWorkOrder" id="83362b26-c610-45db-8291-890f978dfab2">
        <source>deleteWorkOrder( _workOrder : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwrd1	Initial creation

*/

vars
	workOrder : CM_WorkOrder;
begin

	workOrder := app.getMyTerminalDO_NOT_USE.allWorkOrders[_workOrder];
	if workOrder &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteWorkOrder(workOrder, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
