    <JadeMethod name="doChangeDate" id="f2085896-3489-432c-859d-444ed367b8c1">
        <source>doChangeDate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars
	currentExpDate,
	newDate		: Date;
	
	numOfDays	: Integer;
	
	ti 			: CM_TrackedItem;
begin
	
	newDate := self.txtDate.getDate();
	
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		currentExpDate := self.getStorageDateForCal(ti, true); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
	endif;
	
	// If user has selected days in the past, just set it to 0;
	if newDate &lt; currentExpDate then
		self.txtAddDays.text := null;
		//app.msgBox("Date entered cannot be before the current free storage date (" &amp; currentExpDate.asStringJMT() &amp; ").", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString2(Date_enter_canno_befor_curre_f, self.getInvalidDateText(), currentExpDate.asStringJMT()), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	numOfDays := newDate - currentExpDate;
	
	self.txtAddDays.text := numOfDays.String;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeDays" id="93db6745-8cc6-43c3-9e05-e79fb6e2b2c9">
        <source>doChangeDays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars
	numOfAddDays	: Integer;
	
	currentExpDate,
	newDate			: Date;
	
	ti 				: CM_TrackedItem;
begin
	
	numOfAddDays := self.txtAddDays.text.Integer;
	
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		currentExpDate := self.getStorageDateForCal(ti, true); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
	endif;
	
	newDate := currentExpDate.addDays(numOfAddDays);
	
	self.txtDate.setDate(newDate);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="4b439268-76c7-4ab8-a150-71d43f33b4ec">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2012	cnwer1	Initial creation SFW 1295
08 Aug 2016	cnwma1	TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time
03 Mar 2021 cnwma1  Bug 50883: STWO - Storage Days Validation
*/
	
vars
	result : Integer;
	ti     : CM_TrackedItem;
	
begin
	
	//epr par 30841 5/12/12 in cargo enquiry edit mode update/create the ti transaction 
	if self.inEditMode then		
		if self.transController = null then       // 09/08/2016 cnwma1 TFS #2467 PAR #38101
			foreach ti in self.allTrackedItems do 
				//03.03.2021 cnwma1 #50883
//				if ti.hasTransactionOfType (TRANS_TYPE_FUTURE_STORAGE) then
				if ti.hasStartedFutureStorageProcess()  then // ### TFS BUG 58953 29JUN2023 NAVAB1
					app.raiseCMException1(ERR_UPDATE_ADDDAYS,ti.id,null,ti);
					return;
				endif;	
				
				global.createTxnControllerForType(TRANS_TYPE_FREE_STORAGE_ADJ,self.transController);
				self.transController.userId        := app.myPassport.getUserCode;
				self.transController.noCharge      := true;
				self.transController.myTrackedItem := ti;	
				self.transController.dateTime      := app.actualTimeServer;
				self.transController.CMIF_FreeStorageAdjustment.additionalStorageDays := self.txtAddDays.text.Integer;
				self.transController.CMIF_FreeStorageAdjustment.changeReason          := self.txtReason.text;
			endforeach;
		endif;
	else
		while true do
			app.myTrxUA.trxUpdateTIAddStorageDays(self.allTrackedItems,self.txtAddDays.text.Integer, self.txtReason.text, app.myPassport);   // 09/08/2016 cnwma1 TFS #2467 PAR #38101
			if app.myPassport.trxCompletedOK then
				break;
			else
				 result:= app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
		endwhile; 
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getInvalidDateText" id="59cdbefb-8aa4-4390-a95f-346ce1781db6">
        <source>getInvalidDateText() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars
	
begin
	
	return app.getErrorString(Free_storage_date);
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStorageDateForCal" id="d44cc980-be14-404a-b52a-a3938d65cc2a">
        <source>getStorageDateForCal(_ti : CM_TrackedItem; _excludeAdditionalDays : Boolean) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars
	date		: Date;
	numOfDays	: Integer;
	stoExpDtl	: CM_StorageExpiryDetail;
begin
	
	if _ti = null then
		return null;
	endif;
	
	stoExpDtl := _ti.getStorageExpiryDetail(); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
	
	//if _ti.getStorageExpiryDetail() = null then
	if stoExpDtl = null then //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936	
		return date;
	endif;
	
	date := _ti.deriveFreeStorageDateTime().date();
	
	//if not _isSetup then
	if _excludeAdditionalDays then
		//Get the original free storage end date without the additional days
		//Because on Save, TRX is getting the orignal date +  the num of days entered.
		//We want to display the date that MTN will be saving
		//date := date.addDays(_ti.getFreeStorageDays() * -1); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
		date := date.addDays(stoExpDtl.additionalStorageDays * -1); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
	endif;
	
	return date;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_excludeAdditionalDays" type="Boolean"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="isAllCargoHavingSameStoDate" id="10a6eaa1-c202-4ff9-bfd9-c887271c7673">
        <source>isAllCargoHavingSameStoDate() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936: EUP | Addition Storage Days - Date selection for Multiple cargo items with same storage Expiry date

*/

vars
	ti 				: CM_TrackedItem;
	tiStoEndDate,
	prevStoEndDate 	: Date;
begin
	
	prevStoEndDate := null;
	
	foreach ti in self.allTrackedItems do
		
		tiStoEndDate := self.getStorageDateForCal(ti, true);
		
		if prevStoEndDate &lt;&gt; null and tiStoEndDate &lt;&gt; prevStoEndDate then
			return false;
		endif;
		
		prevStoEndDate := tiStoEndDate;
	endforeach;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItems" id="e35da4d5-731c-4b34-8bf2-90f5fb4be57f">
        <updating/>
        <source>setMyTrackedItems(_tiArray : CM_TIArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2016	cnwma1	   TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time

*/

vars

begin
	self.allTrackedItems.clear();
	_tiArray.copy(self.allTrackedItems);
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e50b1dd9-bb42-4d37-aeb2-1f11b5ff74cf">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295
08 August 2016	cnwma1	   TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time

*/

vars
	ti		: CM_TrackedItem; //21/01/2025	navkc1 JIRA Bug MTN-33812
	today	: Date;
begin
	self.frmMain.transparent:=true;
	inheritMethod();
	if not self.allTrackedItems.isEmpty then                        // 09/08/2016 cnwma1 TFS #2467 PAR #38101
		
		self.myTrackedItem := self.allTrackedItems.last;   
		
		ti := self.myTrackedItem; //21/01/2025	navkc1 JIRA Bug MTN-33812
		
		//21/01/2025	navkc1 JIRA Bug MTN-33812
		if self.allTrackedItems.size() = 1	or 
			self.isAllCargoHavingSameStoDate() //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
			then
			self.lblMessage.caption := app.getErrorString(Pleas_enter_eithe_date_numbe_a);
			self.txtDate.setDate(self.getStorageDateForCal(ti, false)); //31/01/2025	navkc1 JIRA Defect Sub-task MTN-33936
		else
			//21/01/2025	navkc1 JIRA Bug MTN-33812 Hide them if we have more than 1 cargo selected, because each cargo might have different free storage end date
			self.frmMessage.visible := false;
			self.frmMain.top := self.frmMessage.top;
			
			self.lblDate.visible := false;
			self.txtDate.visible := false;
			
			self.lblReason.top := self.lblDate.top;
			self.txtReason.top := self.lblDate.top + 25;
			
			self.height -= self.frmMessage.height - self.lblDate.height;
		endif;
		
	endif;
	if ti &lt;&gt; null then
		self.txtAddDays.text:= ti.additionalStorageDays.asStringJMT;
		self.txtReason.text:= ti.getFreeStorageChangeReason(); // ### TFS BUG 60548 09OCT2023 NAVAB1
	endif;
	
	self.txtAddDays.setFocus(); //21/01/2025	navkc1 JIRA Bug MTN-33812
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c32d7b5c-a298-42b5-af33-7a2519a3a121">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 January 2025 10:31:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018615, locale);
	lblAddFreeDays.translateCaption(Xlat_0018616, locale);
	lblDate.translateCaption(Xlat_0027036, locale);
	lblMessage.translateCaption(Xlat_0027037, locale);
	lblReason.translateCaption(Xlat_0018617, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtAddDays_change" id="27c7b832-8dac-497f-b91f-ccd3f1a41436">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAddDays_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2025	navkc1 JIRA Bug MTN-33812: EUP - FR - Additional Storage Days - Date Selection

*/

vars

begin
	if self.txtAddDays.text.Integer &lt; 0 then
		app.msgBox(app.getErrorString(Days_entere_cannot_less_than), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.txtDate.visible then
		self.doChangeDays();
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtDate_lostFocus" id="e4be95ae-e338-48c3-8dd6-a5882e0809a8">
