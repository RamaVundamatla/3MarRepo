    <JadeMethod name="addToolbarControls" id="ce4b3d5b-b35c-4237-8d5e-4ca93dacb651">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
