    </PrimAttribute>
    <JadeMethod name="setLargestDepthSpan" id="7158b486-e5a7-4c50-bbb3-ad835abc9047">
        <updating/>
        <source>setLargestDepthSpan(_value : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.largestDepthSpan := _value;

end;


</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
