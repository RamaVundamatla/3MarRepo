    </JadeMethod>
    <JadeMethod name="doPrint" id="ede1ed0c-4ec9-4165-8fa3-4e1ab178113d">
        <updating/>
        <source>doPrint() updating;

// set selected locale and category(ies) - if validation is okay, then unload form to pass back to caller

vars

begin
	selectedLocale := cmbLocale.listObject.CM_Locale; 

	if selectedLocale = null then
		app.msgBox("Please select a locale", caption, MsgBox_Stop_Icon);
		cmbLocale.setFocus;
		return;
	endif;
	
	selectedCategories.clear;
	if chkTextMessages.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Exceptions]);
	endif;
	if chkFormCaptions.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_FormCaptions]);
	endif;
	if chkMenuEntities.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Menus]);
	endif;
	if chkPermissions.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Permissions]);
	endif;
	if chkReportNames.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_ReportNames]);
	endif;
	if chkTableEntities.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[EntTableRows]);
	endif;
	
	if selectedCategories.isEmpty then
		app.msgBox("Please select at least one category", caption, MsgBox_Stop_Icon);
		return;
	endif;
	
	selectAllTranslations := optAllTranslatio.value;
	
	modalResult := 1;
	unloadForm;

end;</source>
    </JadeMethod>
    <JadeMethod name="fileExHandler" id="46184c04-44cd-4267-8f13-6c78ff97db61">
        <source>fileExHandler(ex : FileException) : Integer;

vars

begin
	app.msgBox(ex.text, "Error", MsgBox_OK_Only);
	return Ex_Abort_Action;
end;
</source>
        <Parameter name="ex" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAgent" id="d91d4091-b0b9-4eea-8d4b-584167f36561">
        <updating/>
        <source>setAgent(agent : CM_TranslationAgent) updating;
// Used by the SOP_TextTransalationForm to pass the agent object
begin
	self.agent := agent;
end;
</source>
        <Parameter name="agent" type="CM_TranslationAgent"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4454a3cc-4db6-48fa-97fa-72ab5ae5e78b">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	btnOk.visible:= false;
	btnCancel.visible:= false;
	
	cmbLocale.displayCollection(agent.myRoot.allLocales, false, 0, null, null);
	cmbLocale.listIndex := cmbLocale.findObject(agent.myRoot.myDefaultLocale);
	if cmbLocale.listIndex = -1 then
		cmbLocale.listIndex := cmbLocale.findObject(agent.myRoot.getStandardTextLocale(false));
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="79fc7e3b-8287-424f-adf8-bd9af14cee36">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007225, locale);
	btnPrint.translateBubbleHelp(Xlat_0004883, locale);
	btnPrint.translateCaption(Xlat_0004884, locale);
	chkFormCaptions.translateCaption(Xlat_0007226, locale);
	chkMenuEntities.translateCaption(Xlat_0007227, locale);
	chkPermissions.translateCaption(Xlat_0007228, locale);
	chkReportNames.translateCaption(Xlat_0007229, locale);
	chkTableEntities.translateCaption(Xlat_0007230, locale);
	chkTextMessages.translateCaption(Xlat_0007231, locale);
	lCategories.translateCaption(Xlat_0014528, locale);
	lLocale.translateCaption(Xlat_0014529, locale);
	optAllTranslatio.translateCaption(Xlat_0007232, locale);
	optExistResults.translateCaption(Xlat_0007233, locale);
end;</source>
    </JadeMethod>
