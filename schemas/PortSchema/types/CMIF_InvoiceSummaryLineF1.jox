        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isMafi" type="Boolean"/>
        <Parameter name="_isTowc" type="Boolean"/>
        <Parameter name="_isRoro" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
