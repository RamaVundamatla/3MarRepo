<CollClass name="CM_BOLTfrTransByTiDict" id="3741a363-c690-4528-96b3-77f89a6afb5f">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_BOLTransferTransaction"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <MemberKey>
        <property name="CM_BOLTransferTransaction::myTrackedItem"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_BOLTransaction::dateTime"/>
    </MemberKey>
    <JadeMethod name="getBolTfrHistForTi" id="1140e83d-c89b-408d-a498-2c0d779e27a9">
        <source>getBolTfrHistForTi( _ti : CM_TrackedItem; _lastBolTrx : CM_BOLTransferTransaction output ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation

*/

vars

	bolTrx : CM_BOLTransferTransaction;
	str : String;

begin

	if not self.isEmpty then	
		foreach bolTrx in self do
			_lastBolTrx := bolTrx;
			if str = null then
				str := bolTrx.getSourceBolString;
			endif;
			str := str &amp; "=&gt;";
			str := str &amp; bolTrx.getTargetBolString;
	//		workTrxs1.remove(bolTrx);
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lastBolTrx" type="CM_BOLTransferTransaction" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTfrTrnsForTi" id="e472eec8-177e-4aa9-ac24-2a8446bcdf59">
        <source>getTfrTrnsForTi(	_coll : CM_BOLTfrTransByTiDict input;
					_ti : CM_TrackedItem;
					_onePerTrxPair : Boolean
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	startBolTrx : CM_BOLTransferTransaction;
	bolTrx : CM_BOLTransferTransaction;
	iter : Iterator;
	matchingTrx : CM_BOLTransferTransaction;
	
	parentTi : CM_TrackedItem;
	parentColl : CM_BOLTfrTransByTiDict;

begin

	_coll.clear();

	startBolTrx := self.getAtKeyGeq( _ti, null ).CM_BOLTransferTransaction;
	if startBolTrx &lt;&gt; null and startBolTrx.myTrackedItem = _ti then
		iter := self.createIterator;
		iter.startAtObject(startBolTrx);
		while iter.next(bolTrx) do
			if bolTrx.myTrackedItem = _ti then
				if _onePerTrxPair then
					matchingTrx := bolTrx.getMatchingTfrTrx();
					if matchingTrx &lt;&gt; null and _coll.includes(matchingTrx) then
						continue;
					endif;
				endif;
				_coll.add( bolTrx );
			else
				break;
			endif;
		endwhile;
	endif;
	
	//17 Jun 2016	NDL	TFS 1904 - include split cargo....
	parentTi := _ti.getMySplitFromParent;
	if parentTi &lt;&gt; null then
		create parentColl transient;
		self.getTfrTrnsForTi(	parentColl,	//_coll : CM_BOLTfrTransByTiDict input;
								parentTi,	//_ti : CM_TrackedItem;
								_onePerTrxPair	//_onePerTrxPair : Boolean
								);
		
		foreach bolTrx in parentColl do
			_coll.addNoDuplicates(bolTrx,false);
		endforeach;
		delete parentColl;
	endif;
		

epilog

	delete iter;
	delete parentColl;

end;</source>
        <Parameter name="_coll" type="CM_BOLTfrTransByTiDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_onePerTrxPair" type="Boolean"/>
    </JadeMethod>
</CollClass>
