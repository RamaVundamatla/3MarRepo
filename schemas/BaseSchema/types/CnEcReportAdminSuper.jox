    <JadeMethod name="doCancelReportQueueEntry" id="0af7343e-21a6-43d8-908b-c6f58de62c85">
        <updating/>
        <source>doCancelReportQueueEntry(pTable:Table input) updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	if pTable.cnEcIsRowSelected(pTable.row) then
		tableRow		:=	pTable.accessRow(pTable.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;
		
		self.aMyTA.trxReportQueueEntrySetStatus(theQueueEntry, 0, CNEC_REPORT_CANCELLED, null);
	endif;

	self.doEnableButtons();
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCheckErrorStatus" id="b8894b5b-9402-41a3-849c-749a38080588">
        <updating/>
        <source>doCheckErrorStatus(pButton:Control input; pTable:Table) updating, protected;
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/11/2000	cnwdad1		Changed the "pButton" parameter from type "Button" to
//							type "Control" so that applications that reimplement
//							(subclass) these forms can use JadeMask controls
//							instead of Button controls.
// --------------------------------------------------------------------------------
vars
	theQueueEntry	: CnEcReportQueueEntry;
	table			: Table;
	tableRow		: JadeTableRow;

begin
	table	:=	pTable;

	if table.cnEcIsRowSelected(table.row) then
		tableRow		:=	table.accessRow(table.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;

		if theQueueEntry &lt;&gt; null and app.isValidObject(theQueueEntry) then
			if theQueueEntry.printStatus = CNEC_REPORT_ERROR then
				pButton.enabled	:=	true;
				return;
			endif;
		endif;
	endif;

	pButton.enabled	:=	false;
end;</source>
        <access>protected</access>
        <Parameter name="pButton" type="Control" usage="input"/>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtons" id="0bdfeb30-f4c6-4086-9323-4356a59336be">
        <updating/>
        <source>doEnableButtons() updating, protected;
//
// This method is an abstraction for subclass forms.
//
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPauseReportQueueEntry" id="88fdb0da-736d-4657-98ac-f7b6671cd279">
        <updating/>
        <source>doPauseReportQueueEntry(pTable:Table input) updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
