    <JadeMethod name="initCargoCounterForm" id="29b75eb2-27c7-4d57-adfd-d7fb87296b06">
        <source>initCargoCounterForm() : SHP_VoyageCargoCounterForm;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/01/2015	cnwdap1		Initial creation PAR #35397 CCM SSFW 1394 Voyage Rationalisation
//
vars
	form 		: SHP_VoyageCargoCounterForm;
	menuAction 	: CMUI_MenuAction;
	
begin
	menuAction := app.myController.createMenuAction(PmShipVoyageCargoCounter, null, self.myMasterMenuAction, self.myTerminal);
	
	if menuAction = null then
		return null;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).SHP_VoyageCargoCounterForm;

	if form = null then
		return null;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		form.myCurrentVoyage := self.myCurrentVoyage;
	else
		form.myCurrentVoyage := app.myCurrentVoyage;
	endif;
	
	return form;
epilog

end;</source>
        <ReturnType type="SHP_VoyageCargoCounterForm"/>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="4acfdf34-22d0-42a5-b1b2-0a904297a363">
        <source>initFilterTable();
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
//--------------------------------------------------
constants
	HorzGap = 5;
	//VertGap = 20;	//	navkc1	18/08/2025	JIRA MTN-35759
vars
	//theDef 	: EntTableDef;
	combo : CMUI_ComboBox;
