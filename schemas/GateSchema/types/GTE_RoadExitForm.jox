        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
// ---------------------------------------------------------------------------
vars
	
begin
	
	self.setNavigatorHeading(self.caption);
	self.allowAdd	 := false;
	self.allowUpdate := false;
	self.allowDelete := false;
	self.allowSearch := false;
	self.allowExportCSV := false;
	
