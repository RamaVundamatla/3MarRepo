begin
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		self.destinationPort := operator.getXlationSystemCode(_code[1:5].trimBlanks(), XLATION_TYPE_PORT_BYOP, foundMatch);
	else
		self.destinationPort := _code[1:5].trimBlanks(); //par 26352 cnwrs1 18 Nov 2010
	endif;
end;</source>
