    <JadeMethod name="delete" id="3fa098d1-491d-4692-a058-3433b0cbfec3">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 02 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allVoyageBookingSummary.purge();
	self.allVoyageSummaryObjects.purge();
	self.allCMIFJobTITotals.purge();
	self.allJobSequenceReporters.purge();
	


end;</source>
    </JadeMethod>
    <JadeMethod name="getDepartDateFromLocalTZ" id="4f6bdeba-8785-4d9c-bd8f-55efc6bd9d25">
        <source>getDepartDateFromLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.departDateFrom,self.departTimeFrom);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDepartDateToLocalTZ" id="8009cd78-20da-417b-84c0-90f143bfc3ea">
        <source>getDepartDateToLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.departDateTo,self.departTimeTo);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDepartTimeFromLocalTZ" id="325e4212-d26d-49df-af72-cdf22568b4bf">
