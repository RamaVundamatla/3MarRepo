    <JadeMethod name="getObjectAndPointsForPosClass" id="3eaeea66-3cf2-41aa-99df-f8e2e29f302c">
        <source>getObjectAndPointsForPosClass(_class: Class; x: Integer; y: Integer; xy1: Point output; xy2: Point output): Object;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject	: Object;
begin
	anObject:= self.myDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,_class);

	return anObject;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectAndPointsForPosition" id="eabfe8c5-2088-4f87-9800-187e94b07451">
        <source>getObjectAndPointsForPosition(x, y : Integer; xy1, xy2 : Point output) : Object;
// ---------------------------------------------------------------------------
// Created:     November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	anObject : Object;
begin
	tmpDrawingController := self.myDrawingController;

	if tmpDrawingController = null then
		return null;
	endif;

	if anObject = null then
		anObject:= tmpDrawingController.allGridObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_TrackedItem);
	endif;
	if anObject = null then
		anObject:= tmpDrawingController.allGridObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_FutureMove);
		if anObject = null then
			anObject:= tmpDrawingController.allGridObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_Restriction);
			if anObject = null then
				anObject:= tmpDrawingController.allGridObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_LocationsController);
				if anObject = null then
					anObject:= tmpDrawingController.allGridObjects.findObjectInDictByClass(x, y, xy1, xy2, CMIF_YardHeightExceeded);
					if anObject = null then
						anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,null);
					endif;
				endif;
			endif;
		endif;
	endif;

	return anObject;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForPosition" id="86c3e645-aa92-4649-81d8-d4ef9d83ae10">
