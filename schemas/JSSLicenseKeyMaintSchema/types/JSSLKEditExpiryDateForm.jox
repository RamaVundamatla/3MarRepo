    <JadeMethod name="btnCancel_click" id="7d0430ff-ef3f-49a3-9db8-9629ce55e9ab">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="b7986cc6-20e1-449a-9d5d-d3da4cfdef3c">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate(false) then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="1e83476b-5330-4c03-8fb0-e004df1df3ab">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedProduct	: JSSLKUsedProduct;
	
begin
	inheritMethod();
	
	theUsedProduct			:=	self.aMyUsedProduct;
	
	lblProductName.caption	:=	" " &amp; theUsedProduct.getProductName();
	txtExpiryDate.text		:=	theUsedProduct.expiryDate.shortFormat();
	
	self.resynchObjectAndSetEdition(theUsedProduct);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="fbda2e76-264b-4e3c-b0e1-695d8f5ab397">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedProduct	: JSSLKUsedProduct;
	
begin
	inheritMethod();
	
	theUsedProduct	:=	self.aMyUsedProduct;
	lstComponents.listCollection(theUsedProduct.myProduct.allComponents, true, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="0523e65c-20db-43fd-aa52-b1bae42af991">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedProduct	: JSSLKUsedProduct;
	expiryDate		: Date;
	
begin
	theUsedProduct	:=	self.aMyUsedProduct;
	expiryDate		:=	txtExpiryDate.text.trimBlanks().Date;
	
	if not expiryDate.isValid() then
		expiryDate	:=	null;
	endif;
	
	app.myTA.trxUpdateProductExpiryDate(theUsedProduct, self.aObjectEdition, expiryDate);
	
	app.causeEvent(CUSTOMER_USEDCOMPONENT_CHANGE, true, JSSLKMaintenanceForm.EVENT_TAG_USERCOMPONENT);
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstComponents_displayEntry" id="13b1b540-4d2b-42dd-b673-b598c1bfdc69">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstComponents_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.JSSLKComponent.getDisplay();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setUsedProduct" id="f254b2ac-f929-415e-b633-824cc6e706a9">
        <updating/>
        <source>setUsedProduct(pTheUsedProduct:JSSLKUsedProduct) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Sets a reference to the specified used product object on the form.
//
// Parameters:	pTheUsedProduct - The reference to the used product object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyUsedProduct	:=	pTheUsedProduct;
end;</source>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct"/>
    </JadeMethod>
</GUIClass>
