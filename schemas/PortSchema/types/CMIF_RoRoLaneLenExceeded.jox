<Class name="CMIF_RoRoLaneLenExceeded" id="54329d27-149e-49b9-940b-2e2b3bbcaee9">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A class used when a RoRo Lane has been over-queued/planned to. An object of this type is keyed into the drawing dict to represent the position of the indicator drawn on screen. </text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myLocationsController" id="52d80bee-65d3-4f33-aa2c-0d7fab359229">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <JadeMethod name="getExtraInfo" id="2ada1273-2fd4-4514-933e-04065d016d8f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwjk3	Initial creation

*/

vars
	block 	: CM_DataContainerBlock;
	yal 	: CM_YardAllocation;
	aTI 	: CM_TrackedItem;
	isFirst : Boolean;
	fm 		: CM_FutureMove;
begin
	block := _dataContainer.addNewBlock;
	block.addNewItem("Location", DC_Label, 1, self);
	block.addNewItem(self.myLocationsController.getFullId(), DC_Data, 1, self);

	if not self.myLocationsController.allQueuedFutureMoves.isEmpty then
		isFirst := true;
		foreach fm in self.myLocationsController.allQueuedFutureMoves do
			if isFirst then
				block.addNewItem(app.getErrorString(Queued) &amp; " " &amp; app.getErrorString(Cargo), DC_MoreInfo, 1, null);
				isFirst := false;
			endif;
			aTI := fm.CM_FutureMoveQueued.myTrackedItem;
			block := _dataContainer.addNewBlock;
			block.addNewItem("ID", DC_Label, 1,  aTI);
			block.addNewItem(aTI.id, DC_Data, 1,  aTI);
		endforeach;
	endif;

	
	if not self.myLocationsController.allPlannedFutureMoves.isEmpty then
		isFirst := true;
		foreach fm in self.myLocationsController.allPlannedFutureMoves do
			if isFirst then
				block.addNewItem(app.getErrorString(Planned) &amp; " " &amp; app.getErrorString(Cargo), DC_MoreInfo, 1, null);
				isFirst := false;
			endif;
			aTI := fm.CM_FutureMovePlanned.myTrackedItem;
			block := _dataContainer.addNewBlock;
			block.addNewItem("ID", DC_Label, 1,  aTI);
			block.addNewItem(aTI.id, DC_Data, 1,  aTI);
		endforeach;
	endif;

	
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
</Class>
