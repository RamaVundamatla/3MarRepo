    <JadeMethod name="buildSelf" id="8e6ccf7e-20ef-4d72-b2c4-9ae8ec3aba1b">
        <updating/>
        <source>buildSelf() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	frmLine		: Frame;
begin

	if self.isInPainter then
		return;
	endif;
	
	self.autoRedraw := true;
	
	self.setFrameDefaults(self);
		
	create self.picOpen as CMUI_RowFramePicture transient;
	self.picOpen.parent := self;
	self.form.addControl(self.picOpen);
	self.picOpen.move(1,1, 10, 10);
	self.picOpen.stretch := Picture.Stretch_ControlTo;
	
	create self.picClosed as CMUI_RowFramePicture transient;
	self.picClosed.parent := self;
	self.form.addControl(self.picClosed);
	self.picClosed.move(1,1, 10, 10);
	self.picClosed.stretch := Picture.Stretch_ControlTo;
	
	create frmInput transient;
	self.setFrameDefaults(frmInput);
	frmInput.parent := self;
	self.form.addControl(frmInput);
	frmInput.move(20, 0, 400, 200);
	frmInput.autoRedraw := true;
	frmInput.borderStyle	:= Frame.BorderStyle_None;
	frmInput.caption := 'Frame for input';
	
	create frmText transient;
	self.setFrameDefaults(frmText);
	frmText.parent := self;
	self.form.addControl(frmText);
	frmText.move(20, 0, 400, 15);
	frmText.autoRedraw := true;
	frmText.borderStyle	:= Frame.BorderStyle_None;
	frmText.visible := false;
	frmText.caption := 'Short Description';

end;</source>
    </JadeMethod>
