<Class name="CMUI_SubSystem" id="44e6f5e0-1db5-4f5d-ba5b-fe88d3639183">
    <superclass name="CMUI_Transient"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cmui"/>
    <ImplicitInverseRef name="myAssistantClass" id="1295f783-8d2e-49ac-9585-3cd19b46d9e1">
        <embedded/>
        <type name="Class"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="name" id="ab52d5f8-1fd3-4618-8674-34f3de7684df">
        <length>31</length>
        <embedded/>
