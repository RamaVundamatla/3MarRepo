    <JadeMethod name="setForCreate" id="4233ec6e-4ce5-409d-bcc0-8b4293809c92">
        <updating/>
        <source>setForCreate(_tempParams: CMIF_TempReading) updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Reefer properties are now on tracked item
vars
	temp : Real;
	defrostTemp : Real;
	ti	: CM_TrackedItem;
	reeferJob : CM_YardActivity;
	now : TimeStamp;
begin
	self.dateTime := _tempParams.dateTime;
	//self.myContainer := _tempParams.myTrackedItem;			// CCMS 1007
	
	//self.myReeferProperties := _tempParams.myTrackedItem.myReeferProperties;		//cnwmc5 - 18 Feb 2014 - PAR 33486
	ti := _tempParams.myTrackedItem;												//cnwmc5 - 18 Feb 2014 - PAR 33486
	ti.createReeferPropertiesIfReqd(self.dateTime);									//cnwmc5 - 18 Feb 2014 - PAR 33486
	self.myReeferProperties := ti.myReeferProperties;								//cnwmc5 - 18 Feb 2014 - PAR 33486
	
	defrostTemp := app.getMyTerminalDO_NOT_USE().getConfig(ReeferDefrostTemp).Real; //Aug 2007 cnwrs1 CCMS1551
	if _tempParams.tempIsFahrenhiet then
		//convert to celcius, always store in celcius
		temp := app.temperatureConversion(false, _tempParams.temperature);
	else
		temp := _tempParams.temperature;
	endif;
	if temp = defrostTemp and  //Aug 2007 cnwrs1 CCMS1551
	   defrostTemp &lt;&gt; 0 then
		self.temperature := NULL_DEFROST_TEMPERATURE;
		//self.myContainer.setDefrostTemp(self.dateTime);		// CCMS 1007
		self.myReeferProperties.setDefrostTemp(self.dateTime);	// CCMS 1007
	else
		self.temperature := temp;
		if temp &lt;&gt; NULL_TEMPERATURE then
			//self.myContainer.setDefrostTemp(null);			// CCMS 1007
			self.myReeferProperties.setDefrostTemp(null);		// CCMS 1007
		endif;
		
		// ### TFS 51455 09JUL2021 NAVAB1 -  delete the monitor job
		if app.getMyUser.canDo(null,Sub_ReeferJobs) then // REEFER JOBS
			now := app.actualTimeAppServer;
			reeferJob := ti.getCurrentReeferMonitorJob();
			if reeferJob &lt;&gt; null 
			and reeferJob.actionTime &lt; now then // only delete current monitor job
				reeferJob.doAction();  // this will delete the alarm job as well
			else
				// if it has an alarm job, delete it.
				reeferJob := ti.getCurrentReeferAlarmJob();
				if reeferJob &lt;&gt; null then
					reeferJob.doAction();  
				endif;
			endif;
		endif;
		
	endif;
	self.isRefConReading := _tempParams.isRefConReading;
	self.myRefConRawData := _tempParams.refConRawData;
	self.userId := _tempParams.userId;
end;</source>
        <Parameter name="_tempParams" type="CMIF_TempReading"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6b291603-c8a8-43c8-978f-f4014228c73a">
        <updating/>
        <source>setForUpdate(_proxy : CM_TempReading) updating;
//
// 10/12/2009	cnwdap1		CCMS 1007 Any tracked item can be a reefer, not just a container
//							Reefer properties moved to separate class
//
vars
	defrostTemp : Real;
begin
	defrostTemp := app.getMyTerminalDO_NOT_USE().getConfig(ReeferDefrostTemp).Real; //Aug 2007 cnwrs1 CCMS1551
//	self.temperature := _proxy.temperature;
	if _proxy.temperature = defrostTemp and //Aug 2007 cnwrs1 CCMS1551
	   defrostTemp &lt;&gt; 0 then
		self.temperature := NULL_DEFROST_TEMPERATURE;
		//self.myContainer.setDefrostTemp(self.dateTime);		// CCMS 1007
		self.myReeferProperties.setDefrostTemp(self.dateTime);	// CCMS 1007
	else
		self.temperature := _proxy.temperature;
		if _proxy.temperature &lt;&gt; NULL_TEMPERATURE then
			//self.myContainer.setDefrostTemp(null);			// CCMS 1007
			self.myReeferProperties.setDefrostTemp(null);		// CCMS 1007
		endif;
	endif;

//	self.systemCreated := _proxy.systemCreated;
	self.userId := _proxy.userId;
	self.dateTime := _proxy.dateTime;
end;</source>
        <Parameter name="_proxy" type="CM_TempReading"/>
    </JadeMethod>
