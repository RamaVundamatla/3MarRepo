<GUIClass name="ComboBox">
    <JadeMethod name="controlNamePrefix" id="e7417f65-64a2-4b2d-a17d-66d93a4ad064">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "cmb";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="3ea01d83-7d08-4702-bc89-8f3d7ee49149">
        <updating/>
        <source>jssSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's listIndex with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listIndex &lt;&gt; pValue then
		self.listIndex	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssSetObjectIndex" id="c63535b2-88ea-419a-90b3-3e9c316d0f7a">
        <updating/>
        <source>jssSetObjectIndex(pTheObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findObject(pTheObject);
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

