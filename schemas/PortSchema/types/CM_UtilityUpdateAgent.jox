    <JadeMethod name="utlUpdateWeightRange" id="98435ad1-e711-4a25-aeef-dad92c8ab87f">
        <source>utlUpdateWeightRange(pProxyWeightRange:CM_WeightRange; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realWeightRange:CM_WeightRange;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	pProxyWeightRange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyWeightRange.pxyGetRealObjectAndEdition(realWeightRange, expectedEdition);
	
	if realWeightRange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WeightRange.name, null, null);
		return;
	endif;

	app.myValUA.valWeightRange(realWeightRange, pProxyWeightRange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realWeightRange);

	if _passport.noErrors and realWeightRange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'WeightRange', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWeightRange, true);
	endif;
	
	if _passport.noErrors then
		if realWeightRange.colour &lt;&gt; pProxyWeightRange.colour then
			codeChanged := true;
		endif;
		realWeightRange.setForUpdate(pProxyWeightRange);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realWeightRange.value.String  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realWeightRange.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realWeightRange.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realWeightRange, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyWeightRange" type="CM_WeightRange"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWharf" id="09430943-f40e-4d63-9586-d21e14718f3b">
