    <JadeMethod name="getListDisplay" id="ce577e87-73cb-4d43-8091-22949c06a4ac">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Returns a display string for the receiver.
//
// Parameters:	None
//
// Returns:		The list display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "[" &amp; self.code &amp; "] " &amp; self.description;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6e490efa-c215-4b2b-b5a5-7f52be5cb9d2">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		08 September 2006 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj		:=	inheritMethod();
	proxyObj.myRoot	:=	self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8032dccf-b4ee-4e5b-9b6e-2897fcd46780">
        <updating/>
        <source>setForCreate(_proxyObj: HMS_VesselUnavailCode; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		08 September 2006 by cnwdad1
//
// Purpose:		Standard method for setting the receiver's property values upon creation.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj, _passport);
	self.setForUpdate(_proxyObj, _passport);
end;</source>
        <Parameter name="_proxyObj" type="HMS_VesselUnavailCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cdefeb45-2164-43e3-b6c0-2c4b49184f8a">
        <updating/>
        <source>setForUpdate(_proxyObj: HMS_VesselUnavailCode; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		08 September 2006 by cnwdad1
//
// Purpose:		Standard method for setting the receiver's property values upon update.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj, _passport);
	
	// Set any non-key properties, and non-inverse references.
	
	self.description	:=	_proxyObj.description;
	
	// Set any key property values.
	
	self.code			:=	_proxyObj.code;
	
	// Set any inverse references.
	
	self.myRoot			:=	_proxyObj.myRoot;
end;</source>
        <Parameter name="_proxyObj" type="HMS_VesselUnavailCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="af4f4a8a-696e-412e-8ced-062ea05524f7">
        <updating/>
        <source>setProxy(_rootObj:CM_Root) updating;
// --------------------------------------------------------------------------------
// Created:		08 September 2006 by cnwdad1
//
// Purpose:		Standard method for setting the property values of the receiver, but
//				only when the receiver is a transient proxy object.
//
// Parameters:	_rootObj - A reference to the parent root object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myRoot			:=	_rootObj;
end;</source>
        <Parameter name="_rootObj" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="05f346f5-5720-480c-b042-cf2f433bd149">
        <source>validateMe(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		08 September 2006 by cnwdad1
//
// Purpose:		Standard validation method for the receiver, that is invoked by a
//				transaction when the receiver is created or updated.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	existingObj		: HMS_VesselUnavailCode;
	originalObj		: HMS_VesselUnavailCode;
	
begin
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD , 'Harbour Root', null, null);
		app.raiseCMException(Input_required_field_harbRoot, null, null); // cnwdb2	PAR 35364
	endif;
	
	originalObj	:=	self.pxyGetRealObject();
	existingObj	:=	app.myRoot.allVesselUnavailabilityCodes[self.code];
	
	if existingObj &lt;&gt; originalObj then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	inheritMethod(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
