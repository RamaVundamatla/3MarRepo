        <source>utlCreateHazardClass(pProxyHazardClass:CM_HazardClass; pNewHazardClass:CM_HazardClass output; _pxyDraw : CM_DrawingAttribute; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
//							New _pxyDraw parameter
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	newDrawingAttribute : CM_DrawingAttribute;				// PAR #36206
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valHazardClass(pProxyHazardClass);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewHazardClass persistent;
	
	if _pxyDraw &lt;&gt; null then										// PAR #36206
		pNewHazardClass.createDrawingAttribute();					// PAR #36206
		pNewHazardClass.myDrawingAttribute.setForCreate(_pxyDraw);	// PAR #36206
	endif;															// PAR #36206
	
	pNewHazardClass.setForCreate(pProxyHazardClass);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewHazardClass);
	endif;

end;</source>
        <Parameter name="pProxyHazardClass" type="CM_HazardClass"/>
        <Parameter name="pNewHazardClass" type="CM_HazardClass" usage="output"/>
