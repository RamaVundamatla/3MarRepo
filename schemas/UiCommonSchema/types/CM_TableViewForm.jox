    <JadeMethod name="getConvertedDisplayValue" id="595ee59c-b73e-4e22-a419-58cc465e9643">
        <source>getConvertedDisplayValue( _rowName : String; _measureType : CM_MeasurementType ):Decimal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	measureTable : CMUI_MeasurementTable;
	prefix : String;

begin

	if _measureType = null then
		return 0;
	endif;

	prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );

	measureTable := self.getMeasurementControl(prefix &amp; _rowName &amp; "_" &amp; _measureType.shortName);
	if measureTable &lt;&gt; null then
		return measureTable.getConvertedValue;
	endif;
	
	return 0;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
