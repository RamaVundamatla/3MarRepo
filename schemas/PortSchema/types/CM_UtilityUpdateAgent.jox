    <JadeMethod name="utlUpdateOrganisation" id="b4df7c26-fdbd-4095-a5f0-d4111a59c5bb">
        <source>utlUpdateOrganisation(pRealOrg : CM_Organisation io; pEdition : Integer; pLogo : Binary; 
				pDACs : CM_DataAccessControllerSet; _isNotAvailableForEntry : Boolean;
				_isAvailableForLabourRestrict : Boolean; _debtor : CM_Debtor;
				_emails : CM_EmailAddressByAddressDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();

	exclusiveLock(pRealOrg);

	if _passport.noErrors and pRealOrg.edition &lt;&gt; pEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'organisation', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealOrg, true);
	endif;
	
	if _passport.noErrors then
		pRealOrg.setForUpdate(pLogo, _isNotAvailableForEntry, _isAvailableForLabourRestrict, _debtor, _emails);
		pRealOrg.setDataAccessControllers(false,pDACs);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealOrg, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pRealOrg" type="CM_Organisation" usage="io"/>
        <Parameter name="pEdition" type="Integer"/>
        <Parameter name="pLogo" type="Binary"/>
        <Parameter name="pDACs" type="CM_DataAccessControllerSet"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isAvailableForLabourRestrict" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOrganisationType" id="8de64bbf-89aa-4daa-bf7d-069a2ff31346">
        <source>utlUpdateOrganisationType(pRealOrg : CM_Organisation io; pEdition : Integer; pLogo : Binary; 
				pDACs : CM_DataAccessControllerSet; _isNotAvailableForEntry : Boolean;
				_isAvailableForLabourRestrict : Boolean; _debtor : CM_Debtor;
				_emails : CM_EmailAddressByAddressDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	7/11/07		cnwer1 		par 15269	
// ---------------------------------------------------------------------------
vars
	classToCreate : Class;
	newOrganisation : CM_Organisation;
	auditObject : CM_AuditObject;
	dataAccessController : CM_DataAccessController;
	eventRequest : CM_EventRequest;
	terminalOrg : CM_TerminalOrganisation;
	user  : CM_User;
begin

	self.initialiseActivity();

	if pRealOrg.isKindOf(CM_InternalOrganisation) then
		classToCreate:=CM_ExternalOrganisation;
	elseif pRealOrg.isKindOf(CM_ExternalOrganisation) then
		classToCreate:=CM_InternalOrganisation;
	endif;
	
	exclusiveLock(pRealOrg);

	
	if _passport.noErrors and pRealOrg.edition &lt;&gt; pEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'organisation', null, null);
		return;
	endif;
	
	newOrganisation:=pRealOrg.copySelfAs(classToCreate,false).CM_Organisation;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealOrg, true);
	endif;
	
	//update audits
//	foreach auditObject in pRealOrg.allAuditObjects do
	foreach auditObject in pRealOrg.allAuditObjectsForClass do	//21 Jan 2021	NDL	TFS 50152
		auditObject.setSubject(newOrganisation);
	endforeach;
	//pRealOrg.allDataAccessControllerObjects
	foreach dataAccessController in pRealOrg.allDataAccessControllerObjects do
		dataAccessController.allObjects.add(newOrganisation);
	endforeach;
	
	pRealOrg.allDataAccessControllers.copy(newOrganisation.allDataAccessControllers);
	
	//debtors
	pRealOrg.setMyDebtor(null);
	
	//users
	foreach user in pRealOrg.allUsers do
		user.setMyOrganisation(newOrganisation);
	endforeach;
	
	//allEventRequestsNofity
	
	foreach eventRequest in pRealOrg.allEventRequestsNofity do
		eventRequest.setMyOrganisation(newOrganisation);
	endforeach;
	
	foreach eventRequest in pRealOrg.allEventRequestsStops do
		eventRequest.setMyOrganisation(newOrganisation);
	endforeach;
	
	
	foreach terminalOrg in pRealOrg.allTerminalOrganisations do
		terminalOrg.setMyOrganisation(newOrganisation);
	endforeach;
	
	if _passport.noErrors then
		delete pRealOrg;
		newOrganisation.setForUpdate(pLogo, _isNotAvailableForEntry, _isAvailableForLabourRestrict,_debtor, _emails);
		newOrganisation.setDataAccessControllers(false,pDACs);
		newOrganisation.setMyRoot();
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(newOrganisation, false);
		
	endif;

epilog
	
	
end;</source>
        <Parameter name="pRealOrg" type="CM_Organisation" usage="io"/>
        <Parameter name="pEdition" type="Integer"/>
        <Parameter name="pLogo" type="Binary"/>
        <Parameter name="pDACs" type="CM_DataAccessControllerSet"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isAvailableForLabourRestrict" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateOutputFormatSS" id="784c9d1a-2fd9-4e7b-9224-238bd96061d4">
