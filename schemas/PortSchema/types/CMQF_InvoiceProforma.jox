    <JadeMethod name="cloneReferences" id="2165ead2-cb88-4dd1-b488-10c7c56918e3">
        <updating/>
        <source>cloneReferences(_obj: CMQF_InvoiceProforma; _transient: Boolean) updating;
/*

Date		Who		Reason
18/08/2015	cnwer1	Initial creation PAR 36778
13/02/2018	jlgdap1	TFS 37030 SSL Demurrage Report
*/

vars
	query : CM_MenuUserQuery;			// TFS 37030

begin
	inheritMethod(_obj, _transient);
	self.effectiveDate := _obj.effectiveDate;
	self.voyageInwardCode := _obj.voyageInwardCode;
	query := _obj.getMyQuery;									// TFS 37030
	if query &lt;&gt; null and app.isValidObject(query) then			// TFS 37030
		self.setMyQuery(query);									// TFS 37030
	else														// TFS 37030
		self.setMyQuery(null);									// TFS 37030
	endif;														// TFS 37030
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_InvoiceProforma"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertQuantityToDays" id="bb1d42f1-589e-45d6-8cf8-06e43828df09">
        <source>convertQuantityToDays(_quantity : Real; _calcType : CM_CalculationType; _weight : Decimal; _volume : Real; _length : Real) : Integer protected;
//
// Purpose:			Calculate storage says based on TI details and calculation type
//					**************************************************************************************
//					************** CODE COPIED FROM INV_Assistant METHOD WITH THE SAME NAME **************
//					************** ANY CHANGES HERE OR THERE NEED TO BE MIRRORED            **************
//
// Parameters:			
//
// Return Value:	Storage invoice line (real or pro forma) quantity converted to number of days	
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars
	storageDays	: Integer;
	blockUnit	: Integer;
	chargeByUnits	: Integer;
	units		: Integer;
	amount		: Real;
	convRate	: Real;

begin
	storageDays := _quantity.Integer;
	if _quantity = 0 or
	   _calcType = null then
		return storageDays;
	endif;
	// only for calculation types which use days - if not return 1
	units := _calcType.calculationType;
	if units &lt;&gt; INV_CALC_TYPE_DAYS_SINCE_RECVL and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SUBTERM and	//29 Jun 2018	NDL	TFS 39338
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_TEU and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_RT and	//08 May 2018	NDL	TFS 38525
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_ST and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_EN and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_IN and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_OUT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_WEIGHT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_VOLUME and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_ONSITE_AT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_CONNECTED and
	   units &lt;&gt; INV_CALC_TYPE_CARGOWEIGHTCONVT and
	   units &lt;&gt; INV_CALC_TYPE_CARGOLENGTHCONVT and
	   units = INV_CALC_TYPE_CARGOVOLUMECONVT and
	   units &lt;&gt; INV_CALC_TYPE_BOARDFEET_DAYS
	   then
		return 1;
	endif;
	blockUnit := _calcType.theCalcTypeUnit;
	chargeByUnits := _calcType.calculationType;
	if _calcType.myMeasurementType &lt;&gt; null then
		convRate := _calcType.myMeasurementType.conversionRate;
	else
		convRate := 1;
	endif;
	if chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT then
		amount := _weight;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT then
		amount := _volume;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT then
		amount := _length;
	else
		amount := 1;
	endif;
	// safety factor
	if amount = 0 then
		amount := 1;
	endif;
	
	storageDays := ((_quantity * convRate) / amount).Integer;
		
	return storageDays;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Real"/>
        <Parameter name="_length" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBOLSearch" id="a285fb9b-3775-40f4-8e2a-2898d3316e76">
        <source>doBOLSearch(objArray : ObjectArray input) protected;
/*

Date		Who		Reason
14 August 2015	cnwer1	Initial creation PAR 36778

*/

vars
	bol		: CM_BOLIn;
	ti		: CM_TrackedItem;
	parent	: CM_TrackedItem;
begin
	if self.getMyVoyage = null and self.billOfLading = null then
		return;
	endif;
	
	if self.getMyVoyage &lt;&gt; null then
		bol := self.getMyVoyage.getBOL(self.billOfLading);
		// this method does a find GEQ
		if bol &lt;&gt; null and
		   bol.number &lt;&gt; self.billOfLading then
			bol := null;
		endif;
	endif;
	
	if bol &lt;&gt; null then
		foreach	ti in bol.allTrackedItems do
			if not self.allTerminals.includes(ti.myTerminal) then
				continue;
			endif;
			
			if ti.isChild then
				parent := ti.myParent;
				if parent &lt;&gt; null and
				   not objArray.includes(parent) then
					objArray.add(parent);
				endif;
			else
				if not objArray.includes(ti) then
					objArray.add(ti);
				endif;
			endif;
		endforeach;
	elseif self.getMyVoyage &lt;&gt; null then
		self.getMyVoyage.lookupTrackedItemAnyWhereBOL(self.billOfLading, true, objArray);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doGPHAProforma" id="d778684b-09e9-4dc3-bbf3-d19f55a10df7">
        <source>doGPHAProforma(_tiArray : CM_TIArray) : CMIF_CashReceiptHeader protected;
/*
Oct 2015			copy of INV_Assistant doPrintCashReceiptGPHA printing from real and pro forma invoice lines includes CM_CashReceipt getInvoiceStatsByIldId
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support			
07 Jun 2016	cnwrs1	TFS2107 round all values to this field
28 Oct 2021 navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/
vars
	containers,
	packages			: Integer;
	count				: Integer;
	parentKey			: Integer;
	now					: Date;
	ts					: TimeStamp;
	cen					: String;
	str					: String;
	cargoId				: String;
	narration			: String;
	voyageCode,
	bolNumber,
	customsAgentName,
	receiptNumber,
	barcodeString		: String;
	goodsDescription	: String;
	handlingType		: String;
	packageTypes		: StringArray;
	cargoWeight			: Decimal[12, 3];
	cashToPay,
	taxTotal,	
	cashTotal 			: Decimal[16,6];
	taxValue			: Decimal[16,6];
	taxValue1,	
	taxValue2			: Decimal[16,6];
	lineTotal			: Decimal[16,6];
	quantity			: Real;
	rate				: Decimal[12,2];
	totalCargoCharges	: Decimal[16,6];
	cmif_header			: CMIF_CashReceiptHeader;		// 28/8/19 MAP TFS45303
	cmif_detail			: CMIF_CashReceiptDetail;		// 28/8/19 MAP TFS45303
	invoiceAgent		: CM_CashInvoiceProformaAgent;
	bank				: CM_Bank;
	invoiceLine			: CM_InvoiceLine;
	debtor				: CM_Debtor;
	voyage				: CM_Voyage;
	ti					: CM_TrackedItem;
	bol					: CM_BOL;
	taxCode				: CM_TaxCode;
	taxRate1,
	taxRate2			: CM_TaxRate;
	terminal			: CM_Terminal;
	taxCodes,
	oa					: ObjectArray;
	obj					: Object;
	dict				: DynaDictionary;
	jdo					: JadeDynamicObject;
	hookExempt 			: Boolean;

begin
	now := app.actualTimeServer.date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create oa transient;
	create taxCodes transient;
	create packageTypes transient;
	// get all details from tracked items
	foreach ti in _tiArray do
		// take first BOL
		if bol = null then
			bol := ti.myReceivalBOL;
		endif;
		// take the first customs entry number if more than one 
		if cen = null then
			if ti.isExport then
				foreach str in ti.allCustomsDetails do
					if str &lt;&gt; null then
						cen := str;
						break;
					endif;
				endforeach;
			else
				foreach str in ti.allCustomsEntryNumbers do
					if str &lt;&gt; null then
						cen := str;
						break;
					endif;
				endforeach;
			endif;
		endif;
		if ti.isKindOf(CM_Container) then
			containers := containers + 1;
		else
			if ti.quantity &gt; 0 then
				packages := packages + ti.quantity;
			else
				packages := packages + 1;
			endif;
			handlingType := null;
			if ti.myProduct &lt;&gt; null then
				if ti.myProduct.myHandlingType &lt;&gt; null then
					handlingType := ti.myProduct.myHandlingType.description;
				endif;
			elseif ti.myCargoType &lt;&gt; null and
				   ti.myCargoType.myDefaultHandlingType &lt;&gt; null then
					handlingType := ti.myProduct.myHandlingType.description;
			endif;
			if handlingType &lt;&gt; null then
				if not packageTypes.includes(handlingType) then
					packageTypes.add(handlingType);
				endif;
			endif;
		endif;
		if ti.description &lt;&gt; null then
			goodsDescription := goodsDescription &amp; " " &amp; ti.description;
		endif;
	endforeach;

	create cmif_header transient;
	cmif_header.gpha_invoiceTitle 		:= "CASH PROFORMA INVOICE";
	voyage 								:= self.getMyVoyage;
	bolNumber 							:= self.billOfLading;
	cmif_header.gpha_bolNumber 			:= bolNumber;
	cmif_header.gpha_customsEntryNumber := cen;
	cmif_header.gpha_myCustomsAgent 	:= self.getMyCustomsAgent;
	
	if self.getMyCustomsAgent &lt;&gt; null then
		customsAgentName 				:= self.getMyCustomsAgent.name;
	endif;
	
	debtor 					  			:= self.getMyDebtor;
	cmif_header.gpha_myDebtor 			:= debtor;
	
	if voyage &lt;&gt; null then
		cmif_header.gpha_vesselName 	:= voyage.vesselName;
		voyageCode				    	:= voyage.code;
		if voyage.shipExchangeCompleteDT &lt;&gt; null then
			cmif_header.gpha_dischargeCompletionDate := voyage.shipExchangeCompleteDT.date;
		endif;
	endif;
	
	cmif_header.gpha_myVoyage 			:= voyage;
	
	if bol &lt;&gt; null then
		cmif_header.gpha_releaseDate := bol.getLatestStopClearedDate();
	endif;
	
	cmif_header.gpha_effectiveDate		 := self.effectiveDate;
	cmif_header.gpha_numberOfContainers  := containers;
	cmif_header.gpha_numberOfPackages 	 := packages;
	cmif_header.gpha_receiptDate		 := self.effectiveDate;		// this gets printed as the date
	
	foreach handlingType in packageTypes do
		if str = null then
			str := handlingType;
		else
			str := str &amp; " ," &amp; handlingType;
		endif;
	endforeach;
	cmif_header.gpha_packageType := str;
	cmif_header.gpha_goodsDescription := goodsDescription;

	// get the configured cash tax codes
	foreach terminal in self.allTerminals do
		terminal.getAllCashTaxCodes(taxCodes);
		if not taxCodes.isEmpty then
			break;
		endif;
	endforeach;
	// get the VAT tax rate to use for each detail
	if debtor &lt;&gt; null and
	   not debtor.isZeroRatedTax then
		foreach obj in taxCodes do
			taxCode := obj.CM_TaxCode;
			count := count + 1;
			// tax code 1 is NHIL, 2 is VAT
			// feedback from Ghana 5/04/2016 the tax values column is to be both NHIL and VAT taxes
			ts.setDate(self.effectiveDate);
			if count = 1 then
				taxRate1 := taxCode.getTimeRate(ts);
			elseif count = 2 then
				taxRate2 := taxCode.getTimeRate(ts);
			endif;
		endforeach;

		// TFS 37562 exempt by voyage
		voyage := self.myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				taxRate1 := null;
				taxRate2 := null;
			endif;
		endif;
	endif;
	
	// dyna dictionary to group invoice line details by cargo id, parent/child and invoice line type
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(String, 60, false, true);	// CM_TrackedItem.id + ISO group description/cargo type description
	dict.addExternalKey(Integer, 4, false, true);	// 0 for parent, 1 for child
	dict.addExternalKey(String, 200, false, true);	// CM_InvoiceLineDesc.narration		//28.10.2021 navma1 #52163 Pending
	dict.endKeys(false);							// no duplicates

	// consolidate invoice line details based on container id, parent/child and invoice line description
	ts := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	foreach ti in _tiArray do
		bank := ti.companyOid;
		if bank = null then
			bank := ti.myTerminal.getDefaultCompanyBank();
		endif;
		
		create invoiceAgent transient;
		invoiceAgent.init( bank, ti, now,  true );
		invoiceAgent.createProformaInvLines(null, false, false );
		invoiceAgent.getCurrentInvLines();
		foreach invoiceLine in invoiceAgent.allProformaInvLines do	
			jdo				  := self.writeJDO(dict, invoiceLine, cargoId, parentKey, narration);
			totalCargoCharges := totalCargoCharges + invoiceLine.lineTotal;
		endforeach;
		foreach invoiceLine in invoiceAgent.allCurrentInvLines do
			jdo 			  := self.writeJDO(dict, invoiceLine, cargoId, parentKey, narration);
			totalCargoCharges := totalCargoCharges + invoiceLine.lineTotal;
		endforeach;
		
		delete invoiceAgent;
	endforeach;

	// read the JDOs and report by cargo type, parents then children and invoice line type
	if not dict.isEmpty() then
		foreach obj in dict do
			jdo := obj.JadeDynamicObject;
			create cmif_detail transient;
			
			cargoId 	 := jdo.getPropertyValue("cargoId").String;
			narration 	 := jdo.getPropertyValue("lineDescription").String;
			cargoWeight  := jdo.getPropertyValue("cargoWeight").Decimal;
			
			if cargoWeight = 0 then
				cargoWeight := 1;
			endif;
			
			lineTotal := jdo.getPropertyValue("lineTotal").Decimal;
			quantity  := jdo.getPropertyValue("quantity").Real;
			
			if quantity &lt;&gt; 0 then
				rate := (lineTotal / quantity).roundedTo(2);
			else
				rate := lineTotal.roundedTo(2);
			endif;
			// feedback from Ghana 5/04/2016 print rate not net value
			cmif_detail.gpha_lineRate 			  := rate;
			cmif_detail.gpha_cargoId 			  := cargoId;
			cmif_detail.gpha_invoiceLineNarration := narration;		//28.10.2021 navma1 #52163
			
			// feedback from Ghana 5/04/2016 the tax values column is to be both NHIL and VAT taxes
			taxValue1 := 0;
			taxValue2 := 0;
			if taxRate1 &lt;&gt; null then
				taxValue1 := ((lineTotal * taxRate1.rate) / 100);
			endif;
			if taxRate2 &lt;&gt; null then
				taxValue2 := ((lineTotal * taxRate2.rate) / 100);
			endif;
			cmif_detail.gpha_lineTaxValue := taxValue1 + taxValue2;
			cmif_detail.gpha_lineTotal    := lineTotal + taxValue1 + taxValue2; 
			cmif_detail.gpha_cargoWeight  := quantity.rounded;
			cmif_header.gpha_allDetails.add(cmif_detail);
		endforeach;
	endif;

	cashToPay := totalCargoCharges.roundedTo(2);
	ts.setDate(self.effectiveDate);
	taxValue1 := 0;
	taxValue2 := 0;
	count := 0;
	if self.getMyDebtor &lt;&gt; null and
	   not self.getMyDebtor.isZeroRatedTax then
		foreach obj in taxCodes do
			// tax code 1 is NHIL, 2 is VAT
			count := count + 1;
			taxCode := obj.CM_TaxCode;
			taxRate1 := taxCode.getTimeRate(ts);
			if taxRate1 &lt;&gt; null then
				taxValue := ((cashToPay * taxRate1.rate) / 100).roundedTo(2);
				taxTotal := taxTotal + taxValue;
				if count = 1 then
					taxValue1 := taxValue;
				elseif count = 2 then
					taxValue2 := taxValue;
				endif;
			endif;
		endforeach;

		// TFS 37562 exempt by voyage
		voyage := self.myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				taxRate1 := null;
				taxRate2 := null;
			endif;
		endif;
	endif;

	cashTotal 	 				  := totalCargoCharges + taxValue1 + taxValue2;
	barcodeString 				  := voyageCode &amp; "|" &amp; bolNumber &amp; "|" &amp; receiptNumber &amp; "|" &amp; ts.date.shortFormatJMT &amp; " " &amp; ts.time.String &amp; "|"
									&amp; cashTotal.asCurrencyJMT &amp; "|" &amp; customsAgentName;
	cmif_header.gpha_barCode 	  := app.convertStringToPDF417(barcodeString);
	cmif_header.gpha_total		  := totalCargoCharges;
	cmif_header.gpha_totalInWords := cashTotal.roundedTo(2).asCurrencyJMTWords();
	cmif_header.gpha_totalTax1    := taxValue1;
	cmif_header.gpha_totalTax2    := taxValue2;

	return cmif_header;
epilog
	delete oa;
	delete taxCodes;
	delete packageTypes;
	delete invoiceAgent;
	delete dict;
end;
</source>
        <access>protected</access>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <ReturnType type="CMIF_CashReceiptHeader"/>
    </JadeMethod>
    <JadeMethod name="filterObjects2" id="5aa4b7c6-2e81-47ea-98cb-ea61e54f4f86">
        <updating/>
        <source>filterObjects2(_collection: Collection input; _jrwTrans: CM_JRWInvoice; _passport: CM_Passport) updating;
/*

Date		Who		Reason
14/08/2015	cnwer1	Initial creation PAR 36778
16/05/2016	cnwns1	TFS 488 - Multi Timezone Support
15/02/2018	jlgdap1	TFS 37030 SSL Demurrage Report
02 Oct 2019	jlgdi1	46619 - Set the cmif attribute 'isEstimated' to true
*/

vars
	date	: Date;
	tiArray : CM_TIArray;	
	ti : CM_TrackedItem;
	isGhana : Boolean;
	ioClass		: CM_ExtFinanceIO;
	cmif_header	: CMIF_CashReceiptReporting;
	cmif_detail	: CMIF_CashReceiptReporting;
	invoiceAgent	: CM_CashInvoiceProformaAgent;
	invoiceVoyageAgent	: CM_CashProformaVoyageAgent;
	bank : CM_Bank;
	invoiceLine		: CM_InvoiceLine;
	tiLength 	: Real;							// TFS 37030
	tiVolume	: Real;							// TFS 37030
	tiWeight	: Decimal[14, 4];				// TFS 37030
	isStorage 	: Boolean;						// TFS 37030
	voyage : CM_Voyage;
	term : CM_Terminal;
	invLineDesc : CM_InvoiceLineDesc; //02/10/2025	navkc1 JIRA 36149
	calcType : CM_CalculationType; //02/10/2025	navkc1 JIRA 36149

begin
	
	create tiArray transient;
	
	// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
	if self.allTrackedItems.isEmpty() then // ### TFS CR 65817 TASK 65819 27AUG2024 NAVAB1
		self.findAllTIs(self.allTrackedItems);
	endif;
	
	if self.allTrackedItems.isEmpty
	and self.allVoyages.isEmpty then
		return;
	endif;
	
	self.allTrackedItems.copy(tiArray);
	
	ti := tiArray.first;
	if ti &lt;&gt; null then
		term := ti.myTerminal;
	else
		voyage := self.allVoyages.first;
		if voyage &lt;&gt; null then
			term := voyage.myTerminal;
		endif;
	endif;
	
	// default effectiveDate to today if not entered
	if self.effectiveDate = null then
		self.effectiveDate := app.actualTimeServer.date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	ioClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	isGhana := (app.myRoot.isClientGhana() or
				(ioClass &lt;&gt; null and ioClass.class.name = CM_GPHAInterface.name));
	if isGhana then
		cmif_header := self.doGPHAProforma(tiArray);
		_collection.add(cmif_header);
		return;
	endif;
	
	create cmif_header as CMIF_CashReceiptHeader transient;

	date := self.effectiveDate;
	
	cmif_header.setHeaderDetails(term, self.getMyDebtor, self.billOfLading, self.getMyVoyage, date, "CASH PROFORMA INVOICE");
	
	foreach ti in tiArray do
		bank := ti.companyOid;
		if bank = null then
			bank := term.getDefaultCompanyBank();
		endif;
		
		create invoiceAgent transient;
		invoiceAgent.init( bank, ti, date, true );
		invoiceAgent.createProformaInvLines(null, false, false );
		if not self.ignoreCurrentInvoiceLines then // JIRA 32861 27SEP2024 NAVAB1 - Accruals Performance
			invoiceAgent.getCurrentInvLines();
		endif;
		foreach invoiceLine in invoiceAgent.allProformaInvLines do
			create cmif_detail as CMIF_CashReceiptDetail transient;
			cmif_detail.setDetailFromInvoiceLine(invoiceLine, ti.myVoyage);// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
			
			cmif_detail.CMIF_CashReceiptDetail.isEstimated := true;		//	46619 
			
			// TFS 37030 at this point in its life, the invoiceLine is a transient copy
			// of the one created tehn aborted in teh invoice calculations, so it doesn't
			// have a myTransactionTi. So we need to use another way of deciding whether
			// it's a storage line
			if invoiceLine.myTransactionTI = null then
				isStorage := invoiceLine.quantityNoMinMax.Integer = TRANS_TYPE_STORAGE;
				cmif_detail.CMIF_CashReceiptDetail.isStorage := isStorage;
				if isStorage then
					tiVolume := invoiceLine.trackedItem.getChargeVolume();
					invLineDesc := invoiceLine.invoiceLineDesc;
					//02/10/2025	navkc1 JIRA 36149
					if invLineDesc &lt;&gt; null then
						calcType := invLineDesc.myCalculationType;
						if calcType &lt;&gt; null then
							if calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT and calcType.isUseCargoWeight() then
								tiWeight := invoiceLine.trackedItem.weightCargo; //02/10/2025	navkc1 JIRA 36149
							else
								tiWeight := invoiceLine.trackedItem.getChargeWeight();
							endif;
						endif;
					endif;
					tiLength := invoiceLine.trackedItem.length;
					cmif_detail.CMIF_CashReceiptDetail.storageDays := self.convertQuantityToDays(invoiceLine.quantity, invoiceLine.invoiceLineDesc.myCalculationType, tiWeight, tiVolume, tiLength);
				endif;
			endif;
			// TFS 37030 end
			cmif_header.addDetailToHeader(cmif_detail);
		endforeach;
		
		foreach invoiceLine in invoiceAgent.allCurrentInvLines do
			create cmif_detail as CMIF_CashReceiptDetail transient;
			
			// ### TFS CR 65817 TASK 65818 27AUG2024 NAVAB1
			voyage := null;
			ti := invoiceLine.trackedItem;
			if ti &lt;&gt; null then
				voyage := ti.myVoyage;
			endif;
			
			cmif_detail.setDetailFromInvoiceLine(invoiceLine, voyage);
			cmif_header.addDetailToHeader(cmif_detail);
		endforeach;
		
		delete invoiceAgent;
	endforeach;
	
	

	// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
	if self.allVoyages.isNotEmpty() then
		foreach voyage in self.allVoyages discreteLock do
			create invoiceVoyageAgent transient;
			invoiceVoyageAgent.initialise(voyage, date, true, false );
			invoiceVoyageAgent.createProformaInvLines(null, false, false );
			invoiceVoyageAgent.getCurrentInvLines();
			
			foreach invoiceLine in invoiceVoyageAgent.allProformaInvLines do
				create cmif_detail as CMIF_CashReceiptDetail transient;
				cmif_detail.setDetailFromInvoiceLine(invoiceLine, invoiceVoyageAgent.myVoyage);
				
				cmif_detail.CMIF_CashReceiptDetail.isEstimated := true;
				cmif_header.addDetailToHeader(cmif_detail);
			endforeach;
			delete invoiceVoyageAgent;
		endforeach;
	endif;
	
	cmif_header.updateTotalsFromDetails();
	
	_collection.add(cmif_header);
	
	
epilog
	delete invoiceAgent;
	delete invoiceVoyageAgent;
	delete tiArray;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_jrwTrans" type="CM_JRWInvoice"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="findAllTIs" id="f8c81b0c-ce32-4e09-99d3-a2d8a9f5f349">
        <updating/>
        <source>findAllTIs(objArray : ObjectArray  input) protected, updating;
/*

Date		Who		Reason
14 August 2015	cnwer1	Initial creation PAR 36778
21/04/2016 cnwma1 PAR #37681  QNS - locking issue
*/

vars
	
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
	voyage	: CM_Voyage;
	id,
	str		: String;
	sa		: StringArray;
	failedDAC  :CM_DataAccessController;
	obj		: Object;
	oa		: ObjectArray;
begin
	create oa transient;
	voyage := self.getMyVoyage;
	// look for customs entry number first
	if self.customsEntryNumber &lt;&gt; null then
		foreach terminal in self.allTerminals do : terminalLoop
			//foreach ti in terminal.allOnsiteTIsByCargoTypeId do
			foreach ti in terminal.allOnsiteTIsByCargoTypeId discreteLock do //21/04/2016 cnwma1 PAR #37681 
				if ti.isExport then
					foreach str in ti.allCustomsDetails do
						if str.toUpper = self.customsEntryNumber then		// Par 37730
							if ti.isChild then
								continue;
							endif;
							oa.add(ti);
							break;
						endif;
					endforeach;
				else
					foreach str in ti.allCustomsEntryNumbers do
						if str.toUpper = self.customsEntryNumber then		// Par 37730
							if ti.isChild then
								continue;
							endif;
							oa.add(ti);
							break;
						endif;
					endforeach;
				endif;
			endforeach;
			//foreach ti in terminal.allOffsiteTIsByCargoTypeId do
			foreach ti in terminal.allOffsiteTIsByCargoTypeId discreteLock do //21/04/2016 cnwma1 PAR #37681 
				if ti.isExport then
					foreach str in ti.allCustomsDetails do
						if str.toUpper = self.customsEntryNumber then		// Par 37730
							if ti.isChild then
								continue;
							endif;
							oa.add(ti);
							break;
						endif;
					endforeach;
				else
					foreach str in ti.allCustomsEntryNumbers do
						if str.toUpper = self.customsEntryNumber then		// Par 37730
							if ti.isChild then
								continue;
							endif;
							oa.add(ti);
							break;
						endif;
					endforeach;
				endif;
			endforeach;	
		endforeach;
	else
		// look for voyage and/or BOL next
		// find voyage by code or inwards code
		if voyage = null and
		   self.voyageInwardCode &lt;&gt; null then
			foreach terminal in self.allTerminals do
				voyage := terminal.allVoyagesByInwardCode[voyageInwardCode];
				if voyage &lt;&gt; null then
					self.setMyVoyage( voyage );
					break;
				endif;
			endforeach;
		endif;
		if voyage &lt;&gt; null or self.billOfLading &lt;&gt; null then
			if  voyage &lt;&gt; null and cargoId &lt;&gt; null then
				ti :=  voyage.lookupTrackedItemAnyWhere(cargoId, oa);

				if ti &lt;&gt; null and ti.id = cargoId then
					oa.add(ti);
				endif;
			else
				self.doBOLSearch( oa);
			endif;
		else
			// look for cargo ids last
			if self.cargoId &lt;&gt; null then
				create sa transient;
				self.cargoId .convertToDelimitedArray(",", sa);
				
				foreach id in sa do
					foreach terminal in self.allTerminals do
						ti := terminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
						if ti = null then
							ti := terminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false);
						endif;
						if   ti = null then
							ti := terminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_OFFSITE, null, false);
						endif;
						if ti = null then
							ti := terminal.lookupTrackedItem(id, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
						endif;
						if ti = null then
							ti := terminal.lookupTrackedItem(id, TI_CargoType_Null, TI_STATE_NOTIFIED, null, false);
						endif;
						if  ti = null then
							ti := terminal.lookupTrackedItem(id, TI_CargoType_Null, TI_STATE_OFFSITE, null, false);
						endif;
						if ti &lt;&gt; null and
						   ti.id = id then		// can find cargo with partial id match, not wanted here so check the found id
							oa.add(ti);
						endif;
					endforeach;
				endforeach;
				
			endif;
		endif;
	endif;	
	// do user security on the TIs, for cash proforma invoice report
	foreach obj in oa do
		if obj.CM_Object.canUserAccessSelf(null, failedDAC, app.myPassport) then
			objArray.add(obj);
		endif;
	endforeach;
	
epilog
	delete sa;
	delete oa;

end;</source>
        <access>protected</access>
        <Parameter name="objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyQuery" id="149db3a2-54bc-4b29-a97b-1899eaa6b254">
        <source>getMyQuery() : CM_MenuUserQuery;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars

begin
	return self.myQuery;
epilog

end;</source>
        <ReturnType type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="38e2ea5e-adff-4d63-bb08-9b022fc2f2c5">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
// 08/10/2019	jlgdap1		TFS 46315 JMT Proforma Report Issue
//
vars

begin
	if _attrName = ETRow_CustomsEntryNumber then
		return self.customsEntryNumber;
	elseif _attrName = ETRow_EffectiveDate then
		return self.effectiveDate.asStringJMT;
	elseif _attrName = ETRow_InwardCode then
		return self.voyageInwardCode;
	elseif _attrName = ETRow_SelectorQueryIds then
		if self.myQuery &lt;&gt; null and app.isValidObject(self.myQuery) then
			_oid := self.myQuery.getOidAsString;							// TFS 46315
			return self.myQuery.heading;
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyQuery" id="bf4d7cc6-96e0-4d8a-bd6a-9d14af13407f">
        <updating/>
        <source>setMyQuery(_query : CM_MenuUserQuery) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars

begin
	if _query &lt;&gt; self.myQuery then
		self.myQuery := _query;
	endif;
epilog

end;</source>
        <Parameter name="_query" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="writeJDO" id="661887b0-6aa5-448e-9066-f6499d7172ee">
        <source>writeJDO(_dict : DynaDictionary; _invoiceLine : CM_InvoiceLine; _cargoId : String output; _parentKey : Integer output; _narration : String output) : JadeDynamicObject protected;

// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 28 Oct 2021 navma1   ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

vars
	pos				: Integer;
	parentKey		: Integer;
	isContainer		: Boolean;
	now				: Date;
	cargoId			: String;
	remarks			: String;
	narration		: String;
	quantity		: Real;
	cargoWeight		: Decimal[12, 3];
	lineTotal		: Decimal[16, 6];
	invoiceLine		: CM_InvoiceLine;
	ild				: CM_InvoiceLineDesc;
	isoGroup		: CM_ISOTypeGroup;
	ti				: CM_TrackedItem;
	parent			: CM_TrackedItem;
	dict			: DynaDictionary;
	jdo				: JadeDynamicObject;
begin
	now := app.actualTimeServer.date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	narration   := null;
	ild 		:= null;
	ti 			:= null;
	invoiceLine := _invoiceLine;
	lineTotal   := invoiceLine.lineTotal;
	remarks 	:= invoiceLine.remarks;
	ild 		:= invoiceLine.invoiceLineDesc;
	ti 			:= invoiceLine.trackedItem;
	
	if ti = null then	// don't expect this of course
		return null;
	endif;
	// feedback from Ghana 5/04/2016 this is number of days for Storage, 1 or TEU for regular charges
	//  use the invoice line quantity as the default value
	cargoWeight := invoiceLine.quantity;
	quantity    := _invoiceLine.quantity;
	isContainer := ti.isContainer();
	// child cargo is reported under the parent as this is what the example cash receipts seem to show.
	// NOTE that this code deliberately reports the parent whether or not it is part of the receipt tracked items
	//  It also uses the cargo type if the parent happens to be other than a container - not expected but coded for just in case.
	parent := ti.myParent;
	if parent = null then
		parent := ti.getMyUnpackedFromContainer();
	endif;
	if parent = null then
		cargoId := ti.id;
		if isContainer then
			isoGroup := ti.getISOTypeGroup();
			if isoGroup &lt;&gt; null then
				cargoId := cargoId &amp; CrLf &amp; isoGroup.description;
			endif;
		else
			cargoId := cargoId &amp; CrLf &amp; ti.cargoTypeDescr;
		endif;
		parentKey := 0;
	else
		cargoId := parent.id;
		if parent.isContainer then
			isoGroup := parent.getISOTypeGroup();
			if isoGroup &lt;&gt; null then
				cargoId := cargoId &amp; CrLf &amp; isoGroup.description;
			endif;
		else
			cargoId := cargoId &amp; CrLf &amp; parent.cargoTypeDescr;
		endif;
		parentKey := 1;
	endif;

	// handle manual charges, which end up with VOID invoice line type
	if ild &lt;&gt; null then
		if ild.isVoid then
			// strip any quantity at end
			pos := remarks.pos(" (x", 1);
			if pos &gt; 1 then
				narration := remarks[1:pos-1];
			else
				narration := remarks;
			endif;
		else
			narration := ild.narration;
		endif;
		// from TFS 2003 testing add null test (is null for VOID invoice line type)
		if ild.myCalculationType &lt;&gt; null and
		   ild.myCalculationType.isWeightBased then
			cargoWeight := ti.totalWeight / 1000;	// in tonnes
		endif;
	else		// manual charge
		narration := remarks;
	endif;
		
	dict 		:= _dict;
	//narration   := narration[1:100];	// length limit added from TFS 2003 24/05/2016 	//28.10.2021 navma1 #52163
	
	jdo := dict.getAtKey(cargoId, parentKey, narration).JadeDynamicObject;
	
	if jdo = null then
		create jdo transient;
		jdo.addProperty("cargoId"			  , String);
		jdo.addProperty("lineDescription"     , String);
		jdo.addProperty("cargoWeight"         , Decimal);
		jdo.addProperty("quantity"			  , Real);
		jdo.addProperty("lineTotal"			  , Decimal);
		jdo.addProperty("parentKey"			  , Integer);
		jdo.setPropertyValue("cargoId"		  , cargoId);
		jdo.setPropertyValue("lineDescription", narration);
		jdo.setPropertyValue("parentKey"	  , parentKey);
		jdo.setPropertyValue("cargoWeight"	  , cargoWeight);
			
		dict.putAtKey(cargoId, parentKey	  , narration, jdo);
	endif;

	// accumulate value and quantity (both as cargoWeight to print and quantity for the rate
	jdo.setPropertyValue("lineTotal"  , jdo.getPropertyValue("lineTotal").Decimal + lineTotal);
	jdo.setPropertyValue("cargoWeight", jdo.getPropertyValue("cargoWeight").Decimal + cargoWeight);
	jdo.setPropertyValue("quantity"   , jdo.getPropertyValue("quantity").Real + quantity);
	
	_cargoId   := cargoId;
	_parentKey := parentKey;
	_narration := narration;
	
	return jdo;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_dict" type="DynaDictionary"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_cargoId" type="String" usage="output"/>
        <Parameter name="_parentKey" type="Integer" usage="output"/>
        <Parameter name="_narration" type="String" usage="output"/>
        <ReturnType type="JadeDynamicObject"/>
    </JadeMethod>
</Class>
