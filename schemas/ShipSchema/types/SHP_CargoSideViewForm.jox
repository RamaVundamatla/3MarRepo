    <JadeMethod name="doDrawRemarks" id="16da6f2a-405b-445d-9324-6f0856e995f1">
        <updating/>
        <source>doDrawRemarks(_slot :CM_ROROSlotDefnVoyage) updating, protected;
/*
Date		Who		Reason
25 Jul 2012	cnwcs5	Initial creation - par 29124
*/
vars
	pic 		: Picture;
	text 		: String;
	index		: Integer;
	left, top	: Real;		// note same name as form properties
begin
	text := _slot.getROROPlanningRemarks (true); 
	
	if text = null then 
		return;
	endif; 
	// find the top left position for the location
	if not self.getPositionForRemarks (_slot, left, top) then 
		return;
	endif;
	// each icon will have a unique index - we will use the same index for the remarks moveable frame as well
	index	:= self.lastIndexForRemarks + 1;
	pic 	:= self.picRemarks.loadControl (index).Picture;
	// save off last index used
	self.lastIndexForRemarks	:= index;
	
	self.allRemarksControls.add(pic);
	
	pic.parent 		:= self.frmLocationSlots;
	pic.bubbleHelp 	:= _slot.code &amp; CrLf &amp; text;		// par 29124:2 Aug 2012
	pic.userObject 	:= _slot;
	
	pic.left 		:= left;
	pic.top 		:= top;
	pic.visible 	:= true;
	
	pic.zOrder(1);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_slot" type="CM_ROROSlotDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="18f2cec7-6cbd-4444-a7b7-b8a86f8f0ca8">
        <updating/>
        <source>doDropFromGridAreaForm(frame: Frame input; win: Window input; x: Real; y: Real) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	tmpObj		: Object;
	aSlotController : CM_VoyageROROController;
	aLabel, moveString : String;
	jobOne, jobTwo : CM_Job;
	tmpDrawController	: SHP_ROROPlanDrawingController;
	tmpMoveController	: CMIF_MoveController;
	moveControllerMoveMode	: Integer;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	tmpMoveController := app.myMoveController;
	tmpDrawController := self.myROROPlanningForm.myROROPlanDrawController;
	
	if tmpMoveController = null then
		return;
	endif;
	if tmpMoveController.myTrackedItem = null then
		return;
	endif;

	tmpObj := tmpDrawController.getLCFromXYNoTI(x,y);
	

	if tmpObj = null or (tmpObj &lt;&gt; null and (not CM_VoyageROROController.hasInstance(tmpObj))) then
		return;
	endif;
	
	tmpMoveController.ignoreWeightValidation	:=	false; //self.chkIgnoreWeightV.value;

	moveControllerMoveMode := tmpMoveController.moveMode;
	
	aSlotController := tmpObj.CM_VoyageROROController;
	tmpMoveController.setMyToPrimaryLocation(aSlotController);
	tmpMoveController.mySlotRequest := null;

	if moveControllerMoveMode = REAL_MODE then
		tmpMoveController.myVoyageRequest := null;
		tmpMoveController.setMyWorkListEntry(null);
	elseif moveControllerMoveMode = PLANNING_MODE then
		if tmpMoveController.myTrackedItem.isRehandle 
		and self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			tmpMoveController.myVoyageRequest := aSlotController.myRORORequestLoad;
		elseif   self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad 
		and not  tmpMoveController.isMoveAnExportRePlan()  
		and not  tmpMoveController.myTrackedItem.isSOB then
			tmpMoveController.myVoyageRequest := aSlotController.myRORORequestLoad;
		endif;
	endif;

	if moveControllerMoveMode = QUEUE_MODE then
		app.msgBox("Cannot drag drop in Queue mode.","Dragging From " &amp; aLabel &amp; " Error",
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if moveControllerMoveMode = REAL_MODE then
		app.msgBox("Cannot drag drop in Instant mode.","Dragging From " &amp; aLabel &amp; " Error",
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if moveControllerMoveMode = PLANNING_MODE then
	
	
		// if we are dropping in planning mode then this must be a load.
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch then
			app.msgBox("Cannot drop in Discharge Colour Coding Planning mode.", "Planned Discharge Drag Drop Error",
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			if aSlotController.myRORORequestLoad = null then
				app.msgBox("Cannot drop in planning mode.There is no load colour coding for slot " &amp; aSlotController.getFullId &amp; ".", "Planned Load Drag Drop Error",
								MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			else
				jobOne := aSlotController.myRORORequestLoad.myJob;
				if tmpMoveController.myVoyageRequest &lt;&gt; null then
					jobTwo :=  tmpMoveController.myVoyageRequest.myJob;
				endif;
				if jobOne = null then
					app.msgBox("Cannot drop in planning mode. There is no job defined for the load colour coding for slot " 
								&amp; aSlotController.getFullId &amp; ".", "Planned Load Drag Drop Error",
									MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				else
					if jobTwo &lt;&gt; jobOne and jobTwo &lt;&gt; null then
						app.msgBox("Cannot drop in planning mode. Cannot drag " &amp; tmpMoveController.myTrackedItem.id
								&amp; " between job " &amp; jobTwo.id 
								&amp; " and job " &amp; jobOne.id &amp; ".", "Planned Load Drag Drop Error",
										MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
						return;
					endif;
				endif;
			endif;
		endif;
	endif;

	self.myROROPlanningForm.moveTrackedItemTarget(aSlotController); 
	tmpMoveController.ignoreWeightValidation	:=	false;	
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doHideRemarks" id="2d27ab5c-f9fd-44e1-a561-8d2fa22881ab">
        <updating/>
        <source>doHideRemarks()updating, protected;
/*
Date		Who		Reason
25 July 2012	cnwcs5	Initial creation - par 29124
*/
vars
	obj		:Object;
	control	:Control;
begin
	foreach obj in self.allRemarksControls do
		control			:= obj.Control;
		control.visible := false;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuAutoplan" id="02e94253-80df-43ec-9b08-58dbc5d169e5">
        <source>doMnuAutoplan();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx ,result: Integer;
	wles,wlesWithWarnings : CM_WLEArray;
	aReq : CM_RORORequest;
begin
	if self.myROROLocnDrawingController.allSelectedObjects.isEmpty then
		return;
	endif;

	create wles transient;
	
	foreach anObj in self.myROROLocnDrawingController.allSelectedObjects do
		idx := idx + 1;
		
		if anObj.isKindOf(CM_VoyageROROController) then
			aReq := anObj.CM_VoyageROROController.myRORORequestDischarge.CM_RORORequest;
			if aReq &lt;&gt; null then
				if aReq.myJob = null then
					continue;
				endif;
				foreach tmpWLE in aReq.allWorkListEntries discreteLock do
					if tmpWLE.myFutureMove &lt;&gt; null then
						continue;
					endif;
					aTI := tmpWLE.myTrackedItem;
					if aTI &lt;&gt; null then
						if str = null then
							str := aTI.id;
						else
							if idx mod 3 = 0 then
								str := str &amp; ", " &amp; Cr &amp; aTI.id;
							else
								str := str &amp; ", " &amp; aTI.id;
							endif;
						endif;
						wles.add(tmpWLE);
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	// PAR 18695
	if wles.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_cargo_autoplan),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Autoplan) &amp; " "  &amp; str &amp; "?", app.getErrorString(Confirm_autoplan_cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;

	create wlesWithWarnings transient;	
	
	while true do
		app.myTrxUA.trxUpdateWLEsAutoplan(wles, wlesWithWarnings, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Voyage Auto-Planning', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wles.clear;
				wlesWithWarnings.copy(wles);
				wlesWithWarnings.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wles;
	delete wlesWithWarnings;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoEraseClick" id="50e8cc69-0ca6-431b-93e4-646be519beaa">
        <updating/>
        <source>doMnuCargoEraseClick(_tiSet : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2012	cnwmc5	Initial creation - par 30018

Copied from SHP_ROROPlanningForm :: doMnuCargoEraseClick

*/
vars
	theTI 		: Object;
	theReturn 	: Integer;
	tiSet 		: CM_TISet;
	tiString 	: String;
	tisWithWarnSet : CM_TISet;
begin
	create tiSet transient;
	create tisWithWarnSet transient;
	
	tiString := '';
	
	if _tiSet &lt;&gt; null then
		foreach theTI in _tiSet do
			if theTI.isKindOf(CM_TrackedItem) then
				tiSet.add(theTI.CM_TrackedItem);
				tiString := tiString &amp; theTI.CM_TrackedItem.id.String &amp; ', ';
			endif;
		endforeach;

		if app.msgBox(app.getErrorString(ConfirmDeleteItems) &amp; CrLf &amp; tiString.padTrimTo(tiString.length() - 2), 
					app.getErrorString(CM_WARNING), MsgBox_Yes_No) = MsgBox_Return_Yes then
			while true do
				app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, false, app.myPassport);
				if app.myPassport.trxCompletedOK then
					global.beep;
					break;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
						theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					return;
				endif;
				break;
			endwhile;
		else
			return;
		endif;
	endif;
epilog
	delete tiSet;
	delete tisWithWarnSet;
end;</source>
        <Parameter name="_tiSet" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoSetGrade" id="ec90ec2f-cacf-4eb0-8041-380c2f2923a4">
        <updating/>
        <source>doMnuCargoSetGrade(_menuItem: MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	container	: CM_Container;
	result		: Boolean;
	tmpGrade	: CM_MTGrade;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if _menuItem = self.mnuCargoSetGrade then
		return;
	endif;
	tmpGrade := _menuItem.userObject.CM_MTGrade;
	if tmpGrade = null then
		return;
	endif;
	
	container := self.mnuCargoSetGrade.userObject.CM_Container;
	if container = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'current object is null');
		return;
	endif;
	
	if tmpGrade.code = container.getAvailabilityGrade then
		// already set.
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIAvailabilityGrade(container, tmpGrade.code, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Grade', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	_menuItem.checked := not _menuItem.checked;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemarks" id="ecdc3997-c989-4ee9-ad96-9194e7ca3bc3">
        <updating/>
        <source>doMnuRemarks(_menuItem: MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	lForm : CMUI_GetData;
	theTI : CM_TrackedItem;
begin
	if _menuItem.userObject = null then
//		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " MENU ITEM USER OBJECT WAS FOUND TO BE NULL"); 
		return;
	endif;
	
	theTI := _menuItem.userObject.CM_TrackedItem;

	create lForm;
	lForm.centreWindow;
	
	self.mousePointer := MousePointer_Default;
	
	lForm.lblTextCaption := app.getErrorString1( Additional_remarks_ti,theTI.id) ;
	
	lForm.txtReadOnly.visible := true;
	lForm.bigSize := true;
	lForm.txtReadOnly.text := theTI.remarks;
	lForm.txtData.text := null;
//	lForm.txtData.height := lForm.txtData.height * 5;
	lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
	lForm.myCaller := self;
	lForm.formCaption := app.getErrorString(Additional_remarks);
	lForm.type := self.GetData_Remarks;
	lForm.show;
	
epilog
	mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuStop" id="9ff4ae02-bdde-4f94-8864-76a9913e553b">
        <updating/>
        <source>doMnuStop( menuItem : MenuItem input ) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
//	lStops		: IntegerArray;
	result		: Integer;
	lTI			: CM_TrackedItem;
	stopsTable	: CM_StopsTable;
	tiSet		: CM_TISet;
	
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI(lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	
	return;

epilog
	delete tiSet;
	app.mousePointer	:= Idle;
	
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="cbeb80d6-f812-4268-96f7-c590f542f319">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	lTI	: CM_TrackedItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="a3502194-f402-4d54-9da6-5d0672b3ba36">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Ship_roro_planning), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskRemove" id="9389d421-571f-415a-b0c2-a946e33e524a">
        <updating/>
        <source>doMnuTaskRemove(_menuItem : MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	lTI		: CM_TrackedItem;
	answer	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := _menuItem.userObject.CM_TrackedItem;
	if lTI = null or 
	   _menuItem = self.mnuTaskRemove then
		return;
	endif;

	answer := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskRemove(lTI, _menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Remove_Task), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnplan" id="8c7f83cd-5480-4ace-9175-e50983cafb2c">
        <updating/>
        <source>doMnuUnplan(_menuItem : MenuItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;
	
	if _menuItem.userObject.isKindOf(CM_FutureMove) then
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);
	elseif _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 
		self.doUnqueueTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpContextId = TI_FutureMoveOverstow));
	else
		self.doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = self.UnplanMenu_TypeLoad));
	endif;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOrderROROLocns" id="ece9a565-e2f8-4cc1-a8f9-53ecf280dfda">
        <updating/>
        <source>doOrderROROLocns(_deckItemLayoutArray : CM_RORODeckItemLayoutArray input) updating;
/*
Date		    Who			Reason
13 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
Feb 2012		cnwjre1		revised 28859
21 Aug 2012		cnwcs5		par 29124:2
*/
constants
	
vars
	deckItemLayout 	: CM_DeckItemLayout;
	tempLocn	   	: CM_ROROLocnDefnVoyage;
	ord1, ord2		: Integer;
	deck			: CM_Deck;
	vessel			: CM_Vessel;
begin
	self.doClearRemarks;	// par 29124:2
	
	if _deckItemLayoutArray.isEmpty() then
		return;
	endif;
	
	self.allDeckItemLayouts.clear();
	
	_deckItemLayoutArray.copyNoDuplicates(self.allDeckItemLayouts);
	
	deckItemLayout := self.allDeckItemLayouts.first();
	if deckItemLayout.myDeckItem &lt;&gt; null then 
		deck := deckItemLayout.myDeckItem.myDeck;
		if deck &lt;&gt; null then 
			vessel := deck.getVessel();
		endif;
	endif;
	
	self.myROROLocnDrawingController.init(vessel);
	self.optColour.value := ( self.myROROLocnDrawingController.modeViewSub = ShpDisplayModeSub_Colour);
	self.optText.value := ( self.myROROLocnDrawingController.modeViewSub = ShpDisplayModeSub_Text);
	
	self.allOrderedROROLocns.clear();
	self.allLocnDefnsByRowCol.clear();
	
	foreach deckItemLayout in self.allDeckItemLayouts discreteLock do
		if not deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
			continue;
		endif;
		tempLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage;
		
		deckItemLayout.getOrdinalsForSorting(AFPS_Value, ord1, ord2);
		
		// 28859 Feb 2012 
		self.allOrderedROROLocns.putAtKey(ord1, ord2, tempLocn);
		self.allLocnDefnsByRowCol.putAtKey(ord2, ord1, tempLocn);
		
		self.myROROLocnDrawingController.allLocnDefns.addNoDuplicates(tempLocn,false);
		self.myROROLocnDrawingController.allLocnDefnsByRowCol.putAtKey(ord1, ord2, tempLocn);
				
	endforeach;
	
	
	if self.myROROLocnDrawingController.modeView = 0 then // PAR 28990 first time only
		self.myROROLocnDrawingController.modeView := self.myROROPlanningForm.modeView;
	endif;
	self.setCaption(  self.myROROPlanningForm.setCaptionForModesGetView(self.myROROPlanningForm.modeView));
	
	self.doDrawFrames();
	
	if self.btnDrawRemarks.value then	// par 29124:2 Aug 2012
		self.doShowRemarks;				// par 29124:2 Aug 2012
	endif;								// par 29124:2 Aug 2012
	
epilog

end;</source>
        <Parameter name="_deckItemLayoutArray" type="CM_RORODeckItemLayoutArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPicCloseRemarksClick" id="ca469b3d-53d9-462e-a987-dcb2c77809e8">
        <source>doPicCloseRemarksClick(_picture :CMUI_Picture)protected;
/*
Date		Who		Reason
21 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars
	parent	:Window;
	frame	:CMUI_MoveableRemarksFrame;
begin
	parent := _picture.parent;
	
	if parent &lt;&gt; null and parent.isKindOf(CMUI_MoveableRemarksFrame) then
		frame := parent.CMUI_MoveableRemarksFrame;
	endif;
	
	if frame = null then
		return;
	endif;
	
	self.allRemarksControls.removeIfPresent (frame);
	
	delete frame;	// will delete receiver
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_picture" type="CMUI_Picture"/>
    </JadeMethod>
    <JadeMethod name="doPicRemarksClick" id="d0b27dfc-f42d-43c0-8abf-e9c1ed620f72">
        <updating/>
        <source>doPicRemarksClick(_picture :Picture) updating, protected;
/*
Date		Who		Reason
26 July 2012	cnwcs5	Initial creation - par 29124
*/
constants
	Offset 		= 5;
	Width		= 200;
vars
	slot		:CM_ROROSlotDefnVoyage;
	frame		:CMUI_MoveableRemarksFrame;
	remarks		:String;
	gotException	:Boolean;							// par 29124:2 Aug 2012
	closeButton		:Picture;							// par 29124:2 Aug 2012	
begin
	frame 		:= self.frmRemarks.getControl (_picture.index);
	
	if frame = null then
		on Exception do app.handleDeletedObject (exception, slot, gotException);	// par 29124:2 Aug 2012

		slot		:= _picture.userObject.CM_ROROSlotDefnVoyage;
		remarks		:= slot.getROROPlanningRemarks (true);									// par 29124:2 Aug 2012

		if gotException then														// par 29124:2 Aug 2012
			// graphic has been deleted - should not be possible 
			return;
		endif;																		// par 29124:2 Aug 2012	

		// need to create it
		frame 				:= self.frmRemarks.loadControl (_picture.index).CMUI_MoveableRemarksFrame;
		frame.wordWrap		:= true;
		frame.setContents (slot.code, remarks, Width, Offset);					// par 29124:2 Aug 2012
		frame.userObject	:= _picture.userObject;
		frame.parent		:= _picture.parent;
	
		self.allRemarksControls.add (frame);
		
		frame.move (_picture.left + _picture.width + Offset, _picture.top, frame.width, frame.height);	// par 29124:2 Aug 2012
		
		// also create button to close it
		closeButton 		:= self.picCloseRemarks.loadControl (_picture.index).CMUI_Picture;	// par 29124:2 Aug 2012
		closeButton.parent	:= frame;															// par 29124:2 Aug 2012
		closeButton.borderStyle	:= Picture.BorderStyle_None;									// par 29124:2 Aug 2012
		
		closeButton.move (frame.width - closeButton.width - 2, 1, 16, 16);
	else
		frame.move (_picture.left + _picture.width + Offset, _picture.top, frame.width, frame.height);	// par 29124:2 Aug 2012	
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_picture" type="Picture"/>
    </JadeMethod>
