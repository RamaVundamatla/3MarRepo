      &lt;dischargePort&gt;NZLYT&lt;/dischargePort&gt;
      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
    &lt;CargoOnSite Terminal="TT1"&gt;
      &lt;TestCases&gt;37279&lt;/TestCases&gt;
      &lt;cargoTypeDescr&gt;Motor Vehicle&lt;/cargoTypeDescr&gt;
      &lt;id&gt;JLG37279W7UA09&lt;/id&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;locationId&gt;GCVH01 CARS&lt;/locationId&gt;
      &lt;weight&gt;5000.0000&lt;/weight&gt;
      &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
      &lt;commodity&gt;MCAR&lt;/commodity&gt;
      &lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
  &lt;/AllCargoOnSite&gt;
&lt;/JMTInternalCargoOnSite&gt;';

	self.ediLoadVerifyDBLoadActualSetup(ediData, null, method.name, EDIFileType_JMTInternal, false, true, false, false, null);
		
	// add release requests
	self.opts.purge();
	self.opts.addAssoc("Number", 3);
	self.opts.addAssoc("Voyage", self.getVoyage("MSCK000002").CM_Voyage);
	self.opts.addAssoc("Operator", app.myRoot.allOperators["MSL"].CM_Operator);
	self.opts.addAssoc("FullRelease", true);
	
	release := self.addReleaseByTypeRequestOpts("JLG37279ROAD001", 1, 7);
	
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA01").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA02").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA03").CM_TrackedItem);
	
	release := self.addReleaseByTypeRequestOpts("JLG37279ROAD002", 1, 7);
	
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA04").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA05").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA06").CM_TrackedItem);
	
	release := self.addReleaseByTypeRequestOpts("JLG37279ROAD003", 1, 7);
	
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA07").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA08").CM_TrackedItem);
	self.releaseAssignCargo(release, null, self.getTrackedItem("JLG37279W7UA09").CM_TrackedItem);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete tisToDelete;
	delete tiSet;
	delete pinsStrDict;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_37284" id="077106cf-9b49-47ae-a30b-2ce09864d762">
        <source>resetData_37284();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2020	jlgmh5	Initial creation

*/

vars

	roroLaneArea			: CM_TerminalArea;
	rlaController			: CM_RoRoController;
	terminal				: CM_Terminal;
	
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	roroLaneArea := self.getTerminalArea("RLA001");
	app.writeLog("************** roroLaneArea: " &amp; roroLaneArea.String, LogINFO);
		
	foreach rlaController in roroLaneArea.CM_RoRoLaneArea.allLanesById do
		app.writeLog("************** inside loop: " &amp; rlaController.String, LogINFO);
		app.myTrxUA.trxUpdateRoRoLaneFreedLength(rlaController, 0, app.myPassport );
	endforeach;
	
epilog

	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_37388" id="729d14a7-5482-45a9-ba2d-3002bf6592bb">
        <source>resetData_37388();
constants

	ReleaseRequestID		: String = "JLGRRROAD37388A01";


vars

	terminal				: CM_Terminal;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;
	cargoType				: CM_CargoType;
	user					: CM_User;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// delete the release request
	self.deleteReleaseRequest(ReleaseRequestID);
	
	cargoType := self.getCargoType("BSAND");
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37388A01");

	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, cargoType.id, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37392" id="8b9ec091-e400-47a0-9587-e02166d42b4b">
        <source>resetData_37392();
/*

Purpose:	Reset 37392		

Date		Who		Reason
16/08/2021	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteVehicle("37392");

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37455" id="4e2d1094-55d6-4c3f-b5c3-0dad321c6bb1">
        <source>resetData_37455();
/*

Purpose:	Reset 37392		

Date		Who		Reason
17/01/2022	navmh5	Initial creation

*/
constants
	VechileID				: String = "37455";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle(VechileID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VechileID, LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37494" id="fd0baf06-59a4-4622-b350-2cf209e7ad1b">
        <source>resetData_37494();
/*

Purpose:	Reset 37392		

Date		Who		Reason
21/06/2022	navmh5	Initial creation

*/
constants
	VechileID				: String = "37494";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle(VechileID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VechileID, LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
	self.deleteVehicle(VechileID);

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37741" id="29e2bd34-d627-4b7d-8ae4-b2f684dbbdcf">
        <source>resetData_37741();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2021	jlgmh5	Initial creation

*/

constants

	ReleaseRequestID		: String = "JLG37741ROADA01";


vars

	terminal				: CM_Terminal;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	// delete the release request
	self.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37741A01");
	tisToDelete.add("JLG37741A02");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_37877" id="73ddd526-4d61-4bf9-a0b3-247ceb1cb9bb">
        <source>resetData_37877();

/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
05 April 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "VOY37877";
	VesselCode				    : String = "JDIAM";
	CraneId						: String = "CRN1";

vars
	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	voyageLoadJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	operator					: CM_Operator;
	bs						    : CM_BlockStack;
	
	slotsFrom					: CM_SlotControllerArray;
	tisToDelete					: StringArray;
	
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
		
	//DELETE THE VOYAGE
	self.deleteVoyage(VoyageId);
	
	// create the voyage
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselCode, "MSK", "AZL"); 
	self.assertNotNull(voyage);
	
	operator := app.myRoot.allOperators["MSK"];
	self.assertNotNull(operator);

		
	// colour code the load slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "25", DeckOnDeck, 1, 3, 1, slotsFrom);
	self.markSlotsAsLoadJob(slotsFrom,tmpLoadCC);
	self.markSlotsAsLoadCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "25", DeckOnDeck, 1, 3, 1, slotsFrom);
	
	voyageLoadJob := self.addVoyageJob(voyage, CraneId, slotsFrom, false);
	self.assertNotNull(voyageLoadJob);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	delete slotsFrom;
	delete tmpLoadCC;
end;



</source>
    </JadeMethod>
    <JadeMethod name="resetData_38004" id="d5a344af-00ee-4a71-8c3a-34faea113519">
        <source>resetData_38004();
/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
13 August 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "VOY_38004";
	VesselId					: String = "MESDAI2";
	CraneId						: String = "CRN3";

vars
    voyage						: CM_Voyage;
	voyageQueue					: CM_VoyageQueue;
	queue						: CM_RadioTelemetryQueue;
	crane						: CM_Machine;
	machine1					: CM_Machine;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG38004A01");
	tisToDelete.add("JLG38004A03");
	tisToDelete.add("JLG38004A06");
	tisToDelete.add("JLG38004A09");
	tisToDelete.add("JLG38004A10");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
	
	voyageQueue := self.addVoyageQueue(voyage);
	crane := getCrane("CRN3");
	machine1 := getMachine("FK06");
	
	queue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	self.machineAssignToQueue(machine1, queue);
	
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	
	ti := self.addContainerOnShip("JLG38004A01", operator, "2200", "GEN", null, voyage, "USJAX", "011082").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG38004A03", operator, "2200", "GEN", null, voyage, "USJAX", "010882").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG38004A06", operator, "2200", "GEN", null, voyage, "USJAX", "010682").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG38004A09", operator, "2200", "GEN", null, voyage, "USJAX", "010482").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG38004A10", operator, "2200", "MT", null, voyage, "USJAX", "010282").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 2, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 3, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 4, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 5, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 2, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 3, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 4, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 5, 1, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;

end;



</source>
    </JadeMethod>
    <JadeMethod name="resetData_38106" id="8cb0b056-df21-4b0d-a25f-a9edbdedca2b">
        <source>resetData_38106();

constants

	VoyageId				: String = "MSKA5000001";
	VesselCode				: String = "MSKA5";
	CargoID					: String = "JLG38106A01";

vars

	terminal				: CM_Terminal;
	ti						: Object;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	tmpLoadCC				: CMIF_LoadColorCode;
	crane					: CM_Machine;
	voyageDischJob			: CM_VoyageJob;
	voyageLoadJob			: CM_VoyageJob;
	slot					: CM_SlotController;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	slotsFrom				: CM_SlotControllerArray;
	slotsTo					: CM_SlotControllerArray;
	allObjectEditions		: CM_ObjectByOidEditionDict;	

	trackedItemId			: String;
	arrivalTS				: TimeStamp;
	departureTS				: TimeStamp;

begin

	
	app.initialize();

	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add(CargoID);
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// delete the voyage
	self.deleteVoyage(VoyageId);
	
	// create the voyage
	arrivalTS.setDate("11/12/2021".Date);
	arrivalTS.setTime("09:00:00".Time);
	departureTS.setDate("11/12/2021".Date);
	departureTS.setTime("12:00:00".Time);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselCode, "MSK", "AZL"); 
	self.assertNotNull(voyage);
	
	operator := app.myRoot.allOperators["MSK"];
	self.assertNotNull(operator);
	
	// create cargo
	self.addContainerOnShip("JLG38106A01", operator, "2200", "GENL", null, voyage, "USJAX", "250782");
	
	
epilog

	delete tisToDelete;
	delete tiSet;
	delete slotsFrom;
	delete allObjectEditions;	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_38282" id="d1654aa9-732d-46c9-a708-0ed3df160aa5">
        <source>resetData_38282();

constants

	VehicleID				: String = "38282";
	ReleaseRequestID		: String = "JLGINTERROAD38282A01";
	InterTermConfigName		: String = ReleaseRequestID;

vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle
	self.deleteVehicle(VehicleID);
	self.addVehicle(VehicleID, app.myRoot.allCarriers["AAUTO"].CM_Carrier, terminal);
	
	// delete inter terminal config
	self.deleteInterTermConfig(InterTermConfigName);
	
	// delete the release request
	self.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG38282A01");
	tisToDelete.add("JLG38282A02");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
		
	/*****************************************************
	 * Terminal - TT2
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT2"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle
	self.deleteVehicle(VehicleID);
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG38282A01");
	tisToDelete.add("JLG38282A02");
	
	foreach trackedItemId in tisToDelete do
		
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
