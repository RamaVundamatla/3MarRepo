//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wle	: CM_ToDoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="3851d921-6123-429b-ae8f-b9cbbb3b0029">
        <source>createWLEs();
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (self.allWorkListEntries.size &gt; 0) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_HAS_WL_ENTRIES, null, null);
		return;
	endif;

	self.createWLE();

end;</source>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="599aaf5a-6bea-4ce6-b805-6ee9b4d91b4a">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_To_Do_Task), DC_Label, 1, null);
	//block.addNewItem(self.myToDoRequestType.description, DC_Data, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
