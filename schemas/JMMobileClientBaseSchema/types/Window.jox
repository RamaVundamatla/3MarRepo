<GUIClass name="Window">
    <Constant name="MB_MODAL_CANCEL" id="9a9ea5e2-15af-405e-ad44-8d63b4b63731">
        <source>0</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form without having made
any changes.</text>
    </Constant>
    <Constant name="MB_MODAL_CLOSE" id="29b8851f-3d45-4c70-bb23-6c8edabb7cd1">
        <source>1</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form without any action.</text>
    </Constant>
    <Constant name="MB_MODAL_CREATE" id="8cc406c2-16cc-4529-b088-adc6c6724f0b">
        <source>2</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after creating an
object.</text>
    </Constant>
    <Constant name="MB_MODAL_DELETE" id="2d61b052-fa7c-4599-bfaa-06db43d6def3">
        <source>3</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after deleting an
object.</text>
    </Constant>
    <Constant name="MB_MODAL_SELECT" id="1198a3bc-4360-4537-943b-7bc17d35ff9e">
        <source>4</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after selecting one or
more objects.</text>
    </Constant>
    <Constant name="MB_MODAL_UPDATE" id="a7fa3e96-d192-413b-8561-c26c0857f361">
        <source>5</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after updating an
object.</text>
    </Constant>
    <JadeMethod name="mbIsSaveRequired" id="d8682ceb-4662-47c1-9190-a9703f9dc240">
        <source>mbIsSaveRequired():Boolean protected, abstract;</source>
        <abstract/>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbSetIsSaveRequired" id="88ed6087-8ce5-4119-84e2-e4069b63affa">
        <updating/>
        <source>mbSetIsSaveRequired(_isRequired:Boolean) updating, protected, abstract;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="_isRequired" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBackForeColor" id="357db66f-ab65-484a-bce8-532f91c7a9e7">
        <updating/>
        <source>setBackForeColor(_backColor:Integer; _foreColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Sets the background and fore colors of the receiver. Not all Windows
//				or its subclasses have both a background and foreground, so this
//				method is reimplemented where necessary.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor	:=	_backColor;
end;</source>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_foreColor" type="Integer"/>
    </JadeMethod>
</GUIClass>
