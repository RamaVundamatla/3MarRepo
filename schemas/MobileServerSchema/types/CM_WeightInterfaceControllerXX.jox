/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);


