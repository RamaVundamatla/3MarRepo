    <JadeMethod name="currentObjectHasBooking" id="fce40cd2-ffb3-4d3c-805d-382154749dce">
        <source>currentObjectHasBooking() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2010	cnwrd1	Initial creation

*/

vars

	obj		: Object;
	br		: CM_BulkRelease;
begin
	
	obj := self.myCurrentObject;
	
	if CM_BulkRelease.hasInstance(obj) then
		if obj.CM_BulkRelease.myBookingRefStock &lt;&gt; null then
			return true;
		endif;
	elseif CM_ReserveDetail.hasInstance(obj) then
		if obj.CM_ReserveDetail.myBookingRefItem &lt;&gt; null then
			return true;
		endif;
		br := obj.CM_ReserveDetail.myReserveHeader;
		if br &lt;&gt; null and
		br.myBookingRefStock &lt;&gt; null then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="currentObjectHasEDIFile" id="96cd3a4f-f2f3-4761-85ef-98075599f985">
        <source>currentObjectHasEDIFile():Boolean protected;
/*
Date		Who		Reason
14 Dec 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	obj		: Object;
	br		: CM_BulkRelease;
	coll	: CM_EDIFileArray;
begin
	
	obj := self.myCurrentObject;
	
	if CM_BulkRelease.hasInstance(obj) then
		br := obj.CM_BulkRelease;
	elseif CM_ReserveDetail.hasInstance(obj) then
		br := obj.CM_ReserveDetail.myReserveHeader;
	endif;
	
	if br &lt;&gt; null then
		create coll transient;
		br.getAllEDIFiles (coll);
		
		if not coll.isEmpty then
			return true;
		endif;
	endif;
	
	return false;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="currentObjectHasTIs" id="83dbcfd8-9b32-4977-bc53-8b36251e2956">
        <source>currentObjectHasTIs(): Boolean;
//----------------------------------------------------------------
//	Created:	04 November 2005	by Jason Chapman  (cnwjc2)
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//----------------------------------------------------------------
vars
	obj		: Object;
	br		: CM_BulkRelease;
begin
	
	obj := self.myCurrentObject;
	
	if CM_BulkRelease.hasInstance(obj) then
		if obj.CM_BulkRelease.allTrackedItemsAssigned.isNotEmpty
		or obj.CM_BulkRelease.allTrackedItemsReleased.isNotEmpty then
			return true;
		endif;
	elseif CM_ReserveDetail.hasInstance(obj) then
		//if obj.CM_ReserveDetail.allTrackedItems.isNotEmpty then
		if obj.CM_ReserveDetail.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
			return true;
		endif;
		br := obj.CM_ReserveDetail.myReserveHeader;
		if br &lt;&gt; null and
		(br.allTrackedItemsAssigned.isNotEmpty
		or br.allTrackedItemsReleased.isNotEmpty) then
			return true;
		endif;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="currentObjectIsPacking" id="66ef42c8-174c-4f13-8fc5-89d50f48d847">
        <source>currentObjectIsPacking(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2009	cnwrd1	Initial creation

*/

vars
	obj		: Object;
	br		: CM_BulkRelease;
begin
	
	obj := self.myCurrentObject;
	
	if CM_BulkRelease.hasInstance(obj) then
		if obj.CM_BulkRelease.type = BR_TYPE_PACKING then
			return true;
		endif;
	elseif CM_ReserveDetail.hasInstance(obj) then
		br := obj.CM_ReserveDetail.myReserveHeader;
		if br &lt;&gt; null and
		br.type = BR_TYPE_PACKING then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnDeletePin" id="9402732d-3319-4dab-aef9-c85c366e5eac">
        <updating/>
        <source>doBtnDeletePin()updating;
//----------------------------------------------------------------
//	Created:	07 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Date			Who		Reason
// 01 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with self.myTerminal
vars
	obj				: Object;
	consignee		: CM_ConsigneeConsignor;
	theBR			: CM_BulkRelease;
	brSet 			: CM_BulkReleaseSet;
	updateEmail		: Integer;
	canUpdate		: Boolean;
	user			: CM_User;
	tmpEmailDef,
	termEmailDef	: CM_PINObjectDefaultEmail;
	carrier			: CM_Carrier;
	br				: CM_BulkRelease;
begin
	if (not self.allowGeneratePin) then
		app.msgBox(app.getErrorString1(NoPermission, 'delete a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;

	create brSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_BulkRelease.hasInstance(obj) then
			theBR := obj.CM_BulkRelease;
		elseif CM_ReserveDetail.hasInstance(obj) then
			theBR := obj.CM_ReserveDetail.myReserveHeader;
		elseif CM_TrackedItem.hasInstance(obj) then
			theBR := obj.CM_TrackedItem.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_ROAD,null,null,null);
		endif;
		if theBR &lt;&gt; null then
			if (not brSet.includes(theBR)) then
				brSet.add(theBR);
			endif;
		endif;
	endforeach;
	
	user := app.myPassport.myUser;
//	termEmailDef := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_ReleaseRequestDelete);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	termEmailDef := self.myTerminal.getEmailDefaultsSettings( PINEmail_ReleaseRequestDelete );
	
	if user &lt;&gt; null
	and brSet.size = 1
	and termEmailDef.enabled then
		br := brSet.first;
		canUpdate := user.canDo(self.myTerminal, PmAdmPINEmailDefUpdate) or user.canDo(self.myTerminal, PmAdmPINEmailDefMaint);
		if canUpdate
		and br.status = BR_ACTIVE
		and br.myPinNo &lt;&gt; null then
			updateEmail := app.msgBox("Do you want to update the carrier e-mail before sending?", "PIN E-mail", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		endif;
	elseif (not app.msgBox('Are you sure you want to delete the Pin numbers for the selected items?', 'Delete Pin No.', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes) then
		return;
	
	endif;
	
	if (not brSet.isEmpty) then
		if updateEmail = MsgBox_Return_Yes then	//can and wants to update the email
			tmpEmailDef := termEmailDef.cloneSelf(true);
			carrier 	:= brSet.first.getCarrier();
			consignee	:= brSet.first.getConsignee();
			
//			if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if carrier = null and termEmailDef.sendToCarrier then
				app.msgBox("You need to set the Carrier before modifying the email defaults.","E-mail Options",null);
				return;
			endif;
	
//			if consignee = null and self.myTerminal.getConfig(DefaultConsignorEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if consignee = null and termEmailDef.sendToConsignee then
				app.msgBox("You need to set the Consignee before modifying the email defaults.","E-mail Options",null);
				return;
			endif;
			
//			tmpEmailDef.setAddresses(self.myTerminal, carrier, consignee);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			tmpEmailDef.setAddresses( self.myTerminal, carrier, consignee, PINEmail_ReleaseRequestDelete );
			modalResult := self.myAssistant.showCarrierEmailOptions(carrier, tmpEmailDef, true, null);
	 		
	 		if modalResult &lt;&gt; IDOK then
	 			//take the cancel as a sign to bail out
	 			app.msgBox("The PIN has not been deleted.","E-mail Options",MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
		endif;
		app.mousePointer := MousePointer_HourGlass;
	endif;
	
	//DELETE THE PIN
	self.doDeletePin(brSet, tmpEmailDef);
	
epilog
	if tmpEmailDef &lt;&gt; null then	//Par 18860 Feb 2009
		delete tmpEmailDef.myEmailController;
		delete tmpEmailDef;
	endif;
	delete brSet;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEditStatus" id="560c09b7-4647-4802-a8e6-9851c774cc87">
        <updating/>
        <source>doBtnEditStatus() updating, protected;

/*
Purpose:		Get all of the selected release requests and pass them through to the edit status form.

Date				Who		Reason
24 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
16/02/2012			cnwcs5	CCMS POL 2151 / par 29137 - remove refresh (don't need it)
*/
	
vars
	allReleaseRequests	: CM_BulkReleaseSet;
	saveMultiEdit		: Boolean;
	br : CM_BulkRelease;								//navra1 - MTN-35875- 5th Sep 2025-3
	noEditPermission : Boolean;							//navra1 - MTN-35875- 5th Sep 2025-3
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for bulk status update');
		return;
	endif;
	
	// The form does not currently allow multi-edit but save
	// value and reset later in case ever changed
	saveMultiEdit				:= self.allowMultiSelectEdit;
	self.allowMultiSelectEdit	:= true;
	self.setDoingMultiEdit();
	
	create allReleaseRequests transient;
	
	self.tblData.allSelectedObjects.copy( allReleaseRequests );
	
	//navra1 - MTN-35875- 5th Sep 2025-3 - start	
	if allReleaseRequests &lt;&gt; null and allReleaseRequests.size() &gt;= 1 then
		noEditPermission  := not app.myCurrentUserCan(self.myTerminal, PmAdmEditAGGatewayRRMaint);
		if noEditPermission then
			foreach br in allReleaseRequests do
				if br.CM_BulkRelease.remarksAdditional1.startsWith("YARA") = true then
					app.msgBox(app.getErrorString(Cannot_edit_AG_Gateway_RR), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			endforeach;	
		endif;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-3 - end
	
	self.createMyAssistant( GTE_Assistant );		// just in case?
	
	if self.myAssistant.GTE_Assistant.showEditReleaseReqStatus( allReleaseRequests ) then
		self.setIgnoreFilterStatus (true);	// par 29137
	endif;
epilog
	self.allowMultiSelectEdit := saveMultiEdit;
	delete allReleaseRequests;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnEditType" id="2ce26296-bc33-4164-94b6-25cf6adefe85">
        <updating/>
        <source>doBtnEditType() updating, protected;
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
16/02/2012	cnwcs5	CCMS POL 2151 / par 29137 - remove refresh (don't need it);
*/
vars
	coll		: CM_BulkReleaseSet;
	saveValue	: Boolean;
	br : CM_BulkRelease;								//navra1 - MTN-35875- 5th Sep 2025-3
	noEditPermission : Boolean;							//navra1 - MTN-35875- 5th Sep 2025-3
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for bulk type update');
		return;
	endif;
	
	// The form does not currently allow multi-edit but save
	// value and reset later in case ever changed
	saveValue					:= self.allowMultiSelectEdit;
	self.allowMultiSelectEdit	:= true;
	
	self.setDoingMultiEdit();
	
	create coll transient;
	self.tblData.allSelectedObjects.copy( coll );
	
	//navra1 - MTN-35875- 5th Sep 2025-3 - start	
	if coll &lt;&gt; null and coll.size() &gt;= 1 then
		noEditPermission  := not app.myCurrentUserCan(self.myTerminal, PmAdmEditAGGatewayRRMaint);
		if noEditPermission then
			foreach br in coll do
				if br.CM_BulkRelease.remarksAdditional1.startsWith("YARA") = true then
					app.msgBox(app.getErrorString(Cannot_edit_AG_Gateway_RR), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			endforeach;	
		endif;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-3 - end
	
	self.createMyAssistant( GTE_Assistant );		// just in case?
	
	if self.myAssistant.GTE_Assistant.showEditReleaseReqType( coll ) then
		self.setIgnoreFilterType (true);
	endif;
	
epilog
	self.allowMultiSelectEdit := saveValue;
	
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnFullReqClick" id="f036873f-9ea4-42d5-b0dd-1796bddba13c">
        <updating/>
        <source>doBtnFullReqClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 10 Nov 2023 navnk30 ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
// ---------------------------------------------------------------------------

vars
	addedObjects ,
	coll				: ObjectSet;
	obj : Object;
	invalidObj : Boolean;
	reserveDetail : CM_ReserveDetail;
	reserveHeader : CM_BulkRelease;
	edition : Integer;
begin
	
	self.showFullReq := not self.showFullReq;
	if self.showFullReq then
		self.btnFullReq.bubbleHelp := app.getErrorString(GTE_Show_Bulk_Release_Details);
		self.btnFullReq.myToolbarButton.drawButtonDown();
		self.btnDeleteTV.enabled := false;
	else
		self.btnFullReq.bubbleHelp := app.getErrorString(GTE_Show_Full_Request_Details);
		self.btnFullReq.myToolbarButton.clearGraphics();
		self.btnDeleteTV.enabled := true;
	
	endif;

	//epr TFS 1826 15/4/16 the problem was when form is populated from the MT pooling enquiry the column organiser use to redo the search
	// now just reloads from the current table data

	create coll transient;
	self.tblData.getAllRowObjects(coll);
	
	self.tblData.clearAllData();
	
	create addedObjects transient;
	
	on Exception do app.handleDeletedObject(exception,obj,invalidObj);
	foreach obj in coll discreteLock do
		invalidObj:=false;
		edition:=obj.edition;
		if invalidObj then
			continue;
		endif;
		if self.showFullReq then
			if obj.isKindOf(CM_ReserveDetail) then
				self.tblData.addObject(obj.CM_Object);
			elseif obj.isKindOf(CM_BulkRelease) then
				foreach reserveDetail in obj.CM_BulkRelease.allReserveDetails discreteLock do
					self.tblData.addObject(reserveDetail);
				endforeach;
				
				//To show child reserve detail items
				foreach reserveDetail in obj.CM_BulkRelease.allReservePackingChildren discreteLock do		//10.11.2023 navnk30 #60646
					self.tblData.addObject(reserveDetail);
				endforeach;
			endif;
		else
			if obj.isKindOf(CM_ReserveDetail) then
				reserveHeader:= obj.CM_ReserveDetail.myReserveHeader;
				if not addedObjects.includes(reserveHeader) then
					self.tblData.addObject(reserveHeader);
					addedObjects.add(reserveHeader);
				endif;
				
			elseif obj.isKindOf(CM_BulkRelease) then
				self.tblData.addObject(obj.CM_Object);		
			endif;		
		endif;
	endforeach;
	
	self.zTblDataColorRows();
	self.numItemsShown:=self.tblData.rows - self.tblData.fixedRows;
	self.showNumRowsShown();
epilog
	delete addedObjects;
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnGeneratePin" id="6c8109f3-4734-4a91-8e54-69d777eb7a0f">
        <updating/>
        <source>doBtnGeneratePin()updating;
//--------------------------------------------------
// Created:	06 January 2006 By: cnwgd1
//--------------------------------------------------
// Date			Who		Reason
// 01 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with self.myTerminal
vars
	obj				: Object;
	consignee		: CM_ConsigneeConsignor;
	theBR			: CM_BulkRelease;
	brSet 			: CM_BulkReleaseSet;
	updateEmail		: Integer;
	canUpdate		: Boolean;
	user			: CM_User;
	tmpEmailDef,
	termEmailDef	: CM_PINObjectDefaultEmail;
	carrier			: CM_Carrier;
	br				: CM_BulkRelease;
begin
	if (not self.allowGeneratePin) then
		app.msgBox(app.getErrorString1(NoPermission, 'generate a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;

	create brSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_BulkRelease.hasInstance(obj) then
			theBR := obj.CM_BulkRelease;
		elseif CM_ReserveDetail.hasInstance(obj) then
			theBR := obj.CM_ReserveDetail.myReserveHeader;
		elseif CM_TrackedItem.hasInstance(obj) then
			theBR := obj.CM_TrackedItem.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_ROAD,null,null,null);
		endif;
		if theBR &lt;&gt; null then
			if (not brSet.includes(theBR)) then
				brSet.add(theBR);
			endif;
		endif;
	endforeach;
	
	user := app.myPassport.myUser;
//	termEmailDef := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_ReleaseRequest);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	termEmailDef := self.myTerminal.getEmailDefaultsSettings( PINEmail_ReleaseRequest );
	
	if user &lt;&gt; null
	and brSet.size = 1
	and termEmailDef.enabled then
		br := brSet.first;
		canUpdate := user.canDo(self.myTerminal, PmAdmPINEmailDefUpdate) or user.canDo(self.myTerminal, PmAdmPINEmailDefMaint);
		if canUpdate
		and br.status = BR_ACTIVE then
			updateEmail := app.msgBox("Do you want to update the carrier e-mail before sending?", "PIN E-mail", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		endif;
		
	elseif (not app.msgBox(app.getErrorString(Gte_GeneratePinNo), app.getErrorString(Gte_ReGenerate_Pin_No), MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes) then
		return;
	
	endif;
	
	if (not brSet.isEmpty) then
		if updateEmail = MsgBox_Return_Yes then	//can and wants to update the email
			tmpEmailDef := termEmailDef.cloneSelf(true);
			carrier := brSet.first.getCarrier();
			consignee := brSet.first.getConsignee();
			
//			if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if carrier = null and termEmailDef.sendToCarrier then
				app.msgBox("You need to set the Carrier before modifying the email defaults.","E-mail Options",null);
				return;
			endif;
	
//			if consignee = null and self.myTerminal.getConfig(DefaultConsignorEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if consignee = null and termEmailDef.sendToConsignee then
				app.msgBox("You need to set the Consignee before modifying the email defaults.","E-mail Options",null);
				return;
			endif;
			
//			tmpEmailDef.setAddresses(self.myTerminal, carrier, consignee);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			tmpEmailDef.setAddresses( self.myTerminal, carrier, consignee, PINEmail_ReleaseRequest );
			modalResult := self.myAssistant.showCarrierEmailOptions(carrier, tmpEmailDef, true, null);
	 		
	 		if modalResult &lt;&gt; IDOK then
	 			//take the cancel as a sign to bail out
	 			app.msgBox("The PIN has not been generated.","E-mail Options",MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
		endif;
		app.mousePointer := MousePointer_HourGlass;
	endif;
	
	//GENERATE THE PIN
	self.doGeneratePin(brSet, tmpEmailDef);
	
epilog
	if tmpEmailDef &lt;&gt; null then	//18860 Feb 2009
		delete tmpEmailDef.myEmailController;
		delete tmpEmailDef;
	endif;
	delete brSet;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuRailLines" id="cde3dacd-0fff-441f-b97e-53d6460b1b1c">
        <updating/>
        <source>doBuildMenuRailLines(tmpMenu : MenuItem) updating, protected;
//----------------------------------------------------------------
//	Created:	07 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ioTypeStr		: String;
	idx				: Integer;
	rail			: CM_TerminalArea;
	subMenu,tmpSubMenu			: MenuItem;
	railway			: CM_Rail;
	railIO			: CM_RailJSInOut;
	railIORake		: CM_RailJSInOutRake;
	
	menuMaster		: MenuItem;
	ioType 			: Integer;
begin

	ioType := Rail_JSIO_Type_Out;
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	
	menuMaster := tmpMenu; //self.mnuOutwardRail.description.asOid.MenuItem;
	tmpSubMenu := self.zCloneMenu(menuMaster,self.mnuOutwardRailSub, true); 
	self.mnuOutwardRailSub.visible := true;
	tmpSubMenu.visible := false;

	ioTypeStr := app.railRakeTypeEnumToString(ioType);
	
	foreach railIO in self.myTerminal.myRailJobSheet.inouts do
		if railIO.outwards = ioType then
			foreach railIORake in railIO.inoutRakes do

				subMenu := self.zCloneMenu(menuMaster, tmpSubMenu, true); 
				
				if railIORake.myRail &lt;&gt; null then
					subMenu.caption := ioTypeStr &amp; ' ' &amp; railIORake.myRail.id &amp; "...";
				else
					subMenu.caption := ioTypeStr;				
				endif;
				subMenu.userObject := railIORake;
				subMenu.enabled := true;
				subMenu.visible := true;
				tmpSubMenu := subMenu;
			endforeach;
		endif;
	endforeach;

	// ### TRAINS PAR 19710
	subMenu := self.zCloneMenu(menuMaster, tmpSubMenu, true); 
	subMenu.caption := app.getErrorString(Planned_trains) &amp; "...";				
	subMenu.userObject := CM_Train.class;
	//20 Feb 2017	NDL	TFS 3485
	subMenu.enabled := false; //true;
	subMenu.visible := false; //true;
	
end;</source>
        <access>protected</access>
        <Parameter name="tmpMenu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuCompleteItems" id="8097c4e7-fe3a-4559-b73c-34a8e31beb22">
        <updating/>
        <source>doBuildMnuCompleteItems(_tmpMenu : MenuItem) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2011	cnwrd1	Initial creation

*/

vars
	theBR 	: CM_BulkRelease;
	aTI		: CM_TrackedItem;
	mnuMaster,
	mnuChild		: MenuItem;
	mnuIndex		: Integer;
begin
		
	mnuMaster := _tmpMenu;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	self.mnuCompleteItemSub.visible := true;


	
	if not self.currentObjectIsPacking() then
		mnuMaster.visible := false;
		return;
	endif;
	
	if not self.myTerminal.getConfig(PackingRelAsInternalRel).Boolean then
		mnuMaster.visible := false;
		return;
	endif;
	
	// need the bulk release and figure out if we have any cargo to 'release'.
	theBR := self.getCurrentBulkRelease();
	
	if theBR = null then
		mnuMaster.visible := false;
		return;
	endif;

	if theBR.allTrackedItemsAssigned.isEmpty then
		mnuMaster.visible := false;
		return;
	endif;
	
	// 	Build up menu of available TIs

	foreach aTI in theBR.allTrackedItemsAssigned do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
		endif;
		mnuChild.caption := aTI.id;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := aTI.id;
		mnuChild.userObject := aTI;
	endforeach;

	//  Hide remaining old sub menu items
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tmpMenu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="4b0dc638-f49a-46ec-99ab-1c67a8b716e1">
        <source>doCargoEnquiry();
//----------------------------------------------------------------
//	Created:	04 November 2005	by Jason Chapman  (cnwjc2)
// 10/10/2016 cnwrh7	TFS	2804
//----------------------------------------------------------------
vars
	obj		: Object;
	masterTI	: CM_TrackedItem;
	tiArray		: CM_TIArray;
	br			: CM_BulkRelease;
	rs			: CM_ReserveSelection;
	rti			: CM_ReserveTI;
	theTIs		: CM_TIByIdDict;
	set			: CM_TISet;
	ti			: CM_TrackedItem;
begin
	
	obj := self.myCurrentObject;
	
	if obj = null then
		return;
	endif;
	
	create theTIs transient;
	
	if CM_BulkRelease.hasInstance(obj) then
		br := obj.CM_BulkRelease;
		//br.allTrackedItemsAssigned.copy(theTIs);													//-TFS2804
		br.allTrackedItemsAssigned.copyNoDuplicates(theTIs, false);				//+TFS2804
		foreach ti in br.allTrackedItemsReleased do
			if not theTIs.includesKey(ti.id) then
				theTIs.add(ti);
			endif;
		endforeach;
	elseif CM_ReserveSelection.hasInstance(obj) then
		rs := obj.CM_ReserveSelection;
		rs.allTrackedItems.copy(theTIs);
		br := rs.myReserveHeader;
		if br &lt;&gt; null then
			foreach ti in br.allTrackedItemsAssigned do
				if not theTIs.includesKey(ti.id) then
					theTIs.add(ti);
				endif;
			endforeach;
			foreach ti in br.allTrackedItemsReleased do
				if not theTIs.includesKey(ti.id) then
					theTIs.add(ti);
				endif;
			endforeach;
		endif;
	elseif CM_ReserveTI.hasInstance(obj) then
		rti := obj.CM_ReserveTI;
		rti.allTrackedItems.copy(theTIs);
	endif;
	
	if theTIs.isEmpty then
		return;
	endif;
	
	create tiArray transient;
	
	theTIs.copy(tiArray);
	
	masterTI := tiArray.first;
	
	self.myAssistant.showCargoEnquiryForTIs(masterTI,
											tiArray,
											self.myMasterMenuAction,
											false);
	
epilog
	delete theTIs;
	delete tiArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="223b397c-e131-4f38-bd49-5004cec3eb16">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 28/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - remove redundant code (never used)
vars
	obj	: Object;
begin
// cnwdad1 16/09/2008 - PAR #17942.
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	obj	:=	menuItem.userObject;
	
	if obj = null then
		return;
	endif;
	
	if obj.isKindOf(CM_RailJSInOutRake)  then
		self.myAssistant.GTE_Assistant.doMnuAssignOutwardRailClick(obj.CM_RailJSInOutRake, self.tblData.allSelectedObjects, self);
	
	elseif obj.isKindOf(CM_Train.class) then
		self.myAssistant.GTE_Assistant.doMnuAssignOutwardRailClick(null, self.tblData.allSelectedObjects, self);
	
	elseif obj.isKindOf(CM_TrackedItem) then
		self.doMnuCompleteItem(menuItem);
	endif;
	
	inheritMethod(menuItem);
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbViewBuild" id="18df76d7-6235-4b05-8327-8310dacc5f51">
        <updating/>
        <source>doCmbViewBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release types no longer translatable, replaced by string constants
vars

begin
	self.cmbView.sorted := false;
	
	self.cmbView.addItem(BR_ACTIVE_STRING);
	self.cmbView.addItem(BR_PENDING_STRING);
	self.cmbView.addItem(BR_COMPLETE_STRING);
	self.cmbView.addItem(BR_ARCHIVE_STRING);
	self.cmbView.addItem(BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING);
	self.cmbView.addItem(BR_TYPE_ALL_STR);							// PAR #27972
	
	self.cmbView.text 	:= BR_ACTIVE_STRING;
	self.viewStatusMode := BR_ACTIVE_STRING;

end;</source>
    </JadeMethod>
    <JadeMethod name="doContextForTestAutoPlan" id="5ea62421-8a24-4cf0-9815-df39dfa591bb">
        <updating/>
        <source>doContextForTestAutoPlan() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	menu : MenuItem;
	mnuChild : MenuItem;
	idx : Integer;
	obj : Object;
	bulkRelease : CM_BulkRelease;
	detail : CM_ReserveDetail;
	reserveSelection : CM_ReserveSelection;
	reserveSet : CM_ReserveDetailSet;

begin
	
	create reserveSet transient;

	obj := self.myCurrentObject;
	if CM_BulkRelease.hasInstance(obj) then
		bulkRelease := obj.CM_BulkRelease;
		foreach detail in bulkRelease.allReserveDetails do
			if reserveSet.size &gt;= 20 then	//27 Feb 2019	NDL found in testing - Blowing some clone control limit.
				break;
			endif;
			if CM_ReserveSelection.hasInstance(detail) then
				reserveSelection := detail.CM_ReserveSelection;
				reserveSet.add( reserveSelection );
			endif;
		endforeach;
		//18 Dec 2015	NDL	Par 37288
		foreach detail in bulkRelease.allReservePackingChildren do
			if reserveSet.size &gt;= 20 then	//27 Feb 2019	NDL found in testing - Blowing some clone control limit.
				break;
			endif;
			if CM_ReserveSelection.hasInstance(detail) then
				reserveSelection := detail.CM_ReserveSelection;
				reserveSet.add( reserveSelection );
			endif;
		endforeach;
	elseif CM_ReserveSelection.hasInstance(obj) then
		reserveSet.add( obj.CM_ReserveSelection );
	endif;
	
	if reserveSet.isEmpty then
		return;
	endif;

	
	if reserveSet.size &gt; 0 then
	
		self.mnuTestAutoPlan.visible := true;	
		menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuTestAutoPlan, false);
		
		foreach idx in 1 to 20 do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				break;
			endif;
			mnuChild.caption := null;
			mnuChild.userObject := null;
			mnuChild.visible := false;
		endforeach;
		
		idx := 0;
		foreach detail in reserveSet do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				mnuChild := menu.loadSubMenu(idx);
			endif;
			mnuChild.caption := detail.getDescription() &amp; "...";
			mnuChild.userObject := detail;
			mnuChild.visible := true;
			mnuChild.setEventMapping("click", "mnuTestAutoPlan_click" );
		endforeach;
		
		self.mnuFindMatching.visible := true;
		menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuFindMatching, false);
		
		foreach idx in 20 to 40 do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				break;
			endif;
			mnuChild.caption := null;
			mnuChild.userObject := null;
			mnuChild.visible := false;
		endforeach;
		
		idx := 20;
		foreach detail in reserveSet do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				mnuChild := menu.loadSubMenu(idx);
			endif;
			mnuChild.caption := detail.getDescription() &amp; "...";
			mnuChild.userObject := detail;
			mnuChild.visible := true;
			mnuChild.setEventMapping("click", "mnuFindMatching_click" );
		endforeach;
		
	else
	
		self.mnuTestAutoPlan.visible := false;	
		menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuTestAutoPlan, false);
	
		foreach idx in 1 to 20 do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				break;
			endif;
			mnuChild.caption := null;
			mnuChild.userObject := null;
			mnuChild.visible := false;
		endforeach;
		
		self.mnuFindMatching.visible := false;	
		menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuFindMatching, false);
	
		foreach idx in 20 to 40 do
			idx := idx + 1;
			mnuChild := menu.getMenuItem(idx);
			if mnuChild = null then
				break;
			endif;
			mnuChild.caption := null;
			mnuChild.userObject := null;
			mnuChild.visible := false;
		endforeach;
	
	endif;

epilog

	delete reserveSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateInternalMove" id="1a4482b2-f345-4c05-9cff-c4ec6f82e270">
        <source>doCreateInternalMove();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwrd1	Initial creation

*/

vars
	menuAction			: CMUI_MenuAction;
	frm				: CM_TableViewForm;
	scm				: Schema;
	assistantClass,
	frmClass		: Class;
	theBR 			: CM_BulkRelease;
	obj				: CM_Object;
	assistant 		: CMUI_Assistant;
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
		//only for 1 release for now
		return;
	endif;

	obj :=  self.tblData.allSelectedObjects.first.CM_Object;
	
	if CM_BulkRelease.hasInstance(obj) then
			theBR := obj.CM_BulkRelease;
	else
		//check reserve detail and use that?
	/*	elseif CM_ReserveDetail.hasInstance(obj) then
			theBR := obj.CM_ReserveDetail.myReserveHeader;*/
		return;
	endif;
	
	scm := rootSchema.getSchema('YardSchema');
	frmClass := scm.getClass('YRD_RequestInternalMoveForm');
	assistantClass := scm.getClass('YRD_Assistant');
	
	create assistant as assistantClass;

	assistant.setMyTerminal(  self.myTerminal );
	assistant.showInternalMoveForm( self, false, 2, 200, theBR);
	/*
	frm := app.loadForm(frmClass, assistantClass, false, false, false, self.myTerminal, null).CM_TableViewForm;
	if frm = null then
		return;
	endif;
	
	frm.showWithObject(theBR, true, false);
	*/
	
				
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="8f57e719-2d5c-4492-bb1c-7679cad4c9ae">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Mar 2023  navma1		Bug 62845: MTN - 1308 when bulk deleting release requests
// ---------------------------------------------------------------------------
vars
	obj 		: Object;
	bulkRelease : CM_BulkRelease;
	theResult   : Integer;	
	invalidObj	: Boolean;
	objArr		: ObjectArray;
	edition		: Integer;
begin
	
   //FD for 1884 : allow multiple delete
    if self.allowMultiSelectDelete = false then
		if CM_BulkRelease.hasInstance(self.myCurrentObject) then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteBulkRelease(self.myCurrentObject.CM_BulkRelease, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Delete Release', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
		
		endif;
		
	else
		on Exception do app.handleDeletedObject( exception, obj, invalidObj );
		
		create objArr transient;									//11.03.2024 navma1 #62845
		self.tblData.allSelectedObjects.tryCopy(objArr);			//11.03.2024 navma1 #62845
		
		foreach obj in objArr do
			
			invalidObj := false;									//11.03.2024 navma1 #62845
			edition	   := obj.edition;								//11.03.2024 navma1 #62845
			
			if invalidObj then										//11.03.2024 navma1 #62845
				continue;
			endif;
			
			if obj.isKindOf(CM_BulkRelease) then
				bulkRelease 		 := obj.CM_BulkRelease;
				self.myCurrentObject := bulkRelease;
			elseif obj.isKindOf(CM_ReserveDetail) then
				bulkRelease 		  := obj.CM_ReserveDetail.myReserveHeader;
				self.myCurrentObject  := bulkRelease;
			else
				continue;
			endif;
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteBulkRelease(bulkRelease, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Delete Release', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
		endforeach;
	endif;

epilog
	delete objArr;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeletePin" id="6d3053aa-6b70-4624-9cd0-804955b2ff07">
        <updating/>
        <source>doDeletePin(_brSet : CM_BulkReleaseSet; _carrierEmail: CM_PINObjectDefaultEmail input)updating;
//----------------------------------------------------------------
//	Created:	07 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if (not self.allowGeneratePin) then
		// User can't have permission to generate pin
		app.msgBox(app.getErrorString1(NoPermission, 'delete a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	if _brSet.isEmpty() then
		app.msgBox('No active road releases are currently selected.', 'Delete Pin Number', MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRemovePinBR(_brSet, _carrierEmail, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Release Request Delete Pin', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
				
end;</source>
        <Parameter name="_brSet" type="CM_BulkReleaseSet"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEditBooking" id="c0cc3625-8c5a-4e7d-b48b-3ea69f56f8d5">
        <source>doEditBooking();
/*
Date		Who		Reason
11 October 2010	cnwrd1	Initial creation

*/

vars

	menuAction			: CMUI_MenuAction;
	frm				: CM_TableViewForm;
	scm				: Schema;
	assistantClass,
	frmClass		: Class;
	theBR 			: CM_BulkRelease;
	obj				: CM_Object;
	assistant 		: CMUI_Assistant;
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
		//only for 1 release for now
		return;
	endif;

	obj :=  self.tblData.allSelectedObjects.first.CM_Object;
	
	//navra1 - MTN-35875- 5th Sep 2025-3 - start
	if obj &lt;&gt; null and obj.CM_BulkRelease &lt;&gt; null and obj.CM_BulkRelease.remarksAdditional1.startsWith("YARA") = true and not app.myCurrentUserCan(self.myTerminal, PmAdmEditAGGatewayRRMaint) then
		app.msgBox(app.getErrorString(Cannot_edit_AG_Gateway_RR), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-3 - end
	
	if CM_BulkRelease.hasInstance(obj) then
			theBR := obj.CM_BulkRelease;
	elseif CM_ReserveDetail.hasInstance(obj) then
		theBR := obj.CM_ReserveDetail.myReserveHeader;
	endif;

	if theBR.myBookingRefStock = null then
		return;
	endif;
	
	//we have a booking so edit it
	self.myAssistant.GTE_Assistant.doAddEditBookRequest(theBR.CM_BulkRelease.myBookingRefStock);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="9784f43f-6cb8-41e0-bcb1-12b6db310c60">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Sep 2023	navlw1	CR 60415: MTN - Add Text Filter to Release Request Enquiry Screen
19 Sep 2023 navnk30 Defect 60529: MTN - Rows found is showing the wrong value on the Release Request form

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	visibleRows,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	methodStartTime	: TimeStamp;
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper();
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*//25/06/2024	navkc1 CR 64823 Task 64824
	start := self.tblData.fixedRows + 1;
	visibleRows := 0;												//19.09.2023 navnk30 #60529

	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx);
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				visibleRows := visibleRows + 1;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
	*/
	//25/06/2024	navkc1 Delete old table filter control
	if self.frmTableFilter &lt;&gt; null then
		visibleRows := self.frmTableFilter.numOfRowVisible;
	endif;
	self.tblData.topRow := 1;
	self.staMain.caption := visibleRows.String &amp; " rows found.";	//19.09.2023 navnk30 #60529
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doGeneratePin" id="ff184cf3-611a-42e0-8a0a-22debfea1edc">
        <updating/>
        <source>doGeneratePin(_brSet : CM_BulkReleaseSet; _carrierEmail: CM_PINObjectDefaultEmail)updating;
//--------------------------------------------------
// Created:	06 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	result	: Integer;
	
begin
	if (not self.allowGeneratePin) then
		// User can't have permission to generate pin
		app.msgBox(app.getErrorString1(NoPermission, 'generate a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	if _brSet.isEmpty() then
		app.msgBox(app.getErrorString(Gte_Select_Active_Road), app.getErrorString(Gte_ReGenerate_Pin_No), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;
	endif;

	while true do			
	
		app.myTrxUA.trxUpdateGeneratePinBR(_brSet, _carrierEmail, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
		else
			result := app.showErrorWarningDialog('Release Request Generate Pin', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
		
	endwhile;

end;</source>
        <Parameter name="_brSet" type="CM_BulkReleaseSet"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="doInstructions" id="19b84501-c339-45a7-aeef-4cfb3a6903de">
        <source>doInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	obj : ObjectArray;
begin
	obj := self.tblData.allSelectedObjects;
	if obj.size = 1 then
		self.btnInstruction.enabled := true;
	else	
		self.btnInstruction.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuBlockEDI" id="1d560146-17a5-4214-9fc8-bc8e07cf9509">
        <updating/>
        <source>doMnuBlockEDI()updating,protected;
/*
Date		Who		Reason
23/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	coll		: CM_BulkReleaseSet;
	saveValue	: Boolean;
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for bulk type update');
		return;
	endif;
	
	// The form does not currently allow multi-edit but save
	// value and reset later in case ever changed
	saveValue					:= self.allowMultiSelectEdit;
	self.allowMultiSelectEdit	:= true;
	
	self.setDoingMultiEdit();
	
	create coll transient;
	self.tblData.allSelectedObjects.copy( coll );
	
	self.createMyAssistant( GTE_Assistant );		// just in case?
	
	if self.myAssistant.GTE_Assistant.showEditReleaseReqBlockEDI( coll ) then
		self.setIgnoreFilterType (true);
	endif;
	
epilog
	self.allowMultiSelectEdit := saveValue;
	
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuCompleteItem" id="fd6d6e9a-8709-4180-8e20-c8723608168a">
        <updating/>
        <source>doMnuCompleteItem(_tmpMenu : MenuItem) updating, protected;

/*

Purpose:			
	// we have an assigned ti on a packing/internal release with the term config option PackingRelAsInternalRel set
	// we need to shift this to the released collection - this is a 'fix up' process
	// normaly we would do this as part of an internal move
Parameters:			

Return Value:		


Date		Who		Reason
18 July 2011	cnwrd1	Initial creation

*/

vars
	theTI : CM_TrackedItem;
	obj : Object;
	theBR : CM_BulkRelease;
	result		: Integer;
	aTISet		: CM_TISet;
begin

	obj := _tmpMenu.userObject;
	
	if CM_TrackedItem.hasInstance(obj) then
		theTI := obj.CM_TrackedItem;
	else
		return;
	endif;
	

	theBR := self.getCurrentBulkRelease();
	

	create aTISet transient;


	aTISet.add(theTI);
	
	while true do
		app.myTrxUA.trxUpdateBulkReleaseCompleteTI(	aTISet, theBR, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return ;
		else
			result :=  1;//'error';//app.showErrorWarningDialog('Create Pack docket', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return ;
	endwhile;
epilog
	delete aTISet;
end;</source>
        <access>protected</access>
        <Parameter name="_tmpMenu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuFindCargo" id="70f88930-cc04-454f-93ae-52069803398f">
        <source>doMnuFindCargo( _reserve : CM_ReserveSelection );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	transUserQuery : CM_MenuUserQuery;
	transCriteriaLineHolder : CM_QueryCriteriaLineHolder;

	selectorForm : CMUI_Selector;
	
	msg : String;

begin

	if _reserve = null then
		return;
	endif;

	// Build a selector query that will match cargo to the request details.
	// set up the base query details
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	
	msg := _reserve.buildQueryToMatchDetails( transUserQuery, transCriteriaLineHolder );

	// get the selector form
	selectorForm	:=	app.getSelectorForm(self, self.myMasterMenuAction);	
	if selectorForm = null then
		return;
	endif;
	
	//show the query details...
	selectorForm.show();
	selectorForm.showQuery(transUserQuery);
	
	if msg &lt;&gt; null then
		msg := app.getErrorString(Unable_convert_criteria) &amp; CrLf &amp; msg;
		app.msgBox(msg,app.getErrorString(Warning),MsgBox_OK_Only);
	endif;
	
epilog

	delete transUserQuery;

end;</source>
        <Parameter name="_reserve" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="doMnuTestAutoPlan" id="b80ad04c-1697-4a2d-a7d1-655b2286d2f0">
        <source>doMnuTestAutoPlan( _reserve : CM_ReserveSelection );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

