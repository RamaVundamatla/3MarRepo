<PrimType name="Boolean">
    <JadeMethod name="asRunningStopped" id="b342afa1-a4ff-4449-b6e7-26ff3632f82d">
        <source>asRunningStopped(_isSetup : Boolean) : String;

// cnwdvb1 29 October 2002 

vars

begin

	if self then
		return "Running";
	endif;
	
	if _isSetup then
		return "Stopped";
	else
		return "Controller not set up";
	endif;

end;</source>
        <Parameter name="_isSetup" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
