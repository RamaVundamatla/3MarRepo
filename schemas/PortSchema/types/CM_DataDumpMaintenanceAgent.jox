12 July 2023	navmv20	CR 58420 Task 58421: Jade - Data Extra JRW Views
*/

vars
	xdbFeature : CMIF_ExternalDBFeature;
begin
	//all super class attributes	CM_ReserveDetail
	create xdbFeature transient;
