        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="jobTitle" id="983d5031-7842-41d7-bc28-d06a46253543">
        <length>41</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myVoyageJob" id="fca969ad-6426-489e-a64b-d493bf8ca6bd">
