<GUIClass name="CMUI_DeckingRoRoRulesForm" id="ce033e3a-317c-44e2-9931-ad335b65c598">
    <superclass name="CMUI_DeckingRulesForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="drawArea" id="980a224b-a275-406f-8763-5790aa95eca2">
        <source>drawArea(_direction, _rows, _stacks, _tiers: Integer; _rowsLabel, _stacksLabel: String);
//12 December 2008	cnwdw1	
//
vars
	frame: CMUI_Frame;
	top, left, bottom, right: Integer;
	row, stack, tier: Integer;
	rowOffset: Integer;
	labelOffsetX, labelOffsetY: Integer;
	cellWidth, cellHeight: Integer;
	rect: Rectangle;

	stackNumber : Integer;
	number, startNumber : Integer;
begin
	frame := self.frmOrderGraphic;
	frame.autoRedraw := true;
	frame.clearGraphics;
	frame.drawStyle := Frame.DrawStyle_Solid;
	frame.drawWidth := 1;
	frame.drawFillColor := LightGray;
	locations.purge;
	
	rowOffset := 80;
	cellWidth := 30;
	cellHeight := 23;
	labelOffsetX := 60;
	labelOffsetY := 7;
	stackNumber := 0;
	foreach stack in 1 to _stacks do
		if stackNumber = 0 then
			stackNumber := _stacks;
		else
			stackNumber := stackNumber - 1;
		endif;
		
		if stack = 1 then
			top := 45;
		elseif stack = 2 then
			top := 100;
		elseif stack = 3 then
			top := 160;
		endif;
		
		//top := stackNumber * 55;	
		left := rowOffset;
		bottom := top + (cellHeight * _tiers);
		right := left + (cellWidth * _rows);
				
		frame.drawFilledRectangle(left, top, right, bottom, Black);
		foreach tier in 1 to _tiers do
			frame.drawTextAlign := DrawTextAlign_Left;
			frame.drawTextAt("Lane "&amp; stackNumber.asStringJMT(), left-labelOffsetX, top+((tier-1)*cellHeight)+labelOffsetY, Black);
			
			foreach row in 1 to _rows do
				create rect transient;
				rect.left := left+((row-1)*cellWidth) + 1;
				rect.top := top+((_tiers-tier)*cellHeight) + 1;
				rect.right := rect.left + cellWidth - 1;
				rect.bottom := rect.top + cellHeight - 1;
				locations[row, stack, tier] := rect;
			endforeach;
		endforeach;
		foreach row in 1 to _rows do
			if row &lt; _rows then
				frame.drawLine(left+(row*cellWidth), top, left+(row*cellWidth), bottom, Black);
			endif;	
			frame.drawTextAlign := DrawTextAlign_Center;
			frame.drawTextAt("P"&amp;row.String, left+((row-1)*cellWidth)+(cellWidth/2), bottom+1, Black);
		endforeach;
	endforeach;
	
	if self.optByStackIn.value and self.optRowIncreasIn.value then		//By Lane, Increasing
		foreach stack in 1 to _stacks do
			startNumber := 0;
			number := 0;
			foreach row in 1 to _rows do				
				foreach tier in 1 to _tiers do
					if stack = 3 then
						if startNumber = 0 then
							startNumber := 1;
							number := startNumber;
						else
							number := number + 1;
						endif;
					elseif stack = 2 then
						if startNumber = 0 then
							startNumber := 6;
							number := startNumber;
						else
							number := number + 1;
						endif;
					elseif stack = 1 then
						if startNumber = 0 then
							startNumber := 11;
							number := startNumber;
						else
							number := number + 1;
						endif;
					endif;
					self.drawOrderNumber(row,stack,tier,number.String);
				endforeach;
			endforeach;
		endforeach;
	elseif self.optByStackIn.value and not self.optRowIncreasIn.value then		//By Lane, Decreasing
		foreach stack in 1 to _stacks do
			startNumber := 0;
			number := 0;
			foreach row in 1 to _rows do				
				foreach tier in 1 to _tiers do
					if stack = 1 then
						if startNumber = 0 then
							startNumber := 1;
							number := startNumber;
						else
							number := number + 1;
						endif;
					elseif stack = 2 then
						if startNumber = 0 then
							startNumber := 6;
							number := startNumber;
						else
							number := number + 1;
						endif;
					elseif stack = 3 then
						if startNumber = 0 then
							startNumber := 11;
							number := startNumber;
						else
							number := number + 1;
						endif;
					endif;
					self.drawOrderNumber(row,stack,tier,number.String);
				endforeach;
			endforeach;
		endforeach;
	elseif not self.optByStackIn.value and self.optRowIncreasIn.value then		//By Position, Increasing
			foreach stack in 1 to _stacks do
			startNumber := 0;
			number := 0;
			tier := 1;
			foreach row in 1 to _rows do				
					if stack = 1 then
						if startNumber = 0 then
							startNumber := 3;
							number := startNumber;
						else
							number := number + 3;
						endif;
					elseif stack = 2 then
						if startNumber = 0 then
							startNumber := 2;
							number := startNumber;
						else
							number := number + 3;
						endif;
					elseif stack = 3 then
						if startNumber = 0 then
							startNumber := 1;
							number := startNumber;
						else
							number := number + 3;
						endif;
					endif;
					self.drawOrderNumber(row,stack,tier,number.String);
			endforeach;
		endforeach;
	elseif not self.optByStackIn.value and not self.optRowIncreasIn.value then				//By Position, Decreasing
			foreach stack in 1 to _stacks do
			startNumber := 0;
			number := 0;
			tier := 1;
			foreach row in 1 to _rows do				
					if stack = 1 then
						if startNumber = 0 then
							startNumber := 1;
							number := startNumber;
						else
							number := number + 3;
						endif;
					elseif stack = 2 then
						if startNumber = 0 then
							startNumber := 2;
							number := startNumber;
						else
							number := number + 3;
						endif;
					elseif stack = 3 then
						if startNumber = 0 then
							startNumber := 3;
							number := startNumber;
						else
							number := number + 3;
						endif;
					endif;
					self.drawOrderNumber(row,stack,tier,number.String);
			endforeach;
		endforeach;

	endif;
epilog
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <Parameter name="_rowsLabel" type="String"/>
        <Parameter name="_stacksLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAreaRule" id="338ba2e4-b33b-4519-b9ca-33450797cd56">
        <source>getAreaRule(_direction: Integer): Integer;
//08 February 2010	cnwml2


vars

begin
	if _direction = DeckingDirectionIn then
		if self.optByStackIn.value then			//by Lane
			return DeckingRule_ByRow;
		else
			return DeckingRule_ByStack;			//by Position
		endif;
	endif;
	
	
	return inheritMethod(_direction);

epilog

end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
