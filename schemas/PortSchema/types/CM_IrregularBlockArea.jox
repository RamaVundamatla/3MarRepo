    <JadeMethod name="initialiseForDecking" id="f45a7f08-a744-4d95-a82d-7a776eaf4510">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsTA input);
//----------------------------------------------------------------
//	Created:	17 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	index, height	: Integer;
	tmpController, shelf		: CM_LocationsController;
begin

	if self.allLocationsControllers.isEmpty then
		return;
	endif;

	index := 0;
	foreach tmpController in self.allLocationsControllers discreteLock do
	
		if tmpController.isRack then // PAR 34890
			height := tmpController.CM_IrregularBlockController.allSubLocations.size; // PAR 34890
			tmpController.CM_YardController.setupForDeckingInTA(1, height, _pxyDeckingOptions, index); // PAR 34890
		else // PAR 34890
			tmpController.CM_YardController.setupForDeckingInTA(1, 1, _pxyDeckingOptions, index);
		endif;
	endforeach;

	//do default out - reverse of in
	_pxyDeckingOptions.setOutDeckingReverseOfIn();

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsTA" usage="input"/>
    </JadeMethod>
