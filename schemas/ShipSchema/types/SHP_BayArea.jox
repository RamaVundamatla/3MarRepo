    <JadeMethod name="gridXMLpopulate" id="e7d98852-d9e3-4146-a058-285ba5417e9d">
        <updating/>
        <source>gridXMLpopulate(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aRow : CMUI_GridRow;
	aCol : CMUI_GridColumn;
	theXMLTag,gridPointCoOrds : String;
	theTagNum : Integer;
	theRow, theCol : Integer;
	aPoint : CMUI_GridPoint;
begin
	if self.drawMe = false then
		return;
	endif;
	foreach aRow in self.allGridRows do
		aRow.SHP_BayRow.pileWeight := null;
	endforeach;
	foreach aCol in self.allGridColumns do
		aCol.SHP_BayColumn.pileWeight := null;
	endforeach;
	inheritMethod(_theXMLString);

//	if self.viewMode = ShpViewMode_Actual and (not self.generatedACT or (self.workingMode = SHP_VoyageAreaForm.WorkMode_EDI)) then
	if self.displayMode = ShpDisplayMode_GetAll then
		self.generatedACT := true;
		self.generatedLOAD := true;
		self.generatedDISCH := true;
	elseif self.displayMode = ShpDisplayMode_Actual and (not self.generatedACT) then
		self.generatedACT := true;
//	elseif self.displayMode = ShpDisplayMode_EDI and (not self.generatedACT) then
//		self.generatedACT := true;
	elseif self.displayMode = ShpDisplayMode_Proposed and not self.generatedPRO then
		self.generatedPRO := true;
	elseif self.displayMode = ShpDisplayMode_Defn and not self.generatedDEFN then
		self.generatedDEFN := true;
	elseif self.displayMode = ShpDisplayMode_ColCodeLoad and not self.generatedLOAD then
		self.generatedLOAD := true;
	elseif self.displayMode = ShpDisplayMode_ColCodeDisch and not self.generatedDISCH then
		self.generatedDISCH := true;
		self.generatedACT := true;
	endif;

	if self.myGridAreaFrame.backColor = 0 then
		theXMLTag := _theXMLString.cnEcGetTagValueOfName("Col");
		if theXMLTag &lt;&gt; null then
			self.myGridAreaFrame.backColor := theXMLTag.Integer;
		endif;
	endif;

	if self.myBay = null then
		theXMLTag := _theXMLString.cnEcGetTagValueOfName("BY");
		if theXMLTag &lt;&gt; null then
			self.myBay := theXMLTag.asOid.CM_Bay;
		endif;
	endif;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="hasLidRow" id="85e1ccd3-ae2c-43c1-99d1-91bed8356d0f">
        <source>hasLidRow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aRow : CMUI_GridRow;
begin
	foreach aRow in self.allGridRows do
		if aRow.SHP_BayRow.amLidRow then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
