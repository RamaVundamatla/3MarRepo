//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if self.workingMode = WorkMode_Volume
	or self.displayMode = ShpDisplayMode_Actual
	then
		if app.myMoveController &lt;&gt; null then
			self.setFocus();
			self.zOrder(1);
			self.windowState := WindowState_Normal;
		endif;	
	endif;
epilog

end;</source>
