    <JadeMethod name="saveTerminalsTable" id="57aa37b8-9974-419e-a56a-f559bec40ec2">
        <source>saveTerminalsTable(_user : CM_User) protected;

vars
	theForm 	: SOP_TableMaintForm;
	pxyUserTerm	: CM_UserTerminal;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	terminal	: CM_Terminal;
	chkValue,
	roleName	: String;
	secRole		: CM_SecurityRole;
	obj			: Object;
	defCargoType		: CM_CargoType;
	defBOLType			: CM_BOLType;
	defCargoBOLType		: CM_CargoBOLType;
	
begin

	theForm := self.myForm; 

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		chkValue 			:= tmpDataTable.accessCell(idx, 1).text;
		roleName 			:= tmpDataTable.accessCell(idx, 3).text;
		defCargoType		:= tmpDataTable.accessCell(idx, self.Column_CargoType).itemObject.CM_CargoType;
		defBOLType			:= tmpDataTable.accessCell(idx, self.Column_BOLType).itemObject.CM_BOLType;
		defCargoBOLType		:= tmpDataTable.accessCell(idx, self.Column_CargoBOLType).itemObject.CM_CargoBOLType;
		
		obj := tmpDataTable.accessRow(idx).itemObject;
		
		if obj.isKindOf(CM_Terminal) then
			terminal := obj.CM_Terminal;
		else
			continue;
		endif;
		
		pxyUserTerm := _user.getUserTerminal(terminal);

		if chkValue = TableCheckBox_NotSelected then
			if pxyUserTerm &lt;&gt; null then
				pxyUserTerm.erase(NORMAL_ERASE);
			endif;
			continue;
		else
			if pxyUserTerm = null then
				create pxyUserTerm transient;
			endif;
			secRole := app.myRoot.allRoles[roleName];
			pxyUserTerm.setForProxy(terminal, _user, secRole, defCargoType, defBOLType, defCargoBOLType);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="cd860f3f-e283-4ac8-afb1-bc54c475f25e">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 05/08/2021	navmd1		TFS 51226 Allow users with permission to force off old sessions
vars
	theForm		: SOP_TableMaintForm;
	tblInput	: CM_EntryTable;
	tblData		: CM_DataTable;
	idx,
	numRows,
	theRow,
	fixedRows	: Integer;
	_warn		: Boolean;
begin
  
    theForm := self.myForm;
    tblInput := theForm.tblInput1;
    tblData	 := theForm.tblData1;

	tblInput.userInputEnabled := true;
	tblData.userInputEnabled := true;
	theForm.cmbCargoBOLType.enabled := true;
	theForm.cmbSecurityRole.enabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		tblInput.clearValues;
		tblInput.setValueByName(ETRow_Status, NewUserDescr);
		
		tblInput.setValueByName(ETRow_AllowAutomaticDisability, true);	// cnwvu1	20/11/2006	ccms1051
		
		tblInput.setValueByName(ETRow_SingleSignOnOnly, false);  //+ cnwmd1 Par 22287
		tblInput.setValueByName(ETRow_SingleSignOnOverride, false);		// TFS 51226
		self.setSsoLinkedIdentifier(null); //20.07.2022 navam1 #52824
		
		numRows := tblData.rows;
		fixedRows := tblData.fixedRows; 
		//Clear rows starting one after the number of fixed rows. 
		foreach idx in fixedRows + 1 to numRows do
			tblData.accessCell(idx, 1).text := TableCheckBox_NotSelected;
			tblData.accessCell(idx, 3).text := null;
		endforeach;
		
		theForm.cmbSecurityRole.text := null;
		theForm.cmbSecurityRole.listObject := null;
		theForm.cmbCargoBOLType.text := null;
		theForm.cmbCargoBOLType.listObject := null;
		
//		tblInput.enableRowByName(ETRow_IsExternal);
		tblInput.enableRowByName(ETRow_Code);
		//When we are adding, blow away the reference to the object in the myObject reference
		//of the comboBox control otherwise we'll get that object for all subsequent new profiles while the form is open 
		//(or until the comboBox is accessed).  
		theForm.cmbOrganisation.setObject(null);
		theForm.cmbLocale.setObject(null);
		theForm.cmbDACarrier.setObject(null);
		theForm.cmbDAConsignee.setObject(null);
		theForm.cmbDAOperator.setObject(null);
		theForm.cmbDAOrg.setObject(null);
		theForm.cmbDAAgent.setObject(null);
		theForm.cmbDAStevedore.setObject(null);						// TFS 44554
		
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		
	else
		//	theRow := tblInput.getRowByName(ETRow_IsExternal);
		//	tblInput.accessRow(theRow).inputType := Table.InputType_None;
		tblInput.disableRowByName(ETRow_IsExternal);
		tblInput.disableRowByName(ETRow_Code);
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_User.allSystemAlertTypes);
		theForm.mulSelect2.setSelected(theForm.myProxyObject.CM_User.allEventTypes);
		theForm.mulSelect3.setSelected(theForm.myProxyObject.CM_User.allEmailsICanSee);
		tblInput.setValueByName(ETRow_AllowAutomaticDisability, theForm.myProxyObject.CM_User.allowAutomaticDisability);	// cnwvu1	20/11/2006	ccms1051
		tblInput.setValueByName(ETRow_SingleSignOnOnly, theForm.myProxyObject.CM_User.getUserSingleSignOnOnly);  //+ cnwmd1 Par 22287
		tblInput.setValueByName(ETRow_SingleSignOnOverride, theForm.myProxyObject.CM_User.getUserSingleSignAllowOverride);	// TFS 51226
		//20.07.2022 navam1 #52824
		tblInput.setValueByName(ETRow_SsoMatchingId, theForm.myProxyObject.CM_User.ssoMatchingId);
		self.setSsoLinkedIdentifier(theForm.myProxyObject.CM_User.ssoUniqueId);
	endif;

	if app.myPassport.myUser.mySystemSecurityRole = app.myRoot.mySecurityRoleSystem
	or app.myPassport.myUser.mySystemSecurityRole.allChildMaintenanceRoles.includes( app.myRoot.mySecurityRoleSystem )	//14 Feb 2018	NDL	TFS 36947
	then
		tblInput.enableRowByName(ETRow_DataAccessCarrier);
		tblInput.enableRowByName(ETRow_DataAccessConsignee);
		tblInput.enableRowByName(ETRow_DataAccessOperator);
		tblInput.enableRowByName(ETRow_DataAccessOrganisation);
		tblInput.enableRowByName(ETRow_DataAccessCustomsAgent);
		tblInput.enableRowByName(ETRow_DataAccessStevedore);		// TFS 44554
//		tblInput.showRowByName(ETRow_AllowAutomaticDisability, _warn);	// cnwvu1	20/11/2006	ccms1051
	else
		// this user does not have permission to do data access restrictions
		if theForm.mode = theForm.Mode_Add then
			// set to what they are for current user
			self.showDataAccessDetails(app.myPassport.myUser);
		endif;

		tblInput.disableRowByName(ETRow_DataAccessCarrier);
		tblInput.disableRowByName(ETRow_DataAccessConsignee);
		tblInput.disableRowByName(ETRow_DataAccessOperator);
		tblInput.disableRowByName(ETRow_DataAccessOrganisation);
		tblInput.disableRowByName(ETRow_DataAccessCustomsAgent);
		tblInput.disableRowByName(ETRow_DataAccessStevedore);		// TFS 44554
//		tblInput.hideRowByName(ETRow_AllowAutomaticDisability, _warn);	// cnwvu1	20/11/2006	ccms1051

	endif;

	self.enableMulSelect1Contents();
	self.enableMulSelect2Contents();

	if theForm.mode = theForm.Mode_Add then
		tblInput.moveFirst();
		tblInput.setFocus;
	else
		if theForm.fldInput.topSheet = theForm.shtTblInput1 then
			tblInput.moveFirst();
			tblInput.setFocus;
			theForm.tblInput1.gotFocus(theForm.tblInput1);
		elseif theForm.fldInput.topSheet = theForm.shtDataTable1 then
			tblData.setFocus;
		endif;
	endif;

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="1135cf69-5e2b-4e18-86b3-96ecc6530c0f">
