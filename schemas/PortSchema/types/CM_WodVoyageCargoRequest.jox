    <JadeMethod name="validateWorkPoints" id="08f9f560-0b9a-4a02-aa1d-ed78fdf03545">
        <source>validateWorkPoints( _msg : String output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlgndl1	Initial creation	TFS 41980
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars

	cargoDetail : CM_WodCargoRequest;

begin

	foreach cargoDetail in self.allCargoDetails do
		if cargoDetail.getMyWorkPoint = null then
			_msg := app.getErrorString( Cargo_reque_requi_wp );
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_msg" type="String" usage="output"/>
    </JadeMethod>
</Class>
