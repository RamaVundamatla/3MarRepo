end;</source>
    </JadeMethod>
    <JadeMethod name="getControlType" id="f9f5217a-c1f3-41bd-b142-78fb0a1725b8">
        <source>getControlType() :Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2019	jlger1	Initial creation TFS 47132

*/

vars

begin
	if self.myQueryOperator = null or self.myQueryProperty = null then
		return null;
	endif;
	
   	return  self.myQueryProperty.getControlTypeForOperator(self.myQueryOperator);
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionString" id="72ce5118-a9b1-48cd-9d6f-9099c9cbedb0">
        <source>getDescriptionString() : String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	unavailableAsterisk,
	str					: String;
	
begin
	if self.isUnavailableAtRunTime then
		unavailableAsterisk := '*';
	endif;
	
	str := unavailableAsterisk &amp; 
			self.myQueryProperty.niceName &amp; ' ' &amp;
		   	self.myQueryOperator.description &amp; ' ' &amp;
		   	self.myQueryOperator.getSearchValueStr(self.myQueryProperty);

	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPerformanceColour" id="d19e9eb2-8a38-4670-a31d-9d377606878b">
        <source>getPerformanceColour() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

begin

	if self.myQueryProperty &lt;&gt; null then
		return self.myQueryProperty.getPerformanceColour();
	endif;
	
	return CM_QueryProperty.NotSetColour;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
