    <JadeMethod name="getDisplayStringForAttribute" id="1e0cb643-94c4-46a0-bd38-789df5210406">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	28 May 2004 By: cnwgd1
//--------------------------------------------------


vars

begin
	if _attrName = ETRow_EndPosition then
		return (self.startPosition + self.length).String;
	elseif _attrName = ETRow_ExternalRef1 then
		return self.externalReference1;
	elseif _attrName = ETRow_ExternalRef2 then
		return self.externalReference2;
	elseif _attrName = ETRow_ExternalRef3 then
		return self.externalReference3;
	elseif _attrName = ETRow_ExternalRef4 then          //02.10.2018 cnwma1 TFS #41234
		return self.externalReference4;
	elseif _attrName = ETRow_RequiresLengthOfTime then	//27 Jul 2018	NDL	TFS 39932
		return self.requiresLengthOfTime.asStringJMT();
	elseif _attrName = ETRow_TugBaseToBase then	//13 Nov 2018	NDL	TFS 41964
		return self.baseToBaseTugDuration.asStringJMT();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFromTimeStamp" id="d164d274-c042-4666-bcca-bdd4da63d140">
        <source>getFromTimeStamp(_move : HMS_VoyageMovement) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theMove : HMS_VoyageMovement;
begin
	
	theMove := _move.getVoyageMovementPrevious(); //&lt;-- GD user this method
	if theMove &lt;&gt; null then
		return theMove.occursOnDTNEW;
	else
		return _move.occursOnDTNEW;
	endif;
		
	/*if _move.moveType = HMSMovementTypeArrival then
		return _move.occursOnDT;
	elseif _move.moveType = HMSMovementTypeShift then
		return _move.occursOnDT;

	elseif _move.moveType = HMSMovementTypeDeparture then
		theMove := _move.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeShift);
		if theMove &lt;&gt; null then
			return theMove.occursOnDT;
		else
			theMove := _move.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
			if theMove &lt;&gt; null then
				return theMove.occursOnDT;
			endif;
		endif;
	endif;*/	
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getHarbour" id="98727be6-b631-46e7-a177-60093296a8b8">
        <source>getHarbour() : HMS_Harbour;
// ---------------------------------------------------------------------------
// Created:     08 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot = null then
		return self.myHarbour;
	endif;
	return app.myRoot.getHarbourForScenario(self.myHarbour);
end;</source>
        <ReturnType type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="getHarbourReal" id="0a896b1a-39ec-4c74-b677-91fffec64874">
        <source>getHarbourReal() : HMS_Harbour;
// ---------------------------------------------------------------------------
// Created:     08 January 2007 by cnwrs2
//
