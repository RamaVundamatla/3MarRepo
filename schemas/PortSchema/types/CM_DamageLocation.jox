/*

Purpose:			TFS 41427

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlgab1	Initial creation

*/

vars

begin
	return self.damagedInLocation;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
