    <JadeMethod name="btnAdd_click" id="e2633c41-e53a-468f-9a66-f2936115a173">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;

vars

begin
	if self.saveData(true) then
		self.myQuantityRangeMap := self.myYardAllocation.CM_InvoiceAllocation.myQuantityMap.allQuantityRanges.first;
		self.populateMappingDetails();
		self.populateTable(false);
	endif;
end;
</source>
