    <JadeMethod name="trxFixupStockOnHandTerminal" id="00e8aee0-1208-4fa6-b2d7-828eb13bdbc2">
        <updating/>
        <source>trxFixupStockOnHandTerminal(_terminal:CM_Terminal input; _comment : String;
					 _cmifMonitor : CMIF_Monitor input;
					 _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	fixupHdr	: CM_SOHFixupHdr;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	app.writeLog('Fixup Stock-On-Hand (' &amp; _terminal.code &amp; '): start', LogINFO);

	beginTransaction;
	create fixupHdr persistent;
	fixupHdr.init(_passport.userCode, _terminal);
	commitTransaction;

	if _passport.noErrors then
		_terminal.fixupStockOnHand(_passport, _comment, fixupHdr, _cmifMonitor, true);
		if _cmifMonitor &lt;&gt; null and _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
			app.writeLog('Fixup Stock-On-Hand (' &amp; _terminal.code &amp; '): user aborted', LogINFO);
			app.raiseCMException(UserAbortedAction, null, null);
		endif;
	endif;
	
	app.writeLog('Fixup Stock-On-Hand (' &amp; _terminal.code &amp; '): complete', LogINFO);
	
	if _passport.noErrors and (not process.isInTransactionState) then
		// done so that finalise will work correctly
		beginTransaction;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
