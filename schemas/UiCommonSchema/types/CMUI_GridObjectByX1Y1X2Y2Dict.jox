    <JadeMethod name="getMaxXY" id="e9117b99-8067-4a86-9770-1a759e9b8ee8">
        <source>getMaxXY(_x, _y : Real io);
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 15274
//
// ---------------------------------------------------------------------------
vars
	aGO : Object;
	iter : Iterator;
	x1,y1,x2,y2 : Real;
begin
	iter := self.myIterator;
	if iter &lt;&gt; null then
			aGO := self.last;
			if aGO = null then // PAR 17067
				return;
			endif;
			iter.startAtObject(aGO);
			self.getIteratorKeys(x1,y1,x2,y2, iter);
			_x := x2;
			_y := y2;
	endif;
end;</source>
        <Parameter name="_x" type="Real" usage="io"/>
        <Parameter name="_y" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMinXY" id="fb6c762e-ca61-4455-9e45-7a2882291347">
        <source>getMinXY(_x, _y : Real io);
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 15274
//
// ---------------------------------------------------------------------------
vars
	aGO : Object;
	iter : Iterator;
	x1,y1,x2,y2 : Real;
begin
	iter := self.myIterator;
	if iter &lt;&gt; null then
			aGO := self.first;
			if aGO = null then // PAR 17067
				return;
			endif;
			iter.startAtObject(aGO);
			self.getIteratorKeys(x1,y1,x2,y2, iter);
			_x := x1;
			_y := y1;
	endif;
end;</source>
        <Parameter name="_x" type="Real" usage="io"/>
        <Parameter name="_y" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXRange" id="cabf1b59-8f2f-4ff5-b7ba-b374969b4d40">
        <source>getXRange( _x : Integer; _x1, _x2 : Integer output);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		if _x &gt;= x1 and  _x &lt;= x2 then
			if not tmpObj.isKindOf(CM_LocationsController) then
				continue;
			endif;

			if x1 &lt;= 0 then
				_x1 := 1;
				_x2 := x2;
			else
				_x1 := x1;
				_x2 := x2;
			endif;
			return;
		endif;
	endwhile;
	if _x &lt;= 0 then
		_x1 := 1;
		_x2 := 1;
	else
		_x1 := _x;
		_x2 := _x;
	endif;
	
	return;
end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getYRange" id="e008370d-de37-4e4d-9905-b7d8a2d190cf">
        <source>getYRange( _y : Integer; _y1, _y2 : Integer output);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return;
	endif;
	
	tmpIterator.reset();

	while tmpIterator.next(tmpObj) do
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		if _y &gt;= y1 and  _y &lt;= y2 then
			if not tmpObj.isKindOf(CM_LocationsController) then
				continue;
			endif;

			if y1 &lt;= 0 then
				_y1 := 1;
				_y2 := y2;
			else
				_y1 := y1;
				_y2 := y2;
			endif;
			return;
		endif;
	endwhile;

	if _y &lt;= 0 then
		_y1 := 1;
		_y2 := 1;
	else
		_y1 := _y;
		_y2 := _y;
	endif;
	return;
end;</source>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="includeThisObject" id="da29fad0-e605-4b7f-acac-b0c9f3ff576e">
        <source>includeThisObject(_obj : Object; _includeAllGC : Boolean; _class : Class; _doingLocations : Boolean; _includeTouched : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/05/2023	navdap1		Initial creation TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues
//
vars

begin
	if not _includeAllGC then
		return true;
	endif;
	
	if _obj.isKindOf(_class) then
		if _includeAllGC and _obj.isKindOf(CM_LocationsController) 
		and _obj.CM_LocationsController.myTerminalArea &lt;&gt; null 
		and _obj.CM_LocationsController.myTerminalArea.isKindOf(CM_IrregularBlockArea) then
			if _includeTouched then
				return true;
			endif;
			return _doingLocations;
		endif;
		return true;
	endif;
	
	if _obj.isKindOf(CM_IrregularBlockArea) and _includeAllGC then
		return not _doingLocations;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_includeAllGC" type="Boolean"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_doingLocations" type="Boolean"/>
        <Parameter name="_includeTouched" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObjectFromDict" id="131530d9-7eef-421e-9c3c-26eb465cbef8">
        <lockReceiver/>
        <updating/>
        <source>removeObjectFromDict(_obj : Object) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		self.removeKeyEntry(x1, y1, x2, y2, tmpObj);
		return true;
	endwhile;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObjectsInDict" id="0df84c76-427b-4bb5-b756-9eb7d83e27cc">
        <lockReceiver/>
        <updating/>
        <source>removeObjectsInDict( _x1, _y1, _x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2 : Integer;
	tmpObj		: Object;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
	endif;


	self.startKeyGeq(_x1, 0, 0, 0, tmpIterator);
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
		
		if x1 &gt; _x2 then
			break;
		endif;
		if _x1 &lt;= x1 and
//		   _x2 &gt;= x2 and // PAR 17839 generally this is where we need to get rid of all the XYs for containers that are within an LC. This changes says that if the container starts within the rectangle of the LC then get rid of it
		   _x2 &gt; x1 and // &lt;&lt;&lt;&lt; this is what is different
		   _y1 &lt;= y1 and
		   _y2 &gt;= y2 then
			self.removeKeyEntry(x1, y1, x2, y2, tmpObj);
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
</CollClass>
