    <JadeMethod name="revealAllFinancialTypes" id="c91b002d-b2f5-456b-a7ee-983caef7b2b3">
        <source>revealAllFinancialTypes();
/*
Purpose:			 // PAR 36631 TFS 678
Date		Who		Reason
03 August 2015	cnwab1	Initial creation
*/

vars
	ioClass:   CM_ExtFinanceIO;
	default : CM_ExtFinanceIO;
	clsCol : ClassNDict; 
	cls : Class;
	str : String;
begin
	app.writeLog(method.qualifiedName &amp; " Reveal all external financial types ", LogINFO);
	
	create clsCol transient;
	cls := currentSchema.getClass(CM_ExtFinanceIO.name);
	cls.getAllSubclassesAnywhere(clsCol); 

	foreach cls in clsCol do
		if not cls.abstract then
			if cls.name = "Nimbus" then // AKB2014JAN Unit Testing this was intended for Port Nelson but they did not go a head
				continue;
			endif;
			if cls.name = "Decfin" then // PAR 35572 this is Port Otago's old system no longer used
				continue;
			endif;
			if cls.name = "Maximise" then // PAR 35572 this is Centreport's old system no longer used
				continue;
			endif;
			if cls.name = "CODA" then // PAR 35572 this is Centreport's old system no longer used
				continue;
			endif;
			
			if cls.instances.size = 0 then
				ioClass := app.myTrxCA.trxCreateExternalFinanceClass(cls);
				if ioClass &lt;&gt; null then
					app.writeLog(method.qualifiedName &amp; " Reveal - " &amp; ioClass.getNiceName(), LogINFO);
				endif;
			endif;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnhancedForms" id="5157f2eb-dc73-43bd-8c00-dc74fb6f38fd">
        <source>setEnhancedForms();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation	PAR #30949

*/

vars
	root : CM_Root;
	term : CM_Terminal;
	
begin
	root := CM_Root.firstInstance();
	
	if root.isDeprecated("8.1.2") then
		beginTransaction;
		foreach term in root.allTerminals do
			term.setConfig(UseBookingSummView, true);
		endforeach;
		commitTransaction;
	endif;
epilog
	
end;</source>
    </JadeMethod>
