        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEmailRetry"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="835f4b1f-6cce-44d9-8a32-ec92ed98d32f">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 January 2023	navmd1	Initial creation TFS 55020 OAuth Email Enhancements

*/

vars

begin
	if _rowName = ETRow_NumberOfRetries then
		self.numMaxRetries := _value.Integer;
	endif;

	inheritMethod(_rowName, _value);

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="96ac5143-3e9a-4572-8c08-bcfea9cd2b09">
        <source>validate();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 January 2023	navmd1	Initial creation TFS 55020 OAuth Email Enhancements

*/

vars
	rowText : String;
begin
	inheritMethod();
	
	if self.numMaxRetries &lt;= 0 then
		rowText := app.getEntTableRowTranslation(ETRow_NumberOfRetries, ETGrp_BGPBackground);
		app.raiseCMException1(Must_greater_than_zero, rowText, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
