    <JadeMethod name="hasEntTableSpecialConditions" id="a23e8fc9-b62e-4ddf-a08a-588af9de1db7">
        <source>hasEntTableSpecialConditions(	_entRow : EntTableRow;
								_alteredHeaderName : String output;
								_hideRow : Boolean output;
								_measureType : CM_MeasurementType output
								): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

	attrName : String;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	returnValue : Boolean;
	
begin

	if self.isEntTableSpecialProductAttr( _entRow.name ) then

		prod := self.mySystemProductType;
		
		if prod = null then
			return inheritMethod(_entRow, _alteredHeaderName, _hideRow, _measureType);
		endif;
		
		return prod.hasEntTableSpecialConditions(_entRow, _alteredHeaderName, _hideRow, _measureType);
	
	else
	
		if _entRow.name = ETRow_TotalWeight
		or _entRow.name = ETRow_TotalVolume
		then
			
			prod := self.mySystemProductType;
			
			if prod = null then
				return inheritMethod(_entRow, _alteredHeaderName, _hideRow, _measureType);
			endif;
			
			if _entRow.name = ETRow_TotalWeight and prod.getMyWeight &lt;&gt; null then
				prodAttr := prod.getProdAttrFromName( ETRow_MyWeight );
				_measureType := prod.getMyWeight.myMeasurementType;
			elseif _entRow.name = ETRow_TotalVolume and prod.getMyVolume &lt;&gt; null then
				prodAttr := prod.getProdAttrFromName( ETRow_MyVolume );
				_measureType := prod.getMyVolume.myMeasurementType;
			endif;
			
			if _measureType &lt;&gt; null then
				returnValue := true;
			endif;
			
			if prodAttr &lt;&gt; null then
				if prodAttr.getDisplayStringForAttribute( ETRow_SystemName, false ) &lt;&gt; prodAttr.displayName then
					_alteredHeaderName := prodAttr.displayName;
					returnValue := true;
				endif;
			endif;
		
			return returnValue;
			
		endif;

		return inheritMethod(_entRow, _alteredHeaderName, _hideRow, _measureType);
	
	endif;

epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_alteredHeaderName" type="String" usage="output"/>
        <Parameter name="_hideRow" type="Boolean" usage="output"/>
        <Parameter name="_measureType" type="CM_MeasurementType" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasProductTypes" id="581b9e08-0b38-4fb8-94b2-8f3b20d937d2">
        <source>hasProductTypes() : Boolean;
/* ---------------------------------------------------------------------------
Created:	26 May 2009	by cnwvu1

Purpose:	Returns TRUE for user-defined cargo type that requires 
			sub-cargo types	(former product tytpes) and has some
			sub-cargo types entered.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.isSystemCargoBOLType then
		return false;
		
	elseif not self.isSubCargoTypeRequired then
		return false;
	
	else	// user-defined and self.isSubCargoTypeRequired
		if self.allProducts.size &gt; 0 then
			return true;
		else
			return false;
		endif;
		
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSubTypesForOperator" id="f8bd19a8-76b5-4b1a-9fcb-ef680cfe2305">
        <source>hasSubTypesForOperator(_operator : CM_Operator) : Boolean;
// Feb 2012 28882 for cargo edit validation, check for no sub-types for the TI operator
//11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	proDict		: CM_ProductByOpCodeProCodeDict;
	pro			: CM_Product;
	opCodeKey,
	proCodeKey,
	filtOpCode	: String;
	iter		: Iterator;
	result		: Boolean;
begin
	
	result := false;
	proDict := self.allProducts;
	iter := proDict.createIterator();
	if _operator &lt;&gt; null then
		filtOpCode := _operator.code;
	endif;
	
	// check for sub-types with no operator first
	pro := proDict.first();
	if pro &lt;&gt; null and
	   pro.myOperator = null then
		return true;
	endif;
	
	proDict.startKeyGeq(filtOpCode, null, iter);
	
	while iter.next(pro) do
		iter.getCurrentKeys(opCodeKey,proCodeKey); //MTN-35226
		if filtOpCode &lt;&gt; null and filtOpCode &lt;&gt; opCodeKey then
			break;
		endif;
	
		result := true;
		break;
		
	endwhile;

	return result;
epilog
	delete iter;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="c85b31d4-bf17-4995-a381-c51b705c5a42">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navsp1	Initial creation TFS#53104

*/

vars
	opsviewtable : CMIF_AuxRefCommodity;
begin
	if _opsViewTable.isKindOf(CMIF_AuxRefCommodity) then
		opsviewtable					:= _opsViewTable.CMIF_AuxRefCommodity;
		opsviewtable.tableName			:= opsviewtable.Aux_Ref_Commodity;
		opsviewtable.gkey       		:= opsviewtable.generateFullGKey(self,"");
		opsviewtable.client_id 			:= opsviewtable.generateCpxGKey().String;
		opsviewtable.id 				:= self.abbreviation;
		opsviewtable.description 		:= self.description;
		opsviewtable.created			:= self.createdTime.String.Integer;
		if self.allAuditObjects &lt;&gt; null and self.allAuditObjects.first &lt;&gt; null and self.allAuditObjects.first.myUser&lt;&gt; null then //navsp1 08Jun2022
			opsviewtable.creator 		:= self.allAuditObjects.first.myUser.code;
		else
			opsviewtable.creator 		:= "";
		endif;
		opsviewtable.changed			:= app.actualTimeServer.String.Integer;
		opsviewtable.changer 			:= app.getMyUserCode();
		opsviewtable.is_non_reefer 		:= self.isReefer;
		opsviewtable.temp_max 			:= self.getMaximumTemperature();
		opsviewtable.temp_min 			:= self.getMinimumTemperature();
		opsviewtable.short_name 		:= self.description;
		//navra1 - 17th June 2022 - TFS-53105 - Creating a life_cycle_state for ref_commodity
		opsviewtable.life_cycle_state	:= opsviewtable.n4LifeCycleState(self); 
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
