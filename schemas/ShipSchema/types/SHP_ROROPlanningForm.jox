        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseUpLftCtrlEvent" id="a53911e2-6f17-4087-8670-f0dbf5f510b3">
        <updating/>
        <source>doFrameDrawMouseUpLftCtrlEvent(_frame : Frame; _firstPoint, _lastPoint : Point) updating;
/*
Purpose:			
// CALLED BY CMUI_POINTDRAWINGFRAME, no references

Date		Who		Reason
20 July 2011	cnwab1	Initial creation
*/

vars
	locns : CM_RORODeckItemByOrd1Ord2;
	tmpDeckItem : CM_DeckItem;
	anItemLayout : CM_DeckItemLayout;
	tmpLayer : CM_DeckLayerLayout;
	tmpLocn :CM_ROROLocnDefn;
	otherFrame,
	theFrame : CMUI_PointDrawingFrame;
	theObjectIndex : Integer;
begin

	
	theFrame := _frame.CMUI_PointDrawingFrame; 
	if self.optColour.value then
		theFrame.setPropertyValue("modeViewSub", ShpDisplayModeSub_Colour);
		self.myROROPlanDrawController.modeViewSub := ShpDisplayModeSub_Colour;
		self.myROROPlanDrawController.modeView := self.modeView;
	else
		self.myROROPlanDrawController.modeViewSub := ShpDisplayModeSub_Text;
		theFrame.setPropertyValue("modeViewSub", ShpDisplayModeSub_Text);
		self.myROROPlanDrawController.modeView := self.modeView;
	endif;

	create locns transient;

	
	// #### CARGO LAYER
	if self.myCurrentLayer = null then
		tmpLayer := self.myCurrentDeck.myDeckLayout.getCargoLayer();
	else
		tmpLayer := self.myCurrentLayer;
	endif;
	
	if tmpLayer &lt;&gt; null then
		tmpLayer.getLocnDefnForArea(_firstPoint, _lastPoint, locns, self.scaleFactor );
	endif;
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if self.modeView = ShpDisplayMode_ColCodeLoad 
	or self.modeView = ShpDisplayMode_Proposed then
		tmpLayer := self.myCurrentDeck.myDeckLayout.getCCLoadLayer();
		if tmpLayer = null then
			return;
		endif;
		
		tmpLayer.getLocnDefnForArea(_firstPoint, _lastPoint, locns, self.scaleFactor );
	endif;

	if tmpLayer = null then
		return;
	endif;
	
	foreach tmpDeckItem in locns  discreteLock do
		anItemLayout := tmpDeckItem.myLayout;
		if anItemLayout = null then
			continue;
		endif;
		// PAR 28336 - ignore as it is covered by a GC polygon
		if not anItemLayout.isSelectableByMode(self.modeView) then
			continue;
		endif;
		//cnwmc5 - 26 Nov 2013 - PAR 32697
		if self.modeView = ShpDisplayMode_ColCodeLoad 
		or self.modeView = ShpDisplayMode_Proposed then
			if anItemLayout.isCovered(DeckItemLayoutType_Locn,false) then
				continue;
			endif;
		endif;
		
		//theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, Grey, anItemLayout);		//cnwmc5 - 11 Dec 2013 - PAR 32697
		//self.myROROPlanDrawController.selectObject(tmpDeckItem,false, false);							//cnwmc5 - 11 Dec 2013 - PAR 32697

		//cnwmc5 - 26 Nov 2013 - PAR 32697
		self.doFrameDrawDetectOtherGraphic(anItemLayout, true);
	endforeach;
	
	//epr TFS 3594 30/5/17
	if locns.isEmpty  then 
		if  self.modeView = ShpDisplayMode_ColCodeLoad then
			otherFrame :=self.myROROPlanDrawController.getFrameForLayer(tmpLayer);
			if otherFrame.detectIfInPolygon(_firstPoint.x,_firstPoint.y,theObjectIndex) then
				self.doFrameDrawDetectOtherGraphic(otherFrame.allPointGraphics[theObjectIndex].CM_DeckItemLayout,true);
				
			endif;
		endif;
	
		
	endif;
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		self.myROROPlanDrawController.getAllPolygonsColourCoding(theFrame,null,true, Black); // PAR 30373 changed to Black
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		self.myROROPlanDrawController.getAllPolygonsColourCoding(theFrame,null,false, Black);
	elseif self.modeView = ShpDisplayMode_Proposed then
		self.myROROPlanDrawController.getAllPolygonsProposed(theFrame,tmpLayer, Black);
	else
		self.myROROPlanDrawController.getAllPolygonsActual(theFrame,tmpLayer, Black); // PAR 30373 changed to Black
	endif;	
epilog
	delete locns;
end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_firstPoint" type="Point"/>
        <Parameter name="_lastPoint" type="Point"/>
    </JadeMethod>
