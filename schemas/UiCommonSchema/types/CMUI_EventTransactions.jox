    <JadeMethod name="doBaseFormCancel" id="0a944989-fc8d-4dcc-b9d8-96fcc0df07f4">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if	self.tblEvents.selectedCount = 0 then
		if not btnSaveBase.enabled then
			self.unloadForm();
			return;
		endif;
	endif;

	inheritMethod();
	
	self.clearEditControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="14385fd4-492d-4d34-b0b8-cc8bcaae4614">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Date		Who		Reason
10/12/2014	cnwer1	Initial creation PAR
10 Mar 2017	cnwrs1	TFS3601 fix 1090 error
20/04/2017	cnwdap1	TFS 4174 LNX Additional Information on Voyage Events
05/05/2017	cnwdap1	TFS 4342 LNX Voyage Event Date Issues
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
03/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
29/07/2022	jlizm1	TFS 54165 EDI Voyage Events
20/02/2023	jlizm1	TFS 56675 Truck Events remarks field
*/

vars
	realEvent, 
	proxyEvent 	   : CM_EventTransaction;
	allPreWarnings : HugeStringArray;
	eventType 	   : CM_EventType;
	timeStamp 	   : TimeStamp;
	endTimeStamp   : TimeStamp;
	date,
	endDate 	   : Date;
	time,
	endTime 	   : Time;
	loadState 	   : Boolean;
	noCharge 	   : Boolean;
	theReturn 	   : Integer;
	amount 		   : Decimal[16,4];
	debtor	       : CM_Debtor;
	weight 		   : Decimal[23,4]; // TFS 54165
begin
	
	date := self.txtDate.getDate;
	time := self.txtTime.getTime;
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	endTimeStamp := null;
	
	if self.txtEndDate.visible then
		endDate := self.txtEndDate.getDate;
		endTime := self.txtEndTime.getTime;
		endTimeStamp.cnEcSetDateAndTime(endDate,endTime);
	endif;
	
	noCharge := not cmbCharge.itemData[cmbCharge.listIndex].Boolean;
	amount   := self.txtAmount.text.asDecimalJMT;
	weight 	 := self.tblWeight.getConvertedValue();	// TFS 54165
	
	if self.cmbDebtor.listObject &lt;&gt; null then
		debtor   := self.cmbDebtor.listObject.CM_Debtor;                           //03/06/2020 cnwma1 Tfs #49400
	endif;
	
	if self.mode = self.Mode_Add then
		if cmbEventType.listIndex &gt; 0 then
			eventType := self.cmbEventType.itemObject[self.cmbEventType.listIndex].CM_EventType;
		endif;
		create allPreWarnings transient;
		if eventType = null then
			allPreWarnings.add(app.getErrorString(Must_select_event_type));
		endif;
		if not allPreWarnings.isEmpty then
			app.showErrorWarningDialogArray(app.getErrorString(Train_event_update), allPreWarnings, null, ErrWarnMode_CanAckWarnings);
			return;
		endif;
		proxyEvent:=eventType.createEvent(self.localToSystemTime(timeStamp),self.myTerminal,app.myPassport.myUser.code,true,noCharge, amount);
		
		if proxyEvent.isKindOf(CMEVT_TrainTransaction) then
			proxyEvent.CMEVT_TrainTransaction.setMyTrain(self.myParent.CM_Train);
			proxyEvent.CMEVT_TrainTransaction.setEndDataTime(eventType.isFromToDateTimeRequired,self.localToSystemTime(endTimeStamp));	//ChangeRequest 45575
			proxyEvent.CMEVT_TrainTransaction.setUnitDescription(eventType.unitDescription);											//ChangeRequest 45575
			proxyEvent.CMEVT_TrainTransaction.setRemarks(self.txtRemarks.text);															//ChangeRequest 45575
			proxyEvent.setShiftDetails(self.myCurrentShift);																			//ChangeRequest 45575
		elseif proxyEvent.isKindOf(CMEVT_TruckEvent) then
			proxyEvent.CMEVT_TruckEvent.setMyVisit(self.myParent.CM_VehicleVisitRecord);
			proxyEvent.CMEVT_TruckEvent.setRemarks(self.txtRemarks.text);	// TFS 56675
		elseif proxyEvent.isKindOf(CMEVT_VoyageEvent) then
			proxyEvent.CMEVT_VoyageEvent.setMyVoyage(self.myParent.CM_Voyage);						     // TFS 4342
			proxyEvent.CMEVT_VoyageEvent.setEndDataTime(eventType.isFromToDateTimeRequired,self.localToSystemTime(endTimeStamp));//nds TFS 3047 26/01/17	// TFS 4342
			proxyEvent.CMEVT_VoyageEvent.setUnitDescription(eventType.unitDescription);					 //nds TFS 3047 26/01/17
			proxyEvent.CMEVT_VoyageEvent.setRemarks(self.txtRemarks.text);								 //nds TFS 3047 26/01/17
			proxyEvent.setShiftDetails(self.myCurrentShift);											 // TFS 3548
			proxyEvent.CMEVT_VoyageEvent.setJobDetails(self.myCurrentJob, self.myCurrentJobSheet);		// TFS 4174
			proxyEvent.CMEVT_VoyageEvent.setWeight(weight); // TFS 54165
		endif;
	else
		realEvent:= self.tblEvents.accessRow(self.tblEvents.row).itemObject.CM_EventTransaction;
		app.cmsBeginLoad(loadState);
		proxyEvent := realEvent.pxyCreateUpdateProxy;	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
		app.cmsEndLoad(loadState);

		proxyEvent.setDateTime(self.localToSystemTime(timeStamp));
		proxyEvent.setNoCharge(noCharge);
		proxyEvent.setAmount(amount);
		
		if proxyEvent.isKindOf(CMEVT_VoyageEvent) then
			proxyEvent.CMEVT_VoyageEvent.setEndDataTime(realEvent.myEventType.isFromToDateTimeRequired,self.localToSystemTime(endTimeStamp));				// TFS 4342
			proxyEvent.CMEVT_VoyageEvent.setRemarks(self.txtRemarks.text);																			  //25/01/17 cnwns1 TFS3214 
			proxyEvent.CMEVT_VoyageEvent.setWeight(weight); // TFS 54165
		elseif proxyEvent.isKindOf(CMEVT_TruckEvent) then
			proxyEvent.CMEVT_TruckEvent.setRemarks(self.txtRemarks.text);	// TFS 56675
		elseif proxyEvent.isKindOf(CMEVT_TrainTransaction) then
			proxyEvent.CMEVT_TrainTransaction.setEndDataTime(realEvent.myEventType.isFromToDateTimeRequired,self.localToSystemTime(endTimeStamp));	//ChangeRequest 45575
			proxyEvent.CMEVT_TrainTransaction.setRemarks(self.txtRemarks.text);																 		//ChangeRequest 45575
		endif;
		
	endif;
	//03/06/2020 cnwma1 TFS #49400
	if debtor &lt;&gt; null then
		if proxyEvent.isKindOf(CMEVT_VoyageEvent) then
			proxyEvent.CMEVT_VoyageEvent.setDebtor(debtor);
		elseif  proxyEvent.isKindOf(CMEVT_TrainTransaction) then
				proxyEvent.CMEVT_TrainTransaction.setDebtor(debtor);
		elseif proxyEvent.isKindOf(CMEVT_TruckEvent) then
			proxyEvent.CMEVT_TruckEvent.setDebtor(debtor);
		endif;	
	endif;
	
	while true do
		if realEvent = null then
			app.myTrxCA.trxCreateEventTransaction(proxyEvent,realEvent,app.myPassport);
		else
			app.myTrxUA.trxUpdateEventTransaction(proxyEvent,app.myPassport);
		endif;
		if  not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;	
		break;
	endwhile;
	
	self.clearEditControls();

epilog
	delete proxyEvent;
	delete allPreWarnings;
	app.cmsEndLoad(loadState);	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteEvent" id="1e4c28a6-8180-4f14-a243-b893f8d6c2fa">
        <updating/>
        <source>doDeleteEvent() updating;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	event : CM_Object;
	result : Integer;
	
begin

	event := self.tblEvents.accessRow(self.tblEvents.row).itemObject.CM_Object;
	
	if event &lt;&gt; null then
		
		while true do
			app.myTrxDA.trxDeleteCMObject( event, app.myPassport);
			
			if not app.myPassport.trxCompletedOK then
				result := app.showErrorWarningDialog(app.getErrorString(Train_user_event) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
		
			return;
		endwhile;		
	endif;
	
	self.clearEditControls();
epilog

end;</source>
    </JadeMethod>
