    <JadeMethod name="resizeTable" id="4c919589-c67b-4946-9206-a6290f9ddead">
        <updating/>
        <source>resizeTable() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25/05/2010	cnwer1	Initial creation
25/05/2015	cnwdap1	PAR #36311 Don't do the cnEc resize stuff, this overwrites what the table itself
						has already decided the column widths should be, based on the text extent of
						the Position and Damage codes (see CM_DamageTable::initCombos). 
						cnAdjustColumnWidths for an empty table just sets all columns to minimum 
						and the last column to maximum.
*/

vars

	theHeight : Real;
	vTop : Real;

begin

	self.setResizeableMarginAndFontSize();
	vTop := self.txtCargoId.top + self.txtCargoId.height + self.resizedMargin;
	theHeight:= (self.clientHeight - vTop - self.getCMDHeight());
	if self.chkToDo.visible then
		theHeight:=theHeight - (self.chkToDo.height * 2);
	endif;
	self.tblDamages.move( self.resizedMargin, 
	                    vTop, 
						self.clientWidth - 2*self.resizedMargin, 
						theHeight);
						
	//self.tblDamages.cnAdjustColumnWidths();			// PAR #36311

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="e834021f-9d2d-46e6-af94-f43b467d269b">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForEdit" id="1d3e5f15-c62c-4c12-8d00-0e5239ec04ab">
        <source>setForEdit() protected;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/

vars

begin
	// 37244 from to-do task completion
/*	if self.myToDoTaskDesc = null then
		self.btnOne.caption := app.getErrorString(Edit);
		self.btnOne.enabled := false;
	else
		self.btnOne.caption := app.getErrorString(Save);
	endif; */
	self.btnOne.caption := app.getErrorString(Save);	//19 Oct 2016	NDL	TFS 2802
	
	self.chkToDo.enabled := false; //cnwas3 par 24175
	self.btnTwo.enabled := true;
	self.txtCargoId.enabled := false;
	self.btnPartCargoId.enabled := false;
	self.tblDamages.userInputEnabled := true;
	self.tblDamages.setFocus();
	
	if self.getSessionAgent.mySelectedTI.allDamageInstancesByPos.size &gt; 0 then
		self.tblDamages.addNewRow();
	endif;
	self.getSessionAgent().setMyProxy( self.myTrackedItem );
	
	if self.myMobileGenericAgent.unpackChangeID then	//09 Apr 2014	NDL	Par 33934
		self.tblDamages.prefillForPennTerminals();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForView" id="79cafe20-c72c-400f-884e-2d4e25c52a4e">
        <updating/>
        <source>setForView() protected, updating;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/

vars

begin
	self.btnOne.caption := app.getErrorString(Edit);
	self.chkToDo.enabled := false; //cnwas3 par 24175
	self.btnOne.enabled := self.myTrackedItem &lt;&gt; null;
	self.btnTwo.enabled := false;
	self.txtCargoId.enabled := true;
	self.btnPartCargoId.enabled := true;
	self.tblDamages.userInputEnabled := false;
	
	self.somethingChanged := false;
	self.getSessionAgent().setMyProxy( null );
	self.txtCargoId.setFocus;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCargoCheckItem" id="d9a267f6-4568-460b-aeb8-f205b2f48dd6">
        <updating/>
        <source>setMyCargoCheckItem() updating;

/*
Date		Who		Reason
12 May 2010	cnwas3	par 24175

*/

vars	
	
	cargoCheck		: CM_CargoCheck;
	item			: CM_CargoCheckItem;
	sessionAgent 	: CM_MobileAgent;
	
begin

	sessionAgent:=self.getSessionAgent;
	
	if sessionAgent.myCargoCheckItem &lt;&gt; null then			//cnwas3 par 24175 part2
		self.myDamageCargoCheckItem := sessionAgent.myCargoCheckItem;
		return;
	endif;
	
	if app.myHandHeldCheckerAgent = null then
		return;
	endif;
	
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems where item.requiredExtraInfo = EXTRA_INFO_DAMAGE do
			self.myDamageCargoCheckItem := item;
			break;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="83c2205a-1b94-49da-b908-c68752438ef7">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
epilog

end;</source>
