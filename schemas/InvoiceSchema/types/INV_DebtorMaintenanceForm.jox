    <JadeMethod name="addSelectedEntity" id="665b333e-8447-4d07-86a2-64bd844efcd6">
        <updating/>
        <source>addSelectedEntity(_obj : Object) updating, protected;
//
// Changed On	By			Reason
// ---------- 	--------	-----------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 01 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars

begin
	if _obj.isKindOf(CM_Carrier) then
		self.allSelectedCarriers.add(_obj.CM_Carrier);
	elseif _obj.isKindOf(CM_ConsigneeConsignor) then
		self.allSelectedConsignors.add(_obj.CM_ConsigneeConsignor);
	elseif _obj.isKindOf(CM_CustomsAgent) then
		self.allSelectedCustomsAgents.add(_obj);
	elseif _obj.isKindOf(CM_DebtorType) then
		self.allSelectedDebtorTypes.add(_obj);
	elseif _obj.isKindOf(CM_Operator) then
		self.allSelectedOperators.add(_obj.CM_Operator);
	elseif _obj.isKindOf(CM_EmailAddress2) then 	//epr par 35304 2/12/14
		self.allSelectedContacts.add(_obj);
	elseif _obj.isKindOf(CM_Stevedore) then			// TFS 44554
		self.allSelectedStevedores.add(_obj);		// TFS 44554
	elseif _obj.isKindOf(CM_ShippingLine) then		// Jun 1, 2022 navak20 TFS 53204
		self.allSelectedShippingLine.add(_obj);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
