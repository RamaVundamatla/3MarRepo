    <JadeMethod name="checkTIVoyDetDiscrepancy" id="056c474e-b4b7-40f3-841f-9216de753939">
        <source>checkTIVoyDetDiscrepancy(_discharge : CM_Port; _tranship : CM_Port; _voyage : CM_Voyage; _expectFailDischarge : Boolean; _expectFailTranship : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwas3	Initial creation

*/

vars
	validDischarge,
	validTranship,
	noTranship	: Boolean;
	portRotation : CM_PortRotation;
	port : CM_Port;
	transhipPort	: String;		// 21/01/2011 cnwmh5
	dischargePort	: String;		// 21/01/2011 cnwmh5
begin
	dischargePort := null;			dischargePort := null;
	if _discharge = null then
		validDischarge := true;
	else
		if _voyage.allPorts.includes(_discharge) then
			validDischarge := true;
		endif;
		dischargePort := _discharge.code &amp; " - " &amp; _discharge.description;	// 21/01/2011 cnwmh5
	endif;
	noTranship := true;
	transhipPort := null;				// 21/01/2011 cnwmh5
	if _tranship &lt;&gt; null then
		foreach portRotation in _voyage.allPortRotations where portRotation.allTranshipPorts.size &gt; 0 do
			foreach port in portRotation.allTranshipPorts where port = _tranship do
				if _discharge &lt;&gt; null and _discharge &lt;&gt; portRotation.myPort then
					validTranship := false;
				else
					validTranship := true;
				endif;
				noTranship := false;
			endforeach;
		endforeach;
	
		if noTranship then
			validTranship := false;
		endif;
		
		transhipPort := _tranship.code &amp; " - " &amp; _tranship.description;	// 21/01/2011 cnwmh5
	else
		validTranship := true;
	endif;
	if _expectFailDischarge then
		//self.assertTrueMsg( not validDischarge, "The discharge port of " &amp;_discharge.String&amp;  " is invalid for the voyage " &amp; _voyage.description );
		self.assertTrueMsg( not validDischarge, "The discharge port of " &amp; dischargePort &amp; " is invalid for the voyage " &amp; _voyage.description );		// 21/01/2011 cnwmh5
	else
		//self.assertTrueMsg(validDischarge, "The discharge port of " &amp;_discharge.String&amp;  " is invalid for the voyage " &amp; _voyage.description );
		self.assertTrueMsg(validDischarge, "The discharge port of " &amp; dischargePort &amp; " is invalid for the voyage " &amp; _voyage.description );			// 21/01/2011 cnwmh5
	endif;
	
	if _expectFailTranship then
		//self.assertTrueMsg(not validTranship, "The tranship port of " &amp;_tranship.String&amp;   " has been moved under another discharge port or is invalid for the voyage " &amp; _voyage.description);
		self.assertTrueMsg(not validTranship, "The tranship port of " &amp; transhipPort &amp;  " has been moved under another discharge port or is invalid for the voyage " &amp; _voyage.description);	// 21/01/2011 cnwmh5
	else
		//self.assertTrueMsg( validTranship, "The tranship port of " &amp;_tranship.String&amp;   " has been moved under another discharge port or is invalid for the voyage " &amp; _voyage.description);
		self.assertTrueMsg( validTranship, "The tranship port of " &amp; transhipPort &amp;   " has been moved under another discharge port or is invalid for the voyage " &amp; _voyage.description);		// 21/01/2011 cnwmh5
	endif;
end;</source>
        <Parameter name="_discharge" type="CM_Port"/>
        <Parameter name="_tranship" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_expectFailDischarge" type="Boolean"/>
        <Parameter name="_expectFailTranship" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteWharfLockout" id="a7cc8e5e-8747-4fbd-ac7d-fe50fff0993f">
        <updating/>
        <source>deleteWharfLockout(_startDate, _endDate : String; _startMark : Integer; _harbour : String) updating;
/*
Purpose:			Delete the named wharf lockout at the named harbour

Parameters:			

Return Value:		

Date		Who		Reason
07/03/2012	cnwdap1	Initial creation PAR #28402
*/
vars
	harbour 		: HMS_Harbour;
	lockout 		: HMS_WharfLockout;
	hmsObj			: HMS_Object;
	startD, endD	: TimeStamp;

begin
	startD 	:= _startDate.asTimeStampJMT();
	endD 	:= _endDate.asTimeStampJMT();
	harbour := app.myRoot.allHarbours[_harbour];
	lockout := harbour.allWLockoutsByStartDT[startD, endD, _startMark];
	hmsObj 	:= lockout;
	app.myTrxDA.trxDeleteHMSObject(hmsObj, app.myPassport);
epilog

end;</source>
        <Parameter name="_startDate" type="String"/>
        <Parameter name="_endDate" type="String"/>
        <Parameter name="_startMark" type="Integer"/>
        <Parameter name="_harbour" type="String"/>
    </JadeMethod>
    <JadeMethod name="tHMSAdmin" id="d46fb58b-ec8b-4756-89f5-33656c4389f4">
        <updating/>
        <source>tHMSAdmin() updating;
/*
Purpose:			Create Tug,Resource and ResourceType

Date		Who		Reason
04/03/2014	cnwma1	Initial creation 
*/
vars
	term			: CM_Terminal;
	service			: CM_Service;
	services		: CM_ServiceByNameDict;
	invType			: CM_InvoiceDesc;
	resourceType	: HMS_ResourceType;
	origHarbour,
	harbour			: HMS_Harbour;
	wharf			: HMS_Wharf;
	berth			: HMS_Berth;
	arrResource,
	depResource,
	shiftResource	: HMS_Resource;
	tug				: HMS_Tug;
	voyage			: CM_Voyage;
	oa				: ObjectArray;
	
	
begin

	term := self.getTerminal();
	origHarbour := term.myHarbour;
	
	// clear terminal harbour so can add new one
	beginTransaction;
	origHarbour.allTerminalsByCode.remove(term);
	commitTransaction;

	// harbour
	create oa transient;
	oa.add(term);
	self.opts.purge();
	self.opts.addAssoc("IgnoreWarnings", true);
	self.opts.addAssoc("Terminals", oa);

	harbour := app.myRoot.allHarbours["UTHAVEN"];
	if harbour = null then
		harbour := self.addHarbour("UTHAVEN", "Test harbour").HMS_Harbour;
	endif;
	
	// wharf
	wharf := harbour.allWharves["UTWHARF"].HMS_Wharf;
	if wharf = null then
		wharf := self.addWharf("UTWHARF","Test wharf", harbour, 100, 10);
	endif;
	// berth
	berth := harbour.allBerths["UTBERTH"];
	if berth = null then
		berth := self.addBerth("UTBERTH", "Test berth", harbour, 1, 50, 2.5, false, wharf);
	endif;
	
	// resource type - delete used resource first
	resourceType := self.addHMSResourceType("UTTUGS", "Test Tugs", null, 0, true, false,
										false, false, true, false);		
	// resource
	arrResource := self.addHarbourResource("UTTUGAR", "Tugs - arrival", harbour, resourceType, null, 
										0, 0, false);
	depResource := self.addHarbourResource("UTTUGDP", "Tugs - Departure", harbour, resourceType, null, 
										0, 0, false);
	shiftResource := self.addHarbourResource("UTTUGSH", "Tugs - Shift", harbour, resourceType, null, 
										0, 0, false);

	//  Add  Tug
	tug := self.addHMSTug("UTHM", "Test harbour tug", harbour);

	// Update tug Details
	self.opts.purge();
	self.opts.addAssoc("TugDesc","Test harbour tug2");
	self.opts.addAssoc("HarbourToCheck", "UTHAVEN");
	self.opts.addAssoc("ArrResource", arrResource);
	self.opts.addAssoc("DepResource", depResource);
	self.opts.addAssoc("ShResource", shiftResource);
	self.updateHMSTug(tug);
	
epilog

	delete oa;
	// restore original harbour
	if term &lt;&gt; null and origHarbour &lt;&gt; null and
	   global.isValidObject(origHarbour) then
		beginTransaction;
		if harbour &lt;&gt; null and harbour.allTerminalsByCode &lt;&gt; null and 
				harbour.allTerminalsByCode.includes(term) then
			harbour.allTerminalsByCode.remove(term);
		endif;
		origHarbour.allTerminalsByCode.add(term);
		commitTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSMarineServiceTimingsTrans" id="d15b8ed6-8cf3-4b20-9cc5-979b6fe90a61">
        <source>tHMSMarineServiceTimingsTrans();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2025	navlw1	JIRA-36117: ATD | Marine Service Audits - unit tests

*/

constants
Voyage1 = "VOY36117";
Vessel1 = "Ves36117";
vars
	voy,
	pxyVoy				: CM_Voyage;
	operator 			: CM_Operator;
	vessel 				: CM_Vessel;
	pxyMarineService, 
	marine				: HMS_MarineServicesTimings;
	hmsTrans			: HMS_Transaction;
	marineServiceEdit	: HMS_MarineServicesTimingsEdit;
	found				: Boolean;
begin
	// delete set up data
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Vessel1);
	// create voyage
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	//set up data
	vessel := addVesselCellular(Vessel1,operator);
	self.assertNotNullMsg(vessel,"Vessel has not been created");
	
	voy := self.addVoyageWithContainerStructur(Voyage1, Vessel1, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voy,"Voyage not created");
	vessel := voy.myVessel;
	self.assertNotNullMsg(vessel,"Vessel is null");
	
	create marine transient;
	marine.setPropertyValue(HMS_MarineServicesTimings::myMovement.name, voy.myHMSVoyageData.allVoyageMovements.first);
	marine.setProxy(null,null,null,null,null,null,"TEST",null,null,null,null,null,null,null,null,null,null,null,null,null,null,voy.myHMSVoyageData.allVoyageMovements.first,null,null,null,null,true);
	app.myTrxUA.trxUpdateMarineTimings(marine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach hmsTrans in voy.myHMSVoyageData.allHMSTransactions do
		if hmsTrans.isKindOf(HMS_MarineServicesTimingsEdit) then
			found := true;
			marineServiceEdit := hmsTrans.HMS_MarineServicesTimingsEdit;
			self.assertEqualMsg(marineServiceEdit.myMarineServiceTimings.hasRamp, true, "Has Ramp should be set to True");
			self.assertEqualMsg(marineServiceEdit.myMarineServiceTimings.movementRemarks, "TEST", "Movement Remarks should be set to TEST");
		endif;
	endforeach;
	self.assertTrueMsg(found, "No HMS Marine Timings transaction was found");
epilog
	delete marine;
	delete pxyMarineService;
	delete pxyVoy;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSVoyageDetails" id="a46ee91e-5a25-4188-a1c1-d216e0899e66">
        <source>tHMSVoyageDetails();
/*

Purpose:		 Add HMS VoyageDelay	

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	hmsVoyageDelay  : HMS_Delay;
	delayDesc		: String;
	pxyHMSVoyage : HMS_VoyageData;
	voyage			: CM_Voyage;
	pxyVoyageDelay,voyageDelay : HMS_VoyageDelay;
	realDelay : HMS_Object;
	startDt		: TimeStamp;
	endDt		: TimeStamp;
	
begin
	
	// Add HMS Voyage Delay
	hmsVoyageDelay := self.addHMSVoyageDelay("BD","Boom Down",true);
	self.assertNotNull(hmsVoyageDelay);
	//Update HMS Voyafe Delay
	delayDesc := hmsVoyageDelay.description &amp; "_UP";
	self.opts.purge();
	self.opts.addAssoc("DelayDesc", delayDesc);
	self.updateHMSVoyageDelay(hmsVoyageDelay);
	
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
