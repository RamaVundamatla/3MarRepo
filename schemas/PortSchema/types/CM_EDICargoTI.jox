    <JadeMethod name="getLLDisplayString" id="364abad2-8d4e-41ba-b69e-5539ed6c1ed6">
        <source>getLLDisplayString(_entTblRows: StringArray):String;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	entRow		: String;
	strReturn	: String;
begin
	
	strReturn := self.id &amp; " (LL)";
	foreach entRow in _entTblRows do
		if entRow = ETRow_Id then
			continue;
		endif;
		strReturn := strReturn &amp; Tab &amp; self.getDisplayStringForAttribute(entRow, false);
	endforeach;
epilog
	return strReturn;		
end;</source>
        <Parameter name="_entTblRows" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
