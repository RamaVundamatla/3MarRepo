    </JadeMethod>
    <JadeMethod name="jssFileExt" id="74e60ca5-068c-482a-83ea-cb28dd909322">
        <source>jssFileExt() :String;
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Return the extension of the node's name.
//
// Parameters:	None.
//
// Returns:		The file/folder name's extension.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/05/2002	cnwdad1		If the node name did not have an extension, then the
//							name (from 2nd character onwards) was being returned.
// --------------------------------------------------------------------------------
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename

	uniqueName	:=	self.jssUnqualName();
	charIndex	:=	1;
	
	if uniqueName.pos(".", 1) = 0 then		// cnwdad1 08/05/2002
		return null;						// cnwdad1 08/05/2002
	endif;									// cnwdad1 08/05/2002
	
	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return "";
	endif;

	return uniqueName[(lastCharPos + 1):end];		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssFilePath" id="b47f9e44-699b-41dd-8334-8893c8ebc230">
        <source>jssFilePath():String;
// --------------------------------------------------------------------------------
// Created:		16 April 2003 by cnwdad1
//
// Purpose:		Return the path part of the fully qualified filename only (up to
//				and including the FINAL "\").
//
// Parameters:	None
//
// Returns:		The name of the file path.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos(global.jssGetFileSeparator(), (lastCharPos + 1));
	endwhile;

	return fileName[1:lastCharPos];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssFileStem" id="23316a39-2734-4aae-992f-2d98a05cf698">
        <source>jssFileStem():String;
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Return the filestem, i.e. the unqualified filename without the file
//				extension (after the FINAL ".").
//
// Parameters:	None.
//
// Returns:		The stem of the node's name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/05/2002	cnwdad1		If the node name did not have an extension, then no
//							name was being returned at all.
// --------------------------------------------------------------------------------
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename
	uniqueName	:=	self.jssUnqualName();
	charIndex	:=	1;
	
	if uniqueName.pos(".", 1) = 0 then		// cnwdad1 08/05/2002
		return uniqueName;					// cnwdad1 08/05/2002
	endif;									// cnwdad1 08/05/2002
	
	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return uniqueName;
	endif;

	return uniqueName[1:(lastCharPos - 1)];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
