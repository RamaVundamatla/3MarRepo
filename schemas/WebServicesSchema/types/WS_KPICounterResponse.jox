    </JadeMethod>
    <JadeMethod name="getKPICounterCargoTypes" id="f96da9f4-1f55-4a96-a221-71edff884b94">
        <updating/>
        <source>getKPICounterCargoTypes(_terminal : CM_Terminal input;
						_startDate : String;
						_endDate : String) updating;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	kpiCounter : CMIF_KPICounter;
	kpiCargoType : CMIF_KPICounterCargoType;
	startDate 	: TimeStamp;
	endDate : TimeStamp;
	time : Time;
	cargoTypes 	: CM_CargoTypesByIdDict;
	cargoType 	: CM_CargoBOLType;
	wsKPICargoType : WS_KPICounterCargoType;
	endTime : Time;
begin
	
	self.terminal:=_terminal.code;
	self.startDate:=_startDate;
	self.endDate:=_endDate;
	
	time:= null;
	startDate.setDate(self.startDate.asDateFromWebInterface);
	startDate.setTime(null);
	
	endDate.setDate(self.endDate.asDateFromWebInterface);
	endTime.setTime(23,59,59,59);
	endDate.setTime(endTime);
	
	create cargoTypes transient;
	foreach cargoType in _terminal.allCargoBOLTypes do
		if cargoType.isKindOf(CM_CargoType) then
			cargoTypes.add(cargoType.CM_CargoType);
		endif;
	endforeach;
	
	
	create kpiCounter transient;
	kpiCounter.setDetails(_terminal, startDate,endDate,cargoTypes);
	
	foreach kpiCargoType in kpiCounter.allKPICounterCargoTypes discreteLock do
		if kpiCargoType.allKPICounterMonths.size = 0 then
			continue;
		endif;			
		
		create wsKPICargoType transient;
		wsKPICargoType.setFromCMIFKPICounterCargoType(kpiCargoType);
		self.allKPICounterCargoTypeArray.add(wsKPICargoType);
	endforeach;
	
	
	
epilog
	delete kpiCounter;
	delete cargoTypes;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_startDate" type="String"/>
        <Parameter name="_endDate" type="String"/>
    </JadeMethod>
</Class>
