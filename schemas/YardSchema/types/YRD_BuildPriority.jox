    <JadeMethod name="buildComboVoyage" id="d65fd5d6-b7bb-4491-90d9-72fb8e5e51c3">
        <source>buildComboVoyage();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lID		: String;
	lVoyage	: CM_Voyage;
	idx		: Integer;

begin

//	self.myAssistant.comboBoxVoyageCode(self.cmbFiltVoyage1, null, true);
//	self.myAssistant.comboBoxVoyageCode(self.cmbVoyage1, null, true);
	
			
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
											null,
											true,
											false,
											true,
											true,
											true,
											true,
											true,
											false,
											false);
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
											null,
											true,
											false,
											true,
											true,
											true,
											true,
											true,
											false,
											false);
	
	self.cmbVoyage.armNotification(self.myTerminal);
	self.cmbFiltVoyage.armNotification(self.myTerminal);
/*	self.cmbFiltVoyage.clear;
	self.cmbVoyage.clear;
	idx := self.cmbVoyage.addItem(null);
	idx := self.cmbFiltVoyage.addItem(null);
	
	foreach lVoyage in self.myTerminal.allVoyagesByCode do
		if lVoyage.isKindOf(CM_NullVoyage) then
			continue;
		endif;
		
		lID := lVoyage.code.trimBlanks &amp; Tab &amp; lVoyage.description.trimBlanks;
		if cmbFiltVoyage.findObject(lVoyage) &lt; 0 then
			idx := self.cmbFiltVoyage.addItem(lID);
			self.cmbFiltVoyage.itemObject[idx] := lVoyage;
			idx := self.cmbVoyage.addItem(lID);
			self.cmbVoyage.itemObject[idx] := lVoyage;
		endif;
	endforeach;
*/

end;</source>
    </JadeMethod>
