    <JadeMethod name="doSlotAvailability" id="b956d50c-b272-445e-b532-bf8ca591aae4">
        <source>doSlotAvailability();
/*
Date		    Who			Reason
18 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	deckItem : CM_DeckItem;
begin
	if self.myCurrentProxyItemLayout &lt;&gt; null then
