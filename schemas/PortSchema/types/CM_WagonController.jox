    <JadeMethod name="getSpannedToLCs" id="12ed0a55-a70a-446e-8044-6990cc157880">
        <source>getSpannedToLCs(control : CMIF_MoveController input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			08 August 2001 by cnwdwq1
Purpose:			Returns the EXTRA LC's this TI will need to sit over.
							We DONT check capacity at this point
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	units : Real;
	tArray : CM_LCArray;
	lc : CM_WagonController;
	moveTI,
	tmpTI : CM_TrackedItem;
	count : Integer;
begin
	
	inheritMethod(control);		//Clears toSecondaryLocations coll
	
	moveTI := control.myTrackedItem;
	//Determine the # of spaces this TI will take up
// WAS	units := moveTI.getLengthInUnits();
// NOW PAR 18015
	units := moveTI.getLengthInUnitsForWagon();
	
	if units &lt;= 1 then
		//---------------
		//This controller will carry it off
		//---------------
		return true;
	endif;

	//---------------
	//Because each of me is a 10' unit, I need one for each unit returned from the call
	//as they are 10' units as well
	//---------------

	create tArray transient;
	lc := self.myNextController;
	if lc = null then
		//There is NO next LC!
		return false;
	endif;
	count := 1;
	
	while true do
		tArray.add(lc);
		count := count + 1;
		if count = units then
			break;
		endif;
		if lc.myNextController = null then
			break;
		endif;			
		lc := lc.myNextController;
	endwhile;

	//--------------------
	//Return whether there are enough positions
	//--------------------
	// we add one to account for self as self is not added to the array
	if (tArray.size + 1 ) &lt;&gt; units then
		return false;
	endif;
	//Set the array
	control.setMyToSecondaryLocations(tArray);
	return true;
epilog
	delete tArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSpannedToLCsNEW" id="bd674117-f87b-4dc6-bafc-1ecd4f672866">
        <source>getSpannedToLCsNEW(control: CMIF_MoveController input): String;
/*
 ------------------------------------------------------------------------
Created:			28 September 2001 by cnwdwq1
Purpose:			Returns the EXTRA LC's this TI will need to sit over.
							We DONT check capacity at this point
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	units 	: Real;
	tArray 	: CM_LCArray;
	lc 		: CM_WagonController;
	count 	: Integer;
	
begin
	if self.isThereRoomForTI(self,control,control.myTrackedItem) &lt;&gt; null then
		return app.getErrorString1(ERR_No_Room, null);
	endif;
	
	if control.myTrackedItem.getActualLength = 10 then //12 Aug 2010 NDL Par 25316 - Its a generator, don't dick about
		return null;								// it doesn't need any additional room.	
	endif;

	units := self.getNumUnitsFlexiOffset(control.myTrackedItem); // PAR 18682 #############################
	
	create tArray transient;
	lc := self.myNextController;

	if lc = null then
		//There is NO next LC!
		//return "Greater than 20' and no pad.";
		return app.getErrorString1(ERR_No_Room, null); // PAR 18682
	endif;
	count := 0; // WAS 1 PAR 23533
	while true do
		tArray.add(lc);
		count := count + 1;
		if count &gt;= units then
			break;
		endif;	
		if lc.myNextController = null then
			break;
		endif;
		lc := lc.myNextController;
	endwhile;	

	//Set the array
	control.setMyToSecondaryLocations(tArray);
	return null;
epilog
	delete tArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStackHeight" id="c5d0364c-2359-4a08-8d79-a97efe9b4977">
        <source>getStackHeight():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408
21 October 2024		jlizm1	TFS 65987 Error 1308 when iterating collections

*/

vars

	tiSet : CM_TISet;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	stackHeight : Real;
	wle : CM_WorkListEntry;
	req : CM_Request;
	isoType : CM_ISOType;
	str : String;
	isoTypeGroup : CM_ISOTypeGroup;
	isROBorLoaded : Boolean;
	
begin

	create tiSet transient;
	create tiArray transient;
	
	if self.myTerminal.getConfig(RailDisallowOutwardQueue).Boolean then
		foreach ti in self.allTrackedItems do
			if ti.myPrimaryQueuedLocation &lt;&gt; null then
				continue;
			endif;
			
			isROBorLoaded := ti.isROB or not self.myWagon.allReportTIsInwards.includes(ti);  // it is a remain on board or was just loaded
			if not isROBorLoaded then
				tiSet.addNoDuplicates( ti, false );
			endif;
		endforeach;
	else
		self.allTrackedItems.copyNoDups(tiSet);
	endif;
	
	self.getAllQueuedTrackedItems( tiArray, true );
	
	foreach ti in tiArray do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
	
	self.getAllPlannedTrackedItems( tiArray, true, false );
	
	foreach ti in tiArray do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
	
	foreach ti in tiSet do
		stackHeight := stackHeight + ti.getActualHeight;
	endforeach;
	
	foreach wle in self.allRailWLELoad do
		if wle.myTrackedItem &lt;&gt; null then
			if not tiSet.includes( wle.myTrackedItem ) then	//25 Jan 2017	NDL	TFS 3198/2877
				stackHeight := stackHeight + wle.myTrackedItem.getActualHeight;
			endif;
		else
			req := wle.myRequest;
			if req &lt;&gt; null then
				str := req.getISOType;
				if str &lt;&gt; null then
					isoType := app.myRoot.allISOTypes.getAtKey(str);
					if isoType &lt;&gt; null then
						stackHeight := stackHeight + isoType.getHeight;
						continue;
					endif;
				endif;
				str := req.getISOGroup;
				if str &lt;&gt; null then
					isoTypeGroup := app.myRoot.allISOTypeGroups.getAtKey(str);
					if isoTypeGroup &lt;&gt; null then
						isoType := isoTypeGroup.allISOTypes.first;
						if isoType &lt;&gt; null then
							stackHeight := stackHeight + isoType.getHeight;
							continue;
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return stackHeight;
	
epilog

	delete tiSet;
	delete tiArray;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getStateForTIHere" id="acd0e346-27d7-4a3a-b90b-a0c8f5a1dc15">
        <source>getStateForTIHere(_ti : CM_TrackedItem): Integer;
/*
 ------------------------------------------------------------------------
Created:			09 January 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myWagon.confirmed then
		return TI_STATE_NORMAL;
	endif;
	
	if _ti.isOnSite then
		return TI_STATE_NORMAL; // CCMS 1067 PAR 19913
	endif;
	
	return TI_STATE_NOTIFIED;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="b2155957-87f4-4554-801f-1d595f2f5565">
        <source>getTerminal():CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	term : CM_Terminal;

begin

	if self.myWagon &lt;&gt; null then
		term := self.myWagon.getTerminal();
	endif;
	if term &lt;&gt; null then
		return term;
	endif;
	
	return app.myPassport.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToLC" id="1134e09e-c0ac-4fc1-a6ee-5d289ffecea1">
        <source>getTiTxnTypesForMoveFromToLC(_toController: CM_LocationsController; _intArray: IntegerArray input; _moveController: CMIF_MoveController);
/* ---------------------------------------------------------------------------
Created:	19 December 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	transReceive	: CM_Receive;
	
begin
	inheritMethod(_toController, _intArray, _moveController);

	// PAR 18363 - ensure we always create a receive transaction
	transReceive := _moveController.myTrackedItem.getTransReceive();
	if transReceive = null then
		_intArray.add(TRANS_TYPE_REC_RAIL);
		app.addTiTxnSubTerminalReceive(_moveController.myTrackedItem, TI_TRANSMODE_RAIL, _intArray);
	endif;
end;</source>
        <Parameter name="_toController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="285ce604-21db-4f48-a1de-c939d38030fb">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
	
begin
	inheritMethod(_moveController, _intArray);
	
	tmpTI := _moveController.myTrackedItem;

	app.addTiTxnSubTerminalRelease(tmpTI, TI_TRANSMODE_RAIL, _intArray);	// PAR 20706 (swap order)

	// clearing the rake
	if tmpTI.isAnInterTerminalRelease() then
		_intArray.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REL_RAIL);
	endif;

	// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 	_intArray.add(TRANS_TYPE_STORAGE);
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromNULL" id="2e45da8d-9fbb-4a7e-b0ee-584a1fa508e4">
        <source>getTiTxnTypesForMoveToFromNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
//--------------------------------------------------
// Created:	05 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
	
begin
	inheritMethod(_moveController, _intArray);
	
	tmpTI := _moveController.myTrackedItem;

	//Cargo comming into yard from Rail
	if tmpTI.isAnInterTerminalReceival() then
		_intArray.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REC_RAIL);
	endif;
	
	app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_RAIL, _intArray);
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTierId" id="06d0eeb2-1814-40f3-a5f9-15c600c6e2e4">
        <source>getTierId( _ti : CM_TrackedItem ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408
//21 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
*/

vars
	ti : CM_TrackedItem;
	index : Integer;
	futureMove : CM_FutureMove;
	nextLc : CM_WagonController;
	numTIs : Integer;
begin
	numTIs := self.allTrackedItems.size;
	foreach ti in self.allTrackedItems do	// if the existing Tis are planned or queued to be moved then ignore them
		if ti.queuedLocnId &lt;&gt; null then
			numTIs := numTIs - 1;
		elseif ti.plannedLocnId &lt;&gt; null then
			numTIs := numTIs - 1;
		endif;
	endforeach;

	if _ti = null then
		index := numTIs + 1;
	elseif self.allTrackedItems.includes(_ti) then
		index := self.allTrackedItems.indexOf(_ti);
	elseif self.allQueuedFutureMoves.containsTI(_ti) then
		index :=  numTIs + self.allQueuedFutureMoves.getIndexOfTI(_ti);
	elseif self.allPlannedFutureMoves.containsTI(_ti) then
		index := numTIs + self.allQueuedFutureMoves.size + self.allPlannedFutureMoves.getIndexOfTI(_ti); //21 May 2015	Par 36169
	endif;
	
	if index = 0 or self.myWagon = null or self.myWagon.myWagonClass = null then
		return null;
	elseif self.myWagon.myWagonClass.tierIds.isEmpty then
		return null;
	elseif index &gt; 0 and self.myWagon.myWagonClass.tierIds.size &lt; index then
		index := 1;
	endif;
	return self.myWagon.myWagonClass.tierIds[index];	
		
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransport" id="b682b49b-3b11-43e6-9bce-3ddb699e40e3">
        <source>getTransport(_isLoad : Boolean): CM_Object;
/*
Purpose:			

Date		Who		Reason
15 December 2021	navab1	TFS 51855
*/

vars

begin
	if self.myWagon &lt;&gt; null then
		if _isLoad then
			return self.myWagon.myTrainOutwards;
		else
			return self.myWagon.myTrainInwards;
		endif;
