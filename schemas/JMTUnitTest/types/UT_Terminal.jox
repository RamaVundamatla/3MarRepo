    <JadeMethod name="checkExpectedError" id="505e92b5-3ddd-42f8-9a99-741117b59d26">
        <updating/>
        <source>checkExpectedError(exObj: Exception; _passport : CM_Passport input; _expectedError : Boolean output): Integer updating, protected;
/*

Purpose:			Creating this to handle and check expected error as the error is not raised in the standard TRX framework

Parameters:			

Return Value:		

Date		Who		Reason
17/09/2025	navkc1 JIRA 35860 MSL - Cargo ID Partial Search Configuration

*/

vars

begin
	if exObj.errorCode = MinCharToPerformSearch then
		if self.expectedTrxErrors.includes(MinCharToPerformSearch) then
			_expectedError := true;
		endif;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_expectedError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createContainerOnShip" id="279dfd1a-d8e5-4ba4-b5c8-8499dc20ded0">
        <source>createContainerOnShip(_contractId, _id : String; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer) : CM_Container;
/*
Purpose:			

Date		Who		Reason
26 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	cont : CM_Container;
begin
	self.deleteContainer(_id);

	self.opts.purge();
	
	cont := self.addContainerOnShip( _id , _operator, "2200", "GENL", null, _voyage, _port.code, _voyage.code).CM_Container;
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight",_weight);
	self.opts.addAssoc("Mark",'GREEN');

	self.updateTI(cont);

	self.assertTrueMsg(cont.contractId = _contractId, "Container Contract Id is wrong");
	assertEqual(cont.totalWeight, _weight.Decimal);

	return cont;
epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="deleteScanReader" id="ca84cf30-5617-48b3-85d3-ec1971890003">
        <source>deleteScanReader(_deviceId : String; _terminal : CM_Terminal);
/*

Purpose:			Deletes a Scan Reader

Parameters:			_deviceId	String	The device id of the Scan Reader

Return Value:		NONE

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	scanReader : CM_ScanReaderObj;
	
begin
	foreach scanReader in _terminal.allScanReaders do
		if scanReader.deviceId = _deviceId then
			beginTransaction;
				delete scanReader;
			commitTransaction;
			break;
			
		endif;
	
	endforeach;

end;</source>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="tBulkEditSimple01" id="f23fcbb0-4b97-40b5-b7f3-7173155378bf">
        <source>tBulkEditSimple01();
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/
constants
	MapName						: String = "UT_ReceiveAB";
	CONTRACTID = "UT_221206-02";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_101";
	CONTID1 = "CNTU230126";
	CARGOID1 = "VB230126";
	VOYAGE2 = "UTVB_202";
	CONTID2 = "CNTU230130";
	CARGOID2 = "VB230130";

vars
	operator : CM_Operator;
	tis : CM_TISet;
	idx : Integer;
	ti : CM_TrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	agent : CMIF_TIBulkUpdateAgent;
	idstr : String;
	now : Date;
	edit : CM_Edit;
	fldVal : CM_Strings;
begin
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	idstr := now.formatAsYYMMDD();
	
	create tis transient;
	foreach idx in 1 to 5 do
		ti := self.createContainerOnShip("", "CNTU" &amp; idstr &amp;  idx.stringWithLeadingZeros(1), operator, voyage, aPort,15000);
		tis.add(ti);
	endforeach;
	
	create agent transient;
	agent.init(tis);
	agent.addProperty(ETRow_Mark,CM_TrackedItem::mark,"RED");
	
	app.myTrxUA.trxUpdateTIsForBulkEditSimple(agent, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("");
	
	foreach ti in tis do
		edit := ti.getLastTransOfType(TRANS_TYPE_EDIT).CM_Edit;
		
		self.assertTrueMsg(edit &lt;&gt; null, ti.id &amp; " EDIT is null");
		self.assertTrueMsg(edit.fieldsValues &lt;&gt; null, ti.id &amp; " EDIT FIELD VALUES is null");
		fldVal := edit.fieldsValues;
		self.assertTrueMsg(fldVal.numStrings = 1, ti.id &amp; " EDIT FIELD VALUES is not ONE");
		
//	write "&gt;&gt;&gt;" &amp;  edit.fieldsValues.getString01() &amp; "&lt;&lt;&lt;";
		self.assertTrueMsg(fldVal.includes("mark GREEN =&gt; RED") &lt;&gt; 0, ti.id &amp; " EDIT should be Green to Red");
		
	endforeach;
	
	
	foreach ti in tis do
		self.deleteTrackedItem(ti, false);
	endforeach;
	
	self.deleteVessel(VESSEL);
	self.deleteVoyage(VOYAGE1);
epilog
	agent.allProperties.purge;
	delete agent;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCargoPartialSearchConfig" id="69d7d344-8b8a-40f4-98b3-81741b58d6da">
        <updating/>
        <source>tCheckCargoPartialSearchConfig() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/09/2025	navkc1 JIRA 35860 MSL - Cargo ID Partial Search Configuration

*/

constants
	TIID 	= "UTPART1";
	TRUCKID = "UTPARTT";
vars
	term		: CM_Terminal;
	ti			: CM_TrackedItem;
	vvr			: CM_VehicleVisitRecord;
	searchCtrl	: CMIF_QuickViewController;
	val			: Boolean;
	expectedEx	: Boolean;
begin
	on Exception do self.checkExpectedError(exception, app.myPassport, expectedEx);
	
	term := self.getMyTerminal();
	
	// Delete TI
	ti := self.getTrackedItem(TIID);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
	endif;
	
	// Gate in TI
	self.deleteVehicle(TRUCKID);
	vvr := self.gateInContainer(TRUCKID, TIID, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	self.assertNotNullMsg(vvr, "Failed to create VVR");
	self.workVehicle(vvr);
	
	// Get TI
	ti := self.getTrackedItem(TIID);
	self.assertNotNullMsg(ti, "Failed to get the TI");
	
	// Set Config, minimum character to 3
	self.setTerminalConfig(WpMinCharPartialSearch, 3);
	
	/*===================================
	Test entering less than min number of characters required, 
	should get an error
	=====================================
	*/
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(MinCharToPerformSearch);
		create searchCtrl transient;
		searchCtrl.setTerminal(term);
		searchCtrl.canDoPartialMatch := true;
		searchCtrl.id := "T";
		
		val := searchCtrl.doSearch();
		self.assertTrueMsg(expectedEx, "Invalid exception raised");
		self.assertTrueMsg(val = false, "Should return false in this validation");
		self.clearExpectedTrxErrors();
		
	/*===================================
	Test entering more than min number of characters required, 
	should get the TI in the search result
	=====================================
	*/
		searchCtrl.id := "UTPART";
		
		val := searchCtrl.doSearch();
		self.assertTrueMsg(val = true, "Should return true in this validation");
		self.assertTrueMsg(searchCtrl.allTIs.includes(ti), "TI should be in the search result.");
	
epilog
	delete searchCtrl;
	
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
	endif;
	
	// Disarm the exception handler
	on Exception do null;
end;</source>
    </JadeMethod>
