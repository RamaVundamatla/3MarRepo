    <JadeMethod name="doBuildComboVoyages" id="9e3d45d6-75c6-45f7-b17b-89c4c5bc3b3b">
        <source>doBuildComboVoyages();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars

begin
	self.allVoyages.clear;
//	self.myTerminal.getAllVoyagesNPNWScreen(self.allVoyages, true, app.myPassport);
	self.myTerminal.getAllCurrentCellularVoyages(self.allVoyages, false, false);	//17 Mar 2017	NDL TFS 3754
	self.cmbVoyage.listCollection(self.allVoyages, false, 0);

	if self.myCurrentVoyage &lt;&gt; null then
		if self.cmbVoyage.findObject(self.myCurrentVoyage) &gt; 0 then
			self.cmbVoyage.listObject := self.myCurrentVoyage;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="6d4817fa-a62e-47f2-95b4-9b6ef34eabae">
        <updating/>
        <source>doSave() updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars
	pxyJob, realJob : CM_VoyageJob;
    pxyShift, realShift, tmpShift : CM_Shift;
    shiftCode : String;
    shiftDesc : String;
	startTSSystem, endTSSystem : TimeStamp;
	theReturn : Integer;
	loadState : Boolean;
	startTS, endTS : TimeStamp;

	allOtherJobs : CM_VoyageJobSet;	//17 Mar 2017	NDL	TFS 3785
	rowIndex : Integer;	//17 Mar 2017	NDL	TFS 3785
	
begin

	if myCurrentJob= null then
		return;
	endif;
	
	//17 Mar 2017	NDL	TFS 3785
	create allOtherJobs transient;
	foreach rowIndex in 1 to self.tblData.rows do
		if self.tblData.accessRow( rowIndex ).selected then
			realJob :=  self.tblData.accessRow( rowIndex ).itemObject.CM_VoyageJob;
			if realJob = null or realJob = self.myCurrentJob then
				continue;
			endif;
			allOtherJobs.add( realJob );
		endif;
	endforeach;


	app.cmsBeginLoad(loadState);
	pxyJob := self.myCurrentJob.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	// sort out shift start and end times
	startTS := null;
	endTS := null;
	if self.txtShiftStartDate.getDate &lt;&gt; null then
		startTS.setDate(self.txtShiftStartDate.getDate);
		startTS.setTime(self.txtShiftStartTime.getTime);
		startTSSystem := startTS;	
	endif;
	if self.txtShiftEndDate.getDate &lt;&gt; null then
		endTS.setDate(self.txtShiftEndDate.getDate);
		endTS.setTime(self.txtShiftEndTime.getTime);
		endTSSystem := endTS;	
	endif;
	
	
	tmpShift := self.cmbShifts.listObject.CM_Shift;
	
	if tmpShift &lt;&gt; null then
		realShift := self.myTerminal.allShiftsDay[tmpShift.startDateTime, tmpShift.code];
		if realShift &lt;&gt; null then
			pxyShift := app.myProxyManager.getProxyObject(realShift).CM_Shift;
			if pxyShift = null then
				pxyShift := app.createUpdateProxy(realShift).CM_Shift;
			endif;
			shiftCode := realShift.code;
			shiftDesc := realShift.description;
		else
			shiftCode := tmpShift.code;
			shiftDesc := tmpShift.description;
		endif;
	else
		pxyShift := pxyJob.myShift;
	endif;
	if pxyShift = null then
		create pxyShift transient;
	endif;
	
	if pxyShift &lt;&gt; pxyJob.myShift then
		pxyJob.setMyShift(pxyShift);
	endif;
	pxyShift.setProxy(null, startTSSystem.time, endTSSystem.time, shiftCode, shiftDesc, self.myTerminal, false);
	pxyShift.startDateTime := startTSSystem;
	pxyShift.endDateTime := endTSSystem;
	pxyShift.setRemarks(self.txtShiftRemarks.text);
	
	while true do
		app.myTrxUA.trxUpdateVoyageJobShift(pxyJob, allOtherJobs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog
	delete pxyShift;
	delete pxyJob;
	delete allOtherJobs;	//17 Mar 2017	NDL	TFS 3785
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectJob" id="70c79847-e4fb-4bd0-b830-0f5134068fef">
        <updating/>
        <source>doSelectJob(_job : CM_VoyageJob input) updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars
	shiftString : String;
begin
	self.mnuInspectObject.userObject := _job;
	self.myCurrentJob := _job;
	
	if _job &lt;&gt; null then
		if _job.myShift &lt;&gt; null then
			shiftString := _job.myShift.getShiftDay &amp; Space &amp; _job.myShift.code &amp; Space &amp; _job.myShift.startDateTime.date.asStringJMT();
			self.cmbShifts.listIndex := self.cmbShifts.findStringExact(1, shiftString);
			
			self.doSelectShift(_job.myShift);
		else
			self.cmbShifts.listIndex := -1;
			self.doSelectShift(null);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSelectShift" id="f7dd1e9c-de26-4c40-b076-b39f7e43753f">
        <source>doSelectShift(_shift : CM_Shift);
/*
Purpose:			
Date				Who			Reason
FEB 2017		CNWAB1		Initial creation
*/

vars
	shift : String;

begin
	self.txtShiftStartDate.text := null;
	self.txtShiftStartTime.text := null;
	self.txtShiftEndDate.text := null;
	self.txtShiftEndTime.text := null;
	self.txtShiftRemarks.text := null;

	if _shift = null then
		return;
	endif;
	
	shift := _shift.getShiftDay &amp; Space &amp; _shift.code &amp; Space &amp; _shift.startDateTime.asStringJMT();
	self.txtShiftStartDate.text := _shift.startDateTime.date.asStringJMT;
	self.txtShiftStartTime.text := _shift.startDateTime.time.asStringJMT;
	self.txtShiftEndDate.text := _shift.endDateTime.date.asStringJMT;
	self.txtShiftEndTime.text := _shift.endDateTime.time.asStringJMT;
	
	if _shift.remarks &lt;&gt; null then
		self.txtShiftRemarks.text := _shift.remarks;
	endif;
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="6e85f56c-acd8-459b-800f-80effb674ed9">
        <source>loadCombos();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancenments
//
vars
	startDT, endDT : TimeStamp;
	workPoint : CM_WorkPoint;
	idx : Integer;

begin
	
	// load shifts for the period the voyage is in harbour
	startDT := self.myCurrentVoyage.getArrivalDT;
	endDT := self.myCurrentVoyage.getDepartureDT;
	self.allShiftsDays.purge;
	self.cmbShifts.clear;
	self.cmbShifts.sorted := false;
	self.myTerminal.getShiftsFromRange(self.allShiftsDays, startDT, endDT);
	self.cmbShifts.listCollection(self.allShiftsDays, false, ComboBox.DisplayCollection_Forward);
	
	self.loadJobs();	//17 Mar 2017	NDL	TFS 3754
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadJobs" id="48858f8a-b08b-42b5-b32e-af2b1ae7bf06">
        <source>loadJobs();
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars

    vjob : CM_VoyageJob;
	job : CM_Job;

	entDef : EntTableDef;
    str : String;
begin

	if self.myCurrentVoyage = null then
		return;
	endif;
		
	
	self.tblData.rows := 1;
	
	entDef := app.myController.getEntTableDef(ETDef_CraneShift);
	self.tblData.setMyEntTableDef( entDef );
	self.tblData.setTblDataEntRowsFromDef( entDef );
	//self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_BaseTable.SelectionType_Row;	//17 Mar 2017	NDL	TFS 3785
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;	//17 Mar 2017	NDL	TFS 3785
	self.tblData.rows := self.tblData.fixedRows;
	
	foreach job in  self.myCurrentVoyage.allVoyageJobs discreteLock do
		vjob := job.CM_VoyageJob;
		str := vjob.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

		self.tblData.addItemObject(vjob, str);
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
