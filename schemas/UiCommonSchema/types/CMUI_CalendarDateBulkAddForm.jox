    <JadeMethod name="doCreateRealDates" id="389406a6-0b14-4a34-91db-ee5ad86e99ff">
        <source>doCreateRealDates();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Oct 2010	cnwndl1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	calendarDate : CM_CalendarDate;
	calendarDateProxy : CM_CalendarDate;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;
	iter : Iterator;
	invalidObject : Boolean;
	year : Integer;
	theReturn : Integer;
	sendNotification : Boolean;
	count : Integer;
	msg : String;

begin

	iter := self.allTransCalendarDates.createIterator;
	
	on Exception do app.handleDeletedObject(exception, calendarDateProxy, invalidObject);
	
	while iter.next( calendarDateProxy ) do
	
		year := calendarDateProxy.date.year;
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		
		calendarYear := self.myCalendar.allCalendarYears.getAtKey(year);
		if calendarYear = null then
		
			// have to create a new calendar year first...
			create calendarYearProxy transient;
			calendarYearProxy.setProxy( year, self.myCalendar);
		
			while true do
				app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
				if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					delete calendarYearProxy;
					sendNotification := true;
					self.clearErrorWarnings();
					break;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(Calendar), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					return;
				endif;
				break;
			endwhile;
			
		endif;
		
		// set up the calendar and calendar year on the calendar date transient.
		calendarDateProxy.setProxy(	calendarDateProxy.date,	//_date : Date;
									calendarDateProxy.description,	//_description : String;
									self.myCalendar,	//_myCalendar : CM_Calendar;
									calendarYear,	//_myCalendarYear : CM_CalendarYear;
									calendarDateProxy.dataSource	//_dataSource : Integer
									);
									
		count := count + 1;
								
		
		while true do
			app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, calendarDate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				delete calendarDateProxy;
				self.clearErrorWarnings();
				sendNotification := true;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Calendar), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
		
	endwhile;
	
	if sendNotification then
		self.myCalendar.causeEvent(EVENT_Calendar_Update, true, self.myCalendar);
	endif;
	
	self.populateTblDayData();
	
	if sendNotification then
		if count &gt; 0 then
			msg := app.getErrorString2(Calendar_entries_created, count.String, self.myCalendar.description);
			app.msgBox( msg, app.getErrorString(Calendar), MsgBox_OK_Only);
		endif;
	endif;

epilog
	delete calendarYearProxy;
	delete iter;		// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateRealDatesFinancial" id="235fe1c1-9c7c-42ef-9f5f-745833e5f68a">
        <source>doCreateRealDatesFinancial();
/*
Purpose:			TFS 215
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/

vars

	calendarDate : CM_CalendarDate;
	calendarDateProxy : CM_CalendarDate;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;
	iter : Iterator;
	invalidObject : Boolean;
	year : Integer;
	theReturn : Integer;
	sendNotification : Boolean;
	count : Integer;
	msg : String;
	finDateTime : CM_FinancialPeriodDateTime;
	tmpTS : TimeStamp;
	allProxyDates : CM_FinancialPeriodDateTimeDict;
begin

	iter := self.allTransCalendarDates.createIterator;
	
	on Exception do app.handleDeletedObject(exception, calendarDateProxy, invalidObject);
	
	create allProxyDates transient;
	
	foreach calendarDateProxy in self.allTransCalendarDates discreteLock do
		tmpTS.setDate(calendarDateProxy.date);
		if invalidObject then
			continue;
		endif;
		
		tmpTS.setTime(calendarDateProxy.startTime);
		
		create finDateTime transient;
		finDateTime.setProxy(tmpTS,calendarDateProxy.description,self.myCurrentFinancialPeriodType);
		
		allProxyDates.add(finDateTime);
		
		count := count + 1;
								
	endforeach;
		
	while true do
		app.myTrxCA.trxCreateFPDateTimeBulk(self.myCurrentFinancialPeriodType, allProxyDates);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			delete calendarDateProxy;
			self.clearErrorWarnings();
			sendNotification := true;
			self.allTransCalendarDates.clear();
		
			self.initTblDayData();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Calendar), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
		

epilog
	allProxyDates.purge;
	delete allProxyDates;
	delete iter;		
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c400dfa9-899d-4b3b-a4dd-853b2d01867e">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	vLeft : Real;
	vWidth : Real;

begin

	inheritMethod();
	
	vLeft := 1;
	self.grpType.left := vLeft;
	self.grpSelect.left := vLeft;
	self.grpDayData.left := vLeft;
	
	
	vWidth := self.width - 10;
	self.grpType.width := vWidth;
	self.grpSelect.width := vWidth;
	self.grpDayData.width := vWidth;
	self.grpDateButtons.width := grpDayData.width - 10;
	
	self.grpType.top := 5;
	self.grpType.height := 30;
	
	self.grpSelect.top := self.grpType.top + self.grpType.height;
	self.grpDayData.top := self.grpSelect.top + self.grpSelect.height;
	
	self.tblTemplates.width :=  (( self.grpSelect.width - self.tblTemplates.left  ) / 2 ) - 10;
	self.tblLabels.left := self.tblTemplates.left + self.tblTemplates.width + 5;
	self.tblLabels.width :=  self.tblTemplates.width;
	self.tblLabels.height := self.tblTemplates.height;
	
	self.tblDayData.width := self.grpDayData.width - self.tblDayData.left - 5;
	self.tblDayData.height := self.grpDayData.height - self.tblDayData.top - self.grpDateButtons.height - 5;
	self.grpDateButtons.top := self.tblDayData.top + self.tblDayData.height;
	
	self.frmProxyMaint.left := ( self.width - self.frmProxyMaint.width ) / 2;
	self.frmProxyMaint.top := ( self.height - self.frmProxyMaint.height ) / 2;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowProxyDateMaint" id="564d127e-dd51-488f-84d1-145242fa315d">
        <source>doShowProxyDateMaint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

	transCalendarDate : CM_CalendarDate;

begin

	transCalendarDate := self.tblDayData.allSelectedObjects.last.CM_CalendarDate;
	if transCalendarDate &lt;&gt; null then
		self.frmProxyMaint.visible := true;
		self.grpDayData.enabled := false;
		self.grpSelect.enabled := false;
		self.grpType.enabled := false;
		self.txtProxyDate.setDate(transCalendarDate.date);
		self.txtProxyDesc.text := transCalendarDate.description;
		self.txtProxyStart.setTime(transCalendarDate.startTime);
		self.txtProxyEnd.setTime(transCalendarDate.endTime);
		self.txtProxyStart.enabled := myCalendar.hasTime;
		self.txtProxyEnd.enabled := myCalendar.hasEndTime;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="genDatesByDay" id="342c1005-d5eb-4c0a-9911-6949559e13f1">
        <source>genDatesByDay( templateRow : JadeTableRow; label : String io; startDate : Date; endDate : Date; startTime : Time; endTime : Time ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation
11/03/2015		cnwmh5	Transient Leak

*/

vars

	templateCalendarDate : CM_CalendarDate;
	transCalendarDate : CM_CalendarDate;
	loopDate : Date;
	nullTime : Time;
	hookDayNamesArray : StringArray;
	hookCalendar : CM_Calendar;

begin

	templateCalendarDate := templateRow.itemObject.CM_CalendarDate;
	if templateCalendarDate = null then
		return;
	endif;
	if label = null then
		label := templateCalendarDate.description;
	endif;
	
	nullTime := "00:00:00".Time;
	
	loopDate := startDate - 1;
	
	while loopDate &lt; endDate do
	
		loopDate := loopDate + 1;
		
		if self.myCalendar.myHookCode &lt;&gt; null then
			
			delete hookDayNamesArray;
			create hookDayNamesArray transient;
			self.dayListArray.copy(hookDayNamesArray);
			hookCalendar := self.myCalendar;
			if not app.myHookAgent.runHookLinkPublic(	HookType_CalendarDay,
														self.myCalendar,
														self.myCalendar,
														hookDayNamesArray,	//_dayNamesArray : StringArray; 
														hookCalendar,	//_calendar : CM_Calendar;
														templateCalendarDate,	//_templateCalendarDate : CM_CalendarDate;
														loopDate	//_proposedDate : Date
														).Boolean then
				continue;
			endif;
		
		else
			if not app.myRoot.isCandidateCalendarDate( self.dayListArray, self.myCalendar,  templateCalendarDate,  loopDate ) then
				continue;
			endif;
			
		endif;
		
		if loopDate = startDate then
			if startTime &lt;&gt; nullTime and endTime &lt;&gt; nullTime and templateCalendarDate.endTime &lt; startTime then
				//too early.
				continue;
			endif;
		elseif loopDate = endDate then
			if endTime &lt;&gt; null and templateCalendarDate.startTime &gt; endTime then
				// too late.
				continue;
			endif;
		endif;
		
		if self.financialPeriodMode then
			label := loopDate.dayName() &amp; " " &amp; loopDate.cnEcWeekOfMonth().String &amp; " " &amp; loopDate.monthName();
		endif;
		
		// if we get to here we have a live one...
		create transCalendarDate transient;
		
		transCalendarDate.setProxy(	loopDate,	//_date : Date;
									label,	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									templateCalendarDate.dataSource	//_dataSource : Integer
									);
		transCalendarDate.setStartEndTime(	startTime,	//_startTime : Time;
											endTime	//_endTime : Time
											);
		self.allTransCalendarDates.add(transCalendarDate);
		
	endwhile;
	
epilog

	delete hookDayNamesArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="templateRow" type="JadeTableRow"/>
        <Parameter name="label" type="String" usage="io"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startTime" type="Time"/>
        <Parameter name="endTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="genDatesByMonth" id="16ac00cb-191f-4ebf-b0f5-0537b54529a8">
        <source>genDatesByMonth( templateRow : JadeTableRow; label : String io; startDate : Date; endDate : Date; startTime : Time; endTime : Time ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation
11/03/2015		cnwmh5	Transient Leak
*/

vars

	templateCalendarDate : CM_CalendarDate;
	transCalendarDate : CM_CalendarDate;
	loopDate : Date;
	nullTime : Time;
	hookDayNamesArray : StringArray;
	hookCalendar : CM_Calendar;

begin

	templateCalendarDate := templateRow.itemObject.CM_CalendarDate;
	if templateCalendarDate = null then
		return;
	endif;
	if label = null then
		label := templateCalendarDate.description;
	endif;
	nullTime := "00:00:00".Time;
	
	loopDate := startDate - 1;
	
	while loopDate &lt; endDate do
		loopDate := loopDate + 1;
		
		if self.myCalendar.myHookCode &lt;&gt; null then
			
			delete hookDayNamesArray;
			create hookDayNamesArray transient;
			self.dayListArray.copy(hookDayNamesArray);
			hookCalendar := self.myCalendar;
			if not app.myHookAgent.runHookLinkPublic(	HookType_CalendarDay,
														self.myCalendar,
														self.myCalendar,
														hookDayNamesArray,	//_dayNamesArray : StringArray; 
														hookCalendar,	//_calendar : CM_Calendar;
														templateCalendarDate,	//_templateCalendarDate : CM_CalendarDate;
														loopDate	//_proposedDate : Date
														).Boolean then
				continue;
			endif;
		
		else
			if  not app.myRoot.isCandidateCalendarDate( self.dayListArray, self.myCalendar,  templateCalendarDate,  loopDate ) then
				continue;
			endif;
			
		endif;
		
		
		if loopDate = startDate then
			if startTime &lt;&gt; nullTime and endTime &lt;&gt; nullTime and templateCalendarDate.endTime &lt; startTime then
				//too early.
				continue;
			endif;
		elseif loopDate = endDate then
			if endTime &lt;&gt; null and templateCalendarDate.startTime &gt; endTime then
				// too late.
				continue;
			endif;
		endif;
		
		// if we get to here we have a live one...
		create transCalendarDate transient;
		
		
		if self.financialPeriodMode then
			label := loopDate.year.String &amp; " " &amp;  loopDate.monthName;
		endif;
		
		transCalendarDate.setProxy(	loopDate,	//_date : Date;
									label,	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									templateCalendarDate.dataSource	//_dataSource : Integer
									);
		transCalendarDate.setStartEndTime(	startTime,	//_startTime : Time;
											endTime	//_endTime : Time
											);
											
		self.allTransCalendarDates.add(transCalendarDate);
		
	endwhile;
	
epilog

	delete hookDayNamesArray;

end;</source>
        <access>protected</access>
        <Parameter name="templateRow" type="JadeTableRow"/>
        <Parameter name="label" type="String" usage="io"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startTime" type="Time"/>
        <Parameter name="endTime" type="Time"/>
