    <JadeMethod name="healthCheckIsValid" id="91c5119c-6c6a-4b13-9932-72baa9c03ae4">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;




/*
	term := self.getMyTerminal();
	if term = null then // if terminal is null it could be because the bank is null
		// ### Business Unit
		if not self.healthCheckObject(self.bank, resultType) then
			create detail transient;
			detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Bank, self.name, CMIF_InvoiceHealthAgent.ItemType_Service, self.getMyTerminal(), resultType, self);
			return false;
		else
			return true;
		endif;
	endif;
	
	if not _agent.allTerminals.includes(term) then
		return true;
	endif;
*/
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Bank)
	and not self.healthCheckObject(self.bank, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Bank, self.name, CMIF_InvoiceHealthAgent.ItemType_Service, self.getMyTerminal(), resultType, self);
		return false;
	endif;

	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_GLCode)
	and not self.healthCheckObject(self.genLCode, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_GLCode, self.name, CMIF_InvoiceHealthAgent.ItemType_Service, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Tax)
	and not self.healthCheckObject(self.myTaxCode, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Tax, self.name, CMIF_InvoiceHealthAgent.ItemType_Service, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	return true;
	
epilog
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b7f199c2-24e8-4ed2-9d32-a888728b9296">
        <updating/>
        <source>setForCreate(_pxyService : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.name := _pxyService.name;
	self.bank := _pxyService.bank;
	self.remarks := _pxyService.remarks;
	self.genLCode := _pxyService.genLCode;
	self.group := _pxyService.group;
	self.myTaxCode := _pxyService.myTaxCode;
	self.isNotAvailableForEntry := _pxyService.isNotAvailableForEntry;
end;</source>
        <Parameter name="_pxyService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="601c791d-44ce-48f5-9e68-3daacffa1cac">
        <updating/>
        <source>setForUpdate(_pxyService : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.name := _pxyService.name;
	self.bank := _pxyService.bank;
	self.remarks := _pxyService.remarks;
	self.genLCode := _pxyService.genLCode;
