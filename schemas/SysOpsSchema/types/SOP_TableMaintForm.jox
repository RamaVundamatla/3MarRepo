    <JadeMethod name="comboBoxVehicleBookingRules" id="f726174d-922d-4bb3-adb2-3653d3223775">
        <source>comboBoxVehicleBookingRules( _cmb : ComboBox input; _value : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	idx : Integer;

begin

	_cmb.clear();
	_cmb.sorted := false;
	
	idx := _cmb.addItem(CM_VehicleBookings.BVR0);
	idx := _cmb.addItem(CM_VehicleBookings.BVR1);
	
	if _value &lt;&gt; null then
		_cmb.listIndex := _cmb.findStringExact(1,_value);
	endif;
	
	if _cmb.listIndex &lt; 1 then
		_cmb.listIndex := _cmb.findStringExact(1,CM_VehicleBookings.BVR0);
	endif;
	

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="3d127fd9-1b90-476c-bc00-f6dd1d6c5ae0">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 June 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// This is ok as the actual permissions are set
	// when the user selects an option from the combo box
	// Permissions for opening are set in the setAllTblItems method
	
	
	// This form is used for sys admin and term admin. To show it on the navigator you set PmAdmTabledefineView for terminal admin and PmAdmSystemTableView for system admin
	
	
	self.permissionView  := PmAdmTabledefineView; // TFS 2180 this setting is needed to run Terminal Admin, but not to run System Admin
// TFS 2180	self.permissionMaint := 0;
	
	self.helpFileName	:=	HelpFile_SystemCodes;
	
end;</source>
    </JadeMethod>
