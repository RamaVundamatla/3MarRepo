    <JadeMethod name="create" id="88bc6d5e-2da0-4b05-9f2e-b2942e8f90a0">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView 	:= PmAdmCargoEnquiryView;
	self.permissionMaint 	:= PmAdmCargoEnquiryMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPxyAddStops" id="056d5618-58dd-4220-ba6d-5090d36568eb">
        <source>doPxyAddStops( _stopsTable : CM_StopsTable; _coll : CM_TISet ) protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	proxyTI 	: CM_TrackedItem;
	pxyStop		: CM_Stops;
	
begin
	foreach proxyTI in _coll do
		if _stopsTable.requiresInfo then
			// reset any requires information fields that have been previously set
			// eg for Delivery Release number - this field must be null prior to the stop being added.
			proxyTI.setRequiresInformation( _stopsTable.requiresInfoType, null );
		endif;
		
		pxyStop	:= proxyTI.getStop( _stopsTable.id );
		
		if pxyStop = null then 
			create pxyStop transient;
			
			pxyStop.id	:= _stopsTable.id;
			// checks that the cargo type is OK - should not fail because we checked when we loaded the form
			if not pxyStop.setMyTrackedItem( proxyTI ) then
				// we will never get here as the method raises an exception
				delete pxyStop; 
				return;
			endif;
		endif;
		// expiry date should be null for a new stop
		pxyStop.setClearanceExpiryDate( null );
		
		// cnwrl1 27/08/2010 PAR 23697 - start of coding
		// stop override reason should be null if adding a stop, it might have been set previously.
		pxyStop.setPxyStopOverrideReason( null );
	endforeach;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_coll" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="doPxyCancelStops" id="c7535935-a0e6-4935-9f08-da2258df0017">
        <source>doPxyCancelStops( _stopsTable : CM_StopsTable; _coll : CM_TISet ) protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	proxyTI 	: CM_TrackedItem;
	pxyStop	: CM_Stops;
	
begin	
	foreach proxyTI in _coll do
//		pxyStop	:= proxy.getStopByIDAsAtDate( _stopsTable.id, CM_Stops.Away_In_The_Future_Date );	// cnwrl1 21/09/2010 PAR 23697 - what it was
		pxyStop	:= proxyTI.getStop( _stopsTable.id );
		
		if pxyStop &lt;&gt; null then
			pxyStop.pxySetCancelStop;
		endif;
	endforeach;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_coll" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="doPxyClearStops" id="e44873fb-13b9-4867-be4f-3701dec38dbd">
        <source>doPxyClearStops( _stopsTable : CM_StopsTable; _coll : CM_TISet input; _inputData : String; _expiryDate : Date ) protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
// 26/09/2025   navvk1		MTN-36140: Fix Error Code: 75793
vars
	proxyTI 	: CM_TrackedItem;
	pxyStop		: CM_Stops;
	toRemove  : CM_TISet;    // children to prune after iteration MTN-36140
	
begin	
	create toRemove transient;
	foreach proxyTI in _coll do
		pxyStop	:= proxyTI.getStop(_stopsTable.id);
		// MTN-36140
		// If this is a child AND its parent is also selected AND the child does not (and cannot) hold this stop
        // (e.g. Stop Table Processing Option = Remove when Child), then skip the child.
        if proxyTI.isChild and proxyTI.myParent &lt;&gt; null and _coll.includes(proxyTI.myParent) then
            if pxyStop = null then
                // Parent holds the stop; we will clear it via the parent only.
                toRemove.add(proxyTI);
                continue;
			elseif pxyStop &lt;&gt; null then
				toRemove.add(proxyTI);
            endif;
        endif; // MTN-36140
		
		// stop not set for this ti so can't clear it
		if pxyStop = null then
			continue;
		endif;
		// record any information that must be captured to clear the stop
		if _stopsTable.requiresInfo then
			proxyTI.setRequiresInformation( _stopsTable.requiresInfoType, _inputData );
		endif;
		// record expiry date if set and relevant
		if _stopsTable.allowClearanceExpiryDate and _expiryDate &lt;&gt; null then
			// don't delete - just set the clearance date (what if date is null - we won't be able to tell);
			pxyStop.setClearanceExpiryDate( _expiryDate );
		else
			// we need to delete the stop 
			delete pxyStop;
		endif;
		
	endforeach;
	// MTN-36140 Remove pruned children so trxUpdateTrackedItems does not attempt edition check on them.
    foreach proxyTI in toRemove do
        _coll.remove(proxyTI);
    endforeach; // MTN-36140
	
epilog
	delete toRemove; // MTN-36140
end;
</source>
        <access>protected</access>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_coll" type="CM_TISet" usage="input"/>
        <Parameter name="_inputData" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doPxyOverrideStops" id="3c78cecd-ca44-42f8-80f1-edbc211eea6f">
        <source>doPxyOverrideStops(
	_stopsTable		: CM_StopsTable;
	_coll			: CM_TISet;
	_inputData		: String;
	_expiryDate		: Date;
	_overrideReason	: CM_StopOverridenReason ) protected;
	
/*
Date			Who		Reason
23 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	proxyTI			: CM_TrackedItem;
	pxyStop			: CM_Stops;
	
begin
	foreach proxyTI in _coll do
		pxyStop	:= proxyTI.getStop( _stopsTable.id );
		// stop not set for this ti so can not override it
		if pxyStop = null then
			continue;
		endif;
		pxyStop.pxySetOverrideStop();		// sets the action.
		
		// record any information that must be captured to clear the stop
		if _stopsTable.requiresInfo then
			proxyTI.setRequiresInformation( _stopsTable.requiresInfoType, _inputData );
		endif;
		
		// record expiry date if set and relevant
		if _stopsTable.allowClearanceExpiryDate then
			pxyStop.setClearanceExpiryDate( _expiryDate );
		endif;
		
		// now set the override reason against this proxy stop
		pxyStop.setPxyStopOverrideReason( _overrideReason );
	endforeach;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_coll" type="CM_TISet"/>
        <Parameter name="_inputData" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_overrideReason" type="CM_StopOverridenReason"/>
    </JadeMethod>
    <JadeMethod name="doPxyUpdateStops" id="d6b55b9f-02f3-421d-8b9e-97121a5ac4d8">
        <source>doPxyUpdateStops( _stopsTable : CM_StopsTable; _coll : CM_TISet; _expiryDate : Date; _overrideReason : CM_StopOverridenReason ) protected;
// doPxyUpdateStops(_stopsTable :CM_StopsTable; _coll :CM_TISet; _date :Date)protected;	// cnwrl1 30/08/2010 PAR 23697 - what it was
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
vars
	proxyTI 	: CM_TrackedItem;
	realTI 		: CM_TrackedItem;
	proxyStop	: CM_Stops;
	realStop	: CM_Stops;
	
begin
		
	// cnwrl1 30/08/2010 PAR 23697 - start of replacement coding
	// If we are updating the clearanceExpiryDate then this stop will exist on the proxyTI
	// otherwise we need to create a proxtStop and add the updated overridden reason.
	foreach proxyTI in _coll do
		proxyStop	:= proxyTI.getStop( _stopsTable.id );
		if proxyStop &lt;&gt; null then
			proxyStop.pxySetUpdateStop();		// sets the action.	// cnwrl1 22/09/2010 PAR 23697
			if _stopsTable.allowClearanceExpiryDate then
				proxyStop.setClearanceExpiryDate( _expiryDate );
			endif;
			
			// cnwrl1 24/09/2010 PAR 23697 - start of coding
			// now set the override reason against this proxy stop
			proxyStop.setPxyStopOverrideReason( _overrideReason );
			// cnwrl1 24/09/2010 PAR 23697 - end of coding
			continue;
		endif;
		
		// Here the proxyTI will not contain the appropriate proxyStop,
		// so get the realTI and check if the required stop is on that.
		realTI		:= proxyTI.pxyGetRealObject().CM_TrackedItem;
		realStop	:= realTI.getStop( _stopsTable.id );
		if realStop = null then
			// This can happen if doing a bulk edit and this TrackedItem does not have the stop on it.
			continue;
		endif;
		proxyStop	:= realStop.pxyGetProxyObject();
		if proxyStop = null then
			// create a suitable proxy
			beginLoad;
			proxyStop	:=	realStop.pxyCreateUpdateProxy();
			endLoad;
		endif;
		proxyStop.pxySetUpdateStop();			// sets the action.	// cnwrl1 22/09/2010 PAR 23697
		// set the expiry date
		if _stopsTable.allowClearanceExpiryDate then
			proxyStop.setClearanceExpiryDate( _expiryDate );
		endif;
		
		// now set the override reason against this proxy stop
		proxyStop.setPxyStopOverrideReason( _overrideReason );
		// and add this stop to the proxyTI
		proxyStop.setMyTrackedItem( proxyTI );
	endforeach;
	// cnwrl1 30/08/2010 PAR 23697 - end of coding
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;
</source>
        <access>protected</access>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
        <Parameter name="_coll" type="CM_TISet"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_overrideReason" type="CM_StopOverridenReason"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="c92a37de-2774-410b-8cde-df7bd4d8353e">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// 01/09/2016   cnwma1		TFS #2628:PAR38184 STWO - Delivery Order Stop/ Kernel stack Overflow Error
// 26/09/2025   navvk1		MTN-36140: Fix Error Code: 75793

// ---------------------------------------------------------------------------
vars
	row					: Integer;
	rows				: Integer;
	result				: Integer;
	stopsTable			: CM_StopsTable;
	clearStop			: Boolean;
	cancelStop			: Boolean;
	overrideStop		: Boolean;					// cnwrl1 23/08/2010 PAR 23697
	addStop				: Boolean;
	updateStop			: Boolean;
	col					: Integer;					// cnwrl1 23/08/2010 PAR 23697
	overrideReason		: CM_StopOverridenReason;	// cnwrl1 23/08/2010 PAR 23697
	inputData			: String;
	expiryDate			: Date;
	ti					: CM_TrackedItem;
	proxy				: CM_TrackedItem;
	tiSet				: CM_TISet;	
	gotException		: Boolean;
	passport			: CM_Passport;
	table				: CM_DataTable;
	idArray				: StringArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	app.mousePointer	:= Busy;
	passport 			:= app.myPassport;
	
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	// Get proxy TrackedItems of all the selected TrackedItems to modify this stop on.
	create tiSet transient;
	create idArray transient;   //01/09/2016 cnwma1 TFS #2628
	foreach ti in self.allTrackedItems do
		if idArray.includes(ti.id) then   //01/09/2016 cnwma1 TFS #2628
			continue;
		endif;
		// navvk1 MTN-36140 Reuse existing proxy if already created in this app (prevents Error 75793).
		proxy := ti.pxyGetProxyObject().CM_TrackedItem;
		if proxy = null then
			proxy	:= app.createUpdateProxy( ti ).CM_TrackedItem;
		endif; // navvk1 MTN-36140
		
		if gotException then
			if ti = self.myTrackedItem then
				// display message and close form
				self.unloadFormWithMessage;
			else
				// ignore other invalid objects in the collection
				gotException := false;	// for next time
				
				continue;				// just don't update this one
			endif;
		endif;
		
		if ti = self.myTrackedItem then
			// latest version of ti will be in cache after creating proxy
			if ti.edition &gt; self.expectedEdition then
				// someone has updated it and we have not got the notification yet
				self.refreshFormWithMessage;
				return false;
			else
				// it will be hangled by trx
			endif;
		endif;
		
			idArray.add(proxy.id);   //01/09/2016 cnwma1 TFS #2628
			tiSet.add( proxy );

	endforeach;

		
	// in case altering multiple TIs get the main one
	//proxy	:= self.myTrackedItem.pxyGetProxyObject();   //01/09/2016 cnwma1 TFS #2628
	
	// start with stops to be added/updated
	table	:= self.tblStopsAdd;
	rows 	:= table.rows;
	row		:= table.fixedRows;
	
	while row &lt; rows do
		row 		:= row + 1;
		addStop 	:= (table.getCellValueByName (ETRow_Add, row) = 1.String);
		updateStop 	:= (table.getCellValueByName (ETRow_Update,row) = 1.String);
		
		if not addStop and not updateStop then
			// not being added or updated
			continue;
		endif;
		
		stopsTable 	:= table.accessRow(row).itemObject.CM_StopsTable;
		
		if addStop then
			// we are adding this stop
			self.doPxyAddStops (stopsTable, tiSet);
			
		elseif updateStop then
			expiryDate	:= table.getCellValueByName (ETRow_ClearanceExpiryDate, row).asDateJMT;
			
//			self.doPxyUpdateStops (stopsTable, tiSet, expiryDate);		// cnwrl1 30/08/2010 PAR 23697 - what it was
			
			// cnwrl1 30/08/2010 PAR 23697 - start of replacement coding
			col	:= table.getColumnByRowName( ETRow_OverrideReason );
			if col = null then
				overrideReason	:= null;
			else
				overrideReason	:= table.accessCell( row, col ).itemObject.CM_StopOverridenReason;
			endif;
			self.doPxyUpdateStops( stopsTable, tiSet, expiryDate, overrideReason );
			// cnwrl1 30/08/2010 PAR 23697 - end of coding
		endif;
	endwhile;
	
	// cnwrl1 23/08/2010 PAR 23697
	// now look at stops to be cleared/cancelled/overridden
	table	:= self.tblStopsClear;
	rows 	:= table.rows;
	row		:= table.fixedRows;
	
	while row &lt; rows do
		row := row + 1;
		
		clearStop 		:= (table.getCellValueByName (ETRow_Clear, row) = 1.String);
		cancelStop		:= (table.getCellValueByName (ETRow_Cancel, row) = 1.String);
		overrideStop	:= (table.getCellValueByName (ETRow_Override, row) = 1.String);		// cnwrl1 23/08/2010 PAR 23697
//		if not clearStop and not cancelStop then			// cnwrl1 23/08/2010 PAR 23697 - what it was
		if not clearStop and not cancelStop and not overrideStop then
			// not being cleared/cancelled/overridden
			continue;
		endif;
		
		stopsTable 	:= table.accessRow(row).itemObject.CM_StopsTable;
		
		inputData	:= table.getCellValueByName( ETRow_Input, row );
		expiryDate	:= table.getCellValueByName( ETRow_ClearanceExpiryDate, row ).asDateJMT;
		
		if clearStop then
			self.doPxyClearStops (stopsTable, tiSet, inputData, expiryDate);
		
		elseif cancelStop then 
			self.doPxyCancelStops (stopsTable, tiSet);
		
		elseif overrideStop then 									// cnwrl1 23/08/2010 PAR 23697
			col	:= table.getColumnByRowName( ETRow_OverrideReason );
			if col = null then
				overrideReason	:= null;
			else
				overrideReason	:= table.accessCell( row, col ).itemObject.CM_StopOverridenReason;
			endif;
			self.doPxyOverrideStops( stopsTable, tiSet, inputData, expiryDate, overrideReason );
		endif;
	endwhile;
	
	// Now we have a collection of proxy TrackedItems with the appropriate
	// proxy stops on them do the update transaction for them all.
	passport.setWarningsIgnored( true );
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTrackedItems( tiSet, TI_UPDMODE_NORMAL, null, passport );
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
epilog	
	tiSet.purge;
	delete tiSet;
	delete idArray;  //01/09/2016 cnwma1 TFS #2628
	
	app.mousePointer	:= Idle;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="08a17936-4d05-4894-b803-cb0981e13bae">
        <source>doTableClick( _table : CM_DataTable input; _row, _col : Integer ) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	
begin
	if not self.canUpdate then
		return;
	endif;
	
	if _row &lt;= _table.fixedRows then
		return;
	endif;
	
	// which table has been clicked and which if any of the checkboxes.
	if _table = self.tblStopsClear then				// top table
		if _col = _table.getColumnByRowName (ETRow_Clear) then
			self.setRowForClear (_table, _row);
		elseif _col = _table.getColumnByRowName (ETRow_Cancel) then
			self.setRowForCancel (_table, _row);
		// cnwrl1 23/08/2010 PAR 23697 - start of coding
		elseif _col = _table.getColumnByRowName( ETRow_Override ) then
			self.setRowForOverride( _table, _row );
		// cnwrl1 23/08/2010 PAR 23697 - end of coding
		endif;
	
	elseif _table = self.tblStopsAdd then			// bottom table
		if _col = _table.getColumnByRowName (ETRow_Add) then
			self.setRowForAdd (_table, _row);
		elseif _col = _table.getColumnByRowName (ETRow_Update) then
			self.setRowForUpdate (_table, _row);
		// cnwrl1 30/08/2010 PAR 23697 - start of coding
		elseif _col = _table.getColumnByRowName( ETRow_OverrideReason ) then
			self.setRowForOverrideUpdate( _table, _row );
		// cnwrl1 30/08/2010 PAR 23697 - end of coding
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTableRowColChange" id="6773bb9a-b94d-4f74-bfbf-6c9c6fa06090">
        <source>doTableRowColChange( _table : CM_DataTable input; _row : Integer; _col : Integer ) protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/08/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	strCaption			: String;
	strInfo				: String;
	maxLength			: Integer;
	case				: Integer;
	stopsTable			: CM_StopsTable;
	textbox				: CMUI_TextBox;
	overrideReason		: CM_StopOverridenReason;
	table				: CM_DataTable;
	
begin
	
	// cnwrl1 25/08/2010 PAR 23697 - replaced with code below
	table	:= _table;
	if _row &lt;= table.fixedRows then
		return;
	elseif _col &lt;&gt; table.getColumnByRowName( ETRow_Input ) and
		   _col &lt;&gt; table.getColumnByRowName( ETRow_OverrideReason ) then
		return;
	endif;
	
	if _col = table.getColumnByRowName( ETRow_Input ) then
		textbox	 := self.txtExtraInfo;
		
		if table.accessCell (_row, _col).cellControl = textbox then
			stopsTable := table.accessRow (_row).itemObject.CM_StopsTable;
			// make sure length, case etc are set properly
			if stopsTable.requiresInfo then		
				stopsTable.getDetailsForRequiredInfo (strCaption, strInfo, maxLength, case, self.myTrackedItem);
				
				textbox.text		:= null;		// to avoid string too long exceptions
				textbox.maxLength	:= maxLength;
				textbox.case		:= case;
				textbox.text		:= strInfo;
				
			endif;
		endif;
	else
		if table.accessCell( _row, _col ).cellControl = self.cmbOverrideRsons then
			overrideReason	:= self.cmbOverrideRsons.listObject.CM_StopOverridenReason;
			table.accessCell( _row, _col ).itemObject	:= overrideReason;
		endif;
	endif;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentObject" id="105a6da4-fb91-4382-932f-622c58e8fcde">
        <source>getCurrentObject(): CM_Object protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myTrackedItem;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getStopsString" id="225ae09e-ad96-4199-906f-4abc6ce742cb">
        <source>getStopsString():String protected;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stop 				: CM_Stops;
	stopsTable			: CM_StopsTable;
	strStop, strAll, 
	strInfo, strCaption : String;
	intLength, intCase	: Integer;
	ti					: CM_TrackedItem;
	overridenReason		: CM_StopOverridenReason;		// cnwrl1 25/08/2010 PAR 23697
	allStops			: CM_StopsByIdDict;				// cnwrl1 03/09/2010 PAR 23697
	
begin
//	foreach stop in self.myTrackedItem.getAllStops do	// cnwrl1 03/09/2010 PAR 23697 - what it was
	
	// cnwrl1 03/09/2010 PAR 23697 - start of replacement coding
	create allStops transient;
	self.myTrackedItem.getAllActiveStopsAsAtDate( allStops, CM_Stops.Away_In_The_Future_Date );
	// cnwrl1 03/09/2010 PAR 23697 - end of coding
	
	foreach stop in allStops do							// cnwrl1 03/09/2010 PAR 23697
		stopsTable	:= stop.myStopsTable;
		ti			:= stop.myTrackedItem;
		strStop 	:= stop.id.String &amp; stop.clearanceExpiryDate.asStringJMT;
		
		// cnwrl1 25/08/2010 PAR 23697 - start of coding
		overridenReason	:= stop.getStopOverrideReason();
		if overridenReason &lt;&gt; null then
			strStop		:= strStop &amp; overridenReason.description.display;
		endif;
		// cnwrl1 25/08/2010 PAR 23697 - end of coding
		
		if stopsTable &lt;&gt; null and stopsTable.requiresInfo then		
			stopsTable.getDetailsForRequiredInfo (strCaption, strInfo, intLength, intCase, ti);
			strStop := strStop &amp; strInfo;
		endif;
		
		strAll := strAll &amp; strStop;
	endforeach;
	
	return strAll;
	
epilog
	delete allStops;									// cnwrl1 03/09/2010 PAR 23697
	
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
