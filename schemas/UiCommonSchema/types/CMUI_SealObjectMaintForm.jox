*/

vars

begin

	self.mySealedObject := _obj;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setRetroDT" id="b79de010-e30c-4f8d-ad3d-c654b985357f">
        <updating/>
        <source>setRetroDT(_dt : TimeStamp)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks

*/

vars

begin
	if _dt.isValid then
		self.retrospectiveDT := _dt;
	endif;
epilog

end;</source>
