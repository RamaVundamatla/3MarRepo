// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	app.mousePointer := Busy;

	if table.row &gt; table.fixedRows then
		self.tblDataDetailSaveText := table.accessCell(table.row, table.column).text;
		self.zDoTblDetailDataRowColChg(table);
	endif;
	
epilog
	app.mousePointer := Idle;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
