    <JadeMethod name="create" id="229ae8c0-32a6-478d-99fe-9e69308fe814">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmRailLoadList;
	self.permissionMaint := PmAdmRailLoadListMaint;

	self.helpFileName := HelpFile_Yard;
	
	create self.mySummaryReport transient;
	self.mySummaryReport.setSummaryClass(CMIF_LoadListSummaryObject);
	
	create self.mySummaryFilterTrain transient;
	self.noteTimes.atPut(SR_Note_Tag, 0);
	self.noteTimes.atPut(TI_Note_Tag, 0);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e9a11480-e1ab-4c03-80f7-441751f745fa">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.mySummaryReport.reset();
	delete self.mySummaryReport;
	delete self.mySummaryFilterTrain;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayAllTable" id="c809e3b8-d95d-4a9e-892d-fc23f54d5b2c">
        <updating/>
        <source>displayAllTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time based rather than object count based
vars
	obj 			: Object;
	numZeros,
	idx  		 	: Integer;
	ti				: CM_TrackedItem;
	cmifMonitor		: CMIF_Monitor;
	partsInJob		: Integer;
	lastUpdated		: Decimal [20];							// PAR #35843
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	cmifMonitor.partsDone := 0;
	cmifMonitor.monitorReturnValue := null;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(app.getErrorString(CMUI_Displaying_Data), null, app.getErrorString(Cancel), null, null, app.getErrorString(CMUI_Displaying_Data));
	self.pbProgressBar.visible := true;
	
	foreach obj in self.tblAll.allTableObjects do
			ti := obj.CM_TrackedItem;	
			idx := idx + 1;
			self.doQueryAddItem(self.tblAll, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			//if (cmifMonitor.partsDone mod 10 = 0) then													// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp;app.getErrorString(Items_displayed);
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;		
	endforeach;

		// Have to resort the table
	self.tblAll.setSortColumnsForMaxNumCols();				
					
	self.doTblDataRenumberItems(self.tblAll, 0);
	
	//08 Dec 2011	NDL	Par 28797
	self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; (self.tblAll.rows - self.tblAll.fixedRows).String &amp; ")";

epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
	self.progressFinish();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTable" id="fc05abd7-dee6-4a29-9fce-c4ed5daa1aab">
        <updating/>
        <source>displayTable(_table : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time based rather than object count based
// ---------------------------------------------------------------------------

vars
	obj 			: Object;
	numZeros,
	idx  		 	: Integer;
	ti				: CM_TrackedItem;
	filterObject	: CMQF_TrainLoadListTIs;
	cmifMonitor		: CMIF_Monitor;
	partsInJob		: Integer;
	lastUpdated		: Decimal [20];							// PAR #35843
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	_table.rows := _table.fixedRows;

	if self.myQuery = null then
		return;
	endif;
	
	filterObject := self.myQuery;
	partsInJob := filterObject.allQryTrackedItems.size;
	numZeros := partsInJob.String.length();
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	cmifMonitor.partsDone := 0;
	cmifMonitor.partsInJob := partsInJob;
	cmifMonitor.monitorReturnValue := null;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
//	self.modalDialogShow('Displaying', null, 'Cancel', null, null, 'Displaying data');
	self.modalDialogShow(app.getErrorString(CMUI_Displaying_Data), null, app.getErrorString(Cancel), null, null, app.getErrorString(CMUI_Displaying_Data));
	self.pbProgressBar.visible := true;
	
	if _table.allTableObjects &lt;&gt; null
	and (not _table.allTableObjects.noKeys) then
		
		_table.allTableObjects.clear();
		
		foreach ti in filterObject.allQryTrackedItems do
			_table.allTableObjects.addObject(ti);
		endforeach;
		
		foreach obj in _table.allTableObjects do
			ti := obj.CM_TrackedItem;	
			idx := idx + 1;
			self.doQueryAddItem(_table, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			//if (cmifMonitor.partsDone mod 10 = 0) then													// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
//				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp; ' out of ' &amp; partsInJob.String &amp; ' items displayed';
				
				self.lblModalInfo.caption := app.getErrorString2(Items_displayedOutOf, cmifMonitor.partsDone.String, partsInJob.String);
				self.pbProgressBar.partsInJob	:= cmifMonitor.partsInJob;	
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;
	
		endforeach;	
	
	else		
	
		foreach ti in filterObject.allQryTrackedItems do	
			idx := idx + 1;
			self.doQueryAddItem(_table, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			//if (cmifMonitor.partsDone mod 10 = 0) then													// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
//				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp; ' out of ' &amp; partsInJob.String &amp; ' items displayed';
				self.lblModalInfo.caption := app.getErrorString2(Items_displayedOutOf, cmifMonitor.partsDone.String, partsInJob.String);
				self.pbProgressBar.partsInJob	:= cmifMonitor.partsInJob;	
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;
	
		endforeach;

		// Have to resort the table
		_table.setSortColumnsForMaxNumCols();				
					
	endif;

	self.doTblDataRenumberItems(_table, 0);

epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
	self.progressFinish();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAssignTrain" id="485bc7c0-ce61-4701-9968-399f8397144e">
        <updating/>
        <source>doAssignTrain() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwndl1	Initial creation

*/

vars

	idx : Integer;
	aTrain : CM_Train;
	
begin

	self.frmAssignTrain.visible := true;
	self.frmAssignTrain.left := 300;
	self.frmAssignTrain.top := 200;
	
	self.frmAssignTrain.zOrder(1);
	
//	aTrain := self.myTerminal.getNullTrain();	//29 Oct 2012	NDL	Par  30499
	
	self.cmbAssignTrain.clear();
//	self.cmbAssignTrain.addItem("&lt;" &amp; aTrain.description &amp;"&gt;"); // NULL TRAIN	//29 Oct 2012	NDL	Par  30499
	self.cmbAssignTrain.sorted := true;
	
	foreach aTrain in self.myTerminal.allTrainsOnTerminal discreteLock do
		if aTrain.isNullTrain() then
			continue;
		endif;
		idx := self.cmbAssignTrain.addItem(aTrain.getCodeDateString());
		self.cmbAssignTrain.itemObject[idx] := aTrain;
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAutoplanToTrain" id="6eb9ee86-72f7-45d8-a351-bbed9eac6d02">
        <updating/>
        <source>doAutoplanToTrain() updating;
// ---------------------------------------------------------------------------
// Created:     20 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
	tis, tisWarn : CM_TIArray;
	theTrain : CM_Train;
begin
	create tis transient;
	create tisWarn transient;
	self.tblData.allSelectedObjects.copy(tis);
	
	if tis.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_some_cargo_autop), app.getErrorString(Train_autoplan), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theTrain := self.getCommonTrain();	//31 Aug 2009	NDL	CCMS 1067
	
	if theTrain = null then
		app.msgBox(app.getErrorString(Please_select_train_autopl_car), app.getErrorString(Train_autoplan), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIsAutoplanToWagon(tis,PLANNING_MODE, null, theTrain, null, tisWarn, app.myPassport);
//		if app.myPassport.trxCompletedOK then
		if tisWarn.isEmpty() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Train_autoplan), app.myPassport, ErrWarnMode_AddUpdate ); //+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				tis.clear;
				tisWarn.copy(tis);
				tisWarn.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete tis;
	delete tisWarn;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCargoUnplanCLick" id="8fd07aa5-f210-4365-9655-577285b3d2ac">
        <updating/>
        <source>doBtnCargoUnplanCLick() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx : Integer;
	ls : Boolean;
	wles : CM_WLEArray;
begin
	if self.tblPlanned.allSelectedObjects.isEmpty then
		return;
	endif;

	create wles transient;
	
	foreach anObj in self.tblPlanned.allSelectedObjects do
		idx := idx + 1;
		aTI := anObj.CM_TrackedItem;
		// PAR 18695 from here
		if aTI &lt;&gt; null then
		
			tmpWLE := aTI.getTrainWLEUnactioned(true);	
			if tmpWLE &lt;&gt; null then 
				wles.add(tmpWLE);
		// PAR 18695 to here
				
				if str = null then
					str := aTI.id;
				else
					if idx mod 3 = 0 then
						str := str &amp; ", " &amp; Cr &amp; aTI.id;
					else
						str := str &amp; ", " &amp; aTI.id;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	// PAR 18695
	if wles.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_some_cargo_unpla),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Unplan_GC) &amp; str &amp; "?", app.getErrorString(SHP_Confirm_Unplan_Cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.cmsBeginLoad(ls);

	if self.tblPlanned.allSelectedObjects.size = 1 then
		aTI := anObj.CM_TrackedItem;
		self.doUnplanTI(aTI,true);
	else
		self.doUnplanTIs(wles, NO_MODE);	// Dec 2011 cnwjre1 28636 RORO unplanning of queued load moves
	endif;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347 - Moved here from above epilog
	delete wles;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEnquireClick" id="441f4da0-f139-49ae-b896-486d867a4b03">
        <source>doBtnEnquireClick();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	08 Dec 2011	NDL	Par 28797	
// ---------------------------------------------------------------------------
vars
	theObject : Object;
	objArray : ObjectArray;
begin
	//epr par 32613 1/10/13
	create objArray transient;
	getSelectedTIs(objArray);
	
	if objArray.isEmpty then
		return;
	endif;
	
	theObject:=objArray.first;
	
	if theObject &lt;&gt; null and theObject.isKindOf(CM_TrackedItem) then
		if objArray.size &gt; 1 then
			self.myAssistant.showCargoEnquiryForTIs(theObject.CM_TrackedItem, objArray,	self.myMasterMenuAction, false);
		else
			self.myAssistant.showCargoEnquiryForm(theObject.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		endif;
	endif;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLocateClick" id="2d86e34d-efa6-461c-a75b-5a13464d54cf">
        <updating/>
        <source>doBtnLocateClick(_theTable : CM_DataTable) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	
begin


	if fldMain.topSheet = self.shtNonplanned then
		theTable := self.tblData;
	elseif fldMain.topSheet = self.shtPlanned then
		theTable := self.tblPlanned;
	elseif fldMain.topSheet = self.shtAll then
		theTable := self.tblAll;
	elseif fldMain.topSheet = self.shtSummary then
		return;
	endif;
	inheritMethod(theTable);
	
	
epilog
	
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBtnLocateYardEnqClick" id="d554f9e7-0313-417f-af22-75924c9b49db">
        <updating/>
        <source>doBtnLocateYardEnqClick() updating;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
vars

	rows : CM_ObjectArray;
	objs : ObjectSet;
	theENQ : CM_EnquiryController;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	create objs transient;

	if self.fldMain.topSheet = self.shtNonplanned then
		self.tblData.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.tblPlanned.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtAll then
		self.tblAll.allSelectedObjects.copy(objs);
	endif;

	theENQ := self.myAssistant.YRD_Assistant.doGetSelectorTIsLoadList(objs, self.myCurrentTrain, false);

	self.myAssistant.showYardRowEnquiryForm(objs,  self.myMasterMenuAction,  theENQ,true, VIEW_DESTPORT, 3, self.myCurrentTrain);

epilog
	delete rows;
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRTSClick" id="f164ef09-ef3b-4012-b4dd-d6d91163974d">
        <updating/>
        <source>doBtnRTSClick(table : Table) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ignoreWarnings 	: Boolean;
	theObject 		: Object;
	tiArray			: CM_TIArray;
	rts				: Boolean;
	result			: Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if table.CM_DataTable.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(SHP_Please_Select_TrackedItem) ,app.getErrorString(SHP_Ready_To_Ship_Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create tiArray transient;
	foreach theObject in table.CM_DataTable.allSelectedObjects where CM_TrackedItem.hasInstance(theObject) do
		tiArray.add(theObject.CM_TrackedItem);
	endforeach;
	
	rts := (not tiArray.first.readyToShip);
	while true do
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray, rts, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Ready_ship), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete tiArray;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="fc3009ce-057d-4fce-9b99-136af9fb725e">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	cm_DataTable		: CM_DataTable;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	cm_DataTable	:= self.getCurrentDataTable();
	cm_DataTable.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedBulkRelNoteUpdate" id="d0fda88e-fd31-491d-8c70-528e81b9d8f9">
        <updating/>
        <source>doCentralisedBulkRelNoteUpdate() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	tmpStr				: String;
	doSummaryRebuild	: Boolean;
	release				: CM_BulkRelease;

begin
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

//	self.startedTimer := false;	//11 June 2013	NDL	Par 31692 - moved to after this method in timerEvent, wasg etting dups.
	
	self.resetSummaryCriteria();
	
	doSummaryRebuild := (self.allBulkReleasesSummaryUpdate.size &gt; 150);
	foreach release in self.allBulkReleasesSummaryUpdate do
		if not doSummaryRebuild then
			self.updateSummaryBulkRelFromNote(release);
		endif;
	endforeach;
	
	if doSummaryRebuild then
		self.doSummaryQuery();
	else
		self.tblSummary.rows := self.tblSummary.fixedRows;
		self.mySummaryReport.populateTable(self.tblSummary);
		self.mySummaryReport.addTableTotal(self.tblSummary);
	endif;
	
	self.allBulkReleasesSummaryUpdate.clear;

epilog
	self.updateShtCaptions();
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedRailJobNoteUpdate" id="fe4d2893-0b52-4af7-ac37-3bf9e8694e3e">
        <updating/>
        <source>doCentralisedRailJobNoteUpdate() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
					Force summary tab update when WLEs moved from train job sheet to rail area job sheet
*/
vars
	tmpStr		: String;

begin
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);
	
	//self.startedTimer := false;	//11 June 2013	NDL	Par 31692 - moved to after this method in timerEvent, was getting dups.
	self.resetSummaryCriteria();
	self.doSummaryQuery();
	
	self.trainJobsRefresh := false;

epilog
	self.updateShtCaptions();
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedTINoteUpdate" id="38fa6ef8-3700-406c-a5b6-2ad4b17add62">
        <updating/>
        <source>doCentralisedTINoteUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		21 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 update summary totals
//	08 Dec 2011	NDL	Par 28797
vars
	startTime		: TimeStamp;
	tmpTI :			 CM_TrackedItem;
	renumberPlanned,
	doSummaryRebuild,
	renumberData,
	renumberAll    : Boolean;

	tmpStr      : String;
begin
	//
	// PAR 21787
	//	
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

	//self.startedTimer := false;	//11 June 2013	NDL	Par 31692 - moved to after this method in timerEvent, was getting dups.
	
	self.resetSummaryCriteria();
	
	doSummaryRebuild := (self.allTIsSummaryUpdate.size &gt; 150);
	foreach tmpTI in self.allTIsSummaryUpdate do
		self.doCentralisedTIUpdate(tmpTI, renumberPlanned, renumberData, renumberAll);
		if not doSummaryRebuild then
			self.updateSummaryTIFromNote(tmpTI);
		endif;
	endforeach;
	
	if renumberPlanned then
		self.doTblDataRenumberItems(self.tblPlanned, 0);
	endif;
	
	if renumberData then
		self.doTblDataRenumberItems(self.tblData, 0);
	endif;
	if renumberAll then
		self.doTblDataRenumberItems(self.tblAll, 0);
	endif;
	
	if doSummaryRebuild then
		self.doSummaryQuery();
	else
		//self.initSummaryTable();
		self.tblSummary.rows := self.tblSummary.fixedRows;
		self.mySummaryReport.populateTable(self.tblSummary);
		self.mySummaryReport.addTableTotal(self.tblSummary);	// PAR #23794
	endif;
	
	self.allTIsSummaryUpdate.clear;

epilog
	self.updateShtCaptions();
	//
	// PAR 21787
	//
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedTIUpdate" id="794cd128-109b-4f3f-b07d-fb8fbd485d81">
        <updating/>
        <source>doCentralisedTIUpdate(_theTI : CM_TrackedItem; _renumberPlanned, _renumberData, _renumberAll : Boolean output) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	aTI : CM_TrackedItem;
	theRow : Integer;
	breakOut : Boolean;
	invalid : Boolean;
	id : String;
	
begin
	on Exception do app.handleDeletedObject(exception, aTI, invalid);
	
	aTI := _theTI;
	
	//added for par15901
	if not self.mySummaryFilterTrain.checkStatusIncludesObject(aTI, app.myPassport, breakOut) then
		if self.tblData.findObjectInRow(aTI, theRow) then
			self.updateSummaryTI(aTI,false); 
			self.tblData.removeItemObject(aTI);
			_renumberData := true;
			self.doNotableRemove(aTI);
		endif;
		return;
	endif;
	//add end
	
	if aTI = null then
		invalid := true;
	else
		invalid := false;
		id := aTI.id;		// Dereference to ensure TI is valid
	endif;
	
	if invalid then
		if self.tblPlanned.findObjectInRow(aTI, theRow) then
			self.tblPlanned.removeItemObject(aTI);
			_renumberPlanned := true;
			self.doNotableRemove(aTI);
		elseif self.tblData.findObjectInRow(aTI, theRow) then
			self.updateSummaryTI(aTI,false); 
			self.tblData.removeItemObject(aTI);
			_renumberData := true;
			self.doNotableRemove(aTI);
		elseif self.tblAll.findObjectInRow(aTI, theRow) then
			self.tblAll.removeItemObject(aTI);
			_renumberAll := true;
			self.doNotableRemove(aTI);
		endif;
		
	else
		if aTI.isPlannedToTrain then
			if self.tblData.findObjectInRow(aTI, theRow) then
				self.tblData.removeItemObject(aTI);
				_renumberData := true;
			endif;
			
			self.tblPlanned.removeItemObject(aTI);
			self.updateTableItem(self.tblPlanned, aTI);
			_renumberPlanned := true;
			
			self.updateTblAllTi(aTI);	
			_renumberAll := true;
			
		else
			if self.tblPlanned.findObjectInRow(aTI, theRow) then
				self.tblPlanned.removeItemObject(aTI);				
				_renumberPlanned := true;				
			endif;
			
			self.tblData.removeItemObject(aTI);
			self.updateTableItem(self.tblData, aTI);
			_renumberData := true;
			
			self.updateTblAllTi(aTI);
			_renumberAll := true;
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_renumberPlanned" type="Boolean" usage="output"/>
        <Parameter name="_renumberData" type="Boolean" usage="output"/>
        <Parameter name="_renumberAll" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doCentralisedWLENoteUpdate" id="8c8a2ac6-600e-47fe-8ab3-cdba8523d4df">
        <updating/>
        <source>doCentralisedWLENoteUpdate() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	startTime			: TimeStamp;
	tmpWLE 				: CM_WorkListEntry;
	doSummaryRebuild	: Boolean;
	tmpStr      		: String;
	
begin
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

	//self.startedTimer := false;	//11 June 2013	NDL	Par 31692 - moved to after this method in timerEvent, was getting dups.
	
	self.resetSummaryCriteria();
	
	doSummaryRebuild := (self.allWLEsSummaryUpdate.size &gt; 150);
	foreach tmpWLE in self.allWLEsSummaryUpdate do
		self.doCentralisedWLEUpdate(tmpWLE);
		if not doSummaryRebuild then
			self.updateSummaryWLEFromNote(tmpWLE);
		endif;
	endforeach;
	
	if doSummaryRebuild then
		self.doSummaryQuery();
	else
		//self.initSummaryTable();
		self.tblSummary.rows := self.tblSummary.fixedRows;
		self.mySummaryReport.populateTable(self.tblSummary);
		self.mySummaryReport.addTableTotal(self.tblSummary);
	endif;
	
	self.allWLEsSummaryUpdate.clear;

epilog
	self.updateShtCaptions();
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedWLEUpdate" id="ccaf18c0-6d77-4602-a47f-dbe39a90e9ae">
        <updating/>
        <source>doCentralisedWLEUpdate(_theWLE : CM_WorkListEntry) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
vars
	wle			: CM_WorkListEntry;
	theRow 		: Integer;
	breakOut 	: Boolean;
	invalid		: Boolean;
	ed 			: Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, wle, invalid);
	
	wle := _theWLE;
	if wle &lt;&gt; null then
		ed := wle.edition();
	endif;
	if invalid then
		return;
	endif;
	

	if not self.mySummaryFilterTrain.checkStatusIncludesObject(wle, app.myPassport, breakOut) then
		self.updateSummaryWLE(wle, false); 
		self.doNotableRemove(wle);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_theWLE" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doCmbTrainBuild" id="fcc32e15-9e74-4951-a7e9-e56a867db654">
        <updating/>
        <source>doCmbTrainBuild() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTrain 		: CM_Train;
	idx 			: Integer;
	theTrains 		: CM_TrainSet;
	theTrain : CM_Train;
	theTerm : CM_Terminal;
	
begin
	theTerm := self.myTerminal;

	// ### init with object
	theTrain := self.myCurrentTrain;
	
	self.cmbTrainNote.clear;
	self.cmbTrainNote.sorted := false;
	self.cmbTrainNote.addItem("&lt;" &amp; app.getErrorString(GIVE_ME_ALL_DA_TRAINS_YO)&amp;"&gt;");
	self.cmbTrainNote.sorted := true;
	
	foreach aTrain in self.myTerminal.allTrainsOnTerminal discreteLock do
		if aTrain.isNullTrain() then
			continue;
		endif;
	
//		idx := self.cmbTrainNote.addItem(aTrain.code &amp; " - " &amp; aTrain.scheduledArrivalDT.asStringJMT());
		idx := self.cmbTrainNote.addItem(aTrain.getCodeDateString());
		self.cmbTrainNote.itemObject[idx] := aTrain;
	endforeach;

	if theTrain &lt;&gt; null then
		self.myCurrentTrain := theTrain;
/*
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Create_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Update_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Delete_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_START), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_STOP), Response_Continuous, null);
	*/	
		//cnwjo3
		//self.beginNotification(theTrain, theTerm.getTerminalEvent(Train_Update_Event), Response_Continuous, null);

		idx := self.cmbTrainNote.findObject(theTrain);
		if idx &gt; 0 then
			self.cmbTrainNote.listIndex := idx;
		endif;
	else
		self.cmbTrainNote.listIndex := 1;
	endif;
	
epilog
	delete theTrains;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTrainClick" id="a9cd23ee-8414-4a25-9b50-cbdaf30ac290">
        <updating/>
        <source>doCmbTrainClick(_combo : ComboBox) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTrain : CM_Train;
	theTerm : CM_Terminal;
	
begin

	theTrain := self.myCurrentTrain;
	theTerm := self.myTerminal;
	
	if theTrain &lt;&gt; null then

		self.doNotableRemove(theTrain);
		/*
		self.endNotification(theTrain, theTerm.getTerminalEvent(RailJob_Create_Event));
		self.endNotification(theTrain, theTerm.getTerminalEvent(RailJob_Update_Event));
		self.endNotification(theTrain, theTerm.getTerminalEvent(RailJob_Delete_Event));
		self.endNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_START));
		self.endNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_STOP));
		*/
	endif;

	theTrain := _combo.listObject.CM_Train;
	self.myCurrentTrain := theTrain;
	
	self.mnuTrainAP.caption := app.getErrorString(Autoplan_train);
	if theTrain &lt;&gt; null then
	/*
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Create_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Update_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(RailJob_Delete_Event), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_START), Response_Continuous, null);
		self.beginNotification(theTrain, theTerm.getTerminalEvent(EVENT_FULL_PLAN_STOP), Response_Continuous, null);
*/
		self.mnuTrainAP.caption := self.mnuTrainAP.caption &amp; " " &amp; theTrain.code;

	endif;
	self.doComboOperatorBuild();
	self.doComboPortBuild();

end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doComboCargoBuild" id="d871df9c-1b90-4613-9882-d9beac25bf2a">
        <updating/>
        <source>doComboCargoBuild() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	anArray : ObjectArray;
begin
	self.lstCargoTypes.rows := 0;
	self.lstCargoTypes.zOrder(1);
	foreach aCargoType in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		if self.myTerminal &lt;&gt; null then
			if not aCargoType.allTerminals.includes(self.myTerminal) then
				continue;
			endif;
		endif;
		
		self.lstCargoTypes.addItemObject(aCargoType.abbreviation &amp; " - " &amp; aCargoType.description,aCargoType);
		
		// #################
		// DEFAULT TO CONTAINER
		if aCargoType.id = TI_CargoType_Container then
			self.lstCargoTypes.rowChecked(lstCargoTypes.rows);

			if not self.lstCargoTypes.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
				self.lstCargoTypes.allSelectedObjects.add(aCargoType);
			endif;


		endif;
	endforeach;
	aCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	create anArray transient;
	anArray.add(aCargoType);
	self.lstCargoTypes.setSelected(anArray);
	
epilog
	delete anArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboOperatorBuild" id="f3f3282a-b224-48c5-b06a-1f2f41d2a2fa">
        <updating/>
        <source>doComboOperatorBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aOperator : CM_Operator;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	opDict : CM_OperatorByCodeDict;
	failedDAC  :CM_DataAccessController;

begin
	passport := app.myPassport;
	self.lstOperators.zOrder(1);
	self.lstOperators.rows := 0;

	opDict := app.myRoot.allOperators;
	
	app.cmsBeginLoad(ls);
	foreach aOperator in opDict do
		if aOperator.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstOperators.addItemObject(aOperator.code &amp; " - " &amp; aOperator.description,aOperator);
		endif;
	endforeach;
	app.cmsEndLoad(ls);
	self.lstOperators.setSelected(null);

	
	self.lstOperators.userInputEnabled := false;
epilog
	endLoad;

end;</source>
    </JadeMethod>
