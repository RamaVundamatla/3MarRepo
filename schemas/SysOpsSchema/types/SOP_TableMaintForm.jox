    <JadeMethod name="txtBox01_change" id="84aac75f-ce68-4741-9741-9b8ff487af7f">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBox01_change(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     14 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	msg : String;

begin

	// Do not do this as for passwords this will show what was entered in the table cell.
	//tblInput1.text := textbox.text;
	
	//07 Jul 2017	NDL	TFS 5235
/*	if textbox.text.length &gt; 64 then
		msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '64');
		app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif; */
	//self.enteredPassword := textbox.text[1:64];
	//25 Aug 2021	NDL	TFS 51632 - no longer truncate here
	self.enteredPassword := textbox.text;
	if self.enteredPassword &lt;&gt; null then
		tblInput1.text := '&lt;set&gt;';
	else
		tblInput1.text := null;
	endif;

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtPartnerCode_change" id="362a08c4-66e8-4f26-851d-22e925960dc3">
