    <JadeMethod name="handleNotification" id="33ecad1f-4d77-47e6-8e95-ec46c8f41e78">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx				: Integer;
	tbl				: CM_DataTable;
	segCond			: CM_SegregationCondition;
	
begin
	tbl := self.tblConditions;
	if CM_SegregationCondition.hasInstance(theObject) then
		segCond := theObject.CM_SegregationCondition;
	endif;
	
	//23 Oct 2008 cnwdz2 par 18230
	if global.isValidObject(segCond) and segCond.myTerminal &lt;&gt; self.myTerminal then
		return;
	endif;
	
	if eventType = Object_Create_Event and segCond &lt;&gt; null and segCond.type = self.ruleMode then
		self.tblConditions.findObjectInRow(segCond,idx);
		if idx &lt; 1 then
			idx := self.tblConditions.addItem(segCond.getAttributeStringForDefArray(tbl.allTblDataEntRows));
			tbl.accessRow(idx).itemObject := segCond;
			tbl.accessCell(idx, self.colorValueColumn).backColor := segCond.colour;
			tbl.resort();
		endif;

	elseif eventType = Object_Update_Event and segCond &lt;&gt; null and segCond.type = self.ruleMode then
		self.tblConditions.findObjectInRow(segCond,idx);
		if idx &gt; 1 then //update just the row
			tbl.setCellText(idx, 1, segCond.getAttributeStringForDefArray(tbl.allTblDataEntRows));
			tbl.accessRow(idx).itemObject := segCond;
			tbl.accessCell(idx, self.colorValueColumn).backColor := segCond.colour;
			tbl.resort();
			self.loadSegregationMatrix(false);
		else//not found so add it
			idx := self.tblConditions.addItem(segCond.getAttributeStringForDefArray(tbl.allTblDataEntRows));
			tbl.accessRow(idx).itemObject := segCond;
			tbl.accessCell(idx, self.colorValueColumn).backColor := segCond.colour;
			tbl.resort();
		endif;
		
		
	elseif eventType = Object_Delete_Event then
		if self.mode = self.Mode_UpdateCondition and self.mySelectedCondition = theObject then
			app.msgBox('Another user has deleted the segregation condition you are currently editing. The editing must now be cancelled','Condition deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.doShowHideCondFrm(false);
		endif;
		self.tblConditions.findObjectInRow(segCond,idx);
		if idx &gt; 1 then
			tbl.removeItem(idx);
			tbl.resort();
		endif;
		
	elseif eventType = SegMatrix_Update_Event then
		if self.mode = self.Mode_UpdateMatrix then
			app.msgBox('Another user has updated the hazard segregation matrix. Your editing must now be cancelled','Hazard segregation matric updated by another user.', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.doMatrixEdit(false);
		else
			self.loadSegregationMatrix(false);
		endif;
	endif;
	
end;


</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="importSegregationMatrix" id="beb555db-7175-494a-bf50-d61dbef48769">
        <updating/>
        <source>importSegregationMatrix() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	diag			: CMDFileOpen;
	file			: File;
	mode			: Integer;
	block			: String;
	result			: Integer;
begin
	create diag transient;
	create file transient;
	
	
	diag.defaultExt := '*.xml';
	if diag.open = 0 then	//user clicked OK
		file.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		file.fileName := diag.fileName;
		
		if (not file.isAvailable) then
			app.msgBox('Error: The file either does not exist or is in use by another process.', 'Error: File unavailable', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else
		return;
	endif;
	
	if app.msgBox('Are you sure you want to completely replace the existing hazard segregation matrix for this rule mode?','Are you sure?', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	self.mySegregationMatrixAgent.ruleType := self.ruleMode;
	self.mySegregationMatrixAgent.allSegMatrixTransByColRow.purge();
	self.mySegregationMatrixAgent.allSegMatrixTransByRowCol.purge();
	
	block := file.readString(file.fileLength);
	self.mySegregationMatrixAgent.importMeXML(block);
	
	if not app.myPassport.noErrors then
		app.showErrorWarningDialog('Segregation Matrix Import', app.myPassport, ErrWarnMode_AddUpdate);
		self.clearErrorWarnings();
		self.doMatrixEdit(false);
		return;
	endif;
	/*
	if self.mySegregationMatrixAgent.allSegMatrixTransByRowCol.isEmpty then
		app.msgBox('Nothing to import','Nothing imported',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	*/
	while true do
		app.myTrxUA.trxImportFullSegMatrix(self.mySegregationMatrixAgent, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doMatrixEdit(false);
			break;
		else
			result := app.showErrorWarningDialog('Segregation Matrix Update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	
		break;
	endwhile;

	
epilog


	delete file;
	delete diag;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="ebfc54bd-fad7-44bb-b8ee-c488afe3b2e7">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	userWindow		: CM_UserWindow;
	theXML			: String;
	splitterRatio			: Integer;
begin
	inheritMethod(_userWindow);

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
 	splitterRatio := theXML.cnEcGetTagValueOfName(XML_SPLITMAINT).Integer;
	if splitterRatio = null then
		splitterRatio := 25;
	endif;
 	
	self.splRuleMaint.setLeftToRightRatio(splitterRatio);


end;





</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblMatrix" id="1f103949-7f66-438f-a3f5-8b0146ec8c22">
        <updating/>
        <source>initTblMatrix() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tbl				: CM_DataTable;
	
	newRow,
	newCol			: Integer;
begin
	tbl := self.tblMatrix;
	newRow 				:= 1;
	tbl.rows 			:= newRow;
	tbl.fixedRows 		:= newRow;
	tbl.accessRow(newRow).height := self.Column_Width;
	//tbl.accessRow(newRow).fontBold := true;
	
	newCol 				:= 2;
	tbl.columns 		:= newCol;
	tbl.fixedColumns 	:= newCol;
	//tbl.accessColumn(newCol).fontBold := true;
	tbl.accessColumn(1).alignment := Table.Alignment_Left;
	tbl.accessedColumn.width := 160;
	tbl.accessedColumn.partialTextIndication := true;
	
	tbl.accessColumn(newCol).width := self.Column_Width;
	tbl.accessColumn(newCol).alignment := Table.Alignment_Center;
	
	tbl.accessCell(1,1).text := 'Hazard Class';
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.fontBold := true;
	
	self.doMatrixEdit(false);	// Par 13735 - initializing buttons in not Edit state

end;


</source>
        <access>protected</access>
    </JadeMethod>
