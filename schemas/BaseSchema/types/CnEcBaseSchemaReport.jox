    <JadeMethod name="printBody" id="5b6b3833-924f-471e-9e91-135bc8406d37">
        <updating/>
        <source>printBody(pCaption:String; pErrorMessage:String io):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Prints a line in the body of the report.  The body label is
//				automatically resized (resize=auto, wordwrap=true), but the width
//				is manually set to the width of the standard print width (as
//				identified by the width of the non-printing lblStandardWidth
//				control which is painted onto the report but is only used to
//				determine the appropriate width at run-time.  Refer to the
//				"setFrameDimensions" method.
//
// Parameters:	pCaption (String) - The caption text of the body.
//				pErrorMessage (String, IO) - Returns a message if an error occurs.
//
// Returns:		A flag to indicate whether the print requst was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblBody.caption	:=	pCaption;
	self.setFrameDimensions();

	return self.doPrint(fraBody, pErrorMessage);
end;</source>
        <access>protected</access>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printMajorHeading" id="12f7242c-cc1f-4944-a873-068fde187aee">
        <updating/>
        <source>printMajorHeading(pCaption:String; pErrorMessage:String io):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Prints a Major Heading line in the report.  The lenth of the underline
//				will be adjusted to the length of the heading (which has resize=auto).
//
// Parameters:	pCaption (String) - The caption text of the body.
//				pErrorMessage (String, IO) - Returns a message if an error occurs.
//
// Returns:		A flag to indicate whether the print requst was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblMajorHeading.caption	:=	pCaption;
	lblMajorLine.width		:=	lblMajorHeading.width;
	return self.doPrint(fraMajorHeading, pErrorMessage);
end;</source>
        <access>protected</access>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printMediumHeading" id="bc15e47f-eb85-41da-94e0-541dc3736108">
        <updating/>
        <source>printMediumHeading(pCaption:String; pErrorMessage:String io):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Prints a Medium Heading line in the report.  The lenth of the underline
//				will be adjusted to the length of the heading (which has resize=auto).
//
// Parameters:	pCaption (String) - The caption text of the body.
//				pErrorMessage (String, IO) - Returns a message if an error occurs.
//
// Returns:		A flag to indicate whether the print requst was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblMediumHeading.caption	:=	pCaption;
	lblMediumLine.width			:=	lblMediumHeading.width;
	return self.doPrint(fraMediumHeading, pErrorMessage);
end;</source>
        <access>protected</access>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printMinorHeading" id="bb7c481a-dcb9-4ba2-b77d-16ecac53c9f7">
        <updating/>
        <source>printMinorHeading(pCaption:String; pErrorMessage:String io):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Prints a Minor Heading line in the report.  The lenth of the underline
//				will be adjusted to the length of the heading (which has resize=auto).
//
// Parameters:	pCaption (String) - The caption text of the body.
//				pErrorMessage (String, IO) - Returns a message if an error occurs.
//
// Returns:		A flag to indicate whether the print requst was successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblMinorHeading.caption	:=	pCaption;
	lblMinorLine.width		:=	lblMinorHeading.width;
	return self.doPrint(fraMinorHeading, pErrorMessage);
end;</source>
        <access>protected</access>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="469622c8-0a2b-4b4f-bd29-dae6b851830d">
        <updating/>
        <source>printReport(pQueueEntryObj: CnEcReportQueueEntry; pIsPreview: Boolean; pErrorMessage: String output): Integer updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2000 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aStandardLabelWidth	:=	lblStandardWidth.width;
	self.aStandardFrameHeight	:=	fraBody.height;
	
	return inheritMethod(pQueueEntryObj, pIsPreview, pErrorMessage);
end;</source>
        <Parameter name="pQueueEntryObj" type="CnEcReportQueueEntry"/>
        <Parameter name="pIsPreview" type="Boolean"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFrameDimensions" id="b1a5582b-a097-42f0-810b-da40d7e30896">
        <updating/>
        <source>setFrameDimensions() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		The body label is automatically resized (resize=auto, wordwrap=true),
//				but the width is manually set to the width of the standard print
//				width (as identified by the width of the non-printing lblStandardWidth
//				control, which is painted onto the report but is only used to
//				determine the appropriate width at run-time.
//
//				Therefore, this method will set that standard label width, then
//				alter the heigth of the label's parent frame to the height of the
//				body label, which will have been automatically adjusted by JADE
//				depending upon the amount of text the caption has.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblBody.width	:=	self.aStandardLabelWidth;
	fraBody.height	:=	lblBody.height;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
