    <JadeMethod name="translateForm" id="bc94dea4-2dea-4b81-a450-f75b1d5edadc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 May 2023 08:11:50.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024520, locale);
	btnAudits.translateCaption(Xlat_0026072, locale);
	btnDelete.translateCaption(Xlat_0024521, locale);
	btnEdit.translateCaption(Xlat_0025254, locale);
	btnLoad.translateCaption(Xlat_0024522, locale);
	btnView.translateCaption(Xlat_0024523, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0024524, locale);
	mnuContext.translateCaption(Xlat_0024525, locale);
end;</source>
    </JadeMethod>
