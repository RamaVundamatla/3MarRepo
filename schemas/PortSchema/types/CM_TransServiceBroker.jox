    <JadeMethod name="pxyCreateUpdateProxy" id="2e360883-4918-48d2-bbb8-8abc4541f7c3">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyMe.commodityMap := self.commodityMap;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="cc345361-7660-4928-ab0d-43d068bb2d2a">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	resourceBroker	: CM_TransResourceServiceBroker;
begin
	count := self.myChildQuantityMap.replaceInvoiceLineTypes(_oldILD, _newILD);

	foreach resourceBroker in self.allResourceBrokers do
		count := count + resourceBroker.myChildQuantityMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="006144c6-4ae1-448f-ba3a-15317ef5fbe6">
        <updating/>
        <source>setForCreate(_pxySB : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxySB);
	self.myTransactionType := _pxySB.myTransactionType;
	self.className := _pxySB.className;
	self.commodityMap := _pxySB.commodityMap;
	self.initialise(self.commodityMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap.bank);
//	self.initialise(self.commodityMap.contentsMap.imexMap.trackedServiceMap.transactionMap.bank);
end;</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyTSB" id="6cf93329-02a9-4eff-99b8-c3155b3dba3c">
        <updating/>
        <source>setProxyTSB(_className : String; _comMap : CM_CommodityMap; _tt : CM_TransactionType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.setProxy();

	self.className := _className;
	self.commodityMap := _comMap;
	self.myTransactionType := _tt;
end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_comMap" type="CM_CommodityMap"/>
        <Parameter name="_tt" type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="fcf8a426-f5a7-4a2f-82bc-a964eecdc8f6">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TransServiceBroker::className.name or
		propName = CM_TransServiceBroker::myChildQuantityMap.name or
		propName = CM_TransServiceBroker::commodityMap.name or
		propName = CM_TransServiceBroker::myTransactionType.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
