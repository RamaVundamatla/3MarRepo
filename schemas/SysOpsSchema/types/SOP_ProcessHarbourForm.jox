    <JadeMethod name="cmbHarbour_displayEntry" id="7c68fd90-f619-46f5-9d90-ff63b254d230">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHarbour_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation

*/

vars

begin

	if obj = null then
		return null;
	endif;
	
	if obj.isKindOf( HMS_Harbour ) then
		return obj.HMS_Harbour.description;
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
