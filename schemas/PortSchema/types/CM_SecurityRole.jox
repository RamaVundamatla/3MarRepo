    <JadeMethod name="getLevelRelativeTo" id="3b61e1e1-43cd-4512-9d94-1706a0e734a0">
        <source>getLevelRelativeTo( _role : CM_SecurityRole ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

begin
	
	if _role = null or self = _role or myParentRole = null then
		return 1;
	endif;
	
	return self.myParentRole.getLevelRelativeTo( _role ) + 1;

epilog

end;</source>
