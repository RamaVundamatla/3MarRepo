    <JadeMethod name="getValueForObject" id="6e928958-7526-4205-8377-af70c066cc20">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// ---------------------------------------------------------------------------
vars

begin
	if _obj.CM_TrackedItem.myBookingRef &lt;&gt; null then
		return _obj.CM_TrackedItem.myBookingRef.createdTime.date();
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
