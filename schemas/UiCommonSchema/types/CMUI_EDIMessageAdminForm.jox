    <JadeMethod name="doShowSearcherClick" id="2e2f79f0-bb38-4349-8516-48a8a4017000">
        <updating/>
        <source>doShowSearcherClick() updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
