    <JadeMethod name="loadRemarksTable" id="bf81a106-2943-479b-adb7-b43ce4b8ff8b">
        <updating/>
        <source>loadRemarksTable() updating;
/*
Date		    Who			Reason
25 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	deck		: CM_Deck;
	iter 		: Iterator;
	roroStructure : CM_Object;
begin
	
	if self.isSingleDeck then		
		self.addTableItemsForDeck(self.myCurrentDeck);			
	else
		roroStructure:=self.myCurrentDeck.getROROStructure;
		
		if roroStructure.isKindOf(CM_ROROVesselStructure) then
			iter:=roroStructure.CM_ROROVesselStructure.allDecks.createIterator;
		elseif roroStructure.isKindOf(CM_ROROVoyageStructure) then
			iter:=roroStructure.CM_ROROVoyageStructure.allDecks.createIterator;
		endif;
		
		while iter.next(deck) do
			self.addTableItemsForDeck(deck);
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
