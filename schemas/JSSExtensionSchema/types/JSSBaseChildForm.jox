    <JadeMethod name="menuDisplay" id="bec05d87-8239-41cd-8f06-3739de3343bd">
        <source>menuDisplay(pMessage:String; pIsClosed:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		14 November 2001 by cnwdad1
//
// Purpose:		Use this method in the "select" event method of a menu property to
//				display a message in the status barof the MDI frame.
//
// Parameters:	pMessage - The message to display in the caption bar.
//				pIsClosed - The boolean flag from the menu's "select" event method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMdiForm	: JSSBaseMdiForm;
	
begin
	theMdiForm	:=	app.getForm(JSSBaseMdiForm.name).JSSBaseMdiForm;
	theMdiForm.menuDisplay(pMessage, pIsClosed);
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pIsClosed" type="Boolean"/>
    </JadeMethod>
</GUIClass>
