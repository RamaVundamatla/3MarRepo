    <JadeMethod name="getMessageType" id="d9532d66-a85c-4164-89a2-142202533aab">
        <source>getMessageType(_transaction: CM_TITransaction;
				_messageTypeArray: IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	_messageTypeArray.clear;
	
	if _transaction.isCamsShipReceiveType() then
		_messageTypeArray.add(COARRI_SHIPDISCHARGE);
	elseif _transaction.isCamsShipReleaseType() then
		_messageTypeArray.add(COARRI_SHIPLOAD);
	else
		//do nothing 
		//epr TFS 2387 19/7/16 more logging
		if _camAgent &lt;&gt; null then
			_camAgent.logReasonForExclusion(_transaction,"transaction not supported");
		endif;
	endif;
	
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMessageTypeString" id="8978fff8-55f2-409a-9f71-a4bfe862bce7">
        <source>getMessageTypeString(_messageType : Integer) : String;

vars

begin

	if _messageType = COARRI_SHIPLOAD then
		return "Coarri Loaded onto Ship";
	elseif _messageType = COARRI_SHIPDISCHARGE then
		return "Coarri Discharged from Ship";
	else
		return "Unknown Coarri Message!";
	endif;


end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSenderCode_UNB" id="f2a9fc79-71a4-41bc-84e3-ef6816eaeb85">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
/*	
Return Value:	sender code to use in UNB segment

Date		Who		Reason
16 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	code, fCode	:String;
	terminal	:CM_Terminal;
begin
	code 		:= _protocol.camGroup.senderCode.trimBlanks;
	terminal	:= _protocol.terminal;
	
	// 09/03/2012 cnwar2 #29175
	if code = null then
		code := _protocol.camISOPortDesc.trimBlanks;
	endif;
	
	if code = null then
		code := terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimRight;
	
	return fCode;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="0dc435d8-2247-4994-ae27-3056a772ea7d">
        <source>getVoyage(_transaction :CM_TITransaction; _ti :CM_TrackedItem):CM_Voyage;
/*
Date		Who		Reason
13 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars
	voyage	:CM_Voyage;
begin
	voyage 	:= _transaction.getVoyage();
	
	if voyage = null then
		app.writeLog("Error : Transaction for " &amp; _ti.id.trimRight &amp; " has an null voyage. " &amp; _transaction.String, LogINFO);
		
		if _ti.myVoyage = null then
			app.writeLog("Error : Container " &amp; _ti.id.trimRight &amp; " has an null voyage. " &amp; _transaction.String, LogINFO);
		else
			voyage := _ti.myVoyage;
		endif;
	endif;

	return voyage;
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="imExStatusToString" id="aaa5db6e-919d-4a8b-a289-6bdc88582df0">
        <source>imExStatusToString(_ti:CM_TrackedItem) : String;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExprt for tranships
//
vars
	imexString:String;
begin
	if _ti.isRehandle and not _ti.isARework then
		imexString := "5";  //Shifter(restow)
	elseif _ti.isSOB and not _ti.isARework then
		imexString := "4";  //remain on board
	//elseif _ti.isExport then							// PAR #25021
	elseif _ti.isExport or _ti.isTranshipOutbound then	// PAR #25021
		imexString := "2";
	elseif _ti.isStorage then//for Coarri a storage has been imported
	//	imexString := "2";
		imexString := "3";	//05 Dec 2019	NDL	TFS 47868
	//elseif _ti.isImport then							// PAR #25021
	elseif _ti.isImport or _ti.isTranshipInbound then	// PAR #25021
		imexString := "3";
	else
		imexString := "";
	endif;
	return imexString;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
