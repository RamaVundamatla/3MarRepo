    <JadeMethod name="validateDelete" id="b52acd15-0e17-431c-aa66-2acfcb69f1d9">
        <source>validateDelete(_passport: CM_Passport input);
/*
Purpose:		PAR 31671	
Date				Who			Reason
JUNE 2013		CNWAB1		Initial creation
*/

vars
	lc : CM_ROROLanePositionController;
begin

		if self.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Cannot_delete_becaus_colour_co,self.code, null, null);
		endif;
		if self.hasTIs(REAL_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_actual_ca,self.code, null, null);
		endif;
		if self.hasTIs(PLANNING_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_planne_ca,self.code, null, null);
		endif;
		if self.hasTIs(QUEUE_MODE) then
			app.raiseCMException1(Cannot_delete_becaus_queued_ca,self.code, null, null);
		endif;	
		
		foreach lc in self.myLaneController.allLanePositionsLCs discreteLock do
			lc.myLanePositionDefn.validateDelete(_passport);
		endforeach;
			
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
