    <JadeMethod name="setSystemColours" id="0c659422-5e6e-4799-b7f0-09ee39dcf098">
        <updating/>
        <source>setSystemColours(_harbour : HMS_Harbour)updating;
//--------------------------------------------------
// Created:	10 May 2004 By: cnwgd1
//--------------------------------------------------
begin
	if _harbour &lt;&gt; null then
		if process.isJLGAB1() then // Draw like BWM
			self.midnightLineColour	:=	LightGray;
			self.timeNowLineColour	:=	LightOrange;
			self.dayLabelColour		:=	LightGray;
			self.planningNotesDateColour	:=	_harbour.plannedNoteColour;
		
		else
		self.midnightLineColour	:=	_harbour.midnightLineColour;
		//self.midnightLineColour := _harbour.timeNowLineColour;
		self.timeNowLineColour	:=	_harbour.timeNowLineColour;
		self.dayLabelColour		:=	_harbour.timePositonLabelColour;
		self.planningNotesDateColour	:=	_harbour.plannedNoteColour;
		endif;
	else
		//self.midnightLineColour	:=	Yellow;
		self.midnightLineColour	:=	Black;
		self.timeNowLineColour	:=	Black;
		self.dayLabelColour		:=	Red;
		self.planningNotesDateColour	:=	Black;
	endif;

	if self.lblTimePointer &lt;&gt; null then
		self.lblTimePointer.foreColor	:=	self.midnightLineColour;
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setTimePeriod" id="78e70fc6-f65b-4469-848f-5618a39463e5">
        <updating/>
        <source>setTimePeriod(_from, _to : TimeStamp) updating;
//--------------------------------------------------
// Created:	12 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	now : TimeStamp;
begin
	now := app.actualTimeServer();	// 27/5/16 cnwmp6 TFS 488 - Multi timezone support
	if _from = null then
		self.fromTimePeriod := now;
	else
		self.fromTimePeriod := _from;
	endif;

	self.toTimePeriod := _to;
	self.drawMe();				
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="32b90de0-3b29-45d2-a88e-91d8ec35d800">
        <updating/>
        <source>setupControls() updating, protected;
//--------------------------------------------------
// Created:	10 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	scrLabelsFrm : CMUI_ScrollableLabelsFrame;
begin
	textOffset := (self.myLabelFrame.drawTextHeight('HH:MM') / 2);
	create pointer1 transient;
	pointer1.ignoreSkin := true;
	self.myGraphicalView.addControl(pointer1);
	pointer1.parent	:= self.myLabelFrame;
	pointer1.height := 1;
	pointer1.width  := 20;
	pointer1.left 	:= self.myLabelFrame.width - 20;
	pointer1.borderStyle:= 0;
	pointer1.caption	:= '';
	pointer1.backColor	:= Red;
	pointer1.visible:= false;

	create pointer2 transient;
	pointer2.ignoreSkin := true;
	self.myGraphicalView.addControl(pointer2);
	pointer2.parent := self.myLabelFrame;
	pointer2.height := 1;
	pointer2.width  := 20;
	pointer2.left 	:= self.myLabelFrame.width - 20;
	pointer2.borderStyle:= 0;
	pointer2.caption	:= '';
	pointer2.backColor	:= Red;
	pointer2.visible:= false;
	
	create self.lblTimePointer transient;
	self.lblTimePointer.ignoreSkin := true;
	self.myGraphicalView.addControl(lblTimePointer);
	lblTimePointer.parent := self.myLabelFrame.parent.CMUI_ScrollableFrame.myTopLeftFillerFrame;
	lblTimePointer.parentAspect := lblTimePointer.ParentAspect_StretchBoth;
	lblTimePointer.borderStyle	:= lblTimePointer.BorderStyle_Single;		
	lblTimePointer.caption	:= '';
	lblTimePointer.fontName := 'Arial';
	lblTimePointer.fontSize := 8;
	lblTimePointer.transparent	:= true;
	lblTimePointer.visible:= true;		
	lblTimePointer.wordWrap := true;
	lblTimePointer.alignment := lblTimePointer.Alignment_Center_Middle;
	lblTimePointer.stretchHeight := true;
	lblTimePointer.stretchWidth := true;
	lblTimePointer.foreColor := self.midnightLineColour;	
	
	//Set up scrollable label
	scrLabelsFrm := self.myLabelFrame;
	scrLabelsFrm.drawMode 		:= scrLabelsFrm.DrawMode_Copy;
	scrLabelsFrm.drawFontName	:= 'Arial';	
	scrLabelsFrm.drawFontSize	:= 8;
	scrLabelsFrm.borderStyle	:= scrLabelsFrm.BorderStyle_Single;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="stepCounter" id="e302de9c-0048-4cb9-bf8f-d283155006c2">
        <source>stepCounter(pInt : Integer io):Boolean;

vars

begin
	if alignScale = Align_NS then
		pInt := pInt + 1;
		if pInt &gt; self.scaleHeight.Integer then
			return true;
		endif;
	else
		pInt := pInt - 1;
		if pInt &lt; 1 then
			return true;
		endif;
	endif;	
	return false;
end;</source>
        <Parameter name="pInt" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="d75057da-c141-48e8-8ac8-a5bb02c55c48">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars

begin
	if eventTag = UpdateCurrentTimeMarker then
		self.drawCurrentTime();
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
