    <JadeMethod name="asStringJSON" id="404d9d14-043f-4aba-a118-9e0299228eda">
        <source>asStringJSON() : String;
/*

Purpose:			Return the receiver formatted for JSON

Parameters:			None

Return Value:		JSON string representing the receiver

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	return '[' &amp; self.x.String &amp; ',' &amp; self.y.String &amp; ']';
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="below" id="4477acb7-d41f-41f2-8869-5bc6af240d46">
        <source>below(point : Point) : Boolean;
// Return true if self is below point
begin
	return self.y &gt; point.y;
end;
</source>
        <Parameter name="point" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="bottom" id="89dfa7f2-24d9-4133-a2e9-5444786333c8">
        <source>bottom() : Integer;
begin
	return self.y;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
