    <JadeMethod name="doSave" id="c97ef25a-144a-46ef-808a-ed617482e3de">
        <updating/>
        <source>doSave(): Boolean updating;
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
vars
	errObj								: CM_Error;
	idx									: Integer;
	tmpListBox							: ListBox;
	ignoreWarnings,rtnValue,
	isNotAvailableForEntry				: Boolean;
	proxyHazardClass					: CM_HazardClass;
	lCode,lDescription,lAlternateCode	: String;
	lColour								: Integer;
	theForm								: SOP_TableMaintForm;
	pxyDrawingAttribute					: CM_DrawingAttribute;		// PAR #36206
	font								: String;					// PAR #36206
	character							: String;					// PAR #36206
begin
  theForm := self.myForm; 

	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
    lAlternateCode := theForm.tblInput1.getValueByName(ETRow_AlternateCode).String;
    lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
    isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	
	font := theForm.tblInput1.getValueByName(ETRow_Font).String;						// PAR #36206
	character := theForm.tblInput1.getValueByName(ETRow_Character).String;				// PAR #36206
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_HazardClass transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyHazardClass := theForm.myProxyObject.CM_HazardClass;
	proxyHazardClass.setProxy(lCode,lDescription,lAlternateCode,lColour, isNotAvailableForEntry);
	
	if proxyHazardClass.myDrawingAttribute &lt;&gt; null then									// PAR #36206
		pxyDrawingAttribute := proxyHazardClass.myDrawingAttribute;						// PAR #36206
	else																				// PAR #36206
		create pxyDrawingAttribute transient;											// PAR #36206
	endif;																				// PAR #36206
	if not self.doSaveDrawingAttributePxy(pxyDrawingAttribute) then						// PAR #36206
		delete pxyDrawingAttribute;														// PAR #36206
		pxyDrawingAttribute := null;									// PAR #36421
	endif;																				// PAR #36206

	if theForm.mode = theForm.Mode_Add then
		//app.myTrxCA.trxCreateHazardClass(proxyHazardClass, theForm.myCurrentObject,app.myPassport);						// PAR #36206						// PAR #36206
		app.myTrxCA.trxCreateHazardClass(proxyHazardClass, theForm.myCurrentObject, pxyDrawingAttribute, app.myPassport);	// PAR #36206
	elseif theForm.mode = theForm.Mode_Update then
		//app.myTrxUA.trxUpdateHazardClass(proxyHazardClass,app.myPassport);												// PAR #36206
		app.myTrxUA.trxUpdateHazardClass(proxyHazardClass, pxyDrawingAttribute, app.myPassport);							// PAR #36206
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
