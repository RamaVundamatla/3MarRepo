    <JadeMethod name="getKeyLengthForXTABDictionary" id="df91f211-acef-4461-b48f-4b59a0790d64">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query

*/

vars
	length	:Integer;
begin

	length := app.getErrorString(Invoice).length;
	length := length.max(app.getErrorString(Credit_note).length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
