    <JadeMethod name="create" id="2b42324c-ecf5-4ff3-8c77-64c94727acde">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

