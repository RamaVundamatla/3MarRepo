<GUIClass name="CMUI_Sheet" id="d0729396-05cb-4922-895a-6b42f7058f99">
    <superclass name="Sheet"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="disableAllChildren" id="e71ed004-935a-483f-9cf4-061d6d1902cf">
        <source>disableAllChildren();
/*
Purpose:			
Date		Who		Reason
08 July 2016	cnwab1	Initial creation
*/

vars
	children : CnEcControlArray;
	child : Control;
begin
	create children transient;
	self.cnEcGetAllChildControls(children, true);
	
	foreach child in children	discreteLock do
		child.enabled := false;
	
	endforeach;
	
	
epilog
	delete children;
end;</source>
    </JadeMethod>
    <JadeMethod name="getFirstChildOfType" id="b10fa334-8e91-45c4-b7b4-ffb75f5c853c">
        <source>getFirstChildOfType(_type : Class) : Control;
/*
Purpose:			
Date		Who		Reason
08 July 2016	cnwab1	Initial creation
*/

vars
	children : CnEcControlArray;
	child : Control;
begin
	create children transient;
	self.cnEcGetAllChildControls(children, true);
	
	foreach child in children	discreteLock do
		if child.class = _type then
			return child;
		endif;
	
	endforeach;
	
	return null;
epilog
	delete children;
end;</source>
        <Parameter name="_type" type="Class"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="visible" id="602b7a46-ada2-4121-8022-034babd34aac">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>visible(set: Boolean; value: Boolean io) updating, mapping, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpParent	: Window;
begin
	if (not set) or 
	   self.isInPainter then
		inheritMethod(set, value);
		return;
	endif;

	tmpParent := self.parent;
	if (not CMUI_Folder.hasInstance(tmpParent)) then
		inheritMethod(set, value);
		return;
	endif;

	if (not value) then
		// need to set own backColor to non-selected
		tmpParent.CMUI_Folder.setSheetBackColor(self, false);
	endif;

	inheritMethod(set, value);

	if (not value) then
		// need to set new top sheet to selected color
		tmpParent.CMUI_Folder.setSheetBackColor(tmpParent.Folder.topSheet, true);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
