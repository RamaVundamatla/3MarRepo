    <JadeMethod name="doConnectionTest" id="f748c681-4092-44c5-b15c-73b94996e721">
        <source>doConnectionTest(_result: String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2024	jlier1	Initial creation

*/

vars
	token : CMIF_OAuthToken;
	errorResponse,
	bearerToken : String;
	ewsActivity : CM_EWSActivityInvoiceAPI;
begin

	if self.clientKey = null or (self.clientSecret = null and self.userCode = null and self.password = null) or self.tenantId = null  then
		return inheritMethod(_result);
	endif;
	
	token:=	app.allExtOAuthTokens[CMIF_OAuthToken.TYPE_API, null];
	if token &lt;&gt; null then
		app.allExtOAuthTokens.remove(token);
		delete token;
	endif;
	
	//lets see if we can get a token
	if self.allEndpoints[ETRow_NswCreateInvHeader] = null then
		//bearerToken := app.getTokenFromEndpoint(null,CMIF_OAuthToken.TYPE_API, self.getBaseAuthEndpoint, self.clientKey, self.clientSecret, self.scope, self.tenantId, self.userCode, app.pwDeCode(self, self.password), self.oAuth2Version, self.resource, errorResponse);
		// CM_ExternalWebServiceDef::doConnectionTest does all the token stuff for us AND actually does a connection test on the base endpoint
		return inheritMethod(_result);
	else
		bearerToken := self.getMultipartFormDataToken(null,null,errorResponse,ewsActivity);
	endif;
	
	if bearerToken &lt;&gt; null  then
		_result:="Successfully got Authentication from " &amp; self.name &amp; " " &amp;  self.getAuthenticationURL;
		return true;
	endif;
	
	_result:="Failed to get Authentication from "  &amp; self.name &amp; " " &amp;   self.getAuthenticationURL  &amp; " returned error " &amp; errorResponse;
	return false;
	
epilog

end;</source>
        <Parameter name="_result" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuthenticationURL" id="20451e4d-6f14-4006-b36c-eb70bf6e2057">
        <source>getAuthenticationURL() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2024	jlier1	Initial creation 65950

*/

vars
	url : String;
begin
	url := self.getBaseAuthEndpoint;		
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	if self.oAuth2Version = 1 then
		url:=url  &amp; self.tenantId &amp; "/oauth2/token";
	else
		url:=url  &amp; self.tenantId &amp; "/oauth2/v2.0/token";
	endif;
	
	return url;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBaseAuthEndpoint" id="40ca04a7-e7ea-4ef8-8b08-7e6f3649ac52">
        <source>getBaseAuthEndpoint() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2024	jlier1	Initial creation TFS 65949 - task 65950 - NSW | Dynamics Integration

*/

vars

begin
	if self.baseAuthEndpoint &lt;&gt; null then	
		return self.baseAuthEndpoint;
	endif;
	
	return "https://login.microsoft.com/";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomer" id="8ee12f8b-aef6-4d17-b470-11efb570ea4e">
        <source>getCustomer() : String;
/*

Purpose:			Added a "Customer" attribute to the External Web Service Definition, so that we can dynamically choose the transformation type instead of always defaulting to CMIF_ApiMapper.CUSTOMER_EUP earlier. 
					This getter method returns the customer associated with this external web service which helps us retrive the right customer dynamically, making it more flexible.

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2025	naviv1	JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer

*/

vars
begin
	if self.customer &lt;&gt; null then
		return self.customer;
	endif; 
	return CMIF_ApiMapper@getClientNameFromSystem();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4b1a4726-a011-47df-b088-f4a87b02bf2f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
// 14/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message`
// 30/05/2023	navra1		TFS 58203 - FR 54536 - EDI Message Type - Damage &amp; Repair Blur Security Fields
// 05/09/2024	jlier1 		TFS 65950 - CR 65949 NSW | Dynamic Integration Development
// 04 Feb 2025  naviv1  	JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceAPIEndpoint;
	elseif _attrName = ETRow_AuthKey then
		return self.authKey;
	elseif _attrName = ETRow_ClientID then
		return self.clientKey;
	elseif _attrName = ETRow_ClientSecret then
		//navra1 - TFS 58203 - 30th May 2023
		if self.clientSecret = null then
			return '';
		else
			return '******';
		endif;
	elseif _attrName = ETRow_ExportDetails then
		return self.exportDetails;
	elseif _attrName = ETRow_IsForCams then
		return self.isForCams.cnEcGetTableCheckBoxValue;
	elseif _attrName = ETRow_Scope then
		return self.scope;
	elseif _attrName = ETRow_SubscriptionKeyName then
		return self.subscriptionKeyName;
	elseif _attrName = ETRow_SubscriptionKeyValue then
		//navra1 - TFS 58203 - 30th May 2023
		if self.subscriptionKeyValue = null then
			return '';
		else
			return '******';
		endif;
	elseif _attrName = ETRow_TenantId then
		return self.tenantId;
	elseif _attrName = ETRow_BaseAuthEndpoint then	
		return self.baseAuthEndpoint;
	elseif _attrName = ETRow_OAuth2Version then	
		if self.oAuth2Version = 0 then
			return "2";
		else
			return self.oAuth2Version.asStringJMT;
		endif;
	elseif _attrName = ETRow_Resource then	
		return self.resource;
	elseif _attrName = ETRow_Customer then		//04-Feb-2025 naviv1 MTN-12173
		return self.customer;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastSuccessfulTS" id="09f23ded-b9f3-457c-af42-5fbc5061af27">
        <source>getLastSuccessfulTS(_terminal : CM_Terminal) : TimeStamp;
/*
Purpose: Retrieve the last successful timestamp for the provided terminal.
Parameters:
    _terminal : CM_Terminal - The terminal for which the last successful timestamp is to be retrieved.
Return Value: TimeStamp - The last successful timestamp associated with the terminal code.
Date         Who    Reason
09 Dec 2025 navah1  Initial creation
09 Dec 2025 navah1	MTN-36364: NSW | OnePort API Last Run Date - Use the terminal-specific Last Successful Date/Time for external web service task runs
*/
vars
	lastSuccessfulDT : CM_EWSTerminalLastSuccessDT;
begin
    if self.allTerminalLastSuccessDT &lt;&gt; null then
        lastSuccessfulDT := self.allTerminalLastSuccessDT[_terminal.code]; 
        if lastSuccessfulDT &lt;&gt; null then
            return lastSuccessfulDT.lastSuccessDt;
        endif;
    endif;
    // Return null if the entry for the terminal code is not found
    return null;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getMultipartFormDataToken" id="d92cb490-8ecd-49e4-935d-aaffadc7dc25">
        <source>getMultipartFormDataToken(_terminal : CM_Terminal; _invoice : CM_Invoice; _errorResponse : String output; _ewsActivity :  CM_EWSActivityInvoiceAPI output): String;
/*

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Sep 2024 jlier1  TFS 65950: CR 65949 NSW | Dynamics Integration - External Web Service Definition Changes
*/
constants
	RefreshWindowSecs	: Integer = 300;	// 5 minutes
	DefaultTimeout		: Integer = 3600;
vars
	oAuthToken		: CMIF_OAuthToken;
	jadeRestClient : JadeRestClient;
	request  : JadeRestRequest;
    response : JadeRestResponse;
	responses : ObjectArray;
	url 		: String;
	msg 			: String;
	msTokenRes		: MSOAuthResponse;
	token			: String;
	tokenTimeout	: Integer;
	agent : CM_APIConsumerAgent;
begin
	oAuthToken := app.allExtOAuthTokens[CMIF_OAuthToken.TYPE_API, _terminal];
	if oAuthToken = null or oAuthToken.expiresIn &lt; RefreshWindowSecs then
		if self.clientKey  = null or (self.clientSecret = null and self.userCode = null and  self.password = null) or self.tenantId = null then		//TFS 63842
			msg := "Client ID, Client Secret or Tenant ID not defined in Terminal or System Config";
			app.writeLog(method.qualifiedName &amp; Tab &amp; msg, LogERROR);
			app.createAlert(app.getErrorString1(EmailReceiveFailure, msg), true);
			app.raiseCMException1(EmailReceiveFailure, msg, null, null);			
			return null;
		endif;
	
		url := self.getAuthenticationURL();
	
		jadeRestClient:=create JadeRestClient(url);
		request := create JadeRestRequest("");
		request.dataFormat:=JadeRestRequest.DataFormat_MultipartFormData;  //multipart/form-data
		msg:='Content-Type: multipart/form-data' &amp; CrLf;
		if self.clientKey &lt;&gt; null then
			request.addMultipartFormData("client_id",null,"text/plain",self.clientKey);
			msg:=msg &amp; "form client_id=" &amp; self.clientKey &amp; CrLf;
		endif;
		if self.clientSecret &lt;&gt; null then
			request.addMultipartFormData("client_secret",null,"text/plain",self.clientSecret);
			request.addMultipartFormData("grant_type",null,"text/plain","client_credentials");
			msg:=msg &amp; "form client_secret=****************" &amp; CrLf;
			msg:=msg &amp; "form grant_type=client_credentials" &amp; CrLf;
		elseif  self.password &lt;&gt; null then
			request.addMultipartFormData("grant_type",null,"text/plain","Password");
			request.addMultipartFormData("password",null,"text/plain", self.password);
			request.addMultipartFormData("username",null,"text/plain",self.userCode);
			msg:=msg &amp; "form grant_type=Password" &amp; CrLf;
		endif;
		if self.resource &lt;&gt; null then
			request.addMultipartFormData("resource",null,"text/plain", self.resource);
			msg:=msg &amp; "form resource=" &amp; self.resource  &amp; CrLf;
		endif;
		if self.scope &lt;&gt; null then
			request.addMultipartFormData("scope",null,"text/plain",self.scope);
			msg:=msg &amp; "form scope=" &amp; self.scope &amp; CrLf ;
		endif;
		
		app.writeLog(method.qualifiedName &amp; 
                       "_name="&amp;self.name&amp;
					   " _url=" &amp; url &amp;
					   ", _verb=" &amp; "POST" &amp;
					   ", _additionalHeaders=" &amp; request.getAllHeaders &amp;
					", _postData=" &amp; msg, LogDEBUG);	
		
		
		response := create JadeRestResponse();
		jadeRestClient.post(request, response);
		
		//should create an activity history if there is a problem
		app.writeLog(method.qualifiedName &amp; " returnVal=" &amp; response.data, LogDEBUG);
		
		if self.isInvoiceAPIDef then
			create agent as CM_InvoiceAPIConsumerWSAgent transient;
			agent.CM_InvoiceAPIConsumerWSAgent.setMyInvoice(_invoice);
		else
			create agent transient;
		endif;
		agent.setupFromWebServiceDefinition(self);
		agent.setMyTerminal(_terminal);
		
		agent.doCreateActivityHistory(null,"POST " &amp; url, msg,response.data,response.statusCode);
		
		if self.isInvoiceAPIDef then
			_ewsActivity:=agent.CM_InvoiceAPIConsumerWSAgent.myEWSActivity;
		endif;
		
		if response.statusCode &lt;&gt; HttpResponseOK  and response.statusCode &lt;&gt; HttpResponseCreated then
			return null;
		endif;
		
		create responses transient;
		response.deserialize(MSOAuthResponse, responses);
		msTokenRes:=responses.first.MSOAuthResponse;
		
		if msTokenRes = null then
			_errorResponse:=response.data;
			// Welp, something went wrong, can only bail from here
			app.writeLog(method.qualifiedName &amp; " Error parsing Token response", LogERROR);
			return null;
		endif;
		
		// If we have a sensible error message back, then let the user see it
		if msTokenRes.error &lt;&gt; null then
			_errorResponse:=response.data;
			app.writeLog(method.qualifiedName &amp; "  Error getting token. (" &amp; msTokenRes.error &amp; ")", LogERROR);		
			return null;
		endif;
		
		if msTokenRes.access_token = null then
			// *something* must have gone wrong, not much we can do except bail
			app.raiseUnexpectedProgramError(class.name, method.name, "Unknown error. 'access_token' is null");
			return null;
		endif;
		
		token := msTokenRes.access_token;
		tokenTimeout := msTokenRes.expires_in;
		if tokenTimeout = 0 then
			tokenTimeout := DefaultTimeout;
		endif;
		
		if app.logLevel = LogTRACE then
			// The token is a sensitive string and should NOT be logged normally!
			app.writeLog("Got a token back - " &amp; token, LogTRACE);
		else
			app.writeLog("Got a token back - token timeout is " &amp; tokenTimeout.String, LogINFO);
		endif;
		
		if oAuthToken = null then
			oAuthToken := create CMIF_OAuthToken(_terminal, CMIF_OAuthToken.TYPE_API);
		endif;
		oAuthToken.accessToken := token;
		oAuthToken.expiresIn := tokenTimeout;
	else	
		//should create activity history
		if app.logLevel = LogTRACE then
			// The token is a sensitive string and should NOT be logged normally!
			app.writeLog("Reusing existing token - " &amp; oAuthToken.accessToken, LogTRACE);
		else
			app.writeLog("Reusing existing token.", LogINFO);
		endif;
	endif;
	
	return oAuthToken.accessToken;
	
epilog
	delete jadeRestClient;
	delete request;
    delete response;
	if responses &lt;&gt; null then	
		responses.purge;
	endif;
	delete responses;
	delete agent;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_errorResponse" type="String" usage="output"/>
        <Parameter name="_ewsActivity" type="CM_EWSActivityInvoiceAPI" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
