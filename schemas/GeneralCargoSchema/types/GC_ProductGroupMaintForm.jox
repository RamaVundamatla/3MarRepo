    <JadeMethod name="setProductsAvailForMultiSelect" id="88b5d29e-712f-4db4-a83e-df7af3e94761">
        <source>setProductsAvailForMultiSelect( _cargoType : CM_CargoType; _prodGroup : CM_ProductGroup ) protected;
/* ---------------------------------------------------------------------------
Created:	06 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	productSet	: CM_ProductSet;

begin

	create productSet transient;
	
	self.myAssistant.getAllProductsForProductGroup(_cargoType, _prodGroup, productSet);

	self.msgProducts.setAvailable(productSet, true);
	
	if self.mode = self.Mode_Add then
		self.msgProducts.setSelected(null);
	else
		self.msgProducts.setSelected(_prodGroup.allProducts);
	endif;

	

epilog
	delete productSet;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_prodGroup" type="CM_ProductGroup"/>
    </JadeMethod>
    <JadeMethod name="setProductsAvailable" id="88b978d8-bea1-437f-aaee-71e9794f67ac">
        <source>setProductsAvailable() protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	productGroupObj	: CM_ProductGroup;
	cargoTypeObj	: CM_CargoType;
	
begin
	
	if self.myCurrentObject = null then		// 25/03/2008 cnwar2 #16257 - don't populate available products if creating new product group
		self.setProductsAvailForMultiSelect(null, null);	//cleares multi select box. Par 18926 April 2009
		return;
	endif;
	
	productGroupObj	:=	self.myCurrentObject.CM_ProductGroup;
	
	//commented by Par18296 April 2009. When select a cargo type in the seracher and don't search, 
	//there is problem, when editting an existing current prod group in the data table.
	//The prod group will have all products availabale from the searcher with different cargo typre,
	//but not from the exisiting current prod group in the data table.
	/*if self.aMyCurrentCargoType = null then
		cargoTypeObj	:=	productGroupObj.myCargoType;
	else
		cargoTypeObj	:=	self.aMyCurrentCargoType;
	endif;*/
	cargoTypeObj	:=	productGroupObj.myCargoType;	//Always get the cargo type from an existing current prod group in the data table. Par18296 April 2009.

	self.setProductsAvailForMultiSelect(cargoTypeObj, productGroupObj);	// to put in one place and use from many places using CMUI_Assistant. Par 18926 April 2009
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="539c9f75-6b25-46fd-b97d-2549a6adc425">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	self.isSearcherVisible := true;
	//self.caption := "Product Groups";
	self.caption := app.getErrorString(Cargo_Subtype_Groups);
		
//	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType,null);
	cmbCargoType.automaticCellControl	:=	true;
	self.sptDataFilter.setLeftToRightRatioAndResize(35);
	self.allowDelete := true; 
	self.initMSG();
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="1af9c30a-e671-49dc-87cd-919e4cc6188a">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	productGroupObj	: CM_ProductGroup;
	rowPointer		: Integer;
	rowCount		: Integer;
	tableCellObj,
	valueCell 	: JadeTableCell;
	
begin
	self.fldEntDetail.visible	:=	false;
	productGroupObj				:=	obj.CM_ProductGroup;
	self.tblThumb.rows			:=	0;
	self.tblThumb.columns		:=	2;
	self.showThumbnailForDef(ETDef_ProductGroupMaint, productGroupObj);
	
	rowPointer	:=	1;
	rowCount	:=	self.tblThumb.rows;
	
	foreach rowPointer in rowPointer to rowCount do
		tableCellObj	:=	self.tblThumb.accessCell(rowPointer, 1);
		
		if tableCellObj.text = "Colour" then
		//epr par 12709 10/10/06
			valueCell:=self.tblThumb.accessCell(rowPointer, 2);
			valueCell.backColor	:=	productGroupObj.colour;
			valueCell.text		:=	null;
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblFilterCellInputReady" id="42ef0433-9fc0-40c8-928f-3af3cc7d4c80">
