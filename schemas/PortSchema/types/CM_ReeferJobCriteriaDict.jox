    <JadeMethod name="findByNamne" id="2c4c5d80-8a87-4658-b4bb-fc7338a86bae">
        <source>findByNamne( _name: String ):CM_ReeferJobCriteria;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	iter : Iterator;
	reeferJobCriteria : CM_ReeferJobCriteria;

begin

	iter:= self.createIterator;
	while iter.next( reeferJobCriteria ) do
		if reeferJobCriteria.name = _name then
			return reeferJobCriteria;
		endif;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_ReeferJobCriteria"/>
    </JadeMethod>
</CollClass>
