    <JadeMethod name="setYATypeCommReeferUnused" id="e0504185-073f-456d-aa6e-e75d930f9a2a">
        <source>setYATypeCommReeferUnused(_controller : CnEcReleaseController);
/*

Purpose:  Hide Communicating/NonCommunciating Reefer Yard Allocation Criteria form JMT by setting the IsUsed to false

Parameters:			

Return Value:		

Date		Who		Reason
26/04/2016  cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria

*/

vars
	yat : CM_YATypeCommReefer;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Set CM_YATypeCommReefer IsUsed Property to false ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Set CM_YATypeCommReefer IsUsed Property to false") ;	
	endif;
	
	yat := CM_YATypeCommReefer.firstInstance;
	 
	if yat &lt;&gt; null then
		if yat.isUsed then
			beginTransaction;
				yat.setPropertyValue("isUsed",false);
			commitTransaction;
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Set CM_YATypeCommReefer IsUsed Property to false complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Set CM_YATypeCommReefer IsUsed Property to false complete") ;	
	endif;
	self.addScriptRun(method.name);
	

epilog

end;</source>
