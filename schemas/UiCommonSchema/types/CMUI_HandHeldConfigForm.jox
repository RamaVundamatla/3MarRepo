    <JadeMethod name="keyDown" id="d6793520-89a6-4398-8d32-cf23aa9a74b0">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//12 Dec 2017	cnwrs1	TFS 3148/2866 use new HH config matchFindCargoConsignee
vars

begin
	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh;
		return;
	endif;
	inheritMethod(keyCode, shift);
end;
</source>
