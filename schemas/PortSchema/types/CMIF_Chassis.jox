    <JadeMethod name="actionForCreate" id="66474114-c83c-48db-bfc5-f1b8c6af1b68">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 15 May 2007
//
//----------------------------------------------------------------------

vars
	trailerType 	: CM_TILCType;
	trailerHeader 	: CM_TIMasterTILC;
	trailerItemInfo : CM_TILC;
	tmpTI : CM_TrackedItem;
	theCargoType 	: CM_CargoType;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	job 			: CM_RoadJob;
	request 		: CM_Request;
	plannedLocn		: CM_LocationsController;
	subItem				: CMIF_TIObject;
	nullObject			: CM_Object;
		tmpConsignorVoyageCode, tmpEirNumber, tmpConsignee : String;

begin
	
	job := self.getInOutJob();
	if job = null then
		return false;
	endif;

	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if self.myProxyTrackedItem &lt;&gt; null then
		self.myPersistentTrackedItem := self.myTerminal.createTrackedItem(self.myProxyTrackedItem, _passport); // &lt;&lt; this creates and attaches the children as well
	endif;
	
	if self.myPersistentTrackedItem &lt;&gt; null then
		//From CMIF_Receival
		if _passport.noErrors then
			//Receive the TI onto the vehicle, DO NOT pass in the job or wle else the job gets set to complete and a visit is recorded
			//changed back to original  job.myVehicle.myPrimaryActualLocation
			//self.myPersistentTrackedItem.moveToLocation( job.myVehicle.locationsController, null, null, null,REAL_MODE, true, true, false, false, false, false, null,null,_passport);		// TFS 2651
			self.myPersistentTrackedItem.moveToLocation( job.myVehicle.locationsController, null, null, null,REAL_MODE, true, true, false, false, false, false, null,null,null,null,job.myVehicleVisit,_passport);	// TFS 2651
			//self.myPersistentTrackedItem.setHazardLocations(); PAR 16097
			self.myPersistentTrackedItem.setHazardLocationsForMode(REAL_MODE, false);
			
// REMOVE THIS! AKB2008OCT			
//			foreach subItem in self.allSubItems do
//				subItem.actionForCreatePost(self.myPersistentTrackedItem, _passport);
//			endforeach;
		endif;
	endif;
	
	if _passport.noErrorsIgnored() then
		// create the request
		create self.myProxyTIRequest transient;
/* WAS
		self.myProxyTIRequest.setProxy(false, self.myProxyTrackedItem.consignorVoyageCode, self.myProxyTrackedItem.eirNumber, // lClean, lconsignorVoyageCode, leirNumber
								self.myProxyTrackedItem.consignee, self.doorsDirection, 
								null, self.freightForwarderCode, null, true, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
								null,null, 0,null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
								false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
								false, null, self.remarks, self.myPersistentTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI
								_passport.userCode, null);
							*/
		if self.myProxyTrackedItem &lt;&gt; null then
			tmpConsignorVoyageCode := self.myProxyTrackedItem.consignorVoyageCode;
			tmpEirNumber := self.myProxyTrackedItem.eirNumber;
			tmpConsignee := self.myProxyTrackedItem.consignee;
		endif;
		
		self.myProxyTIRequest.setProxy(false, tmpConsignorVoyageCode, tmpEirNumber, // lClean, lconsignorVoyageCode, leirNumber
								tmpConsignee, self.doorsDirection, 
								null, self.freightForwarderCode, null, true, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
								null,null, 0,null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
								false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
								false, null, self.remarks, self.myPersistentTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI
								_passport.userCode, null);
							
	endif;
	
	if _passport.noErrors then	
		//Validate the request (TI is already validated)
		self.myProxyTIRequest.validate(self.myUserObject);
	endif;
	
	if (not _passport.noErrorsIgnored()) then
		return false;
	endif;

	//Add the request to the job	
	request := job.addRequest(self.myProxyTIRequest, _passport);
	self.myRequest := request; // PAR 17703
	
	
	if request = null or _passport.hasErrors then
		return false;
	endif;

	//Add the TI to the job
	job.addTI(self.myPersistentTrackedItem, self.myProxyTIRequest);

	if _passport.noErrors then		
		// Autoplan the TI to suitable yard location
		if  job.autoComplete then
			plannedLocn := self.getPlannedLocation();
			if plannedLocn &lt;&gt; null then
				//self.myPersistentTrackedItem.moveToLocation(plannedLocn, job, null, null,PLANNING_MODE, false, true, false, false,false,  false, null,null,_passport);	// TFS 2651
				self.myPersistentTrackedItem.moveToLocation(plannedLocn, job, null, null,PLANNING_MODE, false, true, false, false,false,  false, null,null,null,null,job.myVehicleVisit,_passport);	// TFS 2651
			endif;
		endif;
	endif;	
	
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
