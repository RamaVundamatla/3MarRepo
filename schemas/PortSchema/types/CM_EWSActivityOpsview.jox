    <JadeMethod name="getUnitId" id="3cbc8982-a6e9-4fae-9859-1dcf04911b44">
        <source>getUnitId() : String;
/*
Purpose:			

Date		Who		Reason
09JUN2022	NAVAB1	TFS 53105
*/

vars
	st, ed, len : Integer;
	unitID : String;
begin
	if dataType = BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM then
		st := self.request.pos('"id"', 1);
		
		if st &gt; 0 then
			st += 6;
			ed := self.request.pos(",", st) - 1;
			len := ed - st;
			
			if st &gt; 0 and len &gt; 0 then
				unitID &amp;= BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM &amp; " - " &amp;  self.request[st:len];
			endif;
		endif;
	endif;

	return unitID;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseActivity" id="4f4bc9e3-d0fe-4762-a351-2e04b382e013">
        <updating/>
        <source>initialiseActivity(_description, _interface : String; _terminal : CM_Terminal; _opsViewObject : CM_Object; _dataAction: Character; _dataType : String; _snapshot : Boolean; _oid : String) updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
begin
	inheritMethod(_description, _interface, _terminal, _opsViewObject, _dataAction, _dataType, _snapshot, _oid);
	
	self.myOpsviewObject := _opsViewObject;
	self.dataAction := _dataAction;
	self.dataType := _dataType;
	self.isSnapshot := _snapshot;
	self.objectOid := _oid;
	
	
epilog
end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_interface" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opsViewObject" type="CM_Object"/>
        <Parameter name="_dataAction" type="Character"/>
        <Parameter name="_dataType" type="String"/>
        <Parameter name="_snapshot" type="Boolean"/>
        <Parameter name="_oid" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseStatus" id="40a87248-8a96-4773-8b71-cbd12a93e135">
        <updating/>
        <source>initialiseStatus(_status : String; _manager : BGP_Manager) updating;
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
*/

vars
	request : BGP_Request;
begin
	inheritMethod(_status, _manager);
	
	request := self.myBGPRequest;
	if request &lt;&gt; null then
		app.myUtilityDA.utlDeleteBGPRequest(_manager,request , true, app.myPassport);

		self.myBGPRequest := null;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_status" type="String"/>
        <Parameter name="_manager" type="BGP_Manager"/>
    </JadeMethod>
