<Class name="CM_YATypeItemized" id="0c713797-5673-46a8-b77b-f40ef472335b">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="52b113d6-1d2e-47ec-b61b-f0d788f7e072">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 August 2023
TFS#		: 58429
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	_process := _ti.itemised;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="cadaa9fc-824b-4615-abad-05d0896d44f7">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 August 2023
TFS#		: 58429
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _ti.itemised then
		_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="517e4856-82f6-4d59-a889-9eae0f44044a">
        <source>getTypeName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 June 2023	navpw1	Initial creation TFS: 58429 (58517)

*/

begin
	return "Itemized";
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
