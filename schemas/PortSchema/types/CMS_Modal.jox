        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

vars

begin

	self.doOK();
	modalResult := IDOK;
	unloadForm;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkSecurity" id="b1ebcfd3-d776-4c6e-8287-d0395fc3c1e8">
        <source>checkSecurity(permissionCode:Integer; permLabel:String):Boolean;

vars

begin
	// AKB PAR 3736 - 24Jan2001 added. Has the user got  access?
	if not app.myCurrentUserCan(self.myTerminal, permissionCode) then
		app.msgBox(app.getErrorString1(VB_SECMOVE,permLabel) ,
										"Application Security",
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	else
		return true;
	endif;

end;</source>
        <Parameter name="permissionCode" type="Integer"/>
        <Parameter name="permLabel" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
