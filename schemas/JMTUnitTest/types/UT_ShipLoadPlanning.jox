epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="getAllContainerDetails" id="734012e4-0328-43cd-ab4b-99318064b141">
        <source>getAllContainerDetails(_startID,
							_numContainers : Integer;
							_terminalArea : CM_StraddleStack;
							_voyageID,
							_dischargePort : String;
							_imex : Integer;
							_commodity,
							_iso,
							_operator: String;
							_allAssocs : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2008	cnwer1	Initial creation

*/

vars

	numberToCreate,
	i : Integer;
	alphaPart, id : String;
	//stradStackA : CM_StraddleStack;
	maxRow,
	maxCol,
	row,
	col,
	maxHeight,
	height : Integer;
	rowCol : Point;
	assocDict : CM_AssociationDict;
begin
	
	
	alphaPart:="USLP" ;//;//;"EPR2410"
	//stradStackA:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	maxRow:=_terminalArea.numberOfRows;
	maxCol:=_terminalArea.numberOfColumns;
	maxHeight:= _terminalArea.heightOfStack;
	if _numContainers = null then
		numberToCreate:=_terminalArea.allGridControllersByRowColumn.size;
		numberToCreate:=numberToCreate*maxHeight;
	else
		numberToCreate:=_numContainers;
	endif;
	row:=1;
	col:=1;
	height:=1;
	i:=1;
	while i  &lt;= numberToCreate do
		id:=alphaPart &amp; (_startID + i).stringWithLeadingZeros(7);
		
		create assocDict transient;
		assocDict.addAssociation("ID",id);
		if _voyageID &lt;&gt; null then
			assocDict.addAssociation("VoyageName",_voyageID);
		endif;
		if _imex &lt;&gt; null then
			assocDict.addAssociation("IMEX",_imex);
		endif;
		if _dischargePort &lt;&gt; null then
			assocDict.addAssociation("DischargePort",_dischargePort);
		endif;
		if _iso &lt;&gt; null then
			assocDict.addAssociation("ISO",_iso);
		endif;
		if _commodity &lt;&gt; null then
			assocDict.addAssociation("Commodity",_commodity);
		endif;
		if _operator &lt;&gt; null then
			assocDict.addAssociation("Operator",_operator);
		endif;
		
		if _terminalArea &lt;&gt; null then
			assocDict.addAssociation("LOC_TA",_terminalArea);
			assocDict.addAssociation("LOC_ROW",row);
			assocDict.addAssociation("LOC_COL",col);
		endif;
		_allAssocs.add(assocDict);
		if height = maxHeight then
			height:=0;
			if col = maxCol then
			
				col:=1;
				row:=row +1;
			else	
				col:=col + 1;	
			endif;
		endif;
		i:=i + 1;
		height:=height+1;
	endwhile;

end;</source>
        <Parameter name="_startID" type="Integer"/>
        <Parameter name="_numContainers" type="Integer"/>
        <Parameter name="_terminalArea" type="CM_StraddleStack"/>
        <Parameter name="_voyageID" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_iso" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_allAssocs" type="ObjectArray" usage="input"/>
    </JadeMethod>
