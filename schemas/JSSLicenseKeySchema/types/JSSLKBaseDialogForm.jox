    <JadeMethod name="setReferences" id="bbc6cd1b-1580-44a3-b96a-1c3ae62aae12">
        <updating/>
        <source>setReferences(pTheServiceManager:JSSLKServiceManager; pTheServiceObject:JSSLicenseKeyService; pTheRoot:JSSLKRoot) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Sets references to the peer schema's service manger and service
//				interface objects, and to the Root object.
//
// Parameters:	pTheServiceManager - The peer schema service manager object.
//				pTheServiceObject - The peer schema service interface object.
//				pTheRoot - The peer schema's root data object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyServiceManager	:=	pTheServiceManager;
	self.aMyServiceObject	:=	pTheServiceObject;
	self.aMyRoot			:=	pTheRoot;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager"/>
        <Parameter name="pTheServiceObject" type="JSSLicenseKeyService"/>
        <Parameter name="pTheRoot" type="JSSLKRoot"/>
    </JadeMethod>
</GUIClass>
