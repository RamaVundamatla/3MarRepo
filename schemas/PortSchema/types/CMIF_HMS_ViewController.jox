    <JadeMethod name="doRefreshView" id="ee9103a5-da5e-4eba-a050-afb70dc3f4b3">
        <updating/>
        <source>doRefreshView(_refreshTimePeriod : Boolean) updating;

/*

Date		Who		Reason
11 Apr 2008	cnwkpd1	PAR #16517 - Need to update currentChangeStackPosition whenever allChanges
					is updated

*/

vars
	monitor : CMIF_Monitor;
begin
 	// This method is called when the user presses the F5 key on the 
 	// graphical view. If there are any changes in the stack the user must
 	// agree to the discard all of these before the view is refreshed.
	
	// refresh view now
	monitor := app.myPassport.myCMIFMonitor;
	
	if monitor &lt;&gt; null then
		if (not monitor.updateProgress(app.getErrorString(Compiling_Voyage_List), 3, 0)) then
			return;
		endif;
	endif;

	self.allChanges.purge;
	self.allNotableObjects.clear;	

	self.currentChangeStackPosition := 0;			// PAR #16517
	
	self.buildView_WorkingVoyageAndMove();
	
	if monitor &lt;&gt; null then
		if (not monitor.updateProgress(app.getErrorString(Rebuilding_Labels_And_Backgrou), 3, 1)) then
			return;
		endif;
	endif;
	
	if _refreshTimePeriod then
		// time period has changed, redraw the time and wharf lables
		self.view_BuildBackground();
	endif;
	
	if monitor &lt;&gt; null then
		if (not monitor.updateProgress(app.getErrorString(Building_Foreground), 3, 2)) then
			return;
		endif;
	endif;

	// rebuild the ships. Draw drag pictures	
	self.view_BuildEntireForeground();
	

end;</source>
        <Parameter name="_refreshTimePeriod" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exclusiveLockExHandler" id="6837f54a-167c-4cab-89be-ce19dc0637cb">
        <source>exclusiveLockExHandler(_exObj : LockException; _object : CM_Object; _gotException : Boolean output; _userCode : String output) : Integer protected;
//--------------------------------------------------
// Created:	29 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	_gotException := true;
	_userCode := app.getUserForException(_exObj);
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="LockException"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_gotException" type="Boolean" usage="output"/>
        <Parameter name="_userCode" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exclusiveLockObjectToUpdate" id="154d1ba1-2d43-4280-b62e-dbc8b00cdd84">
        <updating/>
        <source>exclusiveLockObjectToUpdate(_object : CM_Object) : Boolean protected, updating;
//--------------------------------------------------
// Created:	29 July 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16205	- Handle invalid object references by returning false
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/

vars
	invalidObject,							// PAR #16205
	gotException	: Boolean;
	theUser			: String;
	hmsVoyage		: HMS_VoyageData;
	
begin
	if _object = null then
		return false;
	endif;

/*	if app.getLockDetailsForObject(_object, theUser) then
		app.raiseCMException2(ObjectLockedUableToSaveChanges, _object.getDisplayDetails(false), theUser, null, null);	
		return false;
	endif;*/

	on Exception do app.handleDeletedObject(exception, _object, invalidObject);			// PAR #16205
	on LockException do self.exclusiveLockExHandler(exception, _object, gotException, theUser);

	exclusiveLock(_object);

	// PAR #16205 - Check first that the object is valid
	if invalidObject then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "view", null, null);
		return false;
	endif;
	
	if gotException then
		app.raiseCMException2(ObjectLockedUableToSaveChanges, _object.getDisplayDetails(false), theUser, null, null);
		return false;
	endif;
	
	/*
	if (not self.tryLock(_object, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate)) then
		app.raiseCMException1(ObjectLockedUableToSaveChanges, _object.getDisplayDetails(false), null, null);
		return false;
	endif;
	*/

	if HMS_VoyageData.hasInstance(_object) then
		hmsVoyage := _object.HMS_VoyageData;
	elseif HMS_VoyageMovement.hasInstance(_object) then
		hmsVoyage := _object.HMS_VoyageMovement.myHMSVoyageData;
	elseif CM_Voyage.hasInstance(_object) then
		hmsVoyage := _object.CM_Voyage.myHMSVoyageData;
	endif;
	
	if hmsVoyage &lt;&gt; null then
		if (not self.allNotableObjects.includes(hmsVoyage)) then
			self.allNotableObjects.add(hmsVoyage);
		endif;
	endif;
	// if we get to here, the object exists and we've got the lock
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCMIF_GlobalVoyage" id="8f2dd1ce-c046-40db-a771-91e390bc2281">
        <source>getCMIF_GlobalVoyage(_voyage : CM_Voyage) : CMIF_VoyageGlobal;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	workingVoyage 		: CMIF_HMS_WorkingVoyage;
begin

  	foreach workingVoyage in self.allWorkingVoyages do
		if workingVoyage.myCMIF_VoyageGlobal &lt;&gt; null and workingVoyage.code = _voyage.code then
			return workingVoyage.myCMIF_VoyageGlobal;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CMIF_VoyageGlobal"/>
    </JadeMethod>
