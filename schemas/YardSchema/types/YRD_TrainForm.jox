    <JadeMethod name="unload" id="9e192e43-8015-4a49-8620-aaa174d7f563">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwndl1	Initial creation CCMS 1067

*/

vars

begin

	if not self.allWarnings.isEmpty then
		self.allWarnings.purge();
	endif;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateWagonRow" id="07c69d63-bba4-4418-bea0-d5ddd2de8c46">
        <source>updateWagonRow(_wagon : CM_Wagon; _row : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	rowStr			: String;
	entRow			: EntTableRow;
	idx				: Integer;
begin
	if _wagon = null then
		return;
	endif;
	foreach entRow in self.tblWagons.allTblDataEntRows do				
		rowStr := rowStr &amp; _wagon.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	
	self.tblWagons.accessCell(_row, 1).text := rowStr;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="35210866-d78c-45b1-9693-8415fa75acfc">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.handleNotifications(eventType, theObject, eventTag, userInfo);

end;


</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="wagonReceiveDrop" id="3758cc47-440f-4a42-8a55-026a973f3bd0">
        <updating/>
        <source>wagonReceiveDrop( _atWagon : CM_Wagon ) : Boolean updating;

/*

Purpose:			Receive wagons from Wagon Move Controller.

Parameters:			Drop is done at position of given wagon.

Return Value:		


Date		Who		Reason
18 Jun 2009	consw1	Par 20001 - Initial creation
21 May 2024 navbs1  Bug 64222: EUP - 1090 Error when When using Drag and Drop at Train Enquiry Form

*/

vars
	moveController : CMIF_WagonMoveController;
	result : Integer;
	
begin
	if app.myMoveController &lt;&gt; null then
		//  The presence of a 'move controller' means that the current 'wagon move controller' is left
		//  over from a wagon move that was not completed.  The 'wagon move controller' is no longer valid.
		
		// AKB not sure what the cargo move controller has todo with the wagon move controller so removing this 11/3/10
//		return false;
	endif;

	moveController := app.myWagonMoveController;

	if moveController = null or self.mySelectedTrain = null then	//21.05.2024 navbs1 #64222
		return false;
	endif;
	
	moveController.myTargetTrain := self.mySelectedTrain;
	moveController.myTargetRailLine := null;
	moveController.isInwardTarget := self.optDirInTB.value;
	moveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	moveController.targetPosition := 0;  	// end of train

	if _atWagon &lt;&gt; null then
		if moveController.isInwardTarget then
			moveController.targetPosition := self.mySelectedTrain.allWagonsByOrderInward.indexOf(_atWagon);
		else
			moveController.targetPosition := self.mySelectedTrain.allWagonsByOrderOutward.indexOf(_atWagon);
		endif;
	endif;

	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035
	
	while true do
		app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ...
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

	return true;
	
epilog
	if app.myWagonMoveController &lt;&gt; null then
		delete app.myWagonMoveController;
	endif;		
end;</source>
        <Parameter name="_atWagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="warningExcHandler" id="1d854a97-e127-4ad9-9bee-3522b2b01472">
        <updating/>
        <source>warningExcHandler(exObj: Exception; _passport : CM_Passport input): Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwndl1	Initial creation CCMS 1067

*/

vars

begin

	if _passport &lt;&gt; null then
		if exObj.isKindOf(CM_Exception) and exObj.CM_Exception.isWarning then
			_passport.addWarningFull(exObj.errorCode,	//pErrorCode : Integer;
									exObj.extendedErrorText,	//pText : String;
									exObj.CM_Exception.userString,	//pField : String;
									exObj.CM_Exception.myUserObject,	//pObject : Object;
									exObj.CM_Exception.mySubject	//_subject : CM_Object
									);	   
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
