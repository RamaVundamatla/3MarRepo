    <JadeMethod name="validateHMSInvoice4b" id="0e9b5cba-60a6-49f3-be37-11bb1958df60">
        <source>validateHMSInvoice4b(_invoice : CM_Invoice; _step : Integer; _calcType : Integer);
// after rate and vessel GRT etc change 
vars
	invCount	: Integer;
	qty			: Real;
	rate		: Decimal[12, 6];
	total		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	rate := 6;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
	   _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		rate := 8;
	endif;
	if _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 then
		qty := 1;
	elseif _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		qty := 12;
	elseif _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or
	   _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		if _step = 1 then
			qty := 26400;
		elseif _step = 2 then
			qty := 2400;
		elseif _step = 3 then
			qty := 24000;
		elseif _step = 4 then
			qty := 240;
		elseif _step = 5 then
			qty := 28800;
		endif;
	endif;
	total := qty * rate;
	// the following calc types use the qty * GRT (etc) to multiply the rate for the line total, then set the quantity back to the resource used
//PAR 35940	if _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or // INV_CALC_TYPE_TIMEBLCK_HRS_UNT now uses the UNIT BLOCK
	if    _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		qty := 12;
	endif;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total, "line 1 " &amp; _step.String &amp; " value");
			//self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT", "line 1 ILD " &amp; _step.String);
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 1, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_step" type="Integer"/>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateHMSInvoice5" id="a3f16037-d3fe-4957-b2c9-18b55fe19b4f">
        <source>validateHMSInvoice5(_invoice : CM_Invoice; _step : Integer);
// original invoice, Tidal class
vars
	invCount	: Integer;
	qty1,
	qty2		: Real;
	rate1,
	rate2		: Decimal[12, 6];
	total1,
	total2		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	if _step = 1 then
		qty1 := 1;
		qty2 := 1;
	elseif _step = 2 then
		qty1 := 1200;
		qty2 := 1200;
	elseif _step = 3 then
		qty1 := 100;
		qty2 := 100;
	elseif _step = 4 then
		qty1 := 1000;
		qty2 := 1000;
	elseif _step = 5 then
		qty1 := 10;
		qty2 := 10;
	elseif _step = 6 then
		qty1 := 1400;
		qty2 := 1400;
	elseif _step = 7 then
		qty1 := 5;
		qty2 := 5;
	elseif _step = 8 then
		qty1 := 12;
		qty2 := 6;
	elseif _step = 9 then
	// hook code doubles the quantity
		qty1 := 2;
		qty2 := 2;
	endif;
	rate1 := 4;			// arrival rate from tidal class
	rate2 := 5;			// departure rate from tidal class
	// hook code doubles the rate
	if _step = 9 then
		rate1 := 8;
		rate2 := 10;
	endif;

	total1 := qty1 * rate1;
	total2 := rate2 * qty2;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty1, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total1, "line 1 " &amp; _step.String &amp; " value");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, qty2, "line 2 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total2, "line 2 " &amp; _step.String &amp; " value");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 2, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_step" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateHMSInvoice5a" id="fad19bca-72e6-4840-b770-6dcfb07b97b5">
        <source>validateHMSInvoice5a(_invoice : CM_Invoice; _step : Integer);
// HMS Tidal class after rate change
vars
	invCount	: Integer;
	qty1,
	qty2		: Real;
	rate1,
	rate2		: Decimal[12, 6];
	total1,
	total2		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	if _step = 1 then
		qty1 := 1;
		qty2 := 1;
	elseif _step = 2 then
		qty1 := 1200;
		qty2 := 1200;
	elseif _step = 3 then
		qty1 := 100;
		qty2 := 100;
	elseif _step = 4 then
		qty1 := 1000;
		qty2 := 1000;
	elseif _step = 5 then
		qty1 := 10;
		qty2 := 10;
	elseif _step = 6 then
		qty1 := 1400;
		qty2 := 1400;
	elseif _step = 7 then
		qty1 := 5;
		qty2 := 5;
	elseif _step = 8 then
		qty1 := 12;
		qty2 := 6;
	elseif _step = 9 then
	// hook code doubles the quantity
		qty1 := 2;
		qty2 := 2;
	endif;
	rate1 := 7;			// arrival rate from tidal class
	rate2 := 8;			// departure rate from tidal class
	// hook code doubles the rate
	if _step = 9 then
		rate1 := 14;
		rate2 := 16;
	endif;

	total1 := qty1 * rate1;
	total2 := rate2 * qty2;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty1, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total1, "line 1 " &amp; _step.String &amp; " value");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, qty2, "line 2 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total2, "line 2 " &amp; _step.String &amp; " value");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 2, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
