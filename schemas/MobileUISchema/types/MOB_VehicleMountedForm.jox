        <source>setupTCPWeightInterface() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2016	cnwrh7	Initial creation

*/

vars
	device 				: CM_RadioTelemetryDevice;
