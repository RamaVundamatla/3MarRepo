    <JadeMethod name="doCmdSetAutoPing" id="81cf378d-84a2-4252-a3d3-a6422d58c9dd">
        <updating/>
        <source>doCmdSetAutoPing(target : Object) updating;

vars
	n, errNo : Integer;
	errTxt : String;
	
begin
	n := self.lastAutoPingSetting;
	
	if app.readInteger("Enter the number of transactions after which each driver will respond:",
		true, 0, 999999, n)
	then
		self.lastAutoPingSetting := n;
		
		on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
		
		if target = null then
			system.causeEvent(CmdEventNumber, true, CmdSetPingInterval &amp; ':' &amp; n.String);
		else
			target.causeEvent(CmdEventNumber, true, CmdSetPingInterval &amp; ':' &amp; n.String);
		endif;
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdSetProfile" id="00969925-9115-4427-8815-8d79ba909483">
        <source>doCmdSetProfile(target : Object; profileName : String);

vars
	s, errTxt : String;
	errNo : Integer;
	
begin
	if profileName = null then
		s := CmdSetProfile;
	else
		s := CmdSetProfile &amp; ':' &amp; profileName;
	endif;
		
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	if target = null then
		system.causeEvent(CmdEventNumber, true, s);
	else
		target.causeEvent(CmdEventNumber, true, s);
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
        <Parameter name="profileName" type="String"/>
    </JadeMethod>
