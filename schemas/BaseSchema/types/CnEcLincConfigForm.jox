    <JadeMethod name="unload" id="88c2e6a5-22e8-4ce4-aaf3-eb6a0dfa9270">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars
	intReturn : Integer;

begin
	if btnOK.enabled then 
		intReturn := app.msgBox ( "Details have been Changed - Update?" , "Update Confirmation" , MsgBox_Yes_No );

		if intReturn = MsgBox_Return_Yes	 then 
			btnOK.click(btnOK);
		endif;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateConnection" id="75a0f94c-4306-4007-abbd-0aaf3a9a54f9">
        <updating/>
        <source>updateConnection() updating;

begin
	beginTransaction;

		self.currentLincSystem.configTcp(	txtTcpHostName.text,
											txtAppId.text,
											txtPort.text.Integer,
											txtLocalPort.text.Integer,
											txtRetryConnection.text.Integer,
											txtDialogs.text.Integer); 

	 commitTransaction; 
end;</source>
    </JadeMethod>
    <JadeMethod name="updateDiagnostics" id="3873b269-9a38-4a06-b3c7-9379a0af52c9">
        <updating/>
        <source>updateDiagnostics() updating;

vars
  	blaLogOptions : BooleanArray;

begin
	 beginTransaction;

	 	create	blaLogOptions transient;

	 	blaLogOptions[1] := chkDiagLog1.value;
   		blaLogOptions[2] := chkDiagLog2.value;
   		blaLogOptions[3] := chkDiagLog3.value;
   		blaLogOptions[4] := chkDiagLog4.value;
   		blaLogOptions[5] := chkDiagLog5.value;
   		blaLogOptions[6] := chkDiagLog6.value;
   		blaLogOptions[7] := chkDiagLog7.value;
   		blaLogOptions[8] := chkDiagLog8.value;

		currentLincSystem.setDiagnosticOptions(	txtDiagLogFile.text,
												blaLogOptions,
												chkLogFull.value,
												txtFileSize.text.Integer,
												optFileOld.value); 

		delete blaLogOptions;

	 commitTransaction; 
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFields" id="35aaa21c-9b10-4925-b35f-8922b628015b">
        <updating/>
        <source>updateFields() updating;

vars
	row		: Integer;
    field	: CnEcLincFieldDef;
    blnProcessing	: Boolean;

begin
	// Initialise row counter
		row := 0;

		while blnProcessing do 
			tabFieldContents.row := row + 1; 
			tabFieldContents.column := 7;

			if tabFieldContents.itemObject = null then 
				break;
			endif;

    //	if ( row = tabFieldContents.row ) then

			// Set the new default field value

			field := tabFieldContents.itemObject.CnEcLincFieldDef;

  			beginTransaction;
     			field.setDefaultFieldValue(tabFieldContents.text.trimBlanks.toUpper);
    		commitTransaction;
	endwhile;
 	//	endif;

  // endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFieldsTable" id="fc77a6a3-0c83-41aa-a31d-bd94eac23c83">
        <updating/>
        <source>updateFieldsTable() updating;

vars
	newRow 		: Integer;		// Placeholder
	newColumn	: Integer;		// Placeholder
    field		: CnEcLincFieldDef;	// Ref to current ISPEC field

begin
	// Allow read/write for column 7 only. If readOnly := false
	// for the entire table, then the other cells may be selected
	// (blue background, etc) which I didn't want.

    if tabFieldContents.column = 7 then
    	tabFieldContents.readOnly := false;
	else
    	tabFieldContents.readOnly := true;

	endif;

	// Also to avoid the 'selected' blue background
	tabFieldContents.selected := false;

	// Workaround for what appears to be a bug - if the user is
	// editing a field, and terminates with up or down arrow, then
	// the table scrolls one column right without a scrolled event.
	tabFieldContents.leftColumn := 1;

	/*************************************************************
	 Update the default field values (column 7)
	 ************************************************************/

	// Save the selected row / column
	newRow :=		tabFieldContents.row;
	newColumn :=	tabFieldContents.column;

	tabFieldContents.row := 1;			// Initialise row counter
	tabFieldContents.column := 7;

	// Find the ISPEC Field that relates to the selected table row
    foreach field in currentLincIspec.allLincFieldDefs do
  		tabFieldContents.row := tabFieldContents.row + 1; 

		// Write the field value from the database
		beginLoad;
			if field.secureField = true then
				tabFieldContents.text := "*****"; 
			else
				tabFieldContents.text := field.defaultValue;
			endif;
		endLoad;
	endforeach;

	// Restore the selected row / column
	tabFieldContents.row	:= newRow;
	tabFieldContents.column	:= newColumn;

	return;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTimeoutsTable" id="2bec6186-3ab6-422c-a813-bd6d1a040d2c">
        <updating/>
        <source>updateTimeoutsTable() updating;

vars
	newRow 		: Integer;		// Placeholder
	newColumn	: Integer;		// Placeholder
	thisPriority : Integer;		// Ref to current priority (1 - 5)

begin
	// Allow read/write for column 2 only. If readOnly := false
	// for the entire table, then the other cells may be selected
	// (blue background, etc) which I didn't want.

    if tabTimeouts.column = 2 then
    	tabTimeouts.readOnly := false;
	else
    	tabTimeouts.readOnly := true;

	endif;

	// Also to avoid the 'selected' blue background
	tabTimeouts.selected := false;

	// Workaround for what appears to be a bug - if the user is
	// editing a field, and terminates with up or down arrow, then
	// the table scrolls one column right without a scrolled event.
	tabTimeouts.leftColumn := 1;

	/*************************************************************
	 Update the default field values (column 6)
	 ************************************************************/

	// Save the selected row / column
	newRow		:= tabTimeouts.row;
	newColumn	:= tabTimeouts.column;

	// Initialise counters
	thisPriority := 0;
	tabTimeouts.row		:= 1;
	tabTimeouts.column	:= 2;

	// Find the Queue priority that relates to the selected table row
	while thisPriority &lt; currentLincSystem.Timeout_priority_count do
		thisPriority := thisPriority + 1;

  		tabTimeouts.row := tabTimeouts.row + 1; 

		// Write the field value from the database
		beginLoad;
			tabTimeouts.text := currentLincSystem.timeoutValues[thisPriority].String;
		endLoad;
	endwhile;

	// Restore the selected row / column
	tabTimeouts.row		:= newRow;
	tabTimeouts.column	:= newColumn;

	return;
end;</source>
    </JadeMethod>
</GUIClass>
