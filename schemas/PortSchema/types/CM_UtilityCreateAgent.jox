    <JadeMethod name="utlCreateBulkYardAllocations" id="400c1cd8-4933-4710-962e-f1087e1e91c7">
        <updating/>
        <source>utlCreateBulkYardAllocations(_candidates : ObjectSet; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	obj : Object;
	candidate : CM_BulkYACandidate;
	candidates : CM_BulkYACandidateSet;
	pxyYA, newYA : CM_YardAllocation;
	imex : CM_IMEXStatus;
	code, itemCode : String;
	allTransientCriteriaObj	: CMIF_Array;
	pxyCriteria : CM_YACriteria;
	cmifCriteria : CMIF_YACriteriaPriority;
	criteriaType : CM_YACriteriaType;
	dataValue : String;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	create allTransientCriteriaObj transient;
	
	foreach obj in _candidates do
		candidate := null;
		candidates := null;
		// Do we have a single candidate, or a set of them
		if obj.isKindOf(CM_BulkYACandidate) then
			candidate := obj.CM_BulkYACandidate;
			if candidate.myExistingYardAllocation &lt;&gt; null then
				continue;
			endif;
		elseif obj.isKindOf(CM_BulkYACandidateSet) then
			candidates := obj.CM_BulkYACandidateSet;
			candidate := candidates.first;
		endif;
		
		// Create transient yard allocation and build its name
		create pxyYA transient;
		imex := app.myRoot.allImexStatuses[candidate.imexStatus];
		if imex &lt;&gt; null then
			code := imex.description[1:1] &amp; Space &amp; candidate.getCriteriaValueForDisplay;
		else
			code := candidate.getCriteriaValueForDisplay;
		endif;
		allTransientCriteriaObj.purge;
		
		// Create a proxy imex status criteria first
		create pxyCriteria transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus];
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
		pxyCriteria.setProxy(criteriaType, imex.abbreviation, itemCode);
		cmifCriteria := pxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
		
		// Now the other criteria - either single object / code if we just have a candidate,
		// or mutiple objects / codes if we have a candidate set
		create pxyCriteria transient;
		criteriaType := app.myRoot.allYACriteriaTypes[candidate.criteriaType];
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
		if candidates &lt;&gt; null then
			dataValue := null;
			foreach candidate in candidates do
				dataValue := dataValue &amp; candidate.getCriteriaValueForYACreation &amp; Comma;
			endforeach;
			// Strip the last comma off the end
			dataValue := dataValue.stripTrailingChar(Comma);
		else
			if criteriaType.isBooleanType then
				dataValue := candidate.criteriaValue;
			else
				dataValue := candidate.getCriteriaValueForYACreation;
			endif;
		endif;
		
		pxyCriteria.setProxy(criteriaType, dataValue, itemCode);
		cmifCriteria := pxyCriteria.getTransient();
		cmifCriteria.setFlag(true, false, false);
		allTransientCriteriaObj.add(cmifCriteria);
		
		pxyYA.setProxy(code, code, null, YAFillOption_InOrder, YAFillOption_InOrder, YAExpiryType_Never, null, Red, false, YAOverlap_Always, YANoLocation_Continue, null, null, false, false, null, null, false, candidate.myTerminal);
		pxyYA.setAllowMultiRangeSplit(null);
		
		pxyYA.validateForCreate();
		if _passport.hasErrorsOrWarnings then
			continue;
		endif;
		
		self.utlCreateYardAllocation(pxyYA, allTransientCriteriaObj, newYA, _passport);
		delete pxyYA;
	endforeach;

epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge();
	endif;
	delete allTransientCriteriaObj;
	delete pxyYA;
end;</source>
        <Parameter name="_candidates" type="ObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCGAssignment" id="8cb2cca8-5a0a-431e-92a6-1830efd6750e">
        <updating/>
        <source>utlCreateCGAssignment(	_pxyCgAssign : CM_CargoGroupAssignment input;
						_cgAssign    : CM_CargoGroupAssignment output;
						_passport    : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2015	cnwndl1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_pxyCgAssign, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create _cgAssign persistent;
	
	_cgAssign.setForCreate(_pxyCgAssign,_passport);
	
epilog

end;</source>
