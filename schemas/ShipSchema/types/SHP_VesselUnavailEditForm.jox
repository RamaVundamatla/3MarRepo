    </JadeMethod>
    <JadeMethod name="doOK" id="2ac048f6-ba75-4b12-bb7a-82fabf6930e4">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Handles the user clicking then "OK" button.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	unavailabilityObj	: CM_VesselUnavailability;
	dateFrom			: Date;
	dateTo				: Date;
	reasonCodeObj		: HMS_VesselUnavailCode;
	comments			: String;
	
begin
	if not self.validateForm() then
		return;
	endif;
	
	unavailabilityObj	:=	self.aMyVesselUnavail;
	
	if unavailabilityObj = null then
		create unavailabilityObj transient;
		self.aMyVesselUnavail	:=	unavailabilityObj;
	endif;
	
	dateFrom		:=	txtDateFrom.getDate();
	dateTo			:=	txtDateTo.getDate();
	reasonCodeObj	:=	cmbReason.listObject.HMS_VesselUnavailCode;
	comments		:=	txtComments.cnEcString();
	unavailabilityObj.setProxy(dateFrom, dateTo, comments, reasonCodeObj, null);
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="initCodesCombo" id="ddb2e518-04a6-445a-a404-9ba2f5e4f074">
        <source>initCodesCombo() protected;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Populates the combobx control with Vessel Unavailability Reason codes.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	cmbReason.listCollection(app.myRoot.allVesselUnavailabilityCodes, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
end;</source>
        <access>protected</access>
    </JadeMethod>
