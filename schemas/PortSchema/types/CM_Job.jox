    <JadeMethod name="getOperationEnded" id="c031c595-e9c3-4c74-818a-e19ec4a9a8df">
        <source>getOperationEnded():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
27 Jun 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wo		: CM_WorkOrder;
	woDtl	: CM_WorkOrderDtl;
	woTxn	: CM_WOTransaction;
	jobID	: String;
begin
	
	woDtl := self.getMyWorkOrderDtl();
	
	if woDtl = null then
		return null;
	endif;
	
	wo := woDtl.myParent;
	
	if wo = null then
		return null;
	endif;
	
	jobID := self.getJobId();																		//06.03.2025 navma1 #MTN-34179
	
	foreach woTxn in wo.allTransactions discreteLock do
		if woTxn.type = TRANS_TYPE_WOJOBCOMPLETE and woTxn.CM_WOJobDetail.jobId = jobID  then		//09.10.2024 navhl20 #12389
			return woTxn.getJobEnd().asStringJMT();
		endif;
	endforeach;
	
	return null;		//27.06.2024 navnk30 #64601 END
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperationStarted" id="2e38ce01-d5b0-4f2e-9819-c416c62cad79">
        <source>getOperationStarted():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
27 Jun 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wo		: CM_WorkOrder;
	woDtl	: CM_WorkOrderDtl;
	woTxn	: CM_WOTransaction;
	jobID	: String;
begin

	
	woDtl := self.getMyWorkOrderDtl();
	
	if woDtl = null then
		return null;
	endif;
	
	wo := woDtl.myParent;
	
	if wo = null then
		return null;
	endif;
	
	jobID := self.getJobId();																	//25.02.2025 navma1 #MTN-34075
	
	foreach woTxn in wo.allTransactions discreteLock do
		if woTxn.type = TRANS_TYPE_WOJOBSTART and  woTxn.CM_WOJobDetail.jobId = jobID then		//09.10.2024 navhl20 #12389  
			return woTxn.getJobStart().asStringJMT();
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannedLocationCount" id="d826e645-dc82-4e38-81a9-71d6c6c2b917">
