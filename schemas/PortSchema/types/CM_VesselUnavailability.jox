    <JadeMethod name="cloneMe" id="1bea3efc-32e2-444f-a4fd-4e4223b29165">
        <source>cloneMe(_isTransient:Boolean):SelfType;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Returns a clone of the receiver.
//
// Parameters:	_isTransient - True if the clone should be a transient object.
//
// Returns:		A reference to the clone object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cloneObj	: SelfType;
	
begin
	cloneObj				:=	self.cloneSelf(_isTransient);
	cloneObj.myReasonCode	:=	self.myReasonCode;
	
	return cloneObj;
end;</source>
        <Parameter name="_isTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="49ad93e3-a7c9-4c68-b6d9-7e480c0be378">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Returns a display string for the receiver to show in a table control.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	self.dateFrom.shortFormatJMT() &amp;
			Tab &amp; self.dateTo.shortFormatJMT() &amp;
			Tab &amp; self.myReasonCode.getListDisplay() &amp;
			Tab &amp; self.comments;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="59b65923-214e-4b92-87f7-11068ca0783f">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj				:=	inheritMethod();
	proxyObj.myReasonCode	:=	self.myReasonCode;
	proxyObj.myVessel		:=	self.myVessel;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDateFrom" id="59449adc-e1ac-4c79-a1e1-85fa38bbd866">
        <updating/>
        <source>setDateFrom(_date : Date) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 January 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.dateFrom &lt;&gt; _date then
		self.dateFrom:=_date;
	endif;

epilog

end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="67893cd5-ebd9-4f99-a8aa-b8db91b0702f">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Standard transaction create method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_proxyObj.raiseExceptionIfNotTransient(method);
	self.setForUpdate(_proxyObj);
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9dc34ef3-6dc8-44de-a8e2-39d88d1fb2c3">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Standard transaction update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.comments		:=	_proxyObj.comments;
	self.dateTo			:=	_proxyObj.dateTo;
	self.dateFrom		:=	_proxyObj.dateFrom;
	
	self.myReasonCode	:=	_proxyObj.myReasonCode;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="94309997-5f6b-489d-a30a-29b1ba4d171a">
        <updating/>
        <source>setProxy(_dateFrom:Date; _dateTo:Date; _comments:String; _reasonCodeObj:HMS_VesselUnavailCode; _vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Sets the proxy receiver's attribute values and references.
//
// Parameters:	_dateFrom - The date from which the Vessel is unavailable.
//				_dateTo - The date upto which the Vessel is unavailable.
//				_comments - General comments about the unavailability of the Vessel.
//				_reasonCodeObj - A reference to an Unavailable Reason Code object.
//				_vesselObj - A reference to the Vessel that is unavailable.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.dateFrom		:=	_dateFrom;
	self.dateTo			:=	_dateTo;
	self.comments		:=	_comments;
	
	self.myReasonCode	:=	_reasonCodeObj;
	self.myVessel		:=	_vesselObj;
end;</source>
        <Parameter name="_dateFrom" type="Date"/>
        <Parameter name="_dateTo" type="Date"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_reasonCodeObj" type="HMS_VesselUnavailCode"/>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setVessel" id="527c1c00-eae1-4832-a3cf-25a680c0e517">
        <updating/>
        <source>setVessel(_vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Sets the reference to the receiver's Vessel object.
//
// Parameters:	_vesselObj - A reference to the receiver's parent Vessel.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myVessel	:=	_vesselObj;
end;</source>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a494d6a8-0523-4e37-ab96-5d782a93132d">
        <source>validateMe();
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Validates the receiver (as a proxy).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dateFrom = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Date From", null, null);
		app.raiseCMException(Input_required_field_dateFrom, null, null); // cnwdb2	PAR 35364
	elseif not self.dateFrom.isValid() then
		app.raiseCMException1(ERR_INVALID_VALUE, "Date From", null, null);
	endif;
	
	if self.dateTo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Date To", null, null);
		app.raiseCMException(Input_required_field_dateTo, null, null); // cnwdb2	PAR 35364

	elseif not self.dateTo.isValid() then
		app.raiseCMException1(ERR_INVALID_VALUE, "Date To", null, null);
	endif;
	
	if self.myReasonCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Reason Code", null, null);
		app.raiseCMException(Input_required_field_reasonCod, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
