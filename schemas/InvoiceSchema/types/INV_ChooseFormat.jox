    <JadeMethod name="btnBrowse_click" id="709d9c28-0fb2-4e51-90c4-c3f79506daf6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars

begin
	if self.mode = EXTRACT_MODE then
		self.myFile := self.getFileForExtract(null,self.getFileExtension());
	elseif self.mode = LOAD_MODE then
		self.myFile := self.getFileForLoad(self.getFileExtension());
	endif;
	
	if self.myFile &lt;&gt; null then
		self.txtFileName.text := app.getFileName(self.myFile.fileName);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
