    <JadeMethod name="saveVersionCopyRefs" id="41720709-0320-466d-8f4e-24afbed99da3">
        <source>saveVersionCopyRefs(toClone: CM_ConnectPower input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_ConnectPower" usage="input"/>
