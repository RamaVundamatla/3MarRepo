    <JadeMethod name="createSummaryObjTI" id="f5192691-5770-4ae8-87d0-c6f4d1df8c33">
        <source>createSummaryObjTI(_ti: CM_Container; _summaryObjects: CMIF_MTSummaryByOpISOGrpAvaGrd input);
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumObj		: CMIF_MTWarehouseSummary;
	isNew		: Boolean;
begin
	sumObj := _summaryObjects[_ti.operatorCode, _ti.isoTypeGroup, _ti.availabilityGrade].CMIF_MTWarehouseSummary; 
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setForCreateFromFilter(self);
		isNew := true;
	endif;
	
	sumObj.setFromTI(_ti, isNew);
	
	if isNew then
		_summaryObjects.add(sumObj);	
	endif;

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_summaryObjects" type="CMIF_MTSummaryByOpISOGrpAvaGrd" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="a862a58a-83e6-4f94-b73e-a7668e89898f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
29/11/2011	cnwcs5	CCMS POL 2122 / par 28696
*/

vars
	ti					: CM_TrackedItem;
	ta					: CM_TerminalArea;
	lc					: CM_LocationsController;
	terminal			: CM_Terminal;
	breakOut			: Boolean;
	
	bulkRel				: CM_BulkRelease;
	iterTI,
	iterBR				: Iterator;
	cargoTypeKey		: Integer;
	idKey				: String;
	includedTIs			: CM_TIByIdDict;
	includedBRs			: CM_BulkReleaseByTypeStCodeDict; //CM_BulkReleaseByCodeDict;
	statusesOfInterest	: IntegerArray;
	typesOfInterest		: IntegerArray;
	status,brType		: Integer;
	tmpColl				: CMIF_MTSummaryByOpISOGrpAvaGrd;
begin
	
	tmpColl := _collection.CMIF_MTSummaryByOpISOGrpAvaGrd;
	
	create includedTIs transient;
	create includedBRs transient;
	create statusesOfInterest transient;
	create typesOfInterest transient; 
	
	typesOfInterest.add(BR_TYPE_ROAD); 
	typesOfInterest.add(BR_TYPE_RAIL); 
	typesOfInterest.add(BR_TYPE_PACKING); 
	typesOfInterest.add(BR_TYPE_UNKNOWN); // par 28696
	
	statusesOfInterest.add(BR_PENDING);
	statusesOfInterest.add(BR_ACTIVE);
	
	
	foreach terminal in self.allTerminals do
		delete iterTI;
		iterTI := terminal.allOnsiteTIsByCargoTypeId.createIterator();
		
		terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iterTI);
		
		while iterTI.next(ti) do
			
			if ti.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not includedTIs.includes(ti) then
					includedTIs.add(ti);
				endif;
			endif;
		endwhile;
		
		
		delete iterBR;
//		iterBR := terminal.allBulkReleaseByStatusByCode.createIterator(); // AKB2005MAY
		iterBR := terminal.allBulkReleaseByTypeByStByCd.createIterator(); // AKB2005MAY
			
		foreach brType in typesOfInterest do // AKB2005MAY
			foreach status in statusesOfInterest do
	//			terminal.allBulkReleaseByStatusByCode.startKeyGeq(status, null, iterBR); // AKB2005MAY
				terminal.allBulkReleaseByTypeByStByCd.startKeyGeq(brType,status, null,null, iterBR); // AKB2005MAY
				while iterBR.next(bulkRel) do
					if bulkRel.status &lt;&gt; status then
						break;
					endif;
				
					if self.includesObjectBR(bulkRel, _passport, breakOut) then
						if not includedBRs.includes(bulkRel) then
							includedBRs.add(bulkRel);
						endif;
					endif;
					
					if breakOut then
						break;
					endif;
					
				endwhile;
			
			
			endforeach;
		endforeach;	
	endforeach;

	//we've got this stuff now what do we do?
	foreach ti in includedTIs discreteLock do
		self.createSummaryObjTI(ti.CM_Container, tmpColl);
	endforeach;
	
	foreach bulkRel in includedBRs discreteLock do
		self.createSummaryObjBR(bulkRel, tmpColl);
	endforeach;

epilog
	delete includedTIs;
	delete includedBRs;
	delete statusesOfInterest;
	delete typesOfInterest;
	delete iterBR;			// PAR #26678
	delete iterTI;			// PAR #26678
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="6e4f3090-834b-4b7e-95c7-237229fbfe4b">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _ti.isEmpty and 
	   (_ti.isStorage or _ti.getImExStatus = TI_IMEX_STATUS_NULL) and
	   inheritMethod(_ti, _passport, _breakOut) then
	 	
		return true;
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObjectBR" id="44e4d8c5-8e38-474f-88a5-566302738784">
        <updating/>
        <source>includesObjectBR(_br: CM_BulkRelease; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	avaGrades		: IntegerArray;
	firstAvaGrade	: Integer;
begin	
	if _br.type &lt; BR_TYPE_ROAD 
	or _br.fullRelease then
		//null type
		return false;
	endif;

	if self.packByDate.isValid then
		if _br.dateEstimatedRequired.isValid
		and (_br.dateEstimatedRequired.date &gt; self.packByDate) then
			return false;
		endif;
	endif;
// cnwdad1 16/08/2010 - PAR #25218. Refer to "Dialogue" comments for CCMS 1934.
	if not self.includeObjectForPackDate(_br) then
		return false;
	endif;
//write "This one passed: " &amp; _br.dateEstimatedRequired.String;
// cnwdad1 16/08/2010 - PAR #25218 end.
	
	if self.getMyISOTypeGroup &lt;&gt; null
	and (self.getMyISOTypeGroup &lt;&gt; _br.getISOGroup) then
		return false;
	endif;
	
	avaGrades := _br.getAllAvailabilityGrades();
	
	if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
		firstAvaGrade := avaGrades.first;
	endif;
	
	if (not self.allQryAvaGrades.isEmpty) 
	and (not self.allQryAvaGrades.includes(firstAvaGrade)) then
		return false;
	endif;
	
	if self.getMyOperatorGroup &lt;&gt; null then
		if _br.myOperatorGroup &lt;&gt; self.getMyOperatorGroup then
			return false;
		endif;
	endif;

	if self.myOperator &lt;&gt; null
	and (self.myOperator &lt;&gt; _br.myOperator) then
		return false;
	endif;
	
	return (_br.getTotalStorageEmpties &gt; 0);
end;</source>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
