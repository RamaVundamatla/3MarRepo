    <JadeMethod name="displayLine" id="505f808a-d739-4133-9c4b-262457c897d1">
        <source>displayLine(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _theObject = null then
		return null;
	elseif _theObject.CM_InvoiceLineDesc.isNotAvailableForEntry then
		return null;
	else
		return _theObject.CM_InvoiceLineDesc.narration;
	endif;
end;</source>
