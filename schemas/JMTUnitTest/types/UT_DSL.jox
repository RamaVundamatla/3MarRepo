        <source>updateTIRemarks(_ti : CM_TrackedItem io; _remarks : String);

/*

Purpose:		Update ti's Remarks

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTI						: CM_TrackedItem;

begin

	if _ti = null then
		return;
	endif;

	beginLoad;
