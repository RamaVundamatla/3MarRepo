	self.setLogGradeComboObjects(_species, _grade, _type, _treatment, _length,
					_table, _gradeCmb, _typeCmb, _treatmentCmb, _lengthCmb);
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
