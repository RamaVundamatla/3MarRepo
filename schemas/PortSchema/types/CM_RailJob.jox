    <JadeMethod name="getJobQueues" id="0fe1c05e-df1a-423e-89c5-f0e047d152d9">
        <source>getJobQueues() : CM_RTQueueArray;
/*
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	queues	: CM_RTQueueArray;
	wle	:	CM_WorkListEntry;
begin
	create queues transient;
	foreach wle in self.workListEntries discreteLock do						//06.03.2025 navma1 #MTN-34179
		if wle.queue &lt;&gt; null then
			queues.tryAdd(wle.queue);										//06.03.2025 navma1 #MTN-34179
