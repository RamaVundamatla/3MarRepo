<GUIClass name="CMUI_ComboShippingLine" id="0c3f7849-e4b2-41d3-964e-8d99c6b36f91">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isDisplayByName" id="6df1bd09-e74a-47c1-8142-3e4400b7c1c8">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="64407887-9c39-457f-b638-ce29d62a8f0c">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; _shippingLine : CM_ShippingLine; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin
	if _shippingLine = null then
		return null;
	endif;

	if _shippingLine.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _shippingLine then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	if (not _shippingLine.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	if self.isDisplayByName then
		return _shippingLine.description &amp; ' - (' &amp; _shippingLine.code &amp; ')';
	else
		return _shippingLine.code &amp; Tab &amp; _shippingLine.description;
	endif;	

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="35a87365-8330-4066-8767-a744f9ed87cb">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allShippingLines;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
