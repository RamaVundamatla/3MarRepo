<Class name="CM_FileDataStorageDetail" id="be9c755a-7d5e-4d60-b316-ad1173dc6f5f">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <Constant name="COPY_CHUNK_SIZE" id="5db203c7-1717-4fa9-99cf-96933db52c61">
        <source>500000</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="csvBlob" id="a61b156f-0fb9-4ca6-ae55-c15f2e4b51e9">
        <type name="Binary"/>
        <access>readonly</access>
        <text>This is just a blob. Not necessarily csv</text>
    </PrimAttribute>
    <PrimAttribute name="fileName" id="4a953e25-331c-445b-8895-9f42ee5c8cd6">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myFileDataStorageHeader" id="e76600f0-cc47-4c7f-a338-c7a2ccc0c46a">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_FileDataHeader"/>
        <access>readonly</access>
        <Inverse name="CM_FileDataHeader::allFileDataStorageDetail"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myMenuUserReport" id="3b33eaa8-647b-4d97-83c6-7e4b5200d63b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_MenuUserReport"/>
        <access>readonly</access>
