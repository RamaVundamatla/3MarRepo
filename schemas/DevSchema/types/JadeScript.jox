    <JadeMethod name="eprNavSearch" id="726a3a6f-090c-4bce-937c-ddbf7e6cadd0">
        <source>eprNavSearch();
/*

Date		Who		Reason
21 January 2014	cnwer1	Initial creation PAR
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	t : CM_Terminal;
	ti : CM_TrackedItem;
	u 	: CM_User;
	ut 	: CM_UserTerminal;
	tiID : String;
	allTis : CM_TISet;
	startTS: TimeStamp;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	
	tiID := "23";
	
	startTS.setDateTime(2014,01,01,0,0,0,0);
	
	create allTis transient;
	foreach ut in app.myPassport.myUser.allUserTerminals do
		t:=ut.myTerminal;
		t.lookupAllOnsiteTrackedItems(null, tiID, allTis, false, null);
		
		//look up cargo for voyages that are in port or about to arrive at moment 
		//arrive within the next week and voyage has not departed
		
		t.lookupAllOnShipTIsInPortFrom(tiID, null, startTS, allTis,false, null);
		
		t.lookupAllNotifiedOnsiteTIs(null, tiID, allTis, false, null);
		
	endforeach;
	
	
	foreach ti in allTis do
		write ti.id &amp; " " &amp;  ti.myTerminal.code &amp; " " &amp;  ti.String;
		if ti.isPreNote then
			write Tab &amp; "Prenotified " &amp; ti.getReceiptTransportModeStr;
		elseif ti.isOnShip then
			write Tab &amp; "Onship " &amp;  ti.myVoyage.code;
		elseif ti.isOnSite then
			write Tab &amp; "Onsite " &amp; ti.getPrimaryLocationId(REAL_MODE);
		endif;
	endforeach;
	
epilog
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprOpenMobileApps" id="77accb99-727b-47ca-8d91-ddebe2782c9b">
        <source>eprOpenMobileApps();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2019	jlger1	Initial creation

*/

vars

	result :	Integer;
	mobileAppsDir : String;
	xml				: JadeXMLDocument;
	elements : JadeXMLElementArray;
	addElement,
	appSetting : JadeXMLElement;
	uriAttribute : JadeXMLAttribute;
	mobileURL : String;
begin
	
	
	mobileAppsDir:= node.getJadeHomeDirectory&amp; "\c_misc\apps\MobileAppsService\MobileApps.exe.config";
	
	create xml transient;
		
	self.eprParseXMLOnServer(mobileAppsDir,xml);
	
	create elements transient;
	appSetting:=xml.rootElement.getElementByTagName("appSettings");

	if appSetting &lt;&gt; null then
		appSetting.getAllElementsByTagName("add",elements);
		foreach addElement in elements do	
			uriAttribute:=addElement.getAttributeByName("key") ;
			if uriAttribute &lt;&gt; null and uriAttribute.value = "ListeningUri" then
				uriAttribute:=addElement.getAttributeByName("value") ;
				if uriAttribute &lt;&gt; null then
					mobileURL:=uriAttribute.value;
				endif;
				break;
			endif;
		endforeach;
	endif;
	
	write mobileURL;
	if mobileURL &lt;&gt; null then
		result := call josShellExecute(null, 'open', mobileURL, null, null, 1);
		if result &lt;= 32 then
			app.msgBox('You do not have a default browser or the URL http://www.jadeworld.com could not be found', 'Error', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
epilog
	delete xml;
	delete elements;

end;</source>
    </JadeMethod>
    <JadeMethod name="eprOpenVehicleApp" id="bd653f6e-fb5d-4221-b2dc-90eb02ff5f11">
        <source>eprOpenVehicleApp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2019	jlger1	Initial creation

*/

vars

	result :	Integer;
	vehicleAppsDir : String;
	xml				: JadeXMLDocument;
	elements : JadeXMLElementArray;
	addElement,
	appSetting : JadeXMLElement;
	uriAttribute : JadeXMLAttribute;
	vehicleWebsite : String;
begin
	
	
	vehicleAppsDir:= node.getJadeHomeDirectory&amp; "\c_misc\apps\VehicleAppsService\Vehicleapps.exe.config";
	
	create xml transient;
		
	self.eprParseXMLOnServer(vehicleAppsDir,xml);
	
	create elements transient;
	appSetting:=xml.rootElement.getElementByTagName("appSettings");

	if appSetting &lt;&gt; null then
		appSetting.getAllElementsByTagName("add",elements);
		foreach addElement in elements do	
			uriAttribute:=addElement.getAttributeByName("key") ;
			if uriAttribute &lt;&gt; null and uriAttribute.value = "ListeningUri" then
				uriAttribute:=addElement.getAttributeByName("value") ;
				if uriAttribute &lt;&gt; null then
					vehicleWebsite:=uriAttribute.value;
				endif;
				break;
			endif;
		endforeach;
	endif;
	
	write vehicleWebsite;
	if vehicleWebsite &lt;&gt; null then
		result := call josShellExecute(null, 'open', vehicleWebsite &amp; '/Login?terminalId=JBL&amp;machineId=ESS', null, null, 1);
		if result &lt;= 32 then
			app.msgBox('You do not have a default browser or the URL http://www.jadeworld.com could not be found', 'Error', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
epilog
	delete xml;
	delete elements;
end;</source>
