	self.btnPrintTV.enabled 		:= self.allowPrint;
	self.btnExportCSVTV.enabled 	:= self.allowExportCSV;
	self.btnResetSearchTV.enabled	:= self.allowSearch;
	self.btnSearchTV.enabled		:= self.allowSearch;
	self.btnSelectAllTV.enabled		:= self.allowSelectAll;
	self.btnShowSearchTV.enabled	:= self.allowSearch;
	self.btnCloseSearchTV.enabled	:= self.allowSearch;	

	self.btnSaveBase.enabled 	:= false;
