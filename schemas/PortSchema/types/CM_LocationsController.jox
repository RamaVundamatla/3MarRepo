    <JadeMethod name="getNetBalance" id="88a36f6c-f3fa-4720-8d43-734821c50c97">
        <source>getNetBalance(	_balAct : CMEVT_LocationActivity;
				_toAct : CMEVT_LocationActivity;
				_netQuantity : Integer output;
				_netVolume : Decimal output;
				_netWeight : Decimal output
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	iter : Iterator;
	startObject : CMEVT_LocationActivity;
	locAct : CMEVT_LocationActivity;

begin

	iter := self.allLocationActivity.createIterator;
	if _balAct &lt;&gt; null then
		iter.startAtObject( _balAct );
	endif;
	
	while iter.next( locAct ) do
	
		if _balAct &lt;&gt; null and locAct = _balAct then
			_netQuantity := locAct.quantity;
			_netVolume := locAct.volume;
			_netWeight := locAct.weight;
			continue;
		endif;
		if locAct.cargoType &lt;&gt; _toAct.cargoType then
			continue;
		endif;
		if locAct.operatorCode &lt;&gt; _toAct.operatorCode then
			continue;
		endif;
		if locAct.isLocationBalance then
			break;
		endif;
		
		if locAct.isLocationDiscrepancyDecrease 
		or ( locAct.isLocationMove and locAct.mySourceLocation = self ) then
			_netQuantity := _netQuantity - locAct.quantity;
			_netVolume := _netVolume - locAct.volume;
			_netWeight := _netWeight - locAct.weight;
		elseif locAct.isLocationDiscrepancyIncrease
		or ( locAct.isLocationMove and locAct.myTargetLocation = self ) then
			_netQuantity := _netQuantity + locAct.quantity;
			_netVolume := _netVolume + locAct.volume;
			_netWeight := _netWeight + locAct.weight;
		endif;
		
		if locAct = _toAct then
			break;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_balAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_toAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_netQuantity" type="Integer" usage="output"/>
        <Parameter name="_netVolume" type="Decimal" usage="output"/>
        <Parameter name="_netWeight" type="Decimal" usage="output"/>
    </JadeMethod>
