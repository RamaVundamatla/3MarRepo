    <JadeMethod name="timerEvent" id="c6f53861-f7c7-42f0-a3d2-461eff19e497">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 December 2020	jlgndl1	Initial creation	TFS 50549
04 June 2021		navmd1	TFS 51320 - Add filter to Sys/Terminal forms

*/

vars

begin

	if eventTag = self.CamProtocol_Refresh then
		if self.mode = Mode_View or self.addUpdateTransactionComplete then
			if self.myCurrentObject &lt;&gt; null and CM_CamProtocol.hasInstance( self.myCurrentObject ) then
				self.zShowThumbnailData( self.myCurrentObject );
			endif;
		endif;
		self.delayNotifications := false;
		return; 
	elseif eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();	// TFS 51320
	endif;

	inheritMethod(eventTag);

epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
