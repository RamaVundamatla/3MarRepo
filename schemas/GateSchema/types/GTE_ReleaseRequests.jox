							);
		
		modalResult := form.showModal();
		
		if pxyDocActions &lt;&gt; null then
			dispStr := pxyDocActions.getTaskList(CrLf,false).trimBlanks;
		elseif reserveTi &lt;&gt; null and reserveTi.myReserveDetailActions &lt;&gt; null then
			dispStr := reserveTi.myReserveDetailActions.getTaskList(CrLf,false).trimBlanks;
		endif;
		
		//now update the rest
		if modalResult = IDOK then
			updatedDocActions := pxyDocActions;
			foreach obj in objs do
				// make sure each one has a reserveDetails action obj.
				if obj.isKindOf(CM_ReserveTI) then
					reserveTi := obj.CM_ReserveTI;
					pxyDocActions := reserveTi.myReserveDetailActions;
					if pxyDocActions &lt;&gt; null and pxyDocActions &lt;&gt; updatedDocActions then
						pxyDocActions.setTaskDescsToAdd( updatedDocActions.allTaskDescsToAdd, updatedDocActions.allTaskRemarkToAdd );	//05 Oct 2016	NDL	TFS 2001 / 2792
					endif;
				endif;
			endforeach;
		endif;
		
		tblEntry.setValueByName( ETRow_TaskToApply, dispStr );
		tblEntry.cnEcResizeContents;
		
	endif;
					

epilog

	delete objs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="1490e611-f450-4177-9703-663e6bace184">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	obj	: Object;
	objArray			: ObjectArray;
begin

	obj := menuItem.userObject;
	
	if obj = null then
		return;
	endif;
	
	
	if obj.isKindOf(CM_RailJSInOutRake) then
		create objArray transient;
		objArray.add(self.myMasterObject.CM_BulkRelease);
		self.myAssistant.GTE_Assistant.doMnuAssignOutwardRailClick(obj.CM_RailJSInOutRake, objArray, self);
	endif;
	
	inheritMethod(menuItem);

epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e4ef6c0a-3093-4644-866c-9b70c19493c6">
        <updating/>
        <source>doDelete() : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	if CM_ReserveDetail.hasInstance(self.mySelectedObject) then
		return self.doDeleteReserveDetail(self.mySelectedObject.CM_ReserveDetail);
		
	elseif CM_TrackedItem.hasInstance(self.mySelectedObject) then
		return self.doRemoveTrackedItem(self.mySelectedObject.CM_TrackedItem);
	
	endif;
	
	return false;
	
end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteReserveDetail" id="a06bf9de-f6b2-4e11-bac9-a0ded5d7012f">
        <source>doDeleteReserveDetail(_reserveDetail : CM_ReserveDetail io) : Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
----------   ----------  --------------------------------------------------
*/
vars
	release	: CM_BulkRelease;
	ti		: CM_TrackedItem;
	idx		: Integer;
begin
	idx := self.lstTree.listIndex;
	release := self.myMasterProxyObject.CM_BulkRelease;
	
	if release.allReserveDetails.includes(_reserveDetail) and release.allReserveDetails.size = 1 then
		app.msgBox(app.getErrorString(At_Least_One_Request_Line), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	//17 Oct 2017	NDL	TFS 7394
	if not _reserveDetail.validateForDelete( false) then
		app.msgBox(app.getErrorString(Not_delet_reser_detai_that_hav), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	//if CM_ReserveSelection.hasInstance(_reserveDetail) and (not _reserveDetail.allTrackedItems.isEmpty) then
	if CM_ReserveSelection.hasInstance(_reserveDetail) and (_reserveDetail.hasTi()) then //23/06/2023	navkc1	CR 58406 Task 58408
		if app.msgBox(app.getErrorString(AreYouSure_Delete_RequestLine), app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	elseif CM_ReserveTI.hasInstance(_reserveDetail) then
		//epr par 32330 29/8/13
		return self.doRemoveTrackedItem(_reserveDetail.CM_ReserveTI.getTI);
	endif;
	
	foreach ti in _reserveDetail.allTrackedItems do
		if release.allTrackedItemsAssigned.includes(ti) then
			release.allTrackedItemsAssigned.remove(ti);
			release.removeTIFromWorkOrders(ti); //cnwrd1 ccms 1075 28.01.2010
		endif;
	endforeach;
	
	self.lstTree.removeItem(idx);
	delete _reserveDetail;
	return true;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEmailOptionsDblClick" id="52dd3a25-b292-4bac-8b1b-6874d5cebdf2">
        <updating/>
        <source>doEmailOptionsDblClick(table: CM_EntryTable input) updating;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	carrier				: CM_Carrier;
	pxyEmailDefaults,
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	modalResult			: Integer;
	consignee			: CM_ConsigneeConsignor;
	pxyEmailTemplate	: CM_EmailTemplate;
	emailAdding			: Boolean;

begin
	if table.row &lt;&gt; table.getRowByName(ETRow_EmailOptions) then
		return;
	endif;
	
	// cnwrl1 31/07/2009 PAR 20349 - start of coding
	termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_ReleaseRequest );
	if termEmailDefaults = null then		// should never happen but...
		return;
	endif;
	// cnwrl1 31/07/2009 PAR 20349 - end of coding
	
	carrier 	:= self.cmbCarrier.myObject.CM_Carrier;
	consignee	:= self.cmbConsignee.myObject.CM_ConsigneeConsignor;
	
//	if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
	if carrier = null and termEmailDefaults.sendToCarrier then
		app.msgBox(app.getErrorString(Warn_EmailDefaultsCarrier),"E-mail Options",null);
		return;
	endif;
	
//	if consignee = null and self.myTerminal.getConfig(DefaultConsignorEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
	if consignee = null and termEmailDefaults.sendToConsignee then
		app.msgBox(app.getErrorString(Warn_EmailDefaultsConsignee),"E-mail Options",null);
		return;
	endif;
	
	// Par 19427 April 2009. cnwvu1
	if self.myMasterProxyObject.CM_BulkRelease.myEmailTemplate = null then
		emailAdding := true;
		// create and attach
		pxyEmailTemplate := self.myMasterProxyObject.CM_BulkRelease.createPxyEmailTemplate();
	endif;
	pxyEmailTemplate := self.myMasterProxyObject.CM_BulkRelease.myEmailTemplate;
	
	if emailAdding then // email info is empty - getting by default
		//set from terminal for this type of object
//		termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_ReleaseRequest);	// cnwrl1 30/07/2009 PAR 20349 - what it was
		pxyEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
		
	else	// it will get values from pxyEmailTemplate - email info stored on a bulk release
		create pxyEmailDefaults transient;

	endif;

	if pxyEmailDefaults = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults proxy creation failed');
		return;
	endif;

//	pxyEmailDefaults.setAddresses(self.myTerminal, carrier, consignee);	//Par19427 April 2009 cnwvu1	// cnwrl1 30/07/2009 PAR 20349 - what it was
	pxyEmailDefaults.setAddresses( self.myTerminal, carrier, consignee, PINEmail_ReleaseRequest );
	
	//always reset these to the current carrier in case user changes carrier

	if not emailAdding then	// there is some email info saved on bulk release before. Par 19427 April 2009
		pxyEmailDefaults.setFromEmailTemplate(pxyEmailTemplate);	//prepare self.myEmailDefaults from persistent stored email template
	endif;
	
	modalResult := self.myAssistant.showCarrierEmailOptions(carrier, pxyEmailDefaults, false, null);
	
	if modalResult = IDOK then
		pxyEmailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the bulk release. Par 19427 April 2009
	endif;

epilog
	if modalResult &lt;&gt; IDOK and emailAdding then
		delete pxyEmailTemplate;
	endif;
	delete pxyEmailDefaults;	//Par 19427 April 2009 cnwvu1

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadBookRefItems" id="9f4afb80-ce8b-4ba6-9591-a3899f92d566">
        <source>doLoadBookRefItems(_bookingRefObj:CM_BookingRef; _refItemObj:CM_BookingRefItem) protected;
// --------------------------------------------------------------------------------
// Created:		04 June 2008 by cnwdad1
//
// Purpose:		Populates the Booking Reference Item combobox from the specified
//				Booking Reference.
//
// Parameters:	_bookingRefObj - A reference to the Booking Ref topopulate from.
//				_refItemObj - A reference to the currently selected entry.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj	: CMUI_ComboBox;
	
begin
	comboboxObj	:=	cmbBRItem;
	comboboxObj.listCollection(_bookingRefObj.allBookingRefItems, false, 0);
	comboboxObj.automaticCellControl	:=	true;

	if _bookingRefObj &lt;&gt; null then
		comboboxObj.cnEcSetObjectIndex(_refItemObj);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_bookingRefObj" type="CM_BookingRef"/>
        <Parameter name="_refItemObj" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="doLstTreeDblClick" id="11246262-17be-43f7-81bd-ec1932772a45">
        <updating/>
        <source>doLstTreeDblClick(listbox: ListBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti				: CM_TrackedItem;
begin
	if CM_TrackedItem.hasInstance(self.mySelectedObject) then
		self.myAssistant.showCargoEnquiry(self.mySelectedObject.CM_TrackedItem);
	elseif CM_ReserveTI.hasInstance(self.mySelectedObject) then
		ti := self.mySelectedObject.CM_ReserveTI.getTI;
		if ti &lt;&gt; null then
			self.myAssistant.showCargoEnquiry(ti);	
		endif;
		
	endif;


end;


</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstTreeDragDropEvent" id="87782e7e-3160-4d1e-8f0a-732335464baf">
        <updating/>
        <source>doLstTreeDragDropEvent(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	th2 observes on 9th oct 2007 -method too long and contains duplicate code blocks which can
			be factored out - don't have time

/****Changes

Date		Name	TFS#	Description
============================================================================
24/01/2019	jlgka1	41708	Add Release Request BOL validation against the 
							Receive	BOL. 
11/04/2019	jlgka1	44331	Add Voyage validation when doing drag and drop.
09/07/2020	jlgdap1	49703	STWO Testing issues, multiple BOLs on one CRO
11/10/2022	navdb1	55126	Added creatation of failedReserves transient
============================================================================*/

vars
	idx					: Integer;
	otherObj			: Object;
	str					: String;
	droppedOnObj		: CM_Object;
	release				: CM_BulkRelease;
	reserveSelection	: CM_ReserveSelection;
	ti					: CM_TrackedItem;
	reserveTI			: CM_ReserveTI;
	result				: Integer;
	reason				: String;
	reserveDetail		: CM_ReserveDetail;
	reserveGroupingCMIF	: CMIF_ReserveTIGrouping;
	errorCode, fCode	: Integer;					// TFS 49703
	extraCode, fExtra	: String;					// TFS 49703
	fReason, fId		: String;					// TFS 49703
	failedReserves		: CM_ReserveDetailArray;	// TFS 49703
begin
	if self.mode = self.Mode_View then
		app.msgBox(app.getErrorString(ReleaseDragDrop_NotEditMode), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.saveUserEntry();
	idx := self.lstTree.getListIndex(x,y);
	if idx &lt; 1 then
		return;
	endif;
	
	droppedOnObj := self.lstTree.itemObject[idx].CM_Object;
	if droppedOnObj = null then
		//check to see if they have dropped on the 'Assigned Items' Branch
		str := self.lstTree.itemText[idx];
		if str = app.getErrorString(Items_assigned) then
			idx := idx - 1;
			if idx &gt; 1 then
				droppedOnObj := self.lstTree.itemObject[idx].CM_Object;
			endif;
		endif;
	endif;
	
	release := self.myMasterProxyObject.CM_BulkRelease;
	if release.releaseByType then
		if not CM_ReserveSelection.hasInstance(droppedOnObj) then
			app.msgBox(app.getErrorString(ReleaseRequest_DragDropTItoTI), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else//doesn't matter where they dropped, assign the tis to the release because they can't assign them to anything else
		droppedOnObj := release;
	endif;
	
	if CM_ReserveSelection.hasInstance(droppedOnObj) then
		reserveSelection := droppedOnObj.CM_ReserveSelection;		
		
		if app.myMoveController &lt;&gt; null then//drag and drop from another screen
			//validate the item to attach against the request line
			app.myPassport.clearErrorsWarnings();
			on Exception do self.zExAttachItemHandler(exception, app.myPassport);
			app.setContinueCMExceptions(true);
			self.dropTIValidate(reserveSelection, app.myMoveController.myTrackedItem);
			foreach ti in app.myMoveController.allOtherTrackedItems do
				self.dropTIValidate(reserveSelection, ti);
			endforeach;
			
			// following not strictly correct, exception handler earlier handles errors
			// this code to be re-factored as part of PAR 20467
			// no need to show error/warning dialogue unless have warnings
			if app.myPassport.hasWarnings then
				result := app.showErrorWarningDialog('Cargo item attach to release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if result &lt;&gt; IDOK then
					return;
				endif;
			endif;
			
			self.dropTIOnReserveSelection(reserveSelection, app.myMoveController.myTrackedItem);

			foreach ti in app.myMoveController.allOtherTrackedItems do
				self.dropTIOnReserveSelection(reserveSelection, ti);
			endforeach;
		else//drag and drop from within tree
			
			if CM_ReserveTI.hasInstance(self.mySelectedDragDropObject) then
				ti := self.mySelectedDragDropObject.CM_ReserveTI.allTrackedItems.first;
			elseif CM_TrackedItem.hasInstance(self.mySelectedDragDropObject) then
				ti := self.mySelectedDragDropObject.CM_TrackedItem;
			else
				return;
			endif;	
			
			self.dropTIOnReserveSelection(reserveSelection, ti);
			
			foreach otherObj in self.allSelectedDragDropObjects do
			  if CM_ReserveTI.hasInstance(otherObj) then
					ti := otherObj.CM_ReserveTI.allTrackedItems.first;
				elseif CM_TrackedItem.hasInstance(otherObj) then
					ti := otherObj.CM_TrackedItem;
				else
					continue;
				endif;
				
				self.dropTIOnReserveSelection(reserveSelection, ti);
			endforeach;
		endif;
	else//it's a release by ID, so create reserveTI for TI and associate
		if app.myMoveController &lt;&gt; null then//drag and drop from another screen
			//jlgka1 TFS 41708 --&gt;
			/*No use to call validate at this stage because the object hasn't been created yet, 
			  this validation is for CM_ReserveSelection and this piece of code is using CM_ReserveTI*/
			
			/*
			app.myPassport.clearErrorsWarnings();
			on Exception do self.zExAttachItemHandler(exception, app.myPassport);
			app.setContinueCMExceptions(true);
			self.dropTIValidate(reserveSelection, app.myMoveController.myTrackedItem);
			foreach ti in app.myMoveController.allOtherTrackedItems do
				self.dropTIValidate(reserveSelection, ti);
			endforeach;
			
			if app.myPassport.hasWarnings then
				result := app.showErrorWarningDialog('Cargo item attach to release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if result &lt;&gt; IDOK then
					return;
				endif;
			endif;
			*/
			
			//jlgka1 TFS 41708 &lt;--
			
			self.dropTIOnRelease(app.myMoveController.myTrackedItem);
			
			foreach ti in app.myMoveController.allOtherTrackedItems do
				self.dropTIOnRelease(ti);				
			endforeach;
			
			//jlgka1 TFS 41708 --&gt;
			
			if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then				
				app.myPassport.clearErrorsWarnings();
				on Exception do self.zExAttachItemHandler(exception, app.myPassport);
				app.setContinueCMExceptions(true);
				
				create failedReserves transient;
				foreach reserveDetail in self.myMasterProxyObject.CM_BulkRelease.allReserveDetails do
					if  reserveDetail.isKindOf(CM_ReserveTI) then
						reserveTI := reserveDetail.CM_ReserveTI;
						ti 		  := reserveTI.allTrackedItems.first;
						
						if app.myMoveController.allOtherTrackedItems.includes(ti) or app.myMoveController.myTrackedItem = ti  then					
							// TFS 49703 if validation failed, delete the reserve TI and display an error
							//ti.testAgainstReserveTI(reserveTI, reason);
							ti.testAgainstReserveTI(reserveTI, errorCode, reason, extraCode);
							if reason &lt;&gt; null then
								failedReserves.add(reserveTI);
								fCode := errorCode;
								fReason := reason;
								fId := ti.id;
								fExtra := extraCode;
								//app.raiseCMException3(errorCode, ti.id, reason, extraCode, null, null);
							endif;
							// TFS 49703 end
						endif;
					endif;
				endforeach;
				// TFS 49703 check for errors and remove all reserve TIs that failed validation
				if not failedReserves.isEmpty then
					failedReserves.purge;
					app.raiseCMException3(fCode, fId, fReason, fExtra, null, null);
				endif;
				
				// as above - no need to show error/warning dialogue unless have warnings
				if app.myPassport.hasWarnings then
					result := app.showErrorWarningDialog('Cargo item attach to release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if result &lt;&gt; IDOK then						
						return;
					endif;
				endif;
			endif;
			//jlgka1 TFS 41708 &lt;--
		else//drag and drop from within tree
			if CM_ReserveTI.hasInstance(self.mySelectedDragDropObject) then
				ti := self.mySelectedDragDropObject.CM_ReserveTI.allTrackedItems.first;
			elseif CM_TrackedItem.hasInstance(self.mySelectedDragDropObject) then
				ti := self.mySelectedDragDropObject.CM_TrackedItem;
			else
				return;
			endif;
					
			self.dropTIOnRelease(ti);
			
			foreach otherObj in self.allSelectedDragDropObjects do
			  if CM_ReserveTI.hasInstance(otherObj) then
					ti := otherObj.CM_ReserveTI.allTrackedItems.first;
				elseif CM_TrackedItem.hasInstance(otherObj) then
					ti := otherObj.CM_TrackedItem;
				else
					continue;
				endif;
				
				self.dropTIOnRelease(ti);
			endforeach;
		endif;
	endif;
	
	self.loadTree();
	self.selectObject(droppedOnObj);
epilog
	self.mySelectedDragDropObject := null;
	self.allSelectedDragDropObjects.clear();
	delete app.myMoveController;
	delete failedReserves;				// TFS 49703
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doMaintainCriteria" id="b60e9082-e11d-40e7-a65d-85526af658f1">
        <source>doMaintainCriteria()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation	Par 36338

*/	

vars

	theForm : CMUI_ObjectCriteriaLineForm;
	moreTerminals	: Boolean;
	userTerm : CM_UserTerminal;
	reserveObj : CM_ReserveSelection;
	pxyObjMatchCriteria : CM_ReleaseByTypeCriteria;
	dispStr :String;
	
begin

	if CM_ReserveSelection.hasInstance(self.mySelectedObject) then
		reserveObj := self.mySelectedObject.CM_ReserveSelection;
		pxyObjMatchCriteria := reserveObj.myReleaseCriteria;
	else
		return;
	endif;
	
	create theForm transient;
	
	theForm.setMyTerminal(self.myTerminal);
	theForm.setBaseData(	CM_ObjectMatchCriteria.ReleaseByTypeInt,	//_context : Integer;
							reserveObj,	//_contextObj : CM_Object;
							pxyObjMatchCriteria,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							null,	//_myListForm : CMUI_ObjectCriteriaListForm
							null	//_myParentForm: CM_BaseForm
							);
	
	theForm.showModal();
	
	
	if pxyObjMatchCriteria &lt;&gt; null then
		dispStr := pxyObjMatchCriteria.getCriteriaSummary(CrLf).trimBlanks;
	elseif reserveObj &lt;&gt; null and reserveObj.myReleaseCriteria &lt;&gt; null then
		dispStr := reserveObj.myReleaseCriteria.getCriteriaSummary(CrLf).trimBlanks;
	endif;
	
	if dispStr.trimBlanks = null then
		dispStr := "-- Dbl Click to Add --";
	endif;
	
	tblEntry.setValueByName( ETRow_SetCriteria, dispStr );
	tblEntry.cnEcResizeContents;
	
	return;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMaintainStops" id="4c84b8fa-b6fe-4869-ab5f-0e0a3a04ec9d">
        <source>doMaintainStops()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	form : CMUI_DocumentActionsSelectForm;
	reserveDet : CM_ReserveDetail;
	pxyDocActions : CM_ReserveDetailActions;
	dispStr :String;
	
begin

	if CM_ReserveDetail.hasInstance(self.mySelectedObject) then
		reserveDet := self.mySelectedObject.CM_ReserveDetail;
		pxyDocActions := reserveDet.myReserveDetailActions;
		if pxyDocActions = null then
			create pxyDocActions transient;
			pxyDocActions.setMyReserveDetail( reserveDet );
		endif;
	else
		return;
	endif;
	
	create form transient;
	
	form.setMyTerminal(self.myTerminal);
	form.setBaseData( 	pxyDocActions,	//_documentActionsObj : CM_DocumentActions;
						false,	//_isTasks : Boolean;
						true	//_isStops : Boolean
						);
	
	form.showModal();
	
	if pxyDocActions &lt;&gt; null then
		dispStr := pxyDocActions.getStopsList(CrLf,false).trimBlanks;
	elseif reserveDet &lt;&gt; null and reserveDet.myReserveDetailActions &lt;&gt; null then
		dispStr := reserveDet.myReserveDetailActions.getStopsList(CrLf,false).trimBlanks;
	endif;

	if dispStr.trimBlanks = null then
		dispStr := "-- Dbl Click to Add --";
	endif;
	
	tblEntry.setValueByName( ETRow_SetStops, dispStr );
	tblEntry.cnEcResizeContents;
	
	return;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
