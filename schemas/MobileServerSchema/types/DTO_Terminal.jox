    <JadeMethod name="getPersistentObject" id="75a0312b-0221-4b86-9409-e1f185b4add0">
        <source>getPersistentObject(): CM_Terminal protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.masterOid.asOid.CM_Terminal;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistent" id="f2709770-fcf5-45b4-b4e6-e887e0309b72">
        <updating/>
        <source>setFromPersistent(_terminal : CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.code	:= _terminal.code;
	self.name	:= _terminal.name;
	
	inheritMethod(_terminal);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
