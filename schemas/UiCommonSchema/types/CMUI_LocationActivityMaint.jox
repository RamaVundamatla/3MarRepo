        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="46776346-9530-43f6-9dff-4f0dcabf633c">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ts : TimeStamp;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	
	dateChanged : Boolean;
	amountChanged : Boolean;
	sourceChanged : Boolean;
	targetChanged : Boolean;
	remarkChanged : Boolean;
	
	enteredAmount : Decimal[14,4];
	changedAmount : Decimal[14,4];
	chgIsIncrease : Boolean;
	isVolume : Boolean;
	isWeight : Boolean;
	isQuantity : Boolean;
	
	selectedSource : CM_Object;
	selectedSourceLc : CM_LocationsController;
	currentSourceLC : CM_LocationsController;
	
	selectedTarget : CM_Object;
	selectedTargetLc : CM_LocationsController;
	currentTargetLC : CM_LocationsController;
	
	cmifDict : CMIF_TITxnControllerSet;
	pxyLA : CMEVT_LocationActivity;
	
	theResult : Integer;
	success : Boolean;
	load : Boolean;
	msg : String;

begin
	
	dateChanged := self.getChangedDateTime( ts );
	if not dateChanged then
		ts := self.myLocationActivity.dateTime;
	endif;
	
	amountChanged := self.getChangeAmountDetails(	enteredAmount, //enteredAmount : Decimal output;
													changedAmount, //changedAmount : Decimal output;
													chgIsIncrease, //chgIsIncrease : Boolean output;
													isVolume, //isVolume : Boolean output;
													isWeight, //isWeight : Boolean output;
													isQuantity //isQuantity : Boolean output
													);
	
	if self.cmbSource.listIndex &gt; 0 then
		selectedSource :=  self.cmbSource.itemObject[ self.cmbSource.listIndex ].CM_Object;
	endif;
	sourceChanged := self.getChangeSourceDetails(	selectedSourceLc, //selectedSourceLc :  CM_LocationsController output;
													currentSourceLC //currentSourceLC : CM_LocationsController output
													);
													
	if self.cmbTarget.listIndex &gt; 0 then
		selectedTarget :=  self.cmbTarget.itemObject[ self.cmbTarget.listIndex ].CM_Object;
	endif;
	targetChanged := self.getChangeTargetDetails(	selectedTargetLc, //selectedTargetLc :  CM_LocationsController output;
													currentTargetLC //currentTargetLC : CM_LocationsController output
													);
	
	if not dateChanged 
	and not amountChanged
	and not sourceChanged
	and not targetChanged
	then
		if self.myLocationActivity.remarks &lt;&gt; self.txtRemarks.text then
			// Just the remarks changed, update this but nothing else.
			app.cmsBeginLoad(load);
			pxyLA := self.myLocationActivity.pxyCreateUpdateProxy().CMEVT_LocationActivity;
			app.cmsEndLoad(load);
			pxyLA.setRemarks( self.txtRemarks.text );
			while true do
				app.myTrxUA.trxUpdateLocActRemarksOnly( pxyLA, app.myPassport );
			
				if app.myPassport.trxCompletedOK then
					success := true; 
					return;
				else
					theResult := app.showErrorWarningDialog( app.getErrorString(Location_activity) &amp; " " &amp; app.getErrorString(UpdateUpper), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				return;
				
			endwhile;
		else
			//nothing to do
			success := true;
			return;
		endif;
	endif;
	
	app.myPassport.clearErrorsWarnings();
	
	if sourceChanged and selectedSourceLc = null and self.cmbSourceType.text = app.getErrorString(TerminalAreas) then
		msg := app.getErrorString( No_Source_location_found );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbSourceLC.setFocus();
		return;
	elseif targetChanged and selectedTargetLc = null and self.cmbTargetType.text = app.getErrorString(TerminalAreas) then
		msg := app.getErrorString( No_Target_location_found );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbTargetLC.setFocus();
		return;
	endif;
	
	create cmifDict transient;
	
	//Find the object(s) that we have to create the 'Location Activity Discrepancy' transactions against if the user selected one. 	
	self.createDiscrepCMIFs( 	cmifDict,	//_cmifDict : CMIF_TITxnControllerSet;
								sourceChanged,	//_sourceChanged : Boolean;
								targetChanged,	//_targetChanged : Boolean;
								changedAmount, //_changedAmount : Decimal;
								chgIsIncrease, //_chgIsIncrease : Boolean;
								isVolume, //_isVolume : Boolean;
								isWeight, //_isWeight : Boolean;
								isQuantity //_isQuantity : Boolean
								);
								
	if app.myPassport.hasErrors then
		//if errors raised during cmif build, they will have been presented already.
		success := false;
		return;
	endif;
	
	app.cmsBeginLoad(load);
	pxyLA := self.myLocationActivity.pxyCreateUpdateProxy().CMEVT_LocationActivity;
	app.cmsEndLoad(load);
	
	if dateChanged then
		pxyLA.setLocalDateTime( ts, null, self.myTerminal );
	endif;
	
	if amountChanged then
		pxyLA.setPxyAmount(	isVolume,	//_isVolume : Boolean;
							isWeight,	//_isWeight : Boolean;
							isQuantity,	//_isQuantity : Boolean;
							enteredAmount	//_enteredAmount : Decimal
							);
	endif;
	if sourceChanged then
		if selectedSourceLc = null then
			pxyLA.setMySourceAttributesExt( selectedSource );
		else
		//	pxyLA.setPxySourceLocation(selectedSourceLc);
			pxyLA.setMySourceAttributes( selectedSourceLc, false );	//17 Sep 2021	NDL	TFS 51991
		endif;
	endif;
	if targetChanged then
		if selectedTargetLc = null then
			pxyLA.setMyTargetAttributesExt( selectedTarget );
		else
		//	pxyLA.setPxyTargetLocation(selectedTargetLc);
			pxyLA.setMyTargetAttributes( selectedTargetLc, false );	//17 Sep 2021	NDL	TFS 51991
		endif;
	endif;
	
	pxyLA.setRemarks( self.txtRemarks.text );	//01 Sep 2021 TFS 51864 - Now wants to allow and store changes back on the Location Activity too,
												//							not just in any associated Cargo Discrepancy.
	
	while true do
	
		app.myTrxUA.trxUpdateLocationActivity( pxyLA, cmifDict, app.myPassport );
	
		if app.myPassport.trxCompletedOK then
			success := true; 
			break;
		else
			theResult := app.showErrorWarningDialog( app.getErrorString(Location_activity) &amp; " " &amp; app.getErrorString(UpdateUpper), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	app.cmsEndLoad(load);
	delete pxyLA;

	if cmifDict &lt;&gt; null then
		if not cmifDict.isEmpty then
			cmifDict.purge;
		endif;
		delete cmifDict;
	endif;

	if success then
		self.unloadForm();
		return;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="f720f8a2-a7ba-43ac-a992-cbf625cf9239">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2021	navndl1	Initial creation	TFS 51229

*/

vars

begin
	inheritMethod();
	
	self.grpMain.top := self.frmToolbar.height;
	self.grpMain.left := 1;
	
	self.width := self.grpMain.width + 18;
	self.minimumWidth := self.width.Integer;
	self.height := self.grpMain.top + self.grpMain.height + 40;
	self.minimumHeight := self.height.Integer;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getChangeAmountDetails" id="b3e36058-49e3-47fc-b7bd-fc2a5602e0c5">
        <source>getChangeAmountDetails(	enteredAmount : Decimal output;
						changedAmount : Decimal output;
						chgIsIncrease : Boolean output;
						isVolume : Boolean output;
						isWeight : Boolean output;
						isQuantity : Boolean output
						) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	amountChanged : Boolean;
	cargoType : CM_CargoType;

begin

	cargoType := self.myLocationActivity.getCargoType();
	
	if self.txtAmount.visible then
		enteredAmount := self.txtAmount.text.Integer;
	elseif self.tblAmount.visible then
		enteredAmount := self.tblAmount.getConvertedValue();
	endif;
	
	if cargoType = null then
		amountChanged := self.myLocationActivity.quantity &lt;&gt; enteredAmount;
		isQuantity := true;
		if amountChanged then	
			changedAmount := self.myLocationActivity.quantity.max(enteredAmount.Integer) - self.myLocationActivity.quantity.min(enteredAmount.Integer);
			chgIsIncrease := enteredAmount &gt; self.myLocationActivity.quantity;
		endif;
	elseif cargoType.isTrackByVolume then
		amountChanged := self.myLocationActivity.volume &lt;&gt; enteredAmount;
		isVolume := true;
		if amountChanged then
			changedAmount := self.myLocationActivity.volume.max(enteredAmount) - self.myLocationActivity.volume.min(enteredAmount);
			chgIsIncrease := enteredAmount &gt; self.myLocationActivity.volume;
		endif;
	elseif cargoType.isTrackByWeight then
		amountChanged := self.myLocationActivity.weight &lt;&gt; enteredAmount;
		isWeight := true;
		if amountChanged then
			changedAmount := self.myLocationActivity.weight.max(enteredAmount) - self.myLocationActivity.weight.min(enteredAmount);
			chgIsIncrease := enteredAmount &gt; self.myLocationActivity.weight;
		endif;
	else
		amountChanged := self.myLocationActivity.quantity &lt;&gt; enteredAmount;
		isQuantity := true;
		if amountChanged then	
			changedAmount := self.myLocationActivity.quantity.max(enteredAmount.Integer) - self.myLocationActivity.quantity.min(enteredAmount.Integer);
			chgIsIncrease := enteredAmount &gt; self.myLocationActivity.quantity;
		endif;
	endif;

epilog

	return amountChanged;

end;</source>
        <access>protected</access>
        <Parameter name="enteredAmount" type="Decimal" usage="output"/>
        <Parameter name="changedAmount" type="Decimal" usage="output"/>
        <Parameter name="chgIsIncrease" type="Boolean" usage="output"/>
        <Parameter name="isVolume" type="Boolean" usage="output"/>
        <Parameter name="isWeight" type="Boolean" usage="output"/>
        <Parameter name="isQuantity" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChangeSourceDetails" id="9a74b18e-434e-4d85-80a7-51d8cd3156af">
        <source>getChangeSourceDetails(	_selectedSourceLc :  CM_LocationsController output;
						_currentSourceLC : CM_LocationsController output
						):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	sourceChanged : Boolean;
	selectedSource : CM_Object;
	parentSource : CM_Object;

begin

	if self.cmbSource.listIndex &gt; 0 then
		selectedSource :=  self.cmbSource.itemObject[ self.cmbSource.listIndex ].CM_Object;
	endif;
	parentSource := self.myLocationActivity.getSourceParentLocation( _currentSourceLC );
	if self.cmbSourceLC.listIndex &gt; 0 then
		_selectedSourceLc :=  self.cmbSourceLC.itemObject[ self.cmbSourceLC.listIndex ].CM_LocationsController;
	endif;
	
	if parentSource &lt;&gt; selectedSource then
		sourceChanged := true;
	elseif _selectedSourceLc &lt;&gt; null and _selectedSourceLc &lt;&gt; _currentSourceLC then
		sourceChanged := true;
	else
		sourceChanged := false;
	endif;

epilog

	return sourceChanged;

end;</source>
        <access>protected</access>
        <Parameter name="_selectedSourceLc" type="CM_LocationsController" usage="output"/>
        <Parameter name="_currentSourceLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChangeTargetDetails" id="b320bb53-69fb-4160-b74a-aabfd23f634c">
        <source>getChangeTargetDetails(	_selectedTargetLc :  CM_LocationsController output;
						_currentTargetLC : CM_LocationsController output
						) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	targetChanged : Boolean;
	selectedTarget : CM_Object;
	parentTarget : CM_Object;

begin

	if self.cmbTarget.listIndex &gt; 0 then
		selectedTarget :=  self.cmbTarget.itemObject[ self.cmbTarget.listIndex ].CM_Object;
	endif;
	parentTarget := self.myLocationActivity.getTargetParentLocation( _currentTargetLC );
	if self.cmbTargetLC.listIndex &gt; 0 then
		_selectedTargetLc :=  self.cmbTargetLC.itemObject[ self.cmbTargetLC.listIndex ].CM_LocationsController;
	endif;
	
	if parentTarget &lt;&gt; selectedTarget then
		targetChanged := true;
	elseif _selectedTargetLc &lt;&gt; null and _selectedTargetLc &lt;&gt; _currentTargetLC then
		targetChanged := true;
	else
		targetChanged := false;
	endif;

epilog

	return targetChanged;

end;</source>
        <access>protected</access>
        <Parameter name="_selectedTargetLc" type="CM_LocationsController" usage="output"/>
        <Parameter name="_currentTargetLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChangedDateTime" id="f7ff7fb8-fe40-41d5-b86c-26fc45dcbcae">
        <source>getChangedDateTime(	newTimeStamp :  TimeStamp output ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	dateChanged : Boolean;
	oldTime : Time;
	newTime : Time;

begin

	newTimeStamp.setDate( self.txtDate.getDate );
	newTimeStamp.setTime( self.txtTime.getTime );
	
	dateChanged := self.myLocationActivity.dateTime.Date &lt;&gt; newTimeStamp.date;
	if not dateChanged then
		oldTime := self.myLocationActivity.dateTime.Time;
		newTime := newTimeStamp.Time;
		if oldTime.hour &lt;&gt; newTime.hour
		or oldTime.minute &lt;&gt; newTime.minute
		then
			//don't try to match seconds or milliseconds
			dateChanged := true;
		endif;
	endif;

epilog

	return dateChanged;

end;</source>
        <access>protected</access>
        <Parameter name="newTimeStamp" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProspectTIs" id="f0be962b-f02c-4b33-848e-2289343f8b27">
        <source>getProspectTIs( _tis : CM_TISet input;
				_location : CM_LocationsController;
				_cargoType : CM_CargoType;
				_operator : CM_Operator;
				_decreasing : Boolean;
				_changedAmount : Decimal;
				_isQuantity : Boolean;
				_isVolume : Boolean;
				_isWeight : Boolean
				) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ti : CM_TrackedItem;

begin

	_tis.clear();
	foreach ti in _location.allTrackedItems discreteLock do
		if ti.hasBeenMerged then
			continue;
		endif;
		if ti.myOperator &lt;&gt; _operator then
			continue;
		endif;
		if ti.myCargoType &lt;&gt; _cargoType then
			continue;
		endif;
		if _decreasing then
			if _isQuantity then
				if ti.quantity &lt;= _changedAmount then
					continue;
				endif;
			elseif _isVolume then
				if ti.volume &lt;= _changedAmount then
					continue;
				endif;
			elseif _isWeight then
				if ti.weight &lt;= _changedAmount then
					continue;
				endif;
			endif;
		endif;
		_tis.addNoDuplicates( ti, false );
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_decreasing" type="Boolean"/>
        <Parameter name="_changedAmount" type="Decimal"/>
        <Parameter name="_isQuantity" type="Boolean"/>
        <Parameter name="_isVolume" type="Boolean"/>
        <Parameter name="_isWeight" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbItems" id="4e2b6df4-4d6c-4dbd-9e8e-8d3366e00a64">
        <updating/>
        <source>populateCmbItems( _control : Control ) updating, protected;
/*

Purpose:			Any changes to this, probably need to be reflected in a similar change to "createDiscrepCMIFs" as well.

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	amountChanged : Boolean;
	sourceChanged : Boolean;
	targetChanged : Boolean;
	
	cargoType : CM_CargoType;
	enteredAmount : Decimal[14,4];
	changedAmount : Decimal[14,4];
	chgIsIncrease : Boolean;
	isVolume : Boolean;
	isWeight : Boolean;
	isQuantity : Boolean;
	
	selectedSourceLc :  CM_LocationsController;
	currentSourceLC : CM_LocationsController;
	
	selectedTargetLc :  CM_LocationsController;
	currentTargetLC : CM_LocationsController;
	
	tis : CM_TISet;
	operator : CM_Operator;
	ti : CM_TrackedItem;

begin

	cargoType := self.myLocationActivity.getCargoType();
	operator := self.myLocationActivity.getOperator(); 
	
	//Amount changed ??
	amountChanged := self.getChangeAmountDetails(	enteredAmount, //enteredAmount : Decimal output;
													changedAmount, //changedAmount : Decimal output;
													chgIsIncrease, //chgIsIncrease : Boolean output;
													isVolume, //isVolume : Boolean output;
													isWeight, //isWeight : Boolean output;
													isQuantity //isQuantity : Boolean output
													);
	
	//Source changed ??
	sourceChanged := self.getChangeSourceDetails(	selectedSourceLc, //selectedSourceLc :  CM_LocationsController output;
													currentSourceLC //currentSourceLC : CM_LocationsController output
													);
													
	//Target changed ??
	targetChanged := self.getChangeTargetDetails(	selectedTargetLc, //selectedTargetLc :  CM_LocationsController output;
													currentTargetLC //currentTargetLC : CM_LocationsController output
													);
	
	//Set visibility of TI combos.
	if self.myLocationActivity.isLocationDiscrepancyDecrease then
		self.cmbSourceItem.enabled := amountChanged;
		self.cmbNewSourceItem.enabled := false;
		self.cmbTargetItem.enabled := false;
		self.cmbNewTargetItem.enabled := false;
	
	elseif self.myLocationActivity.isLocationDiscrepancyIncrease then
		self.cmbSourceItem.enabled := false;
		self.cmbNewSourceItem.enabled := false;
		self.cmbTargetItem.enabled := amountChanged;
		self.cmbNewTargetItem.enabled := false;
	
	elseif self.myLocationActivity.isLocationMove then
		self.cmbSourceItem.enabled := ( amountChanged and self.cmbSourceType.text = app.getErrorString(TerminalAreas) )
									or ( sourceChanged and currentSourceLC &lt;&gt; null and currentSourceLC.isActivityTrackingLocation );
		self.cmbNewSourceItem.enabled := (  sourceChanged and selectedSourceLc &lt;&gt; null and selectedSourceLc.isActivityTrackingLocation );
		self.cmbTargetItem.enabled := ( amountChanged and self.cmbTargetType.text = app.getErrorString(TerminalAreas) )
									or ( targetChanged and currentTargetLC &lt;&gt; null and currentTargetLC.isActivityTrackingLocation );
		self.cmbNewTargetItem.enabled := (  targetChanged and selectedTargetLc &lt;&gt; null and selectedTargetLc.isActivityTrackingLocation );
		
	endif;
	
	//Clear old data
	self.cmbSourceItem.clear;
	self.cmbNewSourceItem.clear;
	self.cmbTargetItem.clear;
	self.cmbNewTargetItem.clear;
	
	create tis transient;
	
	if self.cmbSourceItem.enabled and currentSourceLC &lt;&gt; null then
		if sourceChanged or ( amountChanged and not chgIsIncrease ) then
			//any matching item, because we are going to add to the item
			self.getProspectTIs( tis, currentSourceLC, cargoType, operator, false, changedAmount, isQuantity, isVolume, isWeight ); 
			self.populateComboTIs( self.cmbSourceItem, tis );	
					
		elseif chgIsIncrease then
			//any matching item that is bigger than the amount ( we want to take from it );
			self.getProspectTIs( tis, currentSourceLC, cargoType, operator, true, changedAmount, isQuantity, isVolume, isWeight );
			self.populateComboTIs( self.cmbSourceItem, tis );
		endif;
		
	endif;
	
	if self.cmbNewSourceItem.enabled and selectedSourceLc &lt;&gt; null then
		if sourceChanged then
			//any matching item that is bigger than the amount ( we want to take from it );
			self.getProspectTIs( tis, selectedSourceLc, cargoType, operator, true, changedAmount, isQuantity, isVolume, isWeight );
			self.populateComboTIs( self.cmbNewSourceItem, tis );
		endif;
	endif;
	
	if self.cmbTargetItem.enabled and currentTargetLC &lt;&gt; null then
		if chgIsIncrease then
			//any matching item, because we are going to add to the item
			self.getProspectTIs( tis, currentTargetLC, cargoType, operator, false, changedAmount, isQuantity, isVolume, isWeight );
			self.populateComboTIs( self.cmbTargetItem, tis );
	
		elseif targetChanged or ( amountChanged and not chgIsIncrease ) then
			//any matching item that is bigger than the amount ( we want to take from it );
			self.getProspectTIs( tis, currentTargetLC, cargoType, operator, true, changedAmount, isQuantity, isVolume, isWeight );
			self.populateComboTIs( self.cmbTargetItem, tis );
		
		endif;
				
	endif;
	
	if self.cmbNewTargetItem.enabled and selectedTargetLc &lt;&gt; null then
		if targetChanged then
			//any matching item, because we are going to add to the item
			self.getProspectTIs( tis, selectedTargetLc, cargoType, operator, false, changedAmount, isQuantity, isVolume, isWeight );
			self.populateComboTIs( self.cmbNewTargetItem, tis );
		endif;
	endif;
	
epilog

	delete tis;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="populateCmbLCs" id="0d9e289e-a929-42cc-a2b8-5e20c1c299cd">
        <updating/>
        <source>populateCmbLCs( _parentCombo : ComboBox; _childCombo : ComboBox input ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906 

*/

vars

	parentObj : CM_Object;
	allLCs : CM_LCSet;
	lc : CM_LocationsController;
	index : Integer;

begin

	if _parentCombo &lt;&gt; null and _parentCombo.listIndex &gt; 0 then
		parentObj := _parentCombo.itemObject[ _parentCombo.listIndex ].CM_Object;
	endif;
	
	_childCombo.clear();
	
	if parentObj = null then
		return;
	endif;
	
	if parentObj.isKindOf( CM_TerminalArea ) then
		if parentObj.isKindOf(CM_GeneralCargoAllocRowArea) then	//15 Jun 2021	NDL	TFS 51336
			create allLCs transient;
			parentObj.CM_GeneralCargoAllocRowArea.getAllRowGroupControllers( allLCs );
		else
			allLCs := parentObj.CM_TerminalArea.getLCSet();
		endif;
			
	elseif parentObj.isKindOf( CM_Voyage ) then
		allLCs := parentObj.CM_Voyage.getAllLcs;
			
	elseif parentObj.isKindOf( CM_Train ) then
		create allLCs transient;
		parentObj.CM_Train.getAllLcs( _childCombo = self.cmbSourceLC, allLCs );
		
	elseif parentObj.isKindOf( CM_VehicleVisitRecord ) then
		create allLCs transient;
		parentObj.CM_VehicleVisitRecord.getAllLcs( _childCombo = self.cmbSourceLC, allLCs );
		
	endif;
	
	if allLCs &lt;&gt; null then
		foreach lc in allLCs do
			index := _childCombo.addItem( lc.getFullId() );
			_childCombo.itemObject[ index ] := lc;
		endforeach;
	endif;
	
	if _childCombo.listCount = 1 then
		_childCombo.listIndex := 1;
	endif;

epilog

	if allLCs &lt;&gt; null and allLCs.isTransient then
		delete allLCs;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_parentCombo" type="ComboBox"/>
        <Parameter name="_childCombo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCmbTypes" id="0347bdb0-6c80-43aa-a3a3-c8eeff4d48cc">
        <updating/>
        <source>populateCmbTypes( _combo : ComboBox input ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	
	parentCombo : ComboBox;
	childCombo : ComboBox;
	chkBox : CMUI_CheckBox;
	defaultParentValue : CM_Object;
	defaultChildValue : CM_LocationsController;
	index : Integer;
	ta : CM_TerminalArea;
	trainSet : CM_TrainSet;
	voyageSet : CM_VoyageSet;								
	vvrSet : CM_VehicleVisitRecordSet;
	earliest : TimeStamp;
	voyage : CM_Voyage;
	train : CM_Train;
	vvr : CM_VehicleVisitRecord;

begin

	if _combo = self.cmbSourceType then
		parentCombo := self.cmbSource;
		chkBox := self.chkSourceMore;
		childCombo := self.cmbSourceLC;
		defaultParentValue := self.myLocationActivity.getSourceParentLocation( defaultChildValue );
	elseif _combo = self.cmbTargetType then
		parentCombo := self.cmbTarget;
		chkBox := self.chkTargetMore;
		childCombo := self.cmbTargetLC;
		defaultParentValue := self.myLocationActivity.getTargetParentLocation( defaultChildValue );
	else
		return;
	endif;
	
	parentCombo.clear();
	childCombo.clear();
	chkBox.visible := true;
	if not chkBox.value then
		earliest := self.myLocationActivity.dateTime.cnEcAddDays( -7 );
	else
		earliest := null;
	endif;

	parentCombo.enabled := true;
	childCombo.enabled := false;
		
	if _combo.text = null then
		parentCombo.enabled := false;
		return;
		
	elseif _combo.text = app.getErrorString(TerminalAreas) then
		childCombo.enabled := true;
		chkBox.visible := false;
		foreach ta in self.myTerminal.allTerminalAreas discreteLock do
			index := parentCombo.addItem( ta.id );
			parentCombo.itemObject[index] := ta;
		endforeach;
		
	elseif _combo.text = app.getErrorString(Voyages) then
		create voyageSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, voyageSet, null, earliest );
		foreach voyage in voyageSet discreteLock do
			index := parentCombo.addItem( voyage.idForLocationActivity );
			parentCombo.itemObject[index] := voyage;
		endforeach;
	
	elseif _combo.text = app.getErrorString(Trains) then
		create trainSet transient;
		self.myTerminal.getValidLocationActivityObjs( trainSet, null, null, earliest );
		foreach train in trainSet discreteLock do
			index := parentCombo.addItem( train.getCodeDateString );
			parentCombo.itemObject[index] := train;
		endforeach;
		
	elseif _combo.text = app.getErrorString(Vehicle_visit_records) then
		create vvrSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, null, vvrSet, earliest );
		foreach vvr in vvrSet discreteLock do
			index := parentCombo.addItem( vvr.visitNumber &amp; " / " &amp; vvr.regNumber &amp; " / " &amp; vvr.getTimeInLocalTZFormatted );
			parentCombo.itemObject[index] := vvr;
		endforeach;
	endif;
	
	if defaultParentValue &lt;&gt; null then
		index := parentCombo.findObject( defaultParentValue );
		if index &gt; 0 then
			parentCombo.listIndex := index;
			self.populateCmbLCs( parentCombo, childCombo );
			index := childCombo.findObject( defaultChildValue );
			if index &gt; 0 then
				childCombo.listIndex := index;
			endif;
		endif;
	endif;

epilog

	delete voyageSet;
	delete trainSet;
	delete vvrSet;

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateComboTIs" id="93da0ab9-4720-463d-8c91-ae11e508ca0f">
        <source>populateComboTIs( _combo : ComboBox input; _tiSet : CM_TISet ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ti : CM_TrackedItem;
	index : Integer;

begin

	_combo.clear();
	
	foreach ti in _tiSet do
		index := _combo.addItem( ti.id );
		_combo.itemObject[ index ] := ti;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setMyLocationActivity" id="80e71852-0d84-4598-bb03-6092df83eb2f">
        <updating/>
        <source>setMyLocationActivity( _locActivity : CMEVT_LocationActivity ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.myLocationActivity := _locActivity;

epilog

end;</source>
        <Parameter name="_locActivity" type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="setupBaseData" id="5f888a7e-f344-4cf1-98d4-7593b2bcad97">
        <updating/>
        <source>setupBaseData()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50905

*/

vars

	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	unit : String;
	converted : String;
	sourceTypeStr : String;
	targetTypeStr : String;
	index : Integer;

begin

	self.txtAmount.visible := false;
	self.tblAmount.visible := false;
	self.tblAmount.left := self.txtAmount.left;
	self.tblAmount.tabKey := J_key_Tab;
	
	self.cmbSourceType.clear();
	self.cmbSourceType.addItem( app.getErrorString(TerminalAreas) );
	self.cmbSourceType.addItem( app.getErrorString(Voyages) );
	self.cmbSourceType.addItem( app.getErrorString(Trains) );
	self.cmbSourceType.addItem( app.getErrorString(Vehicle_visit_records) );
	
	self.cmbTargetType.clear();
	self.cmbTargetType.addItem( app.getErrorString(TerminalAreas) );
	self.cmbTargetType.addItem( app.getErrorString(Voyages) );
	self.cmbTargetType.addItem( app.getErrorString(Trains) );
	self.cmbTargetType.addItem( app.getErrorString(Vehicle_visit_records) );
	

	if self.myLocationActivity &lt;&gt; null then
		cargoType := self.myLocationActivity.getCargoType();
		//Non editable
		self.txtActivityType.text := self.myLocationActivity.getTypeAsString;
		self.txtCargoType.text := self.myLocationActivity.getCargoTypeDescr;
		self.txtOperator.text := self.myLocationActivity.operatorCode;
		self.txtHasBeenEdited.text := self.myLocationActivity.getHasBeenEdited.getYesNo;
		self.txtNeedsRecalc.text := self.myLocationActivity.needsRecalculation.getYesNo;
		self.txtSource.text := self.myLocationActivity.sourceLocationStr;
		self.txtTarget.text := self.myLocationActivity.targetLocationStr;
		
		//editable
		self.txtDate.setDate( self.myLocationActivity.dateTime.date );
		self.txtTime.setTime( self.myLocationActivity.dateTime.time );
		if cargoType = null then
			self.txtAmount.visible := true;
			self.txtAmount.text := self.myLocationActivity.quantity.asStringJMT;
		elseif cargoType.isTrackByVolume then
			self.tblAmount.visible := true;
			self.tblAmount.setup(Type_Volume, self.backColor);
			measureType := cargoType.myVolumeMeasurementType;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit,  self.myLocationActivity.volume);
			self.tblAmount.setMeasurementType(measureType.measurementType);
			self.tblAmount.setValues( converted  &amp; " " &amp; unit );
		elseif cargoType.isTrackByWeight then
			self.tblAmount.visible := true;
			self.tblAmount.setup(Type_Weight, self.backColor);
			measureType := cargoType.myWeightMeasurementType;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit,  self.myLocationActivity.weight);
			self.tblAmount.setMeasurementType(measureType.measurementType);
			self.tblAmount.setValues( converted  &amp; " " &amp; unit );
		else
			self.txtAmount.visible := true;
			self.txtAmount.text := self.myLocationActivity.quantity.asStringJMT;
		endif;
		self.txtRemarks.text := self.myLocationActivity.remarks;
		
		sourceTypeStr := self.myLocationActivity.getSourceTypeString;
		if sourceTypeStr &lt;&gt; null then
			index := self.cmbSourceType.findStringExact(1,sourceTypeStr);
			self.cmbSourceType.listIndex := index;
		else
			self.cmbSourceType.listIndex := -1;
		endif;
		self.populateCmbTypes( self.cmbSourceType );
		
		targetTypeStr := self.myLocationActivity.getTargetTypeString;
		if targetTypeStr &lt;&gt; null then
			index := self.cmbTargetType.findStringExact(1,targetTypeStr);
			self.cmbTargetType.listIndex := index;
		else
			self.cmbTargetType.listIndex := -1;
		endif;
		self.populateCmbTypes( self.cmbTargetType );
		
		if self.myLocationActivity.isLocationDiscrepancyDecrease or self.myLocationActivity.isLocationDiscrepancyIncrease then
			self.lblSource.visible := false;
			self.txtSource.visible := false;
			self.lblTarget.visible := false;
			self.txtTarget.visible := false;
			self.lblNewSourceItem.visible := false;
			self.cmbNewSourceItem.visible := false;
			self.lblNewTargetItem.visible := false;
			self.cmbNewTargetItem.visible := false;
			
			self.chkSourceMore.visible := false;
			self.chkTargetMore.visible := false;
			
			self.cmbSourceType.enabled := false;
			self.cmbSource.enabled := false;
			self.cmbSourceLC.enabled := false;
			self.cmbTargetType.enabled := false;
			self.cmbTarget.enabled := false;
			self.cmbTargetLC.enabled := false;
		endif;
		
		if self.myLocationActivity.isLocationDiscrepancyDecrease then
			self.lblTargetType.visible := false;
			self.cmbTargetType.visible := false;
			self.lblTargetArea.visible := false;
			self.cmbTarget.visible := false;
			self.cmbTargetLC.visible := false;
			self.lblTargetItem.visible := false;
			self.cmbTargetItem.visible := false;
		
		elseif self.myLocationActivity.isLocationDiscrepancyIncrease then
			self.lblSourceType.visible := false;
			self.cmbSourceType.visible := false;
			self.lblSourceArea.visible := false;
			self.cmbSource.visible := false;
			self.cmbSourceLC.visible := false;
			self.lblSourceItem.visible := false;
			self.cmbSourceItem.visible := false;
			
			self.lblTargetType.left := self.lblSourceType.left;
			self.cmbTargetType.left := self.cmbSourceType.left;
			self.lblTargetArea.left := self.lblSourceArea.left;
			self.cmbTarget.left := self.cmbSource.left;
			self.cmbTargetLC.left := self.cmbSourceLC.left;
			self.lblTargetItem.left := self.lblSourceItem.left;
			self.cmbTargetItem.left := self.cmbSourceItem.left;
			
		endif;
		
	endif;
	
	self.populateCmbItems( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="70305818-6590-4a18-9de6-3babc1d30e66">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	inheritMethod();
	
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	
	self.doResize();	//18 May 2021	NDL	TF S51229
	
	self.setupBaseData();
	

epilog

end;</source>
