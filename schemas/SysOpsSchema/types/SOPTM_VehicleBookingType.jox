    <JadeMethod name="setControlsForAddEdit" id="74afeb94-1163-4abc-ad37-ea875b25aafc">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation	Par 35008
23 june 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
06/11/2023	navkc1 Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
*/

vars

	pxyVbsType : CM_VehicleBookingTimeSlotType;
	vbsProcess : CM_VBSProcess;
	term       : CM_Terminal;
	table      : CM_EntryTable;
begin
	table       := self.myForm.tblInput1;
	term		:= self.myForm.myTerminal;
	vbsProcess  := term.getMyVBSProcess();
	
	table.userInputEnabled := true;
	
	if self.myForm.mode = SOP_TableMaintForm.Mode_Add then
		table.clearValues;
		table.setFocus;
		table.moveFirst();
		//Start 23.06.2022 navtnr20 TFS 53697
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then						
			self.myForm.initTblInput(table, ETDef_VBTimeSlotTypeAdvanced); 
		else
			self.myForm.initTblInput(table, ETDef_VBTimeSlotType);			
		endif;
		table.setValueByName(ETRow_VbsProcess, vbsProcess.description);	
		table.setValueByName(ETRow_OutsideSlotTimeAction,app.vbsEnumToString(CM_VehicleBookingTimeSlotType.VBS_ENTRY_NOACTION));
		self.myForm.loadTimeSlotAction(CM_VehicleBookingTimeSlotType.VBS_ENTRY_NOACTION);
		// 06/11/2023	navkc1 Bug 61094 - allow user to set the criteria in Add mode
		//table.hideRowByName(ETRow_DefineMatchingCriteria,false);
		table.setValueByName(ETRow_DefineMatchingCriteria, "Dbl-Click to add"); //06/11/2023	navkc1 Bug 61094
		//End 23.06.2022 navtnr20 TFS 53697
	else
		pxyVbsType:=self.myForm.myProxyObject.CM_VehicleBookingTimeSlotType;
		self.showThumbnail(pxyVbsType);
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="971bd8ea-3d2b-4558-af96-bf7290c031b5">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2022		navma1	Initial creation
10 Oct 2022 navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	theForm : SOP_TableMaintForm;

begin
  	inheritMethod();
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.loadTimeSlotAction(null);		// 10.10.2022 navhl20 TFS 53697
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="9b031206-3ff8-46cb-8e54-db14233b28a7">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2014	cnwndl1	 Initial creation	Par 35008
06 Jul 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
10 Oct 2022 navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes

*/

vars
	theForm : SOP_TableMaintForm;
	vbsProcess : CM_VBSProcess;		// 20.12.2022 navak20 TFS 55978
begin
	theForm 			   := self.myForm;
	theForm.useProxyObject := true;
	vbsProcess := theForm.myTerminal.getMyVBSProcess();		// 20.12.2022 navak20 TFS 55978
	
	//START	05.07.2022 navtnr20 TFS 53697
	//if theForm.myTerminal.getMyVBSProcess() &lt;&gt; null and theForm.myTerminal.getMyVBSProcess().isVbsSlotValidation then		// 20.12.2022 navak20 TFS 55978
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then		// 20.12.2022 navak20 TFS 55978
		theForm.setTblDataEntRows(ETDef_VBSlotTypeAdvanceTBL);
		theForm.initTblInput(theForm.tblInput1, ETDef_VBSlotTypeAdvanceTBL);		// 10.10.2022 navhl20 TFS 53697
	else
		theForm.setTblDataEntRows(ETDef_VBTimeSlotType);
		theForm.initTblInput(theForm.tblInput1, ETDef_VBTimeSlotType);				// 10.10.2022 navhl20 TFS 53697
	endif;
	//END	05.07.2022 navtnr20 TFS 53697
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="22c295f5-3c46-41d9-a0b2-81ef3fe97c9d">
        <updating/>
        <source>showThumbnail(pObj: CM_VehicleBookingTimeSlotType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation	Par 35008
23 june 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars

	theForm	: SOP_TableMaintForm;
	tbl		: CM_EntryTable;
	vbsProcess : CM_VBSProcess;		// 20.12.2022 navak20 TFS 55978
begin

	theForm	:=	self.myForm;
	tbl     :=  theForm.tblInput1;
	vbsProcess := pObj.myVBSProcess;		// 20.12.2022 navak20 TFS 55978
	
	theForm.tblInput1.clearValues();
	
	//Start 22.06.20222 navtnr20 TFS 53697
	theForm.loadTimeSlotAction(pObj.outsideSlotTimeAction);
	//if pObj.myVBSProcess.isVbsStandard then	// 20.12.2022 navak20 TFS 55978
	if vbsProcess.isVbsStandard then			// 20.12.2022 navak20 TFS 55978
		theForm.initTblInput(tbl, ETDef_VBTimeSlotType);	
	else
		theForm.initTblInput(tbl, ETDef_VBTimeSlotTypeAdvanced); 
	endif;
	
	tbl.setValueByName(ETRow_VbsProcess,vbsProcess.description);

	//End 22.06.20222 navtnr20 TFS 53697
	tbl.showRowByName(ETRow_Code				 , false);
	tbl.setValueByName(ETRow_Code				 , pObj.code);
	tbl.setValueByName(ETRow_Description		 , pObj.description);
	tbl.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);
	
	//Start 22.06.20222 navtnr20 TFS 53697
	tbl.setValueByName(ETRow_StartTime				 , pObj.startTime);	
	tbl.setValueByName(ETRow_Duration				 , pObj.duration);
	tbl.setValueByName(ETRow_GracePeriod			 , pObj.gracePeriod);
	tbl.setValueByName(ETRow_OutsideSlotTimeAction   , app.vbsEnumToString(pObj.outsideSlotTimeAction));
	tbl.setValueByName(ETRow_PreGateInCheck			 , pObj.preGateInCheck);
	tbl.setValueByName(ETRow_PreGateOutCheck 		 , pObj.preGateOutCheck);	
	tbl.setValueByName(ETRow_KioskCheck				 , pObj.kioskCheck);
	tbl.setValueByName(ETRow_ExternalRefUpdateAllowed, pObj.isExternelRefUpdateAllowed);
	
	//27.07.2022 namva1 #53697
	tbl.setValueByName(ETRow_DefineMatchingCriteria,pObj.getVBSCriteriaDisplay());    //22.06.20222 navtnr20 TFS 53697
	tbl.setValueByName(ETRow_AutoAssociateRR		 , pObj.autoAssociateRR);		  //25.11.2024 navhl20 #33483
epilog

end;</source>
        <Parameter name="pObj" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
</Class>
