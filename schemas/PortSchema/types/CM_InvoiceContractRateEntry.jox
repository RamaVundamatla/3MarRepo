    <JadeMethod name="setProxy" id="e21d7f17-2da7-49ff-ad30-20c9607b06a4">
        <updating/>
        <source>setProxy(_id : Integer64; _cpu : Decimal; _fromAmt, _toAmt : Decimal; _fromTS, _toTS : TimeStamp; _contractRate : CM_InvoiceContractRate; _bu : CM_Bank) updating;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55677
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars

begin
	self.id := _id ; //08/02/2023 navmv20 TFS 55650 TASK 55702  - NOTE - this is only set on the proxy becasue of how the load from file works, this is not used to set the Id on the object
	self.costPerUnit := _cpu;
	self.fromAmount := _fromAmt;
	self.toAmount := _toAmt;
	self.fromTS := _fromTS;
	self.toTS := _toTS;
	
	self.myInvoiceContractRate := _contractRate;
	self.myBusinessUnit := _bu;
	
epilog

end;</source>
