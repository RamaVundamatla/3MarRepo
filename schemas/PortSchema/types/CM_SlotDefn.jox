    <JadeMethod name="validateMe" id="23dc1e27-d29d-4d9a-bc4f-88dfa8b8f5e1">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_Bay;
begin

	if self.cellId = null or self.tierId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Slot Definition ', null, null);
		app.raiseCMException(Input_required_field_slotDefn, null, null); // cnwdb2	PAR 35364
	endif;

	tmpBay := self.myBay;
	
	// this code has had to be temporarily commented out because of
	// the way the pxyCreateUpdateProxy overrides the fortyFront attribute.
	// When this is fixed up this code should be reinstated.
	/*
	self.validateFortyAttributes();
	*/

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateSetForty" id="39ce8008-967e-4627-8a84-6801f1de9193">
        <updating/>
        <source>validateSetForty() updating;
//----------------------------------------------------------------
//	Created:	29 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	bay: CM_Bay;
	_setForty : Boolean;
begin
	_setForty := self.fortyFront;

	if self.unavailable 
	and  _setForty then
		return;
	endif;

	bay := self.myBay;
	if bay = null then
		// Do a db integrity check
		app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bay.id, "There is no aft bay.", null, null);
	endif;

	if bay.bayType = BAY_TYPE_SINGLE then // if only a single bay =&gt; error
		if _setForty then //if setting 40' property ON
			app.setContinueCMExceptions(false);
			app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bay.id, "Bay " &amp; bay.id &amp; "is a single bay.", null, null);
			return;
		endif;
	else
		if (not bay.isLastInHold()) 
		and  self.myAftSlot &lt;&gt; null then

			if _setForty 
			and self.myAftSlot.unavailable then
				app.raiseCMException3(ERR_FORTYBACK, self.getStowageId(false,true),bay.id,null, null, null);
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
