/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwndl1	Initial creation	Par 29316

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
