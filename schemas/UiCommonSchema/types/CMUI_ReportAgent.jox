					_printerName,
					_networkFilepath: String;
					_destinationOption : Integer;
					_passport 		: CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin 

	// Not user any more.
	return false;
/*	if _pxyMenuUserReport = null then
		app.myTrxCA.trxCreateMenuUserReport(_filterObject,
										_qryReport,
										_processingOption,
										_profName,
										_newMenuUserReport,
										_extraDetail,
										_menuRoot,
										_emailTemplate,
										_isTemplate,
										_reportName,
										_reportDescription,
										_printerName,
										_networkFilepath,
										_destinationOption,
										_passport);

	else
		app.myTrxUA.trxUpdateMenuUserReport(_filterObject,
										_qryReport,
										_processingOption,
										_profName,
										_pxyMenuUserReport,
										_extraDetail,
										_menuRoot,
										_emailTemplate,
										_isTemplate,
										_reportName,
										_reportDescription,
										_printerName,
										_networkFilepath,
										_destinationOption,
										_passport);
	endif;
	
	if not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog('Background reports', app.myPassport, ErrWarnMode_Add);
		return false;
	else
		return true;
	endif;*/
end;</source>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
        <Parameter name="_qryReport" type="CM_QryReport"/>
