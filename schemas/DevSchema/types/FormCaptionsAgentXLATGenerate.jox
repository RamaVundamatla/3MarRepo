<Class name="FormCaptionsAgentXLATGenerate" id="a1db9683-7483-4e77-aed2-af7b195ce1d7">
    <superclass name="FormCaptionsAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <subschemaFinal/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ImplicitInverseRef name="errorDetailsDict" id="403cee9e-7fa3-4d95-89f4-dd430ebc4507">
        <embedded/>
        <type name="DynaDictionary"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myReleaseExtractAgent" id="e0e85638-b37b-4a5f-bcf5-9f94a4071926">
