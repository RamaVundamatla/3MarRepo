    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="8c55f5f9-1918-462b-a61c-1c02f7be9e80">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="defaultTugHours" id="683a2bef-4db5-4cae-baaa-5d96bed3893a">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="b4f9b15b-2a59-46c3-89b3-800fe1e7f434">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isActionDateTimeRequired" id="e96c022c-dc64-4224-aff0-04dd4747abef">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isFromToDateTimeRequired" id="c2a146b0-af26-4252-bcc6-87da388db62a">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isUnitRequired" id="246aa290-b00e-41ab-b42c-063f2b7f7a1f">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="resource" id="d7fc0a72-b844-4a02-b748-c949b47d5225">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
