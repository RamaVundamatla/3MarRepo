    <JadeMethod name="setRTGBay" id="83a9c36f-4682-4b40-9ccf-02fb7577e46a">
        <updating/>
        <source>setRTGBay(_col 	: Integer; 
			_label 	: String; 
			_rtgArea : CM_RTGArea; 
			_lane 	: CM_RTGLane) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.column := _col;
	self.label := _label;
	self.myRTGArea := _rtgArea;
	self.myRTGLane := _lane;
	
end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_rtgArea" type="CM_RTGArea"/>
        <Parameter name="_lane" type="CM_RTGLane"/>
    </JadeMethod>
