    <JadeMethod name="isWeightCertified_Match" id="4881ea1f-0d03-4437-a3e4-98f3bc699754">
        <source>isWeightCertified_Match(_yaData: CM_YADataBoolean): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2016	cnwdap1		Initial creation TFS #1949 VGM Process Requirements - Allocations
//
vars

begin
	if not self.myTrackedItem.isContainer() then
		return _yaData.doesValueMatch(false);
	endif;
	
	return _yaData.doesValueMatch(self.myTrackedItem.isWeightCertified);

epilog

end;</source>
