	endif;

	if self.offset53 = CM_LocationsController.Offset53_Unavailable then
		_yaAgent.addLogEntry(locnId &amp; " cannot be a primary location for a 53.", true);
		return true;
	
	endif;
	*/
		//cnwrd1 19.3.09
	if self.is53ft then
