    <JadeMethod name="setSearchToolbar" id="3f3a10b2-bca6-4297-91dc-037646d607ef">
        <source>setSearchToolbar();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 April 2006
//
//----------------------------------------------------------------------

vars
	vessTxtTop,
	vessComboTop	: 	Real;
begin
	//Check what the form's main toolbar is doing.
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;
	
	//Now move the contols to fit the frame. 
	//Text box and it's corresponding label
	vessTxtTop := self.frmSearchToolbar.height + 3;
	self.txtVesselCode.top := vessTxtTop;
	self.lblVesselCode.top := vessTxtTop;
	
	//Vessel Combo and it's corresponding label.
	vessComboTop := self.txtVesselCode.top + self.txtVesselCode.height + 3;
	self.cmbVesselFilter.top := vessComboTop;
	self.lblVessel.top := vessComboTop;
	
	self.frmSearch.height := vessTxtTop + 55;	// 1/2/17 MAP TFS3267
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setSelectedVessel" id="300b1754-8b82-4799-87b0-2e47dd126a96">
        <updating/>
        <source>setSelectedVessel(_vessel : CM_Vessel)updating;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.picVessel.picture := null;
	self.myCurrentVessel := _vessel;
	
	// Display extra information table
	self.displayExtraInfo();
	
	// Display vessel picture
	if self.myCurrentVessel &lt;&gt; null then
		self.picVessel.picture := self.myCurrentVessel.bitmap;
		self.setNavigatorHeading(self.myCurrentVessel.getDisplayDetails(false));

	else

		self.setNavigatorHeading(self.caption);	
	endif;
	
	self.setControlsForView();
	
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="39ae8267-0693-4223-b357-9ea2c0c44dc6">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx : Integer;
begin
	self.displayVessels();
	if self.tblData.findObjectInRow(self.myCurrentVessel, rowIdx) then
		self.tblData.selectRow(rowIdx, false);
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c5d36aeb-de4b-498f-8937-35b30804624a">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On By Reason
// ---------- ---------- --------------------------------------------------
// 04 Mar 2022  navgm20   TFS #53051 MTN - Add Filter to Vessel Enquiry, Voyage Enquiry
vars
	tmpTerm : CM_Terminal;
	tmpUser : CM_User;
	tmpUserT : CM_UserTerminal;
begin
	inheritMethod();

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	self.setFilterDefaults();

	self.setNavigatorHeading(self.caption);

	// Prioritise self.myTerminal over the app method call as this can return the incorrect terminal because
	// notes can change the terminal in the passport, but the form will relate to the old terminal - cnwcp2 - 20/2/2009 - PAR#18073
	tmpTerm := self.myTerminal;
	if tmpTerm = null then
		tmpTerm := app.getMyTerminalDO_NOT_USE();
		if tmpTerm = null then
			tmpUser := app.getMyUser();
			if tmpUser &lt;&gt; null then
				tmpUserT := tmpUser.allUserTerminals.first;
				if tmpUserT &lt;&gt; null then
					tmpTerm := tmpUserT.getRealTerminal;
				endif;
			endif;
		endif;
	endif;

	if tmpTerm &lt;&gt; null then
		self.cmbVesselFilter.isDisplayByName := tmpTerm.getConfig(VesselComboByName).Boolean;
	endif;	

	self.beginClassNotification(CM_Vessel, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Vessel, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Vessel, false, Object_Delete_Event, Response_Continuous, 0);	
	
	// not use on this form, disable 
	self.btnSaveBase.enabled := false;
	//25/06/2024	navkc1 CR 64823 Task 64824 //self.btnClearFilter.enabled := false;		//TFS 53051
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilter.setCallbackMethod(SHP_VesselEnquiryForm::doFilterTable.name); //05/06/2024	navkc1 CR 63736 Task 63770
	
end;</source>
    </JadeMethod>
