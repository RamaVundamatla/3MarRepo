    <JadeMethod name="switchToReleaseByIdMulti" id="cb54203a-9ae4-4d50-9ce0-0e3e50749740">
        <updating/>
        <source>switchToReleaseByIdMulti() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

begin

	self.onContainerIdChange(null, null);
	
	if not self.isByTypeByWeight and not self.isByTypeByQuantity then		//10.Jan.23 navsp1 TFS 61547 / Task 61999
		self.cmbReleaseItem.clear();		
	endif;
	
	self.txtNumItems.setValue(null);

	self.initFieldsForEntDefName(ETDef_ReleaseByIdMultiItem, false);
	self.doSetCaption();
	self.doShowPicture();
	
	self.lblMainDetails.left := self.picTitleEmpty.left + self.picTitleEmpty.width;
	
	self.chkAnyId.isHidden:= false;
	self.chkAnyId.setValue(true);
	self.chkAnyAmount.isHidden:= false;	//21 Mar 2017	NDL	TFS 3813
	
	self.setCargoID(null);
	self.clearByTypeFields();
	
	self.doWindowEvents(1);	// don't know why, but the cargo id list hangs around without this...
	
	self.chkAnyId.setFocus();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="switchToReleaseEmpty" id="25a8d20e-e881-4914-8186-993d18e1d208">
        <updating/>
        <source>switchToReleaseEmpty() updating, protected;
/*
Date		Who		Reason
20 August 2009	cnwjk3	Initial creation
*/

vars

begin
	self.setIsEmptyContainer();
	self.initFieldsForEntDefName(ETDef_ReleaseContainerEmpty, false);
	self.doSetCaption();
	self.doShowPicture();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="switchToReleaseFull" id="ab5c365d-5399-422f-bb1c-ddf2428ff713">
        <updating/>
        <source>switchToReleaseFull() updating, protected;
/*
Date		Who		Reason
20 Aug 2009	cnwjk3	Initial creation
07 Nov 2019 cnwma1	Bug 47218: JMT - Release general cargo screen changes to release full container when untick 'Any ID' in Road Gate screen    
*/

vars

begin
	//07/11/2019 cnwma1 #47218
	//self.setIsFullContainer();
	//self.initFieldsForEntDefName(ETDef_ReleaseContainerFull, false);
	
	if self.isFullContainer() then
		self.initFieldsForEntDefName(ETDef_ReleaseContainerFull, true);
		self.setIsFullContainer();
		
	elseif self.isEmptyContainer() then
		self.initFieldsForEntDefName(ETDef_ReleaseContainerEmpty, true);
		self.isEmptyContainer();
	elseif self.isGeneralCargo() then
		self.initFieldsForEntDefName(ETDef_ReleaseGeneralCargo, true);	
		self.setIsGeneralCargo();
	endif;
	
	self.doSetCaption();
	self.doShowPicture();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="00031c6a-ffc5-49c6-bd2a-280f0f3c6f19">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 April 2024 10:43:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012160, locale);
	btnAdditionalRel.translateCaption(Xlat_0012161, locale);
	btnCargoAvailCheck.translateBubbleHelp(Xlat_0023563, locale);
