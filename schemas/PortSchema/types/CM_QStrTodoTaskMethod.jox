    <JadeMethod name="create" id="b37b1cc2-8871-4b95-8036-c61eb23fb742">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query

*/

vars
	operator : CM_QStringIsOneOf;
begin
	if self.isTransient then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
