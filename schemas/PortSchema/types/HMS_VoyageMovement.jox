    <JadeMethod name="getVoyageMovementNext" id="c1f0322e-450f-498f-9db8-885015cde31f">
        <source>getVoyageMovementNext(): HMS_VoyageMovement;
/*

Purpose:			Returns the next HMS_VoyageMovement that is on the same voyage as the
					current movement.
					
					
Return Value:		Next movement, or null if there isn't one


Date		Who		Reason
13 Mar 2008	cnwer1	Initial creation - PAR#xxxx
30 Mar 2008	cnwkpd1	PAR #16367 - Allow for proxy operations by using voyage data dictionary if reference
					is not set.  Also ensure movement is for the same voyage by explicitly returning null for 
					a departure.

*/

vars
	voyageMovement	: HMS_Movement;

begin
	if self.isMovementTypeDeparture then
		return null;
	endif;
	
	voyageMovement := self.getMovementNext();
	
	// PAR #16367 - If reference is null, then try using voyage data dictionary
	if voyageMovement = null and self.myHMSVoyageData &lt;&gt; null then
		voyageMovement := self.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(self.occursOnDTNEW);
	endif;
	
	if voyageMovement &lt;&gt; null and voyageMovement.isKindOf(HMS_VoyageMovement) then
//	   self.isSameVoyage(voyageMovement) then
		return voyageMovement.HMS_VoyageMovement;
	endif;
	
	return null;


epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getVoyageMovementPrevious" id="26d45076-f212-498f-829c-75ae5cf0555f">
        <source>getVoyageMovementPrevious() : HMS_VoyageMovement;

/*

Purpose:			Returns the previous HMS_VoyageMovement that is on the same voyage as the
					current movement.
					
					
Return Value:		Previous movement, or null if there isn't one



Date		Who		Reason
13 Mar 2008	cnwer1	Initial creation - PAR#xxxx
30 Mar 2008	cnwkpd1	PAR #16367 - Allow for proxy operations by using voyage data dictionary if reference
					is not set.  Also ensure movement is for the same voyage by explicitly returning null for 
					an arrival.

*/

vars
	voyageMovement	: HMS_Movement;
	
begin
	if self.isMovementTypeArrival() then
		return null;
	endif;
	
	voyageMovement := self.getMovementPrevious;
	
	// PAR #16367 - If reference is null, then try using voyage data dictionary
	if voyageMovement = null and self.myHMSVoyageData &lt;&gt; null then
		voyageMovement := self.myHMSVoyageData.allVoyageMovements.getAtKeyLss(self.occursOnDTNEW);
	endif;
	
	if voyageMovement &lt;&gt; null and voyageMovement.isKindOf(HMS_VoyageMovement) then
//	   self.isSameVoyage(voyageMovement) then
		return voyageMovement.HMS_VoyageMovement;
	endif;
	
	return null;
	

epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="init_BerthBowSternMarks" id="89f71fca-cd97-42ed-bf67-3bb93e45fea2">
        <updating/>
        <source>init_BerthBowSternMarks(_berth : HMS_Berth; _berthPref : HMS_BerthPreference)updating;

/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16367 - hange to use reworked getVoyageMovementPrevious
06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
26 Mar 2019	jlgdi1	TFS# 44012 Consider the preferred berth specified by the user when initializing DepartureMovementType
05 Jul 2019	jlgdap1	TFS 45235 PEL1 - INAP Departure berth not correct
21 Mar 2023	navdap1	TFS 56593 EUP - Show Bollard+Meters in all instances
21 Sep 2023	navdap1	TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
*/

vars
	loa:				Decimal[6,2];
	tmpLength,
	shipStart,
	shipEnd:			Decimal[12,2];
	waterOnLeftOfWharf:	Boolean;
	prevMove 	: HMS_VoyageMovement;	
	tmpBerth	: HMS_Berth;
	bollardMark : Integer;		// TFS 56593
	bollard : HMS_Resource;		// TFS 56593
begin
	if self.moveType = HMSMovementTypeDeparture  then //06.10.2017	cnwma1  TFS #7257
		//if _berth &lt;&gt; null then		// TFS# 44012								// TFS 45235
		//	tmpBerth := _berth;														// TFS 45235
		//else																		// TFS 45235
		//PAR 11009 set berth to default departure berth							// TFS 45235
		//	tmpBerth := self.myHarbour.getDefaultBerthForMoveType(self.moveType);	// TFS 45235
		//endif;																	// TFS 45235
		tmpBerth := self.myHarbour.defaultDepartBerth;								// TFS 45235
		if tmpBerth = null then														// TFS 45235
			tmpBerth := _berth;														// TFS 45235
		endif;																		// TFS 45235
		
		prevMove := self.getVoyageMovementPrevious();	// PAR #16367
		if prevMove &lt;&gt; null then
			//self.myBerth 		:= prevMove.myBerth; PAR 11009
			self.bowMarkTo 		:= prevMove.bowMarkTo;
			self.sternMarkTo	:= prevMove.sternMarkTo;
			self.foreClearanceTo:= prevMove.foreClearanceTo;
			self.aftClearanceTo	:= prevMove.aftClearanceTo;
			self.sideTo			:= prevMove.sideTo; 	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'No arrival movement found');
			return;
		endif;
		
	elseif _berthPref &lt;&gt; null then
		//Set the marks to the prefered berth marks	
		tmpBerth := _berthPref.getMyBerth;
		if tmpBerth = null then
			tmpBerth := self.myHMSVoyageData.getMyBerth;		
		endif;
		
	elseif _berth &lt;&gt; null then
		tmpBerth := _berth;
	else	
		tmpBerth := self.myHMSVoyageData.getMyBerth();
	endif;

	if tmpBerth = null then
		tmpBerth := self.myHarbour.getDefaultBerthForMoveType(self.moveType);
	endif;
	
	self.setMyBerth(tmpBerth);

	if tmpBerth = null then
		return;
	endif;

	if _berthPref &lt;&gt; null then
		
		_berthPref.getDefaultMarks(self.myHMSVoyageData.dim_LengthOverall, self.sideTo, self.bowMarkTo, self.sternMarkTo);
		
		//Calculate and set clearances for marks
		self.berthing_RecalculateClearances();		
	else
		//Calculate and set marks and clearances
		self.berthing_AutoPositionOnBerth();
	endif;
	/* now called in setMyBerth above
	if self.myNextMovement &lt;&gt; null then
		self.setNextMovementBerthPrevious(tmpBerth);
		//self.myNextMovement.myBerthPrevious := self.myBerth;
	endif;
	*/
	// TFS 56593 start
	tmpBerth.getBollardForMark(self.bowMarkTo.Integer, bollardMark, bollard);
	self.bowToBollard := bollardMark;
	self.myBowBollard := bollard;
	tmpBerth.getBollardForMark(self.sternMarkTo.Integer, bollardMark, bollard);
	self.sternToBollard := bollardMark;
	self.mySternBollard := bollard;
	if self.myHMSVoyageData &lt;&gt; null then			// TFS 59472
		if self.sternMarkTo &gt; self.bowMarkTo then
			tmpBerth.getBollardForMark((self.bowMarkTo + self.myHMSVoyageData.dist_BridgeToBow).Integer, bollardMark, bollard);
		else
			tmpBerth.getBollardForMark((self.bowMarkTo - self.myHMSVoyageData.dist_BridgeToBow).Integer, bollardMark, bollard);
		endif;
		self.bridgeToBollard := bollardMark;
		self.myBridgeBollard := bollard;
	endif;
	// TFS 56593 end
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_berthPref" type="HMS_BerthPreference"/>
    </JadeMethod>
    <JadeMethod name="init_CustomerForMove" id="582b1cdd-2f3e-4710-8238-a16751405d08">
        <source>init_CustomerForMove(_defAgent: CM_ShippingAgent output; _defShippingLine: CM_ShippingLine output;
					_agentIsDefault : Boolean output; _defContact : CM_EmailAddress2 output) protected;

vars
	tmpVessel : CM_Vessel;
	tmpVDHarbour : HMS_VesselDataHarbour;
	tmpVesselData :	HMS_VesselData;
begin
	// Returns initialise value for 'AGENT, SHIPPING LINE, CONTACT AND AGENT_IS_DEFAULT FLAG'
	tmpVessel := self.getMyVessel();
	if tmpVessel = null then
		return;
	endif;
	
	tmpVesselData := tmpVessel.myHMSVesselData;
	if tmpVesselData = null then
		return;
	endif;

	tmpVDHarbour := tmpVesselData.allVesselDataForHarbour[self.myHarbour];
	
	if tmpVDHarbour &lt;&gt; null then
		_defAgent := tmpVDHarbour.myShippingAgent;
		_agentIsDefault := _defAgent &lt;&gt; null;
	endif;

	_defShippingLine := tmpVesselData.myDefaultShippingLine;

	// Set contact
	if _agentIsDefault then
		// Return contact for agent (if there is one)
		if _defAgent &lt;&gt; null then
			if _defAgent.allContacts.size &gt; 0 then
				_defContact := _defAgent.allContacts.first;
			endif;
		endif;
	else
		// Return contact for agent (if there is one)
		if _defShippingLine &lt;&gt; null then
			if _defShippingLine.allContacts.size &gt; 0 then
				_defContact := _defShippingLine.allContacts.first;
			endif;
		endif;
	endif;		

end;</source>
        <access>protected</access>
        <Parameter name="_defAgent" type="CM_ShippingAgent" usage="output"/>
        <Parameter name="_defShippingLine" type="CM_ShippingLine" usage="output"/>
        <Parameter name="_agentIsDefault" type="Boolean" usage="output"/>
        <Parameter name="_defContact" type="CM_EmailAddress2" usage="output"/>
    </JadeMethod>
    <JadeMethod name="init_IsPilotExempt" id="d365c126-cef3-4488-b5a1-d312559f83df">
