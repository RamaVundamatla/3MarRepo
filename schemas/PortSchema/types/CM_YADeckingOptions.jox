    <JadeMethod name="isAreaLeftToRight" id="4d5d8c9d-05d2-4fca-ab3a-4bb71f582b93">
        <source>isAreaLeftToRight(): Boolean protected;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea		: CM_GridArea;
begin

	gridArea := self.getGridArea();
	
	if gridArea = null then
		return true;
	endif;
	
	if gridArea.defaultDeckingStartType = CM_GridArea.DefaultDeckingFromLast then
		return false;
	endif;
	
	return true;	
	
	
	
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCustomLeftToRight" id="ac93fe72-ac2c-4ec1-a671-cadc4b9a4741">
        <source>isCustomLeftToRight(): Boolean protected;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	firstPad,
	lastPad		: CM_YardController;
	ta			: CM_TerminalArea;
	rowPosFirst,
	rowPosLast	: Integer;
begin

	if self.allYALocationCellsIn.isEmpty then
		return false;
	endif;
	
	firstPad := self.allYALocationCellsIn.first.myYardController;
	lastPad := self.allYALocationCellsIn.last.myYardController;
	
	if firstPad = null then
		return true;
	endif;
	
	ta := firstPad.myTerminalArea;
	
	rowPosFirst := ta.getPositionInRow(firstPad);
	rowPosLast := ta.getPositionInRow(lastPad);
	
	if rowPosFirst &gt; rowPosLast then
		return false;
	elseif rowPosFirst &lt; rowPosLast then	
		return true;
	elseif rowPosFirst = 1 then
		return true;
	elseif rowPosLast = 1 then
		return false;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
