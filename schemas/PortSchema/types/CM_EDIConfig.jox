    <JadeMethod name="setupEDITransformWrap" id="9ba401df-6d31-4d96-8311-f3961e1374ff">
        <updating/>
        <source>setupEDITransformWrap(_message : String; _transformedMsg, _messageType : String io) : Boolean updating;
//
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//
vars
	ediTrans : CMIF_EdiTransformWrap;
	result : Boolean;
begin
	if _message &lt;&gt; null then
		// PAR #34713 - Call out to .NET EDI
		create ediTrans transient;
		if ediTrans.transformMessage(null, null, null, _message, _transformedMsg) then
//			self.setOriginalFileDataString(_message.String);
			_messageType := System_EDIFileType;
			result := true;
		else
			result := false;
		endif;
	else
		result := false;
	endif;
	return result;
epilog
	delete ediTrans;
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_transformedMsg" type="String" usage="io"/>
        <Parameter name="_messageType" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateVoyagesToProcess" id="f9569480-50a0-4abc-86ba-18326b503a47">
        <source>updateVoyagesToProcess(_voyage : CM_Voyage; _originalVoyageCode : String) : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 May 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 13/05/2010	cnwsh3		PAR24219
// Purpose:
// Check if the voyage we've passed in is already in the keyed collection and if it is in there,
// maintain the dict as we have changed the keys.
//
// Returns:
// true if we found the voyage in the collection and changed the keys
// false if we didn't need to do anything.

// NOTE: We aren't adding the object at this stage.  This should be done after calling this
// method if it is needed.
//----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	if _originalVoyageCode &lt;&gt; null then
		voyage := self.allVoyagesToProcess[_originalVoyageCode];
		
		if voyage &lt;&gt; null then
			
			if _originalVoyageCode &lt;&gt; _voyage.code then
				self.allVoyagesToProcess.removeKey(_originalVoyageCode);
				self.allVoyagesToProcess.add(_voyage);
			endif;
			
			return true; //Because we didn't need to update the collection.
		endif;
	endif;
	//We have not made any update.
	return false;
epilog
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_originalVoyageCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
