    <JadeMethod name="getGLVDrawUsedLengthInPixels" id="bd7c7740-ed49-4ab1-bda8-acf4cfa262bc">
        <source>getGLVDrawUsedLengthInPixels(_zoom : Real) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/

vars

begin
	//return self.stub_geDrawUsedLengthInPixels(_zoom);
	return (self.usedLength * _zoom * self.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE).Integer;
epilog

end;</source>
