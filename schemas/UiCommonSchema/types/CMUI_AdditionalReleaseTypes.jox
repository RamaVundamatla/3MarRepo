    <JadeMethod name="cmbDimType_displayEntry" id="569dfe98-c3d2-4cf7-b388-e7439344971d">
        <controlMethod name="CMUI_FieldComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDimType_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _obj: Any; _index: Integer):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwjk3	Initial creation

*/

vars

begin
	return _obj.CM_ProductAttributeCode.code &amp; ' - ' &amp; _obj.CM_ProductAttributeCode.description;
epilog

end;</source>
        <Parameter name="_combobox" type="CMUI_FieldComboBoxControl" usage="input"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFilterProductAttributes" id="cfa27134-b76c-4283-a1ef-b4c82963137e">
        <source>doFilterProductAttributes(_product : CM_Product) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2009	cnwjk3	Initial creation
15/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	
	if _product.getMyWidth().getIsViewable() then
		self.tblWidth.isHidden := false;
		if self.tblWidth.getConvertedValue() = null and _product.getMyWidth &lt;&gt; null then 
			//self.tblWidth.setValue(_product.getMyWidth.getDisplayValueString);				// PAR #31155
			self.tblWidth.setValueDefault(_product.getMyWidth.getDisplayValueString);			// PAR #31155
		endif;
	else
		self.tblWidth.isHidden := true;
	endif;
	
	if _product.myWidthString.getIsViewable() then
		self.txtWidthText.isHidden := false;
		if self.txtWidthText.getString() = null then
			self.txtWidthText.setValue(_product.myWidthString.getDisplayValueString);
		endif;
	else
		self.txtWidthText.isHidden := true;
	endif;

	if _product.getMyLength().getIsViewable() then
		self.tblLength.isHidden := false;
		if self.tblLength.getConvertedValue() = null then
			//self.tblLength.setValue(_product.getMyLength.getDisplayValueString);				// PAR #31155
			self.tblLength.setValueDefault(_product.getMyLength.getDisplayValueString);			// PAR #31155
		endif;
	else
		self.tblLength.isHidden := true;
	endif;

	if _product.myLengthString.getIsViewable() then	
		self.txtLengthText.isHidden := false;
		if self.txtLengthText.getString() = null then
			self.txtLengthText.setValue(_product.myLengthString.getDisplayValueString);	
		endif;
	else
		self.txtLengthText.isHidden := true;
	endif;

	if _product.getMyHeight().getIsViewable() then
		self.tblHeight.isHidden := false;
		if self.tblHeight.getConvertedValue() = null then
			//self.tblHeight.setValue(_product.getMyHeight.getDisplayValueString);				// PAR #31155
			self.tblHeight.setValueDefault(_product.getMyHeight.getDisplayValueString);			// PAR #31155
		endif;
	else
		self.tblHeight.isHidden := true;
	endif;

	if _product.myHeightString.getIsViewable() then
		self.txtHeightText.isHidden := false;
		if self.txtHeightText.getString() = null then 
			self.txtHeightText.setValue(_product.myHeightString.getDisplayValueString);
		endif;
	else
		self.txtHeightText.isHidden := true;
	endif;

	if _product.myQuantity.getIsViewable() then
		self.txtQuantity.isHidden := false;
		if self.txtQuantity.getString() = null then
			self.txtQuantity.setValue(_product.myQuantity.getDisplayValueString);
		endif;
	else
		self.txtQuantity.isHidden := true;
	endif;

	if _product.getMyWeight().getIsViewable() then
		self.tblTotalWeight.isHidden := false;
		if self.tblTotalWeight.getConvertedValue() = null then
			//self.tblTotalWeight.setValue(_product.getMyWeight.getDisplayValueString);			// PAR #31155
			self.tblTotalWeight.setValueDefault(_product.getMyWeight.getDisplayValueString);	// PAR #31155
		endif;
	else
		self.tblTotalWeight.isHidden := true;
	endif;		

	if _product.myVolume.getIsViewable() then
		self.tblVolume.isHidden := false;
		if self.tblVolume.getConvertedValue() = null then
			//self.tblVolume.setValue(_product.myVolume.getDisplayValueString);					// PAR #31155
			self.tblVolume.setValueDefault(_product.myVolume.getDisplayValueString);			// PAR #31155
		endif;
	else
		self.tblVolume.isHidden := true;
	endif;		

	if _product.myType.getIsViewable() then
		self.cmbDimType.isHidden := false;
		self.cmbDimType.setValue(_product.myType.getDisplayValueString);
	else
		self.cmbDimType.isHidden := true;
	endif;

	if _product.myDensityDec.getIsViewable() then 												// ### TFS 52193 22Nov2021 NAVPW1
		self.tblDensity.isHidden := false;
		if self.tblDensity.getConvertedValue() = null then
			//self.tblDensity.setValue(_product.myDensity.getDisplayValueString);				// PAR #31155
			self.tblDensity.setValueDefault(_product.myDensityDec.getDisplayValueString);		// PAR #31155	// ### TFS 52193 22Nov2021 NAVPW1
		endif;
	else
		self.tblDensity.isHidden := true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="1cf90fbe-0c64-4315-bb36-af98135b7322">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwjk3	Initial creation
14/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
23/08/2013	cnwdap1	PAR #32331 Description and Colour moved to main Release form
*/

vars
	parentForm			: CMUI_ReleaseCargoForm;
	productAttribute	: CM_ProductAttributeCode;
begin
	inheritMethod();
	parentForm := self.myParentForm.CMUI_ReleaseCargoForm;
	
	productAttribute := self.cmbDimType.getObject().CM_ProductAttributeCode;
	//parentForm.doUpdateAdditionalReleaseTypes(self.txtDescription.getString(),	// PAR #32331
	parentForm.doUpdateAdditionalReleaseTypes(null,									// PAR #32331
									self.txtRemarks.getString(),
									//self.tblTotalWeight.getString(),				// PAR #31155
									//self.tblLength.getString(),					// PAR #31155
									//self.tblVolume.getString(),					// PAR #31155
									//self.tblWidth.getString(),					// PAR #31155
									//self.tblHeight.getString(),					// PAR #31155
									self.tblTotalWeight.getConvertedValue().String,	// PAR #31155
									self.tblLength.getConvertedValue().String,		// PAR #31155
									self.tblVolume.getConvertedValue().String,		// PAR #31155
									self.tblWidth.getConvertedValue().String,		// PAR #31155
									self.tblHeight.getConvertedValue().String,		// PAR #31155
									self.txtQuantity.getString(),
									//self.txtColour.getString(),					// PAR #32331
									null,											// PAR #32331
									self.txtMarkNumber.getString(),
									self.txtYardInstruct.getString(),
									self.txtWidthText.getString(), 
									self.txtHeightText.getString(),
									self.txtLengthText.getString(),
									//self.tblDensity.getString(),					// PAR #31155
									self.tblDensity.getConvertedValue().String,		// PAR #31155
									productAttribute);
	self.unloadForm();
	parentForm.setFocus();	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedControls" id="456aa3bd-1bfd-4989-9888-37dafac844c5">
        <updating/>
        <source>hideSelectedControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwjk3	Initial creation

*/

vars
	product	: CM_Product;
begin
	inheritMethod();
	if self.mySubCargoType &lt;&gt; null then 
		self.doFilterProductAttributes(self.mySubCargoType);
	else
		// try the dummy product for the current cargoType
		if self.myCargoType &lt;&gt; null then
			product := self.myCargoType.mySystemProductType;
			if product &lt;&gt; null then 
				self.doFilterProductAttributes(product);
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isUpdatable" id="fb8a1e59-33aa-46d4-87df-7628218b2963">
        <source>isUpdatable() : Boolean;
// -----------------------------------------------------------------------------
// Created:		15 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myParentForm.isKindOf(CMUI_ReleaseCargoForm) then
		return self.myParentForm.CMUI_ReleaseCargoForm.isVVRUpdatable();
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
