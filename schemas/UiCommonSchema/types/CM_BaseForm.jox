    <JadeMethod name="doTerminalClick" id="3d8f87a6-b311-4905-8354-e1df9cf56ac7">
        <updating/>
        <source>doTerminalClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx							: Integer;
	ut							: CM_UserTerminal;
	user						: CM_User;
	newMenu						: MenuItem;
	sysMenuRoot					: CM_MenuRootForUser;
	userTerminalRoot			: CM_MenuRootUserTerminal;
	rootCounter,
	sysMenuPos					: Integer;
begin

	if self.isTerminalMenuInitialised then
		if global.isValidObject(menuItem.userObject) then
			// clicking a sub-menu
			if menuItem.userObject &lt;&gt; null then
				if menuItem.userObject.isKindOf(CM_MenuUserDtl) then
					menuItem.userObject.CM_MenuUserDtl.doDblClick(null);
				endif;
			endif;
		endif;
		return;
	endif;

	beginLoad;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.mnuTerminalDummy.visible := false;
	
	user := app.getMyUser;
	idx := 1;
	if user = null then
		return;
	endif;
	
	sysMenuRoot := user.myMenuRootForSysEntities;
	if sysMenuRoot &lt;&gt; null then
		sysMenuPos := sysMenuRoot.position;
		if sysMenuPos &lt; 1 or sysMenuPos &gt; user.allUserMenuRoots.size then
			sysMenuPos := user.allUserMenuRoots.size;
		endif;
	endif;
	
	foreach rootCounter in 1 to user.allUserMenuRoots.size do
		//we can't 'insert' the system items menu root - so intercept at correct postion and load it
		if (rootCounter = sysMenuPos) and (sysMenuRoot &lt;&gt; null) then 
			delete self.mnuTerminal.getMenuItem(idx);
			newMenu := self.mnuTerminal.loadSubMenu(idx);
			self.loadMenuItem(sysMenuRoot, idx, newMenu);	
		endif;
		
		userTerminalRoot := user.allUserMenuRoots[rootCounter];
		delete self.mnuTerminal.getMenuItem(idx);
		newMenu := self.mnuTerminal.loadSubMenu(idx);
		self.loadMenuItem(userTerminalRoot, idx, newMenu);
	endforeach;

	self.isTerminalMenuInitialised := true;

epilog
	endLoad;
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
