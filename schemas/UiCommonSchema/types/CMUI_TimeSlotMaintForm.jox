    <JadeMethod name="initControls" id="351ea064-d379-46a0-a8eb-590177096c0e">
        <updating/>
        <source>initControls() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startDate		: Date;
	monthIndex		: Integer;
	newEntryIndex	: Integer;
begin
	self.lblInstruction.left := 5;
	self.cmbMonth.left := 5;
	self.txtYear.left := self.cmbMonth.width + self.cmbMonth.left + 5;
	self.tblCalendar.left := 0;
	
	startDate := self.aStartDate;
	self.tblCalendar.selectedDate := startDate;
	self.cmbMonth.clear;
	foreach monthIndex in 12 to 1 step -1 do
		newEntryIndex	:=	cmbMonth.addItem(("1/" &amp; monthIndex.String &amp; "/" &amp; startDate.year.String).Date.monthName);
		cmbMonth.itemData[newEntryIndex]	:=	monthIndex;
	endforeach;
	cmbMonth.listIndex	:=	cmbMonth.findStringExact(1, startDate.monthName);
	
	txtYear.text := startDate.year.String;
epilog

end;</source>
    </JadeMethod>
