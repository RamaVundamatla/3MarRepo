    <JadeMethod name="doQuery" id="37b6cdb7-2f20-4f32-b518-05ff99790e76">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142
08 Jun 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
*/

vars

	bankSet		 : ObjectSet;
	statusArray  : IntegerArray;
	drSet 		 : ObjectSet;
	crit 		 : CM_SelectorCriteriaLine;
	obj 		 : Object;
	int		     : Integer;
	terminal     : CM_Terminal;
	termSet      : ObjectSet;
	userTermDict : CM_UserTerminalByTerminalDict;
	userTerm 	 : CM_UserTerminal;
	bank 		 : CM_Bank;
	voyCode 	 : String;
	bolCode 	 : String;

begin

	self.reset();
	
	create termSet transient;
	create bankSet transient;
	create statusArray transient;
	create drSet transient;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::myTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			terminal := crit.myQueryOperator.getSearchValue().CM_Terminal;
		endif;
	endif;
	if termSet.isEmpty then
		if terminal &lt;&gt; null then
			termSet.add(terminal);
		else
			userTermDict := app.myPassport.myUser.allUserTerminals;
			foreach userTerm in userTermDict do
				termSet.add(userTerm.getMyTerminal);
			endforeach;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::bank.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(bankSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myBank := crit.myQueryOperator.getSearchValue().CM_Bank;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::getInvStatus.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsIntegerArr(statusArray);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.invoiceStatus := crit.myQueryOperator.getSearchValue().Integer;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::getDebtor.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(drSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myDebtor := crit.myQueryOperator.getSearchValue().CM_Debtor;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::voyageCode.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			voyCode := crit.myQueryOperator.getSearchValue().String;
			if voyCode &lt;&gt; null then
				if terminal &lt;&gt; null then
					self.myVoyage := terminal.allVoyagesByCode.getAtKeyGeq(voyCode,null);
					if self.myVoyage &lt;&gt; null and self.myVoyage.code &lt;&gt; voyCode then
						self.myVoyage := null;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	 //epr par 34860 4/9/14
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::sequenceNum.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.sequenceNum:=crit.myQueryOperator.getSearchValue().Integer;
		endif;
	endif;
	
	//24/02/2023 navmv20 TFS 56403 Task 56404 - start
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::getCategoryInt.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.invCategory :=crit.myQueryOperator.getSearchValue().Integer;
		endif;
	endif;
	//24/02/2023 navmv20 TFS 56403 Task 56404 - end
	
	//24/02/2023 navmv20 TFS 56403 Task 56460- start
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::externalNumber.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Contains then
			self.extNumber :=crit.myQueryOperator.getSearchValue().String;
		endif;
	endif;
	//24/02/2023 navmv20 TFS 56403 Task 56460- end
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::voyageGroupCode.name, _qDef.className];  //03/06/2020 cnwma1 TFS #49400
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_StartsWith then
			self.voyageGroupCode := crit.myQueryOperator.getSearchValue().String;
		endif;
	endif;
	//30 May  2025 navrv30 MTN 34789
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_Invoice::getTrackedItemBOL.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			bolCode := crit.myQueryOperator.getSearchValue().String;
		endif;
		if terminal &lt;&gt; null then
			self.myBOL := terminal.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(BOLType_GeneralBillOfLading, bolCode, null);
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		//small enough collection, just do it.
		self.doSearch();
	
	elseif self.myDebtor &lt;&gt; null then
		if not statusArray.isEmpty then
			foreach int in statusArray do
				self.invoiceStatus := int;
				self.doSearch();
			endforeach;
		elseif not bankSet.isEmpty then
			foreach obj in bankSet do
				self.myBank := obj.CM_Bank;
				self.doSearch();
			endforeach;
		else
			self.doSearch();
		endif;
		
	elseif self.myBank &lt;&gt; null then
		if not drSet.isEmpty then
			foreach obj in drSet do
				self.myDebtor := obj.CM_Debtor;
				self.doSearch();
			endforeach;
		elseif not statusArray.isEmpty then
			foreach int in statusArray do
				self.invoiceStatus := int;
				self.doSearch();
			endforeach;
		else
			self.doSearch();
		endif;
		
	elseif self.invoiceStatus &lt;&gt; -1 then
		if not drSet.isEmpty then
			foreach obj in drSet do
				self.myDebtor := obj.CM_Debtor;
				self.doSearch();
			endforeach;
		elseif not bankSet.isEmpty then
			foreach obj in bankSet do
				self.myBank := obj.CM_Bank;
				self.doSearch();
			endforeach;
		else
			foreach obj in termSet do
				terminal := obj.CM_Terminal;
				foreach bank in terminal.companies do
					bankSet.addNoDuplicates(bank,false);
				endforeach;
			endforeach;
			foreach obj in bankSet do
				self.myBank := obj.CM_Bank;
				self.doSearch();
			endforeach;
		endif;
	
	elseif not bankSet.isEmpty then
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
	else

		foreach obj in termSet do
			terminal := obj.CM_Terminal;
			foreach bank in terminal.companies do
				bankSet.addNoDuplicates(bank,false);
			endforeach;
		endforeach;
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
	
	endif;
	
epilog
	delete bankSet;
	delete statusArray;
	delete drSet;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="50d1a9b6-69d4-4ad2-a0ef-c0e2d3b746c9">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142
08 Jun 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
31 Mar 2023 navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
10/04/2024	navkc1 	CR63383 Task 63384: Jade - Improved invoice queries
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
*/

vars
	iter 	    : Iterator;
	invoice     : CM_Invoice;
	breakOut    : Boolean;
	passport    : CM_Passport;
	startObject : Object;
	isInvListForm: Boolean; //10/04/2024	navkc1 CR63383 Task 63384
begin

	passport := app.myPassport;
	
	//10/04/2024	navkc1 CR63383 Task 63384
	isInvListForm := self.isInContext(self.InvoiceListForm);
	
	 //epr par 34860 4/9/14
	if self.myBank &lt;&gt; null and self.sequenceNum &lt;&gt; null then
		invoice:=self.myBank.allInvoices[self.myBank.terminal,self.myBank,self.sequenceNum];	
		if self.includesObject(invoice, breakOut, passport) then
			self.addObjectToSet(invoice);
		endif;
		return;
	endif;
	
	//30 May  2025 navrv30 MTN 34789
	if self.myBOL &lt;&gt; null then
		if isInvListForm then
				self.removeCritLine(CM_Invoice::getCargoSite.name, CM_Invoice.name);
		endif;
		iter := self.myBOL.allInvoices.createIterator;
		while iter.next(invoice) do
			if self.includesObject(invoice, breakOut, passport) then
				self.addObjectToSet(invoice);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
	elseif self.myVoyage &lt;&gt; null then
		//voyage known.
		iter := self.myVoyage.allInvoices.createIterator;
		while iter.next(invoice) do
			if self.includesObject(invoice, breakOut, passport) then
				self.addObjectToSet(invoice);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
				
	elseif self.myDebtor &lt;&gt; null then
		if self.myBank &lt;&gt; null then
			//10/04/2024	navkc1 CR63383 Task 63384
			if isInvListForm then
				// We are getting the collection from the bank, don't need criteria line to match the bank &amp; terminal again
				self.removeCritLine(CM_Invoice::bank.name, CM_Invoice.name);
				self.removeCritLine(CM_Invoice::myTerminal.name, CM_Invoice.name);
			endif;
			//bank and debtor known.
			iter := self.myBank.invoicesByDebtor.createIterator;
			startObject := self.myBank.invoicesByDebtor.getAtKeyGeq( self.myDebtor );
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next(invoice) do
					if invoice.debtor &lt;&gt; self.myDebtor then
						break;
					endif;
					if self.includesObject(invoice, breakOut, passport) then
						self.addObjectToSet(invoice);
					endif;
					if breakOut	or self.breakOutOfSearch then
						break;
					endif;
				endwhile;
			endif;
		
		elseif self.invoiceStatus &lt;&gt; -1 then
			//status and debtor known.
			iter := self.myDebtor.invoicesByStatus.createIterator;
			startObject := self.myDebtor.invoicesByStatus.getAtKeyGeq( self.invoiceStatus );
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next(invoice) do
					if invoice.status &lt;&gt; self.invoiceStatus then
						break;
					endif;
					if self.includesObject(invoice, breakOut, passport) then
						self.addObjectToSet(invoice);
					endif;
					if breakOut	or self.breakOutOfSearch then
						break;
					endif;
				endwhile;
			endif;
			
		else
			//just debtor known
			iter := self.myDebtor.allInvoices.createIterator;
			while iter.next(invoice) do
				if self.includesObject(invoice, breakOut, passport) then
					self.addObjectToSet(invoice);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endwhile;
		
		endif;
	
	elseif self.voyageGroupCode &lt;&gt; null then			//03/06/2020 cnwma1 TFS #49400
		if self.myBank &lt;&gt; null then
			//10/04/2024	navkc1 CR63383 Task 63384
			if isInvListForm then
				// We are getting the collection from the bank, don't need criteria line to match the bank &amp; terminal again
				self.removeCritLine(CM_Invoice::bank.name, CM_Invoice.name);
				self.removeCritLine(CM_Invoice::myTerminal.name, CM_Invoice.name);
			endif;
			iter 	    := self.myBank.allInvoicesByVoyageGroupCode.createIterator;
			startObject := self.myBank.allInvoicesByVoyageGroupCode.getAtKeyGeq( self.voyageGroupCode );
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next(invoice) do
					if self.includesObject(invoice, breakOut, passport) then
						self.addObjectToSet(invoice);
					endif;
					if breakOut	or self.breakOutOfSearch then
						break;
					endif;
				endwhile;
			endif;
		endif;
	elseif self.myBank &lt;&gt; null then
		//10/04/2024	navkc1 CR63383 Task 63384
		if isInvListForm then
			// We are getting the collection from the bank, don't need criteria line to match the bank &amp; terminal again
			self.removeCritLine(CM_Invoice::bank.name, CM_Invoice.name);
			self.removeCritLine(CM_Invoice::myTerminal.name, CM_Invoice.name);
		endif;
		if self.invoiceStatus &lt;&gt; -1 then
			//24/02/2023	navmv20 TFS 56403 Task 56404 - start
			if self.invCategory &lt;&gt; -1 then
				iter := self.myBank.allInvoicesByCategoryStatus.createIterator;
				startObject := self.myBank.allInvoicesByCategoryStatus.getAtKeyGeq(self.invCategory,self.invoiceStatus);
				if startObject &lt;&gt; null then
					iter.startAtObject( startObject );
					while iter.next(invoice) do
						if invoice.status &lt;&gt; self.invoiceStatus then
							break;
						endif;
						if invoice.category &lt;&gt; self.invCategory then
							break;
						endif;
						if self.includesObject(invoice, breakOut, passport) then
							self.addObjectToSet(invoice);
						endif;
						if breakOut	or self.breakOutOfSearch then
							break;
						endif;
					endwhile;
				endif;
			else
			//24/02/2023	navmv20 TFS 56403 Task 56404 - end
			//status and bank known.
				iter := self.myBank.invoicesByStatus.createIterator;
				startObject := self.myBank.invoicesByStatus.getAtKeyGeq( self.invoiceStatus );
				if startObject &lt;&gt; null then
					iter.startAtObject( startObject );
					while iter.next(invoice) do
						if invoice.status &lt;&gt; self.invoiceStatus then
							break;
						endif;
						if self.includesObject(invoice, breakOut, passport) then
							self.addObjectToSet(invoice);
						endif;
						if breakOut	or self.breakOutOfSearch then
							break;
						endif;
					endwhile;
				endif;
			endif; //24/02/2023	navmv20 TFS 56403 Task 56404
		else
			//just bank known
			iter := self.myBank.allInvoices.createIterator;
			while iter.next(invoice) do
				if self.includesObject(invoice, breakOut, passport) then
					self.addObjectToSet(invoice);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endwhile;
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="8a027500-02c8-497c-82af-521ca0872161">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142
22-05-2023  navtnr20 Bug 58091: FR | EUP 54086 - Invoicing Maintenance enhancements - Invoice / Credit note search
*/

vars

begin
	inheritMethod();
	
	self.myBank := null;
	self.myDebtor := null;
	self.invoiceStatus := -1;
	self.myVoyage := null;
	self.sequenceNum:=null; //epr par 34860 4/9/14
	self.invCategory := -1;	//navtnr20 22-05-2023 58091 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="093400f6-8ccf-478e-844e-749a06b664fe">
        <updating/>
        <source>setMyFilterClass() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	self.myFilterClass := CM_Invoice;

epilog

end;</source>
    </JadeMethod>
</Class>
