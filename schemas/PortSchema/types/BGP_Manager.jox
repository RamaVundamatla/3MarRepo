    <JadeMethod name="doClearAllRequests" id="dc5ebfd6-b8d0-4335-8f39-3c897adb989c">
        <source>doClearAllRequests(_controller : BGP_Controller input);

// cnwdvb1 17 January 2003 

vars

	tmpClass	: Class;
	request		: Object;
	className	: String;
	msg : String;
begin
	foreach className in _controller.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		if tmpClass = null then
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error clearing requests ' &amp; className &amp; 
					'. Request class not found' , null, null, null, true, true);	
			continue;
		endif;
		foreach request in tmpClass.instances do
			app.myTrxDA.trxDeleteBGPRequest(self, request.BGP_Request, false, app.myPassport);
		endforeach;
		app.myTrxUA.trxUpdateBGPControllerSDSTerm(_controller, false);
		msg := 'INFO &gt;&gt; Clearing requests for class ' &amp; tmpClass.name;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endforeach;
end;</source>
        <Parameter name="_controller" type="BGP_Controller" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doClearSingleRequest" id="ce0b2913-b6ad-4165-aa46-315190ca33c5">
        <source>doClearSingleRequest(_request : BGP_Request io) : String;

// cnwdvb1 17 February 2003 

vars


begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	app.myTrxDA.trxDeleteBGPRequest(self, _request, false, app.myPassport);
	if app.myPassport.trxCompletedOK then
	else
		return app.myPassport.getErrorsAsString();
	endif;

	return null;
end;</source>
        <Parameter name="_request" type="BGP_Request" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doShowLogName" id="03ad01bf-d204-4349-a112-022a0367f593">
        <source>doShowLogName(_process : Process) protected;
//----------------------------------------------------------------
//	Created:	11 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	alert		: CM_SystemAlert;
	extraDetail,
	detail		: String;
begin
	
	create alert;
	detail := "Log information for BGPManager " &amp; self.name;
	alert.details := detail;
	
	alert.setSeverity(SEVERE_INFO);

	extraDetail := self.machineName &amp; " " &amp; app.getLogFilename();

	alert.addLogEntry(extraDetail);
	
	alert.add;
	app.commitAlert();
	self.sendCallBackMsg(_process, detail &amp; CrLf &amp; extraDetail);
//	self.causeEvent(BGP_Object.BGP_CallBackMsg, true, detail &amp; ',' &amp; _process.getOidString);
	
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
    <JadeMethod name="findRunningController" id="97f1c5a0-ce61-4d8d-8251-6c183a8b1e30">
        <source>findRunningController() : BGP_Controller;
// -------------------------------------------
// Created 10 August 2004 by cnwdvb1
// -------------------------------------------
vars

	controller : BGP_Controller;

begin

	foreach controller in self.allBGPControllers do
		if controller.isRunning() and
		   not global.isValidObject(controller.myCurrentRequest) then
			return controller;
		endif;
	endforeach;
	//app.raiseCMException1(Full_Replacement_Message,app.getErrorString(Cannot_Locate_Free_Controller) , null, null); //- cnwmd1, Par 20524
	app.raiseCMException(Cannot_Locate_Free_Controller, null, null); //+ cnwmd1, Par 20524
	return null;

end;</source>
        <ReturnType type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="finish" id="a382c250-3a5b-4e0e-987a-838a0391ecf8">
        <updating/>
        <source>finish() updating;

// cnwdvb1 19 November 2002 

// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification

vars

begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	app.exitLogFile();
	if not app.isBGPAppAbort then
		if not app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011
	//	self.stopAllBackGroundApps();
			app.myTrxUA.trxUpdateBGPManagerProcess(self, null, null, app.myPassport);
		endif;
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="35fa3767-2cd3-4ee5-bff7-03164b11b2fd">
        <source>getDisplay() : String;

// cnwdvb1 24 October 2002 

vars

	server : String;

begin

	if self.isRunOnServer then
		server := '(Server)';
	endif;

	return Tab &amp; Tab &amp; self.name &amp; server &amp; Tab &amp; Tab &amp; self.machineName &amp; Tab &amp; self.startTime.bgpDisplay();	// CCMS1150 cnwrs1 04 July 2011
//	 &amp; Tab &amp;	 Tab &amp; Tab &amp; Tab &amp; self.isRunning.asRunningStopped(true);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="2299c0d7-3f20-47ba-a11f-595cc0831d61">
        <source>getName() : String;

vars
	
begin
	return inheritMethod() &amp; Tab &amp; self.name.padBlanks( 30 ) &amp; Tab &amp; self.creationTime.cnEcShortFullFormat;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initManager" id="eb150ab4-ff09-4692-a850-77fdfd4d0b1b">
        <updating/>
        <source>initManager() updating;

vars

	error			: Integer;
	ls, found		: Boolean;
	str,str2,str3,
	machName,
	errorText		: String;
	huge			: HugeStringArray;
	msg : String;
begin
	
//	on Exception do app.alertExceptionHandler(exception, null, null, error, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPManager_' &amp; self.name &amp; '_' &amp; str;
	app.initialize();
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	app.setIsBackGroundApp(true);
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(app.myRoot.allUsers["SUPERUSER"]);
 	endif;
	
	app.cmsBeginLoad(ls);
	exclusiveLock(self);

	if self.isRunning then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running' ;
		app.writeLog(msg, LogFATAL);		//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		app.myBGPObject := null;
		terminate;
		return;
	endif;
	
	if not self.isRunOnServer then
		if self.machineNameSpecific &lt;&gt; null then
			if not node.isApplicationServer then
				create huge transient;
				self.machineNameSpecific.parseCSV(huge);
				machName := app.computerName;
				foreach str2 in huge do
					if machName.toUpper() = str2.trimBlanks().toUpper() then
						found := true;
						break;
					endif;
				endforeach;
			endif;
			if not found then
				str3 := app.getErrorString2(InvalidMachine, self.name, self.machineNameSpecific);
				msg := 'Error (' &amp; str3 &amp; ') - Terminating';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				self.sendCallBackMsg(null, str3);
	//			self.causeEvent(BGP_Object.BGP_CallBackMsg, true, str3);
				app.remoteErrorWarningToAlert('ERROR &gt;&gt; ' &amp; str3, null, null, null, false, false);
				terminate;
			endif;
		else
			if node.isApplicationServer and self.isManagedService then
				str3 := app.getErrorString1(ManagedServiceOnly, self.name);
				msg := 'Error (' &amp; str3 &amp; ') - Terminating';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				self.sendCallBackMsg(null, str3);
	//			self.causeEvent(BGP_Object.BGP_CallBackMsg, true, str3);
				app.remoteErrorWarningToAlert('ERROR &gt;&gt; ' &amp; str3, null, null, null, false, false);
				terminate;
			endif;
		endif;
	endif;
	
	app.myTrxUA.trxUpdateBGPManagerProcess(self, process, process.signOnTime, app.myPassport);
	
	// Begin notifications here.
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.startAllBackGroundApps();
	self.causeEvent(BGP_Object.BGP_TerminateAppRequest, true, null);
	
epilog
	app.cmsEndLoad(ls);
	delete huge;
end;</source>
    </JadeMethod>
