    <JadeMethod name="hideShow" id="e6fecea5-faf9-450f-a77d-08572a002c73">
        <source>hideShow() protected;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.chkArrivals.value then
		self.tblEntry.showRowByName(ETRow_ArrivalsDateFrom, false);
		self.tblEntry.showRowByName(ETRow_ArrivalsTimeFrom, false);
		self.tblEntry.showRowByName(ETRow_ArrivalsDateTo, false);
		self.tblEntry.showRowByName(ETRow_ArrivalsTimeTo, false);
	else
		self.tblEntry.hideRowByName(ETRow_ArrivalsDateFrom, false);
		self.tblEntry.hideRowByName(ETRow_ArrivalsTimeFrom, false);
		self.tblEntry.hideRowByName(ETRow_ArrivalsDateTo, false);
		self.tblEntry.hideRowByName(ETRow_ArrivalsTimeTo, false);
	endif;
	
	if self.chkDeparted.value then
		self.tblEntry.showRowByName(ETRow_DepartedDateFrom, false);
		self.tblEntry.showRowByName(ETRow_DepartedTimeFrom, false);
		self.tblEntry.showRowByName(ETRow_DepartedDateTo, false);
		self.tblEntry.showRowByName(ETRow_DepartedTimeTo, false);
	else
		self.tblEntry.hideRowByName(ETRow_DepartedDateFrom, false);
		self.tblEntry.hideRowByName(ETRow_DepartedTimeFrom, false);
		self.tblEntry.hideRowByName(ETRow_DepartedDateTo, false);
		self.tblEntry.hideRowByName(ETRow_DepartedTimeTo, false);
	endif;
	
	if self.chkInPort.value then
		self.tblEntry.showRowByName(ETRow_InPortDateFrom, false);
		self.tblEntry.showRowByName(ETRow_InPortTimeFrom, false);
		self.tblEntry.showRowByName(ETRow_InPortDateTo, false);
		self.tblEntry.showRowByName(ETRow_InPortTimeTo, false);
	else
		self.tblEntry.hideRowByName(ETRow_InPortDateFrom, false);
		self.tblEntry.hideRowByName(ETRow_InPortTimeFrom, false);
		self.tblEntry.hideRowByName(ETRow_InPortDateTo, false);
		self.tblEntry.hideRowByName(ETRow_InPortTimeTo, false);
	endif;
	
	self.tblEntry.resetSize();


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initReport" id="920923ca-eb01-4f22-9f39-da639a8340cb">
        <updating/>
        <source>initReport()protected, updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
/*PAR 9556
In Port From 	:= Today
In Port To		:= Today 
Departed From	:= Two weeks ago today
Departed To		:= Today 
Arrivals From	:= Today 
Arrivals To		:= A month from today*/

vars

	now		: TimeStamp;
	date	: Date;
	time	: Time;

begin

	now := app.actualTimeServer;
	date := now.date;
	time := '00:00'.Time;
	// set the defaults for the report
	self.tblEntry.setValueByName(ETRow_InPortDateFrom, date.shortFormatJMT());
//	self.txtInPortDFrom.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_InPortTimeFrom, time.shortFormatJMT());
//	self.txtInPortTFrom.setTime(time);
	
	self.tblEntry.setValueByName(ETRow_InPortDateTo, date.shortFormatJMT());
//	self.txtInPortDTo.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_InPortTimeTo, time.shortFormatJMT());
//	self.txtInPortTTo.setTime(time);

	self.tblEntry.setValueByName(ETRow_DepartedDateTo, date.shortFormatJMT());
//	self.txtDepartDTo.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_DepartedTimeTo, time.shortFormatJMT());
//	self.txtDepartTTo.setTime(time);

	self.tblEntry.setValueByName(ETRow_ArrivalsDateFrom, date.shortFormatJMT());
//	self.txtArriveDFrom.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_ArrivalsTimeFrom, time.shortFormatJMT());
//	self.txtArriveTFrom.setTime(time);		
	
	date := date - 14;
	self.tblEntry.setValueByName(ETRow_DepartedDateFrom, date.shortFormatJMT());
//	self.txtDepartDFrom.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_DepartedTimeFrom, time.shortFormatJMT());
//	self.txtDepartTFrom.setTime(time);
	
	date	:= now.Date;
	date	:= 	date + 28;
	self.tblEntry.setValueByName(ETRow_ArrivalsDateTo, date.shortFormatJMT());
//	self.txtArriveDTo.setTextFromDate(date);
	self.tblEntry.setValueByName(ETRow_ArrivalsTimeTo, time.shortFormatJMT());
//	self.txtArriveTTo.setTime(time);
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTable" id="c777ff6d-27de-4929-869b-616598a50b66">
        <source>initTable() protected;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
vars

	entTableControl : EntTableDef;

begin
	inheritMethod();
	entTableControl := app.myController.getEntTableDef(ETDef_ShippingReport);
	self.tblEntry.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
//	self.tblEntry.resetSize();
	self.tblEntry.optimiseHeadingColumn();
	self.setColorsForEntryTable(self.tblEntry);

end;</source>
        <access>protected</access>
    </JadeMethod>
