    </ImplicitInverseRef>
    <ImplicitInverseRef name="optDiscard" id="f97e9c2b-3a87-4ae2-a835-7bc009a7659b">
        <embedded/>
        <type name="OptionButton"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optSaveWB" id="be230f31-f6d9-4582-b97a-db52a16619e1">
        <embedded/>
        <type name="OptionButton"/>
    </ImplicitInverseRef>
    <JadeMethod name="setProcessingParameters" id="ec1a6a1c-bc47-47ca-93e4-47c38962de55">
        <updating/>
        <source>setProcessingParameters() updating;

/*****************************************************
	Written by	:	cnwgrp1		11 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if optDiscard.value = true then
		if myDA.isNew then
			app.msgBox('This is a new workbook so you must save the workbook to continue or cancel', 'Next',
								MsgBox_OK_Only);
			blnError := true;
			return;
		endif;
	endif;
	
	myDA.setBlnSaveWorkbookDefn(optSaveWB.value);

epilog

end;</source>
    </JadeMethod>
</GUIClass>
