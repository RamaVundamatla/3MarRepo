    <JadeMethod name="getAllResourceUsageAsString" id="c4c7e049-141d-4f49-be41-c40cbce786b5">
        <source>getAllResourceUsageAsString(): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		18 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 18/03/2010 	cnwsh3		CCMS MES 1006 - Make resource usage available through CICs.
//----------------------------------------------------------------------
vars
	resourceUsage : CM_ResourceTypeUsage;
	str : String;
	firstTime : Boolean;
begin
	firstTime := true;
	foreach resourceUsage in self.allResourceUsages do
		if resourceUsage.myResourceType &lt;&gt; null then
			if firstTime then
				str := resourceUsage.myResourceType.code;
				firstTime := false;
			else
				str := str &amp; ', ' &amp; resourceUsage.myResourceType.code;
			endif;
		endif;
	endforeach;
	return str;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
