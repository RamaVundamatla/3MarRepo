    <JadeMethod name="getStopCompletionFreeDays" id="256152f9-3297-4392-a539-9db1ad184929">
        <source>getStopCompletionFreeDays( _startDate : Date ) : Integer;
// 24/08/2016 cnwjre1  TFS 2570
// 28 Sep 2017	NDL	TFS 7185 - Provide extra fee days config around stop removal.
vars

	endDate : Date;
	freeDays : Integer;
	completionType : Integer;
	workCal : CM_Calendar;
	compCal : CM_Calendar;
	testDate : Date;
	numChargeDays : Integer;
	calendarDate : CM_CalendarDate;
	extraDaysFree : Integer;

begin

	freeDays := self.stopCompletionFreeDays;
	completionType := self.freeDaysType;  // yep, at the moment we are using the same config for both.
	
	if completionType = Calendar_Months then
		endDate := _startDate.addMonths( self.stopCompletionFreeDays );
		freeDays := endDate - _startDate;
		return freeDays;
		
	elseif completionType = Calendar_Days then
		freeDays := self.stopCompletionFreeDays;
		return freeDays;
		
	elseif completionType = Working_Days then
		endDate := _startDate + self.stopCompletionFreeDays;
		workCal := self.myStorageConfig.myWorkingDaysCalendar;
		
	elseif completionType = Working_Compulsory_Days then
		endDate := _startDate + self.stopCompletionFreeDays;
		workCal := self.myStorageConfig.myWorkingDaysCalendar;
		compCal := self.myStorageConfig.getMyCompulsoryCalendar;
		
	endif;
	
	if workCal &lt;&gt; null or compCal &lt;&gt; null then
	
		testDate := _startDate - 1; // increments as soon as it starts
		
		while true do
			testDate := testDate + 1;
			
			calendarDate := null;
			if workCal &lt;&gt; null then
				calendarDate := workCal.getFirstCalendarDateForDay(testDate); // check for a weekend date in the first week (mon-sunday week)
			endif;
			if calendarDate = null and compCal &lt;&gt; null then
				calendarDate := compCal.getFirstCalendarDateForDay(testDate); // check for any compulsory day in the period
			endif;
			if calendarDate &lt;&gt; null then	// weekend or compulsory day
				extraDaysFree := extraDaysFree + 1;
			else
				numChargeDays := numChargeDays + 1;
			endif;
			if numChargeDays &gt;= freeDays then
				if ( workCal &lt;&gt; null and workCal.getFirstCalendarDateForDay(testDate + 1) &lt;&gt; null )
				or ( compCal &lt;&gt; null and compCal.getFirstCalendarDateForDay(testDate + 1) &lt;&gt; null )
				then
					//while the next day is a holiday/weekend we will want to count that too, so carry on.
					continue;
				endif;
				break;
			endif;
		endwhile;
	
		freeDays := freeDays + extraDaysFree;
	
	endif;
	
	return freeDays;
	
end;
</source>
        <Parameter name="_startDate" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
