    <JadeMethod name="tableOptionsDetailsPopulate" id="ce1ead02-e711-4150-a247-e2defcc433c0">
        <source>tableOptionsDetailsPopulate() protected;
// --------------------------------------------------------------------------------
// Created:		11 February 2006 by cnwdad1
//
// Purpose:		Populate the table on the Options tab with session details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04 Mar 2008	cnwkpd1		PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
// --------------------------------------------------------------------------------

vars
	tableObj	: MB_TableNamedCols;
	columnObj	: JadeTableColumn;
	canScroll	: Boolean;
	
begin
	tableObj					:=	tblOptionsDetail;
	tableObj.rows				:=	0;
	tableObj.partialTextIndication	:=	true;
	tableObj.gridLines			:= false;

	columnObj					:=	tableObj.accessColumn(1);
	columnObj.widthPercent		:=	40;
	columnObj					:=	tableObj.accessColumn(2);
	columnObj.fontBold			:=	true;
	
	tableObj.defaultRowHeight	:= 40;
	
	tableObj.readOnly			:= true;
	tableObj.addNamedRow(self.TableRow_UserName, txtUserName.text.trimBlanks());
	tableObj.addNamedRow(self.TableRow_Device, self.aDevice);
	tableObj.addNamedRow(self.TableRow_Machine, self.aMachineCode);
	tableObj.addNamedRow(self.TableRow_PrimaryQueue, self.aPrimaryQueueId);		// PAR #16010

	tableObj.addNamedRow(self.TableRow_Terminal, self.aTerminal);
	
	canScroll					:=	tableObj.mbCanScroll();
	btnPUDetails.visible		:=	canScroll;
	btnPDDetails.visible		:=	canScroll;
end;</source>
        <access>protected</access>
    </JadeMethod>
