    <JadeMethod name="cmbBUs_click" id="c9807efd-3db1-4ee9-aa1f-57a64c23dd34">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBUs_click(combobox: ComboBox input) updating;
// 35872 on change, update the Next Invoice Number from this bank
vars
	bank	: CM_Bank;
	keyseries		:  CM_KeySeries;
	serieskey		:  CM_SeriesKey;
	rowHeading		: String;
	pos,
	nextInvNum,
	idx				: Integer;
	
begin
	// 35872 uses the selected business unit now
	
	/* TFS 39618
	bank := combobox.listObject.CM_Bank;
	if bank &lt;&gt; null then
		keyseries := bank.keySeries[SN_INVOICE];
		serieskey := keyseries.nextKey;
		nextInvNum := serieskey.root;
	
		idx := self.tblDataEntry.getRowByName(ETRow_NextInvoiceNumber);
		// refresh the row heading with the new business code
		rowHeading := self.tblDataEntry.accessCell(idx,1).text;
		pos := rowHeading.pos(" ", 1);
		if pos &gt; 1 and pos &lt; rowHeading.length then
			rowHeading := rowHeading[pos+1:end];
		endif;
		self.tblDataEntry.accessCell(idx,1).text := bank.code &amp; " " &amp; rowHeading;
		self.tblDataEntry.setValueByName(ETRow_NextInvoiceNumber, nextInvNum);
		self.setCaption("Invoice Configuration" &amp; " " &amp; bank.code); //	TFS 2682
	endif;
	*/
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
