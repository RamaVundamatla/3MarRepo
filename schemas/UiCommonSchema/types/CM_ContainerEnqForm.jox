    <JadeMethod name="doMenuCreateWO" id="47858590-dbdb-4686-aae5-be6c0a9725f6">
        <source>doMenuCreateWO();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2022 navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
16 Mar 2023 navdp20 Defect 57097: MTN - 1090 exception when creating a work order using cargo enquiry screen
*/

constants
	FORMNAME         : String = 'YRD_WorkOrder';
vars
	workOrderForm	 : CM_BaseForm;
	subSystem	 	 : CMUI_SubSystem;
	formName	 	 : String;
	assistantClass,	
	formClass		 : Class;
	tiArray			 : CM_TIArray; 
	isHasTask		 : Boolean;
begin
	
	app.mousePointer := MousePointer_HourGlass;
	
	subSystem := app.myController.allSubSystems['YardSchema'];	
	
	if subSystem = null then
		return;
	endif;
	
	subSystem.getFormDetails(FORMNAME, formClass, assistantClass);	

	workOrderForm := app.loadForm(formClass, assistantClass, false, false, false, self.myTerminal, null).CM_BaseForm;
	
	if workOrderForm = null then
		return;
	endif;
	
	workOrderForm.centreWindow;
	workOrderForm.setWorkOrderMode(1);		//Add Mode
	workOrderForm.setWorkOrderType( WorkOrderMode_Cargo);
	workOrderForm.setMyTerminal(self.myTerminal);
	workOrderForm.show;
	
	app.mousePointer := MousePointer_Default;					//16.03.2023 navdp20 #57097
	isHasTask := workOrderForm.addWONewTask();     				//16.03.2023 navdp20 #57097
	
	if not isHasTask then										//21.03.2023 navhl20 #57097
		workOrderForm.unloadForm();
		return;
	endif;
	
	create tiArray transient;
	self.tblData.allSelectedObjects.copy(tiArray);
	workOrderForm.IF_CMUI_TrackedItems.saveSelectedTrackedItems(tiArray);
epilog
	app.mousePointer := MousePointer_Default;
	delete tiArray;
end;</source>
    </JadeMethod>
