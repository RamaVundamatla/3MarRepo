    <JadeMethod name="initTableDataCommon" id="0f949a6d-bab9-448a-8c73-17bcd58e102b">
        <source>initTableDataCommon(_tbl : CM_DataTable input; _entDef : String) protected;
// ---------------------------------------------------------------------------
