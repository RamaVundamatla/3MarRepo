    <JadeMethod name="setCustomDocTypeColor" id="1769009f-c3e8-4ece-858f-0c2cafb329a3">
        <source>setCustomDocTypeColor(_updController : CnEcReleaseController);
/*

Purpose:			
		This script will be all instances in CM_CustomDocumentType.colour to WHITE 
			
Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour

*/

vars
	custDocType	: CM_CustomDocumentType;
	allDocTypes	: ObjectArray;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Setting Custom Document Type colour to White", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Setting Custom Document Type colour to White") ;	
	endif;
	
	create allDocTypes transient;
	CM_CustomDocumentType.allInstances(allDocTypes, 0, true);
	
	beginTransaction;
	
	foreach custDocType in allDocTypes as CM_CustomDocumentType do
		
		custDocType.setPropertyValue(CM_CustomDocumentType::colour.name, White);
		
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed setting Custom Document Type colour to White", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed setting Custom Document Type colour to White") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete allDocTypes;
end;</source>
