/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation

*/

vars
	criteria : CM_YACriteria;	
begin
	
	if self.useVoyageAllocations  then 
		// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Product);
		criteria := self.getAttrByType(YACriteriaType_Product); // PAR 23263 
		if criteria &lt;&gt; null then
			return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Product;			
		endif;
	else
		return self.myCargoSubtype;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_Product"/>
