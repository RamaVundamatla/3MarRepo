    <JadeMethod name="asXMLMessage" id="7df7d5e8-b2f3-4079-afaa-d2f09c2af603">
        <source>asXMLMessage():String abstract;
// --------------------------------------------------------------------------------
// Created:		05 February 2009 by cnwdad1
//
// Purpose:		Taking the receiver, this method will return the data as an XML
//				message.
//
// Parameters:	None
//
// Returns:		The XML message, or null.
//
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetXML" id="c38e1f5f-8f4e-4e2d-b1c7-61e5ecdd9988">
        <source>cnEcGetXML():String;
// --------------------------------------------------------------------------------
// Created:		07 October 2006 by cnwdad1
//
// Purpose:		Returns the receiver's XML string, including any tags contained
//				within.
//
// Parameters:	None
//
// Returns:		The XML string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlString	: String;
	
begin
	xmlString	:=	"&lt;" &amp; self.tagName;
	
	if self.tagAttribute &lt;&gt; null then
		xmlString	:=	xmlString &amp; " " &amp; self.tagAttribute;
	endif;
	
	xmlString	:=	xmlString &amp; "&gt;" &amp; self.tagData.cnEcAsXml &amp;
					"&lt;/" &amp; self.tagName &amp; "&gt;";
	
	return xmlString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
