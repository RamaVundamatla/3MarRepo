    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9f28e0fb-16e6-45f7-a5da-62e73213fe4a">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;

vars
	pxyTi: CM_TrackedItem;
	information : StringArray512;
begin
	//	19/2/19 MAP TFS43243
	pxyTi := pTI;
	if pxyTi.isContainer() and _tiTransCntrl.bulkCompleteContainer then

		pxyTi.setContentsStatus(TI_CONTENTS_STATUS_EMPTY); // 7/9/22 	jlier1	TFS 54700
		pxyTi.setImExStatus(TI_IMEX_STATUS_STORAGE);

		create information transient;
		information.addTruncated("Terminal Configuration 'Bulk Pack/Unpack Complete Transaction Container Processing'"); // TFS 41613
		information.addTruncated("ImEx and Contents Status automatically changed to " &amp; app.getErrorString(Storage).toUpper() &amp; " and " &amp; app.getErrorString(Empty).toUpper()); // TFS 41613
		pxyTi.createInfomationTransaction("Automatic Status Change", information, null, app.myPassport);
	endif;

	inheritMethod(pTI, _tiTransCntrl);
	//self.location := pTI.locationId[1:20];
	//cnwjo3 par 20707
	self.location := pTI.locationId;
epilog
	delete information;
end;
</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="c67b683d-c84a-49d7-9bf8-b271ab97e8e5">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		7 August 2009 by cnwjo3
//
// Purpose:		Creating updateTI so that when this transaction occurs we can set the
//				ti's unpackDT.  Originally it was set in CM_Unpack but now in CM_Unpack
//				it only sets the unpackDT for the child item, not parent
//				par 20271
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 17/11/2014	cnwdap1		PAR #35051 On Unpack Complete, see if we have a Work Order for unpacking
// 27/03/2023 	navma1 		ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
vars
	tmpTI		: CM_TrackedItem;
	wo			: CM_WorkOrder;				// PAR #35051
	woTask		: CM_WorkOrderDtl;			// PAR #35051
	woUnpack	: CM_WodUnpack;				// PAR #35051
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925
	
	tmpTI := self.myTrackedItem;
	
	if tmpTI = null then
		return;
	endif;
	
	tmpTI.setUnpackedDT(self.dateTime);
	
	// PAR #35051 If the TI is the only TI on the work order, and it has an	// PAR #35051
	// unpack task, complete the unpack task								// PAR #35051
	if not tmpTI.allWorkOrders.isEmpty then									// PAR #35051
		foreach wo in tmpTI.allWorkOrders discreteLock do					// PAR #35051
			if wo.CM_WorkOrderTI.allTIs.size &lt;&gt; 1 then						// PAR #35051
				continue;													// PAR #35051
			endif;															// PAR #35051
			foreach woTask in wo.allWoDtls do								// PAR #35051
				if woTask.detailType = WO_TASK_UNPACK then					// PAR #35051
					// complete the task									// PAR #35051
					woUnpack := woTask.CM_WodUnpack;						// PAR #35051
					woUnpack.setTIActioned(tmpTI, true);					// PAR #35051
					woUnpack.setTIComplete(tmpTI,null);						// PAR #35051	//27.03.2023 navma1 #56614:[56615]
				endif;														// PAR #35051
			endforeach;														// PAR #35051
		endforeach;															// PAR #35051
	endif;																	// PAR #35051
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
