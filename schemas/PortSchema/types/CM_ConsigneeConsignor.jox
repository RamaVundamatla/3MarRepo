    <JadeMethod name="hasStockOrders" id="6f3134f6-7b65-406d-932a-62ffb7877afa">
        <source>hasStockOrders() : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerminal		: CM_Terminal;
	needBeginLoad	: Boolean;
	tmpStkOrder		: CM_StockOrderHeader;
	tmpCode			: String;
	rtnValue		: Boolean;
	iterTerm,
	iterStkOrder	: Iterator;
	cnt				: Integer;
begin

	needBeginLoad := process.isInLoadState;
	if needBeginLoad then
		endLoad;
	endif;

	tmpCode := self.code;
	
	iterTerm := app.myRoot.allTerminals.createIterator;
	
	while iterTerm.next(tmpTerminal) do
		beginLoad;
		iterStkOrder := tmpTerminal.allStockOrderHeaders.createIterator;
		while iterStkOrder.next(tmpStkOrder) do
			if tmpStkOrder.hasDetailsForConsignee(tmpCode) then
				rtnValue := true;
				break;
			endif;
			cnt := cnt + 1;
			if cnt mod 100 = 0 then
				endLoad;
				beginLoad;
			endif;
		endwhile;
		endLoad;
		delete iterStkOrder;
	endwhile;

	return rtnValue;

epilog
	endLoad;
	delete iterStkOrder;
	delete iterTerm;
	if needBeginLoad then
		beginLoad;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
