    <JadeMethod name="setIntFaceObjectTemperature" id="1eccb0c1-6906-42e3-b3b0-0aa76f7a9397">
        <source>setIntFaceObjectTemperature(pIntFaceObject : CMIF_TIObject io; pTblMain, pTblExtra : CM_EntryTable input; 
							pFieldName : String; pUseFarenheit : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	
begin

	tmpStr := self.mainExtraGetValue(pTblMain, pTblExtra, pFieldName).String;
	if tmpStr.trimRight = null then
		if pUseFarenheit then
			pIntFaceObject.setPropertyValue(pFieldName, app.temperatureConversion(true, NULL_TEMPERATURE));
		else
			pIntFaceObject.setPropertyValue(pFieldName, NULL_TEMPERATURE);
		endif;
	else
		pIntFaceObject.setPropertyValue(pFieldName, tmpStr.Real);
	endif;
	
end;</source>
        <Parameter name="pIntFaceObject" type="CMIF_TIObject" usage="io"/>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pUseFarenheit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLoadingContractor" id="be71844b-08e0-4475-8cd6-446835cbd28a">
        <source>setLoadingContractor(_sheet : GTE_Sheet; _operator : CM_Operator);
//--------------------------------------------------------------
//Created: 13 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpCodeGroup	: CM_CodesByCodeDict;
	tmpCmb			: GTE_ComboBox;
begin
	tmpCmb	:= _sheet.getControlByName(GTE_InOutForm.Cntrl_cmbHdlCntr2).GTE_ComboBox;
	if _operator = null then
		self.comboBoxHdlCntr2(tmpCmb, null, null);
		return;
	endif;
	tmpCodeGroup := _operator.getAllLoadingContractors();
	if tmpCodeGroup = null then
		return;
	endif;

	self.comboBoxHdlCntr2(tmpCmb, null, tmpCodeGroup);
end;</source>
