    <JadeMethod name="utlUpdateDataDumpExtrDefTs" id="697cdece-c119-446d-9756-52b691b58856">
        <source>utlUpdateDataDumpExtrDefTs(
		_realExtractDef : CM_DataDumpExtractDef; _expectedEdition: Integer;
		_extractedUpTo: TimeStamp; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extractClass : CM_DataDumpExtractClass;
	
begin
	self.initialiseActivity();
	
	if _realExtractDef = null then
		self.raiseExceptionIfNull(_realExtractDef, 'dataDumpExtractDef');
	endif;

	_realExtractDef.raiseExceptionIfTransient(method);

	app.setContinueCMExceptions(true);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realExtractDef);

	if _passport.noErrors and _realExtractDef.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpExtractDef', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractDef, true);
	endif;
	
	foreach extractClass in _realExtractDef.allDataDumpExtractClasses do
		if not _passport.noErrors then
			break;
		endif;
		
		extractClass.setExtractedUpTo(_extractedUpTo);
	endforeach;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractDef, false);
	endif;
end;</source>
        <Parameter name="_realExtractDef" type="CM_DataDumpExtractDef"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_extractedUpTo" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
