    <JadeMethod name="loadDataForFirstTime" id="6c75e25c-fea5-479f-8de2-1e8678e8c2aa">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	regKeys : IntegerArray;

begin
	inheritMethod();
		
	create regKeys transient;
	regKeys.add(J_key_Z);  // PAR 28155
	self.addRegisteredKeys(regKeys);
	regKeys.add(CMUI_Key_F3);  
	self.addRegisteredKeys(regKeys);
	regKeys.add(CMUI_Key_F6);   // PAR 27773
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_UpArrow );  
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_RightArrow );  
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_LeftArrow );  
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_DownArrow );  
	self.addRegisteredKeys(regKeys);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDeckDetails" id="2eaa976b-5e2e-449d-81b8-4ce35fbe805e">
        <updating/>
        <source>loadDeckDetails() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	deck : CM_Deck;
begin
	
	if self.myCurrentDeck &lt;&gt; null then
		deck:=self.myCurrentDeck;
		
	else
		if self.myCurrentProxyDeck &lt;&gt; null then
			deck:=self.myCurrentProxyDeck;
			
		endif;
		
		
	endif;
	
	

	if deck = null then
		self.doClearDeckDetails();
		// PAR 27595 clear out graphic
		self.doClearDeckGraphics();
		return;
	endif;
	
	self.txtCode.text:=deck.code;
	self.txtDescription.text:=deck.description;
	self.txtClearHeight.text:=deck.maxClearHeight.asStringJMT;
	self.txtHeightBL.text:=deck.heightFromBL.asStringJMT;
	self.txtLinearM.text:=deck.totalLM.asStringJMT;
	self.txtMax20.text:=deck.maxLoadStack20.asStringJMT;
	self.txtMax40.text:=deck.maxLoadStack40.asStringJMT;
	self.txtMaxAxel.text:=deck.maxLoadAxel.asStringJMT;
	self.txtMaxLoadM2.text:=deck.maxLoadM2.asStringJMT;
	self.txtRemarks.text:=deck.remarks;
	self.txtTotalArea.text:=deck.totalArea.asStringJMT;
	self.txtTotalCont.text:=deck.totalTEU.asStringJMT;
	self.txtTotalVol.text:=deck.totalVolume.asStringJMT;
	self.txtMaxTier.text:=deck.numTier.asStringJMT;
	
	self.loadDeckItems();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDeckItems" id="ef307e9f-7d60-47a8-b885-fb2dcb64ea24">
        <source>loadDeckItems() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deck : CM_Deck;
	deckItem : CM_DeckItem;
	iter : Iterator;
begin
	if self.myCurrentDeck = null then
		return;
	endif;
	self.tblDeckItems.clearAllData();
	
	iter:=self.myCurrentDeck.allDeckItems.createIterator;
	while iter.next(deckItem) do 
		if not deckItem.isRamp() and
			not deckItem.isMachinery() and
			not deckItem.isGeneralItem() then
			continue;
		endif;
		self.addDeckItemTableItem(deckItem);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadROROStructureCombo" id="99ba23f3-9c0c-4f1f-a6a7-46e09cd84fb0">
        <updating/>
        <source>loadROROStructureCombo(_deck : CM_Deck) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	roroStructure : CM_Object;
begin

	roroStructure:= self.getROROStructure;
	if roroStructure &lt;&gt; null then
		self.myAssistant.comboBoxRORODecks(self.cmbDeck,roroStructure,_deck);
	endif;

	self.doChangeDeck(_deck);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
