    <JadeMethod name="setupThumbnailDefaults" id="3d13bfa5-f2e5-4053-87b6-08d4e0ea05bf">
        <source>setupThumbnailDefaults();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/01/2011	cnwcs5	ccms 1132 - machine delays
// 17/08/2016 cnwrh7	TFS	2501
// 07/05/2017 cnwrh7    TFS 3603      #Import Button Availability on System / Harbour Admin Screen
// ---------------------------------------------------------------------------
vars
	form	: SOP_TableMaintForm;
	theMethod : String;													//+TFS3603
	tmpMethod	: Method;										//+TFS3603
	tmpClass : Class;														//+TFS3603
begin
	form := self.myForm;
	//form.btnImport.visible := true; // TFS 2210		//-TFS3603
	//+TFS3603 starts
	theMethod := "doImportTrx";								//button only enabled when there is such a 'Import' method						
	tmpClass := self.class;
	if class &lt;&gt; null then
	tmpMethod := class.getMethod(theMethod);
	endif;
	if (tmpMethod = null) then
		form.btnImport.visible := false;
	else
		form.btnImport.visible := true;
	endif;
	//+TFS3603 ends
	
	form.allowNext			:= false;
	form.allowPrint			:= true;
	form.allowExportCSV		:= true;
	
	if app.myCurrentUserCan(form.myTerminal, self.permissionMaint) then
		form.allowUpdate := true;
		if form.useTblData then
			form.allowAdd 	 := true;
			form.allowDelete := true;
		else
			form.allowAdd 	 := false;
			form.allowDelete := false;
		endif;
	else
		form.allowAdd 	 := false;
		form.allowUpdate := false;
		form.allowDelete := false;
	endif;

	form.btnAction01.visible	:= false;
	
	if form.allowAdd then										// PAR 23102
		form.btnImport.enabled	:= self.hasImportFunction;   	// JMN Aug2009 MES 1010 TFS 2210 ENABLED
	endif;
	
	form.btnPrintHistory.visible 	:= false;
	form.btnExtractHist.visible		:= false;					// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.btnSerialConn.visible 		:= false;
	form.btnTCPConn.visible			:= false;					// +17/08/2016 cnwrh7	TFS	2501
	form.btnTwistlock.visible		:= false;
	form.btnAddDelay.visible		:= false;					// cnwcs5 01/04/2011 ccms 1132
	form.btnDelaysEnquiry.visible	:= false;					// cnwcs5 01/04/2011 ccms 1132
	form.btnEditWc.visible 			:= false;					// 08 Aug 2009	NDL
	form.btnNewWc.visible 			:= false;					// 08 Aug 2009	NDL
	form.btnEditTV.visible			:= true;  //epr 11/4/13 after gone to wagon class need this reset to visible
	form.frmToolbar.positionToolbarControls();
	form.chkAutoApplyStatus.visible:=false; //jlier1 TFS 51963
	form.btnAdvancedOnToolbar.visible			:= false;	 // ### TFS 51853 17NOV2021 NAVAB1
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="59bfb425-6b66-46f8-901a-a6f4e2ee9494">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	theForm : SOP_TableMaintForm;
	entDef : String;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	entDef:= self.getEntTableDef();
	theForm.setTblDataEntRows(entDef);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, entDef);
	theForm.shtTblInput1.visible := true;
end;</source>
    </JadeMethod>
