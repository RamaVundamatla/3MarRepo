    <JadeMethod name="getPrevSealNum" id="ecce87ba-cce1-491c-9814-54e73c459b5f">
        <source>getPrevSealNum(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2010	cnwndl1	Initial creation

*/

vars

	sealType : CM_SealType;
	sealTi : CM_SealTI;

begin

	// Do we have data stored in the latest version of the way we store operator seal data?
	// If so return the previous value.
	sealType := app.myRoot.getSealType( SealType_Operator );
	if sealType &lt;&gt; null then
		sealTi := self.getSealTI( sealType );
		if sealTi &lt;&gt; null then
			return sealTi.previousSeal;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseROBGateEntity" id="be0c0c10-f9cf-4aa8-8c50-a17e4c394afb">
        <source>getReleaseROBGateEntity() : CMGTE_Entity;
/*

Date		Who		Reason
15 July 2014	cnwer1	Initial creation PAR

*/

vars
	gte : CMGTE_Entity;
begin
	if self.myVehicleVisitRecord = null then
		return null;
	endif;
	
	if self.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
		return null;
	endif;
	
	foreach gte in self.myVehicleVisitRecord.allGateEntities where gte.isKindOf(CMGTE_Release) do
		if gte.CMGTE_Release.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			continue;
		endif;
		if gte.id = self.id then
			return gte;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
