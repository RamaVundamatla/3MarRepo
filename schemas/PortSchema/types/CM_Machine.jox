    <JadeMethod name="setCargoTypes" id="baa47264-674d-4197-b1e9-65f083a9e168">
        <updating/>
        <source>setCargoTypes(cargos : CM_CargoTypeSet input) updating;
//Given an array of cargoTypes, adds them to the list of ta's
//held in the system.
vars
	cargoType	: CM_CargoType;
begin

	exclusiveLock(self);
	//--------------
	//Clear out the existing collection
	//--------------
	if self.allAllowedCargoTypes.size &gt; 0 then
		self.allAllowedCargoTypes.clear;
	endif;
	if cargos.size = 0 then
		return;
	endif;
	//-------------
	//Add these to the coll
	//-------------
	foreach cargoType in cargos do
		self.allAllowedCargoTypes.add(cargoType);
	endforeach; 

end;</source>
        <Parameter name="cargos" type="CM_CargoTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d86e7005-e6d1-4ef7-b4fa-d430f2b505ee">
        <updating/>
        <source>setForCreate(pProxyMachine:CM_Machine; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	machController 	: CM_MachineController;
	machStatus		: CM_MachineStatus;
begin

	pProxyMachine.raiseExceptionIfNotTransient(method);
	
	
	
	self.myTerminal := pProxyMachine.myTerminal;
	self.myRoot		:= app.myRoot;
	self.setForUpdate(pProxyMachine, _passport);
	
	create machController;
	self.myMachineController := machController;
		
	if self.hasRadioTelemetry then
		self.setMachineStatus(STATUS_OFFLINE, null, false);
	endif;
	
end;</source>
        <Parameter name="pProxyMachine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="38e9c71f-4107-4d29-8c10-a8daf5b06911">
        <updating/>
        <source>setForUpdate(pProxyMachine:CM_Machine; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 4/6/2010		cnwjo3		par 24124.  Workzone may need to be recreated if
//							start+end bays fall outside existing workzones
// 15/10/2010	cnwjo3		par 25713.  Need to cause events on each Queue so
//							RT screen updates
// 23/12/2014	cnwdap1		PAR #35451 If changed to be RT enabled, ensure we have a machine status
//29 March 2018	jlgrh7 TFS 37791 SNO - VMT_Issue
//02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
// ---------------------------------------------------------------------------
vars
	startColumn, endColumn : CM_RTGColumn;
	startRTGArea, endRTGArea, rtgArea : CM_RTGArea;
	taArray : CM_TerminalAreaArray;
	taIter,colIter : Iterator;
	ta : CM_TerminalArea;
	gridColumn : CM_GridColumn;
	deletedQueuesExist : Boolean;
	rtQueue : CM_RadioTelemetryQueue;
	term : CM_Terminal;
	nowRTEnabled : Boolean;						// PAR #35451
	newStatus : CM_MachineStatus;				// PAR #35451
begin
	nowRTEnabled := not self.hasRadioTelemetry and pProxyMachine.hasRadioTelemetry;		// PAR #35451
	
	self.id 					:= pProxyMachine.id.trimBlanks;
	self.setCode(self.id);
	self.description 			:= pProxyMachine.description.trimBlanks;
	self.externalRef            := pProxyMachine.externalRef.trimBlanks;   //02.10.2018 cnwma1 TFS #41234
	self.machineType 			:= pProxyMachine.machineType;
	self.maxLiftWeight 			:= pProxyMachine.maxLiftWeight;
	self.available 				:= pProxyMachine.available;
	self.canLift40Foot 			:= pProxyMachine.canLift40Foot;
	self.canLift30Foot 			:= pProxyMachine.canLift30Foot; // PAR 16415 CCMS 1029
	self.canLift45Foot 			:= pProxyMachine.canLift45Foot; // PAR 16415 CCMS 1029
	self.canLift53Foot 			:= pProxyMachine.canLift53Foot; // PAR 16415 CCMS 1029
	
	//self.canTwinLift 			:= pProxyMachine.canTwinLift;//ccms1595 27/11/07
	self.machineLiftType		:= pProxyMachine.machineLiftType;//ccms1595 27/11/07
	self.canWeighCargo			:= pProxyMachine.canWeighCargo;
	self.canCertifyWeight		:= pProxyMachine.canCertifyWeight;	// TFS 2357 14/07/2016
	self.hasRadioTelemetry 		:= pProxyMachine.hasRadioTelemetry;
//	self.onToolbar 				:= pProxyMachine.onToolbar;
	self.maxHeightFull			:= pProxyMachine.maxHeightFull;			
	self.maxHeightMT			:= pProxyMachine.maxHeightMT;
	self.maxRejectedTasks		:= pProxyMachine.maxRejectedTasks;
	self.networkAddress			:= pProxyMachine.networkAddress;
	self.recordActivityHistory	:= pProxyMachine.recordActivityHistory;
	self.requireAvailabilityCode:= pProxyMachine.requireAvailabilityCode;
	self.colour := pProxyMachine.colour;
	self.isNotAvailableForEntry	:= pProxyMachine.isNotAvailableForEntry;
	self.myRFIDTag				:= pProxyMachine.myRFIDTag;
	self.weightDifference		:= pProxyMachine.weightDifference;	//ccms jmt 1032, Par18649. Dec 2008
	self.loadingPosition		:= pProxyMachine.loadingPosition; // ccms 1076 20/8/09
	self.interchangeType		:= pProxyMachine.interchangeType; // ccms 1076 20/8/09
	self.tareWeight				:= pProxyMachine.tareWeight;	//12 Mar 2014	NDL Par 33268
	self.bucketVolume			:= pProxyMachine.bucketVolume; // 9/4/14 epr CCMS 1366
	//epr TFS 37584 27/4/18
	self.accessMaxHeightDiff 	:= pProxyMachine.accessMaxHeightDiff;
	self.accessMaxLocationReach := pProxyMachine.accessMaxLocationReach;
	self.accessMaxOverstowHeight := pProxyMachine.accessMaxOverstowHeight;
	
	self.setMyPhysicalEndBay(pProxyMachine.myPhysicalEndBay); //ccms 1076 5/9/09
	self.setMyPhysicalStartBay(pProxyMachine.myPhysicalStartBay); //ccms 1076 5/9/09
	
	self.allAllowedCargoTypes.clear;
		//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	self.allowedTAMasters.clear;
	pProxyMachine.allAllowedCargoTypes.copy(self.allAllowedCargoTypes);
//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	pProxyMachine.allowedTAMasters.copy(self.allowedTAMasters);
	
	//cnwjo3 par 25713
	term := self.myTerminal;
	//what queues have been deleted?
	foreach rtQueue in self.allQueues do
		if not pProxyMachine.allQueues.includes(rtQueue) then
			self.causeEvent(term.getTerminalEvent(RTMachine_Update_Event), false, rtQueue);
			deletedQueuesExist := true;
		endif;
	endforeach;
	
	//if there are no deleted queues they are either the same queue list or we've added some
	if deletedQueuesExist = false then
		self.causeEvent(term.getTerminalEvent(RTMachine_Update_Event), false, null);
	endif;
	
	if pProxyMachine.allQueues.size &lt;&gt; self.allQueues.size then																							//+TFS37791 machine has difference queues (add/remove secondardy queue) then we will reset the queue 
		self.causeEvent(Event_Machine_Queues_Changed, false, null);
	endif; 
	
	self.allQueues.clear;
	pProxyMachine.allQueues.copy(self.allQueues);
	
	if nowRTEnabled and self.status = null then									// PAR #35451
		create newStatus;														// PAR #35451
		self.status := newStatus;												// PAR #35451
		self.setMachineStatus(STATUS_OFFLINE, null, false);						// PAR #35451
	endif;																		// PAR #35451
	
	self.myOwner := pProxyMachine.myOwner;	//15 May 2018	NDL	TFS 38570
	
	// CCMS 1438
	self.allAllowableContentsStatuses.clear();
	pProxyMachine.allAllowableContentsStatuses.copy(self.allAllowableContentsStatuses);
	
	//needs to be done after ta access and physical end and start bay have been updated
	self.checkWorkzoneUpdates();
	
	self.myTerminal.radioTelemetry.masterQueue.updateMachines();

	//cnwjo3 par 24124 we've destroyed our workzones by moving our start end bays in out-of-bound places.
	//need to rebuild the workzones for the new start and end bays
	if self.allWorkzoneLocations = null or self.allWorkzoneLocations.size = 0 then
		if pProxyMachine.myPhysicalStartBay &lt;&gt; null and pProxyMachine.myPhysicalEndBay &lt;&gt; null then //need something defined...
			startColumn := pProxyMachine.myPhysicalStartBay;
			endColumn := pProxyMachine.myPhysicalEndBay;
			
			startRTGArea:=startColumn.myGridArea.CM_RTGArea;
			endRTGArea:=endColumn.myGridArea.CM_RTGArea;
		
			create taArray transient;
			taArray.add(startColumn.myGridArea);
			taIter:=taArray.createIterator;
			taIter.startAtObject(startRTGArea);
			while taIter.next(ta) do :outerLoop
				rtgArea:=ta.CM_RTGArea;
				delete colIter;
				colIter:=rtgArea.allGridColumns.createIterator;
				if rtgArea = startRTGArea then
					rtgArea.allGridColumns.startKeyGeq(startColumn.column,colIter);
				endif;
				while colIter.next(gridColumn) do
					gridColumn.allControllersByRow.copy(self.allWorkzoneLocations);
					if gridColumn = endColumn then
						break outerLoop;
					endif;
				endwhile;
			endwhile;	
		endif;
	endif;	
epilog
	delete taArray;
end;</source>
        <Parameter name="pProxyMachine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setLastGetMessageTS" id="9bdfc5cd-1500-4a7a-8ee9-3a3e985dffc2">
