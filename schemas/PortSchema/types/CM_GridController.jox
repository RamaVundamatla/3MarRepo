    <JadeMethod name="isBackEndForStackHeight" id="2d5f0df3-681a-42bd-aa72-9f0fafd87a8a">
        <source>isBackEndForStackHeight(_stackHeight : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	#cnwdz2	 27313

*/

vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.allTrackedItems do
		if self.getActualStackPositionOfTI(ti) = _stackHeight then			
			if ti.myPrimaryActualLocation &lt;&gt; self then
				return true;
			endif;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_stackHeight" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
