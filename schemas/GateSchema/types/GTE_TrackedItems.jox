    <JadeMethod name="displaySelectorResults" id="573e85e8-fe71-492d-9386-3ec5ea9e4e2b">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2019	jlgndl1	Initial creation	TFS 46118

*/

vars

	ti : CM_TrackedItem;
	allTIs : CM_TIArray;
	str : String;

begin

	//inheritMethod(_resultCollection, _mode);
	self.tblListAll.rows := self.tblListAll.fixedRows;
	
	if _resultCollection &lt;&gt; null and not _resultCollection.isEmpty then
		
		create allTIs transient;
		_resultCollection.copy( allTIs );
		
		foreach ti in allTIs do
			str := self.getTiDisplay( ti );
			self.tblListAll.accessRow( self.tblListAll.addItem(str) ).itemObject := ti;
		endforeach;
	
	endif;
	
epilog

	delete allTIs;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
