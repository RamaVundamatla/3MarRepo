<Class name="CM_StateReal" id="f7eac95b-9b8d-48c7-a4be-0170c7860b2d">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <PrimAttribute name="value" id="b5752a6f-6471-4a3f-bb78-d5d97d82fa2d">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="64e5987a-4835-4b87-a5fd-4a6ab223b782">
        <source>getValue(): Any;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.value;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="d86ff3a8-8aca-4f6d-986e-26d823746691">
        <updating/>
        <source>setValue(pValue: Any) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpValue	: Real;
	
begin

	tmpValue := pValue.Real;
	if self.value &lt;&gt; tmpValue then
		self.value := tmpValue;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
