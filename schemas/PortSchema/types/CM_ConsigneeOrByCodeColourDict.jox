<CollClass name="CM_ConsigneeOrByCodeColourDict" id="4a8bf3e8-0853-4808-a86f-682ed82ac4a2">
    <memberType name="CM_ConsigneeConsignor"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_ConsigneeConsignor::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_ConsigneeConsignor::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="f9f9067f-0be6-48e2-a853-51966b3153ff">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum, iter);
			self.removeKey(keyCode, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
