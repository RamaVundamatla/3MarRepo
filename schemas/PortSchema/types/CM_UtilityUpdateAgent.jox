	if realPrinterDef = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_PrinterDef.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realPrinterDef);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPrinterDef, true);
	endif;
	
	realPrinterDef.setForUpdate(_proxyPrinterDef);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPrinterDef, false);
