    <JadeMethod name="getMatchingObjectToSelect" id="106b43b8-367c-49c3-96e1-741f778e0999">
        <updating/>
        <source>getMatchingObjectToSelect(_pCode: String; pickW : Boolean io): CM_Object updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bulkRelease		: CM_BulkRelease;
	bookingRef		: CM_BookingRef;
	bookingRefItem  : CM_BookingRefItem;
	tmpTI			: CM_TrackedItem;
	logDocketData		: CM_LogDocketData;
	reserve			: CM_ReserveDetail;
	objArr			: ObjectArray;
	tmpBookingRef,
	rtnBookingRef	: CM_BookingRef;
	iter			: Iterator;
	cnt				: Integer;
	compareCode		: String;
	ts				: TimeStamp;
	
begin
	create objArr transient;
	//booking ref items------------------
	iter := self.myTerminal.allBookingRefsByRef.createIterator;
	self.myTerminal.allBookingRefsByRef.startKeyGeq(_pCode, iter);
	while iter.next(tmpBookingRef) do
		if tmpBookingRef.bookingReference = _pCode then
			objArr.add(tmpBookingRef);
		endif;
	endwhile;
	
	/// Bulk Release----------------------
	compareCode := _pCode.toUpper();	
	bulkRelease := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(compareCode, ts);
	if bulkRelease &lt;&gt; null and bulkRelease.code = compareCode and bulkRelease.type = BR_TYPE_ROAD then
		// 13/08/2008 cnwar2 #16563 - if by type, show reserve lines
		if bulkRelease.releaseByType then
			foreach reserve in bulkRelease.allReserveDetails discreteLock do
				objArr.add(reserve);
			endforeach;
		elseif bulkRelease.allReserveDetails.size = 1 then
		//PAR17915 cnwsh3 16/9/2008
			objArr.add(bulkRelease.allReserveDetails.first);
		else
			objArr.add(bulkRelease);
		endif;
	endif;
	
	///Inter Term TI-----------------------------------
	tmpTI := self.myTerminal.lookupTrackedItem(_pCode, TI_CargoType_Null, TI_STATE_TRANSFER, null, true);	
	if tmpTI &lt;&gt; null then
		objArr.add(tmpTI);
	endif;
	
	///Pre Note TI -----------------------------------
	tmpTI := self.getPreNoteTI(_pCode);
	if tmpTI &lt;&gt; null then
		objArr.add(tmpTI);
	endif;
	///Weigh Bridge------------------------------------------------
	logDocketData := self.myTerminal.allLogDocketDataByDocketNo[_pCode];
	if logDocketData &lt;&gt; null then
		objArr.add(logDocketData);
	endif;

	/// Bring up the pickupwindow if is needed--------------------
	if objArr.size = 0 then
		return null;
	elseif objArr.size = 1 then
		if objArr.first.isKindOf(CM_BookingRef) then
			if objArr.first.CM_BookingRef.allBookingRefItems.size = 1 then
				return objArr.first.CM_BookingRef.allBookingRefItems.first.CM_BookingRefItem;
			else
				pickW := true;
				return self.pickerWindowForObject(objArr);
			endif;
		else 
			return objArr.first.CM_Object;
		endif;
	else
		pickW := true;
		return self.pickerWindowForObject(objArr);
	endif;
epilog
	if objArr &lt;&gt; null then
		delete objArr;
	endif;	
	delete iter;
end;</source>
        <Parameter name="_pCode" type="String"/>
        <Parameter name="pickW" type="Boolean" usage="io"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getMatchingReserveToSelect" id="c9141253-7cfb-4627-8699-cf418766e2de">
        <updating/>
        <source>getMatchingReserveToSelect(_pBR: CM_BulkRelease; pickW : Boolean io): CM_Object updating;
// ---------------------------------------------------------------------------
// Created:     8 December 2008 by cnwar2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	reserve	: CM_ReserveDetail;
	objArr	: ObjectArray;

begin
	create objArr transient;
	
	if _pBR.type = BR_TYPE_ROAD then
		if _pBR.releaseByType then
			foreach reserve in _pBR.allReserveDetails discreteLock do
				objArr.add(reserve);
			endforeach;
		elseif _pBR.allReserveDetails.size = 1 then
			objArr.add(_pBR.allReserveDetails.first);
		else
			objArr.add(_pBR);
		endif;
	endif;
		
	/// Bring up the pickupwindow if is needed--------------------
	if objArr.size = 0 then
		return null;
	elseif objArr.size = 1 then
		return objArr.first.CM_Object;
	else
		pickW := true;
		return self.pickerWindowForObject(objArr);
	endif;
	
epilog
	if objArr &lt;&gt; null then
		delete objArr;
	endif;
end;</source>
        <Parameter name="_pBR" type="CM_BulkRelease"/>
        <Parameter name="pickW" type="Boolean" usage="io"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getPreNoteTI" id="903079cb-4b4e-4b2e-b86e-edcf1c2f91a1">
        <source>getPreNoteTI(pCode : String) : CM_TrackedItem protected;
// ---------------------------------------------------------------------------
// Created:     21 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
begin

	tmpTI := self.myTerminal.lookupTrackedItem(pCode, TI_CargoType_Null, TI_STATE_NOTIFIED, null, true);
