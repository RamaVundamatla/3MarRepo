    <JadeMethod name="doTblMenuContext" id="4f33e368-ca48-4310-b806-6381d485cf31">
        <updating/>
        <source>doTblMenuContext( _table : CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	selectedObject : Object;

begin

	self.mnuAudits.visible := false;
	self.mnuCargoEnq.visible := false;
	self.mnuInspect.visible := false;
	self.mnuCashReceipt.visible := false;
	self.mnuInvoice.visible := false;
	
	
	if _table.allSelectedObjects.size = 1 then
		selectedObject := _table.allSelectedObjects.first;
	endif;
	
	if selectedObject &lt;&gt; null then
	
		if app.isAllowedToInspect() then
			self.mnuInspect.visible := true;
			self.mnuInspect.userObject := selectedObject;
		endif;
		
		if _table = self.tblUnassCashP or _table = self.tblInvLineCashP then
			if selectedObject.CM_CashPayment.hasAudits then	//14 Jan 2021	NDL	TFS 50152
				self.mnuAudits.visible := true;
				self.mnuAudits.userObject := selectedObject;
			endif;
			self.mnuCashReceipt.visible := true;
			self.mnuCashReceipt.userObject := selectedObject;
			
		elseif _table = self.tblCargoInvL then
			if selectedObject.CM_InvoiceLine.hasAudits then	//14 Jan 2021	NDL	TFS 50152
				self.mnuAudits.visible := true;
				self.mnuAudits.userObject := selectedObject;
			endif;
			self.mnuInvoice.visible := true;
			self.mnuInvoice.userObject := selectedObject;
		
		elseif _table = self.tblRelCargo then
			self.mnuCargoEnq.visible := true;
			self.mnuCargoEnq.userObject := selectedObject;
		
		endif;
		
	endif;
	
	self.mnuColOrg.userObject := _table;
	
	return self.showContextMenu(self.mnuTblContext, _table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableActionButtons" id="dd65fd9c-bac3-4d9c-997d-db9e5d699c32">
        <source>enableActionButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	canMaintain : Boolean;
	assignable : Boolean;
	manAssignable : Boolean;
	unassignable : Boolean;
	
	cashPayment : CM_CashPayment;

begin
	
	canMaintain := app.getMyUser.canDo( self.myTerminal, self.permissionMaint );
	
	assignable := not self.tblUnassCashP.allSelectedObjects.isEmpty;
	manAssignable := self.tblUnassCashP.allSelectedObjects.size = 1;
	if manAssignable then
		cashPayment := self.tblUnassCashP.allSelectedObjects.first.CM_CashPayment;
		manAssignable := cashPayment.getInvoiceForManualAssign() &lt;&gt; null;
	endif;
	unassignable := not self.tblInvLineCashP.allSelectedObjects.isEmpty;
	
	self.btnAssign.enabled := canMaintain and assignable;
	self.btnAssignMa.enabled := canMaintain and manAssignable;
	self.btnUnassign.enabled := canMaintain and unassignable;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="1a67a313-6ba9-415c-bed4-7b974c82ff88">
        <source>enableButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	voyage : CM_Voyage;
	bol : CM_BOL;
	cargoType : CM_CargoType;
	cargoId : String;

begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	bol := self.cmbBOL.listObject.CM_BOL;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	cargoId := self.txtCargoId.text.trimBlanks.String;
	
	if voyage = null
	and bol = null 
	and cargoType = null
	and cargoId = null
	then
		self.btnFind.enabled := false;
		self.btnFindUnassign.enabled := false;
	else
		self.btnFind.enabled := true;
		self.btnFindUnassign.enabled := true;
	endif;
	
	self.enableActionButtons();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="6a4c2772-5afd-4cbe-bb1a-c368e833ca1e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	xmlStr	: String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblRelCargo.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblUnassCashP.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblCargoInvL.getXmlStrForColumns(true);	
	xmlStr := xmlStr &amp; self.tblInvLineCashP.getXmlStrForColumns(true);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="3a9e8828-cfdf-4ce4-8d2a-74f0155511dd">
        <source>handleNotifications( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;
	invalid : Boolean;
	rowIndex : Integer;
	edition : Integer;

begin

	if self.myCurrentTrackedItem = null then
		return;
	endif;

	if theObject = null then
		return;
	endif;
	if not theObject.isKindOf(CM_CashPayment) then
		return;
	endif;
	
	cashPayment := theObject.CM_CashPayment;
	on Exception do app.handleDeletedObject( exception, cashPayment, invalid );
	
	edition := cashPayment.edition;
	
	if invalid then
		self.tblUnassCashP.removeDeletedObject(cashPayment);
		self.tblInvLineCashP.removeDeletedObject(cashPayment);
		return;
	endif;
	
	if cashPayment.myTrackedItem &lt;&gt; self.myCurrentTrackedItem then
		self.tblUnassCashP.removeDeletedObject(cashPayment);
		self.tblInvLineCashP.removeDeletedObject(cashPayment);
		return;
	endif;
	
	if cashPayment.myInvoiceLine = null then
		rowIndex := 0;
		if not self.tblUnassCashP.findObjectInRow( cashPayment, rowIndex ) then
			//add it to unassigned
			self.tblUnassCashP.addObject( cashPayment );
		endif;
		rowIndex := 0;
		if self.tblInvLineCashP.findObjectInRow( cashPayment, rowIndex ) then
			//remove it
			self.tblInvLineCashP.removeItem( rowIndex );
		endif;
		
	else
		//it has an invoice line
		rowIndex := 0;
		if self.tblUnassCashP.findObjectInRow( cashPayment, rowIndex ) then
			//remove it from unassigned
			self.tblUnassCashP.removeItem( rowIndex );
		endif;
		if self.myCurrentInvoiceLine &lt;&gt; null and cashPayment.myInvoiceLine = self.myCurrentInvoiceLine then
			//it matches our selected one
			rowIndex := 0;
			if not self.tblInvLineCashP.findObjectInRow( cashPayment, rowIndex ) then
				self.tblInvLineCashP.addObject( cashPayment );
			endif;
		else
			//its assigned but not to the selected one, remove just in case
			self.tblInvLineCashP.removeItemObject( cashPayment );
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initialiseTables" id="8cb9720c-3521-4b64-9887-dcbbe53a213c">
        <source>initialiseTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	def : EntTableDef;

begin

	def := app.myController.getEntTableDef(ETDef_LlHeadings);
	self.tblRelCargo.setTblDataEntRowsFromDef(def);
	self.tblRelCargo.setTblDataEntRowsByDefUserView( def, "CashDefault" );  // Note: special variant method for loading Non-default view 
	self.tblRelCargo.userInputEnabled := false;
	self.tblRelCargo.multiSelect := CM_DataTable.MultiSelect_None;
	self.tblRelCargo.selectMode := Table.SelectMode_CurrentRow;
	self.tblRelCargo.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(self.tblRelCargo);
	
	
	def := app.myController.getEntTableDef(ETDef_PaymentListDetails);
	self.tblUnassCashP.setTblDataEntRowsFromDef(def); // Note: standard variant for loading default view.
	self.tblUnassCashP.userInputEnabled := false;
	self.tblUnassCashP.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblUnassCashP.selectMode := Table.SelectMode_Multiple;
	self.tblUnassCashP.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(self.tblUnassCashP); 
	
	
	def := app.myController.getEntTableDef(ETDef_InvLinesListDetails);
	self.tblCargoInvL.setTblDataEntRowsFromDef(def);
	self.tblCargoInvL.userInputEnabled := false;
	self.tblCargoInvL.multiSelect := CM_DataTable.MultiSelect_None;
	self.tblCargoInvL.selectMode := Table.SelectMode_CurrentRow;
	self.tblCargoInvL.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(self.tblCargoInvL);
	
	
	def := app.myController.getEntTableDef(ETDef_PaymentListDetails);
	self.tblInvLineCashP.setTblDataEntRowsFromDef(def);
	self.tblInvLineCashP.userInputEnabled := false;
	self.tblInvLineCashP.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblInvLineCashP.selectMode := Table.SelectMode_Multiple;
	self.tblInvLineCashP.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(self.tblInvLineCashP); 
	

epilog

end;</source>
    </JadeMethod>
