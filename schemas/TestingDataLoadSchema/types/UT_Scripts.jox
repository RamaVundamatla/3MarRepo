    <JadeMethod name="uDeleteWorkOrder" id="d17bd1ae-7568-4e5d-bfea-f90bf099b3a6">
        <source>uDeleteWorkOrder();

vars

	workOrder					: String;
	
	terminal					: String;
	
	dsl							: UT_DSL;

begin

	workOrder := "Enter Work Order ID";
	
	read workOrder;
	
	terminal := "Enter Terminal Code";
	
	read terminal;
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal);
	
	dsl.deleteWorkOrder(workOrder);
	
	
epilog

	delete dsl;

end;
</source>
