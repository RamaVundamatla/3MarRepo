    <JadeMethod name="getErrorMessageForLocale" id="52f37ebe-0335-4c12-95d1-63eaed12942d">
        <source>getErrorMessageForLocale(localeId : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2023	jlier1	Initial creation

*/

vars
	errorMessages : CM_KioskTranslationByLocale;
	errorMsg : CM_KioskTranslation;
begin
	if localeId = null then
		return null;
	endif;
	
	errorMessages:=self.getAllErrorMessages;
	
	if errorMessages = null then
		return null;
	endif;
	
	errorMsg:=errorMessages[localeId];
	if errorMsg &lt;&gt; null then
		return errorMsg.text;
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="localeId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
