    <JadeMethod name="setupThumbnailDetails" id="f2d148bc-83ff-4bb0-bb2a-5c442c2cfcf5">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
