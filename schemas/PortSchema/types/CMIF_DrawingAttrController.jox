vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpVoyage	: CM_Voyage;

begin

	trimCode := _code.trimBlanks;

	iter := self.myIterVoyage;
	self.allVoyages.startKeyGeq(trimCode, 0, iter);
	self.allVoyages.getIteratorKeys(codeKey, colorKey, iter);

	theCode		:= null;
	theColor	:= NullColour;
	if codeKey = trimCode then
		// found the right one
		theCode		:= _code;
		theColor	:= colorKey;
	else
		tmpVoyage := _voyage;
		if tmpVoyage &lt;&gt; null then
			if tmpVoyage.code &lt;&gt; trimCode then
				// this can happen if invalid data 
				trimCode := tmpVoyage.code;
				self.allVoyages.startKeyGeq(trimCode, 0, iter);
				self.allVoyages.getIteratorKeys(codeKey, colorKey, iter);

				if codeKey = trimCode then
					// found the right one
					theCode		:= _code;
					theColor	:= colorKey;
				else
					self.allVoyages.add(tmpVoyage);
					self.beginNotification(tmpVoyage, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null); // ### PAR 9720
					theCode		:= trimCode;
					theColor	:= tmpVoyage.colour;
				endif;
			else
				self.allVoyages.add(tmpVoyage);
				self.beginNotification(tmpVoyage, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null); // ### PAR 9720
				theCode		:= trimCode;
				theColor	:= tmpVoyage.colour;
			endif;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_Voyage, theCode);
	_colorArray.atPut(TI_ColourMode_Voyage, theColor);
	_objArray.atPut(TI_ColourMode_Voyage, tmpVoyage);

