    <JadeMethod name="maCoverTs" id="d601d3e8-9a45-4d38-97bd-41c7be027125">
        <source>maCoverTs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2020	jlgma1	Initial creation

*/


vars
	param : CMIF_InvoiceSelection;
	invoices : CM_InvoiceBySeqNumDict;
	invoice : CM_Invoice;
	inv : CM_Invoice;
	debtor : CM_Debtor;
	invoiceType : CM_InvoiceDesc;
	paymentType : Integer;
	_invLineType : CM_InvoiceLineDesc;
	tran: CM_TITransaction;	
	theToDate : TimeStamp;
	
begin
	debtor := "2206.63356".asOid.CM_Debtor;				// DI Cash Debtor
	//bank := "2202.8783".asOid.CM_Bank;					// T2B2
	invoiceType := "2735.282494".asOid.CM_InvoiceDesc;	// Storage Liner MAFI
	_invLineType := "2222.1562029".asOid.CM_InvoiceLineDesc;	// Future Storage
	tran := "12579.292191".asOid.CM_FutureStorage;		// Transaction on 01 Dec 2019
	
	//paymentType := _invLineType.getPaymentType(debtor);	
//	app.msgBox("Payment Type is " &amp; paymentType.asStringJMT, "",0);
	
	create invoices transient;
	create param transient;
	
	param.debtor := debtor;
	param.paymentType := paymentType;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := debtor.code;
	
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);
	
	debtor.getOpenInvoices(invoices, param);
	
	app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT,"",0);
	
	if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	
		app.msgBox("Invoice is accrual type", "", 0);
	endif;
	
	foreach invoice in invoices do				
		app.msgBox("Testing Invoice Sequence Num " &amp; invoice.sequenceNum.asStringJMT &amp; " Invoice cover dates " &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT, "", 0);
		
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date FROM " &amp; invoice.fromDT.asStringJMT &amp; " valid ? " &amp; invoice.fromDT.isValid().asStringJMT, "", 0);
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date TO "  &amp; invoice.toDT.asStringJMT &amp;  " valid ? " &amp; invoice.toDT.isValid().asStringJMT, "", 0);
		
		if invoice.coversTimeStampTransaction(tran) then
				app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT &amp; 
								   " MATCHED with Invoice " &amp; invoice.sequenceNum.asStringJMT &amp; 
								   " [" &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT &amp; "]", "", 0);
				break;
		endif;
	endforeach;
	
epilog
	delete param;
	delete invoices;
end;	
/*
	loop := 15;
	transDate := "22 February 2020, 00:01:00".TimeStamp;	
	
	while loop &gt; 1 do 
		fromDT := bank.getPeriodEndDateInitialise(debtor, invoiceType, transDate, false);
		toDT := bank.getPeriodEndDateInitialise(debtor, invoiceType, transDate, true);
		write "Transation date : " &amp; transDate.asStringJMT &amp; " period [ " &amp; fromDT.asStringJMT &amp; " - " &amp; toDT.asStringJMT &amp; " ]";
		
		transDate := transDate.addDays(1);
		loop := loop - 1;
	endwhile;	
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="maFileRename" id="5f680b50-22c7-4a0f-a93e-62d6c84df513">
        <source>maFileRename();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navma1	Initial creation

*/

vars
	file,
	tmpFile 	: File;
	path 		: String; 
	fileEx		: FileException; 
	answer		: Integer;
	sequenceNum : String;
begin
	path := "c:\temp\Inv\";
	sequenceNum := "1234";
	
	create file;
	file.fileName := path &amp; sequenceNum &amp; app.actualTimeAppServer.formatAsYYYYMMDDHHmmSS.asStringJMT &amp; "tmp.inv"; 
	file.mode := File.Mode_Output;	
	file.writeLine("File first Line");
	file.writeLine("File Second Line");
	file.writeLine("File Third Line");

	file.close;
	
	create tmpFile;
	tmpFile.fileName := path &amp; sequenceNum &amp;app.actualTimeAppServer.formatAsYYYYMMDDHHmmSS.asStringJMT &amp;".inv";
	tmpFile.mode := File.Mode_Output;	
	
//tmpFile.close;
	write "tmpFile.isAvailable : " &amp; tmpFile.isAvailable().asStringJMT;
	
	if tmpFile.isAvailable()  then  //Attempting to rename could fail
		answer := app.msgBox("Failed to rename temp file " &amp; file.fileName &amp; " to " &amp; tmpFile.fileName &amp; "." &amp; CrLf &amp; 
							"This file already exists.  Do you want to replace the existing file?" &amp; CrLf &amp; CrLf &amp;
							"Click 'Yes' to delete the existing file, " &amp; tmpFile.fileName &amp; ".","Rename Failed" ,MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
		if answer = MsgBox_Return_No then
			
		else
			tmpFile.purge;
			file.rename(path &amp; sequenceNum &amp; app.actualTimeAppServer.formatAsYYYYMMDDHHmmSS&amp; ".inv"); //Rename the temp file to the correct name now.
		endif;
	else
		write "file.isOpen : " 		&amp; file.isOpen().asStringJMT;
		write "file.isAvailable : " &amp; file.isAvailable().asStringJMT;
		
		answer := app.msgBox("Failed to rename temp file " &amp; file.fileName &amp; " to " &amp; tmpFile.fileName &amp; "." &amp; CrLf &amp; 
							"This file already exists.  Do you want to replace the existing file?" &amp; CrLf &amp; CrLf &amp;
							"Click 'Yes' to delete the existing file, " &amp; tmpFile.fileName &amp; ".","Rename Failed" ,MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
							
		file.rename(path &amp; sequenceNum &amp; app.actualTimeAppServer.formatAsYYYYMMDDHHmmSS &amp; ".inv"); //Rename the temp file to the correct name now.
	endif;
epilog
	delete file; 
	delete tmpFile;
end;</source>
    </JadeMethod>
