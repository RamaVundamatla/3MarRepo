    <JadeMethod name="getValueForObject" id="715165dc-f7e2-462f-a569-a71322a4e32e">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:	21 May 2008 By Graeme Black cnwgb1 PAR 16415
// During a run of the query, this actually goes to the container and calls 
// the method (in this case getActualLength)
// ---------------------------------------------------------------------------
begin

	if _obj = null then
		return 0;
	elseif not _obj.isKindOf(CM_Container) then
		return 0;
	endif;
	
	return _obj.sendMsg(self.propertyName).Integer;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
