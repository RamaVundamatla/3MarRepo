    <JadeMethod name="showDamageSimpleFormForFleet" id="a6bb4fca-0571-4479-99d5-6559690b522e">
        <source>showDamageSimpleFormForFleet(_parentForm: CM_BaseForm;_realTi : CM_TIMaster; _mode : Integer; _term : CM_Terminal);
// ### TFS 55313 08NOV2022 NAVAB1 - ONLY SHOW SIMPLE DAMAGE FROM FLEET
vars
	ti,
	realTi : CM_TIMaster;
	form : CMUI_DamageCodesForm;
	user : CM_User;
	tmpTerm : CM_Terminal;
	termSet : Boolean;
begin
	realTi := _realTi;
	
	user := app.myPassport.myUser;
	if user &lt;&gt; null and not user.allUserTerminals.isEmpty then
		tmpTerm := user.allUserTerminals.first.myTerminal;
	endif;
	
	form := app.loadForm (CMUI_DamageCodesForm, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_DamageCodesForm;
	form.mode := _mode; //Mode_Update;
	form.isParentFormUpdate := true;
	
		
	form.setMyMasterItems(ti, realTi);
	form.setParentForm(_parentForm);
	form.setMyTerminal(tmpTerm);
	form.centreWindow();
	form.showModal();

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_realTi" type="CM_TIMaster"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showDeckingOptions" id="dd229913-b578-4897-b845-9c8d6458a37f">
        <source>showDeckingOptions(_pxyDeckingOptions : CM_YADeckingOptions; _option: Integer; _isInOption: Boolean): Integer;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	aForm 			: CMUI_DeckingOptions;
	mp				: Integer;
begin
	mp := app.mousePointer;
	app.mousePointer	:=	Idle;
	create aForm;
	
	aForm.setAssistantAndTerminalRefs(self, self.myTerminal);
	aForm.sendMsgWithParams('setInitializeWithObject', _pxyDeckingOptions, _option, _isInOption);
	
	return aForm.showModal;	
epilog
	app.mousePointer := mp;
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_option" type="Integer"/>
        <Parameter name="_isInOption" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showDelayAddForm" id="155ce4a2-cc44-4ec3-b55b-c4808579121a">
        <updating/>
        <source>showDelayAddForm(_obj : CM_Voyage; _machine : CM_Machine; _menuAction : CMUI_MenuAction) updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     
// Parameters:  _obj		- a voyage
//				_voyages	- 
//				_machine	-
//				_menuAction -
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		: CMUI_DelaysForm;
	menuAction 	: CMUI_MenuAction;
begin
	form := app.loadForm(CMUI_DelaysForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DelaysForm;
	
	if form = null then
		return;
	endif;
	
	
	form.myDefaultVoyage 	:= _obj;
	form.myDefaultMachine	:=_machine;
	
	form.mode := form.Mode_Add;
	
	form.show();
end;
</source>
        <Parameter name="_obj" type="CM_Voyage"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showDelayEditForm" id="684854b8-3cde-44e1-ab18-3eaf49e3225f">
        <source>showDelayEditForm(_voyage : CM_Voyage; _delay : CM_Delay; _voyages : CM_VoyageSet ; _isEndDelay : Boolean ; _menuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2015   cnwma1      PAR #36709 When voyage is set Don't show 48 hours after departed an error shows up in the delays enquiry screen
// 16/12/2015   cnwma1      PAR #37329 System is not saving ship delays and we have a ship in and working
// 28/09/2016   cnwma1      TFS #2709:Voyage Maint Delay Maint no Working
// ---------------------------------------------------------------------------
vars
	form 		: CMUI_DelaysForm;
	menuAction 	: CMUI_MenuAction;
	voyage		: CM_Voyage;
	voyageGracePeriod : Integer;
	checkDT : TimeStamp;
begin
	form := app.loadForm(CMUI_DelaysForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DelaysForm;

	if form = null then
		return;
	endif;
	
	form.myDefaultVoyage 	:= _voyage;
	form.myDelay 		:= _delay;
		
	if _delay &lt;&gt; null then
		voyage := _delay.myVoyage;
	endif;
	
	if voyage = null then													 // 16/12/2015 cnwma1	 PAR #37329     
		voyage:=_voyage;
	endif;
	
/* TFS 8166 - the voyage display option are for some cargo based screens. Delays are not cargo based.
Delays should always be viewable and maintainable.
Infact the Delay enquiry is usable by departed voyage from many screens in JMT like Voyage Operations 
which always allows delays to be viewed and maintained.

	if voyage.displayOption = VoyageDisplayNever then						//24/11/2015 cnwma1 PAR #36709 
		if _menuAction.myForm = null then                                    //28/09/2016 cnwma1 TFS #2709
			return;
		endif;
	endif;
	
	if voyage.displayOption = VoyageDisplayDefault then						//24/11/2015 cnwma1 PAR #36709 
		voyageGracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
		if voyageGracePeriod &lt;&gt; null then
			checkDT := app.actualTimeServer();
			checkDT := checkDT.changeByXXHours(-voyageGracePeriod);
			//if  checkDT &gt; form.myDelay.myVoyage.departedDT then	             // 16/12/2015 cnwma1	 PAR #37329     
			if voyage.departedDT &lt;&gt; null then
				if  checkDT &gt; voyage.departedDT then                             // 16/12/2015 cnwma1	 PAR #37329
					return;
				endif;	
			endif;
		endif;
	
	endif;
	
*/
	
	if voyage &lt;&gt; null then
		form.myDefaultVoyage := voyage;
	endif;

	
	if _delay &lt;&gt; null then
		form.mode 	:= form.Mode_Update;
	else
		form.mode	:= form.Mode_Add;
	endif;
	
	form.isEndDelay := _isEndDelay;
	
	form.show();
epilog
	
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_voyages" type="CM_VoyageSet"/>
        <Parameter name="_isEndDelay" type="Boolean"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showDelayEnquiryForm" id="f94385c6-ff96-490c-afa2-6f4f1e0e947f">
        <source>showDelayEnquiryForm(_voyage :CM_Voyage; _machine :CM_Machine; _voyageColl :CM_VoyageSet; _delayColl :CM_DelayByStartDTDict);
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:CMUI_DelayEnquiryForm;
begin
	form := app.loadForm(CMUI_DelayEnquiryForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DelayEnquiryForm;

	if form = null then
		return;
	endif;

	form.centreWindow;
		
	if _delayColl &lt;&gt; null then
		_delayColl.copy (form.allSelectedDelays);
		
		form.initialiseWithObject := true;
	endif;
	
	form.myFilterVoyage 	:= _voyage;
	form.myFilterMachine 	:= _machine;
	form.show();
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_voyageColl" type="CM_VoyageSet"/>
        <Parameter name="_delayColl" type="CM_DelayByStartDTDict"/>
    </JadeMethod>
