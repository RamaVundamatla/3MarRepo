    <JadeMethod name="doFilterCargoTypeChange" id="47af0926-9e42-4341-8860-d62ae09ab1f1">
        <updating/>
        <source>doFilterCargoTypeChange() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars
	cmbTiType		: ComboBox;
	currCargoType	: CM_CargoType;
begin
	cmbTiType := self.cmbCargoType;
	self.tblSearch.setValueByControlName(cmbTiType.name, cmbTiType.text);
	currCargoType := cmbTiType.listObject.CM_CargoType;
	
	if currCargoType = null then
		self.tblSearch.hideRowByName(ETRow_FilterISOType, true);
		self.tblSearch.hideRowByName(ETRow_FilterProduct, true);
		return;
	endif;
	
	if currCargoType.isISOType() then
		self.tblSearch.hideRowByName(ETRow_FilterProduct, true);
		self.tblSearch.showRowByName(ETRow_FilterISOType, true);
	else
		self.tblSearch.hideRowByName(ETRow_FilterISOType, true);
		if currCargoType.hasProductTypes() then
			self.tblSearch.showRowByName(ETRow_FilterProduct, true);
			self.myAssistant.comboBoxProduct(self.cmbCargoSubtype, currCargoType, null, null);
		else
			self.tblSearch.hideRowByName(ETRow_FilterProduct, true);
		endif;
	endif;
	
	self.adjustSearcherHeight();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="76c9fa97-b46c-4342-9d79-4caa6b46033b">
