        <source>comboBoxPortObject(_cmb : ComboBox input; _port : CM_Port; _voyage: CM_Voyage) updating;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars

	portCol : Collection;

begin

	if _voyage &lt;&gt; null then
		//_cmb.listCollection(_voyage.allPorts, false, 0);	
		self.allPortsForVoyageInitialize(_voyage);
		portCol := self.allPortsVoyCodeDisplay;
	else
		//cmb.listCollection(app.myRoot.allPorts, false, 0);
