    <JadeMethod name="doMouseDown" id="296790fa-5b45-46d9-9ec9-91bec8311368">
        <updating/>
        <source>doMouseDown(_control	: Control input; 
			_button		: Integer; 
			_shift		: Integer; 
			_x, _y		: Real) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	if _shift &lt;&gt; 1 then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_Size;
	self.mouseDownX := _x + self.left;
	self.mouseDownY := _y + self.top;
	self.zOrder(1); // AKB2003DEC added;
	self.inDragMode := true;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doMouseEnter" id="07dd5f07-a735-467c-b3a1-a25c1d2e1e56">
        <updating/>
        <source>doMouseEnter(_control : Control) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if app.isShiftKeyDown then
		app.mousePointer := Window.MousePointer_Size;
	else
		app.mousePointer := Window.MousePointer_Default;
	endif;
end;


</source>
        <access>protected</access>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doMouseLeave" id="9028b155-b230-4151-ac6a-082ae73f69a6">
        <updating/>
        <source>doMouseLeave(_control : Control input) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
