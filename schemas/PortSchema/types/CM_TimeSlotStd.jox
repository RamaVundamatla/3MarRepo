<Class name="CM_TimeSlotStd" id="b5408e43-ac9a-4a04-8585-04bd369eb8ed">
    <superclass name="CM_TimeSlotEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="day" id="d3be5187-619c-4019-9796-b6b88e59bfd2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="73124bf6-77f6-458c-aa5a-17e7e5646b16">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <Inverse name="CM_Terminal::allTimeSlotStd"/>
    </ExplicitInverseRef>
    <JadeMethod name="getMyTerminal" id="1ad69703-02f8-47ef-be0e-7fe1064ba7de">
        <source>getMyTerminal() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars

begin
	return self.myTerminal;
end;
</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2de4780d-256b-4c90-82c1-c10b8a2c3174">
        <updating/>
        <source>setForCreate(pProxyTimeSlotStd : CM_TimeSlotStd) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------


vars

begin
	pProxyTimeSlotStd.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.startTime := pProxyTimeSlotStd.startTime;
	self.numOfSlot := pProxyTimeSlotStd.numOfSlot;
	self.day 			:= pProxyTimeSlotStd.day;

	self.myTerminal		:= pProxyTimeSlotStd.myTerminal;
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Add), false, null);
end;
</source>
        <Parameter name="pProxyTimeSlotStd" type="CM_TimeSlotStd"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8f3157ca-b287-421d-83e2-df241db0857d">
        <updating/>
        <source>setForUpdate(pProxyTimeSlot : CM_TimeSlotStd) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin
	pProxyTimeSlot.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.day 			:= pProxyTimeSlot.day;
	self.startTime 		:= pProxyTimeSlot.startTime;
	self.numOfSlot		:= pProxyTimeSlot.numOfSlot;
	self.myTerminal		:= pProxyTimeSlot.CM_TimeSlotStd.myTerminal;
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Update), false, null);	


end;
</source>
        <Parameter name="pProxyTimeSlot" type="CM_TimeSlotStd"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="87c1f742-2bd1-4d8c-a526-8d54a11e3954">
        <updating/>
        <source>setProxy(pDay: Integer; pStartTime: Time; pNumOfSlot: Integer;  pTerminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars

begin
	self.day  			:= pDay;
	self.startTime  	:= pStartTime;
	self.numOfSlot		:= pNumOfSlot;
	self.myTerminal		:= pTerminal;
end;
</source>
        <Parameter name="pDay" type="Integer"/>
        <Parameter name="pStartTime" type="Time"/>
        <Parameter name="pNumOfSlot" type="Integer"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="valForCreate" id="35b310e7-db81-47e3-bf0d-869cdaa77993">
        <source>valForCreate(_passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars
	aTimeSlot : CM_TimeSlotStd;
begin
	foreach aTimeSlot in self.myTerminal.allTimeSlotStd do
		if aTimeSlot.startTime = self.startTime and aTimeSlot.day = self.day then
			app.raiseCMException1(VB_DUPLICATED_ITEM, "Time Slot", null, null);
			return;
		endif;	
	endforeach;
end;
</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
