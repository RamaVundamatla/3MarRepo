<Class name="WS_BulkReleaseStatus" id="aec5c148-5d26-40d8-9b6b-e4f1eeb2c98c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Bulk release status </text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="160e59ff-e101-4d57-a534-a7bccae4a29d">
        <type name="String"/>
        <text>Release Request Status Description ex[0=Pending,1=Active,2=Complete,3=Archive,4=Active &amp; Pending,5=All]</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="226cda59-ac12-4573-bb01-12cbd20f7a6b">
        <embedded/>
        <type name="Integer"/>
        <text>Id  on the bulk release Status. Maximum characters.</text>
    </PrimAttribute>
</Class>
