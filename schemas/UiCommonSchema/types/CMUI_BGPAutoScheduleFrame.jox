    <JadeMethod name="loadForTime" id="aaa6f4d5-9a8b-4e65-834a-e97174b1f6df">
        <source>loadForTime() protected;

// cnwdvb1 14 January 2003 

vars

begin
	
	if self.tblD.userInputEnabled then
		self.optT.setFocus();
//		self.tblT.setFocus();
//		self.tblT.moveFirst();
