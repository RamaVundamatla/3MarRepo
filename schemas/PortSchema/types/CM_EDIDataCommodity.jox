    <JadeMethod name="getNumColumns" id="7f4fcee5-bf01-4466-99f6-aa1cb18fad4b">
        <source>getNumColumns(): Integer;
//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	popColl	: PropertyNDict;
begin
	popColl	:= CM_EDICommodityTI.getProperties;
	return popColl.size + inheritMethod;
epilog

end;</source>
        <ReturnType type="Integer"/>
