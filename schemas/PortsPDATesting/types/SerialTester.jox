    <JadeMethod name="doOpen" id="8725b8c5-0c61-46a4-9647-216e06fafa4b">
        <updating/>
        <source>doOpen() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if txtName.text = null then
		app.msgBox("You must input Com Port name","Name",MsgBox_OK_Only);
		return;
	endif;
	

	self.myConnection.name:=txtName.text.trimBlanks;
	self.myConnection.timeout:=txtTimeout.text.Integer * 1000;
	self.myConnection.usePresentationClient:=self.chkCompact.value;
	write self.myConnection.name;
	write self.myConnection.timeout.String;
	self.myConnection.open;
	self.shtRead.enabled:=true;
	self.shtWrite.enabled:=true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRead" id="0043795b-9458-4412-a274-ddaf81de3be9">
        <source>doRead();
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	data : Binary;
begin
	self.txtWrite.text:=null;
	if self.txtBuffer.text.Integer = null then
		app.msgBox("Read buffer must be &gt; 0","Read Buffer", MsgBox_OK_Only);
		return;
	endif;
	
	data:=self.myConnection.readBinary(self.txtBuffer.text.Integer);

	self.txtWrite.text:=data.String;
	self.txtWrite.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadServer" id="5c211522-47f5-49e1-86b6-93eacea20d84">
