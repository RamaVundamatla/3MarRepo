    <JadeMethod name="doContextMenuBuild" id="f05dd18f-534f-4d1c-b4fd-4fb5d0ef324d">
        <updating/>
        <source>doContextMenuBuild(cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	obj	: Object;
	job : CM_VoyageJob;
	ti : CM_TrackedItem;
	controller : CM_LocationsController;
	tis : CM_TIArray;	
	amLinked : Boolean;
	request : CM_SlotRequest;
	mcRequest : CM_Request;
	planMode : Boolean;
	holdFrame : SHP_BulkDrawingFrame;

begin
	planMode := (self.workingMode = WorkMode_Volume);

	self.saveX := (cntrl.left + x).rounded;
	self.saveY := (cntrl.top + y).rounded;

	if SHP_BulkDrawingFrame.hasInstance(cntrl) then
		holdFrame := cntrl.SHP_BulkDrawingFrame;
		obj := holdFrame.getObjectForPosition(x, y);
	endif;
	self.mnuCreateQuickTI.visible := app.isSpecial;
	self.doTurnOffContextMenus();
	
	self.mnuGridPlanDischarge.userObject := null;
	self.mnuGridSelectAreas.visible := true;
	self.mnuGridSelectAreas.caption := "&amp;Select Holds...";
	
	self.mnuGridNewJob.visible := false;
	self.mnuGridShuffle.visible := false;
	self.mnuGridBigFont.visible := true;
//	if self.myCurrentDrawingController &lt;&gt; null then		// 27/7/16 cnwmp6 TFS 1601
//		self.mnuGridSelector.visible := true;
//		self.mnuGridSelectorClear.visible := (not self.myCurrentDrawingController.allSelectorTIs.isEmpty);
//	else
		self.mnuGridSelector.visible := false;
		self.mnuGridSelectorClear.visible := false;
//	endif;
	self.mnuGridNewJobSeed.visible := false;
	
	self.mnuCargoEnquiry.visible := false;
	self.mnuCargoEdit.visible := false;
	self.mnuCargoErase.visible := false;
	
	//self.mnuGridHideLegend.visible := false;
	//self.mnuGridHideMacro.visible := false;
	
	// Summarise menu options are only enabled if display mode is actual and have correct permissions.
	// Has been defaulted to invisible in doTurnOffContextMenus.
	if self.bAllowSummaryDefn and self.displayMode = ShpDisplayMode_Actual then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if a hold is actually selected.
		self.mnuSummariseSelected.visible	:=	self.myCurrentDrawingController &lt;&gt; null and
												not self.myCurrentDrawingController.allSelectedObjects.isEmpty;
	endif;
	
	self.mnuGridAreaContext.enabled := false;
	self.mnuGridPrint.caption := "Print...";
	self.mnuGridPrint.visible 	:= true;
	
	self.mnuGridPlanningTips.visible := false;
	self.mnuGridLayout.visible := false;
	self.mnuZoomSub.visible := false;
	
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, self.saveX,self.saveY);
	
epilog
	delete tis;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="73650ab1-f1a9-43da-8f74-fd37de6cc9b2">
        <updating/>
        <source>doDropFromGridAreaForm(frame : SHP_BulkDrawingFrame input; win : Window input; x : Real; y : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	tmpObj : Object;
	holdController : CM_GeneralCargoController;
	aLabel, moveString : String;
	jobOne, jobTwo : CM_Job;
	tmpDrawController : SHP_BulkDrawingController;
	tmpMoveController : CMIF_MoveController;
	moveControllerMoveMode,
	drawControllerMoveMode : Integer;

begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	tmpMoveController := app.myMoveController;
	
	if tmpMoveController = null then
		return;
	endif;
	if tmpMoveController.myTrackedItem = null then
		return;
	endif;

	tmpObj := frame.getObjectForPosition(x.Integer, y.Integer);
	if tmpObj = null or (tmpObj &lt;&gt; null and (not CM_GeneralCargoController.hasInstance(tmpObj))) then
		return;
	endif;
	
	tmpDrawController := self.myBulkDrawingController;
	moveControllerMoveMode := tmpMoveController.moveMode;
	drawControllerMoveMode := tmpDrawController.getMoveModeFromDisplayMode;
	
	holdController := tmpObj.CM_GeneralCargoController;
	tmpMoveController.setMyToPrimaryLocation(holdController); // AKB2005SEPT added to allow to use 'isMoveAnExportRePlan' below when setting the slot req.

	if moveControllerMoveMode = REAL_MODE then
		tmpMoveController.mySlotRequest := null;
		tmpMoveController.setMyWorkListEntry(null);
	endif;

	// if a planning drop check that there is a request and a job
	if moveControllerMoveMode &lt;&gt; drawControllerMoveMode then
		if moveControllerMoveMode = QUEUE_MODE then
			app.msgBox("Cannot drag drop in Queue mode.","Dragging From " &amp; aLabel &amp; " Error",
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if drawControllerMoveMode = REAL_MODE then
			moveString := "Instant Mode";
		elseif drawControllerMoveMode = PLANNING_MODE then
			moveString := "Planning Mode";
		endif;
		aLabel := win.name;
		app.msgBox("Dragging in different modes." &amp; Cr &amp; "Please reset the dragging mode in " &amp; aLabel &amp; " to be " &amp; moveString &amp; ".","Dragging From " &amp; aLabel &amp; " Error",
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.moveTrackedItemTarget(holdController); 
	tmpMoveController.ignoreWeightValidation := false;
	
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
