    <JadeMethod name="clearTableDates" id="4dde4239-f2b8-4cec-a30b-8d4e9ba44c9e">
        <source>clearTableDates();
/*
Purpose:			
Date		Who		Reason
10 February 2015	cnwab1	Initial creation
*/

vars

	tempDate : CM_CalendarDate;

begin

	foreach tempDate in self.allTransCalendarDates do
		delete tempDate;
	endforeach;
	
	self.allTransCalendarDates.clear();

	self.initTblDayData();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickOption" id="dba4a913-4605-4729-9225-745121ad4675">
        <source>clickOption();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	calendarDate : CM_CalendarDate;
	calendarYear : CM_CalendarYear;
	check : Boolean;
	date : Date;
	year : Integer;
	index : Integer;
	jadeTableCell : JadeTableCell;
	
	dateFrom : Date;
	dateTo : Date;
	templateCalDate : Date;
	
	sourceByDay : Integer;
	sourceByMonth : Integer;

begin

	self.tblTemplates.clear();
	self.tblTemplates.fixedRows := 0;
	self.tblTemplates.rows := 0;
	
	self.tblLabels.clear();
	self.tblLabels.fixedRows := 0;
	self.tblLabels.rows := 0;
	self.tblLabels.columns := 1;
	
	sourceByDay := CM_CalendarDate.SourceByDay;
	sourceByMonth := CM_CalendarDate.SourceByMonth;
	
	
	if optDay.value then
	
		txtYear.visible := false;
		lblUsing.visible := false;
		if self.allTemplateDatesByDay.isEmpty then
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[1],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[2],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[3],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[4],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[5],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[6],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByDay.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									self.dayListArray[7],	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByDay	//_dataSource : Integer
									);
		endif;
		
		check := false;
		index := 0;
		foreach calendarDate in allTemplateDatesByDay do
			index := index + 1;
			tblTemplates.accessRow(tblTemplates.addItem(check.cnEcGetTableCheckBoxValue &amp; Tab &amp; calendarDate.description )).itemObject := calendarDate;
			tblLabels.addItemAt( calendarDate.description, index);
			jadeTableCell := tblLabels.accessCell(index, 1);
			jadeTableCell.inputType := Table.InputType_TextBox;
		endforeach;
	
	elseif optMonth.value then
	
		txtYear.visible := false;
		lblUsing.visible := false;
		if self.allTemplateDatesByMonth.isEmpty then
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_day_of_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
		
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_day_of_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_business_dom),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_business_dom),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_monday_month),	//_description : String;
