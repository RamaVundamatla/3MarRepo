<Class name="AATransaction" id="bde55d99-91f4-499e-a733-90c5a72ea6cf">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="auditor"/>
    <PrimAttribute name="endTime" id="605d6fa9-5c93-4956-acdb-dd16915ea930">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myControl" id="9d3b4a0b-fccb-4f0c-861a-5e536de12273">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="AAControl"/>
        <Inverse name="AAControl::transactions"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="objectOps" id="a9676e04-58cf-40d0-8e0a-dd616031a89e">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="AAObjectOpList"/>
        <Inverse name="AAObjectOp::myTransaction"/>
    </ExplicitInverseRef>
    <PrimAttribute name="startTime" id="7bf3f7d9-57e5-4920-85fd-8aa383b0048c">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="tranID" id="6c4b1df6-5677-409b-b680-271989e37fd7">
        <precision>20</precision>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <ImplicitInverseRef name="user" id="320175e4-4872-4872-89d8-50be9d96a240">
        <embedded/>
        <type name="AAUser"/>
    </ImplicitInverseRef>
    <JadeMethod name="addObjectOp" id="26d0210d-544f-433a-ba22-31de23680b91">
        <source>addObjectOp(oper : String; objectType : Integer; oid : String; timeStamp : TimeStamp; edition : Integer);

vars
	op	: AAObjectOp;
begin
	create op transient;
	op.update(oper, objectType, oid, timeStamp, edition);
	objectOps.add(op);
end;
</source>
        <Parameter name="oper" type="String"/>
        <Parameter name="objectType" type="Integer"/>
        <Parameter name="oid" type="String"/>
        <Parameter name="timeStamp" type="TimeStamp"/>
        <Parameter name="edition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dump" id="af43498b-b1c3-48c1-af4a-a453f52867f9">
        <source>dump(file : File; timestamp : TimeStamp);
vars
	rec : String;
	op  : AAObjectOp;
begin

	rec := tranID.String &amp; "," &amp; startTime.date.format("yyyy-MM-dd") &amp; "," &amp; startTime.time.format("HH:mm:ss") &amp; "," &amp; "Btr" &amp; "," &amp; user.name &amp; "," &amp; user.index.String;
	file.writeLine(rec);
	foreach op in objectOps do
		op.dump(file);
	endforeach;
	rec := tranID.String &amp; "," &amp; timestamp.date.format("yyyy-MM-dd") &amp; "," &amp; timestamp.time.format("HH:mm:ss") &amp; "," &amp; "Ctr" &amp; "," &amp; user.name &amp; "," &amp; user.index.String;
	file.writeLine(rec);
	
end;
</source>
        <Parameter name="file" type="File"/>
        <Parameter name="timestamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="includesOpsForClassNumber" id="71c1aef4-2d3b-465d-aa8c-139686cabb0e">
        <source>includesOpsForClassNumber(_number : Integer) : Boolean;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 August 2008	cnwkpd1	PAR #9721 - UCD FW745-NU Agenda Monitor Extensions

*/

vars
	op				: AAObjectOp;
	
begin
	foreach op in self.objectOps do
		if op.isForClassNumber(_number) then
			return true;
		endif;
	endforeach;
	
	return false;
	
	
epilog

end;</source>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="update" id="16b22d39-ad51-470d-987e-c3dfcbdd3f77">
        <updating/>
        <source>update(userP : AAUser; timestamp: TimeStamp; serialNumber: Decimal; transactionId: Decimal) updating;

begin
	
	user := userP;
	startTime := timestamp;
	tranID := transactionId;

end;
</source>
        <Parameter name="userP" type="AAUser"/>
        <Parameter name="timestamp" type="TimeStamp"/>
        <Parameter name="serialNumber" type="Decimal"/>
        <Parameter name="transactionId" type="Decimal"/>
    </JadeMethod>
</Class>
