    <JadeMethod name="utlCreateInvLineManualCopy" id="6328c6be-27a4-4c38-8715-9f11cfd1f85a">
        <source>utlCreateInvLineManualCopy(_theController : CMIF_InvoiceLineCopy io;_pxyInvLine : CM_InvoiceLine; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55542: Jade - Invoice Line Copy Jade Code
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes
03 May   2023  navmv20 Bug 57664: EUP - Copy function does not include overridden rates

*/

vars

	theInvoice 	   : CM_Invoice;
	calcType	   : CM_CalculationType;
	transCtrl 	   : CMIF_TITransactionController;
	transObj	   : CM_TITransaction;
	newInvLine     : CM_InvoiceLine;
	allRealInvoiceLines : CM_InvoiceLineBySeqNumDict;
	trackedItem : CM_TrackedItem;
	allTrackedItems : CM_TIArray;
	bank : CM_Bank;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not _theController.newInvoice then
		_theController.myInvoice := _pxyInvLine.invoice;
	endif;
	
	_theController.pxyInvLine := _pxyInvLine;
	
	app.myValCA.valInvLineManualCopy(_theController);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create allRealInvoiceLines transient;
	create allTrackedItems transient;
	allTrackedItems.clear();
	if _theController.differentCargos then
		_theController.allTrackedItems.copy(allTrackedItems);
	else
		allTrackedItems.add(_pxyInvLine.trackedItem);
	endif;
		
	if allTrackedItems.size() &gt; 0 then
		foreach trackedItem in allTrackedItems  do
			newInvLine := _pxyInvLine.cloneForCopy(_theController,trackedItem,false);
			// newInvLine.createCharges(); //03/05/2023 navmv20 Bug 57664
			allRealInvoiceLines.add(newInvLine);
			
			//03/05/2023 navmv20 Bug 57664 - START
			newInvLine.createManualInvLineTransaction(false); 
			/* 
			theInvoice := newInvLine.invoice;
			if theInvoice &lt;&gt; null and newInvLine &lt;&gt; null and  newInvLine.trackedItem &lt;&gt; null then
				calcType := newInvLine.getCalcType();
				if calcType &lt;&gt; null and calcType.isCargoCalcType then
					// If a manual invoice line for cargo has been created then
					// we want to create a ManualInvoiceLine Transaction too
					create transCtrl transient;
					transCtrl.myTrackedItem := newInvLine.trackedItem;

					transCtrl.type := TRANS_TYPE_MANUALLINECREATED;
					transCtrl.noCharge := true;
					app.myUtilityCA.utlCreateTITransaction(transCtrl, transObj, _passport);
								
					if transObj &lt;&gt; null then
						transObj.setMyTrackedItem(newInvLine.trackedItem, transCtrl);
						newInvLine.setMyTransaction(transObj);
					endif;
				endif;
			endif;
			delete transCtrl; //15/04/2023  navmv20 TFS 55304 Task 55545
			*/
			//03/05/2023 navmv20 Bug 57664 - END
		endforeach;
	else
		newInvLine := _pxyInvLine.cloneForCopy(_theController,null,false);
		//newInvLine.createCharges();	//03/05/2023 navmv20 Bug 57664
		newInvLine.createManualInvLineTransaction(false); //03/05/2023 navmv20 Bug 57664
		
		allRealInvoiceLines.add(newInvLine);
		theInvoice := newInvLine.invoice;
	endif;
	allRealInvoiceLines.copy(_theController.allRealInvLines);
	
	if app.myPassport.noErrors then
		if newInvLine &lt;&gt; null then
			bank := newInvLine.bank;
		endif;
		
		foreach newInvLine in allRealInvoiceLines discreteLock do
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(newInvLine);
			bank.causeEvent(app.myPassport.myTerminal.getTerminalEvent(Event_InvoiceLineCreate), false, newInvLine);
		endforeach;
	endif;
epilog
	delete transCtrl;
	delete allRealInvoiceLines;
	delete allTrackedItems;
end;
</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineCopy" usage="io"/>
        <Parameter name="_pxyInvLine" type="CM_InvoiceLine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
