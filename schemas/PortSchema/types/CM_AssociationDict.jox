		return self[_key.toUpper()].asBoolean;
	endif;
	return false;	
end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="date" id="7e1acc46-2a01-4258-aca6-6b7298082ad0">
        <source>date(_key: String) : Date;
/*
Purpose:			
Date		Who		Reason
05 January 2015	cnwab1	Initial creation
*/

vars
	now : Date;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.includesKey(_key) then
		return self[_key.toUpper()].asDate;
	endif;
	return now;	

epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
