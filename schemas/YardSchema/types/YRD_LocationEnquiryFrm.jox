    <JadeMethod name="showThumbnailData" id="2e2e483b-19cf-4220-9ba5-0e7dd81e5158">
        <updating/>
        <source>showThumbnailData(_obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		30 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dataContainer	: CM_DataContainer;
	
begin
	inheritMethod(_obj);
	
	self.frmStatusLine.myFrameCaption.caption := "Selected: " &amp; self.tblData.allSelectedObjects.size.String;
	
	//######################
	// DISPLAY INFO
	self.tblExtraInfo.rows := 0;
	self.tblExtraInfo.userObject := null;
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	dataContainer.displayMode := self.getDisplayMode();
	
	if _obj.isKindOf(CM_TrackedItem) then
		_obj.CM_TrackedItem.getExtraInfoFirst(dataContainer);
		_obj.CM_TrackedItem.getExtraInfo(dataContainer);
	else
		return;
	endif;
	
	self.tblExtraInfo.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblExtraInfo, false,false, 4, 1, 4, 1, 1);
	self.doResizeColumnWidths(self.tblExtraInfo, true);
	
	if self.tblData.hasNoData then
		self.btnTransactions.enabled:= false;
		self.btnEditTV.enabled:= false;
	else
		self.btnTransactions.enabled:= true;
		self.btnEditTV.enabled:= true;
	endif;	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled 		:= false;
		self.btnPrintTV.enabled 	:= false;
		self.btnSelectAllTV.enabled	:= false;
		self.btnMoveIt.enabled      := false;
		self.btnRestriction.enabled := false;
		self.btnTransactions.enabled:= false;
		self.btnPrintList.enabled   := false;
		self.frmStatusLine.enabled  := false;
		self.btnMoveIt.enabled:= false;
		self.tblThumb.userInputEnabled 	:= false;

	endif;
	
epilog
	delete dataContainer;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="caf8157f-4873-4fc3-9cdd-0e7b8c3bd875">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin

	self.myStartupObject := pObj; // PAR 13908
	self.amInitialisingInEditMode	:=	_doEdit;
	self.amInitialisingWithObject 	:=	true;
	self.myCurrentObject 			:=	pObj;
	self.useTblData					:=	(not _thumbnailOnly);
	self.useThumbArea				:=	true;
	self.isThumbnailVisible			:=	true;
	self.useBlankCargoTypeAsDefault	:=	true;
	self.show();
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showYardAllocScreen" id="6ad25315-3d2e-4459-b779-8056f94f2c9c">
        <updating/>
        <source>showYardAllocScreen(_yalloc : CM_YardAllocation) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	yas: ObjectArray;
	locationString : String;
begin
	if _yalloc &lt;&gt; null then
		create yas transient;
		yas.add(_yalloc);
	endif;
	
	if self.filterTerminalArea &lt;&gt; null and self.filterTerminalArea.isKindOf(CM_BlockStack) then
		locationString:=self.filterTerminalArea.id;
	endif;
	
	self.myAssistant.showYAMaintForm(yas, null, self,locationString, 0);
epilog
	delete yas;
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
