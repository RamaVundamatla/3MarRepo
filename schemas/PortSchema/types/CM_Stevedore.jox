    <JadeMethod name="setForCreate" id="dec17195-216b-4d0f-ba0d-cbb043af0ba2">
        <updating/>
        <source>setForCreate(pProxyStevedore:CM_Stevedore) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyStevedore);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyStevedore" type="CM_Stevedore"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e741671e-b3a8-4c56-ad74-86a7d279674a">
        <updating/>
        <source>setForUpdate(pProxyStevedore:CM_Stevedore) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// ---------------------------------------------------------------------------
vars

begin
	self.code := pProxyStevedore.code.trimBlanks;
	self.description := pProxyStevedore.description.trimBlanks;
	self.notAvailableForEntry := pProxyStevedore.notAvailableForEntry;	
	self.allContacts.clear();
	pProxyStevedore.allContacts.copy(self.allContacts);
	self.myDebtor := pProxyStevedore.myDebtor;				// TFS 44554
end;</source>
        <Parameter name="pProxyStevedore" type="CM_Stevedore"/>
    </JadeMethod>
