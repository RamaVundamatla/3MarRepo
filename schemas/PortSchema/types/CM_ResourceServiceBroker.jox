    <JadeMethod name="auditIdDisplay" id="66d60ea3-ce37-4099-8571-726c706bff8a">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return 'Voyage Resource Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Voyage Resource Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="40436698-87c2-4847-bbb0-0895eaf50c78">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up


*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;

	if self.myResource &lt;&gt; null then
		tmpStr := self.getResourceClassName;
		txt := txt &amp; app.getErrorString(Resource_types) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myTransMap &lt;&gt; null then
		tmpStr := self.myTransMap.name;
		txt := txt &amp; 'Voyage Map' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTransMap.myBank &lt;&gt; null then
		tmpStr := self.myTransMap.myBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
