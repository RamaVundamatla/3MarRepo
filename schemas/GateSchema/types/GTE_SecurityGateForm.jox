    <JadeMethod name="translateForm" id="6383759c-6a70-4a63-a95a-950dfe1bf0e4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:04:21.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019432, locale);
	btnDelete.translateBubbleHelp(Xlat_0019433, locale);
	btnDelete.translateCaption(Xlat_0019434, locale);
	btnDeparture.translateBubbleHelp(Xlat_0019435, locale);
	btnDeparture.translateCaption(Xlat_0019436, locale);
	btnExportCSVTV.translateCaption(Xlat_0019437, locale);
	btnFind.translateBubbleHelp(Xlat_0019710, locale);
	btnFind.translateCaption(Xlat_0019711, locale);
	btnNew.translateBubbleHelp(Xlat_0019438, locale);
	btnNew.translateCaption(Xlat_0019439, locale);
	btnPrint.translateCaption(Xlat_0019440, locale);
	btnRefresh.translateCaption(Xlat_0019441, locale);
	lblFindBAT.translateCaption(Xlat_0019712, locale);
	lblSearchDays.translateCaption(Xlat_0021380, locale);
	mnuCancelVisit.translateCaption(Xlat_0019442, locale);
	mnuColOrganiser.translateCaption(Xlat_0019443, locale);
	mnuContext.translateCaption(Xlat_0019444, locale);
	mnuDeparture.translateCaption(Xlat_0019445, locale);
	mnuInspect.translateCaption(Xlat_0019446, locale);
	mnuNewVisit.translateCaption(Xlat_0019447, locale);
end;</source>
    </JadeMethod>
