    <JadeMethod name="setupForm" id="819f912e-d5e4-43f2-bab9-db736277f754">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/08/2008	cnwrd1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
26/09/2013	cnwdap1	PAR #32552 Added measurement tables for the weight attributes
04/03/2014	cnwdap1	PAR #33638 Correct External / Internal measurement fields
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/
vars
	lengthType	: CM_MeasurementType;			// PAR #31155
	widthType	: CM_MeasurementType;
	heightType	: CM_MeasurementType;
begin

	inheritMethod();

	self.centreWindow();	//Par18122 Oct 2008

	//self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.toolbarStyle := self.ToolbarStyle_None;
	self.showToolbar := false;
	self.hasChanged := false;
	//self.height := 493;
	//self.width := 836;
	if self.isEdit then
		self.btnNext.visible := false;
		self.txtID.enabled := false;
	else
		self.btnNext.visible := true;
		self.btnNext.bubbleHelp:="Save Next";
		self.txtID.enabled := true;
		self.btnOk.left := self.btnOk.left -74;
		self.btnDamage.top :=self.btnDamage.top + 30 ; //27.02.2018 cnwma1 ChangeRequest #36813
		
	endif;

	self.myAssistant.comboBoxOperator( self.cmbOperator, null, null );
	self.myAssistant.comboBoxOperator( self.cmbOwner, null, null );
	self.myAssistant.comboBoxISOType( self.cmbISOType, null );
	self.myAssistant.comboBoxGenerator(self.cmbGenerator,true,false); //27.02.2018 cnwma1 ChangeRequest #36813
	self.loadComboBoxCoolingType();
	self.loadComboBoxVoltageType();
    
	self.cmbGenerator.visible := false ;//27.02.2018 cnwma1 ChangeRequest #36813
	self.lblGenerator.visible:=false   ; //27.02.2018 cnwma1 ChangeRequest #36813
	// PAR #31155 Show default measurement types in label captions, set up edit masks if needed
	lengthType := app.getDefaultMeasurementForType(Type_Length);					// PAR #31155
	widthType := app.getDefaultMeasurementForType(Type_Width);
	heightType := app.getDefaultMeasurementForType(Type_Height);
	//self.lblWeight.setCaptionForMeasurementType(Type_Weight);						// PAR #31155
	//self.lblMaxWeight.setCaptionForMeasurementType(Type_Weight);					// PAR #31155
	//self.lblExtHeight.setCaptionForMeasurementType(Type_Height);					// PAR #33638
	//self.lblExtLength.setCaptionForMeasurementType(Type_Length);					// PAR #33638
	//self.lblExtWidth.setCaptionForMeasurementType(Type_Width);					// PAR #33638
	//self.lblintHeight.setCaptionForMeasurementType(Type_Height);					// PAR #33638
	//self.lblIntlength.setCaptionForMeasurementType(Type_Length);					// PAR #33638
	//self.lblIntWidth.setCaptionForMeasurementType(Type_Width);					// PAR #33638
	//self.lblVolume.setCaptionForMeasurementType(Type_Volume);						// PAR #31155
	if lengthType.isFeetAndInches then												// PAR #31155
		self.txtExtLength.visible := false;											// PAR #31155
		self.txtIntLength.visible := false;											// PAR #31155
		self.txtFtExtLength.visible := true;										// PAR #31155
		self.txtFtIntLength.visible := true;										// PAR #31155
		self.txtFtExtLength.move(self.txtExtLength.left, self.txtExtLength.top, self.txtExtLength.width, self.txtExtLength.height); 
		self.txtFtIntLength.move(self.txtIntLength.left, self.txtIntLength.top, self.txtIntLength.width, self.txtIntLength.height); 
		self.txtFtExtLength.tabIndex := self.txtExtLength.tabIndex;					// PAR #31155
		self.txtFtIntLength.tabIndex := self.txtIntLength.tabIndex;					// PAR #31155
	endif;	
	if widthType.isFeetAndInches then												// PAR #31155
		self.txtExtWidth.visible := false;											// PAR #31155
		self.txtIntWidth.visible := false;											// PAR #31155
		self.txtFtExtWidth.visible := true;											// PAR #31155
		self.txtFtIntWidth.visible := true;											// PAR #31155
		self.txtFtExtWidth.move(self.txtExtWidth.left, self.txtExtWidth.top, self.txtExtWidth.width, self.txtExtWidth.height); 
		self.txtFtIntWidth.move(self.txtIntWidth.left, self.txtIntWidth.top, self.txtIntWidth.width, self.txtIntWidth.height); 
		self.txtFtExtWidth.tabIndex := self.txtExtWidth.tabIndex;					// PAR #31155
		self.txtFtIntWidth.tabIndex := self.txtIntWidth.tabIndex;					// PAR #31155
	endif;
	if heightType.isFeetAndInches then												// PAR #31155
		self.txtExtHeight.visible := false;											// PAR #31155
		self.txtIntHeight.visible := false;											// PAR #31155
		self.txtFtExtHeight.visible := true;										// PAR #31155
		self.txtFtIntHeight.visible := true;										// PAR #31155
		self.txtFtExtHeight.move(self.txtExtHeight.left, self.txtExtHeight.top, self.txtExtHeight.width, self.txtExtHeight.height); 
		self.txtFtIntHeight.move(self.txtIntHeight.left, self.txtIntHeight.top, self.txtIntHeight.width, self.txtIntHeight.height); 
		self.txtFtExtHeight.tabIndex := self.txtExtHeight.tabIndex;					// PAR #31155
		self.txtFtIntHeight.tabIndex := self.txtIntHeight.tabIndex;					// PAR #31155
	endif;
	
	self.txtWeight.setup(Type_Weight, self.backColor);								// PAR #32552
	self.txtWeight.tabKey := J_key_Tab;												// PAR #32552
	self.txtMaxWeight.setup(Type_Weight, self.backColor);							// PAR #32552
	self.txtMaxWeight.tabKey := J_key_Tab;											// PAR #32552
	self.txtVolume.setup(Type_Volume, self.backColor);								// PAR #32552
	self.txtVolume.tabKey := J_key_Tab;												// PAR #32552
	
	self.txtExtHeight.setup(Type_Height, self.backColor);							// PAR #33638
	self.txtExtHeight.tabKey := J_key_Tab;											// PAR #33638
	self.txtExtLength.setup(Type_Length, self.backColor);							// PAR #33638
	self.txtExtLength.tabKey := J_key_Tab;											// PAR #33638
	self.txtExtWidth.setup(Type_Width, self.backColor);								// PAR #33638
	self.txtExtWidth.tabKey := J_key_Tab;											// PAR #33638
	self.txtIntHeight.setup(Type_Height, self.backColor);							// PAR #33638
	self.txtIntHeight.tabKey := J_key_Tab;											// PAR #33638
	self.txtIntLength.setup(Type_Length, self.backColor);							// PAR #33638
	self.txtIntLength.tabKey := J_key_Tab;											// PAR #33638
	self.txtIntWidth.setup(Type_Width, self.backColor);								// PAR #33638
	self.txtIntWidth.tabKey := J_key_Tab;											// PAR #33638
	
	self.myAssistant.listTableStopsTableSysUser(self.lstTblStops, app.myRoot.allCargoTypesById[ TI_CargoType_Container ], self.allStopsForUser, true);
	self.myAssistant.listTableToDoTasksSysUser( self.lstTblToDoTasks, app.myRoot.allCargoTypesById[ TI_CargoType_Container ], self.allToDoTasksForUser );	
	//self.tblDamageInit();

	self.beginClassNotification(CM_TIMasterContainer, false, Any_System_Event, Response_Continuous, null); //cnwrd1 par #18127 23.1.09
	
	self.loadData();
	
	self.btnDamage.visible := false;  // ### TFS 55313 08NOV2022 NAVAB1 - Recorded damage is not used anywhere
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e2c1e4a4-3972-453c-852c-98bf9cabd175">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	cnwrd1	Initial creation
//cnwrd1 par #18127 23.1.09
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

begin


	
		if eventType = Object_Update_Event and theObject = self.myTiMaster then
				app.msgBox('ISO Container Maintanance Screen: Another user has updated the ISO Container you currently have selected.' &amp; CrLf &amp;
							'The ISO Container must now be re-loaded.', 'ISO Container updated', MsgBox_Exclamation_Mark_Icon);
				self.loadData();
		elseif eventType = Object_Delete_Event and theObject = self.myTiMaster then
			app.msgBox('Another user has deleted the ISO Container you are currently editing. The editing must now be cancelled','ISO Container deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.unloadForm();
		endif;
	
	

	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="71325884-4c21-4bf9-ac2b-0e3daa317aab">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 March 2018 09:04:22.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009985, locale);
	btnCancel.translateCaption(Xlat_0009986, locale);
	btnDamage.translateCaption(Xlat_0011976, locale);
	btnDelete.translateBubbleHelp(Xlat_0009987, locale);
	btnDelete.translateCaption(Xlat_0009988, locale);
	btnNext.translateCaption(Xlat_0009989, locale);
	btnOk.translateCaption(Xlat_0009990, locale);
	grpBasic.translateCaption(Xlat_0009991, locale);
	grpExternal.translateCaption(Xlat_0009992, locale);
	grpInternal.translateCaption(Xlat_0009993, locale);
	grpReefer.translateCaption(Xlat_0009994, locale);
	lCommunicating.translateCaption(Xlat_0009995, locale);
	lCoolingType.translateCaption(Xlat_0009996, locale);
	lCreateRange.translateCaption(Xlat_0009997, locale);
	lEnd.translateCaption(Xlat_0009998, locale);
	lHeavyLift.translateCaption(Xlat_0009999, locale);
	lOverwrite.translateCaption(Xlat_0010000, locale);
	lStart.translateCaption(Xlat_0010001, locale);
	lVoltageType.translateCaption(Xlat_0010002, locale);
	lblExtHeight.translateCaption(Xlat_0010004, locale);
	lblExtLength.translateCaption(Xlat_0010005, locale);
	lblExtWidth.translateCaption(Xlat_0010006, locale);
	lblGenerator.translateCaption(Xlat_0022222, locale);
	lblID.translateCaption(Xlat_0010007, locale);
	lblISOType.translateCaption(Xlat_0010008, locale);
	lblIntWidth.translateCaption(Xlat_0010009, locale);
	lblIntlength.translateCaption(Xlat_0010010, locale);
	lblMaxWeight.translateCaption(Xlat_0010011, locale);
	lblOperator.translateCaption(Xlat_0010012, locale);
	lblOwner.translateCaption(Xlat_0010013, locale);
	lblStops.translateCaption(Xlat_0010014, locale);
	lblToDoTasks.translateCaption(Xlat_0010015, locale);
	lblVerified.translateCaption(Xlat_0016088, locale);
	lblVolume.translateCaption(Xlat_0010016, locale);
	lblWeight.translateCaption(Xlat_0010017, locale);
	lblintHeight.translateCaption(Xlat_0010018, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="bfb101a7-5431-4688-a283-f033ad16292d">
        <updating/>
        <source>unloadForm(): Boolean updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		30 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	self.allDamageInstancesByPos.purge();
	return inheritMethod();
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRangeDetails" id="92ffa033-0454-4849-9208-2af15d639310">
        <source>validateRangeDetails(_rangeStart, _rangeEnd : String; _totalCount, _rStart, _rEnd : Integer output ; _rangeTxt : String output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2008	cnwrd1	Initial creation

*/

vars
	alphaStart,alphaEnd : String;
	numStart,numEnd : String;
	iStart, iEnd : Integer;
begin

	if _rangeStart.length &lt;&gt; 11 then 
		
		return false;
	endif;
	
	if _rangeEnd.length &lt;&gt; 11 then 
	
		return false;
	endif;
	
	
	alphaStart := _rangeStart[1:4];	

	
	alphaEnd := _rangeEnd[1:4];	

	
	if alphaStart &lt;&gt; alphaEnd then
	//	write "Cont range :" &amp; tmpContRange.asStringJMT &amp; " failed alpha start/end check";
	//	continue;
		return false;
	endif;
	

	
	numStart := _rangeStart[5:7];	

	
	numEnd := _rangeEnd[5:7];	

	
	if not numStart.isInteger then
	
		return false;
	endif;
	
	if not numEnd.isInteger then
	
		return false;
	endif;	
	
	iStart := numStart.Integer;
	iEnd := numEnd.Integer;
	
	if iStart &gt; iEnd then
		
		return false;
	endif;
	
	_rStart := iStart;
	_rEnd := iEnd;
	_rangeTxt := alphaStart;
	_totalCount := iEnd - iStart;
	
	return true;
epilog

end;</source>
        <Parameter name="_rangeStart" type="String"/>
        <Parameter name="_rangeEnd" type="String"/>
        <Parameter name="_totalCount" type="Integer" usage="output"/>
        <Parameter name="_rStart" type="Integer" usage="output"/>
        <Parameter name="_rEnd" type="Integer" usage="output"/>
        <Parameter name="_rangeTxt" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
