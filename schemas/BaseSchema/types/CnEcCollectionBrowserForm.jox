    <JadeMethod name="btnCancel_click" id="99b69384-ff00-48a7-92b6-991f07a147b0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Closing browser...");
	modalResult	:=	0;
	unloadForm();
epilog
	self.statusMsg("");
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClearAll_click" id="92dd34bf-ec1c-4045-9524-82ed11a32b13">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearAll_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Clearing all selected objects...');
	tblObjects.clearAllSelected;
	btnOk.enabled	:=	true;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="5ce0dad4-5de5-4d7f-a282-a0b5296c6325">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Updating selected object(s)...');

	if self.formValidate() then
		self.formUpdate();
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formLoad" id="503ef221-18c9-4381-bb58-6eeed6cac4bb">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult				:=	0;
	self.caption			:=	self.caption &amp; ': ' &amp; self.myClass.name;
	lblInfo.caption			:=	null;
	self.canUpdate			:=	self.isEditingAllowed();
	self.viewObjectsByOid	:=	self.getViewObjectsByOid();

	if self.myClass = null then
		app.msgBox("The reference to the class null.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		unloadForm();
		return;
	endif;

	if self.isCollection then
		self.loadCollection(self.myClass);
	elseif self.isReference then
		self.loadReference(self.myClass);
	endif;

	if (not self.canUpdate) or (self.isBrowseOnly) then
		btnClearAll.visible	:=	false;
		btnOk.visible		:=	false;
	endif;

	if self.isManual then
		lblManualWarning.visible	:=	true;
		self.warningColor			:=	lblManualWarning.foreColor;
		beginTimer(500, Timer_Continuous, 0);
	else
		lblManualWarning.visible	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formUpdate" id="2f744819-d0f9-411f-8d7a-0804a43e1e84">
        <updating/>
        <source>formUpdate() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (self.isCollection) then
		self.updateCollection();
	elseif (self.isReference) then
		self.updateReference();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
