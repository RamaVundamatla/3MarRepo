    <JadeMethod name="doDisplayEmailForm" id="dc08131a-5423-444d-92d3-916d320ab65a">
        <source>doDisplayEmailForm(_email : CM_EmailTemplate input) : Boolean protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	attachFrm 		: CMUI_EmailSetupForm;
	sender			: String;
	
begin

//	if not app.myRoot.canDo(PmPDFBackground) then //par 19494 cnwrd1 9.6.09
//		return false;
//	endif;
	
	app.mousePointer := MousePointer_Default;
				
	//attachFrm := app.loadForm(CMUI_EmailSetupForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EmailSetupForm; //par 19494 cnwrd1 9.6.09

	create attachFrm; //par 19494 cnwrd1 9.6.09
	attachFrm.myTerminal := self.myTerminal;
	attachFrm.createMyAssistant(CMUI_Assistant);
	
	if attachFrm = null then
		return false;
	endif;
	
	attachFrm.centreWindow;
	attachFrm.initEmailObject(_email, false);
	
	if attachFrm.showModal = MsgBox_Return_OK then
		return true;
	endif;
	return false;
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_email" type="CM_EmailTemplate" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEmailAsPDF" id="6b804c4f-cc37-4ce9-86ca-8d3eb1fe6031">
        <source>doEmailAsPDF() protected;
// -------------------------------------------
// Created 01 September 2004 by cnwdvb1
// -------------------------------------------
vars

	email	: CM_EmailTemplate;
	name	: String;
begin

	create email transient;
	if not self.doDisplayEmailForm(email) then
		return;
	endif;

	if self.aMyJadeReport.description = null then
		if email.subject = null then
			name := app.getErrorString(Report);
		else
			name := email.subject;
		endif;
	else
		name := self.aMyJadeReport.description;
	endif;
	
	app.myTrxCA.trxCreatePDFEmailRequest(app.myPassport.myUser, self.myTerminal, name, self.aMyJadeReport, email, app.myPassport);

	
epilog	
	delete email;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="de7c0829-79b6-4eb4-be73-d29bebca72aa">
        <updating/>
        <source>doResize() updating;
/*
------------------------------------------------------------------------
Created:			03 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	inheritMethod();
	picBackground.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height.Integer);

	self.getAPage(aCurrentPage);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4372d2a1-81f5-4444-933d-96374f52bd54">
        <source>doSave() : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	folderPicker		: CMUI_OrganizeMenu;
	newMenuUserReport	: CM_MenuUserReport;
	jadeReport			: JadeReport;
	desc, name			: String;
	root				: CM_MenuRoot;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	
	jadeReport := self.aMyJadeReport;
	if jadeReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'JadeReport is null');
		return false;
	endif;
	
	//th2 PAR 14644
	app.mousePointer := Idle;
	create folderPicker transient;
	
	folderPicker.lstBox.allMenuRoots.clear();
	root	:= app.getMyUser().myMenuRootBGRSaved;
	folderPicker.lstBox.allMenuRoots.add(root);
	
	folderPicker.caption := 'Select Folder...';
	folderPicker.showModal;
	if folderPicker.modalResult &lt;&gt; IDOK or folderPicker.mySelectedMenuEntity = null then
		return false;
	endif;
	

	
	desc := jadeReport.description;

	if desc = null then
		desc := 'Print preview';
	endif;
	
	name := desc;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateMenuUserReportSaved(	name,
												desc,
												root,
												folderPicker.mySelectedMenuEntity,
												jadeReport,
												app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Save Jade Report', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog	

	delete folderPicker;
	app.mousePointer := Idle;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doScrollPage" id="d8145464-4de2-4e76-a3d4-375dbb3f3f40">
        <updating/>
        <source>doScrollPage(_isDown:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 December 2005 by cnwdad1
//
// Purpose:		Scrolls the page when the up/down arrow keys are pressed.
//
// Parameters:	_isDown - True if the page is scrolled down.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	scrollMin		: Integer;
	scrollMax		: Integer;
	scrollSmall		: Integer;
	scrollLarge		: Integer;
	verticalPos		: Integer;
	scrollbars 		: Integer; // cnwrd1 30.7.2008 par #17634 
	
begin
	verticalPos	:=	picBackground.scrollVertPos;
	
	// cnwrd1 30.7.2008 par #17634 start
	if picBackground.scrollBars = ScrollBars_None then 
		return;
	endif;
	
	if picBackground.scrollBars = ScrollBars_Both then
		scrollbars := 2;
		else
		scrollbars := picBackground.scrollBars;
	endif;

	//picBackground.getScrollRange(	picBackground.scrollBars, // cnwrd1 30.7.2008 par #17634 --
	picBackground.getScrollRange(	scrollbars,
									scrollMin,
									scrollMax,
									scrollSmall,
									scrollLarge);
	// cnwrd1 30.7.2008 par #17634 end
	
	if _isDown then
		if verticalPos = scrollMax then
			return;		// Do nothing, already at the bottom.
		endif;
		
		if (verticalPos + scrollSmall) &gt; scrollMax then
			picBackground.scrollVertPos	:=	scrollMax;
		else
			picBackground.scrollVertPos	:=	verticalPos + scrollSmall;
		endif;
	else
		if verticalPos = scrollMin then
			return;		// Do nothing, already at the top.
		endif;
		
		if (verticalPos - scrollSmall) &lt; scrollMin then
			picBackground.scrollVertPos	:=	scrollMin;
		else
			picBackground.scrollVertPos	:=	verticalPos - scrollSmall;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isDown" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findString" id="4176ef16-87f5-4d7c-8b79-818351270961">
        <updating/>
        <source>findString(bFirst:Boolean; _goBack : Boolean) : Boolean updating;
/*
------------------------------------------------------------------------
Created:			26 May 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	x 	  : Integer;
	y 	  : Integer;
	bin   : Binary;	
	str   : String;
	point : Point;
begin
	if bFirst then
		self.aAllFoundPositions.clear;
		self.aBackwardsCounter := 0;
	endif;
	
	if _goBack then
		if self.aBackwardsCounter &lt; 1 then
			self.aAllFoundPositions.clear;
			btnFindPrev.enabled := false;
			aV_findNextPage := 1;
			self.getAPage(aCurrentPage); // refresh page to remove previous highlights
			return false;		
		elseif self.aBackwardsCounter = 1 then
			btnFindPrev.enabled := false;
		endif;
	endif;
	
	while aV_findNextPage &lt;= self.aMyJadeReport.pageCount do
		bin := self.aMyJadeReport.getPage(aV_findNextPage).pageImage;
		
		aV_findPageImage := app.printer.sendMsgWithIOParamsJMT('_findStringLocal', bin, aV_findString, aV_findCased, aV_findWholeWords,
						   			  		aV_findNextPagePos, aV_findNextCharPos, x, y).Binary;
		if aV_findPageImage &lt;&gt; null then
			break;
		endif;
		
		aV_findNextPagePos := 0;
		aV_findNextCharPos := 0;
		aV_findNextPage := aV_findNextPage + 1;
	endwhile;
	// if not found - tell user
	if aV_findPageImage = null then 
		aV_findNextPage := 1;
		self.getAPage(aCurrentPage); // refresh page to remove previous highlights

  		if bFirst then
	  		btnFindNext.enabled := false;
			btnFindPrev.enabled := false;
			str := app.getErrorString2(FindStringNotFound, null, aV_findString);
		else
			btnFindPrev.enabled := true;
			str := "No further ";
			str := app.getErrorString2(FindStringNotFound, 'further', aV_findString);
		endif;
			   
  		if aV_findWholeWords then
  			str := str &amp; CrLf &amp; CrLf &amp; app.getErrorString(FindStringWholeWord);
		endif;  			
  			
		app.msgBox(str, app.getErrorString(Print_Preview_Find_Caption), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	//---------------------
	// found
	//---------------------
	//Store WHERE we found it (for working backwards)
	if not _goBack then
		point.set(aV_findNextPage, aV_findNextPagePos);
		self.aAllFoundPositions.add(point);
		self.aBackwardsCounter := self.aBackwardsCounter +1;
	endif;
	
	btnFindNext.enabled := true;

	aCurrentPage := aV_findNextPage;
	//display the page	
	self.getAPage(aCurrentPage);

	if aZoomScale &lt;&gt; 1 then
		aZoomScale := 1; // so stays expanded
		picPreview_mouseDown(picPreview, 1, 0, x, y);
	endif;
	
	return true;

end;</source>
        <Parameter name="bFirst" type="Boolean"/>
        <Parameter name="_goBack" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAPage" id="6a0b5ff5-f3af-48cc-9453-06d792b6d01e">
        <updating/>
        <source>getAPage(_pageNum : Integer) : Boolean updating;
/*
------------------------------------------------------------------------
Created:			03 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

	//	Searches through the control array for the desired page
	//	Each 'header' is the start of a new page

vars
	pages		: Integer;
	picWidth	: Integer;
	picHeight	: Integer;
	lft			: Integer;
begin

	app.mousePointer := Busy;

	if self.aZoomScale = 0 then
		picPreview.mouseCursor := picCursors.pictureDisabled;
	else
		picPreview.mouseCursor := picCursors.picture;
	endif;

	pages := self.aMyJadeReport.pageCount;
		// if have find image when data is local - display that
	if aV_findNextPage = aCurrentPage and aV_findPageImage &lt;&gt; null then
		picPreview.picture := aV_findPageImage;
	else
		aV_findPageImage      := null;
		if _pageNum &lt; 1 or _pageNum &gt; pages then
			picPreview.picture := null;
		else
			picPreview.picture := self.aMyJadeReport.getPage(_pageNum).pageImage;
		endif;
	endif;
	
	if aZoomScale &lt;&gt; 0 then
		//shrink
		aMaxScrollVert := 0;
		aMaxScrollHoriz := 0;
		self.picBackground.scrollBars := 0;		
		self.picPreview.stretch := Picture.Stretch_None;
		self.picPreview.move(0, 0, picBackground.clientWidth, picBackground.clientHeight);
		self.picPreview.stretch := Picture.Stretch_Proportional;

		if picPreview.width &lt; picBackground.clientWidth then
			self.picPreview.left := (picBackground.clientWidth - picPreview.width) / 2;
//			self.picPreview.width := (picBackground.clientWidth / 1.5).Integer;
		else
			picPreview.top := (picBackground.clientHeight - picPreview.height) / 2;
		endif;
	else

		//Full size
		picWidth  := picPreview.pictureWidth;
		picHeight := picPreview.pictureHeight;

		picBackground.scrollBars := 3;
		picPreview.move(0, 0, picWidth, picHeight);

		aMaxScrollHoriz := picWidth - picBackground.clientWidth;

		if aMaxScrollHoriz &lt;= 0 then
			picBackground.scrollBars := ScrollBars_Vertical;
			picPreview.left := (picBackground.clientWidth - picWidth) / 2; 
			aMaxScrollHoriz := 0;
		else
			aMaxScrollHoriz := aMaxScrollHoriz + 20;
			picBackground.setScrollRange(1, 0, aMaxScrollHoriz, 10, 100);
		endif;

		aMaxScrollVert := picHeight - picBackground.clientHeight + 20;
		if aMaxScrollVert &lt;= 0 then
			aMaxScrollVert := 20;
		endif;

		picBackground.setScrollRange(2, 0, aMaxScrollVert, 10, 100);
		picBackground.scrollHorzPos := 0;
		picBackground.scrollVertPos := 0;
	endif;

	self.btnNext.enabled := (pages &gt; 1 and _pageNum &lt; pages );
	self.btnFirst.enabled := ((pages &gt; 1) and aCurrentPage &lt;&gt; 1);
	self.btnLast.enabled := (pages &gt; 1 and _pageNum &lt; pages );
	self.btnSpecific.enabled := (pages &gt; 2);

	aCurrentPage := _pageNum;
	self.frm_LblPgDetail.caption := "Page " &amp; aCurrentPage.String &amp; " of " &amp; pages.String;

epilog
	app.mousePointer := Idle;
	return true;
end;</source>
        <Parameter name="_pageNum" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="519a5fcc-f6f8-4dee-8077-2bb9a960ea3a">
        <updating/>
        <source>init(_report : JadeReport; _eraseReport : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	regKeys : IntegerArray;
begin
	if _report = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No Report Reference", null, null);
		return;
	endif;

	create regKeys transient;
	regKeys.add(J_key_PageUp);
	regKeys.add(J_key_PageDown);
	regKeys.add(J_key_End);
	regKeys.add(J_key_Home);
	regKeys.add(J_key_UpArrow);
	regKeys.add(J_key_DownArrow);
	self.addRegisteredKeys(regKeys);


	self.aMyJadeReport := _report;
	self.aEraseOnClose := _eraseReport;

epilog
	delete regKeys;
end;</source>
        <Parameter name="_report" type="JadeReport"/>
        <Parameter name="_eraseReport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="c16df8b7-c64f-4d86-b48f-2e3d785b5d4d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_PageDown and btnNext.enabled then
		btnNext_click(self.btnCancelBase);
	elseif keyCode = J_key_PageUp and btnPrev.enabled then
		btnPrev_click(self.btnCancelBase);
	elseif keyCode = J_key_Home and btnFirst.enabled then
		btnFirst_click(self.btnCancelBase);
	elseif keyCode = J_key_End and btnLast.enabled then
		btnLast_click(self.btnCancelBase);
	elseif keyCode = J_key_UpArrow then
		self.doScrollPage(false);
	elseif keyCode = J_key_DownArrow then
		self.doScrollPage(true);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="picPreview_mouseDown" id="4e70b6af-d43e-42e9-b9d6-2ac00f798f5f">
        <controlMethod name="Picture::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>picPreview_mouseDown(pict: Picture input; button: Integer; shift: Integer; xin: Real; yin: Real) updating;
/*
------------------------------------------------------------------------
Created:			05 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	lft : Integer;
	tp  : Integer;
	x   : Real;
	y	: Real;
	ratiox:Real;
	ratioy:Real;
begin

	if button &lt;&gt; 1 then	// only left button
		return;
	endif;

	if aZoomScale = 0 then
		btnReduce_click(btnReduce);
		return;
	endif;

	x := xin;
	y := yin;

	if aZoomScale &lt;&gt; 0  then
		ratiox := x / picPreview.width;
		ratioy := y / picPreview.height;
		btnEnlarge_click(btnReduce);
		// convert position into point relative to expanded image
		x := picPreview.width  * ratiox;
		y := picPreview.height * ratioy;
	endif;

	lft := (x - picBackground.width/2).Integer;
	if lft &lt; 0 then
		lft := 0;
	elseif lft &gt; aMaxScrollHoriz then
		lft := aMaxScrollHoriz;
	endif;

	picBackground.scrollHorzPos := lft;

	tp := (y - picBackground.height/2).Integer;
	if tp &lt; 0 then
		tp := 0;
	elseif tp &gt; aMaxScrollVert then
		tp := aMaxScrollVert;
	endif;

	picBackground.scrollVertPos := tp;

end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="xin" type="Real"/>
        <Parameter name="yin" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="44f59fac-14b1-4d2b-9841-2276ce484ff0">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	HDG = 'Print Preview - ';
vars

begin
	inheritMethod();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;

	//Show the first page in the myJadeReport's list of pages.
	if self.aMyJadeReport = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'No jadeReport class', null, null);
		return;
	endif;
	
	self.picBackground.ignoreSkin	:= true;
	self.picPreview.ignoreSkin	:= true;

	self.caption := HDG &amp; self.aMyJadeReport.description;
	//------------------------
	//Pop up the first page.
	//------------------------
	self.aCurrentPage := 1;
	self.picPreview.cachePictures := false;	// no caching of print preview pages
		
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="28d29f80-60b3-4d01-9521-9d8ff27cb7f4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017443, locale);
	btnEmail.translateBubbleHelp(Xlat_0000672, locale);
	btnEmail.translateCaption(Xlat_0000684, locale);
	btnEnlarge.translateBubbleHelp(Xlat_0000673, locale);
	btnEnlarge.translateCaption(Xlat_0000685, locale);
	btnFind.translateBubbleHelp(Xlat_0000674, locale);
	btnFind.translateCaption(Xlat_0000686, locale);
	btnFindNext.translateBubbleHelp(Xlat_0000675, locale);
	btnFindNext.translateCaption(Xlat_0000687, locale);
	btnFindPrev.translateBubbleHelp(Xlat_0000676, locale);
	btnFindPrev.translateCaption(Xlat_0000688, locale);
	btnFirst.translateBubbleHelp(Xlat_0000677, locale);
	btnFirst.translateCaption(Xlat_0000689, locale);
	btnLast.translateBubbleHelp(Xlat_0000678, locale);
	btnLast.translateCaption(Xlat_0000690, locale);
	btnNext.translateBubbleHelp(Xlat_0000679, locale);
	btnNext.translateCaption(Xlat_0000691, locale);
	btnPrev.translateBubbleHelp(Xlat_0000680, locale);
	btnPrev.translateCaption(Xlat_0000692, locale);
	btnPrint.translateBubbleHelp(Xlat_0000681, locale);
	btnPrint.translateCaption(Xlat_0000693, locale);
	btnPrintSelect.translateBubbleHelp(Xlat_0000668, locale);
	btnPrintSelect.translateCaption(Xlat_0000669, locale);
	btnReduce.translateBubbleHelp(Xlat_0000682, locale);
	btnReduce.translateCaption(Xlat_0000694, locale);
	btnSpecific.translateBubbleHelp(Xlat_0000683, locale);
	btnSpecific.translateCaption(Xlat_0000695, locale);
	frm_LblPgDetail.translateCaption(Xlat_0000667, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="794fc709-7eb2-4f87-8c5c-a611f5478520">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	inheritMethod;
epilog
	if self.aEraseOnClose then
		delete self.aMyJadeReport;
	endif;
end;</source>
    </JadeMethod>
</GUIClass>
