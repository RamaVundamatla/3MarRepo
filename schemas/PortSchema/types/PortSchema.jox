    <JadeMethod name="getInvoiceCalcTypeLabel" id="9963be5a-13a9-41b3-a610-117771b162c0">
        <source>getInvoiceCalcTypeLabel(_const : Integer;_lable : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TagLabel = "LABEL";
	TagCaption = "CAPTION";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	terminal	: CM_Terminal;
	bank		: CM_Bank;
	calTypeValue, descPos, catPos : Integer;
	lenTagLabel, len : Integer;
	label : String;

begin
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return null;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return null;
	endif;

	lenTagLabel := TagLabel.length;
	
	foreach const in category.getConstants do
		calTypeValue := const.GlobalConstant.valueAsInteger;
		if _const = calTypeValue then
			if _lable then
				label := const.text.String.cnEcGetTagValueOfName(TagLabel);
			else
				label := const.text.String.cnEcGetTagValueOfName(TagCaption);
			endif;
			if calTypeValue = INV_CALC_TYPE_DAYS_ONSITE_AT then
				// 35872 use default bank of 1st terminal
				terminal := self.myRoot.allTerminals.first;
				if terminal &lt;&gt; null then
					bank := terminal.getDefaultCompanyBank();
					if bank &lt;&gt; null then
						label := label &amp; " " &amp; bank.onsiteStorageChargeTime.String;
					endif;
				endif;
			endif;
			return label;
		endif;
	endforeach;
end;</source>
        <Parameter name="_const" type="Integer"/>
        <Parameter name="_lable" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceChargeTypeString" id="0fbd5fe4-d588-4d67-aa31-bc6b2c3051ce">
        <source>getInvoiceChargeTypeString(_type : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _type = CM_InvoiceLineDesc.CHARGE_OPERATOR then
		return app.getErrorString(CM_Cargo_Operator);
	elseif _type = CM_InvoiceLineDesc.CHARGE_CONSIGNEE then
		return app.getErrorString(Consignee);
	elseif _type = CM_InvoiceLineDesc.CHARGE_CONSIGNOR then
		return app.getErrorString(CM_Consignor);
	elseif _type = CM_InvoiceLineDesc.CHARGE_SHIP_OPERATOR then
		return app.getErrorString(CM_Ship_Operator);
	elseif _type = CM_InvoiceLineDesc.CHARGE_BUSINESS_UNIT then
		return app.getErrorString(CM_Business_Unit);
	elseif _type = CM_InvoiceLineDesc.CHARGE_CUSTOMS_AGENT then
		return app.getErrorString(CM_Customs_Agent);
	elseif _type = CM_InvoiceLineDesc.CHARGE_FREIGHTFWDR then
		return app.getErrorString(FreightForwarder);
	elseif _type = CM_InvoiceLineDesc.CHARGE_EVENT then
		return "Event Type";
	endif;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceProcess" id="834b9acb-f296-4b44-8ef4-b5b03023bfe2">
        <source>getInvoiceProcess(_terminal : CM_Terminal; _invoice : CM_Invoice) : CM_InvoiceProcess;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jan2019	jlgsl4	TFS 39618 - Linx invoice process

*/

vars

begin
	if _invoice = null then // use default invoice process as set for terminal
		return _terminal.getDefaultCompanyBank().getMyInvoiceProcess;
	else	// use invoice's invoice process
		return _invoice.getMyInvoiceProcess;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="CM_InvoiceProcess"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatusString" id="04a1f6de-7d62-4741-bc08-7416eafdd79c">
        <source>getInvoiceStatusString(_process : CM_InvoiceProcess; _status : Integer) : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 03/04/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 31/10/2018   cnwma1		ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
//----------------------------------------------------------------------
vars
	invoiceStatus : CM_InvoiceStatus; // TFS 39618
	invoiceProcess : CM_InvoiceProcess; // TFS 39618
begin
	invoiceProcess := _process; // TFS 39618
	if invoiceProcess = null then // TFS 39618 - use 'Master Terminal Default' Process
		// TFS 39618 PATCH 1 invoiceProcess := CM_InvoiceProcessDefault.firstInstance; // TFS 39618
		
		// TFS 39618 PATCH 1
		foreach invoiceStatus in app.myRoot.allInvoiceStatuses do
			if invoiceStatus.id = _status then
				return invoiceStatus.description;
			endif;
		endforeach;
		
		
	endif; // TFS 39618
	if _status = CM_Invoice.INVOICE_ALL_STATUS then
		return app.getErrorString(CM_Any_Status);
	/*elseif _status = CM_Invoice.INVOICE_SUSPENSE then
		return app.getErrorString(Suspense);
	elseif _status = CM_Invoice.INVOICE_OPEN then
		return app.getErrorString(Open_GC);
	elseif _status = CM_Invoice.INVOICE_PENDING then
		return app.getErrorString(Pending);
	elseif _status = CM_Invoice.INVOICE_POSTED then
		return app.getErrorString(Posted);
	elseif _status = CM_Invoice.INVOICE_VOID then
		return app.getErrorString(Void);
	elseif _status = CM_Invoice.INVOICE_POSTED_REVERSE then	//01 Sep 2017	NDL	TFS 6759
		return app.getErrorString(Posted_returned);
	elseif _status = CM_Invoice.INVOICE_POSTED_CREDIT then	//01 Sep 2017	NDL	TFS 6759
		return app.getErrorString(Posted_credit);		
	elseif _status = CM_Invoice.INVOICE_PREPEND then			// TFS 37560
		return app.getErrorString(Prepend);						// TFS 37560
	elseif _status = CM_Invoice.INVOICE_DISPUTED then			// TFS 37560
		return app.getErrorString(Disputed);					// TFS 37560
	elseif _status = CM_Invoice.INVOICE_PENDING_REVERSE then    // 31/10/2018   cnwma1 TFS# 41703
		return app.getErrorString(Pending_returned);*/
	elseif _status = CM_Invoice.INVOICE_SEND_WSDL112 then	//06 May 2019	NDL	TFS 44248
		return "SEND_WSDL112";
	else
		invoiceStatus := invoiceProcess.allStatuses[_status]; // TFS 39618
		if invoiceStatus &lt;&gt; null then // TFS 39618
			return invoiceStatus.description; // TFS 39618
		endif; // TFS 39618	
	endif;
	
	return null;

epilog
end;</source>
        <Parameter name="_process" type="CM_InvoiceProcess"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
