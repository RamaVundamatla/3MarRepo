    <JadeMethod name="causeUpdateDisplayEvents" id="ecd7f781-437d-408c-abbd-6bff1947c404">
        <source>causeUpdateDisplayEvents(_theTI : CM_TrackedItem; _lcArray : CM_LCArray) protected;
//--------------------------------------------------
// Created:	30 January 2004 By: cnwgd1
//--------------------------------------------------
// Purpose: To remove duplicated code and to use the event manager
// to prevent duplicate notifications from being sent that can
// subsequently cause performance issues across the network and in the GUI
vars
	locnCntrl : CM_LocationsController;
	theWagon : CM_Wagon;
	theEvent : Integer;
begin
	if _theTI = null then
		app.raiseCMException1(ERR_NO_OBJECT, '_theTI reference', null, null);
		return;
	endif;

	if _lcArray = null then
		app.raiseCMException1(ERR_NO_OBJECT, '_lcArray reference', null, null);
		return;
	endif;	

	// PAR 20329
	if _theTI.myPrimaryActualLocation &lt;&gt; null then
		if _theTI.myPrimaryActualLocation.isWagon() then
			theWagon := _theTI.myPrimaryActualLocation.CM_WagonController.myWagon;
		//	theEvent := theWagon.myTerminal.getTerminalEvent(Wagon_Update_Event);
			theEvent := theWagon.getTerminal.getTerminalEvent(Wagon_Update_Event);	//07 Nov 2014	NDL	Par 35087
			app.myEventManager.createSingleObjInfoNoteEvt(theWagon, theEvent, theWagon);
		endif;
	endif;
	
	foreach locnCntrl in _lcArray do
	
		if CM_SlotController.hasInstance(locnCntrl) then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage,
				locnCntrl.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), locnCntrl);
		elseif locnCntrl.myTerminalArea &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.myTerminalArea, 
				locnCntrl.myTerminal.getTerminalEvent(EVENT_TI_MOVE),  // PAR 10328 AKB2005JUL
				locnCntrl);
		endif;
	endforeach;

	foreach locnCntrl in _theTI.allLocations do

		if CM_SlotController.hasInstance(locnCntrl) then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage,
				locnCntrl.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), locnCntrl);

		elseif CM_StackController.hasInstance(locnCntrl) 
		or CM_LogController.hasInstance(locnCntrl) 
		or CM_WarehouseRowController.hasInstance(locnCntrl) 
		or CM_BlockController.hasInstance(locnCntrl)
		or CM_RTGController.hasInstance(locnCntrl) //epr CCMS 1076 24/8/09 noticed notes for RTG areas weren't working for refresh of the source location of the move
		or CM_RoRoController.hasInstance(locnCntrl) // cnwjk3 ccms 1018 28/01/10
		then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.myTerminalArea,
				locnCntrl.myTerminal.getTerminalEvent(EVENT_TI_MOVE), locnCntrl); // PAR 10328 AKB2005JUL
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_lcArray" type="CM_LCArray"/>
    </JadeMethod>
