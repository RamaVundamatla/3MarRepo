    <JadeMethod name="setupForm" id="565ac246-a37a-4260-af2c-4af96f837715">
        <updating/>
        <source>setupForm() updating;
//07 January 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 15/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 19/12/2022	jlika1		TFS 55584 HS Code Combobox Usuage
vars

begin
	inheritMethod();

	self.setupMeasurementControls;					// PAR #31155
	self.modalResult := IDCANCEL;
	//self.loadConsigneeConsignorCombo();
	self.loadCommodityCombo(true);
	self.loadHSCodeCombo();
	if self.mode = Mode_Update or self.myCurrentBOLItem &lt;&gt; null then
		self.loadBOLItem();
	endif;
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpMain.enabled:= false;
		self.btnSave.enabled:= false;
		self.btnNext.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="6398c1df-30c0-4ff4-b4b3-62f1233abfff">
        <updating/>
        <source>setupMeasurementControls() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.tabKey := J_key_Tab;
	
	self.tblVolume.setup(Type_Volume, self.backColor);
	self.tblVolume.tabKey := J_key_Tab;
	
	self.tblLength.setup(Type_Length, self.backColor);
	self.tblLength.tabKey := J_key_Tab;
	
	self.tblWidth.setup(Type_Width, self.backColor);
	self.tblWidth.tabKey := J_key_Tab;
	
	self.tblHeight.setup(Type_Height, self.backColor);
	self.tblHeight.tabKey := J_key_Tab;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2b8dc7f5-26e7-4131-bbb7-9e9803231d5c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 December 2022 14:34:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017255, locale);
	btnCancel.translateCaption(Xlat_0013380, locale);
	btnHSCode.translateCaption(Xlat_0025234, locale);
	btnNext.translateCaption(Xlat_0013381, locale);
	btnSave.translateCaption(Xlat_0013382, locale);
	grpMain.translateCaption(Xlat_0021284, locale);
	lblCargoType.translateCaption(Xlat_0013383, locale);
	lblColour.translateCaption(Xlat_0013384, locale);
	lblCommodity.translateCaption(Xlat_0013385, locale);
	lblConsignee.translateCaption(Xlat_0013386, locale);
	lblConsignor.translateCaption(Xlat_0013387, locale);
	lblHeight.translateCaption(Xlat_0013388, locale);
	lblHsCode.translateCaption(Xlat_0025235, locale);
	lblLength.translateCaption(Xlat_0013389, locale);
	lblMainDetails.translateCaption(Xlat_0013390, locale);
	lblMark.translateCaption(Xlat_0013391, locale);
	lblNumberOfItems.translateCaption(Xlat_0013392, locale);
	lblRemarks.translateCaption(Xlat_0013393, locale);
	lblVolume.translateCaption(Xlat_0014268, locale);
	lblWeight.translateCaption(Xlat_0013394, locale);
	lblWidth.translateCaption(Xlat_0013395, locale);
end;</source>
    </JadeMethod>
</GUIClass>
