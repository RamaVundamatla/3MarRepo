    <JadeMethod name="clearThumbnailData" id="f7a87662-c8be-4164-bdb3-ea237085a39b">
        <updating/>
        <source>clearThumbnailData() updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maintFormObj	: SOP_TableMaintForm;
	
begin
	inheritMethod();
	maintFormObj	:=	self.myForm;
	maintFormObj.tblInput1.clearValues();
	maintFormObj.mulSelect1.setSelected(null);  	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="2f72cf28-c1dc-460d-bb41-4a006241faa1">
        <updating/>
        <source>create() updating, protected;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.name				:=	SOP_TableMaintForm.Table_VesselUnavailCode;
	self.permissionView		:=	PmHMSVesselUnavailCodeView;
	self.permissionMaint	:=	PmHMSVesselUnavailCodeMaint;
	self.myDataClass		:=	HMS_VesselUnavailCode;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="5c9c0a40-118e-483d-b2ee-44fac67ebf8f">
        <updating/>
        <source>doSave(): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj		:	HMS_VesselUnavailCode;
	maintFormObj	:	SOP_TableMaintForm;
		
begin
	maintFormObj	:=	self.myForm.SOP_TableMaintForm;
	
	if maintFormObj.myProxyObject = null then
		if maintFormObj.mode = maintFormObj.Mode_Add then
			create maintFormObj.myProxyObject as HMS_VesselUnavailCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	proxyObj	:=	maintFormObj.myProxyObject.HMS_VesselUnavailCode;
	maintFormObj.tblInput1.setObjectFromTable(proxyObj, null, false);
	proxyObj.setProxy(app.myRoot);
	
	//Are we adding or updating
	if maintFormObj.mode = maintFormObj.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(proxyObj, maintFormObj.myCurrentObject, app.myPassport);
	elseif maintFormObj.mode = maintFormObj.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(proxyObj, app.myPassport);
	else
		app.raiseUnexpectedProgramError( class.name,
										 method.name,
										 '  Invalid mode (' &amp; maintFormObj.mode.String &amp; ')' );
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="07ead6b1-931e-416e-b783-fec50d51b4be">
        <source>getCollection(): Collection;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to a collection of Vessel Unavailability Codes.
//
// Parameters:	None
//
// Returns:		A reference to the collection of codes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return app.myRoot.allVesselUnavailabilityCodes;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="isSystemItem" id="fbe4f876-616c-4ec5-a621-d7b25e37a446">
        <source>isSystemItem(): Boolean;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is a
//				"System Item".
//
// Parameters:	None
//
// Returns:		True.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="993af806-12c4-489c-bb8d-cefd53ed0e2c">
        <updating/>
        <source>setControlsForAddEdit() updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Standard method for setting up controls for user maintenance.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maintFormObj	: SOP_TableMaintForm;

begin
	maintFormObj	:=	self.myForm;
	maintFormObj.tblInput1.userInputEnabled := true;
		
	if maintFormObj.mode = maintFormObj.Mode_Add then
		maintFormObj.tblInput1.clearValues();
		maintFormObj.tblInput1.enableRowByName(ETRow_Code);
		maintFormObj.tblInput1.enableRowByName(ETRow_Description);
		maintFormObj.tblInput1.setFocus();
		maintFormObj.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(maintFormObj.myProxyObject.HMS_VesselUnavailCode);
		// cannot update code
		maintFormObj.tblInput1.enableRowByName(ETRow_Code);
		maintFormObj.tblInput1.enableRowByName(ETRow_Description);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="91e5793a-3603-4d2e-9112-d4490b4b8b91">
        <source>setupThumbnailDetails();
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	defName		: String;
	mainFormObj	: SOP_TableMaintForm;
	
begin
	mainFormObj	:=	self.myForm;
	mainFormObj.useProxyObject	:=	true;
	mainFormObj.setTblDataEntRows(ETDef_HMSTblData);
	//12/01/2011 cnwdz2 25840
	//mainFormObj.zClearSortColumns();
	//mainFormObj.zAddSortColumn(ETRow_Code, false);
	
	mainFormObj.shtTblInput1.caption	:=	'Details';
	
	defName	:=	ETDef_HMSTblData;
	
	mainFormObj.initTblInput(mainFormObj.tblInput1, defName);
	mainFormObj.shtTblInput1.visible	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5aaf3341-d9f9-4d0c-b6c0-0d6ccce79e66">
        <updating/>
        <source>showThumbnail(pObj: HMS_VesselUnavailCode) updating;
// --------------------------------------------------------------------------------
// Created:		11 September 2006 by cnwdad1
//
// Purpose:		Sets up a thumbnail of the receiver's details.
//
// Parameters:	pObj - A reference to the Vessel Unavailability Code.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maintFormObj	: SOP_TableMaintForm;
	
begin
	maintFormObj	:=	self.myForm;
	maintFormObj.tblInput1.clearValues;
	maintFormObj.tblInput1.setValueByName(ETRow_Code, pObj.code);
	maintFormObj.tblInput1.setValueByName(ETRow_Description,pObj.description);
end;</source>
        <Parameter name="pObj" type="HMS_VesselUnavailCode"/>
    </JadeMethod>
</Class>
