    <JadeMethod name="loadTypeTreatLength" id="ec53b8ee-8c47-4449-9cf5-fe8f225c19c2">
        <source>loadTypeTreatLength() protected;

vars

	grade	: CM_LogGrade;

begin

	grade := self.cmbGrade.listObject.CM_LogGrade;
	if grade &lt;&gt; null then
		clear(CLEAR_TTL);
		self.myAssistant.comboBoxAddCode(self.cmbType, grade.allLogTypes, null, true);
		self.myAssistant.comboBoxAddCode(self.cmbTreatment, grade.allLogTreatments, null, true);
		self.myAssistant.comboBoxGeneralNotSorted(self.cmbLength, grade.allLogLengthsBySortOrder);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
