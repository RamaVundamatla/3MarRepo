end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d2cd37d1-9cad-4a84-85ec-a35a02028e7e">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpProxyShipPortGroup : CM_ShipPortGroup;
	proxyShipPort,
	realShipPort	     : CM_ShipPort;
	proxyLineGroupDebtor,
	realLineGroupDebtor  : CM_LineGroupDebtor;
	completedOK		: Boolean;
	
begin
	tmpProxyShipPortGroup := inheritMethod();

	foreach realShipPort in self.shipPorts do
		proxyShipPort := realShipPort.pxyCreateUpdateProxy();
		tmpProxyShipPortGroup.shipPorts.add(proxyShipPort);
	endforeach;

	foreach realLineGroupDebtor in self.lineGroupDebtors do
		proxyLineGroupDebtor := realLineGroupDebtor.pxyCreateUpdateProxy();
		tmpProxyShipPortGroup.lineGroupDebtors.add(proxyLineGroupDebtor);
	endforeach;

	tmpProxyShipPortGroup.shippingLine := self.shippingLine; 
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpProxyShipPortGroup;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpProxyShipPortGroup;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5108bd46-7fd6-4749-8677-51fe7fab20aa">
        <updating/>
        <source>setForCreate(pProxyShipPortGroup : CM_ShipPortGroup) updating;

vars

begin
	setForUpdate(pProxyShipPortGroup);
end;</source>
        <Parameter name="pProxyShipPortGroup" type="CM_ShipPortGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="619fd4a2-6a72-4fde-9761-d0b87625c582">
        <updating/>
        <source>setForUpdate(pProxyShipPortGroup : CM_ShipPortGroup) updating;

// 08/12/2014 cnwdb2 PAR 35364


vars
	proxyShipPort,
	realShipPort			: CM_ShipPort;
	proxyLineGroupDebtor,
	realLineGroupDebtor 	: CM_LineGroupDebtor;
	saveShipLine			: CM_ShippingLine;
	oldGrpCode,
	oldLineCode					: String;
	includedLGDs				: CM_LineGroupDebtorByCodeDict;
	voy 					: CM_Voyage;
	str 					: String;
begin

	saveShipLine := self.shippingLine;
	if saveShipLine &lt;&gt; null then
		oldLineCode := saveShipLine.code;
	endif;
	oldGrpCode := self.code;
	
	self.shippingLine := pProxyShipPortGroup.shippingLine;
	self.code := pProxyShipPortGroup.code.trimBlanks;
	self.description := pProxyShipPortGroup.description.trimBlanks;

	//do ShipPorts - OK to purge for these
	self.shipPorts.purge;
	foreach proxyShipPort in pProxyShipPortGroup.shipPorts do
		create realShipPort persistent;
		// Must add into dict here first before setting
		// Port reference below
		self.shipPorts.add(realShipPort);
		realShipPort.setForCreate(proxyShipPort);
	endforeach;
	
	//do lineGroupDebtors - must check for existing and remove if not proxied
	
	create includedLGDs transient;
	foreach proxyLineGroupDebtor in pProxyShipPortGroup.lineGroupDebtors do
		//get the real
		realLineGroupDebtor := proxyLineGroupDebtor.pxyGetRealObject();
		if realLineGroupDebtor &lt;&gt; null then
			//add to a list of updated reals
			realLineGroupDebtor.setForUpdate(proxyLineGroupDebtor);
		else
			//must be new
			create realLineGroupDebtor persistent;
			realLineGroupDebtor.setForCreate(proxyLineGroupDebtor);
		endif;
		includedLGDs.add(realLineGroupDebtor);
		if self.lineGroupDebtors.includes(realLineGroupDebtor) then
			self.lineGroupDebtors.remove(realLineGroupDebtor);
		endif;
	endforeach;
	
	//self.lineGroupDebtors will now only contain ones to delete - warn and delete
	foreach realLineGroupDebtor in self.lineGroupDebtors do
	//	app.raiseCMWarning2(CONF_DELETE, 'line group debtor', oldLineCode &amp; " " &amp; oldGrpCode &amp; " " &amp; realLineGroupDebtor.debtor.name &amp; ". It has " &amp; realLineGroupDebtor.allVoyages.size.String &amp; " voyages and " &amp; realLineGroupDebtor.serviceRates.size.String &amp; " service rates.", 'lineGroupDebtor', null, self);
		app.raiseCMWarning3(Sure_want_delete35364d, 
						oldLineCode &amp; oldGrpCode &amp; realLineGroupDebtor.debtor.name,
						realLineGroupDebtor.allVoyages.size.String,
						realLineGroupDebtor.serviceRates.size.String,
						'lineGroupDebtor', null, self); //cnwdb2 PAR 35364

	endforeach;
	self.lineGroupDebtors.purge; //warned above
	
	//copy new and updated to collection
	includedLGDs.copy(self.lineGroupDebtors);
	
	//ccms 1058 no longer maintain the voyage allports from shipping line port group
	//if self.shippingLine &lt;&gt; saveShipLine then
	//	self.shippingLine.setPortsForVoyages();
	//endif;

	self.shippingLine.setForVoyageOperators();// PAR 9117
epilog
	delete includedLGDs;
	
end;</source>
        <Parameter name="pProxyShipPortGroup" type="CM_ShipPortGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cd51d66c-76c9-44ab-981f-8759b2e667fb">
        <updating/>
        <source>setProxy(pCode,pDescription : String; pLineGroupDebtors,pShipPorts : ObjectArray; pShippingLine : CM_ShippingLine) updating;

vars
	obj		: Object;
	lgd		: CM_LineGroupDebtor;
begin

	self.raiseExceptionIfNotTransient(method);

    self.shippingLine := pShippingLine;
	self.code := pCode;
	self.description := pDescription;
	
	self.shipPorts.purge;
	pShipPorts.copy(self.shipPorts);
	
	foreach obj in pLineGroupDebtors do
		//remove the pxys we don't want to purge
		lgd := obj.CM_LineGroupDebtor;
		if self.lineGroupDebtors.includes(lgd) then
			self.lineGroupDebtors.remove(lgd);
		endif;
	endforeach;
	self.lineGroupDebtors.purge;
	//add the keepers back
	pLineGroupDebtors.copy(self.lineGroupDebtors);	
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pLineGroupDebtors" type="ObjectArray"/>
        <Parameter name="pShipPorts" type="ObjectArray"/>
        <Parameter name="pShippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="25d33c34-b5a3-4c66-af13-d4a47ec317ab">
        <source>validateForCreate(_passport : CM_Passport input);

vars

begin
	self.validateMe(null, _passport);
	if(self.shippingLine &lt;&gt; null) then
		if(self.shippingLine.shipPortGroups[self.code] &lt;&gt; null) then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a258afea-cc43-4dc5-aa92-60367f041365">
        <source>validateForDelete();

begin
	// Nothing to validate.
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="380a9cbf-1fbb-4e70-b2b1-3c254d70cd00">
        <source>validateForUpdate(pRealShipPortGroup : CM_ShipPortGroup; _passport : CM_Passport input);

vars

begin
	if(self.shippingLine &lt;&gt; null) then
		if(self.shippingLine.shipPortGroups[self.code] &lt;&gt; null) and  (pRealShipPortGroup.code &lt;&gt; self.code )then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	endif;
	self.validateMe(pRealShipPortGroup, _passport);
end;</source>
        <Parameter name="pRealShipPortGroup" type="CM_ShipPortGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d0e74b0b-e3c0-4058-bd11-da4008d80fcc">
        <source>validateMe(pRealShipPortGroup : CM_ShipPortGroup; _passport : CM_Passport input) protected;

vars
	shipPort : CM_ShipPort;
	shipPortGroup : CM_ShipPortGroup;
	port     : CM_Port;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line Port Group Code', null, null);
		app.raiseCMException(Input_required_field_shpLnePrt, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line Port Group Description', null, null);
		app.raiseCMException(Input_required_field_shpLPDesc, null, null);

	endif;
	if self.shippingLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line Port Group ShippingLine', null, null);
		app.raiseCMException(Input_required_field_shpPGSL, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	foreach shipPort in self.shipPorts do
		foreach	shipPortGroup in self.shippingLine.shipPortGroups do
			if shipPortGroup = pRealShipPortGroup then
				continue;
			else
				if shipPortGroup.shipPorts.includesKey(shipPort.port.code) then
					app.raiseCMException2(VB_DUPLICATED_ITEM,shipPort.port.code ,shipPortGroup.code, null, null);
				endif;
			endif;
		endforeach;
	endforeach;
			
end;</source>
        <access>protected</access>
        <Parameter name="pRealShipPortGroup" type="CM_ShipPortGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
