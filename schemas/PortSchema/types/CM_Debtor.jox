    <JadeMethod name="isInternalCustomer" id="fbf7f55a-ffd8-46f1-9d0c-c797cde85bb6">
        <source>isInternalCustomer() : Boolean;
// Mar 2012 for Milaha (Gulftainer) - internal customers have a GL code in their remarks, as the last entry and with
//  four embedded commas or periods
vars
	sta		: String200Array;
	item	: String;
	result	: Boolean;
begin
	create sta transient;
	self.remarks.asString200ArrayByDelimiter(sta, CrLf);
	foreach item in sta do
		if item.countOccurrences('.') = 4 or
		   item.countOccurrences(',') = 4 then
			result := true;
			break;
		endif;
	endforeach;
	
	return result;
epilog
	delete sta;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5e0e9316-b4f5-4af3-91a0-e52248bdd8d7">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxy	: CM_Debtor;
	debtInvType,
	pxyDIT			: CM_DebtorInvType;
	debtInvLineType,
	pxyDILT			: CM_DebtorInvLineType;
	pkgInvoice		: CM_PackageInvoice;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	// 28218 CCMS 2120 copy debtor invoice types and debtor invoice line types, for maintenance
	foreach debtInvType in self.allDebtorInvTypes do
		create pxyDIT transient;
		pxyDIT.setup(pxy, debtInvType.myInvoiceType, debtInvType.defaultDebtorRefTo);
		foreach pkgInvoice in debtInvType.allPackageInvoices do
			pxyDIT.allPackageInvoices.add(pkgInvoice);
		endforeach;
	endforeach;
	foreach debtInvLineType in self.allDebtorInvLineTypes do
		create pxyDILT transient;
		pxyDILT.setup(pxy, debtInvLineType.myInvoiceLineType, debtInvLineType.otherCode);
	endforeach;
	
	completedOK := true;
	return pxy;
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="90996ef3-4304-4ee4-afd6-9acb56547b4d">
        <updating/>
        <source>setForCreate(_debtorNodeController : CMIF_DebtorNode) updating;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//2nd May 2023	navra1	TFS 57086 EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
//----------------------------------------------------------------
vars
	term 					: CM_Terminal;
	usesCash 				: Boolean;
	paymentType 			: Integer;
	currencyType 			: CM_CurrencyType; 			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	locale 					: CM_Locale;				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	invoiceReport 			: String;					// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	debtorTerminalDetail	: CMIF_DebtorTerminalDetail; 
	orgCode					: String;							//navra1 - TFS 57086 - 28th Apr 2023
	interTerminalCode		: String;							//navra1 - TFS 57086 - 28th Apr 2023
	
begin
	
	inheritMethod(_debtorNodeController);
	
	 // ### TFS 52237 02NOV2021 NAVAB1 ALL debtors have a debtor terminal now. Payment type is not part of cash and we need to be able to set the payment type
	foreach term in app.myRoot.allTerminals do
		usesCash 		:= false;
		paymentType 	:= PaymentType_None;
		currencyType 	:= null; 				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		locale 			:= null; 				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		invoiceReport 	:= null; 				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		orgCode				:= null;					//navra1 - TFS 57086 - 28th Apr 2023
		interTerminalCode	:= null;					//navra1 - TFS 57086 - 28th Apr 2023

		debtorTerminalDetail := _debtorNodeController.allDebtorTerminalDetails.getAtKey(term);
		if debtorTerminalDetail &lt;&gt; null then 
			paymentType 		:= debtorTerminalDetail.paymentType;
			usesCash 			:= debtorTerminalDetail.cashOnly;
			currencyType 		:= debtorTerminalDetail.myCurrencyType; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			locale 				:= debtorTerminalDetail.myLocale;			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			invoiceReport 		:= debtorTerminalDetail.defaultInvoiceJRW;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			orgCode				:= debtorTerminalDetail.organizationCode;	//navra1 - TFS 57086 - 28th Apr 2023
			interTerminalCode	:= debtorTerminalDetail.interTerminalCode;	//navra1 - TFS 57086 - 28th Apr 2023
		endif;
		
		//self.createDebtorTerminal( term, usesCash, paymentType);
		//self.createDebtorTerminal( term, usesCash, paymentType, currencyType, locale, invoiceReport); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
		self.createDebtorTerminal( term, usesCash, paymentType, currencyType, locale, invoiceReport, orgCode, interTerminalCode); 	//navra1 - TFS 57086 - 28th Apr 2023
	endforeach;
	
	self.setForUpdate(_debtorNodeController);
	

epilog

end;</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="52814530-1b09-4c4f-9319-253f816fdd30">
        <updating/>
        <source>setForUpdate(_debtorNodeController : CMIF_DebtorNode) updating;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1
08/08/2018  cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
25/09/2018	jlgsl4	TFS 40294 PEL1 - extract/import new fields incl. Payment Type details
30/05/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
28/03/2020  cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
Bug 51081: CPL - 2nd Line of Debtor Address cutting off to new line
07/06/2022 	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
13 may 2022	navtnr20 TFS 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line
08/09/2022	navmd1	TFS 54664 Removed xlat attributes from CM_Debtor
27/04/2023	navra1	TFS 57086 EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
11/05/2023	navra1	TFS 57447 EUP - Customer Update - Process Customer info from API method
*/

vars
	baArray 				: HugeStringArray;
	aString, 
	tmpString 				: String;
	rootDebtor 				: CM_Debtor;
	anOperator 				: CM_Operator;
	aConsignee 				: CM_ConsigneeConsignor;
	stevedore 				: CM_Stevedore;						
	aCA 					: CM_CustomsAgent;
	aDT 					: CM_DebtorType;
	carrier 				: CM_Carrier;
	debtorInvType,
	proxyDIT				: CM_DebtorInvType;
	debtInvLineType,
	proxyDILT			 	: CM_DebtorInvLineType;
	packageInvoice		 	: CM_PackageInvoice;
	drTerm 				 	: CM_DebtorTerminal;
	terminal 			 	: CM_Terminal;
	paymentType			 	: Integer;					
	debtorTerminalDetail	: CMIF_DebtorTerminalDetail; 
	usesCash 				: Boolean;
	shipLine 				: CM_ShippingLine;
	currencyType 			: CM_CurrencyType; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	locale 					: CM_Locale; 		// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	defaultInvoiceJRW 		: String; 			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	cmifAddress				: CMIF_Address;			//navra1 - TFS 57086 - 28th Apr 2023
	pxyAddress 				: CM_Address;			//navra1 - TFS 57086 - 28th Apr 2023
	realAddress 			: CM_Address;			//navra1 - TFS 57086 - 28th Apr 2023
	orgCode 				: String;				//navra1 - TFS 57086 - 28th Apr 2023
	interterminalCode		: String;				//navra1 - TFS 57086 - 28th Apr 2023
	existingDefAddress		: CM_Address;			//navra1 - TFS 57086 - 28th Apr 2023
	existingAltAddress		: CM_Address;			//navra1 - TFS 57086 - 28th Apr 2023
begin
	
	inheritMethod(_debtorNodeController);
	
	self.billingAddress.purge;
	create baArray transient;
	_debtorNodeController.billingAddress.getTokensForDelimiterHugeNoNul(Comma, baArray); //28.03.2020 cnwma1 #48994
	
	foreach aString in baArray do           //19.04.2021 cnwma1 #51081
		self.billingAddress.add(aString);
	endforeach;
	
	rootDebtor := self.bank.rootDebtor;

	// ### detach operators
	foreach anOperator in self.operators do
		anOperator.debtor := rootDebtor;
	endforeach;
	// ### attach operators
	foreach anOperator in _debtorNodeController.allOperators do
		anOperator.debtor := self;
	endforeach;

	// ### detach consignors
	foreach aConsignee in self.consignors do
		aConsignee.setDebtor(rootDebtor);
	endforeach;
	// ### attach consignors
	foreach aConsignee in _debtorNodeController.allConsignors do
		aConsignee.setDebtor(self);
	endforeach;

	// ### detach customs agent
	foreach aCA in self.allCustomsAgents do
		aCA.setDebtor(null);
	endforeach;
	// ### attach customs agent
	foreach aCA in _debtorNodeController.allCustomsAgents do
		aCA.setDebtor(self);
	endforeach;

	// Detach Debtor Type
	// CentrePort CCMS 1047 5 May 2008 cnwgb1
	foreach aDT in self.allDebtorTypes do
		if aDT.allDebtors.includes(self) then
			aDT.allDebtors.remove(self);
		endif;
	endforeach;
	// Attach Debtor Type
	foreach aDT in _debtorNodeController.allDebtorTypes do
		if not aDT.allDebtors.includes(self) then
			aDT.allDebtors.add(self);
		endif;
	endforeach;
	
	//+ cnwmd1, CCMS 1067, Par 19913
	// ### detach carriers
	foreach carrier in self.allCarriers do
		carrier.setDebtor(rootDebtor);
	endforeach;
	// ### attach carriers
	foreach carrier in _debtorNodeController.allCarriers do
		carrier.setDebtor(self);
	endforeach;
	
	//  start 13 may 2022	navtnr20 TFS 53195
	// ### detach ShippingLine
	foreach shipLine in self.allShippingLines do
		shipLine.setDebtor(rootDebtor);
	endforeach;
	// ### attach ShippingLine
	foreach shipLine in _debtorNodeController.allShippingLines do
		shipLine.setDebtor(self);
	endforeach;
	//END	13 may 2022	navtnr20 TFS 53195
	
	// TFS 44554 start
	// ### detach stevedores
	foreach stevedore in self.allStevedores do
		stevedore.setDebtor(rootDebtor);
	endforeach;
	// ### attach stevedores
	foreach stevedore in _debtorNodeController.allStevedores do
		stevedore.setDebtor(self);
	endforeach;

	self.allContacts.clear;
	_debtorNodeController.allContacts.copy(self.allContacts);

	self.allSpecialReleaseTxnTypes.purge;
	_debtorNodeController.allSpecialReleaseTxnTypes.copy(self.allSpecialReleaseTxnTypes);
	
	self.decfinName 	        := _debtorNodeController.decfinName;
	self.code			        := _debtorNodeController.code;
	self.longName				:= _debtorNodeController.longName; 
	self.purchaseOrderCode      := _debtorNodeController.purchaseOrderCode;
	self.externalReference      := _debtorNodeController.externalReference;	
	self.myTermsOfTrade         := _debtorNodeController.myTermsOfTrade;
	self.additionalInformation1 := _debtorNodeController.additionalInformation1;	
	self.additionalInformation2 := _debtorNodeController.additionalInformation2;
	self.taxNumber				:= _debtorNodeController.taxNumber;												//navra1 - TFS 57086 - 23th Apr 2023		
	self.myTaxCountry			:= _debtorNodeController.taxCountry;											//navra1 - TFS 57086 - 23th Apr 2023
	
	self.setShipLineGroupDebtor(); 
	
	// 28218 CCMS 2120 debtor invoice types and debtor invoice line types
	if _debtorNodeController.doDebtorInvoiceTypes then
		// new and updated
		foreach proxyDIT in _debtorNodeController.myPxyDebtorNode.CM_Debtor.allDebtorInvTypes do
			debtorInvType := self.allDebtorInvTypes[proxyDIT.myInvoiceType];
			if debtorInvType = null then
				create debtorInvType persistent;
				debtorInvType.setup(self, proxyDIT.myInvoiceType, proxyDIT.defaultDebtorRefTo);
			else
				debtorInvType.setDefaultDebtorRefTo(proxyDIT.defaultDebtorRefTo);
			endif;
			debtorInvType.allPackageInvoices.clear();
			foreach packageInvoice in proxyDIT.allPackageInvoices do
				debtorInvType.allPackageInvoices.add(packageInvoice);
			endforeach;
		endforeach;
		// deleted
		foreach debtorInvType in self.allDebtorInvTypes do
			proxyDIT := _debtorNodeController.myPxyDebtorNode.CM_Debtor.allDebtorInvTypes[debtorInvType.myInvoiceType];
			if proxyDIT = null then
				delete debtorInvType;
			endif;
		endforeach;
	endif;

	if _debtorNodeController.doDebtorInvoiceLineTypes then
		foreach proxyDILT in _debtorNodeController.myPxyDebtorNode.CM_Debtor.allDebtorInvLineTypes do
			debtInvLineType := self.allDebtorInvLineTypes[proxyDILT.myInvoiceLineType];
			if debtInvLineType = null then
				create debtInvLineType persistent;
				debtInvLineType.setup(self, proxyDILT.myInvoiceLineType, proxyDILT.otherCode);
			else
				debtInvLineType.setOtherCode(proxyDILT.otherCode);
			endif;
		endforeach;
		// deleted
		foreach debtInvLineType in self.allDebtorInvLineTypes do
			proxyDILT := _debtorNodeController.myPxyDebtorNode.CM_Debtor.allDebtorInvLineTypes[debtInvLineType.myInvoiceLineType];
			if proxyDILT = null then
				delete debtInvLineType;
			endif;
		endforeach;
	endif;
	
/* TFS 52337 WAS

	//17 Jul 2012	NDL	Par 29968
	if app.isCashOnlyEnabled then
		foreach drTerm in self.allDebtorTerminals do
			terminal := drTerm.myTerminal;
			drTerm.setCashOnly( _debtorNodeController.allCashOnlyTerminals.includes( terminal ) );
		endforeach;
		foreach terminal in _debtorNodeController.allCashOnlyTerminals do
			if self.allDebtorTerminals.getAtKey( terminal ) = null then
				paymentType := null; 										    // TFS 40294
				if _debtorNodeController.allDebtorTerminalDetails.size &gt; 0 then // TFS 40294 - importing debtor with cash-only details
					debtorTerminalDetail := _debtorNodeController.allDebtorTerminalDetails.getAtKey(terminal); // TFS 40294
					if debtorTerminalDetail &lt;&gt; null then 						 // TFS 40294
						paymentType := debtorTerminalDetail.paymentType; 		 // TFS 40294
					endif; 														 // TFS 40294
				endif; 													 		 // TFS 40294
				self.createDebtorTerminal( terminal, true, paymentType); 		 // TFS 40294
			endif;
		endforeach;
	endif;


NOW */	
		 // ### TFS 52237 27OCT2021 NAVAB1 
		// CREATE NEW. Are there any new terminals in the system?
		foreach terminal in app.myRoot.allTerminals do
			if self.allDebtorTerminals.getAtKey( terminal ) = null then
				paymentType			:= PaymentType_None; 
				usesCash 			:= false;
				currencyType 		:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				locale 				:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				defaultInvoiceJRW 	:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				orgCode				:= null;				//navra1 - TFS 57086 - 28th Apr 2023
				interterminalCode	:= null;				//navra1 - TFS 57086 - 28th Apr 2023
				
				if _debtorNodeController.allDebtorTerminalDetails.size &gt; 0 then // TFS 40294 - importing debtor with cash-only details
					debtorTerminalDetail := _debtorNodeController.allDebtorTerminalDetails.getAtKey(terminal);
					if debtorTerminalDetail &lt;&gt; null then 
						paymentType 		:= debtorTerminalDetail.paymentType;
						usesCash			:= debtorTerminalDetail.cashOnly;
						currencyType 		:= debtorTerminalDetail.myCurrencyType; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						locale 				:= debtorTerminalDetail.myLocale;			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						defaultInvoiceJRW 	:= debtorTerminalDetail.defaultInvoiceJRW;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						orgCode				:= debtorTerminalDetail.organizationCode;	//navra1 - TFS 57086 - 28th Apr 2023
						interterminalCode	:= debtorTerminalDetail.interTerminalCode;	//navra1 - TFS 57086 - 28th Apr 2023
					endif;
				endif;
				
				//self.createDebtorTerminal( terminal, usesCash, paymentType);
				//self.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
				self.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW, orgCode, interterminalCode); //navra1 - TFS 57086 - 28th Apr 2023
			endif;
		endforeach;
		
		// UPDATE EXISTING
		foreach debtorTerminalDetail in _debtorNodeController.allDebtorTerminalDetails do
			drTerm := self.allDebtorTerminals[debtorTerminalDetail.myTerminal];
			
			if drTerm &lt;&gt; null then
				paymentType			:= PaymentType_None; 
				currencyType 		:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				locale 				:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				defaultInvoiceJRW 	:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				orgCode				:= null;				//navra1 - TFS 57086 - 28th Apr 2023
				interterminalCode	:= null;				//navra1 - TFS 57086 - 28th Apr 2023
				
				if _debtorNodeController.allDebtorTerminalDetails.size &gt; 0 then // TFS 40294 - importing debtor with cash-only details
					debtorTerminalDetail := _debtorNodeController.allDebtorTerminalDetails.getAtKey(debtorTerminalDetail.myTerminal);
					if debtorTerminalDetail &lt;&gt; null then 
						paymentType			:= debtorTerminalDetail.paymentType;
						usesCash			:= debtorTerminalDetail.cashOnly;
						currencyType 		:= debtorTerminalDetail.myCurrencyType; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						locale 				:= debtorTerminalDetail.myLocale;			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						defaultInvoiceJRW 	:= debtorTerminalDetail.defaultInvoiceJRW;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						orgCode				:= debtorTerminalDetail.organizationCode;	//navra1 - TFS 57086 - 28th Apr 2023
						interterminalCode	:= debtorTerminalDetail.interTerminalCode;	//navra1 - TFS 57086 - 28th Apr 2023
					endif;
				endif;
				
				drTerm.setCashOnly(usesCash);
				drTerm.setPaymentType(paymentType);
				drTerm.setMyCurrencyType(currencyType);	 		// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				drTerm.setMyLocale(locale);						// ### TFS 54564 (54374) 17Aug2022 NAVPW1
				drTerm.setDefaultInvoiceJRW(defaultInvoiceJRW); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
				drTerm.setOrgCode(orgCode);							//navra1 - TFS 57086 - 28th Apr 2023
				drTerm.setInterTerminalCode(interterminalCode);		//navra1 - TFS 57086 - 28th Apr 2023
			endif;
		
		endforeach;
		
	
epilog
	delete pxyAddress;	
	delete baArray;
end;</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="aba58ae9-2e0f-4e0d-889e-642d60d11401">
        <updating/>
        <source>setProxy(_name: String; _code: String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/08/2018	jlgdap1		Initial creation TFS 40092 PEL1 Adding Changes to Debtors
//
vars

begin
	inheritMethod(_name, _code);
	self.code := _code;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setToDoTaskComplete" id="91156fe1-e521-448b-8e3b-f95deb722616">
        <updating/>
        <source>setToDoTaskComplete(taskCode : Integer; _passport : CM_Passport input; _resourceUsageProxys : CM_ResourceTypeUsageSet; _wodtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
19 May 2023			navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	task 				: CM_ToDoTask;
	found 				: Boolean;
	eventType			: Integer;
	event, trans		: CM_Transaction;
	resourceUsageProxys	: CM_ResourceTypeUsageSet;
	wod					: CM_WodToDoNonOperational;
	tasksComplete		: Boolean;
	transType : CM_TransactionType;
begin
	tasksComplete := true;
	
	foreach task in self.allToDoTasksToDo where (task.toDoTaskDescCode = taskCode and _wodtl.allToDoTasks.includes(task)) do
		found := true;
		break;
	endforeach;
	
	create resourceUsageProxys transient;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(resourceUsageProxys);
	endif;
	
	if found then
		wod := _wodtl.CM_WodToDoNonOperational;
		task.setToDoTaskComplete(_passport, resourceUsageProxys);
		task.CM_NonOpsToDoTask.updateDebtorComplete();
		trans := wod.createWOTransaction(wod.TRANS_COMPLETED, resourceUsageProxys, task);	 // ### JIRA 23013 16OCT2024 NAVAB1
		
		// ### JIRA 14793 24OCT2024 NAVAB1
		transType := task.toDoTaskDesc.myTransactionType;
		if transType &lt;&gt; null and transType.isForWorkOrder()    then // WO Trans Type
			trans := wod.createWOTransactionUserDefined(transType.trxType, resourceUsageProxys, task);
		
		else
			eventType := task.getToDoTaskCompleteEventInt;	
			if eventType &lt;&gt; null then
				//event := self.createTransaction(eventType, app.actualTime, resourceUsageProxys); 
				event := self.createEvent(eventType, app.actualTime, resourceUsageProxys,task, wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
				/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
				if event &lt;&gt; null then														//19.5.2023 navhl20 #56631[56185]
					event.addResourcesFromProxys(resourceUsageProxys);
				endif;
				*/
			endif;
		endif;
		
		foreach task in self.allToDoTasksToDo do
			if task.myWODetailToDo = wod and task.status = STATUS_TODO then
				tasksComplete := false;	
			endif;
		endforeach;
		if tasksComplete then
			wod.allDebtorsActioned.remove(self);
			wod.allDebtorsCompleted.add(self);
		endif;
		self.updateObjectEdition(self);
	endif;

epilog
	delete resourceUsageProxys;
end;</source>
        <Parameter name="taskCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="023c6869-7eca-4916-8339-0befb9b6ecc9">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_Debtor::myChildQuantityMap.name or
		propName = CM_Debtor::myParentDebtorNode.name or 
		propName = CM_Debtor::allAddressesByCode.name or
		propName = CM_Debtor::postingNumber.name	  or 
		propName = CM_Debtor::badDebtor.name          or
		propName = CM_Debtor::hasBadCredit.name       or
		propName = CM_Debtor::decfinName.name         or 
		propName = CM_Debtor::isZeroRatedTax.name     or
		propName = CM_Debtor::isSuspended.name        or
		propName = CM_Debtor::myTermsOfTrade.name     or
		propName = CM_Debtor::group.name		      or
		propName = CM_Debtor::myDebtorRoot.name		   or
		propName = CM_Debtor::myFinancialPeriodEnd.name   or
		propName = CM_Debtor::myServiceBroker.name		      or
		propName = CM_Debtor::bank.name		      or
		propName = CM_Debtor::isPurchaseOrderMandatory.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ee166c89-1f22-41d7-bc18-2abb096749c4">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     17 January 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	whereUsed : String;

begin

	if (not self.allInvoices.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Debtor ' &amp; self.name, "invoice", null, null);
	endif;

	inheritMethod();
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="63a79a5d-8307-4d40-ad30-2795b731a34d">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/08/2018	jlgdap1		Initial creation TFS 40092 PEL1 Adding Changes to Debtors
//
vars
	realMe, debtor : SelfType;

begin
	inheritMethod();
	
	if self.code &lt;&gt; null then
		realMe := self.pxyGetRealObject;
		debtor := app.myRoot.myRootCompany.allDebtorsByCode[self.code];
		if debtor &lt;&gt; null and debtor &lt;&gt; realMe then
			app.raiseCMException1(Already_exists_debtor,self.CM_Debtor.code,null,null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
