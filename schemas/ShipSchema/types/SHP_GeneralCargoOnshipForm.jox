    <JadeMethod name="doDeleteBOL" id="275d813e-d8f3-46e9-b725-cb7de1631547">
        <updating/>
        <source>doDeleteBOL() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2014	cnwmc5	Initial creation	PAR 34074

*/

vars

	bol		: CM_BOL;
	obj		: Object;
	
	retval	: Integer;
	result	: Integer;
	
begin

	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := self.tblBOL.accessRow(self.tblBOL.row).itemObject;
	if (not CM_BOL.hasInstance(obj)) then
		app.raiseCMException2(PleaseSelectAnObject, app.getErrorString(BillOfLading), app.getErrorString(Delete), null, null);
		return;
	endif;
	
	bol := obj.CM_BOL;

	while true do
		app.myTrxDA.trxDeleteBOL(bol, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.tblBOLItems.clearAllData();
			self.showCargoOnBoard();
			break;
		else
			result := app.showErrorWarningDialog('Delete Bill Of Lading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog

	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteCargo" id="b18e886c-3dd0-4950-8bb2-1d76db0de600">
        <updating/>
        <source>doDeleteCargo(_table : CM_DataTable io) updating;
//----------------------------------------------------------------
//	Created:	par 26708 cnwrs1 12 Jan 2011
//----------------------------------------------------------------
vars
	result 			: Integer;
	ti				: CM_TrackedItem;
	tiSet 			: CM_TISet;
	ta				: CM_TerminalArea;
	targetLocn 		: CM_LocationsController;
	tisWithWarnSet 	: CM_TISet;
	retval			: Integer;	
begin
	if self.myCurrentVoyage = null then 
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		
	
	create tiSet transient;
	self.getAllSelectedTIs(tiSet, false, _table);
		
	if tiSet.isEmpty then
		return;
	endif;

	foreach ti in tiSet do
		if ti.getReceiveDate().isValid then
			app.msgBox("Your selection contains cargo not suitable for deleting.  You can only delete unworked cargo.", 'Invalid Cargo', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
	endforeach;

	retval := app.msgBox("You are about to delete all the selected cargo items.  Continue?", 'Confirm Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if retval = MsgBox_Return_No then
		return;
	endif;
	
	create tisWithWarnSet transient;

	while true do
		app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Delete Ship Cargo', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete tisWithWarnSet;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doDevCreateNewCargo" id="1da08822-05f2-4baf-806d-7f2f9c396733">
        <source>doDevCreateNewCargo();
/*
Purpose:			
Date		Who		Reason
10/01/2013	cnwab1	Initial creation
31/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 new parameter for createQuickCargoShipLC
*/

vars
	slots : CM_LCSet;
	numItems, idx : Integer;
	is40 : Boolean;
	ct : CM_CargoType;
	ctType : String;
	mess, mess2 : String;
begin

	if app.msgBox("Create Containers (Yes) or GC (No)", "Cargo Type", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		is40 := app.msgBox("Create 40 foot?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes;
		if is40 then
			mess := "40 Foot";
		else
			mess := "20 Foot";
		endif;

		numItems := 10;
		read numItems;
		//mess2 := s

	
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Containers in " &amp; mess2  &amp; "?", "Quick Container Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
			create slots transient;
			slots.add(self.myCurrentVoyage.myShipBlockStack);
			
			foreach idx in 1 to numItems discreteLock do
				self.myCurrentVoyage.createQuickCargo(slots, is40);
			endforeach;

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			return;
		endif;
	else
		numItems := 10;
		read numItems;
		
		ctType := "CANNONBALL";
		read ctType;
		ct := app.myRoot.getCargoTypeFromAbbrev(ctType);
		if ct &lt;&gt; null then
			mess := ct.description;
		else
			mess := "GC";
		endif;
		
		mess2 := " on " &amp;  self.myCurrentVoyage.code;
		
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Items " &amp; mess2 &amp; "?", "Quick GC Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
		
			//self.myCurrentVoyage.createQuickCargoShipLC(numItems, ct);			// PAR #36766
			self.myCurrentVoyage.createQuickCargoShipLC(numItems, ct, null);		// PAR #36766

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			
			return;
			
		endif;

	endif;

epilog
	delete slots;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLinkItems" id="1d072fb3-2aca-49fa-a7e2-36705685b003">
        <updating/>
        <source>doLinkItems(_bol : CM_BOL input; _bolDetail : CM_BOLDtl input; _tiSet : CM_TISet input) updating, protected;

vars
	bolDetailMode : Boolean;
	count,
	idx,
	result 	: Integer;
	oldBOL		: CM_BOL;
	oldDetail	: CM_BOLDtl;
	ti		: CM_TrackedItem;
begin
	if (_bol = null and
	   _bolDetail = null) or
	   _tiSet = null then
		return;
	endif;
	// 23144 handle cargo linked to BOL but not BOL detail
	bolDetailMode := self.isBOLDetailMode();
	// if no change of item, or empty set just exit
	foreach ti in _tiSet do
		if bolDetailMode then
			if ti.myBOLDtl &lt;&gt; _bolDetail then
				count := count + 1;
				oldDetail := ti.myBOLDtl;
			endif;
		else
			if ti.myReceivalBOL &lt;&gt; _bol then
				count := count + 1;
				oldBOL := ti.myReceivalBOL;
			endif;
		endif;
	endforeach;
	if count = 0 then
		return;
	endif;

	while true do
		///app.myTrxUA.trxAttachTIsToBOLDtl(_tiSet, _bolDetail, app.myPassport); // original
		// par 23598 validate IMEX status
		self.validateCargo(_tiSet);
		if app.myPassport.noErrors then
			self.myBOLAgent.moveTIsToBOLDtl(_tiSet, _bol, _bolDetail);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			// refresh tables, buttons
			foreach ti in _tiSet do
				if self.tblCargo.findObjectInRow(ti, idx) then
					self.tblCargo.removeItem(idx);
					self.btnCOBEdit.enabled := false;
					self.btnCOBDelete.enabled := false;
					self.tblCargo.row := 1;			// so that a click in the table outside the range doesn't re-enable buttons in error
				endif;
			endforeach;
			if bolDetailMode then
				self.refreshBOLDetailEntry(oldDetail);
				self.showBOLDetailCargo();
			else
				self.refreshBOLEntry(oldBOL);
				self.showBOLCargo();
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Link BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknowledged so continue
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadVoyages" id="759b1ce3-704d-4d6e-828f-1dfeb92ab98d">
        <updating/>
