    <JadeMethod name="addCraneSheetForJobSheet" id="c8bd395b-f2b0-4126-af59-7c48cf60882d">
        <source>addCraneSheetForJobSheet(_jobSheet : CM_VoyageJobSheet input) : Boolean;
/*

Date		Who		Reason
21 March 2017	cnwer1	Initial creation TFS 830 - refactored out

*/

vars
	workPointObject : CM_Object;
	aCraneSheet			: CMUI_Sheet;
	idx : Integer;
begin
	if _jobSheet = null then
		return false;
	endif;
	
	workPointObject := _jobSheet.getMyWorkPointObject;
	if workPointObject = null then
		return false; 
	endif;
	//use the crane's instance id
	//epr par 34802 16/9/14 don't use crane instant id because cranes and workpoints could have the same instance id
	aCraneSheet:=self.getSheetForWorkPointObj(workPointObject);
	if aCraneSheet &lt;&gt; null then
		return true;
	endif;
	idx:=self.controlCount + 1;
	aCraneSheet := self.shtCrane.loadControl(idx).CMUI_Sheet;
	aCraneSheet.name := aCraneSheet.name &amp; workPointObject.IF_VoyageWorkPoint.getID;
	aCraneSheet.userObject := workPointObject;
	aCraneSheet.visible := true;
	aCraneSheet.parent := self.fldMain;
	aCraneSheet.caption :=_jobSheet.getOOWDescription;
	
	self.allLoadedSheets.add(aCraneSheet);
	
	
	return true;
epilog

end;</source>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="85ce3f22-d1e5-4539-a742-d61bbe06d644">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//	
// 24 Oct 2012	PJS			PAR #30631 - Voyage Rationalisaton		 
// ----------   ----------  --------------------------------------------------
vars
	frm			: CMUI_Toolbar;
begin
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.addButton(self.btnTBNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBLoadToOps, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBPosition, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBRenumber, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBMoveUp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBMoveDown, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAlloc, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCraneShifts,CMUI_Toolbar.Control_Alignment_Left); // TFS 3472

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	self.btnLashInfo.style := Button.Style_2State;
	frm.addButton(self.btnLashInfo, CMUI_Toolbar.Control_Alignment_Left);
	self.btnLashInfo.value := self.mnuContextLashInfo.caption = MNU_LASH_HIDE;

	self.btnJobTimes.style := Button.Style_2State;
	frm.addButton(self.btnJobTimes, CMUI_Toolbar.Control_Alignment_Left);
	self.btnJobTimes.value := self.mnuContextJobTimes.caption = MNU_TIMES_HIDE;
	
	self.btnHideHatchJobs.style := Button.Style_2State;
	frm.addButton(self.btnHideHatchJobs, CMUI_Toolbar.Control_Alignment_Left);
	self.btnHideHatchJobs.value := self.mnuContextHideHatchJob.caption = MNU_HATCH_SHOW;
	
	// frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	self.btnRemarks.style := Button.Style_2State;
	frm.addButton(self.btnRemarks, CMUI_Toolbar.Control_Alignment_Left);
	
	// 30631 -  forms are opened from here (previously on the navigator)
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnOOWCreation, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPlanGuide, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnOOWMonitor, CMUI_Toolbar.Control_Alignment_Left); //epr TFS 830 30/3/17
	frm.addButton(self.btnOOWConfirm,CMUI_Toolbar.Control_Alignment_Left); //15 Mar 2018	NDL	TFS 37447
	
	self.btnTBLoadToOps.caption := app.getErrorString(LoadUnload_Ops);  //30631
	self.btnTBLoadToOps.bubbleHelp := app.getErrorString(LoadUnload_Operations_Toggle); //30631
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="548e175a-f9db-4a32-adce-cae21321b0f1">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addTotalRowToTable" id="e33b4d26-a47a-4e56-97da-19cf7b27f1e1">
        <source>addTotalRowToTable(	_startCol, _endCol : Integer;
					_lineDesc : String;
					_totals : IntegerArray input) : Integer protected; // PAR 31756 return index
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theDataLine : String;
	idx			: Integer;	
begin
	theDataLine := Tab &amp; Tab &amp; _lineDesc &amp; Tab &amp; Tab &amp; Tab;
	foreach idx in _startCol to _endCol do
		if _totals[idx] &lt;&gt; 0 then
			theDataLine := theDataLine &amp; _totals[idx].String &amp; Tab;
		else
			theDataLine := theDataLine &amp; Tab;
		endif;
	endforeach;
	idx := self.tblData.addItem(theDataLine);

	return idx;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startCol" type="Integer"/>
        <Parameter name="_endCol" type="Integer"/>
        <Parameter name="_lineDesc" type="String"/>
        <Parameter name="_totals" type="IntegerArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
