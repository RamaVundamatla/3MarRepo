    <JadeMethod name="getSurchargeInvoiceLineType" id="154d7c5b-1844-448c-b978-c74a326030a5">
        <source>getSurchargeInvoiceLineType():CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.mySurchargeInvoiceLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;

epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
