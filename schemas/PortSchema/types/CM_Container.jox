    <JadeMethod name="setSweptDetails" id="7103e8b3-7917-4142-bd03-82477f94b0d7">
        <updating/>
        <source>setSweptDetails(_isSwept:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
