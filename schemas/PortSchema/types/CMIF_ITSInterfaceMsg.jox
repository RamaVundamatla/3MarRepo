    <JadeMethod name="getDisplayStringForAttribute" id="f97fcf01-d52a-40aa-ad0e-4bc6b24ae3ac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 

*/

vars

begin
	if _attrName = ETRow_CargoAttributes then
		return self.cargoAttributes;
	elseif _attrName = ETRow_CargoId then
		return self.containerId;	
	elseif _attrName = ETRow_DespatchNow then
		return self.despatchNow;	
	elseif _attrName = ETRow_ErrorCode then
		if self.errorCode = 0 then
			return null;
		else
			return self.errorCode.asStringJMT();	
		endif;
	elseif _attrName = ETRow_ErrorText then
		return self.errorText;	
	elseif _attrName = ETRow_Machine then
		return self.machineId;	
	elseif _attrName = ETRow_MessageNumber then
		if self.messageNumber = 0 then
			return null;
		else
			return self.messageNumber.asStringJMT();	
		endif;
	elseif _attrName = ETRow_MessageType then
		return self.messageType;	
	elseif _attrName = ETRow_MessageVersion then
		if self.messageVersion = 0 then
			return null;
		else
			return self.messageVersion.asStringJMT();	
		endif;
	elseif _attrName = ETRow_Created then
		if self.myMessage &lt;&gt; null then
			//return self.myMessage.createdTS.asStringJMT();
			return self.myMessage.createdTS.formatAsYYYYMMDDHHMMSSMMM;	//11 Feb 2016	NDL	Par 37534
		else
			return null;
		endif;
	elseif _attrName = ETRow_Processed then
		if self.myMessage &lt;&gt; null then
			//return self.myMessage.processedTS.asStringJMT();
			return self.myMessage.processedTS.formatAsYYYYMMDDHHMMSSMMM;	//11 Feb 2016	NDL	Par 37534
		else
			return null;
		endif;
	elseif _attrName = ETRow_OriginalMessageNo then
		if self.originalMsgNo = 0 then
			return null;
		else
			return self.originalMsgNo.asStringJMT();		
		endif;
	elseif _attrName = ETRow_EntryType then
		return self.entryType;		
	elseif _attrName = ETRow_QueueEntryId then
		if self.queueEntryId = 0 then
			return null;
		else
			return self.queueEntryId.asStringJMT();		
		endif;		
	elseif _attrName = ETRow_RequiresWeighing then
		return self.requiresWeighing;	
	elseif _attrName = ETRow_SourceAttributes then
		return self.sourceAttributes;	
	elseif _attrName = ETRow_SourceLocation then
		return self.sourceLocation;	
	elseif _attrName = ETRow_SourceLocationType then
		return self.sourceLocationType;	
	elseif _attrName = ETRow_SourceAttributes then
		return self.sourceAttributes;	
	elseif _attrName = ETRow_TargetAttributes then
		return self.targetAttributes;	
	elseif _attrName = ETRow_TargetLocation then
		return self.targetLocation;	
	elseif _attrName = ETRow_TargetLocationType then
		return self.targetLocationType;	
	elseif _attrName = ETRow_UserName then
		return self.userName;	
	elseif _attrName = ETRow_Weight then
		if self.weight = 0 then
			return null;
		else
			return self.weight.asStringJMT();			
		endif;		
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUser" id="00e91cb2-a778-408b-a270-0f23ab8e8cc9">
        <source>getUser() : CM_User;

/*

Purpose:			Get user specified in the message

Parameters:			None

Return Value:		The User.


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if self.myMessage.isKindOf(CM_ITSInterfaceRequestInternal) then
		return myMessage.CM_ITSInterfaceRequestInternal.myUser;
	endif;
	
	if self.userName = null then
		return null;
	endif;
	
	return app.myRoot.allUsers[self.userName];
	
epilog

end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setMessage" id="5f4a6f4a-1c12-43e2-b973-acf0e7e1db2b">
        <updating/>
        <source>setMessage(_message : CM_ITSInterfaceMessage; _validateFormat : Boolean) updating;

/*

Purpose:			Get ITS Interface Message property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		This object will be populated with values from the given message.


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	
begin
	if self.myMessage &lt;&gt; null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Message already set', null, null);
	endif;
	
	self.myMessage 				:= _message;
	self.myInterfaceDefinition	:= self.myMessage.myITSInterfaceDefinition;
	self.myMachine				:= self.myMessage.myMachine;

	_message.populateCmifMessage( self, _validateFormat );

epilog

end;</source>
        <Parameter name="_message" type="CM_ITSInterfaceMessage"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
</Class>
