    <JadeMethod name="getCargoType" id="91332bcf-9955-494c-a9d5-73ca0020c136">
        <source>getCargoType() : CM_CargoType;

// cnwdvb1 22 October 2002 

vars

	line	: CM_StockOrderProductLine;

begin

	if not self.type = StockOrderHeaderType_Domestic then
		return null;
	endif;
	
	// We only want first order line for Domestic.
	line := self.allStockOrderLines.first.CM_StockOrderProductLine;
	if line = null then
		return null;
	endif;
	
	return line.myProduct.myCargoType;
	
		

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getConsigneeCode" id="1180085b-5bd8-44da-a6af-8d6621662196">
