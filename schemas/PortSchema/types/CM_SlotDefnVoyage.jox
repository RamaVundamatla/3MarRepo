    <JadeMethod name="validateForUpdate" id="054b33e4-cd81-4b01-bcf9-c3d89ff66668">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aSlotReq : CM_SlotRequest;
	aSC : CM_SlotController;
	is40 : Boolean;
begin
	inheritMethod();
	
	if self.isTransient then
		return;
	endif;
	
	aSC := self.mySlotController;
	if aSC &lt;&gt; null then 
		if self.unavailable then
			if not aSC.allTrackedItems.isEmpty() then
				app.raiseCMException3(ERR_SLOT_IN_CC, aSC.getStowageId(null), aSC.myVoyage.code," cargo", null, null);
			endif;
			if not aSC.allPlannedFutureMoves.isEmpty() then
				app.raiseCMException3(ERR_SLOT_IN_CC, aSC.getStowageId(null), aSC.myVoyage.code," planned cargo", null, null);
			endif;
			if not aSC.allSlotRequestsDischarge.isEmpty() then
				app.raiseCMException2(WARN_ALREADY_COLOUR_CODED, 'DISCHARGE ', aSC.getFullId &amp; " cannot be made unavailable", null, null);
			endif;
			if not aSC.allSlotRequestsLoad.isEmpty() then
				app.raiseCMException2(WARN_ALREADY_COLOUR_CODED, 'LOAD ', aSC.getFullId &amp; " cannot be made unavailable", null, null);
			endif;
		endif;
		
		foreach aSlotReq in aSC.allSlotRequestsDischarge do
			if aSlotReq.getAttrIs40() then
				if not (self.fortyBack or self.fortyFront) then
					app.raiseCMException2(WARN_ALREADY_COLOUR_CODED, 'DISCHARGE ', aSC.getFullId &amp; 
							" is colour coded for a 40, cannot be made non 40 compatible. Erase colour coding to continue.", null, null);
			
				endif;
			endif;
		endforeach;
		foreach aSlotReq in aSC.allSlotRequestsLoad do
			if aSlotReq.getAttrIs40() then
				if not (self.fortyBack or self.fortyFront) then
					app.raiseCMException2(WARN_ALREADY_COLOUR_CODED, 'LOAD ', aSC.getFullId &amp; 
							" is colour coded for a 40, cannot be made non 40 compatible. Erase colour coding to continue.", null, null);
			
				endif;
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateLoadCCDischargePort" id="6ad34caf-4149-4476-afda-439fc08c0905">
        <source>validateLoadCCDischargePort(_dischargePort : CM_Port);
/*

Purpose:		For CCMS 1058 If a box is planned on top of another, which has a discharge port before the box being stowed

				validates that the colour code of this discharge port _dischargePort is higher in the
				voyages port rotation list than any load slot requests discharge port that are below in the voyages cell.
				

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	cnwer1	Initial creation

*/

vars
	tmpSlotDefn : CM_SlotDefn;
	disPort : CM_Port;
	slotIter : Iterator;
	pocCurrentOrder,
	pocNewOrder : Integer;
begin
	if self.getVoyage = null then
		return;
	endif;
	pocCurrentOrder:=self.getVoyage.allPorts.indexOf(_dischargePort);
	//validate that any containers in cells below 
	delete slotIter;
	slotIter:=self.myCellDefinition.allSlotDefinitions.createIterator;
	slotIter.startAtObject(self);
	slotIter.back(tmpSlotDefn);
	while slotIter.back(tmpSlotDefn) do
		if tmpSlotDefn.CM_SlotDefnVoyage.mySlotController.mySlotRequestLoad = null then
			continue;
		endif;
		disPort:=tmpSlotDefn.CM_SlotDefnVoyage.mySlotController.mySlotRequestLoad.getAttrDischargePort();
		if disPort = null then
			continue;
		endif;
		if tmpSlotDefn.CM_SlotDefnVoyage.getVoyage.allPorts.indexOf(disPort) &lt; pocCurrentOrder then
		//we have a problem because this container has to come off before this one but we are overstowing it
			app.raiseCMWarning3(Warn_CC_Ports_of_call,tmpSlotDefn.getStowageId(false,useBayCellTierNumbering),disPort.code,_dischargePort.code,null,null,null);

		endif;
	endwhile;

epilog
	delete slotIter;
end;</source>
        <Parameter name="_dischargePort" type="CM_Port"/>
    </JadeMethod>
