    <JadeMethod name="getDrawingAttributes" id="b447535c-efb5-492c-b032-4ef7b7005ce8">
        <source>getDrawingAttributes(pDisplay: Integer; pView: Integer; pHeight: Integer; pColour: Integer output; pLetter: String output);
/*
----------   ----------  --------------------------------------------------
Created:	11 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(pDisplay, pView, pHeight, pColour, pLetter);
	pLetter := "L";
	if pColour = NULL_COLOURCODE then
		pColour := Gray;
	endif;

end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="893c04fd-7ea2-423a-8037-93718962b673">
        <source>getFullId() : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtgBay : CM_RTGBay;
begin
	rtgBay:=self.getMyRTGBay;
	if rtgBay&lt;&gt; null then
		return rtgBay.getFullID(false); 
		//return self.myGridArea.getID() &amp; rtgBay.myRTGLane.getID &amp; rtgBay.label &amp; "00";
	endif;
	
	return inheritMethod;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
