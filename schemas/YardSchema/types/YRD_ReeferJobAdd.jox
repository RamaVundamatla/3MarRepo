    <JadeMethod name="setTableDataFromOrganiser" id="8cf02b3a-b75b-4851-af45-ad49120c0375">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	columnIndex : Integer;
	str : String;
	rowIndex: Integer;
	ti : CM_TrackedItem;

begin

	self.tblReefers.rows := 1;
	columnIndex := self.tblReefers.getColumnByRowName( ETRow_Selected );
	
	foreach ti in self.allDisplayedReefers do
		str := ti.getAttributeStringForDefArray(self.tblReefers.allTblDataEntRows);
		rowIndex := self.tblReefers.addItem( str );
		self.tblReefers.accessCell( rowIndex, columnIndex ).text := "1";		// selected by default
		self.tblReefers.accessRow( rowIndex ).itemObject := ti;	
	endforeach;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c0219e2d-b1ec-4401-8641-4317ebe5c1c8">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	tFS 49581
09 May  2025    navsp1  JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
*/

vars

	now : TimeStamp;
	nowLocal : TimeStamp;
	etDef : EntTableDef;
	columnIndex : Integer;

begin

//	self.tblReefers.columns := 3;
//	self.tblReefers.fixedColumns := 0;
//	self.tblReefers.rows := 1;
//	self.tblReefers.fixedRows := 1;
	
//	self.tblReefers.userInputEnabled := true;

	etDef := app.myController.getEntTableDef(ETDef_ReeferAddSelection);
	self.tblReefers.setColumnHeadingsFromDef(etDef.name, false);
	self.tblReefers.setMyEntTableDef(etDef);
	self.tblReefers.setTblDataEntRowsFromDef(etDef);

	self.tblReefers.selectMode := CM_DataTable.SelectMode_None;
	self.tblReefers.showFocus := false;
	columnIndex := self.tblReefers.getColumnByRowName( ETRow_Selected );
	self.tblReefers.accessColumn(columnIndex).inputType := Table.InputType_CheckBox;
	self.tblReefers.userInputEnabled := true;
	self.tblReefers.autoSize := Table.AutoSize_Column;
	
	self.cmbJobType.clear();
	self.cmbJobType.addItem( CM_YardActivity.ReeferAlarmStr );
	self.cmbJobType.addItem( CM_YardActivity.ReeferConnectStr );
	self.cmbJobType.addItem( CM_YardActivity.ReeferDisconnectStr );
	self.cmbJobType.addItem( CM_YardActivity.ReeferMonitorStr );
	
	now := app.actualTimeAppServer;
	nowLocal := self.myTerminal.systemToLocalTime( now );
	
	self.txtDate.setDate( nowLocal.Date );
	self.txtTime.setTime( nowLocal.Time );
	
	inheritMethod();
	
	self.minimumWidth := 541;
	self.minimumHeight := 650;
	
	self.btnOk.visible := false;
	self.btnCancel.caption := app.getErrorString( Close );

    if self.allDisplayedReefers &lt;&gt; null then                //JIRA-34514
        self.setTableDataFromOrganiser(self.tblReefers);    //JIRA-34514
    endif;                                                  //JIRA-34514
    
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblReefers_contextMenu" id="46d5e6c4-61d7-4fb1-9c45-664656b130c5">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	rowIndex : Integer;
	obj : Object;

begin

	rowIndex := self.tblReefers.row;
	if rowIndex &gt; 1 then
		obj := self.tblReefers.accessRow( rowIndex ).itemObject;
	endif;

	self.mnuInspectObj.visible := obj &lt;&gt; null and ( app.isDevelopmentSystem or app.getMyUser.isSuperUser );
	self.mnuInspectObj.userObject := obj;
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblReefers_dblClick" id="923cde28-b431-4667-a4f7-352a7f35d7b5">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	tmpCol : Integer;
	tmpRow : Integer;

begin

	tmpCol := table.column;
	tmpRow := table.row;
	if tmpRow = table.fixedRows then
		table.CM_DataTable.resortTableByColumn(tmpCol);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b95d68f8-520e-4169-8e7a-65baeb091755">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 August 2020 11:09:44.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023977, locale);
	btnById.translateCaption(Xlat_0023978, locale);
	btnBySelector.translateCaption(Xlat_0023979, locale);
	btnCreateJobs.translateCaption(Xlat_0023980, locale);
	grpOptions.translateCaption(Xlat_0023981, locale);
	grpSelected.translateCaption(Xlat_0023982, locale);
	lblAction.translateCaption(Xlat_0023983, locale);
	lblAddJobs.translateCaption(Xlat_0023984, locale);
	lblJobType.translateCaption(Xlat_0023985, locale);
	mnuColOrg.translateCaption(Xlat_0023986, locale);
	mnuContext.translateCaption(Xlat_0023987, locale);
	mnuInspectObj.translateCaption(Xlat_0023988, locale);
	optId.translateCaption(Xlat_0023989, locale);
	optSelector.translateCaption(Xlat_0023990, locale);
	optVoyage.translateCaption(Xlat_0023991, locale);
end;</source>
    </JadeMethod>
</GUIClass>
