    <JadeMethod name="doDelete" id="1d5eb1b6-ba2f-47cd-bd3b-bae8f44f7de4">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	answer			: Integer;
	camTaskHistory	: CM_CamTaskHistory;
	taskHistArray	: ObjectArray;
	table			: CM_DataTable;
	theResult 		: Integer;
begin	
	
	if self.tblData.allSelectedObjects.isEmpty then
		return;
	endif;
	
	answer := app.msgBox("Are you sure you want to delete the selected tasks?",
				"Delete Task History", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	table := self.tblData;
	
	create taskHistArray transient; 
	
	table.allSelectedObjects.copy(taskHistArray);
	
	while true do
		app.myTrxDA.trxDeleteCamHistGroup(taskHistArray, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Delete Task History", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	self.populateTableCams();
epilog
	delete taskHistArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="0a1fb3cb-3e9c-4f05-a35a-73231afd09ff">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	filterText,
 	cellText	: String;
	start,
	colIdx,
	rowIdx		: Integer;
	cell		: JadeTableCell;
	answer		: Integer;
begin	
	filterText := self.frmTblFilter.txtFilterBox.text.toUpper();
	
	if self.frmTblFilter &lt;&gt; null then
		self.showSelectedCount(self.tblData.allSelectedObjects.size, self.frmTblFilter.numOfRowVisible);
	endif;

	self.tblData.topRow := 1;
epilog

end;
</source>
    </JadeMethod>
