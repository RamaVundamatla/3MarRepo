    <JadeMethod name="getValidLCsCollectionForMove" id="506d3cf4-d8ae-447c-ae16-00fa9a9baf57">
        <source>getValidLCsCollectionForMove( _lcSet : CM_LCSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	lc : CM_LocationsController;
	shelf : CM_RackShelfController;

begin

	foreach lc in self.allLocationsControllers do
		if lc.isRack then
			foreach shelf in lc.CM_IrregularBlockController.allSubLocations do
				_lcSet.add( shelf );
			endforeach;
			continue;
		endif;
		_lcSet.add( lc );
	endforeach;

epilog

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
