    <JadeMethod name="doSave" id="dda7ffcc-7f79-4d55-b3d8-8c7c077c7d6c">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2018	jlgndl1	Initial creation	TFS 39215
25/06/2018	jlgdap1	TFS 39355 PEL1 Pllot Surcharges
20/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
28/03/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

	linesActualTS : TimeStamp;
	linesApprovedTS : TimeStamp;
	linesRequestedTS : TimeStamp;	
	movementActualTS : TimeStamp;
	movementApprovedTS : TimeStamp;
	movementRequestedTS : TimeStamp;	
	pilotActualTS : TimeStamp;
	pilotApprovedTS : TimeStamp;
	pilotRequestedTS : TimeStamp;	
	tugsActualTS : TimeStamp;
	tugsApprovedTS : TimeStamp;
	tugsRequestedTS : TimeStamp;
	tugsActualTSTo : TimeStamp;				// TFS 39741
	tugsApprovedTSTo : TimeStamp;			// TFS 39741
	tugsRequestedTSTo : TimeStamp;			// TFS 39741
	pilotStartMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
	pilotFinshMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
	pilotOffBoardTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
	movementBerthArrTS : TimeStamp;	//26 Oct 2018	NDL	TFS 41413
	
	theReturn : Integer;

begin

	linesActualTS.setDate( self.txtLinesActDate.getDate );
	linesActualTS.setTime( self.txtLinesActTime.getTime );
	linesApprovedTS.setDate( self.txtLinesApprDate.getDate );
	linesApprovedTS.setTime( self.txtLinesApprTime.getTime );
	linesRequestedTS.setDate( self.txtLinesReqDate.getDate );
	linesRequestedTS.setTime( self.txtLinesReqTime.getTime );
	
	movementActualTS.setDate( self.txtMoveActDate.getDate );
	movementActualTS.setTime( self.txtMoveActTime.getTime );
	movementApprovedTS.setDate( self.txtMoveApprDate.getDate );
	movementApprovedTS.setTime( self.txtMoveApprTime.getTime );
	movementRequestedTS.setDate( self.txtMoveReqDate.getDate );
	movementRequestedTS.setTime( self.txtMoveReqTime.getTime );
	movementBerthArrTS.setDate( self.txtBerthArrDate.getDate );	//26 Oct 2018	NDL	TFS 41413
	movementBerthArrTS.setTime( self.txtBerthArrTime.getTime );	//26 Oct 2018	NDL	TFS 41413
	
	pilotActualTS.setDate( self.txtPilotActDate.getDate );
	pilotActualTS.setTime( self.txtPilotActTime.getTime );
	pilotApprovedTS.setDate( self.txtPilotApprDate.getDate );
	pilotApprovedTS.setTime( self.txtPilotApprTime.getTime );
	pilotRequestedTS.setDate( self.txtPilotReqDate.getDate );	
	pilotRequestedTS.setTime( self.txtPilotReqTime.getTime );	
	
	tugsActualTS.setDate( self.txtTugsActDate.getDate );
	tugsActualTS.setTime( self.txtTugsActTime.getTime );
	tugsApprovedTS.setDate( self.txtTugsApprDate.getDate );
	tugsApprovedTS.setTime( self.txtTugsApprTime.getTime );
	tugsRequestedTS.setDate( self.txtTugsReqDate.getDate );
	tugsRequestedTS.setTime( self.txtTugsReqTime.getTime );
	tugsActualTSTo.setDate( self.txtTugsActDateTo.getDate );			// TFS 39741
	tugsActualTSTo.setTime( self.txtTugsActTimeTo.getTime );			// TFS 39741
	tugsApprovedTSTo.setDate( self.txtTugsApprDateTo.getDate );			// TFS 39741
	tugsApprovedTSTo.setTime( self.txtTugsApprTimeTo.getTime );			// TFS 39741
	tugsRequestedTSTo.setDate( self.txtTugsReqDateTo.getDate );			// TFS 39741
	tugsRequestedTSTo.setTime( self.txtTugsReqTimeTo.getTime );			// TFS 39741
	
	//14 Sep 2018	NDL	TFS 40876
	pilotStartMoveTS.setDate( self.txtPilotStartDate.getDate );
	pilotStartMoveTS.setTime( self.txtPilotStartTime.getTime );
	pilotFinshMoveTS.setDate( self.txtPilotFinishDate.getDate );
	pilotFinshMoveTS.setTime( self.txtPilotFinishTime.getTime );
	pilotOffBoardTS.setDate( self.txtPilotOffDate.getDate );	
	pilotOffBoardTS.setTime( self.txtPilotOffTime.getTime );

	self.myMarineServicesTimings.setProxy(	linesActualTS.localToSystemTimeUsingObject(self.myTerminal),	//_linesActualTS : TimeStamp;
											linesApprovedTS.localToSystemTimeUsingObject(self.myTerminal),	//_linesApprovedTS : TimeStamp;
											self.txtLinesRemarks.text.trimBlanks,	//_linesRemarks : String;
											linesRequestedTS.localToSystemTimeUsingObject(self.myTerminal),	//_linesRequestedTS : TimeStamp;	
											movementActualTS.localToSystemTimeUsingObject(self.myTerminal),	//_movementActualTS : TimeStamp;
											movementApprovedTS.localToSystemTimeUsingObject(self.myTerminal),	//_movementApprovedTS : TimeStamp;
											self.txtMoveRemarks.text.trimBlanks,	//_movementRemarks : String;
											movementRequestedTS.localToSystemTimeUsingObject(self.myTerminal),	//_movementRequestedTS : TimeStamp;	
											pilotActualTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotActualTS : TimeStamp;
											pilotApprovedTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotApprovedTS : TimeStamp;
											self.txtPilotRemarks.text.trimBlanks,	//_pilotRemarks : String;
											pilotRequestedTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotRequestedTS : TimeStamp;	
											tugsActualTS.localToSystemTimeUsingObject(self.myTerminal),	//_tugsActualTS : TimeStamp;
											tugsApprovedTS.localToSystemTimeUsingObject(self.myTerminal),	//_tugsApprovedTS : TimeStamp;
											self.txtTugsRemarks.text.trimBlanks,	//_tugsRemarks : String;
											tugsRequestedTS.localToSystemTimeUsingObject(self.myTerminal),	//_tugsRequestedTS : TimeStamp;
											self.chkTooSoon.value,	//_pilotSurchargeRTS : Boolean;		// TFS 39355
											self.chkNotReady.value,	//_pilotSurchargeVNR : Boolean;		// TFS 39355
											tugsRequestedTSTo.localToSystemTimeUsingObject(self.myTerminal),		//_tugsRequestedTSTo : TimeStamp	// TFS 39741
											tugsApprovedTSTo.localToSystemTimeUsingObject(self.myTerminal),		//_tugsApprovedTSTo : TimeStamp		// TFS 39741
											tugsActualTSTo.localToSystemTimeUsingObject(self.myTerminal),		//tugsActualTSTo : TimeStamp			// TFS 39741
											self.myMarineServicesTimings.myMovement,	//_movement : HMS_Movement
											pilotStartMoveTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotStartMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
											pilotFinshMoveTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotFinshMoveTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
											pilotOffBoardTS.localToSystemTimeUsingObject(self.myTerminal),	//_pilotOffBoardTS : TimeStamp;	//14 Sep 2018	NDL	TFS 40876
											movementBerthArrTS.localToSystemTimeUsingObject(self.myTerminal),	//_movementBerthArrTS : TimeStamp;	//26 Oct 2018	NDL	TFS 41413
											self.chkUsedRamp.value											//_usedRamp : Boolean	// TFS 43694
											);
											
	if not self.doTrxInSave then
		return true;
	
	endif;
	
	
	//We were initiated from Movement Maint so we will be doing our own persistent updating
	while true do
		app.myTrxUA.trxUpdateMarineTimings(self.myMarineServicesTimings, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Marine Services Timings", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		return false;
	
	endwhile;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyMarineServicesTimings" id="ef160d37-2a84-40bc-9475-bd5293d14688">
        <updating/>
        <source>setMyMarineServicesTimings( _voyageMovement : HMS_VoyageMovement input; _cmif : CMIF_HMS_WorkingMovement ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

	proxy : HMS_MarineServicesTimings;
	load : Boolean;

begin

	if _cmif &lt;&gt; null then
		self.doTrxInSave := false;
		//We are coming from the Harbour maint form, Working Movements where we are just updating the proxy
		//and the save on the parent form does the persistent updating
		self.myMarineServicesTimings := _cmif.myProxyMarineServicesTimings;	
		
	elseif _voyageMovement &lt;&gt; null then
		self.doTrxInSave := true;
		//We are coming from Movement Maint so we will be doing our own persistent updating
		if _voyageMovement.myMarineServiceTimings = null then
			create proxy transient;
			proxy.setMyVoyageMovement( _voyageMovement );
		else
			app.cmsBeginLoad(load);
			proxy := _voyageMovement.myMarineServiceTimings.pxyCreateUpdateProxy();
			app.cmsEndLoad(load);
		endif;
		self.myMarineServicesTimings := proxy;
		
	endif;

epilog

	app.cmsEndLoad(load);

end;</source>
        <Parameter name="_voyageMovement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_cmif" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ffebde4a-98fa-461c-9b16-f7f205e09520">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2018	jlgndl1	Initial creation	TFS 39215
22/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
20/07/2018	jlgdap1	TFS 39741 PEL1 marine Service Timings Changes
28/03/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

begin

	
	self.grpMain.left := 0;
	self.grpMain.top := 0;
	self.grpMain.borderStyle := 0;
	
	self.clientWidth := self.grpMain.width.Integer;
	self.clientHeight := self.grpMain.height.Integer - self.frmToolbar.height.Integer;
	
	self.handleMenusForModalDisplay();
	
	self.centreOverParent(1);

	inheritMethod();
	
	self.modalResult := IDCANCEL;
	
	self.txtLinesActDate.setDate( self.myMarineServicesTimings.getLinesActualDTLocalTZ.Date );
	self.txtLinesActTime.setTime( self.myMarineServicesTimings.getLinesActualDTLocalTZ.Time );
	self.txtLinesApprDate.setDate( self.myMarineServicesTimings.getLinesApprovedDTLocalTZ.Date );
	self.txtLinesApprTime.setTime( self.myMarineServicesTimings.getLinesApprovedDTLocalTZ.Time );
	self.txtLinesReqDate.setDate( self.myMarineServicesTimings.getLinesRequestedDTLocalTZ.Date );
	self.txtLinesReqTime.setTime( self.myMarineServicesTimings.getLinesRequestedDTLocalTZ.Time );
	self.txtLinesRemarks.text := self.myMarineServicesTimings.linesRemarks;
	
	
	self.txtMoveActDate.setDate( self.myMarineServicesTimings.getMovementActualDTLocalTZ.Date );
	self.txtMoveActTime.setTime( self.myMarineServicesTimings.getMovementActualDTLocalTZ.Time );
	self.txtMoveApprDate.setDate( self.myMarineServicesTimings.getMovementApprovedDTLocalTZ.Date );
	self.txtMoveApprTime.setTime( self.myMarineServicesTimings.getMovementApprovedDTLocalTZ.Time );
	self.txtMoveReqDate.setDate( self.myMarineServicesTimings.getMovementRequestedDTLocalTZ.Date );
	self.txtMoveReqTime.setTime( self.myMarineServicesTimings.getMovementRequestedDTLocalTZ.Time );
	self.txtBerthArrDate.setDate( self.myMarineServicesTimings.getMovementBerthArrDTLocalTZ.Date );		//26 Oct 2018	NDL	TFS 41413
	self.txtBerthArrTime.setTime( self.myMarineServicesTimings.getMovementBerthArrDTLocalTZ.Time );		//26 Oct 2018	NDL	TFS 41413
	self.txtMoveRemarks.text := self.myMarineServicesTimings.movementRemarks;
	self.chkUsedRamp.value := self.myMarineServicesTimings.hasRamp;						// TFS 43694
	
	
	self.txtPilotActDate.setDate( self.myMarineServicesTimings.getPilotActualDTLocalTZ.Date );
	self.txtPilotActTime.setTime( self.myMarineServicesTimings.getPilotActualDTLocalTZ.Time );
	self.txtPilotApprDate.setDate( self.myMarineServicesTimings.getPilotApprovedDTLocalTZ.Date );
	self.txtPilotApprTime.setTime( self.myMarineServicesTimings.getPilotApprovedDTLocalTZ.Time );
	self.txtPilotReqDate.setDate( self.myMarineServicesTimings.getPilotRequestedDTLocalTZ.Date );	
	self.txtPilotReqTime.setTime( self.myMarineServicesTimings.getPilotRequestedDTLocalTZ.Time );	
	self.txtPilotRemarks.text := self.myMarineServicesTimings.pilotRemarks;
	
	
	self.txtTugsActDate.setDate( self.myMarineServicesTimings.getTugsActualDTLocalTZ.Date );
	self.txtTugsActTime.setTime( self.myMarineServicesTimings.getTugsActualDTLocalTZ.Time );
	self.txtTugsApprDate.setDate( self.myMarineServicesTimings.getTugsApprovedDTLocalTZ.Date );
	self.txtTugsApprTime.setTime( self.myMarineServicesTimings.getTugsApprovedDTLocalTZ.Time );
	self.txtTugsReqDate.setDate( self.myMarineServicesTimings.getTugsRequestedDTLocalTZ.Date );
	self.txtTugsReqTime.setTime( self.myMarineServicesTimings.getTugsRequestedDTLocalTZ.Time );
	self.txtTugsActDateTo.setDate( self.myMarineServicesTimings.getTugsActualDTToLocalTZ.Date );		// TFS 39741
	self.txtTugsActTimeTo.setTime( self.myMarineServicesTimings.getTugsActualDTToLocalTZ.Time );		// TFS 39741
	self.txtTugsApprDateTo.setDate( self.myMarineServicesTimings.getTugsApprovedDTToLocalTZ.Date );		// TFS 39741
	self.txtTugsApprTimeTo.setTime( self.myMarineServicesTimings.getTugsApprovedDTToLocalTZ.Time );		// TFS 39741
	self.txtTugsReqDateTo.setDate( self.myMarineServicesTimings.getTugsRequestedDTToLocalTZ.Date );		// TFS 39741
	self.txtTugsReqTimeTo.setTime( self.myMarineServicesTimings.getTugsRequestedDTToLocalTZ.Time );		// TFS 39741
	self.txtTugsRemarks.text := self.myMarineServicesTimings.tugsRemarks;
	
	//14 Sep 2018	NDL	TFS 40876
	self.txtPilotStartDate.setDate( self.myMarineServicesTimings.getPilotStartMoveDTToLocalTZ.Date );
	self.txtPilotStartTime.setTime( self.myMarineServicesTimings.getPilotStartMoveDTToLocalTZ.Time );
	self.txtPilotFinishDate.setDate( self.myMarineServicesTimings.getPilotFinishMoveDTToLocalTZ.Date );
	self.txtPilotFinishTime.setTime( self.myMarineServicesTimings.getPilotFinishMoveDTToLocalTZ.Time );
	self.txtPilotOffDate.setDate( self.myMarineServicesTimings.getPilotOffBoardDTToLocalTZ.Date );	
	self.txtPilotOffTime.setTime( self.myMarineServicesTimings.getPilotOffBoardDTToLocalTZ.Time );
	
	self.btnSave.enabled := app.getMyUser.canDo( self.myTerminal, self.permissionMaint );
	
	self.chkNotReady.enabled := false;															// TFS 39355
	self.chkNotReady.value := self.myMarineServicesTimings.pilotSurchargeInvLIneTypeVNR;		// TFS 39355
	self.chkTooSoon.enabled := false;															// TFS 39355
	self.chkTooSoon.value := self.myMarineServicesTimings.pilotSurchargeInvLIneTypeRTS;			// TFS 39355
	self.btnRecalc.enabled := app.getMyUser.canDo(self.myTerminal, PmShpMarineVoyageNotReady)	// TFS 39355
								or app.getMyUser.canDo(self.myTerminal, PmShpMarineTooSoon);	// TFS 39355
	self.chkNotReady.bubbleHelp := app.getErrorString(Pilot_requs_certa_time_vesse_n);			// TFS 39355
	if self.myMarineServicesTimings.myMovement.moveType = HMSMovementTypeArrival then			// TFS 39355
		self.chkTooSoon.bubbleHelp := app.getErrorString(Reque_pilot_servi_arriv_movem);		// TFS 39355
	else																						// TFS 39355
		self.chkTooSoon.bubbleHelp := app.getErrorString(Reque_pilot_servi_depar_shift);		// TFS 39355
	endif;																						// TFS 39355
	//self.checkNotReadySurcharge();																// TFS 39355
	//self.checkTooSoonSurcharge();																// TFS 39355
	
	//06 Dec 2018	NDL	TFS 42403
	if self.checkNotReadySurcharge( true ) or self.checkTooSoonSurcharge( true ) then
		self.btnRecalc.foreColor := Red;
		self.shtPilots.setFocus();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cae335b3-305c-4ded-905a-12b4b2424969">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 April 2019 13:39:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022611, locale);
	btnClose.translateCaption(Xlat_0022612, locale);
	btnRecalc.translateCaption(Xlat_0022648, locale);
	btnSave.translateCaption(Xlat_0022613, locale);
	chkNotReady.translateCaption(Xlat_0022649, locale);
	chkTooSoon.translateCaption(Xlat_0022650, locale);
	chkUsedRamp.translateCaption(Xlat_0023565, locale);
	grpPilotSurcharge.translateCaption(Xlat_0022651, locale);
	lblBerthArr.translateCaption(Xlat_0023060, locale);
	lblLinesAct.translateCaption(Xlat_0022614, locale);
	lblLinesAppr.translateCaption(Xlat_0022615, locale);
	lblLinesRems.translateCaption(Xlat_0022616, locale);
	lblLinesReq.translateCaption(Xlat_0022617, locale);
	lblMoveAct.translateCaption(Xlat_0022618, locale);
	lblMoveAppr.translateCaption(Xlat_0022619, locale);
	lblMoveRems.translateCaption(Xlat_0022620, locale);
	lblMoveReq.translateCaption(Xlat_0022621, locale);
	lblPilotAct.translateCaption(Xlat_0022634, locale);
	lblPilotAppr.translateCaption(Xlat_0022623, locale);
	lblPilotFinishMove.translateCaption(Xlat_0022991, locale);
	lblPilotOffBoard.translateCaption(Xlat_0022992, locale);
	lblPilotRems.translateCaption(Xlat_0022624, locale);
	lblPilotReq.translateCaption(Xlat_0022625, locale);
	lblPilotStartMove.translateCaption(Xlat_0022993, locale);
	lblTugsAct.translateCaption(Xlat_0022626, locale);
	lblTugsActTo.translateCaption(Xlat_0022863, locale);
	lblTugsAppr.translateCaption(Xlat_0022627, locale);
	lblTugsApprTo.translateCaption(Xlat_0022864, locale);
	lblTugsRems.translateCaption(Xlat_0022628, locale);
	lblTugsReq.translateCaption(Xlat_0022629, locale);
	lblTugsReqTo.translateCaption(Xlat_0022865, locale);
	shtLines.translateCaption(Xlat_0022630, locale);
	shtMovement.translateCaption(Xlat_0022631, locale);
	shtPilots.translateCaption(Xlat_0022632, locale);
	shtTugs.translateCaption(Xlat_0022633, locale);
end;</source>
    </JadeMethod>
