    <JadeMethod name="exportMyCollectionsXML" id="fb67833b-f9d6-46ca-9a60-79c80bfe9767">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);

vars
	code		: CM_Code;
begin
	_file.writeLine('&lt;'&amp;CM_ProductAttr::allCodes.name&amp;'&gt;');
	foreach code in self.allCodes do
		code.exportMeXML(_file, _objArray, false, false);
	endforeach;
	_file.writeLine('&lt;/'&amp;CM_ProductAttr::allCodes.name&amp;'&gt;');

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="1da9ba0e-c035-46e7-b740-24a6069c27d0">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myCode &lt;&gt; null then
		_file.writeLine('&lt;'&amp;CM_ProductAttr::myCode.name&amp;'&gt;');
		self.myCode.exportMeXML(_file, _objArray, false, false);
		_file.writeLine('&lt;/'&amp;CM_ProductAttr::myCode.name&amp;'&gt;');
	endif;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDefaultMeasurementName" id="fd999776-84ff-4f46-b201-f496e7822c2e">
        <source>getDefaultMeasurementName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2024	navrv30	Ticket 63877: PNL - Cannot Create MDF cargo for some Cargo Subtypes

*/

vars

begin
	if self.name = ETRow_MyHeight then
		return self.getMeasurementName(Type_Height);
	elseif self.name = ETRow_MyLength then
		return self.getMeasurementName(Type_Length);
	elseif self.name = ETRow_MyWidth then
		return self.getMeasurementName(Type_Width);
	elseif self.name = ETRow_MyVolume then
		return self.getMeasurementName(Type_Volume);
	elseif self.name = ETRow_MyWeight then
		return self.getMeasurementName(Type_Weight);
	elseif self.name = ETRow_MyDensity then
		return self.getMeasurementName(Type_Density);
	endif;
	return "";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
