    <JadeMethod name="getStevedoresDischarge" id="89600024-8217-4b78-93ef-965332f01d0b">
        <source>getStevedoresDischarge(): String;
//----------------------------------------------------------------
//	Created:	05 October 2005	by Jason Chapman  (cnwjc2)
// 02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
//----------------------------------------------------------------

vars
	stevedore:				CM_Stevedore;
	stvdNameStr:			String;
begin

	if self.allStevedoresDischarge.isEmpty then
		return "";
	endif;
	
	foreach stevedore in self.allStevedoresDischarge do
		// PAR 11645 Lorcan Changed code to description
		if stvdNameStr &lt;&gt; null then
			stvdNameStr := stvdNameStr  &amp; stevedore.description[1:20] &amp; ";"; //02.10.2020 cnwma1 TFS #50112
		else
			stvdNameStr := stevedore.description[1:20] &amp; ";";
		endif;
	endforeach;	

	return stvdNameStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
