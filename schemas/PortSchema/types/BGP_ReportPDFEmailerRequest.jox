    </ExplicitInverseRef>
    <ExplicitInverseRef name="myJadeReport" id="d42e3264-d111-420f-8389-580a03bcf82d">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_JadeReport"/>
        <access>readonly</access>
