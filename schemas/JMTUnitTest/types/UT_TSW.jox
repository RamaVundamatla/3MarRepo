    <JadeMethod name="zTSWDTRGenerateBBBOL" id="938ad697-6894-4c0c-b283-c4380de1b51e">
        <source>zTSWDTRGenerateBBBOL(_cargoTypeBB		: String;
					_bolNumber			: String; 
					_voyage				: CM_Voyage; 
					_operator			: CM_Operator; 
					_terminal			: CM_Terminal; 
					_prefixCargoId		: String; 
					_startCtnNumber, 
					_amountToGenerate	: Integer;
					_terminalUTHelper	: UT_HelperAdmTerm;
					_tiSet				: CM_TISet output) : CM_BOLIn protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 December 2023	navpw1	Initial creation TFS: 61769 (61773)

*/

vars
	number,
	count	: Integer;
	bolIn	: CM_BOLIn;
	ti		: CM_TrackedItem;
	cargoTypeBB : CM_CargoBOLType;
	
begin
	cargoTypeBB := app.myRoot.getCargoTypeFromAbbrev(_cargoTypeBB);
	self.assertNotNullMsg(cargoTypeBB, "cargoTypeBB");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_OnShip, true);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	//Add these to the referenced unit test and pass them in as an array or individual values.
	self.opts.addAssoc(UT_OPTS_TotalQuantity, 50);
	self.opts.addAssoc(UT_OPTS_TotalVolume, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_TotalWeight, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_LoadPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_DischargePort, "NZPOE");
	
	bolIn := _terminalUTHelper.xCreateBOL(_bolNumber, _voyage, _operator, null, _terminal).CM_BOLIn;
	create _tiSet transient;
	number := _startCtnNumber;
	count := 1;
	while count &lt;= _amountToGenerate do
		// create cargo
		ti := self.addCargoAtLocationCommodity(_prefixCargoId &amp; number.padLeadingWith("0", 3), cargoTypeBB, _operator, _voyage.myShipBlockStack);
		_tiSet.add(ti);
		number += 1;
		count += 1;
	endwhile;
	
	return bolIn;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoTypeBB" type="String"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_prefixCargoId" type="String"/>
        <Parameter name="_startCtnNumber" type="Integer"/>
        <Parameter name="_amountToGenerate" type="Integer"/>
        <Parameter name="_terminalUTHelper" type="UT_HelperAdmTerm"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="output"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="zTSWDTRGenerateBOL" id="9c9cdfd3-e146-4411-810c-0b0ce95a0069">
        <source>zTSWDTRGenerateBOL(_bolNumber			: String; 
					_voyage				: CM_Voyage; 
					_operator			: CM_Operator; 
					_terminal			: CM_Terminal; 
					_prefixCtnId		: String; 
					_startCtnNumber, 
					_amountToGenerate	: Integer;
					_terminalUTHelper	: UT_HelperAdmTerm;
					_tiSet				: CM_TISet output) : CM_BOLIn protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	number,
	count	: Integer;
	bolIn	: CM_BOLIn;
	ti1		: CM_TrackedItem;
	
begin
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_Colour, "");
	self.opts.addAssoc(UT_OPTS_Mark, "");
	self.opts.addAssoc(UT_OPTS_NumItems, 1);
	self.opts.addAssoc(UT_OPTS_NumbItems, _amountToGenerate);
	self.opts.addAssoc(UT_OPTS_Volume, 0);
	self.opts.addAssoc(UT_OPTS_Weight, 0);
	self.opts.addAssoc(UT_OPTS_Length, 0);
	self.opts.addAssoc(UT_OPTS_Width, 0);
	self.opts.addAssoc(UT_OPTS_Height, 0);
	
	bolIn := _terminalUTHelper.xCreateBOL(_bolNumber, _voyage, _operator, null, _terminal).CM_BOLIn;
	create _tiSet transient;
	number := _startCtnNumber;
	count := 1;
	while count &lt;= _amountToGenerate do
		ti1 := self.addContainerOnShip(_prefixCtnId &amp; number.padLeadingWith("0", 3), _operator, "22G1", "GENL", null, _voyage, null, _voyage.code);
		_tiSet.add(ti1);
		number += 1;
		count += 1;
	endwhile;
	
	return bolIn;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_prefixCtnId" type="String"/>
        <Parameter name="_startCtnNumber" type="Integer"/>
        <Parameter name="_amountToGenerate" type="Integer"/>
        <Parameter name="_terminalUTHelper" type="UT_HelperAdmTerm"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="output"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="zTSWFile" id="aa9ab7c8-06bb-4b2b-b37b-caead72d7fec">
        <source>zTSWFile(_vesselCode, _voyageCode, _containerID, _roleCode, _nameCode, _bolNumber, _govtAgency : String; _includeStatementClearance : Boolean) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/04/2021	navdap1		Initial creation TFS 50809 CPL TSW responses not processing
//
vars
	roleCode,
	nameCode,
	bolNumber,
	govtAgency,
	additionalInformation : String;
	
begin
	roleCode := CM_EDIAction.RoleCode_GC;
	if _roleCode &lt;&gt; null then
		roleCode := _roleCode;
	endif;
	
	nameCode := "C06";
	if _nameCode &lt;&gt; null then
		nameCode := _nameCode;
	endif;
	
	bolNumber := "1236467";
	if _bolNumber &lt;&gt; null then
		bolNumber := _bolNumber;
	endif;
	
	govtAgency := "NZCS";	//Defaults to NZCS
	if _govtAgency &lt;&gt; null then
		govtAgency := _govtAgency;
	endif;
	
	if _includeStatementClearance then
		additionalInformation := "    " &amp; "&lt;AdditionalInformation&gt;" &amp; CrLf &amp; 
		"        " &amp; "&lt;StatementDescription&gt;MPI APPROVAL TO MOVE TO ATF Test Something Else&lt;/StatementDescription&gt;" &amp; CrLf &amp;
		"        " &amp; "&lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;" &amp; CrLf &amp; 
		"    " &amp; "&lt;/AdditionalInformation&gt;";
	endif;
	
	return 
"&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51358641J&lt;/ID&gt;
      &lt;RoleCode&gt;" &amp; roleCode &amp; "&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
    &lt;IssueDateTime formatCode='204' &gt;20180718145109&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;354&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;"
	&amp; CrLf &amp; additionalInformation &amp;
    "&lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;99156761&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode='204' &gt;20180718145109&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;PW_ICR008&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;EXT ONline Broker&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt; " &amp; _vesselCode &amp; "&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode='102'&gt;20180720&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZWLG&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;" &amp; _voyageCode &amp; "&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType='CLEARANCE'&gt;statusText&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;Consignee&gt;
            &lt;Name&gt;Maersk Line&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;Consignor&gt;
            &lt;Name&gt;Maersk&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;" &amp; bolNumber &amp; "&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;4&lt;/FullnessCode&gt;
            &lt;ID&gt;" &amp; _containerID &amp; "&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
            &lt;ID&gt;NZWLG&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;" &amp; govtAgency &amp; "&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode='204'&gt;20180718145109&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;" &amp; nameCode &amp; "&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode='204' &gt;20180718145109&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetadata&gt;";
epilog

end;</source>
