    <JadeMethod name="create" id="9e1ae204-14f3-46ef-800e-3e3f0869e338">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;

	create operator as CM_QStringLookupIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBanksInPlay" id="7a861cbb-be00-42eb-ac30-48424b20ce14">
        <source>getBanksInPlay( _params: CM_QueryCriteriaLineHolder; objSet : ObjectSet input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	termObjSet : ObjectSet;
	crit 	   : CM_SelectorCriteriaLine;
	obj 	   : Object;
	term	   : CM_Terminal;
	bank 	   : CM_Bank;

begin

	//try to establish the 'Bank(s)' in play directly from the criteria.
	foreach crit in _params.allCriteriaLines do
		if crit.myQueryProperty.propertyName = 'bank' or
			crit.myQueryProperty.propertyName = 'myBank' or
			crit.myQueryProperty.propertyName = 'getBank' then
			crit.myQueryOperator.getSearchValueAsObjectSet( objSet );
			return;
		endif;
	endforeach;
	
	
	//OK, then try to use the banks based on the terminals in play
	create termObjSet transient;
	self.getTerminalsInPlay( _params, termObjSet );
	
	if termObjSet.isEmpty then
		return;
	endif;
	
	//now use the terminals to find the banks
	foreach obj in termObjSet do
		term := obj.CM_Terminal;
		foreach bank in term.companies discreteLock where bank.isBusinessUnit do
			objSet.addNoDuplicates( bank, false );
		endforeach;
	endforeach;
	

epilog

	delete termObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getServicesInPlay" id="805520cd-4e53-4a04-bb14-c9a43e252125">
        <source>getServicesInPlay( _params: CM_QueryCriteriaLineHolder; serviceObjSet : ObjectSet input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	bankObjSet : ObjectSet;
	obj : Object;
	bank : CM_Bank;
	service : CM_Service;

begin

	//We get services in play based on the banks in play.
	create bankObjSet  transient;
	self.getBanksInPlay( _params, bankObjSet );
	
	if bankObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in bankObjSet do
		bank := obj.CM_Bank;
		foreach service in bank.services discreteLock do
			serviceObjSet.addNoDuplicates( service, false );
		endforeach;
	endforeach;

epilog

	delete bankObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="serviceObjSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTerminalsInPlay" id="d9ab5ca3-26e2-49c6-b3d7-83268f2b702a">
        <source>getTerminalsInPlay( _params: CM_QueryCriteriaLineHolder; objSet : ObjectSet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	crit : CM_SelectorCriteriaLine;

begin

	foreach crit in _params.allCriteriaLines do
		if crit.myQueryProperty.propertyName = 'myTerminal' or
			crit.myQueryProperty.propertyName = 'getTerminal' then
			crit.myQueryOperator.getSearchValueAsObjectSet( objSet );
			break;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
