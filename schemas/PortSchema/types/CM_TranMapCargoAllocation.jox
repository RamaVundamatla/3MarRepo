    <JadeMethod name="shouldAuditProperty" id="91a0fdd9-a029-4bfc-96c7-22d9e09359fc">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMapCargoAllocation::myChildQuantityMap.name or
		propName = CM_TranMapCargoAllocation::myInvoiceAllocationConfig.name or
		propName = CM_TranMapCargoAllocation::myBank.name 
		
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="35ff9550-c243-49af-b0bf-d0a2ac55eda8">
        <source>validateForCreate();
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
19 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
*/

vars

	c : CM_YACriteriaType;
begin

	if self.name = null then
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;

	if self.myBank &lt;&gt; null then
		// from TFS 1775 tests Apr 2016 check the correct collection 
		//if self.myBank.allSnapShotTranMaps[self.name] &lt;&gt; null then
		if self.myBank.allCargoAllocTranMaps[self.name] &lt;&gt; null then
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364
		endif;
	endif;
	

	if self.myInvoiceAllocationConfig &lt;&gt; null then
		if self.myInvoiceAllocationConfig.allOpCriteria.isEmpty() then
		
			app.raiseCMException(No_Criteria_values_selected,null,null);
		endif;
				
		//c := self.myInvoiceAllocationConfig.allOpCriteria[YACriteriaType_TransactionType]; //19/06/2017 cnwma1 TFS #4498
		c := self.myInvoiceAllocationConfig.getCriteriaByType(YACriteriaType_TransactionType); //19/06/2017 cnwma1 TFS #4498
			
		if c = null then
			app.raiseCMException(Pleas_selec_some_trans_type_cr,null,null);
		
		endif;
	endif;

end;	</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8736d266-3b5a-41f8-bd07-1da0326f7f2e">
        <source>validateForDelete();
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars

begin
	if self.myBank.myCurrentTranMapCargoAlloc = self then
		app.raiseCMException(ERR_TRANSMAP_ACTIVE, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="04edd75d-b9bf-4ac2-b3a8-f45f41448dc2">
        <source>validateForUpdate();
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	original,
	existingTM	: CM_TranMapCargoAllocation;
begin
	if self.name = null then
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;

	if self.myBank &lt;&gt; null then
		original := self.pxyGetRealObject();
//		existingTM := self.myBank.allCargoAllocTranMaps[self.name];
		if existingTM &lt;&gt; null and existingTM &lt;&gt; original then
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364

		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
