    <JadeMethod name="doUpdateCrane" id="62ed27a0-c2a5-4ab8-8817-a4277c34780f">
        <updating/>
        <source>doUpdateCrane():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474
20 February 2010	cnwas3 PAR 22429
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	ls : Boolean;
	controller : CMIF_OOWCraneUpdate;
	aTS : TimeStamp;
	aDate : Date;
	aTime : Time;
	theReturn : Integer;
	
begin

	/*if app.msgBox( app.getErrorString1(Save_crane_data, self.myCrane.id.String), app.getErrorString(SHP_Confirm), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return false;
	endif;*///Commented out in PAR 22429
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	aDate := txtExchDate.getDate();
	aTime := txtExchTime.getTime();
	
	if aDate.isValid and self.myVoyage &lt;&gt; null and self.myVoyage.shipExchangeDate.isValid then
		aTS.setDate(aDate);
		aTS.setTime(aTime);
		if aTS &lt; self.myVoyage.shipExchangeDate then
			app.msgBox( app.getErrorString(Crane_start_date_prior_berth), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
		endif;
	endif;
	
	create controller;
	app.cmsBeginLoad(ls);
	controller.myCrane := app.createUpdateProxy(self.myCrane).CM_Crane;
	controller.myJobSheet := app.createUpdateProxy(self.myVoyageJobSheet).CM_VoyageJobSheet;
	controller.myVoyageStructure := self.myVoyage.myCellularVoyageStructure;
	app.cmsEndLoad(ls);
	
	controller.craneCPH := txtCPH.getInteger;
	controller.craneSeed := txtStartJob.getInteger;
	controller.exchangeTS.setDate(aDate);
	controller.exchangeTS.setTime(aTime);
	controller.craneRversed := (cmbOrder.getEmbeddedControl.CMUI_FieldComboBoxControl.listIndex = 1);
	
	while true do
		app.myTrxUA.trxUpdateVoyageOOWCrane(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(OOW_Crane_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
	
epilog

	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	
	if controller &lt;&gt; null then
		delete controller.myCrane;
		delete controller.myJobSheet;
		delete controller;
	endif;

	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="frmExchDateAlign" id="12e0d97d-eb7a-4f33-9448-9d6ef0cadc0f">
        <updating/>
        <source>frmExchDateAlign(_fieldGeneric: CMUI_FieldGeneric input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

begin

	if txtStartJob.getEmbeddedControl &lt;&gt; null then
		txtExchDate.left := txtStartJob.getEmbeddedControl.left; // left align with other fields
		btnUseShipExch.left := txtStartJob.width - btnUseShipExch.width; // right align
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
