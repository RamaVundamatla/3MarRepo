    <JadeMethod name="getPlaceHolderObject" id="191fe271-3624-4afe-8698-2b5519749c81">
        <source>getPlaceHolderObject(_placeHolderType: Integer): CM_Object;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	placeHolder : CM_Object;
begin
	if _placeHolderType = PlaceHolderType_Peer then
		create placeHolder as CM_CodeGroupLogSpecs transient;
	elseif _placeHolderType = PlaceHolderType_Child then
		if myObject.CM_CodeGroup.groupType = CodeGroup_SourceLocation then 
			create placeHolder as CM_SourceLocation transient;
		endif;
	endif;
	return placeHolder;
end;</source>
        <Parameter name="_placeHolderType" type="Integer"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadTreeViewArray" id="c0595416-66a3-406b-bbfc-3c272ee65be7">
        <source>loadTreeViewArray(_collection: Collection input; _level: Integer; _form: CMUI_CodesMaintTree; _parent: SOP_ViewModelObject);
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	speciesHolder 	: SOPVM_SpeciesHolder;
	typeHolder 		: SOPVM_LogTypeHolder;
	treatHolder 	: SOPVM_LogTreatmentHolder;
	lengthHolder 	: SOPVM_LogLengthHolder;
begin
	inheritMethod(_collection, _level, _form, _parent);
	
	create speciesHolder transient;
	speciesHolder.initializeMe(self.myObject, _level + 1, self);
	speciesHolder.myForm := _form;
	speciesHolder.loadTreeViewArray(_collection, _level + 1, _form, self);
	
	create typeHolder transient;
	typeHolder.initializeMe(self.myObject, _level + 1, self);
	typeHolder.myForm := _form;
	typeHolder.loadTreeViewArray(_collection, _level + 1, _form, self);
	
	create treatHolder transient;
	treatHolder.initializeMe(self.myObject, _level + 1, self);
	treatHolder.myForm := _form;
	treatHolder.loadTreeViewArray(_collection, _level + 1, _form, self);

	create lengthHolder transient;
	lengthHolder.initializeMe(self.myObject, _level + 1, self);
	lengthHolder.myForm := _form;
	lengthHolder.loadTreeViewArray(_collection, _level + 1, _form, self);


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
