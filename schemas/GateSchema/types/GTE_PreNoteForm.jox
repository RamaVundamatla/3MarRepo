    <JadeMethod name="setPreNote" id="2207ca9e-9a20-4be9-a0b6-ceb33474ee8e">
        <updating/>
        <source>setPreNote() updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	assistant		: GTE_Assistant;
	intFaceObj		: CMIF_TIObject;
	tmpAttach		: CMIF_InOutAttachment;
	tmpCombo		: ComboBox;
	intFaceCOU		: CMIF_InOutCOU;
	theRow			: Integer;
	sysSubType		: CM_ProductAttributeCode;		// 18/11/2009 cnwmh5 PAR21492
begin

	assistant := self.myAssistant.GTE_Assistant;
	
	if self.myIntFacePreNote = null then
		create self.myIntFacePreNote transient;	
	endif;

	intFaceObj := self.myIntFacePreNote;	
	
	assistant.receival_SaveData(intFaceObj,
								self.tblMain,
								 self.tblExtra,
								 self.lstHazardList,
								 self.lstDischarge,
								 self.lstStops,
								 self.lstToDo,
								 null,
								 self,
								 self.myTerminal,
								 null);

//	assistant.receival_SaveCOU(intFaceObj, self.myIntFaceCOU,
	assistant.receival_SaveCOU(intFaceObj, intFaceCOU,
								 tblExtra, null, self);
	
	if self.tblMain.isRowVisible(ETRow_ReceiptTransportMode) then
		intFaceObj.CMIF_PreNote.receiptTransportMode := app.transModeToCode(cmbExtraTransMod.text);
		//app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1. " &amp; cmbExtraTransMod.text);
		intFaceObj.CMIF_PreNote.transportMode := cmbExtraTransMod.text;
	else
	//Allows for Create New Cargo Form to use the Ship view for transportMode.
		intFaceObj.CMIF_PreNote.receiptTransportMode := self.lastTransportMode;
		intFaceObj.CMIF_PreNote.transportMode := app.transModeToString(self.lastTransportMode);
		if intFaceObj.CMIF_PreNote.loadPort = self.myTerminal.getConfig(PortDestCode).String then
			intFaceObj.CMIF_PreNote.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		else
			intFaceObj.CMIF_PreNote.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
		endif;
	endif;
	
	intFaceObj.CMIF_PreNote.type := self.myAssistant.mainExtraGetValue(self.tblMain, self.tblExtra, ETRow_MyType).String; 	// 27/11/2009 cnwmh5 #21492
	
//	intFaceObj.CMIF_PreNote.receiptTransportMode := self.lastTransportMode;
//	intFaceObj.CMIF_PreNote.transportMode := app.transModeToString(self.lastTransportMode);
	intFaceObj.CMIF_PreNote.stowageLocation := intFaceObj.CMIF_PreNote.yardLocationTxt;
	
	//cnwmc5 - par 29728
	if self.myCurrentObject &lt;&gt; null then
		intFaceObj.CMIF_PreNote.setExpectedFromTI(self.myCurrentObject.CM_TrackedItem);
	endif;
	
	// ensure that masterItem is set correctly for all attachments
	if intFaceObj.hasAttachments then
		foreach tmpAttach in self.allAttachments do
			tmpAttach.setMasterItem(intFaceObj);
		endforeach;
	else
		self.allAttachments.purge;
	endif;
	
	self.tblExtra.setProxyFromMeasureTables(intFaceObj);	// PAR #31155
end;</source>
    </JadeMethod>
    <JadeMethod name="setSubTerminalForContainer" id="bf2bb178-e445-4507-9cf2-de9deec4e0f2">
        <source>setSubTerminalForContainer();
/*
----------   ----------  --------------------------------------------------
Created:	17 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04 jun 2009	concms1		par 19807 - avoid exception where sub-terminals are not being used
*/
vars
	cargoBOLType: CM_CargoBOLType;
	terminalObj	: CM_Terminal;
	status : CM_IMEXStatus;
	commodity : CM_Commodity;
	
begin
	terminalObj	:=	self.myTerminal;
	
	if not app.isSubTerminalsOn (terminalObj) then	//par 19807
		return;										// par 19807
	endif;											// par 19807
	
	if cmbSubTerminal.listIndex &lt;&gt; CNEC_NULL_INDEX then
		return;
	endif;
	
	if self.mode = self.Mode_Add then
		cargoBOLType := self.cmbTiType.listObject.CM_CargoBOLType;
		status := self.cmbImexStatus.listObject.CM_IMEXStatus;
		commodity := self.cmbCommodity.listObject.CM_Commodity;
		if cargoBOLType = null or status = null then	
			self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal.code;			
		else
			if cargoBOLType.isISOType() then
				if commodity = null then
					self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal.code;
				else
					if status.code = TI_IMEX_STATUS_IMPORT then
						if commodity.isEmpty then
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForImportMTY).CM_SubTerminal.code;
						else
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForImportFull).CM_SubTerminal.code;
						endif;
					elseif status.code = TI_IMEX_STATUS_EXPORT then
						if commodity.isEmpty then
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForExportMTY).CM_SubTerminal.code;
						else
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForExportFull).CM_SubTerminal.code;
						endif;
					elseif status.code = TI_IMEX_STATUS_STORAGE then
						if commodity.isEmpty then
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal.code;
						else
							self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForStorageFull).CM_SubTerminal.code;
						endif;
					else
						self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal.code;
					endif;
				endif;
			endif;
		endif;
		
		self.tblExtra.setValueByName(ETRow_MySubTerminal, self.cmbSubTerminal.text);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSubTerminalForNonContainer" id="b282e275-c9fb-4a0c-8b6c-f856b5125137">
        <source>setSubTerminalForNonContainer();
/*
----------   ----------  --------------------------------------------------
Created:	17 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	cargoBOLType: CM_CargoBOLType;
	terminalObj	: CM_Terminal;
	status : CM_IMEXStatus;
begin	
	terminalObj	:=	self.myTerminal;
	if not app.isSubTerminalsOn (terminalObj) then	//par 19807
		return;										// par 19807
	endif;			
	
	if cmbSubTerminal.listIndex &lt;&gt; CNEC_NULL_INDEX then
		return;
	endif;
	
	if self.mode = self.Mode_Add then
		cargoBOLType := self.cmbTiType.listObject.CM_CargoBOLType;
		status := self.cmbImexStatus.listObject.CM_IMEXStatus;
		if cargoBOLType = null or status = null then	
			self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal.code;			
		else
			if not cargoBOLType.isISOType() then
				if status.code = TI_IMEX_STATUS_IMPORT then
					self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForImportGen).CM_SubTerminal.code;					
				elseif status.code = TI_IMEX_STATUS_EXPORT then
					self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForExportGen).CM_SubTerminal.code;
				elseif status.code = TI_IMEX_STATUS_STORAGE then
					self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForStorageGen).CM_SubTerminal.code;				
				else
					self.cmbSubTerminal.text := terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal.code;
				endif;
			endif;
		endif;
		
		self.tblExtra.setValueByName(ETRow_MySubTerminal, self.cmbSubTerminal.text);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTiTypeFields" id="b17c1238-23f2-4563-947d-0bb06b35e158">
        <updating/>
        <source>setTiTypeFields() updating, protected;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 20/12/2010	cnwdap1		PAR #26644 Hide to Do Tasks row for Gdansk
// 11/08/2010	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars

begin
	
	inheritMethod();
	
	tblExtra.hideRowByName(ETRow_EmailOptions, false);
	self.tblExtra.hideRowByName(ETRow_CustomsAgentCode, false); // PAR 11607

	//if self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_SHIP) then // cnwrd1 par 18519 6.3.09	// PAR #27972
	if self.viewTransportMode &lt;&gt; BR_TYPE_SHIP_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
		tblMain.hideRowByName(ETRow_YardLocationTxt, false);
		tblExtra.hideRowByName(ETRow_LoadPort, false);
		tblMain.showRowByName(ETRow_ReceiptTransportMode, false);
		tblMain.showRowByName(ETRow_StatusString, false);
		tblExtra.showRowByName(ETRow_Carrier, false);
		//if self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_ROAD) // cnwrd1 par 18519 6.3.09		// PAR #27972
		if self.viewTransportMode = BR_TYPE_ROAD_STR // cnwrd1 par 18519 6.3.09								// PAR #27972
		and self.mode = Mode_Add then
			tblExtra.showRowByName(ETRow_EmailOptions, false);
			tblExtra.disableRowByName(ETRow_EmailOptions);
		endif;
	else
		tblMain.showRowByName(ETRow_YardLocationTxt, false);
		tblExtra.showRowByName(ETRow_LoadPort, false);	
		tblMain.hideRowByName(ETRow_ReceiptTransportMode, false);
		tblMain.hideRowByName(ETRow_StatusString, false);
		tblExtra.hideRowByName(ETRow_Carrier, false);
	endif;
	// 29 Oct 2008	cnwdz2		Par 18224 - only show the Booking Reference Item in the thumbnail when multiple refs allowed
	if not self.myTerminal.getConfig(AllowMultiBookingRef).Boolean then
			self.tblMain.hideRowByName(ETRow_MyBookingRefItem,false);
	endif;
	
		//19/06/2009 cnwdz2  par20027
	if not app.isSubTerminalsOn (self.myTerminal) then	
		self.tblExtra.hideRowByName(ETRow_MySubTerminal,false);
	endif;
	
	// PAR #26644 Hide To Do Tasks row if permissions say to, as the inheritMethod above has just reshown it
	if not app.getMyUser.canDo(null,PmAdmToDoTaskShowPreNote) then
		self.tblExtra.hideRowByName(ETRow_ToDoTasks, false);
	endif;
	// PAR #26644 end

end;</source>
        <access>protected</access>
    </JadeMethod>
