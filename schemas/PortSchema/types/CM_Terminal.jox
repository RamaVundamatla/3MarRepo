    <JadeMethod name="getNextBatNumber" id="13174e13-2000-45c5-bda4-9aeba0196cb0">
        <updating/>
        <source>getNextBatNumber() : CM_BatNumber updating; // serverExecution;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     The next available bat number that is not in use.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	bat		: CM_BatNumber;
	ls,
	found	: Boolean;
		
begin

	app.cmsBeginLoad(ls);

	iter := self.batNumbers.createIterator;

	while iter.next(bat) do
		sharedLock(bat);
		if (not bat.testInUse(self)) then
			found := true;
			break;
		endif;
	endwhile;
	
	if (not found) then
		bat := null;
	endif;

	return bat;

epilog
	app.cmsEndLoad(ls);
	delete iter;
		
end;</source>
        <ReturnType type="CM_BatNumber"/>
    </JadeMethod>
    <JadeMethod name="getNextCheckScalingBatNo" id="9db5da99-decd-4d9a-9ccb-078997682694">
        <source>getNextCheckScalingBatNo() : Integer;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	lastCheckScaleHdr		: CM_LogCheckScaleHdr;
	nextBatchNo				: Integer;
begin
	lastCheckScaleHdr := self.allLogChkScaleByBatchNo.last;
	
	if lastCheckScaleHdr = null then
		nextBatchNo := 1;
	else
		nextBatchNo := lastCheckScaleHdr.batchNo + 1;
	endif;
	
	return nextBatchNo;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextGateTransactionNumber" id="d6f41cbc-7b60-4d30-abe2-a88f0ad7f4e5">
        <source>getNextGateTransactionNumber() : String;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Purpose:      // PAR 17703 AKB2008AUG
//
// Parameters:  None
//
// Returns:     Nothing
/*

Date		Who		Reason
12 Jan 2018	jlgkpd1	TFS 36633 - Performance changes - only lock vehicle Visit collection once
	
*/
constants
	KeySeries = SN_RoadJobTransactionNumber;
	KeyDesc = "Gate Transaction Number";
	
vars
	leadingZeroes,root,prefix : String;	
	lastVisit : CM_VehicleVisitRecord;
	lastUsedSeriesKeyDate : Date;
	startNumber, maxNumber,leadingLength,resetIdx : Integer;
	resetByYear, resetByDate, resetByMax : Boolean;
begin

	if self.roadProcessIsASPA then
		return self.generateNextServiceOrderNumber( true, false, TI_TRANSMODE_ROAD );
	endif;
	
	
	resetByDate := false; 
	resetByYear := false; 
	resetByMax := false;
	
	resetIdx := self.getConfig(VehicleVisitNumRollover).Integer;
	if resetIdx &gt; 0 then
		if resetIdx = 1 then
			resetByDate := true;
		else
			if resetIdx = 2 then
				resetByYear := true;
			else
				resetByMax := true;
			endif;
		endif;
	endif;
			
	startNumber := self.getConfig(VehicleVisitNumStartSeq).Integer;
	prefix := self.getConfig(VehicleVisitNumPrefix).String;
	maxNumber := self.getConfig(VehicleVisitNumMax).Integer;
	leadingLength :=self.getConfig(VehicleVisitNumLength).Integer;
	
	lastVisit := self.allVehicleVisits.last();
	if lastVisit &lt;&gt; null then
		lastUsedSeriesKeyDate := lastVisit.createdTime.date();		
	endif;	
		
	//self.getNextGateTrNoAdrian(resetByDate,resetByYear,startNumber,prefix,maxNumber);	//will become obsolete
	
	root := self.getNextSeriesNumber(lastUsedSeriesKeyDate,KeySeries,KeyDesc,resetByDate,resetByYear,resetByMax,startNumber,prefix,maxNumber);

	//return prefix &amp; leadingZeroes.padLeadingZeros(maxNumber.String.length()-root.length()) &amp; root; 		
	return prefix &amp; leadingZeroes.padLeadingZeros(leadingLength-root.length()) &amp; root; 		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSeriesNumber" id="60cf04cd-7e01-40b7-885d-1e4af58c60fd">
        <source>getNextSeriesNumber(_lastUsedSeriesKeyDate : Date input; _keySeriesCode : String; _keyDesc : String; _resetByDate : Boolean; _resetByYear : Boolean; _resetByMax : Boolean; _startNumber : Integer; _prefix : String; _maxNumber : Integer) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwas3	Initial creation
to be filled to provide generic next gen. number
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	root 			: Integer;	
	tmp, tmp2 : String;
						
	leadingZeroes : String;						
begin
	//self.getNextGateTrNoAdrian(resetByDay,resetByYear,resetByMaxNumber,startNumber,rootLength,prefix,maxNumber);	//will become obsolete
	
	theKeySeries := self.allKeySeriesByCode[_keySeriesCode];	
	
	if theKeySeries = null then
		create theKeySeries persistent;		
		theKeySeries.set(_keySeriesCode, _keyDesc, self);		
		create seriesKey persistent;		
		
		
		seriesKey.set(_prefix, _startNumber);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		
		// RESET		
		if (seriesKey.root &gt; _maxNumber and _keySeriesCode &lt;&gt; SN_RoadJobTransactionNumber) or
		   (seriesKey.root &gt; _maxNumber and _keySeriesCode = SN_RoadJobTransactionNumber and _resetByMax) or
		   (_resetByDate and (_lastUsedSeriesKeyDate&lt;app.actualTimeServer().date())) or					// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		   (_resetByYear and (_lastUsedSeriesKeyDate.year()&lt;&gt;app.actualTimeServer().date().year()))or	// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		   (seriesKey.prefix&lt;&gt;_prefix)	then	
		   
			seriesKey.set(_prefix, _startNumber);
		endif;		
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, tmp, root, tmp2);
	theKeySeries.issue(app.computerName, process.signOnUserCode);
	
	return root.String; 
	

epilog
	unlock(theKeySeries);		
end;</source>
        <Parameter name="_lastUsedSeriesKeyDate" type="Date" usage="input"/>
        <Parameter name="_keySeriesCode" type="String"/>
        <Parameter name="_keyDesc" type="String"/>
        <Parameter name="_resetByDate" type="Boolean"/>
        <Parameter name="_resetByYear" type="Boolean"/>
        <Parameter name="_resetByMax" type="Boolean"/>
        <Parameter name="_startNumber" type="Integer"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_maxNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSuffix" id="d3839b4c-a6ff-4d58-9dae-bf9079506641">
        <source>getNextSuffix(_num : Integer) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwas3	Initial creation

*/

vars
	
	suffix,suffixOverflow : String;
	secondLetter,firstLetter : Integer;
	
begin	
	secondLetter := (_num/26).Integer;
	firstLetter := (_num mod 26).Integer;
	if firstLetter &gt; 0 then				
		suffix := (firstLetter + 64).Character;	
	else
		secondLetter:=secondLetter-1;			
		suffix := (26 + 64).Character;
	endif;
	if secondLetter = 0 then
			suffixOverflow := "";
		else
			suffixOverflow := (secondLetter+64).Character;
	endif;	
	suffix := suffix &amp; suffixOverflow;
	return suffix;
end;</source>
        <Parameter name="_num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextTrainCode" id="fa5958ef-dd94-47d7-ac47-5cf1979e3d69">
        <source>getNextTrainCode(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwrd1	Initial creation

*/
constants
	KeyDesc = 'System Train Number';
	KeySeriesCode = SN_TrainNo;
	StartNumber = 1;
	MaxNumber = 999999;
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix,
	root			: String;
	
	lastUsedSeriesKeyDate : Date;
begin
	
	prefix := self.getConfig(TrainAutoNumberPrefix).String;
	root := self.getNextSeriesNumber(lastUsedSeriesKeyDate,KeySeriesCode,KeyDesc,false,false,false,StartNumber,prefix,MaxNumber);
	/*
	if prefix = null then
		prefix := self.code;
	endif;
	*/
	/*theKeySeries := self.allKeySeriesByCode[SN_TrainNo];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_TrainNo, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);
*/
	//return prefix &amp; root.String; // &amp; suffix; not used at present.	//- 25/05/2009, cnwmd1, CCMS 1067, Par 19710
	return prefix &amp; root.padLeadingZeros(6); 	//+ 25/05/2009, cnwmd1, CCMS 1067, Par 19710 - prefix is set at a max of 4, making a total of 10.

epilog
	//unlock(theKeySeries);	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageCode" id="2fe6436c-1200-4be5-8008-caeb70b738f3">
        <source>getNextVoyageCode(_vessel : CM_Vessel; _voyageNumber : Integer output; _passport : CM_Passport input):String;
//--------------------------------------------------
// Created:	28 March 2006 By: cnwgd1
//--------------------------------------------------
// vesselCode 25 + 4 digit number = 29 characters, but voyage code only 20 characters long
// changed to use 4 digit prefix (terminal code or config setting) + key series sequence number
vars
	vesselCode,
 	sysVoyCode			: String;	
 	count,
 	uniqueCode			: Integer;
 	existingPermVoyage 	: CM_Voyage;
	tmpVesselTerminal	: CM_VesselTerminalData;
	localVessel : CM_Vessel;
	localTerminal : CM_Terminal;
begin

	_voyageNumber := 0;

	if _vessel = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_vessel', null, null);
		return null;
	endif;
	localVessel := _vessel;
	localTerminal := self;
	

	sysVoyCode := app.myHookAgent.runHookLinkPublic(HookType_VoyageCode, self, self, localTerminal, localVessel).String;
	if sysVoyCode &lt;&gt; null and sysVoyCode &lt;&gt; "** not initialised **" then
		return sysVoyCode;
	endif;
	
	// TEMPORARY WAY OF CREATING SYSTEM VOYAGE CODE AS PER ORIGINAL HMS SYSTEM 1998
	
	// This method automatically creates a unique system (only) voyage code
	// The basic structure of the code is: VesselCode XX000 &amp; a 4 digit number
	// eg. SysVoyCode = XX0009999
	// The code is updated if the vessel is changed.
	
	// Get ship code
	vesselCode := _vessel.code[1:5];
	tmpVesselTerminal := _vessel.getVesselTerminalData(self, false);
	if tmpVesselTerminal = null then
		count := 0;
	else
		count := tmpVesselTerminal.nextNumber;
	endif;
	
	// Get next lowest available four digit code with this vessel code combination
	//count := 0;
	
	
	uniqueCode := HMSUniqueCodeNotSet;		
    
    while count &lt;= 9999 do
   		uniqueCode := count;
   		count := HMS_UniqueVoyCode;

    	if count = HMS_UniqueVoyCode then
	   		sysVoyCode := vesselCode &amp; uniqueCode.String.padLeadingZeros(4);
	   		// Check active terminal
     		existingPermVoyage := self.lookupVoyage (sysVoyCode, null, true);

			// PAR-13223 - reinstate lookup for archived voyages
			if existingPermVoyage = null then
				// check archived terminal
	     		existingPermVoyage := self.allVoyagesArchived.getAtKeyGeq(sysVoyCode, null);
				if existingPermVoyage &lt;&gt; null and existingPermVoyage.code &lt;&gt; sysVoyCode then
					existingPermVoyage := null;
				endif;
    		endif;

    		if existingPermVoyage = null then
    			// check inward code
	     		existingPermVoyage := self.allVoyagesByInwardCode.getAtKey(sysVoyCode);    		
    		endif;
    		
    		if existingPermVoyage &lt;&gt; null then
   				// The proposed code is being used by another perm voyage
   				// ie. not the currently selected voyage. 
   				// Increase the count to select the next unique code
   				count := uniqueCode;
   				count := count+1;	
   				uniqueCode := HMSUniqueCodeNotSet;		
    		else
    			// Code is not used by any other existing perm voyage - use this code
    		endif;
    	endif;
    	
    endwhile;
    
  	// Test to see if a unique code has been found
   	if count = HMS_UniqueVoyCode then
   		// Return unique code
		_voyageNumber := uniqueCode;
   		return sysVoyCode;
   	else
   		// Code has not been found - raise error msg - all available codes have been used.
		//errorMsg := "All avaliable voyage codes have been used for this 'Ship'. Please contact the System Administrator.";
    	//msgTitle := "ERROR: All codes used!";
    	app.raiseCMException(Avali_voyag_codes_have_been_us, null, null);
    	return null;
    endif;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_voyageNumber" type="Integer" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageExternalCode" id="b4f1b9c6-0e30-4adb-afe4-2b72882d4f2b">
        <source>getNextVoyageExternalCode(_vessel : CM_Vessel) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/04/2017	cnwdap1		Initial creation TFS 4050 LNX Job ID Enhancements
//
vars
	localVessel : CM_Vessel;
	localTerminal : CM_Terminal;
	sysVoyCode : String;

begin

	if _vessel = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_vessel', null, null);
