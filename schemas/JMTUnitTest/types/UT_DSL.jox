    <JadeMethod name="disableAllMachineRules" id="3ff46ee5-e5fa-429d-b0bc-d80b185bffd4">
        <source>disableAllMachineRules(_disable: Boolean) ;
/*

Purpose:	Disable / Enable all machine rules for a terminal - Quick and nasty will disable all

Date		Who		Reason
24/08/2012	cnwmh5	Initial creation

*/

vars
	
	rtqTAMaster			: CM_RTQueueMultiRuleTAMaster;
	rtqTAType			: CM_RTQueueMultiRuleTAType;
	terminal			: CM_Terminal;
		
begin

	terminal := self.getTerminal();

	beginTransaction;
	foreach rtqTAMaster in terminal.allRTQueueMultiRuleTAMasters do	
		rtqTAMaster.setPropertyValue(CM_RTQueueMultiRuleTAMaster::isDisabled.name, _disable);
	endforeach;

	foreach rtqTAType in terminal.allRTQueueMultiRuleTATypes do
		rtqTAType.setPropertyValue(CM_RTQueueMultiRuleTAType::isDisabled.name, _disable);
	endforeach;
	commitTransaction;
	
epilog
end;</source>
        <Parameter name="_disable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="disableAllYA" id="b3d48e49-ec97-4ef0-a5f1-c3780ad2f8eb">
        <source>disableAllYA(_disable: Boolean);
// Date: 20 November 2008	
// Author: cnwdw1	
// Description: Disable all YA in the current terminal
vars
	ya: CM_YardAllocation;
begin

	// Quick and nasty disabling of all YA
	beginTransaction;
	foreach ya in self.getTerminal.allYardAllocations do
		ya.setPropertyValue(CM_YardAllocation::isDisabled.name, _disable);
	endforeach;
	commitTransaction;
epilog
end;</source>
        <Parameter name="_disable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="disableAllYAExt" id="7b79bf5b-6515-4d03-85b2-b47b1f7f158c">
        <source>disableAllYAExt(_terminal : CM_Terminal; _yardAllArray : CM_YardAllocationArray io; _yardAllocationExclusions : CM_YardAllocationArray);
/*

Purpose:			Deletes all yard allocations except for the excluded ones

Parameters:			_terminal					CM_Terminal				The terminal to use for getting the yard allocations
					_yardAllArray				CM_YardAllocationArray	All the yard allocations that were disabled
					_yardAllocationExclusions	CM_YardAllocationArray	All the yard allocations to exclude

Return Value:		NONE

Date				Who		Reason
21 November 2025	navpw1	Initial creation JIRA: MTN-36370

*/

vars
	terminal		: CM_Terminal;
	yaDict 			: CM_YardAllocationsByCodeDict;
	ya				: CM_YardAllocation;
	iter			: Iterator;
	hasExclusions	: Boolean;
	
begin
	terminal := _terminal;
	if terminal = null then
		terminal := self.getTerminal;
	endif;
	
	if _yardAllocationExclusions &lt;&gt; null then
		hasExclusions := true;
	endif;
	
	yaDict := terminal.allYardAllocatonsByCode;
	iter := yaDict.createIterator;
	
	beginTransaction;
	while iter.next(ya) do
		if hasExclusions and _yardAllocationExclusions.includes(ya) then
			continue;
		endif;
		
		if ya.isDisabled = false then
			if _yardAllArray &lt;&gt; null then
				_yardAllArray.add(ya);
			endif;
			ya.setPropertyValue(CM_YardAllocation::isDisabled.name, true);
			
		endif;
		
	endwhile;
	commitTransaction;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_yardAllArray" type="CM_YardAllocationArray" usage="io"/>
        <Parameter name="_yardAllocationExclusions" type="CM_YardAllocationArray"/>
    </JadeMethod>
    <JadeMethod name="disableYA" id="ecaef7e5-f32f-4dfc-9b47-4100f25e48fa">
        <source>disableYA(_ya: CM_YardAllocation input; _disable: Boolean);
//20 November 2008	cnwdw1	
//
vars
	proxyYA: CM_YardAllocation;
	proxyCriterias: CMIF_Array;
begin
	proxyYA := app.createUpdateProxy(_ya).CM_YardAllocation;

	proxyYA.setDisabled(_disable);
	create proxyCriterias transient;
	app.myTrxUA.trxUpdateYardAllocation(proxyYA, proxyCriterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
epilog
	delete proxyYA;
	delete proxyCriterias;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_disable" type="Boolean"/>
    </JadeMethod>
