<CollClass name="CM_XTABFieldArray" id="2a1120ef-631b-4905-b266-f8dd002554a4">
    <loadFactor>66</loadFactor>
    <memberType name="CM_XTABField"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getFieldFromHeading" id="fdf4c0ee-f761-4880-9e9e-6f286d449e78">
        <source>getFieldFromHeading( _heading : String ):CM_XTABField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	iter : Iterator;
	field : CM_XTABField;
begin
	iter := self.createIterator;
	while iter.next(field) do
		if field.heading = _heading then
			return field;
		endif;
	endwhile;
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="CM_XTABField"/>
    </JadeMethod>
</CollClass>
