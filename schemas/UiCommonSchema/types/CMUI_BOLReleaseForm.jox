    </JadeMethod>
    <JadeMethod name="tblReleases_contextMenu" id="488ad196-ab7b-4916-91f9-a5e6dc1f1b86">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReleases_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	release		: CM_BulkRelease;
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	release := table.accessRow(table.row).itemObject.CM_BulkRelease;
	if release &lt;&gt; null then
		self.mnuDeleteRelease.userObject := release;
		self.mnuDeleteRelease.visible := true;
	endif;
		
	self.mnuAddRelease.userObject := null;
	self.mnuCargoEnquiry.userObject := table;			
	self.mnuColumnOrganiser.userObject := table;	
	self.mnuInspect.userObject := table;
	self.mnuInspect.visible := app.isAllowedToInspect();					
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.mnuAddRelease.visible := false;
		self.mnuAddReleaseFor.visible := false;
		self.mnuDeleteRelease.visible := false;

	endif;


	
	self.popupMenu(self.mnuCargoContext, xLeft.Integer, yTop.Integer);

	return false;

end;</source>
