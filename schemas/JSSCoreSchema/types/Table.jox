    <JadeMethod name="jssFindAndUpdateRow" id="99a9dadc-7f91-421d-a4a1-edd33171b702">
        <updating/>
        <source>jssFindAndUpdateRow(pTheObject:Object; pCellValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Searches for pTheObject and updates the row using the pCellValue parameter.
//
// Parameters:	pTheObject (Object) - The object to find.
//				pCellValue (String) - The value to update the cell with.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	currentRow	: Integer;
	isSelected	: Boolean;

begin
	currentRow	:=	self.row;
	isSelected	:=	self.jssIsRowSelected(currentRow);

	if self.jssFindObject(pTheObject, 2, 1) then
		rowIndex	:=	row;
		deleteRow(rowIndex);
		addItemAt(pCellValue, rowIndex);
		self.jssSetItemObject(rowIndex, 1, pTheObject);
	endif;

	row := currentRow;

	if isSelected then
		self.row	:=	currentRow;
		self.jssSelectRow;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

