    <JadeMethod name="validateMe" id="75edb7d6-5231-4376-a886-651d061b7db1">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	realForCheck : CM_InvTypeDebtorMinCharge;
	existing : CM_InvTypeDebtorMinCharge;

begin

	if self.minimumChargeAmount &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Minimum_charge), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT, null, null); 
	endif;
	
	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getMinimumChargeInvLineType = null then
		app.raiseCMException(Minim_charg_line_type_must_sel, null,null);
		return;
	endif;
	
	if self.myDebtor = null then
		app.raiseCMException(Input_required_field_debtor, null,null);
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargesAndExemptions.allInvTypeDebtorMinCharges.getAtKey( self.myDebtor );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException(Minim_charg_alrea_exist_this_d, null,null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
