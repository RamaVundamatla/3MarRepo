    <JadeMethod name="sort" id="b21c5d4d-cbd8-4d04-8cae-d31e43f862e9">
        <updating/>
        <source>sort(	_voyageJob						: CM_VoyageJob;
		_isSeqForJob					: Boolean;
		_sortType						: String;
		_seqNum							: Integer io;
		_isTwinLiftSort,
		_isSortBoth,
		_isSameSequenceReq,
		_isAllocateCraneLane			: Boolean;
		_customSeqObjs					: CMIF_CustomSeqObjectDictByReq) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
//	tmpSeqObj,
//	last,
//	tmpSeqObj2		: CMIF_CustomSequenceObject;
//	custSeqDict		: CMIF_CustomSeqObjectDict;
//	custSeqNumDict	: CMIF_CustomSeqObjBySeqNumDict;
//	iter			: Iterator;
	seqTwin,
	seqSingle		: Integer;
//	tmpSeqNum		: Integer;
//	sortClass,
//	sortClassOther	: Class;

begin
	seqTwin 	:= _seqNum;
	seqSingle	:= _seqNum;
	self.allocateCraneLane	:=	_isAllocateCraneLane;
	self.sameSequenceReq	:=	_isSameSequenceReq;
	self.isSeqForJob		:=	_isSeqForJob;
	
	// Depending on the mode passed in we will set either the twin lift seqence
	// the single lift sequence or both.
	
	self.useSeperateLength := app.getMyTerminalDO_NOT_USE().getConfig(SeperateLengthSequencing).Boolean;
	
	if not _isTwinLiftSort or _isSortBoth then
	/*	self.getSortClasses(_sortType, sortClass, sortClassOther);
		if sortClass = null or sortClassOther = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Sort class is null for sort type (' &amp; _sortType &amp; ')');
			return;
		endif;
	
		create custSeqDict as sortClass transient;
		
		_customSeqObjs.copy(custSeqDict);*/
/*		seqSingle := (seqSingle - 1).max(0);
		foreach tmpSeqObj in custSeqDict do
			
			if last &lt;&gt; null and tmpSeqObj.mySlotController.myBayVoyage.ordinalBay &lt;&gt; last.mySlotController.myBayVoyage.ordinalBay then
				seqSingle := _seqNum;
			else 
				seqSingle := seqSingle + 1;
			endif;
			tmpSeqObj.seqNum := seqSingle;
			last := tmpSeqObj;
		endforeach;*/
		
/*		foreach tmpSeqObj in custSeqDict do
			tmpSeqObj.seqNum := seqSingle;
			seqSingle := seqSingle + 1;
		endforeach;
		
		delete custSeqDict;
	
		// now do the other side
		create custSeqDict as sortClassOther transient;
		create custSeqNumDict transient;
		
		_customSeqObjs.copy(custSeqDict);
		_customSeqObjs.copy(custSeqNumDict);
		iter := custSeqNumDict.createIterator;		
		foreach tmpSeqObj in custSeqDict do
			if (not iter.next(tmpSeqObj2)) then
				app.raiseUnexpectedProgramError(class.name, method.name, 'dict size mismatch (' &amp;
							custSeqDict.size.String &amp; ', ' &amp; custSeqNumDict.size.String &amp; ')');
			endif;
			custSeqNumDict.getIteratorKeys(tmpSeqNum, iter);
			tmpSeqObj.seqNumOther := tmpSeqNum;
		endforeach;*/
		self.sortForSingleLift(seqSingle, _sortType, _customSeqObjs);
	endif;
	
	if _isTwinLiftSort or _isSortBoth then
		self.sortForTwinLift(_voyageJob, seqTwin, _sortType, _customSeqObjs);
	endif;
	
	if _isTwinLiftSort then
		_seqNum := seqTwin;
	else
		_seqNum := seqSingle;
	endif;
epilog
//	delete custSeqDict;
//	delete custSeqNumDict;
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_isSeqForJob" type="Boolean"/>
        <Parameter name="_sortType" type="String"/>
        <Parameter name="_seqNum" type="Integer" usage="io"/>
        <Parameter name="_isTwinLiftSort" type="Boolean"/>
        <Parameter name="_isSortBoth" type="Boolean"/>
        <Parameter name="_isSameSequenceReq" type="Boolean"/>
        <Parameter name="_isAllocateCraneLane" type="Boolean"/>
        <Parameter name="_customSeqObjs" type="CMIF_CustomSeqObjectDictByReq"/>
    </JadeMethod>
    <JadeMethod name="sortForSingleLift" id="2655b143-c207-4bc7-86dd-09a0ee2555f3">
        <source>sortForSingleLift(_seqNumStart : Integer io; _sortType	: String; _customSeqObjs : CMIF_CustomSeqObjectDictByReq) protected;

vars

	dynaIn			: DynaDictionary;
	obj				: Object;
	last,
	sorterObj		: CMIF_CustomSequenceObject;
	reversedType	: String;
	seqNumber		: Integer;
	isTwinLift,
	isSameSeqReq	: Boolean;

begin

	// Create transient dynamic dictionaries for sorts.
	create dynaIn transient;
	
	// Set membership.
	dynaIn.setMembership(CMIF_CustomSequenceObject);
	
	
	// Setup the keys for the dictionaries.
	self.setSingleSortDict(_sortType, dynaIn);

	dynaIn.endKeys(false);
	
	// Chuck some cmif object into them for appropriate sorting.
	_customSeqObjs.copy(dynaIn);
	
	// Set the initial sequence number.
	seqNumber := (_seqNumStart - 1).max(0);
	
	// Run through sorted objects and apply sequence numbers.
	// Should only need to set the twin lift property once.
	
	foreach obj in dynaIn do
		sorterObj := obj.CMIF_CustomSequenceObject;
		seqNumber := seqNumber + 1;
		sorterObj.seqNum := seqNumber;
	endforeach;
	

/*	foreach obj in dynaIn do
		write obj.getName();
	endforeach;
	
	
	
	foreach obj in dynaReversed do
	
	endforeach;*/
	_seqNumStart := seqNumber;
	
epilog

	delete dynaIn;

end;</source>
        <access>protected</access>
        <Parameter name="_seqNumStart" type="Integer" usage="io"/>
        <Parameter name="_sortType" type="String"/>
        <Parameter name="_customSeqObjs" type="CMIF_CustomSeqObjectDictByReq"/>
    </JadeMethod>
    <JadeMethod name="sortForTwinLift" id="56bd154b-162a-449e-8983-eb209019cd29">
        <source>sortForTwinLift(_voyageJob:CM_VoyageJob; _seqNumStart:Integer io; _sortType:String; _customSeqObjs:CMIF_CustomSeqObjectDictByReq) protected;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars
	dynaIn						: DynaDictionary;
	dynaReversed				: DynaDictionary;
	reversedType				: String;
	seqNumber					: Integer;
	allLiftsInObj				: ObjectArray;
	allLiftsReversedObj			: ObjectArray;
	sequenceObj					: Object;
	allSlotsByBayDeckTierCell	: CM_SlotReqByBayDeckTierCell;
	
begin
	// Create transient dynamic dictionaries for sorts.
	create dynaIn transient;
	create dynaReversed transient;
	
//	terminalObj			:=	app.getMyTerminal();
//	isSameSeqReq		:=	terminalObj.getConfig(SameSeqNumberTwinLift).Boolean;
//	isAllocateCraneLane	:=	terminalObj.getConfig(AllocateCraneLane).Boolean;
	
	// Set membership.
	dynaIn.setMembership(CMIF_CustomSequenceObject);
	dynaReversed.setMembership(CMIF_CustomSequenceObject);
	
	// Get reversed sort type.
	reversedType	:=	self.getTwinSortTypeReversed(_sortType);
	
	// Setup the keys for the dictionaries.
	self.setTwinSortDict(_sortType, dynaIn);
	self.setTwinSortDict(reversedType, dynaReversed);
	dynaIn.endKeys(false);
	dynaReversed.endKeys(false);
	
	// Chuck some cmif objects into them for appropriate sorting.
	_customSeqObjs.copy(dynaIn);
	_customSeqObjs.copy(dynaReversed);
	
	// If loading a twin-lift, we need to group the single lifts at the start or end of the job.
	
	create allLiftsInObj transient;
	create allLiftsReversedObj transient;
	dynaIn.copy(allLiftsInObj);
	dynaReversed.copy(allLiftsReversedObj);
	
	if app.getMyTerminalDO_NOT_USE().getConfig(SeqGroupSingleLifts).Boolean
	and self.isSeqForJob
	and _voyageJob.isTwinLift
	and _voyageJob.jobType = JOB_TYPE_LOAD
	then
		create allSlotsByBayDeckTierCell transient;
		
		// First, we'll do the first side lifts.
		
		foreach sequenceObj in allLiftsInObj do
			allSlotsByBayDeckTierCell.add(sequenceObj.CMIF_CustomSequenceObject.myRequest);
		endforeach;
		
		_voyageJob.groupSinglesForTwinJob(allLiftsInObj, allSlotsByBayDeckTierCell);
		
		// Now, we'll do the other side lifts.
		
		allSlotsByBayDeckTierCell.clear();
		
		foreach sequenceObj in allLiftsReversedObj do
			allSlotsByBayDeckTierCell.add(sequenceObj.CMIF_CustomSequenceObject.myRequest);
		endforeach;
		
		_voyageJob.groupSinglesForTwinJob(allLiftsReversedObj, allSlotsByBayDeckTierCell);
	endif;
	
	// Set the initial sequence number.
	seqNumber	:=	(_seqNumStart - 1).max(0);
	
	// Run through sorted objects and apply sequence numbers.
	// Should only need to set the twin lift property once.
	
	_seqNumStart	:=	self.resequenceForTwinLift(_voyageJob, seqNumber, allLiftsInObj, allLiftsReversedObj);
epilog
	delete dynaIn;
	delete dynaReversed;
	delete allLiftsInObj;
	delete allLiftsReversedObj;
	delete allSlotsByBayDeckTierCell;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_seqNumStart" type="Integer" usage="io"/>
        <Parameter name="_sortType" type="String"/>
        <Parameter name="_customSeqObjs" type="CMIF_CustomSeqObjectDictByReq"/>
    </JadeMethod>
</Class>
