    <JadeMethod name="resizeControls" id="913b38e8-4a30-4452-873d-0677afbb6a6a">
        <source>resizeControls();
/*

Date		Who		Reason
04 December 2013	cnwer1	Initial creation PAR

*/
constants
	Margin = 5;
	HMargin = 10;
vars
	theHeight,theWidth : Integer;
	yesCaption : String;
begin
	yesCaption:=app.getErrorString(Yes);
	theHeight:=self.btnYes.getTextHeight(yesCaption);
	theHeight:= theHeight + (Margin *2);
	self.btnNo.height:=theHeight;
	self.btnYes.height:=theHeight;
	
	theWidth:= self.btnYes.getTextExtent("YESSS").max(theWidth);
	theWidth:=theWidth + (self.btnYes.getTextExtent("W") *2);
	self.btnNo.width:=theWidth;
	self.btnYes.width:=theWidth;
	
	self.grpBtns.width:=(theWidth*2) + HMargin;
	self.btnYes.left:=0;
	self.btnNo.left:=theWidth + HMargin;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFaultQuestion" id="eb74e504-5302-4913-a159-875a515d3527">
        <source>setFaultQuestion() : Boolean protected;
/*

Date		Who		Reason
04 December 2013	cnwer1	Initial creation PAR

*/

vars
	faultQuestion : CM_FaultQuestion;
begin
	
	//epr 24/5/17  TFS 995 mobile vmt generic changes
	if self.faultQuestionIndex &gt;app.myVMAgent.myMachine.allCurrentFaultQuestions.size then
		return false;
	endif;
	faultQuestion:=app.myVMAgent.myMachine.allCurrentFaultQuestions[self.faultQuestionIndex];
	self.blFaultQuestion.caption:=faultQuestion.description;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0b2780eb-a5d8-409f-b719-478986930be8">
        <updating/>
        <source>setupForm() updating, protected;
/*

Date		Who		Reason
04 December 2013	cnwer1	Initial creation PAR

*/

vars
	invalidQ : Boolean;
begin
	inheritMethod();
	if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;
	
	//epr TFS 2696 21/9/16
	on Exception do app.handleDeletedObject(exception,app.myVMAgent.myRTQueue, invalidQ);
	
	self.caption:=app.myVMAgent.myMachine.machineTypeString &amp; " " &amp; app.myVMAgent.myMachine.id.asStringJMT &amp; " " &amp; app.myVMAgent.myRTQueue.id;
	if invalidQ then
		app.myVMAgent.updateRTQueueFromMachine();
		self.caption:=app.myVMAgent.myMachine.machineTypeString &amp; " " &amp; app.myVMAgent.myMachine.id.asStringJMT &amp; " " &amp; app.myVMAgent.myRTQueue.id;
	endif;
	self.setVehicleMountedScreenSize();
	self.faultQuestionIndex:=1;
	
	self.setFaultQuestion;
	
	self.doResize();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ecf77ffc-d283-461f-86a7-72446e79a0ac">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019500, locale);
	blFaultQuestion.translateCaption(Xlat_0019501, locale);
	btnNo.translateCaption(Xlat_0019502, locale);
	btnYes.translateCaption(Xlat_0019503, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="updateFaultResponse" id="61b0cdaf-7d84-4293-ad00-00509fcc7e74">
        <updating/>
        <source>updateFaultResponse(_yes : Boolean) updating;
/*

Date		Who		Reason
04 December 2013	cnwer1	Initial creation PAR 33147

*/

vars
	driverResponse : String;
begin	
	if _yes then
		driverResponse := AuditStringValue_Yes;
	else
		driverResponse:=AuditStringValue_No;
	endif;

	//epr 24/5/17  TFS 995 mobile vmt generic changes
	// Process SendFaultResponse message
	app.myTrxUA.trxMachineUpdateFaultResponse(app.myVMAgent.myMachine,		// _mediator : CM_RadioTelemetryMediator input;
											   self.faultQuestionIndex,		// _index : Integer;
											   driverResponse,	// _response : String;
											   app.myPassport);
	
	
	self.faultQuestionIndex:=self.faultQuestionIndex+1;
	if not self.setFaultQuestion() then	
		self.gotoForm(app.getMainVMTForm(),true);
	endif;
epilog

end;</source>
        <Parameter name="_yes" type="Boolean"/>
    </JadeMethod>
</GUIClass>
