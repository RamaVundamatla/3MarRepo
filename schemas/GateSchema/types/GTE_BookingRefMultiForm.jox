    <JadeMethod name="loadBRItemTable" id="b1483881-0546-4249-9e69-f16ee669e90f">
        <source>loadBRItemTable(_br : CM_BookingRef; _useTransients : Boolean);
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif_BRItem 	: CMIF_BookingRefItem;
	brItem 			: CM_BookingRefItem;
begin
	tblBRItems.clear;
	tblBRItems.rows := 0;
	tblBRItems.clearAllSelected;
	
	if _useTransients then
		foreach cmif_BRItem in self.myInterfaceBookingRef.allCMIF_BRItems do
			tblBRItems.addObjectAndDisplay(cmif_BRItem, cmif_BRItem.viewName);
		endforeach;
	else
		if _br &lt;&gt; null then
			foreach brItem in _br.allBookingRefItems do
				tblBRItems.addObjectAndDisplay(brItem, brItem.getViewName);
			endforeach;
		endif;
	endif;
//	tblExtra.cnEcResizeContents;
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_useTransients" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadBookRefItems" id="7e2b3925-7b21-4bc1-8a2f-86140c46a736">
        <source>loadBookRefItems(_br : CM_BookingRef; _useTransients : Boolean; _refresh : Boolean);
/*
	Created on 04 February 2008 by Debby Hutchison
*/

vars
	
begin
	if _refresh and _br &lt;&gt; null then
		self.myInterfaceBookingRef.load(_br);
	endif;
	
	self.loadBRItemTable(_br, _useTransients);
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_useTransients" type="Boolean"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTableFromBRItem" id="b10887f9-779b-49eb-a0d8-3dcdccfe8282">
        <updating/>
        <source>loadTableFromBRItem(_obj : Object)updating;
/*
	Created on 11 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
30/11/2009	cnwmh5		PAR21492 - Load sub type details
*/

vars
	assistant		: GTE_Assistant;
	defCommodity	: CM_Commodity;
	defTranshipToPort: CM_Port;
	defISOType		: CM_ISOType;
	defBOLType		: CM_BOLType;
	defCargoType	: CM_CargoType;
	blnMulti 		: Boolean;
	idx,
	tmpRow			: Integer;
	defProduct		: CM_Product;
	hazCode, defMarks		: String;
	hazObject	: CM_HazardClass;
	cmb         : ComboBox;	
	id,idz		: Integer;
	generatorType 	: CM_GeneratorType;
begin
	assistant := self.myAssistant.GTE_Assistant;
	if CMIF_BookingRefItem.hasInstance( _obj) then
		self.myCurrentBRItemInterface := _obj.CMIF_BookingRefItem;
	endif;
	self.allAttachments.purge;
	
	defCommodity 	:= app.getCargoFieldObject(_obj, ETRow_Commodity).CM_Commodity;
	defISOType		:= app.getCargoFieldObject(_obj, ETRow_IsoType).CM_ISOType;
	defBOLType		:= app.getCargoFieldObject(_obj, ETRow_BolType).CM_BOLType;
	defCargoType	:= app.getCargoFieldObject(_obj, ETRow_CargoType).CM_CargoType;
	defProduct		:= app.getCargoFieldObject(_obj, ETRow_Product).CM_Product;
	generatorType	:= app.getCargoFieldObject(_obj, ETRow_MyGeneratorType).CM_GeneratorType;
	//defTranshipToPort:= app.getCargoFieldObject(_obj, ETRow_MyTranshipToPort).CM_Port;

	//self.cmbTranship.setObject(defTranshipToPort);
	self.cmbCommodity.setObject(defCommodity);

	self.cmbISOType.setObject(defISOType);
	
	self.cmbGenSetType.setObject( generatorType );
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyGeneratorType, cmbGenSetType.text);

	// PAR 10231 ony display system cargo types
	if defCargoType &lt;&gt; null then
		id := defCargoType.id;
	endif;
	assistant.comboBoxCargoBolType(cmbTiType, id, true, false, true, true);
	
	if defBOLType &lt;&gt; null then
		id := defBOLType.id;
	endif;
	assistant.comboBoxCargoBolType(cmbBOLType, id, false, true, true, true);
	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_CargoType, cmbTiType.text);
	assistant.receival_ShowRows(defCargoType, defISOType, tblMain, tblExtra, self.myTerminal);
	self.cmbProduct.setObject(defProduct);	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyProduct, cmbProduct.text);

	if itemEditMode = Mode_Add then
		self.lstHazardList.loadHazardObjects;
		assistant.resetHazardListTable(lstHazardList);	// CCMS 1203 JC
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_AllTIHazards, null);
//		assistant.clearAttachmentLines(tblExtra);
		return;
	endif;

//	tblMain.setTableFromObject(pObj, GTE_ReceivalsForm::setDefaultsCallBack.name);
	tblExtra.setTableFromObject(_obj, GTE_ReceivalsForm::setDefaultsCallBack.name);

	self.setSysSubTypeDetails(_obj);				// 30/11/2009 cnwmh5 #21492
	
	self.setTiTypeFields();
	self.cmbProduct.setObject(defProduct);	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyProduct, cmbProduct.text);
	self.doResize;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadTableFromBookingRef" id="4574adcc-4b69-459b-891e-f639dfd8022b">
        <updating/>
        <source>loadTableFromBookingRef(_br : CM_BookingRef)updating;
/*
Created on 11 February 2008 by Debby Hutchison
	
30/10/2012	cnwcs5	par 30459 - load optional discharge ports list table 
*/

vars
	defConsignee	: CM_ConsigneeConsignor;
	assistant		: GTE_Assistant;
	defConsignor,
	defFreightFwdr	: CM_ConsigneeConsignor;
	defDestination,
	defDischarge,
	defTranship		: CM_Port;
	defISOType		: CM_ISOType;
	defOperator		: CM_Operator;
	defCargoType	: CM_CargoType;
	defVoyage		: CM_Voyage;
	idx				: Integer;
	tmpStatus		: CM_IMEXStatus;	
begin
	assistant := self.myAssistant.GTE_Assistant;

	self.allAttachments.purge;
	
	if _br = null then
		defCargoType := app.myPassport.getDefaultCargoType();
	else
		defConsignor	:= _br.getObjectForETRow(ETRow_ConsignorCode).CM_ConsigneeConsignor;
		defConsignee	:= _br.getObjectForETRow(ETRow_ConsigneeCode).CM_ConsigneeConsignor;
		defDestination	:= _br.getObjectForETRow(ETRow_DestinationPort).CM_Port;
		defDischarge	:= _br.getObjectForETRow(ETRow_DischargePort).CM_Port;
		defTranship		:= _br.getObjectForETRow(ETRow_MyTranshipToPort).CM_Port;
		defOperator		:= _br.getObjectForETRow(ETRow_OperatorCode).CM_Operator;
		defVoyage		:= _br.getObjectForETRow(ETRow_VoyageCode).CM_Voyage;
		defFreightFwdr 	:= _br.getObjectForETRow(ETRow_FreightForwarderCode).CM_ConsigneeConsignor;
		tmpStatus		:= _br.getObjectForETRow(ETRow_StatusString).CM_IMEXStatus;
	endif;

	self.cmbConsignor.setType(CONSIGNOR);
	self.cmbConsignor.setObject(defConsignor);

	self.cmbConsignee.setType(CONSIGNEE);
	self.cmbConsignee.setObject(defConsignee);

	self.cmbFreightFwdr.setType(FREIGHT_FORWARDER);
	self.cmbFreightFwdr.setObject(defFreightFwdr);

	self.cmbDestination.myAssistant 		:= self.myAssistant;
	self.cmbDestination.showAllDestinations := true;
	self.cmbDestination.setObject(defDestination);	

	self.cmbDischarge.myAssistant := self.myAssistant;
	self.cmbDischarge.setObjectAndVoyage(defDischarge, defVoyage);
	
	self.cmbTranship.myAssistant := self.myAssistant;
	
	if defTranship &lt;&gt; null then
		self.cmbTranship.setObject(defTranship);
	endif;

	self.cmbTranship.setObjectAndVoyageDischPort(defDischarge, defVoyage);
	self.cmbOperator.setObjectAndVoyage(defOperator, defVoyage);

	idx := self.tblMain.getRow(ETRow_StatusString);
	
	if idx &gt; 0 then
		if tmpStatus &lt;&gt; null then
			assistant.comboBoxIMEXStatus(self.cmbImexStatus, tmpStatus.code); 			
		endif;
	endif;
	
	assistant.comboBoxVoyageCurrent(cmbVoyage,
									defVoyage,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									false); //epr par 34857 CCMS 2374

	assistant.receival_ShowRows(defCargoType, defISOType, self.tblMain, self.tblExtra, self.myTerminal);

	if _br = null then
		// Adding so set controls not already set to null.
		assistant.setListTablePorts(self.lstDischarge, null);
		assistant.mainExtraSetValue(self.tblMain, self.tblExtra, ETRow_AllDischargePorts, null);
		return;
	else
		self.loadOptDischargePorts (defVoyage);	// par 30459 - make srue ports are loaded
	endif;

	self.tblMain.setTableFromObject(_br, GTE_ReceivalsForm::setDefaultsCallBack.name);
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
