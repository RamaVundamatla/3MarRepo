    <JadeMethod name="btnCancel_click" id="1cf99bb3-b4a8-4cac-9818-a1a6c6cdedc8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     04 April 2008 by cnwaer1
//
