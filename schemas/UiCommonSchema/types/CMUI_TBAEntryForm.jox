    <JadeMethod name="doBaseFormSave" id="c5702fa4-e40a-4960-9d81-d3cd932f49de">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tbaController : CMIF_TBAContainer;
	theReturn : Integer;
	msg : String;

begin
	inheritMethod();

	create tbaController transient;
	
	self.setControllerFromTable(tbaController);
	
	//06 Jun 2012	NDL	Par 29935
	if tbaController.myOperator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator_GC), app.getErrorString(Operator_GC),null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Operator_GC), app.getErrorString(Operator_GC),null); // cnwdb2	PAR 35364

	endif;
	
	
	while true do
		app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.unloadForm();
//			break;
		else
			theReturn := app.showErrorWarningDialog("Create TBA Container", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete tbaController;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildComboLocations" id="5f1fb450-0812-4c1c-8cbc-a8ab507c7362">
        <source>doBuildComboLocations();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCombo : ComboBox;
	aPort : CM_Port;
	theLCs : CM_LCSet;
	anLC : CM_LocationsController;
begin
	aCombo := self.cmbLocations;
	
	aCombo.clear();
	aCombo.sorted := true;
	create theLCs transient;
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.myVoyage.myCellularVoyageStructure.getLCsWithColourCoding(theLCs,LOAD_MOVETYPE);
	endif;
	
	foreach anLC in theLCs do
		aCombo.addItem(anLC.getFullId);
		aCombo.itemObject[aCombo.newIndex] := anLC;
	
	endforeach;
	
epilog
	delete theLCs;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboPort" id="18af07dc-2d12-42d2-9a2e-a14d9e6c3d1c">
        <source>doBuildComboPort();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCombo : ComboBox;
	aPort : CM_Port;
	portCmbOrderDescrFirst : Boolean;
begin
	aCombo := self.cmbDischPort;
	
	aCombo.clear();
	aCombo.sorted := true;
		
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	foreach aPort in self.myVoyage.allPorts do
		aCombo.addItem(aPort.getDisplayFormatted(portCmbOrderDescrFirst));
		aCombo.itemObject[aCombo.newIndex] := aPort;
	
	endforeach;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboReceive" id="b4e2fff2-0636-40bd-bac2-28248f447df2">
        <source>doBuildComboReceive();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCombo : ComboBox;
begin
	aCombo := self.cmbReceive;
	
	aCombo.clear();
	aCombo.sorted := false;
		
	aCombo.addItem("Receive By " &amp; TI_TRANSMODE_ROAD_STR);
	aCombo.itemData[aCombo.newIndex] := TI_TRANSMODE_ROAD;
	aCombo.addItem("Receive By " &amp; TI_TRANSMODE_RAIL_STR);
	aCombo.itemData[aCombo.newIndex] := TI_TRANSMODE_RAIL;
	aCombo.addItem(TI_TRANSMODE_NULL_STR);
	aCombo.itemData[aCombo.newIndex] := TI_TRANSMODE_NULL;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyage" id="753edf67-265a-49c6-9e89-69e4a409e1e4">
        <source>doBuildComboVoyage();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCombo : ComboBox;
	theVoyages : CM_VoyageSet;
	aVoyage : CM_Voyage;
begin
	aCombo := self.cmbVoyage;
	
	aCombo.clear();
	aCombo.sorted := true;
	create theVoyages transient;
	
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,false, false);
	
	foreach aVoyage in theVoyages do
		aCombo.addItem(aVoyage.code &amp; " " &amp; aVoyage.description);
		aCombo.itemObject[aCombo.newIndex] := aVoyage;
	
	endforeach;
epilog
	delete theVoyages;
	
	
end;</source>
    </JadeMethod>
