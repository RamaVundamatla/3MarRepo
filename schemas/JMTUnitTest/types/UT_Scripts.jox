    <JadeMethod name="uCleanupYardMoveRequest" id="7252571b-dded-47dc-bfe5-9917e599b518">
        <source>uCleanupYardMoveRequest();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2019	jlgndl1	Initial creation

*/

vars

	ymr : CM_YardMoveRequest;
	iter : Iterator;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	term : CM_Terminal;
	
	yardIntJob : CM_YardInternalJob;

begin

//	iter := CM_YardInternalJob.instances.createIterator;
//	while iter.next( yardIntJob ) do
//		if yardIntJob.myWODtl = null or yardIntJob.myWODtl.requiredByDT = null then		
//			if  yardIntJob.allRequests.first = null then
//				beginTransaction;
//				delete yardIntJob;
//				commitTransaction;
//			endif;
//		endif;
//	endwhile;

//	delete iter;
		
	iter := CM_YardMoveRequest.instances.createIterator;
	while iter.next( ymr ) do
		ta := ymr.myTargetTA;
		if ta &lt;&gt; null and not global.isValidObject( ta ) then
			beginTransaction;
			delete ymr;
			commitTransaction;
			continue;
		endif;
		lc := ymr.mySourceLocation;
		if lc &lt;&gt; null and not global.isValidObject( lc ) then
			beginTransaction;
			delete ymr;
			commitTransaction;
			continue;
		endif;
		term := ymr.myTerminal;
		if term &lt;&gt; null and term.code = "UT" then
			if ymr.mySourceLocation = null and ymr.myTargetLocation = null and ymr.targetLocation = null then
				if ymr.myJob &lt;&gt; null and ( ymr.myJob.id = "UTINTM" or ymr.myJob.id = "MOVE_JOB" ) then
					yardIntJob := ymr.myJob.CM_YardInternalJob;
					beginTransaction;
					delete yardIntJob;
					commitTransaction;
				endif;
			endif;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
