    <JadeMethod name="compareClassDetail" id="c3f9648e-522e-49e2-bff7-84fb16240497">
        <source>compareClassDetail(_listbox : ListBox; _entity : DEV_SchemaObjectEntity) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	scm					: Schema;
	currentClass		: Class;
	currentAttribute	: Property;
	currentReference	: Property;
	currentClassConstant: Constant;
	
	currentText,
	newText				: String;
	selIndex,
	dialogResult		: Integer;
	jadeRegexReplacePat	: JadeRegexPattern;
	
	currentTimestamp	: TimeStamp;
	currentModifiedBy,
	currentDocText,
	entityType			: String;
	objectExists		: Boolean;
	devEnt				: DEV_SchemaObjectEntity;
	
begin
	if _entity = null then
		return;
	endif;
	
	objectExists := true;
	
	scm					:= _entity.getMySchema();
	currentClass		:= _entity.getMyClass(scm);
	
	if currentClass = null then
		objectExists := false;
	endif;
	
	if _entity.isKindOf(DEV_Class) and objectExists then
		currentTimestamp	:= currentClass.cnEcGetModifyTimeStamp();
		currentModifiedBy	:= currentClass.getModifiedByJMT();
		currentDocText		:= currentClass.text;
		entityType := "Class";
		
	elseif _entity.isKindOf(DEV_Attribute) and objectExists then
		currentAttribute	:= currentClass.getProperty(_entity.name);
		if currentAttribute = null then
			objectExists := false;
		else
			currentTimestamp	:= currentAttribute.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentAttribute.getModifiedByJMT();
			currentDocText		:= currentAttribute.text;
		endif;
		entityType := "Attribute";
		
	elseif _entity.isKindOf(DEV_Reference) and objectExists then
		currentReference	:= currentClass.getProperty(_entity.name);
		if currentReference = null then
			objectExists := false;
		else
			currentTimestamp	:= currentReference.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentReference.getModifiedByJMT();
			currentDocText		:= currentReference.text;
		endif;
		entityType := "Reference";
		
	elseif _entity.isKindOf(DEV_ClassConstant) and objectExists then
		currentClassConstant:= currentClass.getConstant(_entity.name);
		if currentClassConstant = null then
			objectExists := false;
		else
			currentTimestamp	:= currentClassConstant.cnEcGetModifyTimeStamp();
			currentModifiedBy	:= currentClassConstant.getModifiedByJMT();
			currentDocText		:= currentClassConstant.text;
		endif;
		entityType := "Class Constant";
		
	endif;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	if not objectExists then
		//Show only the loaded constant
		self.lblCurrLastModified.caption := null;
		self.lblLoadLastModified.caption := _entity.modifiedTimeStamp.String &amp; " - " &amp; _entity.modifiedBy.toUpper();
		self.qlbClassData.enabled := false;
		self.qlbClassData.refreshNow();
		newText := _entity.documentationTextData;
		self.jeLoaded.text := newText;
		self.jeCurrent.text := "";
		self.slStatus.caption := "Source Comparison: Missing";
		return;
	endif;
	
	self.lblCurrLastModified.caption := currentTimestamp.String &amp; " - " &amp;  currentModifiedBy.toUpper();
	self.lblLoadLastModified.caption := _entity.modifiedTimeStamp.String &amp; " - " &amp; _entity.modifiedBy.toUpper();
	
	self.qlbClassData.enabled := false;
	self.qlbClassData.refreshNow();
	
	currentText := currentDocText;
	newText := _entity.documentationTextData;
	
	self.jeCurrent.text := currentText;
	self.jeLoaded.text := newText;
	
	self.compareTextEditors();
	
	if jadeRegexReplacePat.replaceAll(currentDocText, "") = jadeRegexReplacePat.replaceAll(_entity.documentationTextData, "") then
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - No Logical Differences Found only";
	else
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - Class Detail Differences Found";
	endif;
	
	if _entity.resolvedBy = null then
		dialogResult := app.msgBox(entityType &amp; ' has been found, continue?', 'Method Found', MsgBox_Yes_No);
		if dialogResult = MsgBox_Return_Yes then
			selIndex := _listbox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := _listbox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			self.removeItemForIndex(selIndex, _listbox);
		endif;
	endif;
	
	if _entity.resolvedBy &lt;&gt; null then
		self.slStatus.caption := "Source Comparison: " &amp; entityType &amp; " - Resolved by: " &amp; _entity.resolvedBy &amp; "@" &amp; _entity.resolvedAt.String;
	endif;
	
epilog
	self.qlbClassData.enabled := true;
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="ListBox"/>
        <Parameter name="_entity" type="DEV_SchemaObjectEntity"/>
    </JadeMethod>
    <JadeMethod name="compareGlobalConstant" id="cc43bd3d-6ce8-4931-851e-c87ea5545469">
        <source>compareGlobalConstant(_newConstant: DEV_GlobalConstant) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	scm					: Schema;
	currentConstant		: Constant;
	
	currentText,
	newText				: String;
	dialogResult		: Integer;
	jadeRegexReplacePat	: JadeRegexPattern;
	
begin
	if _newConstant = null then
		return;
	endif;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	scm := rootSchema.getSchema(_newConstant.myGcCategory.mySchema.name);
	currentConstant := scm.getConstant(_newConstant.name);
	
	if currentConstant = null then
		//Show only the loaded constant
		self.lblCurrLastModified.caption := null;
		self.lblLoadLastModified.caption := _newConstant.modifiedTimeStamp.String &amp; " - " &amp; _newConstant.modifiedBy.toUpper();
		self.qlbGlobalConstants.enabled := false;
		self.qlbGlobalConstants.refreshNow();
		newText := _newConstant.documentationTextData;
		self.jeLoaded.text := newText;
		self.jeCurrent.text := "";
		self.slStatus.caption := "Source Comparison: Missing";
	else
		lblCurrLastModified.caption := currentConstant.getModifiedTimestamp().String &amp; " - " &amp;  currentConstant.getModifiedByJMT().toUpper();
		lblLoadLastModified.caption := _newConstant.modifiedTimeStamp.String &amp; " - " &amp; _newConstant.modifiedBy.toUpper();
		
		self.qlbGlobalConstants.enabled := false;
		self.qlbGlobalConstants.refreshNow();
		
		currentText := currentConstant.text;
		newText := _newConstant.documentationTextData;
		
		self.jeCurrent.text := currentText;
		self.jeLoaded.text := newText;
		
		self.compareTextEditors();
		
		if currentConstant.text = newText and currentConstant.getSource() = _newConstant.value then
			self.slStatus.caption := "Source Comparison: No Differences Found";
			
			if _newConstant.resolvedBy = null then
				dialogResult := app.msgBox('No Changes found would you like to Resolve this item', 'No Changes Found', MsgBox_Yes_No);
				if dialogResult = MsgBox_Return_Yes then
					
					self.mnuLBContext.userObject := self.qlbGlobalConstants;
					self.doRemoveFromList();
					self.mnuLBContext.userObject := null;
					
					self.qlbGlobalConstants.enabled := false;
					self.lblCurrLastModified.caption := null;
					self.lblLoadLastModified.caption := null;
				endif;
			endif;
	else
		if self.isGuineaPig() and jadeRegexReplacePat.replaceAll(currentConstant.text, "") = jadeRegexReplacePat.replaceAll(_newConstant.documentationTextData, "") and currentConstant.getSource() = _newConstant.value then
			self.slStatus.caption := "Source Comparison: No Logical Differences Found only";
		else
			self.slStatus.caption := "Source Comparison: Constant Differences Found";
		endif;
	endif;
		
	endif;
	
epilog
	self.qlbGlobalConstants.enabled := true;
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_newConstant" type="DEV_GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="compareMethod" id="d5b354f1-c142-4083-b3f8-86831c0c9e10">
        <source>compareMethod(_method : DEV_Method) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	schemaName,
	className 		: String;
	currentMethod 	: Method;
	currentSource,
	newSource		: String;
	dialogResult	: Integer;
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	selectedMethod 	: DEV_Method;
	systemSchema	: Schema;
	
begin
	if _method.myClass = null then
		return;
	endif;
	
	if _method.myClass.mySchema = null then
		return;
	endif;
	
	className := _method.myClass.name;
	schemaName := _method.myClass.mySchema.name;
	systemSchema := rootSchema.getSchema(schemaName);
	currentMethod := systemSchema.getClass(className).getMethod(_method.name);
	
	lblCurrLastModified.caption := currentMethod.getModifiedTimestamp().String &amp; " - " &amp; currentMethod.getModifiedBy().toUpper();
	lblLoadLastModified.caption := _method.modifiedTimeStamp.String &amp; " - " &amp; _method.modifiedBy.toUpper();
	
	// Prevent the user from changing methods again until we're finished
	self.qlbDifferentMethods.enabled := false;
	self.qlbDifferentMethods.refreshNow();
	
	self.jeCurrent.text := "";
	self.jeLoaded.text 	:= "";
	
	currentSource := currentMethod.getSource();
	newSource := _method.desc;
	
	self.jeCurrent.text := currentSource;
	self.jeLoaded.text 	:= newSource;
	
	if systemSchema &lt;&gt; null then
		self.jeLoaded.setCurrentSchema(systemSchema);
		self.jeCurrent.setCurrentSchema(systemSchema);
	endif;
	
	self.compareTextEditors();
	
	if currentMethod.getSource() = _method.desc and currentMethod.text = _method.documentationTextData then
		self.slStatus.caption := "Source Comparison: No Differences Found";
		
		if _method.resolvedBy = null then
			dialogResult := app.msgBox('No Changes found would you like to Resolve this item', 'No Changes Found', MsgBox_Yes_No);
			if dialogResult = MsgBox_Return_Yes then
				
				// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				self.mnuLBContext.userObject := self.qlbDifferentMethods;
				self.doRemoveFromList();
				self.mnuLBContext.userObject := null;
				// ### TFS 52791 (58881) 26Jun2023 NAVPW1
				
				self.qlbDifferentMethods.enabled := false;
				self.lblCurrLastModified.caption := null;
				self.lblLoadLastModified.caption := null;
			endif;
		endif;
	elseif currentMethod.getSource() &lt;&gt; _method.desc then
		self.slStatus.caption := "Source Comparison: Method Differences Found";
	else
		self.slStatus.caption := "Source Comparison: Method Documentation Text Differences Found";
	endif;
	
	if _method.resolvedBy &lt;&gt; null then
		self.slStatus.caption &amp;= " - Resolved by: " &amp; _method.resolvedBy &amp; "@" &amp; _method.resolvedAt.String;
	endif;
	
epilog
	self.qlbDifferentMethods.enabled := true;
	//abortTransaction;
	
end;</source>
        <access>protected</access>
        <Parameter name="_method" type="DEV_Method"/>
    </JadeMethod>
    <JadeMethod name="compareTextEditors" id="db186bfa-f686-47a4-a1ab-4c127d4cb1b6">
        <source>compareTextEditors() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	newSrcPos,
	currentSrcPos,
	tempPos				: Integer;
	
	currentSource,
	newSource,
	currentSourceLine,
	newSourceLine,
	tempSourceLine		: String;
	
	marks				: IntegerArray;
	
	currentTextEditor,
	newTextEditor		: JadeTextEdit;
	
begin
	newTextEditor := self.jeLoaded;
	currentTextEditor := self.jeCurrent;
	
	newSource := newTextEditor.text;
	currentSource := currentTextEditor.text;
	
	newSrcPos := 1;
	currentSrcPos := 1;
	
	if newSource = null then
		newTextEditor.text := "&lt;&lt;ERROR LOADING SOURCE&gt;&gt;";
		return;
	endif;
	
	if currentSource = null then
		currentTextEditor.text := "&lt;&lt;ERROR LOADING SOURCE&gt;&gt;";
		return;
	endif;
	
	while true do
		newSourceLine := "";
		currentSourceLine := "";
		
		if newSrcPos &lt;&gt; 0 then
			newSourceLine := newSource.scanUntil(CrLf, newSrcPos);
		endif;
		if currentSrcPos &lt;&gt; 0 then
			currentSourceLine := currentSource.scanUntil(CrLf, currentSrcPos);
		endif;
		
		if newSourceLine &lt;&gt; currentSourceLine then
			if newSrcPos &lt;&gt; 0 then
				newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
			else
				newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
			endif;
			
			// Fudge things a little, and try and hanndle just those "1 line" differences a bit nicer
			tempPos := newSrcPos + 2;
			tempSourceLine := "";
			if tempPos &lt; newSource.length then
				tempSourceLine := newSource.scanUntil(CrLf, tempPos);
			endif;
			
			if tempSourceLine = currentSourceLine then
				newSrcPos := tempPos;
			else			
				if currentSrcPos &lt;&gt; 0 then
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endif;
		endif;
		
		if newSrcPos = 0 and currentSrcPos &lt;&gt; 0 then
			// New method has less lines than the old
			
			while currentSrcPos &lt;&gt; 0 do
				currentSrcPos += 2;	// Skip the CrLf
				if currentSrcPos &gt; currentSource.length then
					break;
				endif;
				
				currentSourceLine := currentSource.scanUntil(CrLf, currentSrcPos);
				if currentSrcPos &lt;&gt; 0 then
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					currentTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, currentSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endwhile;
		endif;
		
		if newSrcPos &lt;&gt; 0 and currentSrcPos = 0 then
			// New method has more lines than the old
			
			while newSrcPos &lt;&gt; 0 do
				newSrcPos += 2;	// Skip the CrLf
				if newSrcPos &gt; newSource.length then
					break;
				endif;
				
				newSourceLine := newSource.scanUntil(CrLf, newSrcPos);
				if newSrcPos &lt;&gt; 0 then
					newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSrcPos, JadeTextEdit.MARKER_JAD_LINEMARK);
				else
					newTextEditor.doLinemarker(JadeTextEdit.LMACT_ADDATPOSITON, newSource.length-1, JadeTextEdit.MARKER_JAD_LINEMARK);
				endif;
			endwhile;
		endif;
		
		// We're done here, move on
		if newSrcPos = 0 or currentSrcPos = 0 then
			break;
		endif;
		
		newSrcPos += 2;			// Skip the CrLf
		currentSrcPos += 2;		// Skip the CrLf
		
		if newSrcPos &gt; newSource.length then
			newSrcPos := 0;
		endif;
		if currentSrcPos &gt; currentSource.length then
			currentSrcPos := 0;
		endif;
	endwhile;
	
	create marks transient;
	newTextEditor.getLinemarkLines(JadeTextEdit.MARKER_JAD_LINEMARK, false, marks);
	if marks.size &gt; 0 then
		newTextEditor.currentPosition := marks[1];
		currentTextEditor.currentPosition := marks[1];
	endif;
	
epilog
	delete marks;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoResolve" id="cb0e5a5d-2170-4460-a9fc-9c2fe932e771">
        <updating/>
        <source>doAutoResolve() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	report						: DEV_SourceCompareReport;
	devSchema 					: DEV_Schema;
	devClass 					: DEV_Class;
	devMethod 					: DEV_Method;
	
	systemSchema				: Schema;
	systemClass					: Class;
	systemMethod				: Method;
	
	resolvedMethodCount,
	resolvedMissingMethodCount	: Integer;
	objsToResolve : ObjectArray;
	
	cmsPrgrs		: CMS_Progress;
	schemaEntity	: DEV_SchemaObjectEntity;
	
begin
	if app.msgBox("Are you sure you want to auto resolve all differences", "Auto Resolve Items", MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	report := self.myReport;
	
	if report = null then
		return;
	endif;
	
	create cmsPrgrs transient;
	cmsPrgrs.show;
	cmsPrgrs.setAction("Initializing...");
	cmsPrgrs.progress.partsInJob := 1;
	cmsPrgrs.progress.partsDone := 0;
	cmsPrgrs.raiseExceptionOnAbort := false;
	cmsPrgrs.progress.foreColor := Blue;
	cmsPrgrs.progress.backColor := White;
	cmsPrgrs.progress.thinClientUpdateInterval := 1000;
	cmsPrgrs.progress.showTaskBarProgress := true;
	
	create objsToResolve transient;
	
	cmsPrgrs.setAction("Getting Data to Resolve");
	
	foreach devSchema in report.allSchemas do
		systemSchema := rootSchema.getSchema(devSchema.name);
		foreach devClass in devSchema.allClasses do
			systemClass := systemSchema.getClass(devClass.name);
			//Different method resolving
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				systemMethod := systemClass.getMethod(devMethod.name);
				
				//Check not resolved
				if devMethod.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				//Check the same
				if systemMethod.getSource() = devMethod.desc and systemMethod.text = devMethod.documentationTextData then
					//resolve the method
					objsToResolve.add(devMethod);
					resolvedMethodCount += 1;
					
				endif;
				
			endforeach;
			
			//Missing method resolving
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				systemMethod := systemClass.getMethod(devMethod.name);
				if systemMethod = null then
					continue;
				endif;
				
				//Check not resolved
				if devMethod.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				//resolve the method
				//devMethod.setResolved(process.getComputerName);
				objsToResolve.add(devMethod);
				resolvedMissingMethodCount += 1;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	if objsToResolve.isEmpty then
		app.msgBox("No Differences to resolve", "Auto Resolved Items", MsgBox_OK_Only);
		return;
	endif;
	
	cmsPrgrs.setAction("Resolving Data");
	cmsPrgrs.progress.partsInJob := objsToResolve.size;
	cmsPrgrs.progress.partsDone := 0;
	
	foreach schemaEntity in objsToResolve as DEV_SchemaObjectEntity do
		schemaEntity.setResolved(process.getComputerName);
		cmsPrgrs.progress.partsDone += 1;
	endforeach;
	
	app.msgBox("Resolved Different Methods: " &amp; resolvedMethodCount.String &amp; CrLf &amp; 
				"Resolved Missing Methods: " &amp; resolvedMissingMethodCount.String &amp; CrLf &amp; 
				"These items are now resolved", "Auto Resolved Items", MsgBox_OK_Only);
	
	self.doClearForm();
	
	self.doQuery();
	
epilog
	delete cmsPrgrs;
	delete objsToResolve;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearForm" id="8274ba0d-b46a-4ae5-b6f5-b84ffddc8762">
        <updating/>
        <source>doClearForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

begin
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.loadedMethod 					:= null;
	self.btnOpenInWinMerge.enabled 		:= false;
	self.btnExportReportFull.enabled 	:= false;
	self.btnExportReportStats.enabled 	:= false;
	self.myReport 						:= null;
	self.btnOpenInNpp.enabled 			:= false;
	self.btnAutoResolve.enabled 			:= false;
	self.btnLoadChange.enabled 			:= false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportReport" id="dd447826-e60e-460d-acc6-425ca55ff4d9">
        <source>doExportReport(_exportStats : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	reportData		: String;
	
	report			: DEV_SourceCompareReport;
	outputFile,
	notepadPlusPlus : File;
	notepad			: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	str				: String;
	args			: StringArray;
	result,
	exitCode		: Integer;
	allArgs			: String;
	statsOnly		: Integer;
	cmsPrgrs		: CMS_Progress;
	
begin
	report := self.myReport;
	
	create cmsPrgrs transient;
	cmsPrgrs.show;
	cmsPrgrs.setAction("Getting Report Data");
	cmsPrgrs.progress.partsInJob := 1;
	cmsPrgrs.raiseExceptionOnAbort := false;
	
	if _exportStats then
		reportData := report.getStats(self.txtSearchString.text);
		
	else
		reportData := report.getReportOrd(self.txtSearchString.text);
		
	endif;
	
	cmsPrgrs.setAction("Exporting Report Data");
	cmsPrgrs.progress.partsInJob := 1;
	cmsPrgrs.raiseExceptionOnAbort := false;
	
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	create outputFile transient;
	outputFile.usePresentationFileSystem := true;
	outputFile.fileName := process.getTempPath() &amp; "exportedReport.jadeReport";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFile.isAvailable and not outputFile.isOpen then
		outputFile.cnRemoveFile(5, 5000);
	endif;
	
	outputFile.writeString(reportData);
	
	create notepad transient;
	notepad.usePresentationFileSystem := true;
	notepad.fileName := node.getEnvironmentVariable("WINDIR") &amp; "\notepad.exe";
	if not notepad.isAvailable then
		notepad.close();
		write "Notepad not found in " &amp; notepad.fileName;
		return;
	endif;
	
	create args transient;
	args[1] := outputFile.fileName;

	result := node.createExternalProcess(".", notepad.fileName, args, null, true, true, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_Successful or exitCode &lt;&gt; 0 then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepad.fileName &amp; allArgs;
		write "Error running Notepad " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
epilog
	delete outputFile;
	delete outputFolder;
	delete notepad;
	delete cmsPrgrs;
end;</source>
        <Parameter name="_exportStats" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadChange" id="54a0fa40-2b48-4d7a-84f4-14f214e445e0">
        <source>doLoadChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	fileGet : CMDFileOpen;
	impFile : File;
	sourceCompareAgent : DEV_SourceCompareAgent;
	
begin
	create sourceCompareAgent transient;
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet transient;
	fileGet.filter 		:= 'Jade Method (.mth)|*.mth';
	//fileGet.filter 		:= 'Jade Method (.mth)|*.mth|Jade Class (.cls)|*.cls|Jade Schema (.scm)|*.scm';
	fileGet.filterIndex	:= 1;
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return;
	endif;
	
	//Use Source Compare Agent to load mth file into the source comparison report
	sourceCompareAgent.doLoadJadeMethod(impFile, impFile.name.replace(".scm", ""));
	
epilog
	delete impFile;
	delete sourceCompareAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMarkUnresolveSelectedItem" id="a08c7baa-535f-4082-98b8-bb7aab8a7258">
        <source>doMarkUnresolveSelectedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex,
	selLevel,
	index		: Integer;
	devEnt		: DEV_SchemaObjectEntity;
	
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	if selIndex &lt; 1 then
		return;
	endif;
	
	selLevel := listBox.itemLevel[selIndex];
	devEnt := listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
	
	if devEnt &lt;&gt; null and devEnt.resolvedBy &lt;&gt; null then
		devEnt.setResolved(null);
		
		if devEnt.isKindOf(DEV_Method) then
			self.compareMethod(devEnt.DEV_Method);
		endif;
		
		listBox.itemForeColor[selIndex] := Window.Color_WindowText;
		
		// Now go down the tree and reset the colour of any subitems
		index := selIndex;
		while true do
			index += 1;
			
			// End of list
			if listBox.listCount &lt; index then
				break;
			endif;
			
			// Same level as us, or higher, so we can stop
			if listBox.itemLevel[index] &lt;= selLevel then
				break;
			endif;
			
			listBox.itemForeColor[index] := Window.Color_WindowText;
		endwhile;
		
		// Same with our direct parents
		index := selIndex;
		while true do
			index -= 1;
			
			// Beginning of list
			if index = 0 then
				break;
			endif;
			
			// Found the next sibling, or children thereof, so skip
			if listBox.itemLevel[index] &gt;= selLevel then
				continue;
			endif;
			
			// Parent is already cleared and the right colour, so we're done
			if listBox.itemForeColor[index] = Window.Color_WindowText then
				break;
			endif;
			
			devEnt := listBox.itemObject[index].DEV_SchemaObjectEntity;
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				listBox.itemForeColor[index] := Window.Color_WindowText;
			endif;
		endwhile;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenInNPP" id="6f58f111-dcd5-4a98-9f6d-ef1c74e65153">
        <source>doOpenInNPP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	outputFileLeft,
	outputFileRight,
	notepadPlusPlus,
	nppSessionFile	: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	loadedClass,
	targetDir,
	appToStart,
	str,
	allArgs			: String;
	args			: StringArray;
	currentMethod 	: Method;
	result,
	exitCode		: Integer;
	
begin
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	if self.loadedMethod.myClass = null then
		return;
	endif;
	
	if self.loadedMethod.myClass.mySchema = null then
		return;
	endif;
	
	create outputFileLeft transient;
	create outputFileRight transient;
	
	loadedClass := self.loadedMethod.myClass.name;
	currentMethod := rootSchema.getSchema(self.loadedMethod.myClass.mySchema.name).getClass(loadedClass).getMethod(self.loadedMethod.name);
	
	outputFileLeft.usePresentationFileSystem := true;
	//outputFileLeft.openOutput(appLogTmpDir &amp; "\" &amp; "Loaded-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileLeft.fileName := process.getTempPath() &amp; "Loaded-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileLeft.isAvailable and not outputFileLeft.isOpen then
		outputFileLeft.cnRemoveFile(5, 5000);
	endif;
	
	outputFileLeft.writeString(jeLoaded.text);
	outputFileLeft.close();
	
	outputFileRight.usePresentationFileSystem := true;
	//outputFileRight.openOutput(appLogTmpDir &amp; "\" &amp; "Current-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileRight.fileName := process.getTempPath() &amp; "Current-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileRight.isAvailable and not outputFileRight.isOpen then
		outputFileRight.cnRemoveFile(5, 5000);
	endif;
	
	outputFileRight.writeString(jeCurrent.text);
	outputFileRight.close();
	
	//Run Code to open in WinMerge
	create notepadPlusPlus transient;
	notepadPlusPlus.usePresentationFileSystem := true;
	notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\Notepad++\notepad++.exe";
	if not notepadPlusPlus.isAvailable then
		//write "Winmerge not found in " &amp; winmerge.fileName;
		notepadPlusPlus.close();
		notepadPlusPlus.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\Notepad++\notepad++.exe";
		if not notepadPlusPlus.isAvailable then
			//write "Winmerge not found in " &amp; winmerge.fileName;
			return;
		endif;
	endif;
	
	create nppSessionFile transient;
	nppSessionFile.usePresentationFileSystem := true;
	nppSessionFile.fileName := process.getTempPath() &amp; "sourceCompareSessionFile.xml";
	if nppSessionFile.isAvailable and not nppSessionFile.isOpen then
		nppSessionFile.cnRemoveFile(5, 5000);
	endif;
	
	nppSessionFile.writeString('&lt;?xml version="1.0" encoding="UTF-8" ?&gt;
&lt;NotepadPlus&gt;
    &lt;Session activeView="1"&gt;
        &lt;mainView activeIndex="155"&gt;
            &lt;File firstVisibleLine="1" xOffset="0" scrollWidth="736" startPos="13752" endPos="13761" selMode="0" offset="0" wrapCount="1" lang="None (Normal Text)" encoding="-1" userReadOnly="no" filename="' &amp; outputFileLeft.fileName &amp; '" backupFilePath="" originalFileLastModifTimestamp="1512048640" originalFileLastModifTimestampHigh="30957285" mapFirstVisibleDisplayLine="-1" mapFirstVisibleDocLine="-1" mapLastVisibleDocLine="-1" mapNbLine="-1" mapHigherPos="-1" mapWidth="-1" mapHeight="-1" mapKByteInDoc="151" mapWrapIndentMode="-1" mapIsWrap="no" /&gt;
        &lt;/mainView&gt;
        &lt;subView activeIndex="155"&gt;
            &lt;File firstVisibleLine="1" xOffset="0" scrollWidth="1152" startPos="3491" endPos="3491" selMode="0" offset="0" wrapCount="1" lang="None (Normal Text)" encoding="-1" userReadOnly="no" filename="' &amp; outputFileRight.fileName &amp; '" backupFilePath="" originalFileLastModifTimestamp="-2012347430" originalFileLastModifTimestampHigh="30978122" mapFirstVisibleDisplayLine="-1" mapFirstVisibleDocLine="-1" mapLastVisibleDocLine="-1" mapNbLine="-1" mapHigherPos="-1" mapWidth="-1" mapHeight="-1" mapKByteInDoc="512" mapWrapIndentMode="-1" mapIsWrap="no" /&gt;
        &lt;/subView&gt;
    &lt;/Session&gt;
&lt;/NotepadPlus&gt;');
	nppSessionFile.close();
	
	create args transient;
	args[1] := '-openSession "' &amp; nppSessionFile.fileName &amp; '"';

	self.enableAllControls(false);
	self.refreshNow();
	
	result := node.createExternalProcess(".", notepadPlusPlus.fileName, args, null, true, false, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_InitiateOK then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write notepadPlusPlus.fileName &amp; allArgs;
		write "Error running Notepad ++ " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
epilog
	delete outputFileLeft;
	delete outputFileRight;
	delete nppSessionFile;
	delete outputFolder;
	delete args;
	delete notepadPlusPlus;
	
	self.enableAllControls(true);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenInWinMerge" id="566d1660-137a-4b74-977d-25f35c774b2d">
        <source>doOpenInWinMerge();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	outputFileLeft,
	outputFileRight,
	winmerge		: File;
	outputFolder	: FileFolder;
	appLogTmpDir,
	loadedClass,
	targetDir,
	appToStart,
	str,
	allArgs			: String;
	args			: StringArray;
	currentMethod 	: Method;
	result,
	exitCode		: Integer;
	
begin
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	create outputFolder transient;
	outputFolder.fileName := "C:\temp\";
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	if self.loadedMethod.myClass = null then
		return;
	endif;
	
	if self.loadedMethod.myClass.mySchema = null then
		return;
	endif;
	
	create outputFileLeft transient;
	create outputFileRight transient;
	
	loadedClass := self.loadedMethod.myClass.name;
	currentMethod := rootSchema.getSchema(self.loadedMethod.myClass.mySchema.name).getClass(loadedClass).getMethod(self.loadedMethod.name);
	
	outputFileLeft.usePresentationFileSystem := true;
	outputFileLeft.kind := outputFileLeft.Kind_ANSI;
	//outputFileLeft.openOutput(appLogTmpDir &amp; "\" &amp; "Loaded-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileLeft.fileName := process.getTempPath() &amp; "Loaded-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileLeft.isAvailable and not outputFileLeft.isOpen then
		outputFileLeft.cnRemoveFile(5, 5000);
	endif;
	
	outputFileLeft.writeString(jeLoaded.text);
	outputFileLeft.close();
	
	outputFileRight.usePresentationFileSystem := true;
	outputFileRight.kind := outputFileRight.Kind_ANSI;
	//outputFileRight.openOutput(appLogTmpDir &amp; "\" &amp; "Current-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	outputFileRight.fileName := process.getTempPath() &amp; "Current-" &amp; loadedClass &amp; "-" &amp; self.loadedMethod.name &amp; ".jadeMethod";
	
	//Stops files from getting into a weird state (Had an extra ; getting added at the end for some reason and rewriting would not fix it)
	if outputFileRight.isAvailable and not outputFileRight.isOpen then
		outputFileRight.cnRemoveFile(5, 5000);
	endif;
	
	outputFileRight.writeString(jeCurrent.text);
	outputFileRight.close();
	
	//targetDir := app.copyFileToLocalMachine(appLogTmpDir &amp; "\" &amp; "Loaded-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod", "C:\temp\"&amp; "Loaded-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	//targetDir := app.copyFileToLocalMachine(appLogTmpDir &amp; "\" &amp; "Current-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod", "C:\temp\"&amp; "Current-" &amp; loadedClass &amp; "--" &amp; self.loadedMethod.name &amp; ".jadeMethod");
	
	//Run Code to open in WinMerge
	//appToStart := "C:\Program Files (x86)\WinMerge\WinMergeU.exe";
	create winmerge transient;
	winmerge.usePresentationFileSystem := true;
	winmerge.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\WinMerge\WinMergeU.exe";
	if not winmerge.isAvailable then
		//write "Winmerge not found in " &amp; winmerge.fileName;
		winmerge.close();
		winmerge.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\WinMerge\WinMergeU.exe";
		if not winmerge.isAvailable then
			//write "Winmerge not found in " &amp; winmerge.fileName;
			return;
		endif;
	endif;
	
	create args transient;
	args[1] := "/e /s /u";
	args[2] := '/dl "' &amp; self.loadedMethod.name &amp; ' - Loaded - Modified: ' &amp; self.loadedMethod.modifiedTimeStamp.String &amp; " - " &amp; self.loadedMethod.modifiedBy.toUpper() &amp; '"';
	args[3] := '/dr "' &amp; self.loadedMethod.name &amp; ' - Current - Modified: ' &amp; currentMethod.getModifiedTimestamp().String &amp; " - " &amp; currentMethod.getModifiedBy().toUpper() &amp; '"';
	args[4] := outputFileLeft.fileName;
	args[5] := outputFileRight.fileName;

	self.enableAllControls(false);
	self.refreshNow();
	
	result := node.createExternalProcess(".", winmerge.fileName, args, null, true, true, exitCode);
	
	if result &lt;&gt; Node.ExternalProcess_Successful or exitCode &lt;&gt; 0 then
		foreach str in args do
			allArgs &amp;= " " &amp; str;
		endforeach;
		write winmerge.fileName &amp; allArgs;
		write "Error running Winmerge " &amp; result.String &amp; "," &amp; exitCode.String;
		return;
	endif;
	
epilog
	delete outputFileLeft;
	delete outputFileRight;
	delete outputFolder;
	delete args;
	delete winmerge;
	
	self.enableAllControls(true);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="d6f5554e-254b-48ae-a4a5-5d506857e9c9">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	report		: DEV_SourceCompareReport;
	searchString	: String;
	cmsPrgrs		: CMS_Progress;
	
begin
	create cmsPrgrs transient;
	
	cmsPrgrs.show;
	cmsPrgrs.setAction("Initializing...");
	cmsPrgrs.progress.partsInJob := 5;
	cmsPrgrs.raiseExceptionOnAbort := false;
	cmsPrgrs.progress.foreColor := Blue;
	cmsPrgrs.progress.backColor := White;
	cmsPrgrs.progress.thinClientUpdateInterval := 1000;
	cmsPrgrs.progress.showTaskBarProgress := true;
	
	self.frmQuery.visible := false;
	self.searcherShowHideControls(true);
	
	if self.cmbSelectReport.text = null then
		return;
	endif;
	
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	
	self.jeCurrent.text 				:= "";
	self.jeLoaded.text 					:= "";
	self.lblCurrLastModified.caption 	:= "";
	self.lblLoadLastModified.caption 	:= "";
	self.btnOpenInWinMerge.enabled 		:= false;
	self.btnOpenInNpp.enabled 			:= false;
	
	report := self.cmbSelectReport.listObject.DEV_SourceCompareReport;
	
	searchString := self.txtSearchString.text;
	
	self.endNotificationForSubscriber(self);
	
	self.btnExportReportStats.enabled := true;
	self.btnExportReportFull.enabled := true;
	self.btnAutoResolve.enabled := true;
	self.btnLoadChange.enabled := true;
	
	self.myReport := report;
	
	cmsPrgrs.progress.partsDone := 1;
	
	/*
	* Differing Methods
	*/
	cmsPrgrs.setAction("Loading Differing Methods");
	
	self.loadDifferingMethods(report, searchString);
	
	// If the search is not for a usercode, then clear it
	if not searchString.startsWith__("nav") and not searchString.startsWith__("jlg") and not searchString.startsWith__("jli") and 
		not searchString.startsWith__("cnw") and searchString &lt;&gt; "JadeLoader" and searchString &lt;&gt; "&lt;unknown&gt;" then
		searchString := null;
	endif;
	
	cmsPrgrs.progress.partsDone := 2;
	
	/*
	* Missing/Differing Class Data
	* Attributes
	* References
	* Constants
	*/
	cmsPrgrs.setAction("Loading Missing/Different Class Data");
	self.loadMissingClasses(report, searchString);
	cmsPrgrs.progress.partsDone := 3;
	
	/*
	* Missing Methods
	*/
	cmsPrgrs.setAction("Loading Missing Methods");
	self.loadMissingMethods(report, searchString);
	cmsPrgrs.progress.partsDone := 4;
	
	/*
	* Global Constants
	*/
	cmsPrgrs.setAction("Loading Missing/Different Global Constants");
	self.loadGlobalConstants(report, searchString);
	cmsPrgrs.progress.partsDone := 5;
	
	self.slStatus.caption := "Report Loaded";
	
epilog
	delete cmsPrgrs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefreshReports" id="669b36cc-3ddf-4414-af84-49d5db06ca94">
        <source>doRefreshReports();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars

begin
	self.loadReports();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveFromList" id="d33cd4fe-2506-4d8e-b884-77783a8b497d">
        <source>doRemoveFromList();
/*

Purpose:			Remove 'Checked-Off' items from the list

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex	: Integer;
	devEnt		: DEV_SchemaObjectEntity;
	
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	if selIndex &lt; 1 then
		return;
	endif;
	
	devEnt := listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
	
	// Mark the difference object as 'resolved'
	if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
		if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
			devEnt.setResolved(process.getComputerName);
		endif;
	endif;
	
	self.removeItemForIndex(selIndex, listBox);
	
	// Now that we have nothing selected, clear the top boxes
	self.jeCurrent.text := null;
	self.jeLoaded.text := null;
	self.lblCurrLastModified.caption := null;		// ### TFS 52791 (58881) 26Jun2023 NAVPW1
	self.lblLoadLastModified.caption := null;		// ### TFS 52791 (58881) 26Jun2023 NAVPW1

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="96a01d23-977e-4666-b2db-00f18c1bd718">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2022	navpw1	Initial creation

*/

vars

begin
	self.splHorizMain.top := self.frmToolbar.height;
	self.splHorizMain.height := self.clientHeight-22-22-24;
	
	//self.splHorizMain.parentBottomOffset := 22;
	inheritMethod();
	
	self.fldQuery.top	:=	self.frmQueryToolbar.height;
	self.splHorizMain.width := self.clientWidth - 10;
	
	self.splHorizMain.sourceCompareResizeContents();
	self.splCodeCompare.sourceCompareResizeContents(); //Resize our split container contents
	self.splData.sourceCompareResizeContents(); //Resize our split container contents
	self.splLeft.sourceCompareResizeContents(); //Resize our split container contents
	self.splRight.sourceCompareResizeContents(); //Resize our split container contents
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunFullComparison" id="684bdc65-52f3-454c-ace2-190b9776b8c8">
        <source>doRunFullComparison();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

constants
	ReleasesFolderM24 = "\\cnwchcm24\cnwpod$\Releases\";
	SchemaFilePathDMast = "\SCMCompare\DailyExtracts";	// ReleasesFolderM24 + CM_Root::getVersionString() + SchemaFilePathDMast = \\cnwchcm24\cnwpod$\Releases\20021\SCMCompare\DailyExtracts
	SchemaFilePathWMast = "\Daily\JadeMaster\schemas";	// ReleasesFolderM24 + CM_Root::getVersionString() + SchemaFilePathWMast = \\cnwchcm24\cnwpod$\Releases\20021\Daily\JadeMaster\schemas

vars
	devSourceCompareAgent 	: DEV_SourceCompareAgent;
	fileNode				: FileNode;
	folder					: FileFolder;
	concatanatedMessage,
	schemaFilePath			: String;
	reportType				: Integer;
	interrupted				: Boolean;
	startTime,
	estDuration				: Time;
	currSecs,
	maxFilesNum,
	curFileNum				: Integer;
	cmsPrgrs		: CMS_Progress;
	dialogResult	: Integer;
	
begin
	//on Exception do self.handleUserInterrupt(exception, interrupted);
	dialogResult := app.msgBox('Are you sure you want to run a full code comparison?', 'Run Code Comparison', MsgBox_Yes_No);
	if dialogResult = MsgBox_Return_No then
		return;
	endif;
	create cmsPrgrs transient;
	
	reportType := DEV_SourceCompareReport.ReportType_Manual;
	estDuration := DEV_SourceCompareRoot.firstInstance.averageFullDuration;
	
	cmsPrgrs.show;
	cmsPrgrs.setAction("Running Source Comparison");
	cmsPrgrs.progress.partsInJob := 1;
	cmsPrgrs.raiseExceptionOnAbort := false;
	
	self.slStatus.caption := "Source Comparison Running";
	
	app.mySourceCompareRoot.setIsRunningComparison(true);
	
	//Create Source Comparison Agent
	create devSourceCompareAgent transient;
	
	//Run cleanup script
	devSourceCompareAgent.cleanUpReportsProgress(cmsPrgrs);
	
	//Run Source Comparison Code
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := ReleasesFolderM24 &amp; app.myRoot.getVersionString() &amp; SchemaFilePathWMast;
	else
		schemaFilePath := ReleasesFolderM24 &amp; app.myRoot.getVersionString() &amp; SchemaFilePathDMast;
	endif;
	
	create folder transient;
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.logMessage("Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		return;
	endif;
	
	//self.pbProgressBar.partsInJob := folder.files.size + 1;
	maxFilesNum := folder.files.size;
	
	cmsPrgrs.show;
	cmsPrgrs.setAction("Running Source Comparison");
	cmsPrgrs.progress.partsInJob := maxFilesNum;
	cmsPrgrs.progress.partsDone := 0;
	cmsPrgrs.raiseExceptionOnAbort := false;
	cmsPrgrs.progress.foreColor := Blue;
	cmsPrgrs.progress.backColor := White;
	cmsPrgrs.progress.thinClientUpdateInterval := 1000;
	cmsPrgrs.progress.showTaskBarProgress := true;
	
	startTime := app.actualTime.time;
	
	foreach fileNode in folder.files do
		curFileNum += 1;
		if (not fileNode.isKindOf(FileFolder)) then
			if estDuration &lt;&gt; null then
				currSecs := estDuration.Integer - (app.actualTime.time - startTime).max(0);
			endif;
			cmsPrgrs.setAction("Loading " &amp; fileNode.name.replace(".scm", "") &amp; CrLf &amp; "[" &amp; curFileNum.String &amp; "/" &amp; maxFilesNum.String &amp; "] Estimated Time Remaining: " &amp; currSecs.Time.String);
			devSourceCompareAgent.doSchemaComparison(fileNode.fileName, fileNode.name.replace(".scm", ""), false, reportType);
			cmsPrgrs.progress.partsDone += 1;
		endif;
	endforeach;
	
	cmsPrgrs.setAction("Finishing Up" &amp; CrLf &amp; "[" &amp; curFileNum.String &amp; "/" &amp; maxFilesNum.String &amp; "] Estimated Time Remaining: Done");
	
	devSourceCompareAgent.reportAgent.setDuration(startTime);
	
	devSourceCompareAgent.setReportAvailable();
	
	concatanatedMessage := devSourceCompareAgent.getReport();
	
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.logMessage(concatanatedMessage, LogERROR);
	endif;
	
	//self.pbProgressBar.partsDone := self.pbProgressBar.partsDone + 1;
	cmsPrgrs.setAction("Complete");
	cmsPrgrs.progress.foreColor := Green;
	
	self.loadReports();
	
epilog
	app.mySourceCompareRoot.setIsRunningComparison(false);
	delete devSourceCompareAgent;
	delete folder;
	//Hide progress bar frames
	
	delete cmsPrgrs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowDetails" id="069fb15d-dd9c-4007-800e-ad69147413c1">
        <source>doShowDetails(_listbox: ListBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	itemObject					: Object;
	sourceComparisonAttributes 	: DEV_SourceComparisonAttributes;
	
begin
	if _listbox.text &lt;&gt; null then
		itemObject := _listbox.itemObject[_listbox.listIndex];
		create sourceComparisonAttributes transient;
		
		if itemObject.isKindOf(DEV_Class) then
			//Load comparison form
			sourceComparisonAttributes.loadClass(itemObject.DEV_Class);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_Attribute) then
			//Load comparison form
			sourceComparisonAttributes.loadAttribute(itemObject.DEV_Attribute);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_Reference) then
			//Load comparison form
			sourceComparisonAttributes.loadReference(itemObject.DEV_Reference);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_ClassConstant) then
			//Load comparison form
			sourceComparisonAttributes.loadConstant(itemObject.DEV_ClassConstant);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_GlobalConstantCategory) then
			//Load comparison form
			sourceComparisonAttributes.loadGlobalConstantCategory(itemObject.DEV_GlobalConstantCategory);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_GlobalConstant) then
			//Load comparison form
			sourceComparisonAttributes.loadGlobalConstant(itemObject.DEV_GlobalConstant);
			sourceComparisonAttributes.show();
		else
			// A list entry with children was double clicked, so expand them
			_listbox.cnEcExpandItem(_listbox.listIndex, true);
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_listbox" type="ListBox" usage="input"/>
    </JadeMethod>
