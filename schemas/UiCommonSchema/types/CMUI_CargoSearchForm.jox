    <JadeMethod name="lstColour_hasGotFocus" id="bd582e6e-f69d-4870-9ede-a3b5a743fa15">
        <controlMethod name="CMUI_FieldFrame::hasGotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_hasGotFocus(_fieldFrame: CMUI_FieldFrame input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars

begin
	// make list box bigger, and place it over the textbox
	self.lstColourList.move(self.txtColourList.getFormLeft, self.txtColourList.getFormTop, self.txtColourList.width, 125);
	self.lstColourList.visible := true;
	self.lstColourList.parent := self;
	self.txtColourList.visible := false;
	self.lstColourList.setFocus;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
