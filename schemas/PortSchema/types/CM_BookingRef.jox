    <JadeMethod name="getShippingMarks" id="cdeadf08-a026-4799-b417-852d00989182">
        <source>getShippingMarks():String;
// ---------------------------------------------------------------------------
// Created:     12 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	brItem : CM_BookingRefItem;
	result : String;
begin
	result := self.allBookingRefItems.first.shippingMarks;
	foreach brItem in self.allBookingRefItems do
		if brItem.shippingMarks &lt;&gt; result then
