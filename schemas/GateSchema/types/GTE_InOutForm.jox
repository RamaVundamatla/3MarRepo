    <JadeMethod name="keyDown" id="6e907c1c-9e20-4e33-9502-fd007059f797">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mainTable	: CM_EntryTable;
	extraTable	: CM_EntryTable;
	
	theActiveControl	: Control;

begin

	if keyCode = J_key_Tab then

		theActiveControl := app.activeControl;

		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.CM_EntryTable;
		endif;

		tblCommon.handleFormTab(keyCode, shift, txtNewItem, btnReceive);

		if topSheet &lt;&gt; null and topSheet.visible then
		
			mainTable  := topSheet.myTblMain;
			extraTable := topSheet.myTblExtra;
			
			if mainTable &lt;&gt; null and extraTable &lt;&gt; null then
				mainTable.handleFormTab(keyCode, shift, fldInOut, extraTable);
				extraTable.handleFormTab(keyCode, shift, mainTable, btnDeleteCurrent);
			endif;
		endif;

		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;

	elseif keyCode = CMUI_Key_F5 then
		self.doRefresh();
	endif;
	
	//Added 11082003 (cnwsh3)
	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listTableLostFocus" id="72e77541-195c-4af2-9bbe-90c196014c47">
        <updating/>
        <source>listTableLostFocus(pListTable : GTE_ListTable; pAttrName : String) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateSheet	: GTE_Sheet;
	mainTbl,
	extraTbl	: CM_EntryTable;
	
begin

	gateSheet := pListTable.mySheet;
	
	if gateSheet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'topSheet is null');
		return;
	endif;

	mainTbl := gateSheet.myTblMain;
	extraTbl := gateSheet.myTblExtra;
	
	self.myAssistant.GTE_Assistant.mainExtraListTableLostFocus(mainTbl, extraTbl, pListTable, pAttrName, saveRowHeight, true);

end;</source>
        <access>protected</access>
        <Parameter name="pListTable" type="GTE_ListTable"/>
        <Parameter name="pAttrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadBookingRefItems" id="1de22474-d5ec-4742-9a2f-b1ebaae5279d">
        <source>loadBookingRefItems(_br : CM_BookingRef; _brItem : CM_BookingRefItem);
// ---------------------------------------------------------------------------
// Created:     13 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cmb					: CMUI_ComboBoxBookRefItem;
	code				: CM_Code;
	conditionDict		: CM_LogConditionCodesByCodeDict;
	sheet				: GTE_Sheet;
begin
	sheet := self.topSheet;
	cmb := sheet.getControlByName(cmbBRItem.name).CMUI_ComboBoxBookRefItem;
	if _br = cmb.myBookingRef then  // store the booking ref so don't reload if it has not changed
		return;
	endif;
	cmb.clear;
	cmb.setMyBookingRef(_br);
	cmb.setObject(_brItem);
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
    </JadeMethod>
