    <JadeMethod name="doRegisterClass" id="01ab9b39-ebd4-478e-bcd1-569e297e6118">
        <source>doRegisterClass(pClass: Integer; pParentClass: Integer) protected;
/*
*/
begin
	if pParentClass = 0 then
		self.myJadeAuditAccess.registerFilterClass(pClass);
	else
		self.myJadeAuditAccess.registerFilterCollection(pClass, pParentClass);
	endif;

//	call registerClass(self.journalHandle, pClass, pParentClass);
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Integer"/>
        <Parameter name="pParentClass" type="Integer"/>
    </JadeMethod>
