    <JadeMethod name="setForAdhocBGPReport" id="f9732456-82cd-4ec8-9184-95872f430c33">
        <updating/>
        <source>setForAdhocBGPReport( _name : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2013	cnwndl1	Initial creation	Par 31562

*/

vars

begin

	self.myMenuReportRoot := null;
	self.reportName := _name;
	self.heading := _name;
	self.jrwReportName.add(_name);
	self.jrwViewName := "CM_TrackedItemView";
	self.filterClassName := CMQF_AnyDataObject.name;
	self.qryMethodName := "qryAnyDataObject";
	// TFS 978 handle form-based reports - assume that the names all start with CMUI_
	if _name.length &gt; 5 and 
	   _name[1:5] = "CMUI_" then
		self.schemaName := "UiCommonSchema";
		self.formClassName := _name;
		self.isFormBasedReport := true;
	endif;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
