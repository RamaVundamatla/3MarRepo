    <JadeMethod name="getNumberFormat" id="bc8bd8b0-6f0c-4032-8ebe-459917c9f456">
        <source>getNumberFormat(pNumberFormatObj:NumberFormat io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the receiver to the specified
//				NumberFormat.
//
// Parameters:	pNumberFormatObj - The NumberFormat to update.
//
// Returns:		The NumberFormat as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pNumberFormatObj.decimalPlaces		:=	self.decimalPlaces;
	pNumberFormatObj.decimalSeparator	:=	self.decimalSeparator;
	pNumberFormatObj.groupings			:=	self.groupings;
	pNumberFormatObj.negativeFormat		:=	self.negativeFormat;
	pNumberFormatObj.negativeSign		:=	self.negativeSign;
	pNumberFormatObj.positiveSign		:=	self.positiveSign;
	pNumberFormatObj.showLeadingZeros	:=	self.showLeadingZeros;
	pNumberFormatObj.thousandSeparator	:=	self.thousandSeparator;
end;</source>
        <Parameter name="pNumberFormatObj" type="NumberFormat" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6b530f8c-bfe4-4bda-a146-67044c7ad590">
        <updating/>
        <source>updateMe(pNumberFormatObj:NumberFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified NumberFormat to
//				the receiver.
//
// Parameters:	pNumberFormatObj - The NumberFormat, who's property values to copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.decimalPlaces		:=	pNumberFormatObj.decimalPlaces;
	self.decimalSeparator	:=	pNumberFormatObj.decimalSeparator;
	self.groupings			:=	pNumberFormatObj.groupings;
	self.negativeFormat		:=	pNumberFormatObj.negativeFormat;
	self.negativeSign		:=	pNumberFormatObj.negativeSign;
	self.positiveSign		:=	pNumberFormatObj.positiveSign;
	self.showLeadingZeros	:=	pNumberFormatObj.showLeadingZeros;
	self.thousandSeparator	:=	pNumberFormatObj.thousandSeparator;
end;</source>
        <Parameter name="pNumberFormatObj" type="NumberFormat"/>
    </JadeMethod>
</Class>
