    <JadeMethod name="clickShowAllStatuses" id="876f6a93-1481-41fd-b49d-dfb436662ef5">
        <updating/>
        <source>clickShowAllStatuses() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
21 Jun 2018	jlgndl1	TFS 39216	Initial creation
09 Aug 2019	jlgka1 	TFS 45921	PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
============================================================================*/

vars

	newValue : Boolean;
	voyageProcess : CM_VoyageProcess;
	currentStatus : CM_VoyageStatus;
	status : CM_VoyageStatus;
	statusId : Integer;
begin

	newValue := self.chkAllStatus.value;
	
	voyageProcess := self.cmbProcess.listObject.CM_VoyageProcess;
	if voyageProcess = null or voyageProcess.isDefaultProcessJMT then
		return;
	endif;
	currentStatus := self.cmbStatus.listObject.CM_VoyageStatus;
	if currentStatus &lt;&gt; null then
		statusId:= currentStatus.id;
	endif;
	self.initComboVoyageStatus(voyageProcess,statusId);
	self.checkandsetCmbStatus(voyageProcess, statusId);

end;</source>
    </JadeMethod>
