    <JadeMethod name="cmbOperator_gotFocus" id="727ea403-2114-4c3f-bc85-68bdcfae7a35">
        <controlMethod name="CMUI_ComboBoxObject::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_gotFocus(combobox: CMUI_ComboOperator input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 February 2007	cnwer1	Initial creation - PAR#12416

*/
vars
	tbl : CM_EntryTable;
	tmpVoyage : CM_Voyage;
	tmpOperator : CM_Operator;
begin
	if CM_EntryTable.hasInstance(combobox.parent) then
		tbl := self.getTableForRow(ETRow_MyVoyage);
		if tbl &lt;&gt; null and not tbl.isRowVisible(ETRow_MyVoyage) then
			return;
		endif;
		tmpOperator:=combobox.listObject.CM_Operator;
		tmpVoyage	:= cmbVoyage.listObject.CM_Voyage;
		
		if tmpVoyage = null then
			if combobox.getCollection = app.myRoot.allOperators then
				return;
			endif;
		else
			//Allows for the case of null voyage not having any operators
			if combobox.getCollection = tmpVoyage.allOperators then
				return;
			endif;
		endif;
		
		combobox.resetCollectionForVoyage(tmpVoyage);	
	
	else
		return;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="CMUI_ComboOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_lostFocus" id="6bc74928-d74d-449e-82a3-7b9fc2e93ef9">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	obj			: Object;
	operator 	: CM_Operator;
	opTerm 		: CM_OperatorTerminal;
	commodity 	: CM_Commodity;
	cgTypeCntns,
	cgType		: CM_CargoType; //02/10/2025	navkc1 JIRA 36144 
	pxyTi 		: CM_TrackedItem; //02/10/2025	navkc1 JIRA 36144 
begin
	if not CM_EntryTable.hasInstance(combobox.parent) then
		return;
	endif;
	
	//lost focus after cancel
	if self.myProxyObject  =  null then
		return;
	endif;
	
	pxyTi := self.myProxyObject.CM_TrackedItem; //02/10/2025	navkc1 JIRA 36144 
	
	operator := combobox.listObject.CM_Operator;
	if self.myProxyObject.CM_TrackedItem.myOperator = operator then
		 return;
	endif;
	
	
	self.myProxyObject.CM_TrackedItem.setMyOperator(operator);
	
	tbl := combobox.parent.CM_EntryTable;
	obj := self.cmbMTGrade.myObject;	
	self.cmbMTGrade.setObjectAndOperator(obj, operator, null);
	tbl.setValueByControlName(combobox.name, combobox.text);
	combobox.doChangedCompareForEntryTable();
	
	//par 17383 cnwjo3
	
	cgTypeCntns := pxyTi.getCargoTypeForContents();
	
	if pxyTi.isContainer() and cgTypeCntns &lt;&gt; null then //02/10/2025	navkc1 JIRA 36144 Rotabox
		cgType := cgTypeCntns;
	else
		cgType := self.myProxyObject.CM_TrackedItem.myCargoType;
	endif;
	
	//self.cmbProduct.setCargoType(self.myProxyObject.CM_TrackedItem.myCargoType);
	self.cmbProduct.setCargoType(cgType);
	self.cmbProduct.setOperator(operator);
	self.cmbProduct.setObject(self.cmbProduct.listObject.CM_Product);
	
	//epr TFS 3581 8/3/17
	commodity:= self.cmbCommodity.listObject.CM_Commodity;
	if commodity &lt;&gt; null and commodity.hasTemp then	
		if operator &lt;&gt; null then
			opTerm:=operator.allOperatorTerminals[self.myTerminal];
		endif;
		
		if opTerm &lt;&gt; null then
			tbl:= self.getTableForRow(ETRow_HasExternalMonitoring);
			if tbl &lt;&gt; null then
				tbl.setValueByName(ETRow_HasExternalMonitoring,opTerm.isExternallyMonitored);
			endif;
		endif;
	endif;
	
	self.loadInvoiceContractId();  // ### TFS BUG 57237 24MAR2023 NAVAB1
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
