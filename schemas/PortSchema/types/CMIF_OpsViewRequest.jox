    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myObject" id="91fc4e51-2195-413e-9282-8bf2882529fa">
        <embedded/>
        <type name="Object"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="31953c9a-6596-4577-a012-458dba12121a">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <PrimAttribute name="oid" id="e169f94a-c52a-4006-8862-b6ef83fe84d7">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="updateAction" id="b2cf71fe-cb66-4386-8398-326c968cea66">
        <embedded/>
        <type name="Character"/>
    </PrimAttribute>
    <PrimAttribute name="updateTimeStamp" id="745df652-88c0-4f44-af45-b62858f2f563">
        <embedded/>
