    <JadeMethod name="removeDummyProperty" id="994394f0-1bc6-4983-b9d0-90259f95a185">
        <source>removeDummyProperty(pListboxObj:CnEcListBox input; pListIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Removes a dummy property child node from the listbox tree.
//
// Parameters:	pListboxObj - The listbox to remove the child node from.
//				pListIndex - The item index of the child node to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pListboxObj.itemText[pListIndex] = self.DUMMY_OBJECT then
		pListboxObj.removeItem(pListIndex);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox" usage="input"/>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resize" id="a49037af-8ade-4e47-8b58-aebf42d9a5a0">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	fldInspector.move(1, 1, (self.width - 9), (staStatus.top - 4));
	basSplitterMain.move(3, 3, (shtInspector.width - 6), (shtInspector.height - 6));
	basSplitterMain.cnEcResizeContents();
	basStackSplit.move(3, 3, (shtCallStack.width - 6), (shtCallStack.height - 6));
	basStackSplit.cnEcResizeContents();
//	tblCallStack.move(3, 3, (shtCallStack.width - 6), (shtCallStack.height - 6));
	lblOid.move(0, 0, lblOid.width, lblOid.height);
	lblEdition.move((lblOid.left + lblOid.width + 3), 0, lblEdition.width, lblEdition.height);
	lblType.move((lblEdition.left + lblEdition.width + 3), 0, lblType.width, lblType.height);
	lblSize.move((lblType.left + lblType.width + 3), 0, lblSize.width, lblSize.height);
	lblState.move((lblSize.left + lblSize.width + 3), 0, lblState.width, lblState.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="selectedPropertyOptions" id="0522f9d1-b22b-4817-bdd0-e614e82ddbe7">
        <source>selectedPropertyOptions() protected;
// -----------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Enables menus and options based upon the currently selected
//				object property.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	listboxObj	: CnEcListBox;
	listIndex	: Integer;
	propertyObj	: Property;
	targetObj	: Object;
	
begin
	listboxObj	:=	lstProperties;
	listIndex	:=	listboxObj.listIndex;
	
	if listIndex = CNEC_NULL_INDEX then
		mnuListboxInspect.enabled	:=	false;
		mnuTableInspect.enabled		:=	false;
	else
		if listIndex = 1 then
			mnuListboxInspect.enabled		:=	true;
			mnuListboxInsertNode.enabled	:=	false;
			mnuListboxInsertPath.enabled	:=	false;
			mnuTableInspect.enabled			:=	true;
		else
			mnuListboxInsertNode.enabled	:=	true;
			mnuListboxInsertPath.enabled	:=	true;
			propertyObj	:=	listboxObj.itemObject[listIndex].Property;
			
			if propertyObj = null then
				mnuListboxInspect.enabled		:=	false;
				mnuListboxInsertNode.enabled	:=	false;
				mnuListboxInsertPath.enabled	:=	false;
				mnuTableInspect.enabled			:=	false;
			elseif propertyObj.cnEcIsPrimitive() then
				mnuListboxInspect.enabled		:=	false;
				mnuTableInspect.enabled			:=	false;
			else
				targetObj	:=	self.getSourceObject(listboxObj, listIndex);
				
				if targetObj = null then
					mnuListboxInspect.enabled	:=	false;
					mnuTableInspect.enabled		:=	false;
				else
					mnuListboxInspect.enabled	:=	true;
					mnuTableInspect.enabled		:=	true;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObject" id="a786af57-a8ca-43ac-8a09-a2872f6ca1c9">
        <updating/>
        <source>setObject(pTargetObj:Object) updating;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Sets a reference to the object to be inspected, and sets up the
//				basic details about that object in the various labels etc.
//
// Parameters:	pTargetObj - The object to be inspected.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	classObj	: Class;
	objectSize	: Integer;
	blobCount	: Integer;
	
begin
	if pTargetObj = null then
		lblEdition.caption	:=	"N/A";
		lblType.caption		:=	"N/A";
		lblSize.caption		:=	"N/A";
	
	else
		self.resynchObjectAndSetEdition(pTargetObj);

		self.aMyObject		:=	pTargetObj;
		classObj			:=	pTargetObj.class();
		lblOid.caption		:=	" OID: " &amp; pTargetObj.getOidString() &amp; " ";
		lblEdition.caption	:=	" Edition: " &amp; self.aObjectEdition.String &amp; " ";
		
		if pTargetObj.isTransient() then
			lblType.caption	:=	" Transient ";
		else
			lblType.caption	:=	" Persistent ";
		endif;
		
		classObj.cnEcGetObjectSize(objectSize, blobCount);
		lblSize.caption		:=	" " &amp; objectSize.String &amp; " bytes ";
		
		self.loadProperties();
		self.initializeValuesTable();
	endif;
end;</source>
        <Parameter name="pTargetObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showModal" id="80898169-eba8-482e-a40e-b11df17a08d7">
        <updating/>
        <source>showModal(): Integer updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aIsShowCallStack	:=	true;
	return inheritMethod();
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startTimer" id="c40bda20-c910-4c25-8348-1cef6e32d061">
        <source>startTimer() protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Start the timer for blinking the "in transaction state" label.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	timerOption		: Integer;
	timeRemaining	: Integer;
	
begin
	self.stopTimer();

	beginTimer(500, Timer_Continuous, self.BLINK_TIMER);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="stopTimer" id="7cd68934-a766-49e0-ba49-22f872b227bc">
        <source>stopTimer() protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Stop the timer for blinking the "in transaction state" label.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	timerOption		: Integer;
	timeRemaining	: Integer;
	
begin
	if self.getTimerStatus(self.BLINK_TIMER, timerOption, timeRemaining) then
		endTimer(self.BLINK_TIMER);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e4e105ef-44de-4a7d-ade2-54da7cbd449a">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Used to trap changes to the state of the object being inspected,
//				and to alert the user of those changes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	userResponse	: Integer;
	userMessage		: String;
	
begin
	if eventType = Object_Update_Event then
		userMessage	:=	"This object has just been updated - do you wish to refresh the inspector ?" &amp;
						CrLf &amp; CrLf &amp;
						"Click 'Yes' to refresh the inspector, 'No' to ignore the update," &amp;
						" or 'Cancel' to close the inspector.";
		
		userResponse	:=	app.msgBox(	userMessage,
										self.INSPECTOR_NAME,
										MsgBox_Question_Mark_Icon + MsgBox_Yes_No_Cancel);
		
		if userResponse = MsgBox_Return_Yes then
			self.setObject(theObject);
			self.doFormLoad();
			
		elseif userResponse = MsgBox_Return_Cancel then
			unloadForm();
			
		endif;

	elseif eventType = Object_Delete_Event then
		app.msgBox(	"This object has just been deleted - the inspector will be closed.",
					self.INSPECTOR_NAME,
					-30);
					
		unloadForm();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCallStack_click" id="47c8a5a0-90c1-4568-aace-3f35a9e8b386">
