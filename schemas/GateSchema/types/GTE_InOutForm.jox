    <JadeMethod name="tblMain_change" id="1daa38a2-d099-4f67-8ea4-68fe7ed03766">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_change(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet		: GTE_Sheet;
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: GTE_ComboBox;
	code		: String;
	tmpRow		: Integer;
	cargoType	: CM_CargoBOLType;	
	
begin

	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	mainTbl := table;
	extraTbl := sheet.myTblExtra;
	code := sheet.myMenuAction.code;
	cmb := sheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;	
	cargoType := cmb.listObject.CM_CargoBOLType;

	if code = NavObj_GTE_In then
		self.myAssistant.GTE_Assistant.receival_tblMainExtraChange(mainTbl, mainTbl, extraTbl, cargoType, sheet.getISOType, self.myTerminal);
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMain_click" id="2376aa53-59a1-4bf2-98e2-b9f10762d7d8">
