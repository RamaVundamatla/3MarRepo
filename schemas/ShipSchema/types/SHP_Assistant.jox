    <JadeMethod name="showAllocateRTQsScreen" id="1a2dfe72-f773-42b2-b668-4e9c3f605026">
        <source>showAllocateRTQsScreen(_voyage: CM_Voyage) : SHP_AllocateHoldsToRTQs;
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/
vars
	allocQs : SHP_AllocateHoldsToRTQs;
begin

	allocQs := app.loadForm(SHP_AllocateHoldsToRTQs, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_AllocateHoldsToRTQs;
	if allocQs = null then
		return null;
	endif;	
		
	allocQs.initialiseWithObject(_voyage);
	
	allocQs.centreWindow();
	allocQs.showModal();
	
	return allocQs;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="SHP_AllocateHoldsToRTQs"/>
