    <JadeMethod name="numberingDirectionToString" id="de4a02a8-20cc-4f13-a346-3bc7fd5eecfe">
        <source>numberingDirectionToString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	ccms 1018

*/

vars
	leftLabel,
	rightLabel,
	direction 	: String;
begin
	
	leftLabel := self.myRoRoLaneArea.leftLabel;
	rightLabel := self.myRoRoLaneArea.rightLabel;

	if self.numberingDirection = self.NUMBERING_DIRECTION_NONE then
	elseif self.numberingDirection = self.NUMBERING_DIRECTION_L_TO_R then
		direction := self.myRoRoLaneArea.getLeftToRightString(leftLabel, rightLabel);
	elseif self.numberingDirection = self.NUMBERING_DIRECTION_R_TO_L then
		direction := self.myRoRoLaneArea.getRightToLeftString(leftLabel, rightLabel);
	endif;
	return direction;
epilog 

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
