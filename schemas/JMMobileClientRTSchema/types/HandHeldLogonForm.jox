    <JadeMethod name="doShowCar" id="c45abe44-895e-496b-8b30-bffffb8520e0">
        <updating/>
        <source>doShowCar() updating;
// ---------------------------------------------------------------------------
// Created:		25 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	frm : Form;
begin
	app.createHandHeldCarGUIAgent();
	app.myHandHeldCarGuiAgent.myHandHeldCarAgent.setForLogon(null,
															app.myHandHeldLogonGuiAgent.myHandHeldAgent.myRTDevice,
															app.myHandHeldLogonGuiAgent.myHandHeldAgent.myTerminal,
															app.myHandHeldLogonGuiAgent.myHandHeldAgent.user);

	create frm as app.myHandHeldCarGuiAgent.getMainForm() transient; 
	frm.HandHeldShipLanderCarForm.doAutoTab := false;
	frm.show();
	
	self.unloadForm;
end;</source>
    </JadeMethod>
