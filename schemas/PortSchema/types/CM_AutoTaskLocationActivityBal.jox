    <JadeMethod name="getValueForRow" id="267b786a-84d0-495b-a510-d9f88041ee5f">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if _rowName = ETRow_RecalculateOnly then
		return recalculateOnly;
	else
		return inheritMethod(_rowName, _obj);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
