        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteWord" id="d8bb61df-774e-4470-bc5e-4e4ce7b0d0ff">
        <source>deleteWord() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord			: JSSWord;
	errorMessage	: String;
	
begin
	theWord	:=	self.getSelectedWord();
	
	if theWord &lt;&gt; null then
		errorMessage	:=	self.aMyTA.trxDeleteWord(theWord);

		if errorMessage = null then
			self.selectWord();
		else
			app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="62c32cd8-5fa4-4c4c-9d36-3ede92a260e1">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allKeyCodes	: JSSKeyCodeArray;
	
begin
	inheritMethod();
		
	create self.aMyTA transient;	// deleted in closeForm();
	btnReplace.enabled		:=	false;
	btnDelete.enabled		:=	false;

	if process.isUsingThinClient then
		create allKeyCodes transient;
		self.registerFormKeys(allKeyCodes);
	endif;
	
	cmbDictionary.listCollection(app.jssMyRoot.allDictionaries, true, Collection.JSS_ORDER_COLLECTION);
	cmbDictionary.listIndex	:=	cmbDictionary.findString(1, JSSWordDictionary.DEFAULT_NAME);
	
	self.setStartRow(null);
epilog
	delete allKeyCodes;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="exportDictionary" id="24387694-6356-43c1-8a13-fa88c55479f1">
        <source>exportDictionary() protected;
// --------------------------------------------------------------------------------
// Purpose:		Exports all Spell Words to a disk file.
//
// Parameters:	None.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;
	theTargetFile	: File;
	
begin
	create theTargetFile transient;
	
	if theTargetFile.jssSetOpenName(false, false, null) then
		app.mousePointer	:=	Busy;
		theDictionary		:=	cmbDictionary.listObject.JSSWordDictionary;
		theDictionary.bulkExport(theTargetFile);
	endif;
epilog
	delete theTargetFile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedWord" id="5332b878-5c8d-446f-ac7e-7f96414b61b7">
        <source>getSelectedWord():JSSWord protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord			: JSSWord;
	theTable		: Table;
	theTableRow		: JadeTableRow;
	currentRow		: Integer;
	numberOfRows	: Integer;
	fixedRows		: Integer;
	
begin
	theTable		:=	tblWords;
	numberOfRows	:=	theTable.rows;
	currentRow		:=	theTable.row;
	fixedRows		:=	theTable.fixedRows;
	
	if currentRow &gt; fixedRows and currentRow &lt;= numberOfRows then
		theTableRow	:=	theTable.accessRow(theTable.row);
		theWord		:=	theTableRow.itemObject.JSSWord;
	endif;
epilog
	return theWord;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSWord"/>
    </JadeMethod>
    <JadeMethod name="importDictionary" id="85eed68b-613f-4524-bec5-03c596ead7a9">
        <source>importDictionary() protected;
// --------------------------------------------------------------------------------
// Purpose:		Imports Spell Words from a disk file.
//
// Parameters:	None.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;
	theSourceFile	: File;
	
begin
	create theSourceFile transient;
	
	if theSourceFile.jssSetOpenName(true, false, null) then
		app.mousePointer	:=	Busy;
		theDictionary		:=	cmbDictionary.listObject.JSSWordDictionary;
		theDictionary.bulkLoad(theSourceFile);
	endif;
epilog
	delete theSourceFile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="replaceWord" id="c86043cd-5c63-4fad-938c-bf14ec3273b5">
        <source>replaceWord() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord				: JSSWord;
	replacementString	: String;
	
begin
	theWord				:=	self.getSelectedWord();
	replacementString	:=	txtEditWord.text.trimBlanks();
		
	if theWord &lt;&gt; null and replacementString &lt;&gt; null then
		self.aMyTA.trxUpdateWord(	theWord,
									theWord.edition,
									theWord.myDictionary,
									replacementString);
		self.selectWord();
	endif; 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="e62ee826-0339-4d2b-bbe0-86b7217d1e23">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isReleaseMouse	: Boolean;
	
begin
	if self.height &lt; self.MINIMUM_HEIGHT then
		isReleaseMouse	:=	true;
	endif;
	
	if self.width &lt; self.MINIMUM_WIDTH then
		isReleaseMouse	:=	true;
	endif;
	
	btnClose.move((self.width - btnClose.width - 18), (self.height - btnClose.height - 37), btnClose.width, btnClose.height);
	btnEditDict.move((btnClose.left - btnEditDict.width - 3), btnClose.top, btnEditDict.width, btnEditDict.height);
	btnImport.move(btnImport.left, btnClose.top, btnImport.width, btnImport.height);
	btnExport.move(btnExport.left, btnClose.top, btnExport.width, btnExport.height);
	fraWordRuler.move(fraWordRuler.left, (self.height - fraWordRuler.height - 71), (self.width - fraWordRuler.left - 18), fraWordRuler.height);
	btnDelete.move((self.width - btnDelete.width - 18), (self.height - btnDelete.height - 79), btnDelete.width, btnDelete.height);
	btnReplace.move((btnDelete.left - btnReplace.width - 3), btnDelete.top, btnReplace.width, btnReplace.height);
	btnAdd.move((btnReplace.left - btnAdd.width - 3), btnDelete.top, btnAdd.width, btnAdd.height);
	txtEditWord.move(txtEditWord.left, (self.height - txtEditWord.height - 107), (self.width - txtEditWord.left - 17), txtEditWord.height);
	lblEditWord.move(lblEditWord.left, (self.height - lblEditWord.height - 126), lblEditWord.width, lblEditWord.height);
	
	cmbDictionary.move(cmbDictionary.left, cmbDictionary.top, (self.width - cmbDictionary.left - 17), cmbDictionary.height);
	txtStartFrom.move(txtStartFrom.left, txtStartFrom.top, (self.width - txtStartFrom.left - 17), txtStartFrom.height);
	fraStartRuler.move(fraStartRuler.left, fraStartRuler.top, (self.width - fraStartRuler.left - 18), fraStartRuler.height);
	tblWords.move(tblWords.left, tblWords.top, (self.width - tblWords.left - 17), (self.height - tblWords.top - 154));
	lblWordCount.move((self.width - lblWordCount.width - 18), (tblWords.top + tblWords.height + 1), lblWordCount.width, lblWordCount.height);
	
	if isReleaseMouse then
		self.releaseMouse();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectWord" id="8b3ac036-62c5-4d58-8e1c-d79c01ca4455">
        <source>selectWord() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord		: JSSWord;
	
begin
	theWord	:=	self.getSelectedWord();

	if theWord = null then
		tblWords.clearAllSelected();
		txtEditWord.text	:=	null;
		btnReplace.enabled	:=	false;
		btnDelete.enabled	:=	false;
	else
		if global.isValidObject(theWord) then
			txtEditWord.text	:=	theWord.wordName;
			btnReplace.enabled	:=	true;
			btnDelete.enabled	:=	true;
		else
			txtEditWord.text	:=	null;
			btnReplace.enabled	:=	false;
			btnDelete.enabled	:=	false;
		endif;
	endif;
	
	txtStartFrom.text	:=	null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSpellCheckForm" id="9b269ec4-d2d5-45bd-9490-a8a9a3f8bae2">
        <updating/>
        <source>setSpellCheckForm(pTheSpellCheckForm:JSSSpellCheckForm) updating;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMySpellCheckForm	:=	pTheSpellCheckForm;
end;</source>
        <Parameter name="pTheSpellCheckForm" type="JSSSpellCheckForm"/>
    </JadeMethod>
    <JadeMethod name="setStartRow" id="30ac0618-7ca3-4034-a65d-07d157e17833">
        <source>setStartRow(pStartValue:String) protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	theDictionary	: JSSWordDictionary;
	theWord			: JSSWord;
	allWords		: JSSWordByNameDict;
	
begin
	theDictionary	:=	cmbDictionary.listObject.JSSWordDictionary;
	allWords		:=	theDictionary.allWords;
	theTable		:=	self.tblWords;
	
	theTable.clear();
	theTable.rows	:=	1;
	theTable.setCellText(1, 1, "Word" &amp; Tab &amp; "Metaphone" &amp; Tab &amp; "Soundex");
	theTable.partialTextIndication	:=	true;
	
	if pStartValue.trimBlanks() = null then
		theWord	:=	null;
	else
		theWord	:=	allWords.getAtKeyGeq(pStartValue.toLower());
	endif;
	
	theTable.displayCollection(allWords, true, Collection.JSS_ORDER_COLLECTION, theWord);
	txtEditWord.text	:=	null;
	self.setWordCount(allWords);
end;</source>
        <access>protected</access>
        <Parameter name="pStartValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setWordCount" id="fb622b8f-cf5b-4bb0-aade-fe5996ae53b5">
        <source>setWordCount(pAllWords:JSSWordByNameDict) protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordCount	: Integer;
	
begin
	wordCount				:=	pAllWords.size();
	lblWordCount.caption	:=	wordCount.userNumberFormat($JSS_NO_DECIMALS) &amp; self.WORD_COUNT;
end;</source>
        <access>protected</access>
        <Parameter name="pAllWords" type="JSSWordByNameDict"/>
    </JadeMethod>
    <JadeMethod name="tblWords_click" id="f745c10f-88f4-4f43-81f1-81d47e424fbe">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWords_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.selectWord();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblWords_displayRow" id="1301a59b-dd66-462d-a59b-aa71795205c6">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWords_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theWord		: JSSWord;
	
begin
	theWord	:=	obj.JSSWord;
	
	if theWord = null then
		return null;
	else
		return theWord.wordName &amp; Tab &amp; theWord.metaphoneName &amp; Tab &amp; theWord.soundexName;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblWords_keyUp" id="ee11638a-b07e-48f4-8b20-7300ebef53a7">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWords_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.jssSelectRow();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWords_mouseDown" id="e65148b0-2737-43d1-8fe1-faa73329bd0a">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWords_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.jssSelectRow();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWords_sysNotify" id="b1b51a7a-f3c3-4459-a92c-8ef8889b5c0b">
        <controlMethod name="Table::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWords_sysNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if theObject.isKindOf(JSSWordByNameDict) then
		self.setWordCount(theObject.JSSWordByNameDict);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtStartFrom_change" id="9a5d8cab-7d27-476b-935a-19a1f2a41fd8">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtStartFrom_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.setStartRow(textbox.jssString());
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="e642ec38-1ceb-4665-8bf2-2a01ed70ccc5">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.updateWordFromDictionary();
	delete self.aMyTA;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateWordFromDictionary" id="b6d497f2-5705-4dbd-bc82-e55e0f246d3b">
        <source>updateWordFromDictionary() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMySpellCheckForm &lt;&gt; null then
		if txtEditWord.text &lt;&gt; "" then
			self.aMySpellCheckForm.aWordFromDictionary	:=	txtEditWord.text;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
