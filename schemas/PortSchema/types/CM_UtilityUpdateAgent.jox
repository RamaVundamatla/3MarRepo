    <JadeMethod name="utlUpdateAutoplanTrackedItems" id="5f54c1c6-230d-467f-8114-9db3320637d2">
        <updating/>
        <source>utlUpdateAutoplanTrackedItems(params : CMIF_AutoplanParams; _passport : CM_Passport input) : String updating;
//--------------------------------------------------------------
//Created: May 2003 By: cnwgd1
//--------------------------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
//02 Apr 2024  navma1		ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
vars
	ti 			: CM_TrackedItem;
	alert		: CM_SystemAlert;
	obj			: CM_Object;
	job			: CM_Job;
	strMode,
	str			: String;
	term		: CM_Terminal;
	hadWarning	: Boolean;
	tiSet		: CM_TIArray;
	wle 		: CM_WorkListEntry;
	voyage		: CM_Voyage;
	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	create tiSet transient;
	term := _passport.myTerminal;

	if not params.allAlerts.isEmpty() then			// 27/04/2009 cnwar2 #19401, #19524, #19522
		foreach alert in params.allAlerts do		// autoplanning from Failed To Plan list, get job info off system alerts
			ti := alert.myTrackedItem;
			if ti = null then
				continue;
			endif;
						
			strMode := null;
			exclusiveLock(ti);
			
			if ti.isQueued() then //epr par 35597 30/1/15
				app.raiseCMException1(ERR_QUEUE_LC_EXISTS, ti.id, null, null);
			endif;
			
			obj := alert.getLinkedTo();
			if obj.isKindOf(CM_FailedToAutoplan) then
				job := obj.CM_FailedToAutoplan.myJob;
			else
				job := params.myJob;
			endif;
			
			ti.autoPlan(params.moveMode, job, params.myTerminalArea, null, _passport);
	
			if params.moveMode = QUEUE_MODE then
				if ti.myPrimaryQueuedLocation = null then
					hadWarning := true;
					tiSet.add(ti);
				else
					strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' has been successfully Queued to location ' &amp; ti.myPrimaryQueuedLocation.getFullId() &amp; CrLf;
				endif;
			elseif params.moveMode = PLANNING_MODE then
				if ti.myPrimaryPlannedLocation = null then
					if params.showWarningWhenNoPlan then // PAR 19450
						app.raiseCMWarning1(ERR_NO_AUTOPLAN, ti.id, null, null, ti);
					else
						strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' could not be auto planned ' &amp; CrLf;
						_passport.returnCode := ERR_NO_AUTOPLAN; // PAR 19450
					endif;
				else
					strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' has been successfully Planned to location ' &amp; ti.myPrimaryPlannedLocation.getFullId() &amp; CrLf;
				endif;
			endif;
	
			if _passport.noErrors then
				str := str &amp; strMode;
			endif;
		endforeach;
		
	else
		foreach ti in params.allTrackedItems do
			strMode := null;
			exclusiveLock(ti);

			
			// DVB changed 10/08/06
			if ti.isQueued() then //epr par 35597 30/1/15
				app.raiseCMException1(ERR_QUEUE_LC_EXISTS, ti.id, null, null);
			endif;
			
			// PAR 20357 this autoplan is now being called from the train graphic where the cargo will have individual job, so cannot set job on PARAMS in calling method
			job := params.myJob;
			if job = null and ti.myPrimaryActualLocation &lt;&gt; null then		// cnwdad1 29/09/2009.
				if ti.myPrimaryActualLocation.isWagon() then // no job and the source is a wagon target is the yard
					job := ti.jobRailReceive;
				
				//21 Aug 2018	NDL	TFS 39972 - Called from the Voyage Operations Form with no specifically associated WLE/JOB
				elseif params.isVoyageOps and ti.myPrimaryActualLocation.isVoyageController then
					wle := ti.getVoyageWLEUnactioned(false);
					
					//02.04.2024 navma1 #63302
					if wle = null then
						voyage := ti.myVoyage;
						// Use workOrde Wle to stop creating VoaygeWle
						if voyage &lt;&gt; null and voyage.myVoyageProcess &lt;&gt; null and 
							voyage.myVoyageProcess.isEUPDefaultProcess then
							wle := ti.getIncompleteReceiveWle();
							
						endif;
					endif;
					//02.04.2024 navma1 #63302
					if wle &lt;&gt; null then
						// if there is a wle/job try and use it.
						job := wle.job;
					endif;
				endif;
			endif;
			
			ti.autoPlan(params.moveMode, job, params.myTerminalArea, params, _passport);// PAR 20357
	
			if params.moveMode = QUEUE_MODE then
				if ti.myPrimaryQueuedLocation = null then
					hadWarning := true;
					tiSet.add(ti);
				else
					strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' has been successfully Queued to location ' &amp; ti.myPrimaryQueuedLocation.getFullId() &amp; CrLf;
				endif;
			elseif params.moveMode = PLANNING_MODE then
				if ti.myPrimaryPlannedLocation = null then
					if params.showWarningWhenNoPlan then // PAR 19450
						app.raiseCMWarning1(ERR_NO_AUTOPLAN, ti.id, null, null, ti);
					else
						strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' could not be auto planned ' &amp; CrLf;
						_passport.returnCode := ERR_NO_AUTOPLAN; // PAR 19450
					endif;
				else
					strMode := app.getErrorString(TrackedItem) &amp; ' ' &amp; ti.id &amp; ' has been successfully Planned to location ' &amp; ti.myPrimaryPlannedLocation.getFullId() &amp; CrLf;
				endif;
			endif;
	
			if _passport.noErrors then
				//self.myUpdateAuditAgent.audUpdateGeneric(ti, false);
				str := str &amp; strMode;
			endif;
		endforeach;
	endif;
	
	if _passport.noErrors and hadWarning then
		foreach ti in tiSet do
			if params.showWarningWhenNoPlan then // PAR 19450
				app.raiseCMWarning1(ERR_NO_AUTOPLAN, ti.id, null, null, ti);
			endif;
		endforeach;
	endif;
		
		
	return str;
epilog
	delete tiSet;
end;</source>
        <Parameter name="params" type="CMIF_AutoplanParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateAutoplanTwin" id="a602648e-77c3-4841-9e34-e89ccfb6cb29">
        <updating/>
        <source>utlUpdateAutoplanTwin(_ti,
					  _twinTI : CM_TrackedItem input;
					  _job,
					  _twinJob : CM_Job;
					  _queueEntry,
					  _twinQueueEntry : CM_RTQueueEntry input;
					  _moveMode : Integer; 
					  _passport : CM_Passport input) updating;
					  
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Dec 2008	cnwer1	Initial creation
27 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Signature change to allow for twin lift Director tasks
18 Dec 2013	cnwer1	Par 33059 if twin planning for director tasks where request has a target specified use that terminal area
*/

vars
	foundLC,
	foundLCTwin		: CM_LocationsController;
	moveController	: CMIF_MoveController;
	wle,
	twinWLE 		: CM_WorkListEntry;
	task, twinTask: CM_RTQueueTask;
	terminalArea: CM_TerminalArea;
	request , twinRequest	: CM_Request;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	
	
	self.raiseExceptionIfNull(_ti, 'TrackedItem');
	_ti.validateForAutoplan();
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	self.raiseExceptionIfNull(_twinTI, 'TrackedItem');
	_twinTI.validateForAutoplan;
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	app.autoPlanAlertOverride(_passport.myTerminal);
	if _passport.noErrors then	
		// PAR 23114 have the two director tasks got the same target?
		if _queueEntry &lt;&gt; null and _twinQueueEntry &lt;&gt; null then
			task := _queueEntry.getDirectorOrPickupTask();
			twinTask := _twinQueueEntry.getDirectorOrPickupTask();
			if task &lt;&gt; null and task.taskType = TASK_DIRECTOR and
			   twinTask &lt;&gt; null  and twinTask.taskType = TASK_DIRECTOR then
				// PAR 23114 found the director tasks, now check the target
				if task.targetLocation &lt;&gt; null and twinTask.targetLocation = task.targetLocation then
					// The two tasks are going to same target
					if task.targetLocation.isGridLocation then
						// For gridded areas need to autoplan to a location in the target terminal area 
						terminalArea := task.targetLocation.myTerminalArea;
					else
						// No need to autoplan for Block stacks
						foundLC := task.targetLocation;
						foundLCTwin := task.targetLocation;
					endif;
				elseif task.targetLocation &lt;&gt; null and twinTask.targetLocation &lt;&gt; null then		//cnwrd1 par 25048 11.7.2011		
					if (task.targetLocation.isWagon and twinTask.targetLocation.isWagon )
					or ( task.targetLocation.isVehicle and twinTask.targetLocation.isVehicle )
					or ( task.targetLocation.isVoyageController and twinTask.targetLocation.isVoyageController )	//22 Apr 2020	NDL	TFS 49174/48549
					then
						//going to road or rail. this should be ok
						foundLC := task.targetLocation;
						foundLCTwin := twinTask.targetLocation;
					endif;
						
				elseif task.targetLocationId = "IMV" and twinTask.targetLocationId = "IMV" then	//21 Apr 2020	NDL	TFS 49174/48549
					request := _queueEntry.getMyRequest;
					twinRequest:=_twinQueueEntry.getMyRequest;
					if request &lt;&gt; null and request.isKindOf(CM_SlotRequest) and twinRequest &lt;&gt; null and twinRequest.isKindOf(CM_SlotRequest) then
						if request.CM_SlotRequest.isLoad then
							//We are a twin lift director task going to ship via an IMV. The IMV is yet to be selected by the user. 
							foundLC := request.CM_SlotRequest.mySlotController;
							foundLCTwin := twinRequest.CM_SlotRequest.mySlotController;
						endif;
					endif;
				endif;
					
				//epr par 33059 18/12/13
				if foundLC = null or foundLCTwin = null and terminalArea = null  then			
					request := _queueEntry.getMyRequest;
					twinRequest:=_twinQueueEntry.getMyRequest;
					if request &lt;&gt; null and request = twinRequest and request.isKindOf(CM_YardRequest) then
						terminalArea:=request.CM_YardRequest.myTargetTA;
					endif;
				endif;
			endif;
	    endif;
	
		if foundLC = null or foundLCTwin = null then			
			app.myYAAgent.autoPlanTwinTi(_passport.myTerminal, terminalArea,  _ti, _twinTI);
			foundLC:= app.myYAAgent.myCMIFYAAutoPlan.allFoundLCs.first;
			foundLCTwin:=  app.myYAAgent.myLinkedYAAutoPlan.allFoundLCs.first;
			
		else	// 13 Sep 2011	NDL	Par 28112
			// We must be going to a block stack or rail or road.
			// Still need to do the twin lift validation done as part of the 'autoPlanTwinTi' immediately above
			if not app.myYAAgent.validateTwins( _ti, _twinTI ) then
				return;
			endif;
		endif;

		if foundLC &lt;&gt; null and foundLCTwin &lt;&gt; null then
			create moveController transient;
			moveController.hazardSegregationValidated := true;//because it's considered when getting a valid autoplan location
			moveController.setMyTrackedItem(_ti);
			moveController.setMyToPrimaryLocation(foundLC);
			moveController.setMoveMode(_moveMode);
			moveController.setJobForMove(_job);
			wle:= _job.getWLEForTI(_ti);
			moveController.setMyWorkListEntry(wle);
			if wle &lt;&gt; null then
				moveController.isRehandleMove := wle.isRehandle;
			endif;
			// For Queue and Planned moves
			moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
			
			// PAR #18743 - Handle twin Director moves
			if _queueEntry &lt;&gt; null and _queueEntry.isOriginalDirector then
				moveController.myRTQueueEntry := _queueEntry;
				moveController.isSystemMove := true;
				moveController.isDirectorMove := true;
			else
				moveController.isForcedMove := true; 
			endif;
		
			self.utlUpdateMoveTrackedItem(moveController, _passport);
			if  _passport.hasErrors then
				return;
			endif;
			
			if app.myYAAgent &lt;&gt; null then
				_ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
			endif;
			
			// Now process twin TI
			delete moveController;
			create moveController transient;
			moveController.hazardSegregationValidated := true;//because it's considered when getting a valid autoplan location
			moveController.setMyTrackedItem(_twinTI);
			moveController.setMyToPrimaryLocation(foundLCTwin);
			moveController.setMoveMode(_moveMode);
			moveController.setJobForMove(_twinJob);
			twinWLE:=_twinJob.getWLEForTI(_twinTI);
			moveController.setMyWorkListEntry(twinWLE);
			if twinWLE &lt;&gt; null then
				moveController.isRehandleMove := twinWLE.isRehandle;
			endif;

			moveController.setMyOriginatingLocation(_twinTI.myPrimaryActualLocation);
			
			// PAR #18743 - Handle twin Director moves
			if _twinQueueEntry &lt;&gt; null and _twinQueueEntry.isOriginalDirector then
				moveController.myRTQueueEntry := _twinQueueEntry;
				moveController.isSystemMove := true;
				moveController.isDirectorMove := true;
			else
				moveController.isForcedMove := true; 
			endif;
			
			self.utlUpdateMoveTrackedItem(moveController, _passport);
			if  _passport.hasErrors then
				return;
			endif;
			
			if app.myYAAgent &lt;&gt; null then
				_twinTI.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
			endif;
		endif;
	endif;
	
epilog
	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_twinJob" type="CM_Job"/>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_twinQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateAvailabilityGrade" id="9ffcad13-ab0e-493c-b76b-803cd85ea217">
        <updating/>
        <source>utlUpdateAvailabilityGrade(pProxyAvailabilityGrade:CM_MTGrade; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realAvailabilityGrade:CM_MTGrade;
	expectedEdition:Integer;
	codeChanged : Boolean;	//29 July 2011	NDL	Par 27890
	eventStr : String;	//29 July 2011	NDL	Par 27890
	
begin

	self.initialiseActivity();

	pProxyAvailabilityGrade.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyAvailabilityGrade.pxyGetRealObjectAndEdition(realAvailabilityGrade, expectedEdition);
	
	if realAvailabilityGrade = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MTGrade.name, null, null);
		return;
	endif;

	app.myValUA.valAvailabilityGrade(realAvailabilityGrade, pProxyAvailabilityGrade);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realAvailabilityGrade);

	if _passport.noErrors and realAvailabilityGrade.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'AvailabilityGrade', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realAvailabilityGrade, true);
	endif;
	
	if _passport.noErrors then
		//29 July 2011	NDL	Par 27890
		if realAvailabilityGrade.colour &lt;&gt; pProxyAvailabilityGrade.colour then
			codeChanged := true;
		endif;
		realAvailabilityGrade.setForUpdate(pProxyAvailabilityGrade);
	endif;

	if _passport.noErrors then
		//29 July 2011	NDL	Par 27890
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realAvailabilityGrade.code.String  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realAvailabilityGrade.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realAvailabilityGrade.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realAvailabilityGrade, false);
	endif;

end;</source>
        <Parameter name="pProxyAvailabilityGrade" type="CM_MTGrade"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateAvailabilityGradeCode" id="8cc9868c-983d-4759-9427-88a8935825d7">
        <source>utlUpdateAvailabilityGradeCode(_proxyMTGradeCode  : CM_MTGradeCode; _passport : CM_Passport input);

vars

	mtGradeCode : CM_MTGradeCode;

begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_proxyMTGradeCode, 'Availability Grade');
	
	app.myValUA.valAvailabilityGradeCode(_proxyMTGradeCode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	mtGradeCode := _proxyMTGradeCode.pxyGetRealObject();
	
	mtGradeCode.setForUpdate(_proxyMTGradeCode);

end;</source>
        <Parameter name="_proxyMTGradeCode" type="CM_MTGradeCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
