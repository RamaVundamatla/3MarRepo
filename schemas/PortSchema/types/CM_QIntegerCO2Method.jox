    <JadeMethod name="translateToDisplayValue" id="2a000e2f-c079-4d02-a067-11be71314ce1">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	if _value.Integer &lt;&gt; NULL_INTEGER then
		return _value.String;
	endif;
	
	return null;
epilog

end;</source>
