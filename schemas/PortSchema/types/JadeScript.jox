    <JadeMethod name="rel831_par34824" id="7007861b-2caf-4b7d-93a8-95eb006f0616">
        <source>rel831_par34824();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28/08/2014	cnwdap1		Initial creation PAR #34824
//
vars
	reefer, delReefer : CM_TIReeferProperties;
	temp : CM_TempReading;
	ti : CM_TrackedItem;

begin
	beginTransaction;
	foreach reefer in CM_TIReeferProperties.instances discreteLock do
		if reefer.myParent = null then
			temp := reefer.allTemperatureReadings.last;
			if temp &lt;&gt; null and temp.myTemperatureReading &lt;&gt; null and temp.myTemperatureReading.myTrackedItem &lt;&gt; null then
				ti := temp.myTemperatureReading.myTrackedItem;
				if ti.myReeferProperties &lt;&gt; null then
					delReefer := ti.myReeferProperties;
					ti.setPropertyValue(CM_TrackedItem::myReeferProperties.name, null);
					delReefer.erase(NORMAL_ERASE);
				endif;
				reefer.setMyParent(ti);
			endif;
			if temp = null then
				delete reefer;
			endif;
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
