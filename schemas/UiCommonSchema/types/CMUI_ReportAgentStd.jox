    <JadeMethod name="getSelectedPackAreas" id="46d379f4-8f12-4a6b-88d8-9790eab92210">
        <source>getSelectedPackAreas(_packAreas: CM_TerminalAreaSet input);
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	area	: Object;
begin
	if _packAreas = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_packAreas', null, null);
		return;
	endif;
	
	foreach area in self.myLstTblPackArea.allSelectedObjects do
		_packAreas.add(area.CM_TerminalArea);
	endforeach;

end;</source>
