    <JadeMethod name="cnwdad1_JadeSkins_Unload" id="ba0ac5a0-6071-485b-a2f1-0f1afc9e5117">
        <source>cnwdad1_JadeSkins_Unload();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jadeSkinObj		: JadeSkin;
	fileObj			: File;
	propertyFileObj	: File;
	fileDirectory	: String;
	propertyColl	: PropertyColl;
	propertyObj		: Property;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	fileDirectory	:=	"c:\temp\TpSkins";
	jadeSkinObj		:=	JadeSkin.firstInstance;

	if jadeSkinObj = null then
		write "JadeSkin is null.";
		return;
	endif;

	create fileObj transient;
	create propertyFileObj transient;

	fileObj.mode				:=	File.Mode_Output;
	fileObj.kind				:=	File.Kind_Binary;
	propertyColl				:=	JadeSkin.allProperties;

	propertyFileObj.mode		:=	File.Mode_Output;
	propertyFileObj.fileName	:=	fileDirectory &amp; "\JadeSkin.dat";
	propertyFileObj.open;

	foreach propertyObj in propertyColl do
		if propertyObj.name[1:3] = "img" then
			fileObj.fileName	:=	fileDirectory &amp; "\" &amp; propertyObj.name &amp; ".png";
			fileObj.open();
			fileObj.writeBinary(jadeSkinObj.getPropertyValue(propertyObj.name).Binary);
			fileObj.close();
		elseif propertyObj.name[1:1] &lt;&gt; "_" then
			propertyFileObj.writeLine(	propertyObj.name &amp; Tab &amp;
										jadeSkinObj.getPropertyValue(propertyObj.name).String);
		endif;
	endforeach;

	propertyFileObj.close();
epilog
	delete fileObj;
	delete propertyFileObj;
	delete propertyColl;
	
	write "Skins Unload completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
