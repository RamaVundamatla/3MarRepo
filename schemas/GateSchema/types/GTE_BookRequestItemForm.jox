    <JadeMethod name="txtMaxRel_change" id="a7e6bcb6-c453-46e1-a548-27c57b6e5576">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtMaxRel_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		8 September 2009 by cnwjo3
//
vars

begin

	if textbox.text.Integer &lt; 1 then
		self.chkIsClean.enabled := false;
		self.chkHeavy.enabled := false;
		self.chkPreTripInspec.enabled := false;
		self.lblAvaliabilityG.enabled := false;
		self.cmbAvalGrade.enabled := false;
	else
		self.chkIsClean.enabled := true;
		self.chkHeavy.enabled := true;
		self.chkPreTripInspec.enabled := true;
		self.lblAvaliabilityG.enabled := true;
		self.cmbAvalGrade.enabled := true;
	//	self.chkIsClean.setFocus(); //cnwrd1 par 20919 9/10/09
		self.focusOnIsClean := true;
	endif;
	
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
