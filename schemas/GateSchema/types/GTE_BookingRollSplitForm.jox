    <JadeMethod name="checkForOnShipContainers" id="76f5e5c1-9eb5-46a5-8c7c-284bce8c2b29">
        <source>checkForOnShipContainers(_tis : CM_TISet; _passport : CM_Passport input);

vars
	ti	: CM_TrackedItem;
begin
	foreach ti in _tis do
		if ti.isOnShip then
			app.raiseCMException1(Error_Container_OnShip, ti.id, null, null);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBooking_click" id="23c6ac0c-dae6-4152-ba16-c846d5ff1d83">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBooking_click(combobox: ComboBox input) updating;

vars
	port	: CM_Port;
	index	: Integer;
begin
	if cmbBooking.listObject &lt;&gt; null then
		port	:= app.myRoot.allPorts[cmbBooking.listObject.CM_BookingRef.dischargePort];
		if port &lt;&gt; null then
			index	:= cmbDischargePort.findObject(port);
			if index &lt;&gt; -1 then
				cmbDischargePort.listIndex	:= index;
				cmbDischargePort.enabled	:= false;
			else
				cmbDischargePort.enabled	:= true;
			endif;
		endif;
	endif;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBooking_displayEntry" id="8d4328ff-2d96-4373-bc9c-33162f2258c9">
