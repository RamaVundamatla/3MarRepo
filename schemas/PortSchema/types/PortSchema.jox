    </JadeMethod>
    <JadeMethod name="listLocks" id="13075995-2e14-42ea-95dd-74d7eeaea7b2">
        <source>listLocks();
//
//21 February 2018	jlgrs1	Initial creation
//
constants
	MaxLocks		= 100000;
vars
	locks			: LockArray;
	aLock			: Lock;
	lockCounts		: IntegerArray;
	dict			: DynaDictionary;
	type,
	duration,
	kind			: String;
	iter			: Iterator;
	count			: Integer;
begin
	create locks transient;
	system.getLocks(locks, MaxLocks);
	
	foreach aLock in locks do
		if aLock.type.Integer = Share_Lock then
			type := "Shared lock";
		elseif aLock.type.Integer = Exclusive_Lock then
			type := "Exclusive lock";
		elseif aLock.type.Integer = Reserve_Lock then
			type := "Reserve lock";
		elseif aLock.type.Integer = Update_Lock then
			type := "Update lock";
		else
			type := "Unknown";
		endif;

		if aLock.kind = Lock.Kind_Node then
			kind := "Node";
		elseif aLock.kind = Lock.Kind_Normal then
			kind := "Normal";
		elseif aLock.kind = Lock.Kind_Local then
			kind := "Local";
		else
			kind := "Unknown";
		endif;
		
		if aLock.duration.Integer = Transaction_Duration then
			duration := "Transaction";
		elseif aLock.duration.Integer = Session_Duration then
			duration := "Session";
		else
			duration := "Unknown";
		endif;
		
		lockCounts := dict[type, duration, kind].IntegerArray;
		if lockCounts = null then
			create lockCounts transient;
			lockCounts[1] := 1;
			dict.putAtKey(type, duration, kind, lockCounts);
		else
			lockCounts[1] := lockCounts[1] + 1;
		endif;
		
		count := count + 1;
	endforeach;
	
	write "Finished, total locks analysed = " &amp; count.String;
	
	iter := dict.createIterator();
	while iter.next(lockCounts) do
		dict.getIteratorKeys(type, duration, kind, iter);
		write type &amp; Tab &amp; duration &amp; Tab &amp; kind &amp; Tab &amp; lockCounts[1].String;
	endwhile;
epilog
	delete iter;
	if locks &lt;&gt; null then
		locks.purge();
		delete locks;
	endif;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadIcons" id="ed15ef13-55c0-49c9-8d2b-4f5ddb4084e2">
        <source>loadIcons();
