epilog

end;</source>
        <Parameter name="_slotDefnVoyage" type="CM_SlotDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="testPileColourHeightUnderDeck" id="3f4af82e-b923-439b-bc65-b2368ad7e79c">
        <source>testPileColourHeightUnderDeck(_prevSelectedCellsHeight : Real; _changeHighCubes : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwas3	Initial creation

*/
vars
	maxHeight,
	pileHeight : Real;
	maxHighCubesUD : Integer;
begin
	
	// Only validate under deck heights, on deck is not problem
	if self.ordinalDeck &lt;&gt; DeckUnderDeck then
		return;
	endif;
		
	if self.myBayVoyage = null then
		return;	
	endif;
	if self.mySlotDefnVoyage = null then
		return;	
	endif;
	
	if self.mySlotDefnVoyage.myCellDefinition = null then
		return;	
	endif;	
	
	maxHighCubesUD := self.mySlotDefnVoyage.myCellDefinition.maxNumHighCubesIfFull;
	
	if maxHighCubesUD &lt; 1 then
		return;
	endif;
	
	maxHeight := (maxHighCubesUD*HEIGHT_FULL_HIGH_CUBE); // The heigt of a high cube is 9.5ft
	
	//pileHeight := self.myBayVoyage.getCellPileColourHeight(self.ordinalDeck,self.ordinalCell) + _prevSelectedCellsHeight;//add the assumed height of the other selected cells
	pileHeight := self.myBayVoyage.getCellPileColourHeight(self.ordinalDeck,self.ordinalCell);//just the pile height of the existing high-cubes
	
	/*if not _changeHighCubes then						//if we're just adding colour coding
		if self.mySlotRequestLoad = null and _prevSelectedCellsHeight = 0 then
			pileHeight := pileHeight + HEIGHT_FULL_NORMAL;
		endif;
	endif;*///don't care about normal height cubes
	
	
	if pileHeight &gt; maxHeight or (_changeHighCubes and _prevSelectedCellsHeight &gt; 0 and pileHeight + HEIGHT_FULL_HIGH_CUBE &gt; maxHeight) then
	//if (pileHeight &gt; maxHeight and (pileHeight mod HEIGHT_FULL_NORMAL &lt;&gt; 0 and pileHeight div HEIGHT_FULL_NORMAL &lt;&gt; HEIGHT_FULL_HIGH_CUBE)) then		
		if _changeHighCubes then
			app.raiseCMWarning2(WarningHighCubeHeightExceeded,maxHighCubesUD.String, self.ident,null,null,null);
		//else
		//	app.raiseCMWarning4(WarnPileColourHeightExceeded, maxHeight.String, maxHighCubesUD.String, self.ident, pileHeight.String,null,null,null);
		endif;			
	endif;	
end;</source>
        <Parameter name="_prevSelectedCellsHeight" type="Real"/>
        <Parameter name="_changeHighCubes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testPileHeight" id="468450cf-b686-4754-8e27-8b9196eb58a2">
        <source>testPileHeight(_ti : CM_TrackedItem);

/*

Purpose:		Copy of 'testPileHeightUnderDeck' modified to handle above and
				below deck if the new attribute on CM_CellDefn is used.

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2010	cnwndl1	Initial creation	CCMS 1140 / Par 25127

*/

vars
	maxHeight,
	pileHeight : Real;
	maxHighCubesUD : Integer;
	cellDefn : CM_CellDefn;
	useOldWay : Boolean;
begin
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'trackedItem', null, null);
		return; 
	endif;
	
	if self.myBayVoyage = null then
		return;	
	endif;
	if self.mySlotDefnVoyage = null then
		return;	
	endif;
	
	if self.mySlotDefnVoyage.myCellDefinition = null then
		return;	
	endif;
	
	// Set the max height from new fields if possible, otherwise revert to the old method.
	if self.ordinalDeck = DeckOnDeck then
		cellDefn := self.myBayVoyage.allCellsOnDeckByOrdinal[self.ordinalCell];
	else
		cellDefn := self.myBayVoyage.allCellsUnderDeckByOrdinal[self.ordinalCell];
	endif;
	if cellDefn &lt;&gt; null then
		maxHeight := cellDefn.maxHeight;
	endif;
	useOldWay := ( maxHeight = 0 );
	
	
	if useOldWay then
		// Only validate under deck heights, on deck is not problem
		if self.ordinalDeck &lt;&gt; DeckUnderDeck then
			return;
		endif;
		
		maxHighCubesUD := self.mySlotDefnVoyage.myCellDefinition.maxNumHighCubesIfFull;
		
		if maxHighCubesUD &lt; 1 then
			return;
		endif;
		
	//	maxHeight := (maxHighCubesUD*HEIGHT_FULL_HIGH_CUBE); // The heigt of a high cube is 9.5ft
		
		//09 Nov 2010	NDL	Par 26194
		maxHeight := self.mySlotDefnVoyage.myCellDefinition.getTotalHeightAvailable();	// number of available slots X normal height
		maxHeight := maxHeight + (maxHighCubesUD *( HEIGHT_FULL_HIGH_CUBE - HEIGHT_FULL_NORMAL )); // add in the difference for the over heights...
	
		pileHeight := self.myBayVoyage.getCellPileHeight(self.ordinalDeck,self.ordinalCell, false);
		
		pileHeight := pileHeight + _ti.getActualHeight();	//Add in the height of the tracked item
		
	else
		pileHeight := self.myBayVoyage.getCellPileHeight(self.ordinalDeck,self.ordinalCell, true);
		// convert to metres.
		//feet * 12 (inches in a foot) / 39.37 (inches in a metre)
		pileHeight := pileHeight + ( _ti.getActualHeight() * 12 / 39.37 );	//Add in the height of the tracked item
		
	endif;
	
	if pileHeight.roundedTo(2) &gt; maxHeight.roundedTo(2) then
		//Warn user if max cell height has been exceeded
		if useOldWay then
			app.raiseCMWarning4(WarningPileHeightExceeded, maxHeight.String, maxHighCubesUD.String, self.ident, pileHeight.asStringJMTWithPrecision(2,false), null, null,self);	
		else
			app.raiseCMWarning3(WarningPileHeightExceed2, maxHeight.String, self.ident, pileHeight.asStringJMTWithPrecision(2,false), null, null,self);
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testPileHeightUnderDeck" id="11be62f1-462d-4275-b8e7-825fbdd1cd0f">
        <source>testPileHeightUnderDeck(_ti : CM_TrackedItem);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	maxHeight,
	pileHeight : Real;
	maxHighCubesUD : Integer;
begin
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'trackedItem', null, null);
		return; 
	endif;

	// Only validate under deck heights, on deck is not problem
	if self.ordinalDeck &lt;&gt; DeckUnderDeck then
		return;
	endif;
		
	if self.myBayVoyage = null then
		return;	
	endif;
	if self.mySlotDefnVoyage = null then
		return;	
	endif;
	
	if self.mySlotDefnVoyage.myCellDefinition = null then
		return;	
	endif;	
	
	maxHighCubesUD := self.mySlotDefnVoyage.myCellDefinition.maxNumHighCubesIfFull;
	
	if maxHighCubesUD &lt; 1 then
		return;
	endif;
	
	//maxHeight := (maxHighCubesUD*HEIGHT_FULL_HIGH_CUBE); // The heigt of a high cube is 9.5ft
	//09 Nov 2010	NDL	Par 26194
	maxHeight := self.mySlotDefnVoyage.myCellDefinition.getTotalHeightAvailable();	// number of available slots X normal height
	maxHeight := maxHeight + (maxHighCubesUD *( HEIGHT_FULL_HIGH_CUBE - HEIGHT_FULL_NORMAL )); // add in the difference for the over heights...
		
		
	pileHeight := self.myBayVoyage.getCellPileHeight(self.ordinalDeck,self.ordinalCell,false);
	
	pileHeight := pileHeight + _ti.getActualHeight();	//Add in the height of the tracked item
	
	if pileHeight &gt; maxHeight then
		//Warn user if max cell height has been exceeded
		app.raiseCMWarning4(WarningPileHeightExceeded, maxHeight.String, maxHighCubesUD.String, self.ident, pileHeight.String, null, null,self);	
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testPileWeight" id="5c4fa180-d5d0-4d24-af24-162b3383492e">
        <source>testPileWeight(_ti : CM_TrackedItem; _mode : Integer);
// ---------------------------------------------------------------------------
// Created:     7 May 2001 by cnwgd1
//
// Purpose:     This method determines the type of pile a container is being moved to onShip
//				and if the move will cause a weight overstow.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	18 Feb 02	DWQ	Hacked to reuturn a warning exception.
// ---------------------------------------------------------------------------

vars

	tiController : CM_SlotController;
	pileWeight : Decimal[14,4];
	maxPileWeight : Decimal[14,4];
	cellDefn : CM_CellDefn;
	useOldWay : Boolean;
	weight20s : Integer;
	weightOthers : Integer;
	addProposed : Boolean;
	bottomTiInCell : CM_TrackedItem;
	
begin

	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'trackedItem', null, null);
		return; //Abort
	endif;
	if self.myBayVoyage = null then
		return;	
	endif;
	if self.mySlotDefnVoyage = null then
		return;	
	endif;
	
	//03 Aug 2010	NDL	Par 25127 / CCMS 1140 - use new 'maxPileWeight20' and 40
	//									to set up max pile weight if its not zero.
	if self.ordinalDeck = DeckOnDeck then
		cellDefn := self.myBayVoyage.allCellsOnDeckByOrdinal[self.ordinalCell];
	else
		cellDefn := self.myBayVoyage.allCellsUnderDeckByOrdinal[self.ordinalCell];
	endif;
	if cellDefn &lt;&gt; null then
		bottomTiInCell := cellDefn.getBottomOfPileTI(_mode);
		if bottomTiInCell = null then
			bottomTiInCell := _ti;
		endif;
		// This correctly assumes that 40's are on top of 20's
		if _ti.getLengthInUnits &gt; 2 then //  30 / 40 / 45 / 53
			maxPileWeight := cellDefn.maxPileWeight40;
		else
			maxPileWeight := cellDefn.maxPileWeight20;
		endif;
	endif;
	useOldWay := ( maxPileWeight = 0 );

	//Work out which pile I'm in
	if useOldWay then	//03 Aug 2010	NDL	Par 25127 / CCMS 1140 - use the old way if is zero.
	
		if self.ordinalDeck = DeckUnderDeck then
			maxPileWeight := self.myBayVoyage.maxPileWeightUD;
		
		elseif self.ordinalDeck = DeckOnDeck then 
			if _ti.getLengthInUnits &gt; 2 then //  is40 then
				if self.mySlotDefnVoyage.isOutboard = true then
					maxPileWeight := self.myBayVoyage.maxPileWeight40OB;	 //I'm in a 40' outboard stack on deck
				else 
					maxPileWeight := self.myBayVoyage.maxPileWeight40IB;  //I'm in a 40' inboard stack on deck
			  endif;
			 else
				//Is 20'
				if self.mySlotDefnVoyage.isOutboard = true then
					maxPileWeight := self.myBayVoyage.maxPileWeight20OB;		//I'm in a 20' outboard stack on deck
				else 
					maxPileWeight := self.myBayVoyage.maxPileWeight20IB;  //I'm in a 20' inboard stack on deck
				endif;
			endif;
		endif;
	
		pileWeight := self.myBayVoyage.getCellPileWeight(self.ordinalDeck,self.ordinalCell,_mode); // PAR 8667 added
		
		if _mode = ShpDisplayMode_Actual then  // PAR 8667 added. proposed already has included our TI
			if _ti.myPrimaryActualLocation.isKindOf(CM_SlotController) then
				tiController := _ti.myPrimaryActualLocation.CM_SlotController;
			endif;
			if tiController &lt;&gt; null then
				if tiController.ordinalCell &lt;&gt; self.ordinalCell then
					pileWeight := pileWeight + _ti.totalWeight;	//Add in the weight of the tracked item
				elseif  tiController.ordinalDeck &lt;&gt; self.ordinalDeck and tiController.ordinalCell = self.ordinalCell  then
					pileWeight := pileWeight + _ti.totalWeight;	//Add in the weight of the tracked item
				endif;
			else
				pileWeight := pileWeight + _ti.totalWeight;	//Add in the weight of the tracked item
			endif;
		endif;
		
	else
		//03 Aug 2010	NDL	Par 25127 / CCMS 1140 - using the new way.
		self.getCellPileWeight( weight20s, weightOthers, _mode );
		
		if _mode = ShpDisplayMode_Actual then 
			if _ti.myPrimaryActualLocation.isKindOf(CM_SlotController) then
				tiController := _ti.myPrimaryActualLocation.CM_SlotController;
			endif;
			if tiController &lt;&gt; null then
				if tiController.ordinalCell &lt;&gt; self.ordinalCell then
					addProposed := true;
				elseif  tiController.ordinalDeck &lt;&gt; self.ordinalDeck and tiController.ordinalCell = self.ordinalCell  then
					addProposed := true;
				endif;
			else
				addProposed := true;
			endif;
			if addProposed then
				if _ti.getLengthInUnits = 2 then
					weight20s := weight20s + _ti.totalWeight.Integer;	
				else
					weightOthers := weightOthers + _ti.totalWeight.Integer;	
				endif;
			endif;
		endif;
		
		if weight20s &gt; 0 then
			//we either have a 20foot only pile or a mixed pile
			pileWeight := weight20s + ( weightOthers / 2).Integer;
		else
			// we have only 40's, show the full value but only if we are looking at the front end.
			if self.isFortyBack then
				pileWeight := 0;
			else
				pileWeight := weightOthers;
			endif;
		endif;
		
		pileWeight := pileWeight / 1000; // new way uses tonnes not kgs.
		
	endif;
	
	
	if maxPileWeight &gt; 0 and (pileWeight.roundedTo(2) &gt; maxPileWeight.roundedTo(2)) then
		//Warn user if max pile weight has been exceeded
		// PAR 28248 uncommemted this warning
		app.raiseCMWarning3(WarningPileWeightExceeded, maxPileWeight.asStringWeightJMT(), self.getFullId &amp; " (" &amp; _ti.id &amp; ")", pileWeight.asStringWeightJMT(), null, null, self);	
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tierId" id="10b9de75-f929-4f45-bbe1-d8d3a0db5a68">
        <methodInvocation>mapping</methodInvocation>
        <source>tierId(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := self.mySlotDefnVoyage.tierId;
//	if self.ordinalDeck = DeckOnDeck then
//		_value := self.myBayBayPlan.bayDefn.allTiersOnDeck[self.ordinalTier].id;
//	else
//		_value := self.myBayBayPlan.bayDefn.allTiersUnderDeck[self.ordinalTier].id;
//	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateOSBackend" id="bc4d5733-6c9d-467f-85e5-083f7c11132a">
        <source>updateOSBackend(_ti : CM_TrackedItem): Boolean;
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by cnwab1
//
// Purpose:      // PAR 18193
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return false;
	else
	
		return true;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttribute" id="f3deacae-2a75-4a03-85f7-02884b188d5f">
        <updating/>
        <source>updateSlotRequestAttribute(_isLoad : Boolean; _attribute : String; _loadCC : CMIF_LoadColorCode; _passport : CM_Passport input) : CM_SlotRequest updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2004 by cnwrs2
//
// Purpose:     code taken from CM_UtilityUpdateAgent::utlUpdateSlotRequestController
// Returns:		The real slot request created/updated
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 changes for release requests on Ship Load List
vars
	theLinkedRequest : CM_Request;
	pxySlotRequest,
	realSlotRequest	: CM_SlotRequest;
	tmpSlot	: CM_SlotController;
	theLinkedSlot : CM_LocationsController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	is53 			: Boolean;			//cnwas3 PAR 24273
	wle				: CM_WorkListEntry;	// PAR #26426
	trans			: Boolean;			// PAR #26426

begin
	tmpVoyage 	:= self.myBayVoyage.myCellularVoyageStructure.myVoyage;
	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	if _isLoad then
		realSlotRequest := self.mySlotRequestLoad;
	else
		realSlotRequest := self.mySlotRequestDischarge;
	endif;
	// PAR 22290 from here
	if realSlotRequest &lt;&gt; null then
		if realSlotRequest.isComplete then
			realSlotRequest := null; 
		elseif realSlotRequest.isCompletedBackend() then	//cnwmc5 - PAR 31050
			realSlotRequest := null;
		endif;
		
		if realSlotRequest &lt;&gt; null then
			if realSlotRequest.fortyBack then // 40 backs are not included in jobs so do not get completed, so check the forward slot
				if realSlotRequest.mySlotRequestForward &lt;&gt; null and realSlotRequest.mySlotRequestForward.isComplete then
					realSlotRequest := null;
				endif;
			// 13/07/2010 cnwmh5 #24827 - Start
			// if front end then need to check that back end doesn't already have something in it
			else
				if _isLoad and _loadCC &lt;&gt; null and _loadCC.myBulkReleaseReserveDetail &lt;&gt; null then
					// PAR #26426 create a persistent TBA TI so we can track it in the Ship Load List form
					//theTI := _loadCC.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self);			// PAR #26426
					if self.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then												// PAR #26426
						trans := false;																								// PAR #26426
					else																											// PAR #26426
						trans := true;																								// PAR #26426
					endif;																											// PAR #26426
					theTI := _loadCC.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self, trans);	// PAR #26426
					// PAR #26426 if we have a wle attached, assign the TBA TI to it, and set bulk release details
					if realSlotRequest.allWorkListEntries.size = 1 then
						wle := realSlotRequest.allWorkListEntries.first;
						// only asign the TBA TI if its persitent
						if not trans then
							wle.assignTIandBOL(theTI, null);
						endif;
						// we're planned, so add request to bulk release "being actioned" collection
						if _loadCC.myBulkReleaseReserveDetail &lt;&gt; null then
							realSlotRequest.setMyOriginatingBulkRelease(_loadCC.myBulkReleaseReserveDetail.myReserveHeader);
						endif;
						// and update wle planned location
						wle.setLocations(null, self.getStowageId(null));
					endif;
					// PAR #26426 end
					if realSlotRequest.mySlotController.has20FTInBackend(theTI) then
						return realSlotRequest;
					endif;
				endif;
				// 13/07/2010 cnwmh5 #24827 - End
			endif;
		endif;
	endif;
	// PAR 22290 to here
	
	if realSlotRequest &lt;&gt; null then
		exclusiveLock(realSlotRequest);
		if realSlotRequest.fortyBack then
			 // PAR 13332 if erasing and the slot req says it is a backend, but it is actually a front end then allow to erase.
			if _attribute = CM_SlotRequest.Attribute_Erase then // PAR 13332
				if self.isFortyBack then // PAR 13332
					app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
					return realSlotRequest;
				endif; // PAR 13332
			else // PAR 13332
				app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
				return realSlotRequest;
			endif;
		endif;
		// PAR 16415 CCMS 1029
		if realSlotRequest.isBackend then
			if _attribute = CM_SlotRequest.Attribute_Erase then
				if self.myBayVoyage.isAftBay() then
					app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
					return realSlotRequest;
				endif;
			else 
				if realSlotRequest.getAttrIs30() then
					realSlotRequest := null;
				else
					app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
					return realSlotRequest;
				endif;
			endif;
		endif;
	endif;
	
	if _attribute = CM_SlotRequest.Attribute_Erase then
		if realSlotRequest = null then
			// nothing to do so RETURN
			return null;
		endif;
		if realSlotRequest.myJob &lt;&gt; null then
			realSlotRequest.myJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
		tmpVoyage.causeEvent(voyUpdEvent, false, self);
		
		//cnwmc5 PAR 31678 - needs to be changed to just use .isLinked() when fixed
		if realSlotRequest.isLinked() or realSlotRequest.getLinkedRequest(realSlotRequest.isReleaseType) &lt;&gt; null then
			theLinkedRequest := realSlotRequest.getLinkedRequest(realSlotRequest.isReleaseType); // PAR 28968 getDLRSOBRequestLink();
			if theLinkedRequest &lt;&gt; null then
				theLinkedSlot := theLinkedRequest.getLC(); // PAR 28968 mySlotController;
				
				//cnwmc5 PAR 31678
				if not realSlotRequest.isReleaseType and realSlotRequest.isSOB() then
					if theLinkedRequest.isKindOf(CM_SlotRequest) then			//cnwmc5 - 4 August 2014 - PAR 34361
						theLinkedRequest.CM_SlotRequest.mySlotController.eraseSlotRequest(theLinkedRequest.CM_SlotRequest);
					endif;
				endif;
				
				// force a redraw of the other slot
				tmpVoyage.causeEvent(voyUpdEvent, false, theLinkedSlot);
			endif;
		endif;
		
		is53 := realSlotRequest.getAttrIs53();		//cnwas3 PAR 24273
		if realSlotRequest.getAttrIs40() 
		or (not realSlotRequest.isBackend and (realSlotRequest.getAttrIs30() or is53 or realSlotRequest.getAttrIs45())) then // PAR 16415 CCMS 1029

			// PAR 16415 CCMS 1029
			if is53 then		//cnwas3 PAR 24273
				tmpSlot := self.myAftSlot.myAftSlot;
				if tmpSlot &lt;&gt; null then
					if realSlotRequest.mySlotRequestAft &lt;&gt; null then// PAR 18823
					if realSlotRequest.mySlotRequestAft.mySlotRequestAft &lt;&gt; null then
						tmpSlot.eraseSlotRequest(realSlotRequest.mySlotRequestAft.mySlotRequestAft);
						tmpVoyage.causeEvent(voyUpdEvent, false, tmpSlot);
					endif;
					endif;
				endif;
			endif;
		
		
			// we also need to delete the fortyBack
			tmpSlot := self.myAftSlot;
			if tmpSlot &lt;&gt; null then
				if realSlotRequest.mySlotRequestAft &lt;&gt; null then
					tmpSlot.eraseSlotRequest(realSlotRequest.mySlotRequestAft);
					tmpVoyage.causeEvent(voyUpdEvent, false, tmpSlot);
				endif;
			endif;
		endif;
		
		realSlotRequest.unsetTwinLiftFromEraserPen();		// 09/08/2010 cnwmh5 #25007
		
		self.eraseSlotRequest(realSlotRequest);
		// ====================
		// RETURN
		// ====================
		return null;
	endif;
	
	if realSlotRequest = null or 
	   (realSlotRequest &lt;&gt; null and
	   realSlotRequest.myJob &lt;&gt; null and
	   realSlotRequest.myJob.isJobComplete) then // REWORK JOB
	   
		realSlotRequest := null;
	   	isCreate := true;

		// we need to create a request
		
		// PAR 21746
		create pxySlotRequest transient;
		
		if _isLoad then
			if _loadCC = null then
				pxySlotRequest.setProxyForCreate(self, LOAD_MOVETYPE, _isLoad, null, null);
			else
				pxySlotRequest.setFromLoadCC(_loadCC, true, LOAD_MOVETYPE, self);
			endif;
		else
			pxySlotRequest.setProxyForCreate(self, DISCHARGE_MOVETYPE, _isLoad, null, null);
		endif;
		// ######  VOYAGE ALLOCATIONS
		// ######  VOYAGE ALLOCATIONS
		// ######  VOYAGE ALLOCATIONS
		// ######  VOYAGE ALLOCATIONS
		// ######  VOYAGE ALLOCATIONS
		// ######  VOYAGE ALLOCATIONS
		if tmpVoyage.useVoyageAllocations then
			if _isLoad then
				app.myUtilityCA.utlCreateSlotRequest(pxySlotRequest, realSlotRequest, _passport);
				
				// 27 Mar 2012	NDL	Par 29070
				if not _passport.checkValidation then
					return null;
				endif;
				
				// PAR 23426
			   if _attribute = CM_SlotRequest.Attribute_SOB then
					realSlotRequest.setMoveType(SOB_MOVETYPE);
			   endif;
			   if  _attribute = CM_SlotRequest.Attribute_DLR then
					realSlotRequest.setMoveType(DLR_MOVETYPE);
			   endif;
				
			   // ## PAR 23906
				if _loadCC &lt;&gt; null then
					needAftRequest := (_loadCC.isForty or _loadCC.isFortyFive or _loadCC.isFiftyThree or _loadCC.isThirty);
				elseif realSlotRequest &lt;&gt; null then
					needAftRequest := (realSlotRequest.getAttrIs40() or realSlotRequest.getAttrIs30()or realSlotRequest.getAttrIs45() or realSlotRequest.getAttrIs53());
				endif;
				
				if needAftRequest then
					if _passport.noErrors and
						realSlotRequest &lt;&gt; null and
						realSlotRequest.mySlotRequestAft = null then
					
						self.createAftSlotRequest(realSlotRequest, _passport);
						tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot);
						if _loadCC.isFiftyThree then
							if realSlotRequest.mySlotController.myAftSlot &lt;&gt; null then // PAR 18823
							if realSlotRequest.mySlotController.myAftSlot.myAftSlot &lt;&gt; null then
								realSlotRequest.mySlotController.myAftSlot.createAftSlotRequest(realSlotRequest.mySlotRequestAft, _passport);
								tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot.myAftSlot);
							endif;
							endif;
						endif;
					endif;
				endif;
		
				return realSlotRequest;
			endif;
		endif;
		/*
		// 21746
		if _isLoad then
			
			if _loadCC = null then
				pxySlotRequest.setProxyForCreate(self, LOAD_MOVETYPE, _isLoad, null, null);
			else
				pxySlotRequest.setProxyForCreate(self, LOAD_MOVETYPE, _isLoad, _loadCC.myCargoType, _loadCC.myDischargePort);
				//pxySlotRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_loadCC);
				pxySlotRequest.setPxyCommodityGroup(_loadCC.myCommodityGroup, _passport.myTerminal);
			endif;
		else
			pxySlotRequest.setProxyForCreate(self, DISCHARGE_MOVETYPE, _isLoad, null, null);
		endif;
		*/
		if _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
	else
		pxySlotRequest := realSlotRequest.pxyCreateUpdateProxy();
		if _isLoad and _loadCC &lt;&gt; null then
			if _attribute &lt;&gt; CM_SlotRequest.Attribute_AssignRelease then
				pxySlotRequest.setPxyCargoType(_loadCC.myCargoType);
				pxySlotRequest.setPxyDischargePort(_loadCC.myDischargePort);
				//pxySlotRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_loadCC);
				pxySlotRequest.setPxyCommodityGroup(_loadCC.myCommodityGroup, _passport.myTerminal);
			endif;
			pxySlotRequest.setPxyBulkReleaseReserveDetail(_loadCC.myBulkReleaseReserveDetail);
			pxySlotRequest.setPxyWeight(_loadCC.weight);		// cnwdad1 09/08/2010 - PAR #25353.
		endif;
	endif;

	theMoveType := pxySlotRequest.moveType;

	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
		pxySlotRequest.setMoveType(theMoveType);		
	endif;

	if _isLoad and _attribute = CM_SlotRequest.Attribute_Forty then
		pxySlotRequest.setPxyFortyFoot((not pxySlotRequest.getAttrIs40()), self);
		needAftRequest := pxySlotRequest.getAttrIs40();

	// PAR 16415 CCMS 1029
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_FiftyThree then
		pxySlotRequest.setProxyFiftyThreeFooter(_passport);
		needAftRequest := not pxySlotRequest.isBackend;
	// PAR 16415 CCMS 1029
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_Thirty then
		pxySlotRequest.setProxyThirtyFooterFrontend(_passport);
		needAftRequest := not pxySlotRequest.isBackend;
	// PAR 18682 CCMS 1055
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_FortyFive then
		pxySlotRequest.setProxyFortyFiveFootFrontend(_passport);
		needAftRequest := not pxySlotRequest.isBackend;

	elseif _isLoad 
	and _attribute = CM_SlotRequest.Attribute_ColourCode 
	and (not isCreate) 
	and _loadCC &lt;&gt; null 
	and (not _loadCC.overrideMoveType) 
	and (realSlotRequest.isSOB or realSlotRequest.isRehandle) then

		/*
		if this request is already a SOB or DLR we do NOT want to
		set back to a CC.  We are just updating the Load-CC attributes 
		(ie. discharge port, commodity, cargo-type) - 
		hence do nothing
		*/		

	else
		pxySlotRequest.setProxyAttribute(_attribute);
	endif;

	if (not _isLoad) then
		theTI := self.allTrackedItems.first;
		if theTI &lt;&gt; null then
			pxySlotRequest.setFromTI(theTI); // PAR 28968 , (theTI.myPrimaryActualLocation = self));
			
			if not pxySlotRequest.is20() then // PAR 16415 CCMS 1029
				needAftRequest := not pxySlotRequest.isBackend; // PAR 16415 CCMS 1029
			endif;
			
			if (_attribute = CM_SlotRequest.Attribute_ColourCode or
			   _attribute = CM_SlotRequest.Attribute_SOB or
			   _attribute = CM_SlotRequest.Attribute_DLR) and
			   theTI.isAttributeTrue(TI_Attrib_IsForty) then
				tmpSlot := self.myAftSlot;
				if tmpSlot = null then
					app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to create 40 request for slot that cannot take fortyFront');
					return null;
				endif;
				// need to create/update request for other end of 40
				needAftRequest := true;
			endif;
		endif;
	endif;

	if isCreate then
		app.myUtilityCA.utlCreateSlotRequest(pxySlotRequest, realSlotRequest, _passport);
	else
		app.myUtilityUA.utlUpdateSlotRequest(pxySlotRequest, _passport, true);
	endif;
	
	if _passport.noErrors and
		needAftRequest and
		realSlotRequest &lt;&gt; null and
		realSlotRequest.mySlotRequestAft = null then
	
		self.createAftSlotRequest(realSlotRequest, _passport);
		tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot);
		
		// PAR 16415 CCMS 1029
		if realSlotRequest.getAttrIs53() then
			if realSlotRequest.mySlotController.myAftSlot &lt;&gt; null then // PAR 18823
			if realSlotRequest.mySlotController.myAftSlot.myAftSlot &lt;&gt; null then
				realSlotRequest.mySlotController.myAftSlot.createAftSlotRequest(realSlotRequest.mySlotRequestAft, _passport);
				tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot.myAftSlot);
			endif;
			endif;
		endif;
	endif;

	return realSlotRequest;

epilog
	delete pxySlotRequest;
	
	//07 Jan 2011	NDL	Transient leak in unit test UT_VoyageOps MtReleaseUsingHatchman
	if trans then
		if theTI &lt;&gt; null and theTI.isTransient then
			if not theTI.allJobsShipRelease.isEmpty then
				theTI.allJobsShipRelease.purge;
			endif;
			delete theTI;
		endif;
	endif;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestCreateProxy" id="c1c6b356-28da-4a19-98da-ad0a0f59fce6">
        <updating/>
        <source>updateSlotRequestCreateProxy(_verifyOnly : Boolean; _isLoad : Boolean; _attribute : String; _loadCC : CMIF_LoadColorCode; _passport : CM_Passport input) : CM_SlotRequest updating;
// ---------------------------------------------------------------------------
// Created:     September 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 24041 -  Probably only suited to EDI stow advice validation	processing
// ---------------------------------------------------------------------------

vars
	theLinkedRequest,
	pxySlotRequest,
	realSlotRequest	: CM_SlotRequest;
	tmpSlot,
	theLinkedSlot	: CM_SlotController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;

begin

	tmpVoyage := self.myBayVoyage.myCellularVoyageStructure.myVoyage;

	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	
	if _isLoad then
		realSlotRequest := self.mySlotRequestLoad;
	else
		realSlotRequest := self.mySlotRequestDischarge;
	endif;
	
	if realSlotRequest &lt;&gt; null then
		exclusiveLock(realSlotRequest);
	endif;
	
	if _attribute = CM_SlotRequest.Attribute_Erase then
		return null;
	endif;
	
	if realSlotRequest = null or 
	   (realSlotRequest &lt;&gt; null and
	   realSlotRequest.myJob &lt;&gt; null and
	   realSlotRequest.myJob.isJobComplete) then // REWORK JOB
	   
		realSlotRequest := null;
	   	isCreate := true;

		// we need to create a request
		create pxySlotRequest transient;
		if _isLoad then
			if _loadCC = null then
				pxySlotRequest.setProxyForCreate(self, LOAD_MOVETYPE, _isLoad, null, null);
			else
				pxySlotRequest.setProxyForCreate(self, LOAD_MOVETYPE, _isLoad, _loadCC.myCargoType, _loadCC.myDischargePort);
				pxySlotRequest.setPxyCommodityGroup(_loadCC.myCommodityGroup, _passport.myTerminal);
			endif;
		else
			pxySlotRequest.setProxyForCreate(self, DISCHARGE_MOVETYPE, _isLoad, null, null);
		endif;
		if not _verifyOnly and _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
	else
		pxySlotRequest := realSlotRequest.pxyCreateUpdateProxy();
		if _isLoad and _loadCC &lt;&gt; null then
			if _attribute &lt;&gt; CM_SlotRequest.Attribute_AssignRelease then
				pxySlotRequest.setPxyCargoType(_loadCC.myCargoType);
				pxySlotRequest.setPxyDischargePort(_loadCC.myDischargePort);
				pxySlotRequest.setPxyCommodityGroup(_loadCC.myCommodityGroup, _passport.myTerminal);
			endif;
			pxySlotRequest.setPxyBulkReleaseReserveDetail(_loadCC.myBulkReleaseReserveDetail);
		endif;
	endif;

	theMoveType := pxySlotRequest.moveType;

	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
		pxySlotRequest.setMoveType(theMoveType);		
	endif;

	if _isLoad and _attribute = CM_SlotRequest.Attribute_Forty then
		pxySlotRequest.setPxyFortyFoot((not pxySlotRequest.getAttrIs40), self);
		needAftRequest := pxySlotRequest.getAttrIs40();

	// PAR 16415 CCMS 1029
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_FiftyThree then
		pxySlotRequest.setProxyFiftyThreeFooter(_passport);
		needAftRequest := not pxySlotRequest.isBackend;
	// PAR 16415 CCMS 1029
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_Thirty then
		pxySlotRequest.setProxyThirtyFooterFrontend(_passport);
		needAftRequest := not pxySlotRequest.isBackend;
	// PAR 18682 CCMS 1055
	elseif _isLoad and _attribute = CM_SlotRequest.Attribute_FortyFive then
		pxySlotRequest.setProxyFortyFiveFootFrontend(_passport);
		needAftRequest := not pxySlotRequest.isBackend;

	elseif _isLoad 
	and _attribute = CM_SlotRequest.Attribute_ColourCode 
	and (not isCreate) 
	and _loadCC &lt;&gt; null 
	and (not _loadCC.overrideMoveType) 
	and (realSlotRequest.isSOB or realSlotRequest.isRehandle) then

		/*
		if this request is already a SOB or DLR we do NOT want to
		set back to a CC.  We are just updating the Load-CC attributes 
		(ie. discharge port, commodity, cargo-type) - 
		hence do nothing
		*/		

	else
		pxySlotRequest.setProxyAttribute(_attribute);
	endif;

	if (not _isLoad) then
		theTI := self.allTrackedItems.first;
		if theTI &lt;&gt; null then
			pxySlotRequest.setFromTI(theTI); // PAR 28968 , (theTI.myPrimaryActualLocation = self));
			
			if not pxySlotRequest.is20() then // PAR 16415 CCMS 1029
				needAftRequest := not pxySlotRequest.isBackend; // PAR 16415 CCMS 1029
			endif;
			
			if (_attribute = CM_SlotRequest.Attribute_ColourCode or
			   _attribute = CM_SlotRequest.Attribute_SOB or
			   _attribute = CM_SlotRequest.Attribute_DLR) and
			   theTI.isAttributeTrue(TI_Attrib_IsForty) then
				tmpSlot := self.myAftSlot;
				if tmpSlot = null then
					app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to create 40 request for slot that cannot take fortyFront');
					return null;
				endif;
				// need to create/update request for other end of 40
				needAftRequest := true;
			endif;
		endif;
	endif;
	pxySlotRequest.setEDIAttributes(_verifyOnly, _loadCC);

	return pxySlotRequest;

epilog
end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestDLRSOB" id="738ed9d3-ed09-4a3f-8bfc-3cf3b4b9177c">
        <updating/>
        <source>updateSlotRequestDLRSOB(_isLoad : Boolean; _moveType : Integer; _passport : CM_Passport input) : CM_SlotRequest updating;
/*
Purpose:		ONLY USED IF DLR ALT LINKING BETWEEN RORO and LOLO	
Date				Who			Reason
MARCH 2012		CNWAB1		Initial creation
*/

vars
	theLinkedRequest,
	realSlotRequest, fwdReq, aftReq	: CM_SlotRequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,

	is53 			: Boolean;			//cnwas3 PAR 24273
	wle				: CM_WorkListEntry;	// PAR #26426
	trans			: Boolean;			// PAR #26426

begin
	tmpVoyage 	:= self.getMyVoyage();
	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	if _isLoad then
		realSlotRequest := self.mySlotRequestLoad;
	else
		realSlotRequest := self.mySlotRequestDischarge;
		if realSlotRequest = null then
			self.createDefaultDischargeCC(_moveType, true, _passport); // PAR 28968 
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // TIDY UP
			
			return realSlotRequest;
		endif;
	endif;

	
	if realSlotRequest &lt;&gt; null then
		if realSlotRequest.isComplete then
			realSlotRequest := null; 
		endif;
		
		if realSlotRequest &lt;&gt; null then
			if realSlotRequest.getAttrIsBackend() then // 40 backs are not included in jobs so do not get completed, so check the forward slot
				fwdReq := realSlotRequest.mySlotRequestForward.CM_SlotRequest;
				if fwdReq &lt;&gt; null and fwdReq.isComplete then
					realSlotRequest := null;
				endif;
			endif;
		endif;
	endif;
	
	if realSlotRequest &lt;&gt; null then
		exclusiveLock(realSlotRequest);
		if realSlotRequest.getAttrIsBackend() then
			app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
			return realSlotRequest;
		endif;
		if realSlotRequest.isRehandle or realSlotRequest.isSOB then
			realSlotRequest.setMoveType(NULL_MOVETYPE); 
			if realSlotRequest.isDischarge then
				realSlotRequest.setLinkedRequest(null);
			endif;
		else
			realSlotRequest.setMoveType(_moveType); //SOB_MOVETYPE DLR_MOVETYPE
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // TIDY UP
		endif;
	else // PAR 31467
		self.createDefaultDischargeCC(_moveType, true, _passport);  // PAR 31467
		app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // TIDY UP
		
		return realSlotRequest;

	endif;

	return realSlotRequest;

epilog
	
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestVA" id="754f1ae0-74b1-49c7-827d-2e2a32e9ec4f">
        <updating/>
        <source>updateSlotRequestVA(_isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _passport : CM_Passport input): CM_SlotRequest updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	theLinkedRequest,
	pxySlotRequest,
	realSlotRequest	: CM_SlotRequest;
	tmpSlot,
	theLinkedSlot	: CM_SlotController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;

begin

	tmpVoyage := self.myBayVoyage.myCellularVoyageStructure.myVoyage;

	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	
	if _isLoad then
		realSlotRequest := self.mySlotRequestLoad;
	else
		realSlotRequest := self.mySlotRequestDischarge;
	endif;	
	
	if _isLoad then
		theMoveType := LOAD_MOVETYPE;
	else
		theMoveType := DISCHARGE_MOVETYPE;
	endif;	
	if realSlotRequest = null or 
	   (realSlotRequest &lt;&gt; null and
	   realSlotRequest.isComplete) then // PAR 30985 REWORK JOB
	   // PAR 30985 realSlotRequest.myJob &lt;&gt; null and
	   // PAR 30985 realSlotRequest.myJob.isJobComplete) then 
	   
	   
		realSlotRequest := null;
	   	isCreate := true;

		// we need to create a request
		create pxySlotRequest transient;
		// PAR 37111 UT 	pxySlotRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_voyAlloc);		
		pxySlotRequest.setProxyForCreateVA(self, theMoveType, _isLoad,_voyAlloc);		
		if _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
	else
		pxySlotRequest := realSlotRequest.pxyCreateUpdateProxy();
		// PAR 37111 UT 	pxySlotRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_voyAlloc);		
		pxySlotRequest.setProxyForCreateVA(self, theMoveType, _isLoad,_voyAlloc);		
	endif;

	theMoveType := pxySlotRequest.moveType;

	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
		pxySlotRequest.setMoveType(theMoveType);		
	endif;
	

	if isCreate then
		app.myUtilityCA.utlCreateSlotRequest(pxySlotRequest, realSlotRequest, _passport);
	else
		app.myUtilityUA.utlUpdateSlotRequest(pxySlotRequest, _passport, true);
	endif;
	
	needAftRequest := _voyAlloc.needsAftRequest();
	app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),_voyAlloc);
	
	if _passport.noErrors 
	and needAftRequest 
	and realSlotRequest &lt;&gt; null 
	and realSlotRequest.mySlotRequestAft = null then	
	
		self.createAftSlotRequest(realSlotRequest, _passport);
		tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot);	
		
		//22 Jun 2020	NDL	TFS 49408	- Removed
	/*	if realSlotRequest.getAttrIs53() then
			if realSlotRequest.mySlotController.myAftSlot &lt;&gt; null then // PAR 18823
			if realSlotRequest.mySlotController.myAftSlot.myAftSlot &lt;&gt; null then
				realSlotRequest.mySlotController.myAftSlot.createAftSlotRequest(realSlotRequest.mySlotRequestAft, _passport);
				tmpVoyage.causeEvent(voyUpdEvent, false, self.myAftSlot.myAftSlot);
			endif;
			endif;
		endif; */
	endif;

	return realSlotRequest;

epilog
	delete pxySlotRequest;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="validateEDIMoveTo" id="123ec5ce-2e75-4a59-90c2-e0e710cc7d49">
        <source>validateEDIMoveTo(control: CMIF_MoveController input; _updateController: CMIF_TIUpdateController);
//----------------------------------------------------------------
//	Created:	26 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	theTI	: CM_TrackedItem;
	thisJob,
	job : CM_Job;
begin
	
	theTI := control.myTrackedItem;
	
	if self.mySlotDefnVoyage.unavailable then
		app.raiseCMException2(SlotIsUnavailable, self.getLocationId(control.moveMode, theTI), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , 'location', _updateController.myUserObject);// PAR 26684 added TI ID
	endif;
	
	if self = control.myToPrimaryLocation then

		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.raiseCMException2(Err_MoveSize, theTI.id, self.getLocationId(control.moveMode, theTI), null, _updateController.myUserObject);
			return;	
		endif;

		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			if lc.CM_SlotController.mySlotDefnVoyage.unavailable then
				app.raiseCMException2(SlotIsUnavailable, lc.CM_SlotController.getLocationId(control.moveMode, theTI), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , 'location', _updateController.myUserObject);// PAR 27385 cnwrs1 11 Apr 2011
				return;
			endif;
			lc.validateMoveTo(control);			
		endforeach;
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(theTI, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	
	//---------------------------
	// Check it is compatible with slot request/job
	//---------------------------
	self.validateSlotRequestMoveTo(control);
	
	//---------------------------
	// Check to see if something in back end
	//---------------------------
	if control.myTrackedItem &lt;&gt; null then
		self.has20FTInBackend(control.myTrackedItem);		// 12/07/2010 cnwmh5 #24827 
	endif;
	
	//-------------------------
	//Perform these tests only once
	//-------------------------
	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;

	if control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is a real EDI move (make actual), ignore the rest of the checks.
		return;
	endif;

	self.testPileWeight(theTI,ShpDisplayMode_Actual); // PAR 8667 added	
//	self.testPileHeightUnderDeck(theTI);
	self.testPileHeight(theTI);	//03 Aug 2010	NDL Par 25127
	
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateForEDIDischarge" id="2c78ee9e-6836-4cef-8221-96ed10c56e07">
        <source>validateForEDIDischarge(_ediStowAdviceTI: CM_EDIStowAdviceTI): Boolean;
//----------------------------------------------------------------
//	Created:	09 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	found 			: Boolean;
	ti				: CM_TrackedItem;
	slotReqDisch	: CM_SlotRequest;
	tmpStowAdviceTI	: CM_EDIStowAdviceTI;
begin

	tmpStowAdviceTI := _ediStowAdviceTI;
	
	if (not self.allTrackedItems.isEmpty) then
		found := false;
		foreach ti in self.allTrackedItems do
			if ti.id = tmpStowAdviceTI.id then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			//was a warning in 731 - user can now edit ID's in 732 so make it an error
			app.raiseCMException2(ERR_STOWAGE_FIELD, tmpStowAdviceTI.id, "DLR tracked item id'.  It does not match the item in this position "
									&amp; tmpStowAdviceTI.stowageId &amp; ", '" &amp; ti.id, 'Stowage', tmpStowAdviceTI);
			return false;
		endif;
	endif;
	
	//disch for DLR
	slotReqDisch := self.mySlotRequestDischarge;
	if slotReqDisch &lt;&gt; null then
		if not (slotReqDisch.isLinked and slotReqDisch.isRehandle) then	//linked DLR discharges will be deleted so ignore
			if slotReqDisch.myJob = null then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED, self.getFullId,"Discharge","Job Not Created", 'Stowage', tmpStowAdviceTI);
				return false;
			elseif slotReqDisch.myJob.isJobComplete = false then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED, self.getFullId,"Discharge",slotReqDisch.myJob.jobId, 'Stowage', tmpStowAdviceTI);
				return false;
			endif;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_ediStowAdviceTI" type="CM_EDIStowAdviceTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForEDILoad" id="f9079b4d-4b82-4608-b0c4-8647e989ed9f">
        <source>validateForEDILoad(_ediStowAdviceTI: CM_EDIStowAdviceTI; dlrIDs: StringArray; _ignoreNotMarkedDisch: Boolean): Boolean;
//----------------------------------------------------------------
//	Created:	09 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	
	if (not _ignoreNotMarkedDisch)
	and self.allTrackedItems.isNotEmpty
	and self.mySlotRequestDischarge = null then
		if not dlrIDs.includes(self.allTrackedItems.first.id) then
			app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT, self.getStowageId(null) &amp; " (load)", 'Stowage', _ediStowAdviceTI, self);
			return false;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_ediStowAdviceTI" type="CM_EDIStowAdviceTI"/>
        <Parameter name="dlrIDs" type="StringArray"/>
        <Parameter name="_ignoreNotMarkedDisch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="1f972700-0003-4a5b-8fad-4d61a461333b">
        <source>validateMoveFrom(control: CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	term : CM_Terminal;
begin
	inheritMethod(control);

	self.validateSlotRequestMoveFrom(control);
	
	// To be re engineered in 7.3.4 validate outside transaction.
/*	if CM_YardController.hasInstance(control.myToPrimaryLocation) then
		tmpTI := control.myTrackedItem;
		if tmpTI &lt;&gt; null then
			term := control.myToPrimaryLocation.myTerminal;
			if term &lt;&gt; null then
				if term.allOnsiteTIsByCargoTypeId[tmpTI.cargoType, tmpTI.id.trimBlanks] &lt;&gt; null then
					app.raiseCMException1(ERR_TI_ONSITE, tmpTI.cargoTypeDescr &amp; ' ' &amp; tmpTI.id, null, null);
				endif;
			endif;
		endif;
	endif;*/
				
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="2ec072b6-f0e7-4ea1-a1c5-372a1bbf92f0">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			24 September 2002 by cnwdwq1
Purpose:			
Parameters:			None
Returns:			Nothing
Changed On		Changed By		Reason
----------		----------		-----------------------------------------
07/12/2011		cnwdap1			PAR #26619 CMCS SFW 1260 Raise warning if planning/queueing/moving 
								on top of an overheight container or a flat
19/12/2011		cnwdap1			PAR #28881 Ignore EDI or discharge TIs when checking overdimensions
---------------------------------------------------------------------------
*/
vars
	lc	: CM_LocationsController;
	theTI, tmpTI, onshipTI	: CM_TrackedItem;
	tmpFM : CM_FutureMove;
	tmpWLE : CM_WorkListEntry;
	thisJob,
	job : CM_Job;
	underSlot : CM_SlotController;	// PAR #26619
	topTI : CM_TrackedItem;			// PAR #26619
	warning : CM_Error;				// PAR #26619
	flat, height : Boolean;			// PAR #26619
	fromLC	: CM_LocationsController; 
	fromVoyage : CM_Voyage;
begin
	theTI := control.myTrackedItem;

	if self.mySlotDefnVoyage.unavailable then
		// PAR 26684app.raiseCMException2(SlotIsUnavailable, self.ident, app.getErrorString(MoveCargo), null, null);
		app.raiseCMException2(SlotIsUnavailable, self.getLocationId(control.moveMode, theTI), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , 'location', self);// PAR 26684
	endif;
	
	if self = control.myToPrimaryLocation then
		inheritMethod(control);
		if control.moveMode = REAL_MODE and theTI.isRehandle then
			if theTI.isOnShip then
				if control.myWorkListEntry &lt;&gt; null then
					thisJob := control.myWorkListEntry.job;
				endif;
				// its on the ship but check if the discharge DLR has completed
				if thisJob = null then
					//It must be a shift on board move, carry on...
				elseif thisJob.jobType = JOB_TYPE_SOB then
					// Carry on..					
				else
					foreach job in theTI.allJobsShipReceive do
						if job = thisJob then
							continue;
						endif;
						if job.isRelease then
							// Belts and braces - You never know, Ignore the Load job.
							continue;
						endif;
						if not job.isJobComplete then
							// Error, cannot move DLR to ship as it is still on the ship
							app.raiseCMException2(TI_DLRDischargeNotComplete, theTI.id, job.jobId, null, null);				
							return;
						endif;			
					endforeach;
				endif;
			endif;
		endif;
		
		// ## PAR 25513
		if control.moveMode = REAL_MODE  then
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.mySlotRequestDischarge &lt;&gt; null then
					tmpTI := self.mySlotRequestDischarge.getTrackedItem();
					if tmpTI &lt;&gt; null then
						onshipTI := self.allTrackedItems.first;
						if tmpTI = onshipTI and onshipTI &lt;&gt; null then
							app.raiseCMException3(Cargo_that_locat_colou_coded_d, onshipTI.id, self.getLocationId(control.moveMode, onshipTI),theTI.id, null, null);
						endif;
					endif;
				endif;
			endif;
		endif;
		// ## PAR 25513
		if control.moveMode = QUEUE_MODE  then
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.mySlotRequestDischarge &lt;&gt; null then
					tmpWLE := self.mySlotRequestDischarge.allWorkListEntries.first;
					if tmpWLE &lt;&gt; null then
						tmpFM := tmpWLE.myFutureMove;
						if tmpFM &lt;&gt; null then
							if tmpFM.moveType &lt;&gt; TI_FutureMoveQueued then
								tmpFM := null;
							endif;
						endif;
						if tmpFM = null then
							onshipTI := self.allTrackedItems.first;
							if onshipTI &lt;&gt; null then
								app.raiseCMException3(Cargo_that_locat_colou_codedee, onshipTI.id, self.getLocationId(control.moveMode, onshipTI),theTI.id, null, null);
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;

		//------------------- RE-ENTRANT PROTECTION PORTION - CALLED ONCE -----------------------------
		//As the primary target we have already been locked by the control object.
		//(or by the caller)
		//-------------------
		//------------------
		//get the extent of the TI in terms of other LC's of this type we have to span
		//------------------
		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.raiseCMException2(Err_MoveSize, theTI.id, self.getLocationId(control.moveMode, theTI), null, null);
			return;	
		endif;
		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			lc.validateMoveTo(control);			
		endforeach;
		
		// 12/07/2010 cnwmh5 #24827 - Start
		//---------------------------
		// Check to see nothing in backend
		//---------------------------
		if control.myTrackedItem &lt;&gt; null then
			self.has20FTInBackend(control.myTrackedItem) ;
		endif;
		// 12/07/2010 cnwmh5 #24827 - End
		
	endif;
	
	//03 Nov 2014	NDL	Par 35017 - migrated down from CM_VoyageController
	if control.moveMode = QUEUE_MODE or  control.moveMode = PLANNING_MODE then
		if fromLC &lt;&gt; null and (fromLC.isWagon or fromLC.isVehicle) then
			if control.moveMode = QUEUE_MODE then
				app.raiseCMException(NoQueue_Rail_To_Voyage, null, null);
			endif;
		endif;
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(theTI, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	
	//---------------------------
	// Check it is compatible with slot request/job
	//---------------------------
	self.validateSlotRequestMoveTo(control);
	
	//-------------------------
	//Perform these tests only once
	//-------------------------
	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;

	// PAR 8141. Cannot move a 20 to a 40 foot only bay
	if self.myBayVoyage.fortyFootOnly
	and not theTI.isAttributeTrue(TI_Attrib_IsForty) then
		//Not enough space!
		app.raiseCMException2(Err_MoveSize, theTI.id, ", Bay " &amp; self.myBayVoyage.id &amp; " (forty foot only), ", null, null);
		return;	
	endif;
	if self.myBayVoyage.fortyFiveFootOnly
	and not theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		//Not enough space!
		app.raiseCMException2(Err_MoveSize, theTI.id, ", Bay " &amp; self.myBayVoyage.id &amp; " (forty five foot only), ", null, null);
		return;	
	endif;

	if control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is a real EDI move (make actual), ignore the checks below
	else
		if control.moveMode = REAL_MODE then // PAR 8667 added
			self.testPileWeight(theTI,ShpDisplayMode_Actual);	 // PAR 8667 added
		else
			self.testPileWeight(theTI,ShpDisplayMode_Proposed);	 // PAR 8667 added
		endif;
		//self.testPileHeightUnderDeck(theTI);
		self.testPileHeight(theTI);	//03 Aug 2010	NDL Par 25127
	endif;

	// PAR #26619 Warn if we're planning/queuing/moving a container on top of another overheight container
	underSlot := self.myUnderfootSlot;
	if underSlot &lt;&gt; null then
		// PAR #28881 changed the way we derive the TI to avoid picking up EDI moves or discharge TIs
		topTI := underSlot.getActualQueuedPlannedLoadTI();
		/*topTI := underSlot.allTrackedItems.first;
		if topTI = null then
			if not underSlot.allQueuedFutureMoves.isEmpty then
				topTI := underSlot.allQueuedFutureMoves.first.CM_FutureMoveQueued.myTrackedItem;
			endif;
		endif;
		if topTI = null then
			if not underSlot.allPlannedFutureMoves.isEmpty then
				topTI := underSlot.allPlannedFutureMoves.first.CM_FutureMovePlanned.myTrackedItem;
			endif;
		endif;	*/
		if topTI &lt;&gt; null then
			// this particular method gets called after warnings have already been acknowledged, so we can end up 
			// raising the same warning twice and displaying two warning boxes. Check here if we already have a 
			// warning for either of these messages
			flat := false; height := false;
			foreach warning in app.myPassport.allWarnings do
				if warning.errorCode = Cannot_contain_underne_overhei then
					height := true;
				elseif warning.errorCode = Container_flat_platform then
					flat := true;
				endif;
			endforeach;
			if topTI.isOverHeight and not height then
				app.raiseCMWarning2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(control.moveMode) &amp; "' " &amp; theTI.id, self.getFullId, "Slot " &amp; self.getFullId, null, self);
			endif;
			
			// also check whether we're putting this container on top of a flat
			//if topTI.getISOTypeObject.isFlat and not flat then
			if topTI.getISOTypeObject &lt;&gt; null and topTI.getISOTypeObject.isFlat and not flat then	//26 June 2012	NDL	Par 29811
				app.raiseCMWarning3(Container_flat_platform, "'" &amp; app.moveModeStatusEnumToString(control.moveMode) &amp; "' ", theTI.id, self.getFullId, "Slot " &amp; self.getFullId, null, self);
			endif;
		endif;
	endif;
	// PAR #26619 end
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateODMoveTo" id="fd79a5a6-e29c-4b59-b9f3-323bffaa0a3a">
        <source>validateODMoveTo(_control: CMIF_MoveController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	ti, otherTI : CM_TrackedItem;
	underSlot, overSlot, portSlot, stbdSlot, fwdSlot, aftSlot : CM_SlotController;
	request : CM_SlotRequest;
	direction : Integer;

begin
	if _control.moveMode &lt;&gt; PLANNING_MODE then
		return;
	endif;
	
	ti := _control.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	// check for over heght underneath me
	underSlot := self.myUnderfootSlot;
	if underSlot &lt;&gt; null then
		otherTI := underSlot.getActualQueuedPlannedLoadTI();
		if otherTI &lt;&gt; null then
			// warning if planned on top of a flat rack with ends down
			if otherTI.isFlat and otherTI.CM_Container.doorsDirn = TI_DOORSDIRN_ENDDOWN then
				app.raiseCMWarning4(Planning_On_Top_Of_Flat, otherTI.id, underSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
			
			// warning if planning on top of an over-height container
			if otherTI.isOverHeight then
				app.raiseCMWarning4(Planning_Next_To_Over_Dim, otherTI.id, underSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
		endif;
	endif;
	
	// check for any containers over stowing me if I'm overheight
	overSlot := self.myOverheadSlot;
	if overSlot &lt;&gt; null and ti.isOverHeight then
		otherTI := overSlot.getActualQueuedPlannedLoadTI();
		if otherTI &lt;&gt; null then
			app.raiseCMWarning4(Planning_Over_Dim_Container, ti.id, self.getFullId, otherTI.id, overSlot.getFullId, null, null, null);
		endif;
	endif;
	
	// check port slot for overwidth tis, and if this ti is overwidth
	portSlot := self.myPortSlot;
	if portSlot &lt;&gt; null then
		otherTI := portSlot.getActualQueuedPlannedLoadTI();
		direction := null;
		request := portSlot.mySlotRequestLoad;
		if request &lt;&gt; null then
			direction := request.doorsDirection;
		endif;
		if otherTI &lt;&gt; null and otherTI.isContainer then
			if (otherTI.CM_Container.overWidthRight &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (otherTI.CM_Container.overWidthLeft &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Next_To_Over_Dim, otherTI.id, portSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
			
			if (ti.CM_Container.overWidthLeft &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (ti.CM_Container.overWidthRight &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Over_Dim_Container, ti.id, self.getFullId, otherTI.id, portSlot.getFullId, null, null, null);
			endif;
		endif;
	endif;
	
	// check starboard slot for overwidth tis, and if this ti is overwidth 
	stbdSlot := self.myStarboardSlot;
	if stbdSlot &lt;&gt; null then
		otherTI := stbdSlot.getActualQueuedPlannedLoadTI();
		direction := null;
		request := stbdSlot.mySlotRequestLoad;
		if request &lt;&gt; null then
			direction := request.doorsDirection;
		endif;
		if otherTI &lt;&gt; null and otherTI.isContainer then
			if (otherTI.CM_Container.overWidthLeft &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (otherTI.CM_Container.overWidthRight &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Next_To_Over_Dim, otherTI.id, stbdSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
			
			if (ti.CM_Container.overWidthRight &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (ti.CM_Container.overWidthLeft &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Over_Dim_Container, ti.id, self.getFullId, otherTI.id, stbdSlot.getFullId, null, null, null);
			endif;
		endif;
	endif;
	
	// check forward slot in same hold
	fwdSlot := self.myForwardSlotInHold;
	if fwdSlot &lt;&gt; null then
		otherTI := fwdSlot.getActualQueuedPlannedLoadTI();
		direction := null;
		request := fwdSlot.mySlotRequestLoad;
		if request &lt;&gt; null then
			direction := request.doorsDirection;
		endif;
		// warning if forward slot door direction is aft and it has a container overlength front
		// or if door direction is forward and it has a container overlength rear
		if otherTI &lt;&gt; null and otherTI.isContainer then
			if (otherTI.CM_Container.overLengthFront &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (otherTI.CM_Container.overLengthRear &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Next_To_Over_Dim, otherTI.id, fwdSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
		endif;
		
		// check this container for overlength, depending on door direction
		if (self.doorDirection = TI_DOORSDIRN_FWD and ti.CM_Container.overLengthFront&lt;&gt; null )
		or (self.doorDirection = TI_DOORSDIRN_AFT and ti.CM_Container.overLengthRear&lt;&gt; null ) then
			if otherTI &lt;&gt; null then
				app.raiseCMWarning4(Planning_Over_Dim_Container, ti.id, self.getFullId, otherTI.id, fwdSlot.getFullId, null, null, null);
			endif;
		endif;
	endif;
	
	// check aft slot in same hold
	aftSlot := self.myAftSlotInHold;
	if aftSlot &lt;&gt; null then
		otherTI := aftSlot.getActualQueuedPlannedLoadTI();
		direction := null;
		request := aftSlot.mySlotRequestLoad;
		if request &lt;&gt; null then
			direction := request.doorsDirection;
		endif;
		// warning if aft slot door direction is aft and it has a container overlength rear
		// or if door direction is forward and it has a container overlength front
		if otherTI &lt;&gt; null and otherTI.isContainer then
			if (otherTI.CM_Container.overLengthRear &lt;&gt; null and direction = TI_DOORSDIRN_AFT)
			or (otherTI.CM_Container.overLengthFront &lt;&gt; null and direction = TI_DOORSDIRN_FWD) then
				app.raiseCMWarning4(Planning_Next_To_Over_Dim, otherTI.id, aftSlot.getFullId, ti.id, self.getFullId, null, null, null);
			endif;
		endif;
		
		// check this container for overlength, depending on door direction
		if (self.doorDirection = TI_DOORSDIRN_FWD and ti.CM_Container.overLengthRear &lt;&gt; null )
		or (self.doorDirection = TI_DOORSDIRN_AFT and ti.CM_Container.overLengthFront &lt;&gt; null ) then
			if otherTI &lt;&gt; null then
				app.raiseCMWarning4(Planning_Over_Dim_Container, ti.id, self.getFullId, otherTI.id, aftSlot.getFullId, null, null, null);
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateSlotRequestMoveFrom" id="75ae7d65-143c-4db5-a6e3-ea9d15400b25">
        <source>validateSlotRequestMoveFrom(control : CMIF_MoveController) protected;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tmpRequestDich	: CM_SlotRequest;
	moveTI, dischargeTI : CM_TrackedItem;
begin
	moveTI := control.myTrackedItem;
	
	tmpRequestDich := self.mySlotRequestDischarge;
	if tmpRequestDich = null then
		if (not self.isOnboardMove(control)) and 
		   control.moveMode = REAL_MODE and
		   control.myToPrimaryLocation &lt;&gt; null then		// added as doing a shuffle moves to null before moving back in correct order
			if control.isForcedMove = false then
				app.raiseCMException5(Err_NoColourCode, self.getFullId, app.getErrorString(Discharge), app.getErrorString(Discharge), moveTI.id, 'from this slot', null, null);
				return;
			endif;
		endif;
	else
		dischargeTI := tmpRequestDich.getTrackedItem();
		// only stop the instant move if the discharge CC is for the TI that we are moving
		if self.isOnboardMove(control) 
		and control.moveMode = REAL_MODE
		and moveTI = dischargeTI
		and (not tmpRequestDich.isComplete)
		//and (not tmpRequestDich.isSOB)																	//cnwmc5 - PAR 31050
		and (not dischargeTI.directDelivery)	//07 Feb 2013	NDL	Par 31102
		then 
			if tmpRequestDich.isSOB then																	//cnwmc5 - PAR 31050
				if tmpRequestDich.myJob = null then															//cnwmc5 - PAR 31050
					app.raiseCMException2(Err_SeqNoJob, self.getLocationId(null, dischargeTI), app.getErrorString(Discharge), null, null);	//cnwmc5 - PAR 31050
					return;																					//cnwmc5 - PAR 31050
				endif;																						//cnwmc5 - PAR 31050
			else																							//cnwmc5 - PAR 31050
				app.raiseCMException1(SlotMarkedForDischCannotMove, self.getLocationId(null, dischargeTI), null, null);		//cnwmc5 - PAR 31050
				return;																						//cnwmc5 - PAR 31050
			endif;																							//cnwmc5 - PAR 31050
		endif;
		
		if control.moveMode &lt;&gt; REAL_MODE
		and tmpRequestDich.myJob = null
		and control.isForcedMove = false
		and control.myToPrimaryLocation &lt;&gt; null then
			if tmpRequestDich.moveType = NULL_MOVETYPE then
				return;
			else
				app.raiseCMException4(Err_SeqNoJob, self.getStowageId(moveTI), 'discharge', moveTI.id, 'from', null, null);
				return;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateSlotRequestMoveTo" id="7367364c-6992-4c47-b7d4-769b71149ac7">
        <source>validateSlotRequestMoveTo(_control : CMIF_MoveController input) protected;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls														
------------------------------------------------------------------------
*/
vars
	fwdSlotRequest : CM_SlotRequest;
	aOK : Boolean;
	sr : CM_SlotRequest;
	ti	: CM_TrackedItem;
begin
	//We are moving TO this slotController, therefore we MUST have a load colour code
	//OR be forcing the move
	if _control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is an EDI move, ignore this stuff
		return;
	endif;
	sr := self.mySlotRequestLoad;
	if sr = null then
		if self.isOnboardMove(_control) = false then	//If its not an onboard instant move...
			app.raiseCMException5(Err_NoColourCode, self.getFullId, app.getErrorString(Load), app.getErrorString(Load), _control.myTrackedItem.id, 'to this slot', null, null);
		endif;
		return;
	endif;
	
	// PAR 31878
	if _control.moveMode = PLANNING_MODE then
		if self.isOnboardMove(_control) = false then	//If its not an onboard instant move...
			if _control.myWorkListEntry = null then
				app.raiseCMException(Work_list_entry_ref,null, null);
				
			endif;
		endif;
	endif;
	
	if _control.moveMode = REAL_MODE then
		if sr.moveType = NULL_MOVETYPE then // AKB2003MAR added
			return;
		else
			
			if sr.myJob = null 
			and _control.isForcedMove = false
			and self.isOnboardMove(_control) = false then
				aOK := false;
				// we have slot requests for the back ends of 40's but that slot request has no WLEs no job and no TI so check the forward slot for a 40 colour coded up
				if self.myBayVoyage.isAftBay then
					fwdSlotRequest := self.myForwardSlot.mySlotRequestLoad;
					if fwdSlotRequest &lt;&gt; null  and fwdSlotRequest.myJob &lt;&gt; null then
						if (fwdSlotRequest.getAttrIs40()) 
						or fwdSlotRequest.isOversizedFrontend then // PAR 17829
							aOK := true;
						endif;
					endif;
				endif;
				if not aOK then
					app.raiseCMException4(Err_SeqNoJob, self.getStowageId(_control.myTrackedItem), 'load', _control.myTrackedItem.id, 'to', null, null);
					return;
				endif;
			endif;
		endif;
	endif;
	// AKB2003NOV. When planning to the ship, i.e. LOAD colour coding, we have already validated the TI
	//					against the SlotRequest as part of assigning it to the job and the WLE, so do not do it again, 
	//					also we get the backend of 40s validating as well
	if _control.moveMode &lt;&gt; PLANNING_MODE then 
		sr.validateMoveTo(_control);
	else
		if (_control.myTrackedItem &lt;&gt; null) and
		   (_control.myTrackedItem.state = TI_STATE_NOTIFIED) then
			app.raiseCMWarning1(ERR_PLANMOVE_PRENOTE, _control.myTrackedItem.id, null, null, _control.myTrackedItem);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
