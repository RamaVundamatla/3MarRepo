<Class name="CM_SnapshotField_Average" id="43b41ebb-6a0a-4886-9c64-95fa092442cd">
    <superclass name="CM_SnapshotField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="snapshots"/>
    <PrimAttribute name="count" id="bf6f2067-d646-4740-907c-838427057a73">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sum" id="e48a0151-e3cd-4eec-b0dc-e4c22c95f252">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="440de72b-3f6e-47c8-98dc-a70fbe50c99b">
        <source>getValue(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation

*/

vars
	value	:Decimal[23,8];
begin
	if self.count = 0 then	
		return null;		
	endif;					
	
	value := self.sum/self.count;		
	
	if value = 0 then		
		return null;		
	endif;					
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXTABFieldFunction" id="7fd15044-fd57-479e-a2c3-e4c5ea49dc83">
        <source>getXTABFieldFunction(): Integer;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_XTABField.Function_Average;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCmifAndXtabFields" id="b9e0eb01-54e8-46af-8c7b-97ff9c4a97ed">
        <updating/>
        <source>setFromCmifAndXtabFields(_cmifField: CMIF_OutputField; _xtabField: CM_XTABField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	inheritMethod(_cmifField, _xtabField);
	
	self.count := _cmifField.CMIF_OutputField_Average.count;
	self.sum := _cmifField.CMIF_OutputField_Average.sum;

epilog

end;</source>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <Parameter name="_xtabField" type="CM_XTABField"/>
    </JadeMethod>
</Class>
