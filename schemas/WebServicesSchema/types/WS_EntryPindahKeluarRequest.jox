    <JadeMethod name="getExtVoyageCode" id="e3fd67c9-3923-451d-8902-7934ce901529">
        <source>getExtVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2019	jlger1	Initial creation

*/

vars

begin
	return self.nomorPkk;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOutgoingVoyageStatus" id="e943f10e-7720-47bd-a2ec-f8587c9d394b">
        <source>getOutgoingVoyageStatus(_voyage: CM_Voyage): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	currentStatus : Integer;
	voyStatus : CM_VoyageStatus;

begin

	if _voyage &lt;&gt; null then
		currentStatus := _voyage.status;
	endif;
	
	if self.jenisGerakan.toUpper = "PINDAH" then		 // Think this is a move to another berth
		// If it is for shift
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftReqIPN );
	elseif self.jenisGerakan.toUpper = "KELUAR" then	// And this must be a departure
		// if it is for departure
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IDepServRequest );
	endif;

	return voyStatus;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="dbd4634a-e878-4599-a3cb-70a774014307">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	pelindo1VoyProcess : CM_VoyageProcess;
	includeLessThanPriorityValue : Integer;
	voyageStatus : CM_VoyageStatus;

begin

	//Any with Priority less than the Priority of Voyage_Status_IDepServPending 

	voyageStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IDepServPending );
	if voyageStatus &lt;&gt; null then
		pelindo1VoyProcess := voyageStatus.myProcess;
	
		includeLessThanPriorityValue := voyageStatus.priority;
	
		foreach voyageStatus in pelindo1VoyProcess.allStatusesById do
			if voyageStatus.priority &gt;= includeLessThanPriorityValue then
				break;
			endif;
			_validStatuses.add( voyageStatus.id );
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="547b7050-21b1-4a1e-9f53-6631306a1497">
        <source>processMessage(  _voyage : CM_Voyage input; _startTS : TimeStamp; _endTS : TimeStamp; _fromBerth : HMS_Berth io; _toBerth : HMS_Berth io );
/*           SHIFT OR DEPARTURE WORK ORDER

Purpose:			

Parameters:	
"	This is the INAPORTNET Web Service equivalent functionality to creating a Marine Services Request for a Shift or Departure.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Departure Marine Services Pending" status, otherwise the request will be rejected.
"	Update should mirror that in the current JMTUserInterfaceService::updateHMSResourcesUsed message if everything is OK.
		

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135
13 Nov 2018	jlger1	TFS 41880 - create the permit requests as well
20 Nov 2018 jlger1	TFS 41880 - changed there mind not creating permits now
08 Dec 2018 jlger1	TFS 42253 - for shift it was getting wrong resources
19 Dec 2019 jlgka1	TFS 48084 - PEL1 Shifting dont get ETMAL (Inaportnet).
*/

vars
	voyage : CM_Voyage;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	pxyResourceUsed : HMS_ResourceUsed;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	nextVoyStatus : CM_VoyageStatus;
	pilotTS : TimeStamp;
	tugTS,
	tugToTS : TimeStamp;
	isShift : Boolean;
	hmsResourceStatus : CM_VoyageStatus;
	pxyPermitWorkOrder,
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderShift : CM_WodShiftMovement;
	realWorkOrder : CM_WorkOrder;
	pxyPermit  	: CM_WodPermitRequest;
	inaportnetProcess : CM_VoyageProcess;
	processHarbour : CM_ProcessHarbour;
	resourceColl : HMS_ResourceByTypeDict;
begin
	isShift:= self.jenisGerakan.toUpper = "PINDAH" ;
	hmsResourceStatus := app.myRoot.allVoyageStatuses[Voyage_Status_IDepServPending];
	if  isShift then
		inaportnetProcess := app.myRoot.allVoyageProcesses[VoyageProcessInaportnet];	
		processHarbour := inaportnetProcess.allProcessHarbours[inaportnetProcess,app.myPassport.myTerminal.myHarbour];
		if processHarbour &lt;&gt; null then
			resourceColl := processHarbour.allHMSResourcesForShift;
		endif;
	else	
		
		resourceColl := hmsResourceStatus.allHMSResourcesAllowed;
	endif;
	//epr TFS 40629 7/9/18
	voyage := _voyage;
	nextVoyStatus := self.getOutgoingVoyageStatus( voyage );

	create allPxyHMSResourcesUsed transient;
		
	//9. Pilot Date, Optional
	//self.tanggalPandu
	//10. Pilot Time, Optional
	//self.jamPandu
	if self.tanggalPandu &lt;&gt; null then
		if resourceColl &lt;&gt; null then	//jlgka1 TFS 48084
			resource := resourceColl.getHMSResourceForClass(app.myPassport.myTerminal.myHarbour,HMS_ResourceForPilot);
			if resource &lt;&gt; null then
				pilotTS.setDate( self.tanggalPandu.asDateFromInaportnet );
				pilotTS.setTime( self.jamPandu.asTimeFromInaportnet );
				
				create pxyResourceUsed transient;
				allPxyHMSResourcesUsed.add( pxyResourceUsed );
				
				if resource &lt;&gt; null then
					resourceType:=resource.myResourceType;
				endif;
			
				
				pxyResourceUsed.setProxy(	app.myPassport.myTerminal.myHarbour,	//_harbour : HMS_Harbour;
											resourceType,	//_resourceType : HMS_ResourceType;
											resource,	//_rescource : HMS_Resource;
											null,	//_pxyVTMISTrans : HMS_VTMISTransaction;
											pilotTS,	//_fromDateTime : TimeStamp;
											null,	//_toDateTime : TimeStamp;
											1,	//_unitsUsed : Real;
											null,	//_poc : Boolean;
											null,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
											null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
											);
			endif;
		endif;
	endif;
	
	//11. Tug Date, Optional
	//self.tanggalTunda
	
	//12. Tug Time, Optional
	//self.jamTunda
	if self.tanggalTunda &lt;&gt; null then
		if resourceColl &lt;&gt; null then	//jlgka1 TFS 48084
			resource := resourceColl.getHMSResourceForClass(app.myPassport.myTerminal.myHarbour,HMS_ResourceForTug);
			if resource &lt;&gt; null then
				tugTS.setDate( self.tanggalTunda.asDateFromInaportnet );
				tugTS.setTime( self.jamTunda.asTimeFromInaportnet );
				
				create pxyResourceUsed transient;
				allPxyHMSResourcesUsed.add( pxyResourceUsed );
				if resource &lt;&gt; null then
					resourceType:=resource.myResourceType;
				endif;
				tugToTS:=tugTS;
				if _toBerth &lt;&gt; null and _toBerth.defaultTugUsageHours &gt; 0 then 
				//	tugToTS:=tugTS.addDecimalDays(_toBerth.defaultTugUsageHours);
					tugToTS := tugTS.addMinutes( (_toBerth.defaultTugUsageHours * 60).rounded );	//25 Jan 2019	NDL	TFS 43085
				endif;
				
				pxyResourceUsed.setProxy(	app.myPassport.myTerminal.myHarbour,	//_harbour : HMS_Harbour;
											resourceType,	//_resourceType : HMS_ResourceType;
											resource,	//_rescource : HMS_Resource;
											null,	//_pxyVTMISTrans : HMS_VTMISTransaction;
											tugTS,	//_fromDateTime : TimeStamp;
											tugToTS,	//_toDateTime : TimeStamp;
											1,	//_unitsUsed : Real;
											null,	//_poc : Boolean;
											null,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
											null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
											);
			endif;
		endif;
	endif;
	
	
	if isShift then	
		
		create pxyWorkOrder  transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(voyage);
		//pxyWorkOrder.setLengthOfTime(etmal);
		if voyage = null then
			pxyWorkOrder.setVoyageExternalCode(nomorPkk);
		endif;
		
		create pxyWorkOrderShift transient;
		pxyWorkOrder.allWoDtls.add(pxyWorkOrderShift);
	//	pxyWorkOrderShift.setProxyWodShiftMovement(null,null,null,_endTS,0,0,0,0,_fromBerth,_toBerth,null,null, false, false, null);// TFS 40236 new params
		pxyWorkOrderShift.setProxyWodShiftMovement(null,null,null,_startTS,0,0,0,0,_fromBerth,_toBerth,null,null, false, false, _endTS);	//25 Jan 2019	NDL	TFS 43085
													
		pxyWorkOrderShift.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);
		
		
		app.myPassport.setWarningsIgnored( true);
		app.myPassport.setWarningsAcknowledged( true);
		app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
	
	/*	//epr TFS 41880 13/11/18
		create pxyPermitWorkOrder transient;
		pxyPermitWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
		pxyPermitWorkOrder.setMyVoyage(voyage);
		if voyage = null then
			pxyPermitWorkOrder.setVoyageExternalCode(nomorPkk);
		endif;
	
		create pxyPermit transient;
		pxyPermit.setProxyPermitRequest(null,WO_TASK_VOY_SHIFTMOVEMENT,null,null);
		pxyPermit.setMyPermitWodVoyageDetail(realWorkOrder.allWoDtls.first.CM_WorkOrderVoyageDtl);
		pxyPermitWorkOrder.allWoDtls.add(pxyPermit);
	
		app.myPassport.setWarningsIgnored( true);
		app.myPassport.setWarningsAcknowledged( true);
		app.myTrxCA.trxCreateWorkOrder(pxyPermitWorkOrder,realWorkOrder,app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;*/
	
		if voyage &lt;&gt; null and nextVoyStatus &lt;&gt; null  then		
			app.myPassport.setWarningsIgnored(true);
	
			app.myTrxUA.trxUpdateVoyageVoyageStatus(voyage,nextVoyStatus.id,true,app.myPassport);
		endif;	
	else
			
		app.myTrxUA.trxUpdateHMSResourcesUsed( allPxyHMSResourcesUsed, voyage,self.nomorPkk   ,hmsResourceStatus.id, _toBerth,
																			null,null, nextVoyStatus, 
																			0,0,0,false,false, // TFS 40236
																			app.myPassport );
	endif;
	

epilog
	
	delete pxyWorkOrder;
	delete pxyPermitWorkOrder;
	
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
		delete allPxyHMSResourcesUsed;
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_fromBerth" type="HMS_Berth" usage="io"/>
        <Parameter name="_toBerth" type="HMS_Berth" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="7a6e3c02-10bc-4a43-865f-8ac96f1c86d0">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output; _startTS : TimeStamp output; _endTS : TimeStamp output; _fromBerth : HMS_Berth output; _toBerth : HMS_Berth output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	term : CM_Terminal;
	date : Date;
	time : Time;
	harbour : HMS_Harbour;
begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	

	term := app.myPassport.myTerminal;
	
	
	//3. self.nomorPkk
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);	
	//epr TFS 40629 7/9/18
	
	//5. Start Date, Mandatory
	date:=self.tanggalMulai.asDateFromInaportnet;
	if not date.isValid then
		app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryPindahKeluarRequest::tanggalMulai.name, null, null); 
	endif;
	
	//6. Start Time, Mandatory
	time:=self.jamMulai.asTimeFromInaportnet;
	if not time.isValid then
		app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryPindahKeluarRequest::jamMulai.name, null, null); 
	endif;
	
	_startTS.setDate( date );
	_startTS.setTime( time );
	
	//7. Finished Date, Mandatory
	date:=self.tanggalSelesai.asDateFromInaportnet;
	if not date.isValid then
		app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryPindahKeluarRequest::tanggalSelesai.name, null, null); 
	endif;
	
	
	//8. Finished Time, Mandatory
	time:=self.jamSelesai.asTimeFromInaportnet;
	if not time.isValid then
		app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryPindahKeluarRequest::jamSelesai.name, null, null); 
	endif;

	_endTS.setDate( date );
	_endTS.setTime( time );
	
	if not app.myPassport.hasErrors then
		if _startTS &gt;= _endTS then
			app.raiseCMException2(ERR_DateRangeInvalid, WS_EntryPindahKeluarRequest::tanggalMulai.name &amp; "/" &amp; WS_EntryPindahKeluarRequest::jamMulai.name,
										WS_EntryPindahKeluarRequest::tanggalSelesai.name &amp; "/" &amp; WS_EntryPindahKeluarRequest::jamSelesai.name, null, null);
		endif;
	endif;
	
	
	//9. Pilot Date, Optional
	//self.tanggalPandu
	
	//10. Pilot Time, Optional
	//self.jamPandu
	if self.tanggalPandu &lt;&gt; null then
		date:=self.tanggalPandu.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryPindahKeluarRequest::tanggalPandu.name, null, null); 
		endif;
		time:=self.jamPandu.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryPindahKeluarRequest::jamPandu.name, null, null); 
		endif;
	endif;
	
	
	
	//11. Tug Date, Optional
	//self.tanggalTunda
	
	//12. Tug Time, Optional
	//self.jamTunda
	//epr TFS 44692 13/5/19
	if self.tanggalTunda &lt;&gt; null then
		date:=self.tanggalTunda.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryPindahKeluarRequest::tanggalTunda.name, null, null); 
		endif;
		time:=self.jamTunda.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryPindahKeluarRequest::jamTunda.name, null, null); 
		endif;
	endif;
	
	
	//13. Starting Location, Mandatory	dock, sea, anchored area
	_fromBerth := self.getBerth( self.lokasiAsal );
	if _fromBerth = null then
		//The value '%1' in the field '%2' did not resolve to a '%3' in JMT.
		app.raiseCMException3(Value_field_not_resolve, self.lokasiAsal, WS_EntryPindahKeluarRequest::lokasiAsal.name, app.getErrorString(Berth), null, null);
	endif;
	
	//14. Destination, Mandatory	dock, sea, anchored area
	_toBerth := self.getBerth( self.lokasiTujuan );
	if _toBerth = null then
		if self.lokasiTujuan = "LAUT" then //to sea 
			harbour:= term.myHarbour;
			if harbour &lt;&gt; null then
				_toBerth:=harbour.getDefaultBerthForMoveType(HMSMovementTypeDeparture);
			endif;
		endif;
		if _toBerth = null then
		//The value '%1' in the field '%2' did not resolve to a '%3' in JMT.
			app.raiseCMException3(Value_field_not_resolve, self.lokasiTujuan, WS_EntryPindahKeluarRequest::lokasiTujuan.name, app.getErrorString(Berth), null, null);
		endif;
	endif;
	
	
	//15. Type of Action, PINDAH / KELUAR    move or out.
	if self.jenisGerakan &lt;&gt; null then
		if self.jenisGerakan.toUpper &lt;&gt; "PINDAH"
		and self.jenisGerakan.toUpper &lt;&gt; "KELUAR"
		then
			app.raiseCMException3(Value_field_not_resolve, self.jenisGerakan, WS_EntryPindahKeluarRequest::jenisGerakan.name, "'PINDAH' or 'KELUAR'", null, null);
		endif;
	endif;
	

epilog

	return not app.myPassport.hasErrors;


end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_endTS" type="TimeStamp" usage="output"/>
        <Parameter name="_fromBerth" type="HMS_Berth" usage="output"/>
        <Parameter name="_toBerth" type="HMS_Berth" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="c2a79718-a867-49fb-b276-ef3d5e26df9b">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of PKK, (voyage notification) Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::nomorPkk.name, null, null);
	endif;
	
	//4. Number of PPKB, (Request for Vessel service) Optional
	// self.nomorPpk
	
	//5. Start Date, Mandatory
	if self.tanggalMulai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::tanggalMulai.name, null, null);
	endif;
	
	//6. Start Time, Mandatory
	if self.jamMulai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::jamMulai.name, null, null);
	endif;
	
	//7. Finished Date, Mandatory
	if self.tanggalSelesai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::tanggalSelesai.name, null, null);
	endif;
	
	//8. Finished Time, Mandatory
	if self.jamSelesai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::jamSelesai.name, null, null);
	endif;
	
	//9. Pilot Date, Optional
	//self.tanggalPandu
	
	//10. Pilot Time, Optional
	//self.jamPandu
	
	//11. Tug Date, Optional
	//self.tanggalTunda
	
	//12. Tug Time, Optional
	//self.jamTunda
	
	//13. Starting Location, Mandatory	dock, sea, anchored area
	if self.lokasiAsal = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::lokasiAsal.name, null, null);
	endif;
	
	//14. Destination, Mandatory	dock, sea, anchored area
	if self.lokasiTujuan = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::lokasiTujuan.name, null, null);
	endif;
	
	//15. Type of Action, PINDAH / KELUAR    move or out.
	if self.jenisGerakan = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPindahKeluarRequest::jenisGerakan.name, null, null);
	endif;
	
	//16. self.portCode - Checked in superClass ::validareCredentials

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
