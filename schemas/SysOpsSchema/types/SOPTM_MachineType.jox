    <JadeMethod name="doActionBtnSetDefault1" id="0626d1dd-aa62-499c-b0fb-922a4d93d85b">
        <updating/>
        <source>doActionBtnSetDefault1(pObj: Object) updating;

// cnwdvb1 25 June 2003 

vars

	machineType : CM_MachineType;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	machineType := pObj.CM_MachineType;
	if app.msgBox("Would you like to apply these terminal areas types to all machines of this type on site?", "Apply Terminal Area Changes", MsgBox_Yes_No) = MsgBox_Return_Yes then
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxSetAllowedTAFromMachineType(machineType, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Default Terminal Area Access', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
        <Parameter name="pObj" type="Object"/>
    </JadeMethod>
