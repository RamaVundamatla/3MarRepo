    <JadeMethod name="getPlannedRailLine" id="9ae3f494-13a2-439c-a0c7-dcf82170f2a5">
        <source>getPlannedRailLine() : CM_RailLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2022	jlier1	Initial creation 54366

*/

vars
	locationStrs,remainingStrs : StringArray;
	terminal : CM_Terminal;
	allTAs : CM_TerminalAreaSet;
	ta : CM_TerminalArea;
	railLine : CM_RailLine;
begin
	if self.plannedLocn = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;
	create locationStrs transient;
	self.plannedLocn.getTokensForDelimiter(Space,locationStrs);
		 
	if locationStrs.size = 0 then
		return null;
	endif;
	create remainingStrs transient;
	create allTAs transient;
	terminal.findTAFromString(locationStrs,remainingStrs,true,allTAs);
	
	ta:=allTAs.first;
	if ta = null or allTAs.size &gt; 1 then
		return null;
	endif;
	
	if not ta.isKindOf(CM_Rail) then
		return null;
	endif;
	
	if locationStrs.size = 1 then
		return ta.CM_Rail.allRailLines.first;
	endif;
	
	railLine:=ta.CM_Rail.allRailLines[locationStrs[2].trimBlanks];
	return railLine;
	
epilog
	delete locationStrs;
	delete remainingStrs;
	delete allTAs;
end;</source>
        <ReturnType type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="hasSealData" id="aa0993d0-b4b4-45dc-808c-f1410bddb181">
