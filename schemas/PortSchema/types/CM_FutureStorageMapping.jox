    <JadeMethod name="setProxy" id="5d77907a-4f3c-4e59-a1ff-3652d2371b71">
        <updating/>
        <source>setProxy(_storageGroup : CM_TerminalAreaStorageGroup; _invoiceLineType : CM_InvoiceLineDesc; _storageDetail : CM_StorageDetail; _quantityMap : CM_QuantityMap) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
vars

begin
	
	self.myStorageGroup := _storageGroup;
//	self.myInvoiceLineType := _invoiceLineType;
//	self.myStorageDetail :=	_storageDetail;
	self.setStorageDetail(_storageDetail); //19 May 2016	NDL TFS 1981
	self.myQuantityMap := _quantityMap; // PAR 36275

end;</source>
        <Parameter name="_storageGroup" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_invoiceLineType" type="CM_InvoiceLineDesc"/>
