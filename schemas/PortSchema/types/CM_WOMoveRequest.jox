    <JadeMethod name="createWLEs" id="08baf912-d9ab-4cff-b5d5-62a084491eec">
        <source>createWLEs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwrd1	Initial creation

*/

vars
	collStart : Integer;
	collSize : Integer;
	totalRequested : Integer;
	ti : CM_TrackedItem;
	i : Integer;
	wle : CM_WorkListEntry;
	iter : Iterator;
begin

	if self.myJob = null then
		return;
	endif;
	
	if not CM_YardInternalJob.hasInstance(self.myJob) then
		return;
	endif;


	collSize := self.allWorkListEntries.size; // atm we are just creating these and not updating so cant see us adding any as yet
	totalRequested := self.getTotalRequested();
	
	iter := self.myJob.CM_YardInternalJob.allTrackedItems.createIterator();
	
	//need to create totalRequested WLE's but create them for any associated job.alltrackeditems first then create empty ones
	
	i := 1;
			
	while iter.next( ti ) do	

		if (i &gt; totalRequested) then
			break;
		endif;
		
		wle := self.createYardWLE(self, WLE_UNACTIONED, ti);
		self.myJob.myWODtl.setTIActioned(ti, false);
		wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);				  	
		i := i + 1;		
	
	endwhile;
	
	//then if we need more create empty ones
	
	while i &lt; totalRequested+1 do
	
		wle := self.createYardWLE(self, WLE_UNACTIONED, null);
		wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);				  	
		i := i + 1;		
		
	endwhile;
	
	/*

	if collSize &gt; 0 then
		if totalRequested = collSize then
			return;
		else
			if (collSize &gt; totalRequested) then
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_HAS_WL_ENTRIES, null, null);
				return;				
			endif;
			collStart := collSize;
		endif;
	endif;

	ti := self.getTrackedItem();
	//OK, we have the request Struct, depending on what it is, produce wl entries.
	if ti = null then
		i := collStart;
		while (i &lt; totalRequested) do
			wle := self.createYardWLE(self, WLE_UNACTIONED, ti);
			i := i + 1;
		endwhile; //wle
	else
		resynchObject(ti);
		wle := self.createYardWLE(self, WLE_UNACTIONED, ti);
	endif;

*/
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="165d6765-e13c-4faf-98ba-e11933006690">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwrd1	Initial creation
// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if _attrName = ETRow_RequiredByDT then
		return self.systemToLocalTime(self.requiredByDT).date.String;// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_CargoDetails then
		return null;
	elseif _attrName = ETRow_DischargePort then //cnwrd1par 27017
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="f6b1f85f-7de9-4d02-a1eb-261d56a6448f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwrd1	Initial creation

*/


vars
	block : CM_DataContainerBlock;
	idx	: Integer;
	operCodes,
	str : String;

begin
	inheritMethod(_dataContainer);


	//str := self.getIdsAsString.trimBlanks;
	//str.replaceChar(Cr," ");

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Additional_Information), DC_Label, 1, null);
	block.addNewItem(str, DC_Data, 1, null);
		
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Total_Requested), DC_Label, 1, null);
	block.addNewItem(self.totalRequested.String, DC_Data, 1, null);
	


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
