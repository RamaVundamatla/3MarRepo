<Class name="CM_PackTempReading" id="32045aa2-7325-4390-afa4-9338505b2537">
    <superclass name="CM_TempReading"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Abstract class will be used in future for recording one off temperature readings</text>
    <DbClassMap file="discrep"/>
    <PrimAttribute name="displayTempFahrenheit" id="fcdd10f8-e5de-4463-9b20-ef8364e412f8">
        <embedded/>
        <virtual/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="tempC" id="6323a7d0-aa29-4211-a0ec-ad48ff637286">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="tempF" id="2ae5d51b-e14f-4b5c-82ce-f28be3dac551">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <JadeMethod name="displayTempFahrenheit" id="c98435fb-9813-420f-b490-f98433ca3411">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>displayTempFahrenheit(set: Boolean; value: Boolean io) mapping, updating;
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		value := false;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="684a8815-bba9-4ef1-bcf2-43fbedf61ea9">
        <updating/>
        <source>setForUpdate(proxy : CM_PackTempReading) updating;

vars

begin
	tempC 		:= proxy.tempC;
	tempF 		:= proxy.tempF;
	dateTime 	:= proxy.dateTime;
end;</source>
        <Parameter name="proxy" type="CM_PackTempReading"/>
    </JadeMethod>
</Class>
