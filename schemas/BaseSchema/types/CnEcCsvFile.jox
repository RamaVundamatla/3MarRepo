____________________________________________________________________________

This subclass of the File class is for reading CSV formatted files.
If the fields in the file records are enclosed within double-quotes,
then the quotes will be stripped out as each field is loaded.

Methods
-------

1. loadCsvFile(pFileDef:CnEcFileDefinition; pShowProgress:Boolean) updating;

	Use this method to read the disk file.  Create an instance of the
	CnEcFileDfinition class and send it to this method, along with a
	boolean value to indicate whether to show a progress dialog.  Note
	that it is not neccessary to explicitly open and close the disk file,
	as this method will handle all such operations.

	Once the file has been read and loaded, the instance of CnEcFileDefinition
	will be returned with colections of the records and their fields.

Properties
----------

1.	isCancelled - Indicates whether the User cancelled reading the file. Note
	that the 'rowArray' property will still contain all of the records that
	have been read upto the point where the User cancelled the operation.

2.	headerIdentifier - Set this (String) property to specify a value which
	indicates that a file record is the header record.  If this property
	is set, the "headerFieldNo" property should also be set.

3.	headerFieldNo - Set this property to specify which field in a record
	indicates that it is the header record.  If this property is set, the
	"headerIdentifier" property should also be set.

4.	trailerIdentifier - Set this (String) property to specify a value which
	indicates that a file record is the trailer record.  If this property
	is set, the "trailerFieldNo" property should also be set.

5.	trailerFieldNo - Set this property to specify which field in a record
	indicates that it is the trailer record.  If this property is set, the
	"trailerIdentifier" property should also be set.

When identifying a header or trailer record, the identifying (String) value
(headerIdentifier or trailerIdentifier) will be compared against the value
that is read from the specified field number (headerFieldNo or trailerFieldNo)
and, if the value matches, then a reference to that record object (an instance
of CnEcFileRecord) will be updated to the "myHeaderRecord" or "myTrailerRecord"
property of the CnEcFileDefinition object.  If a header record is identitied,
then subsequent reads of other records will use the field values from the header
recod for the fieldName property of each CnEcFileField object.


The following is an example of how this class may be used:

vars
	csvFile	: CnEcCsvFile;
	fileDef	: CnEcFileDefinition;
	record	: CnEcFileRecord;
	field	: CnEcFileField;

begin
	app.mousePointer	:=	Busy;
	create csvFile;
	csvFile.headerFieldNo		:=	1;
	csvFile.headerIdentifier	:=	"H";
	create fileDef transient;

	fileDef.set("swans.csv", "c:\temp\swans.csv", "c:\temp\");
	csvFile.loadCsvFile(fileDef, true);

	if (csvFile.isCancelled) then
		write "The file load was cancelled.";
		return;
	endif;

	foreach record in fileDef.allRecords do
		foreach field in record.allFields do
			write record.recordNo.String &amp; ": " &amp; field.fieldName &amp; "=" &amp; field.fieldValue;
		endforeach;

		// Alternatively, we could simply get a string of all fields delimited by a
		// specified character.  In this case, a "|" is used as the delimiter.

		write record.recordNo.String &amp; ": " &amp; record.getDelimitedRecord("|");

	endforeach;

epilog
	delete csvFile;
	delete fileDef;		// This will also delete the collections of Records and Fields.
	app.mousePointer	:=	Idle;
end;</text>
    <DbClassMap file="basemap"/>
    <PrimAttribute name="headerFieldNo" id="6248fa38-ebd4-459d-99f1-9036d67e313a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="headerIdentifier" id="8f3dac75-d456-43ac-a938-4ec63e67b658">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isCancelled" id="874a4755-f3de-4097-b88e-e7b6c58e9602">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="trailerFieldNo" id="613e107a-582a-4f3f-969a-05532342c71b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="trailerIdentifier" id="992f6d83-0f23-4bb6-9b75-502dda325432">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="clearCancelled" id="8231b97a-a10d-4da3-beb8-20452fc706ab">
        <updating/>
        <source>clearCancelled() updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2005 by cnwdad1
//
// Purpose:		Clears the "isCancelled" flag on the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCancelled	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcCreateIniFile" id="545bb757-feca-4139-8cdd-aea67750bc24">
        <source>cnEcCreateIniFile(pFileName:String):CnEcIniFile protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Creates a BaseSchema initialization file object and returns it.
//
// Parameters:	pFileName - The name of the file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniFileObj	: CnEcIniFile;

begin
	create iniFileObj transient;
	iniFileObj.set(pFileName);
	return iniFileObj;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="CnEcIniFile"/>
    </JadeMethod>
    <JadeMethod name="cnEcLoadCsvFile" id="7416ffbf-857d-441b-bce2-574f6a669bed">
        <updating/>
        <source>cnEcLoadCsvFile(pFileDefObj:CnEcFileDefinition io; pShowProgress:Boolean; pProgressPercent:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Reads a comma-delimited file (quote-enclosed) into an array of arrays.
//
// Parameters:	pFileDefObj (CnEcFileDefinition) - This is a efinition of the disk file
//					that will be opened and read.
//				pShowProgress (Boolean) - Indicates whether a progress dialog is to be
//					shown whilst the file is being read.
//
//				pProgressPercent (Integer) - Specifies how frequently to refresh the
//					progress bar (as a percent value).
//
// Returns:		pFileDef (CnEcFileDefinition) - Returned as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/08/2000	cnwdad1		Added "pProgressPercent" parameter.  This will determine
//							how frequently to refresh the progress bar by specifying
//							a percent value, e.g. if the value is 10, then the
//							progress bar will be refreshed with every 10 percent
//							of the job that is completed.
// 12/08/2002	cnwdad1		Fixed bug where the updating of the progress form was
//							being done unconditionally.  Added a check of the
//							pShowProgress parameter.
// 17/08/2004	cnwjub1		PAR 10817.
//							(1) Prevent exception 4030 when attempting to calculate
//							percentNowDone if the file length is less than 100 characters.
//							(2) Include the record terminator string length when calculating
//							partsDone.
// --------------------------------------------------------------------------------
constants
	COMMA			: String = ',';
	DOUBLE_QUOTE	: String = '"';

vars
	fieldNo			: Integer;
	fieldPos		: Integer;
	fieldLen		: Integer;
	inString		: String;
	stringLen		: Integer;
	progressFormObj	: CnEcProgressForm;
	eolLength		: Integer;	//PAR 10817
	partsInJobDiv100 : Integer;	// PAR 10817
	partsInJob		: Integer;
	partsDone		: Integer;
	percentLastDone	: Integer;
	percentNowDone	: Integer;

	recordObj		: CnEcFileRecord;
	recordNo		: Integer;
	fieldObj		: CnEcFileField;
	headerRecordObj	: CnEcFileRecord;
	headerField		: Integer;
	headerId		: String;
	trailerField	: Integer;
	trailerId		: String;

begin
	self.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	self.openInput(pFileDefObj.fileName);	// Open the file.
	pFileDefObj.setHeaderRecord(null);
	pFileDefObj.setTrailerRecord(null);
	pFileDefObj.allRecords.purge();
	headerField		:=	self.headerFieldNo;
	headerId		:=	self.headerIdentifier;
	trailerField	:=	self.trailerFieldNo;
	trailerId		:=	self.trailerIdentifier;

	if pShowProgress then
		eolLength	:=	self.endOfLine.length;	// PAR 10817
		partsInJob	:=	self.fileLength();
		partsInJobDiv100	:=	(partsInJob div 100).max(1);	// PAR 10817
		create progressFormObj;
		progressFormObj.startProgress('Reading ' &amp; pFileDefObj.fileName &amp; '...', partsInJob);
		progressFormObj.show();
		partsDone	:=	0;
		progressFormObj.refreshNow();
	endif;
	
	while (not self.endOfFile()) do
		inString	:=	self.readLine;		// Get the (next) file record.
		stringLen	:=	inString.length;	// Get the length of the record.
		fieldPos	:=	1;					// Initialize the field position.
		fieldNo		:=	1;					// Initialize the field number.
		recordNo	:=	recordNo + 1;

		if pShowProgress then
			partsDone	:=	partsDone + stringLen + eolLength;	// PAR 10817
		endif;

		// Create a new array of record fields.

		create recordObj transient;
		recordObj.set(pFileDefObj, recordNo, null, false, false, false);
		headerRecordObj	:=	pFileDefObj.myHeaderRecord;

		// Now scan the record...

		while fieldPos &lt; stringLen do
			fieldLen	:=	inString.pos(COMMA, fieldPos);		// Locate the next subsequent comma (field delimiter).
			fieldLen	:=	fieldLen - fieldPos;				// Get the length of this field.

			if inString.pos(COMMA, fieldPos) = 0 and fieldPos &lt; stringLen then
				// This must be the last field in the record.
				fieldLen	:=	stringLen - fieldPos + 1;
			endif;

			create fieldObj transient;
			fieldObj.set(recordObj, fieldNo, null, inString[fieldPos:fieldLen], false);	// Add this field to the array of fields.

			// If the comma is inside double-quotes, scan ahead in the record for the next double-quote.

			while fieldObj.fieldValue[1] = DOUBLE_QUOTE
			and fieldObj.fieldValue[fieldObj.fieldValue.length] &lt;&gt; DOUBLE_QUOTE
			do
				fieldPos			:=	fieldPos + fieldLen + 1;
				fieldLen			:=	inString.pos(COMMA, fieldPos);
				fieldLen			:=	fieldLen - fieldPos;
				fieldObj.setFieldValue(fieldObj.fieldValue &amp; COMMA &amp; inString[fieldPos:fieldLen]);
			endwhile;

			// String any double-quotes that surround the field value.

			if	fieldObj.fieldValue[1] = DOUBLE_QUOTE and
				fieldObj.fieldValue[fieldObj.fieldValue.length] = DOUBLE_QUOTE then
				fieldObj.setFieldValue(fieldObj.fieldValue[2:(fieldObj.fieldValue.length - 2)]);
			endif;

			// Update the header and trailer record flags.

			if headerField &lt;&gt; 0 and headerId &lt;&gt; null then
				if fieldNo = headerField and fieldObj.fieldValue = headerId then
					recordObj.setIsHeader(true);
				endif;
			endif;

			if trailerField &lt;&gt; 0 and trailerId &lt;&gt; null then
				if fieldNo = trailerField and fieldObj.fieldValue = trailerId then
					recordObj.setIsTrailer(true);
				endif;
			endif;

			// If we're reading a header record, then use each field's value as the field name,
			// otherwise, get the field name from the Header record fields.

			if recordObj.isHeader then
				fieldObj.setFieldName(fieldObj.fieldValue);
			elseif headerRecordObj &lt;&gt; null then
				fieldObj.setFieldName(headerRecordObj.allFields.getAtKey(fieldObj.fieldNo).fieldName);
			endif;

			// Increment positions to the next field position.

			fieldPos	:=	fieldPos + fieldLen + 1;
			fieldNo		:=	fieldNo + 1;
		endwhile;

		// Update the header or trailer reference onthe file definition object.

		if recordObj.isHeader then
			pFileDefObj.setHeaderRecord(recordObj);
		elseif recordObj.isTrailer then
			pFileDefObj.setTrailerRecord(recordObj);
		endif;

		// Update the progress bar (if required).

		if pShowProgress then
			percentNowDone	:=	partsDone div partsInJobDiv100;	// PAR 10817
			
			if (percentNowDone - percentLastDone) &gt;= pProgressPercent then
				progressFormObj.updateProgress(partsDone);
				percentLastDone	:=	percentNowDone;
			endif;

			if progressFormObj.isCancelled then
				self.isCancelled	:=	true;
				return;
			endif;
		endif;
	endwhile;
	
	if pShowProgress then							// cnwdad1 12/08/2002.
		progressFormObj.updateProgress(partsInJob);
	endif;											// cnwdad1 12/08/2002.
epilog
	self.close();

	if progressFormObj &lt;&gt; null then
		progressFormObj.unload();
		delete progressFormObj;
	endif;
end;</source>
        <Parameter name="pFileDefObj" type="CnEcFileDefinition" usage="io"/>
        <Parameter name="pShowProgress" type="Boolean"/>
        <Parameter name="pProgressPercent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcLoadIniFile" id="13d1a861-770a-4418-9c29-43042ffb1063">
        <updating/>
        <source>cnEcLoadIniFile(pFileName:String):CnEcIniFile updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Loads an initialization file into a BaseSchema file structure.
//
// Parameters:	pFileName - The name of the file to load.
//
// Returns:		The BaseSchema initialization file structure.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inString		: String;
	iniFileObj		: CnEcIniFile;
	iniSectionObj	: CnEcIniSection;
	iniElementObj	: CnEcIniKey;
	elementName		: String;
	setPosition		: Integer;

begin
	self.kind   := File.Kind_Unknown_Text; // 1/3/16 cnwmp6 PAR 36286 unicode version
	self.openInput(pFileName);							// Open the disk file.
	iniFileObj	:=	self.cnEcCreateIniFile(pFileName);

	while (not self.endOfFile()) do
		inString	:=	self.readLine.trimBlanks;		// Get the (next) file record.

		if inString &lt;&gt; null then
			if inString[1:1] = "[" then
				iniSectionObj	:=	iniFileObj.createSection(inString[2:(inString.length - 2)]);

			elseif (inString[1:1] &lt;&gt; "/") and (inString[1:1] &lt;&gt; ";") then
				setPosition	:=	inString.pos("=", 1);

				if setPosition &gt; 1 then
					elementName		:=	inString[1:(setPosition - 1)];
					iniElementObj	:=	iniSectionObj.createKey(elementName, null);
				endif;

			endif;
		endif;
	endwhile;

	return iniFileObj;
epilog
	self.close();
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="CnEcIniFile"/>
    </JadeMethod>
</Class>
