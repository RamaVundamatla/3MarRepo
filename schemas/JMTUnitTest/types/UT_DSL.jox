    <JadeMethod name="setSubTerminalAreaDefined" id="965a36a1-715e-41ec-8387-fc779a87a613">
        <source>setSubTerminalAreaDefined( _value : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	subTerm : CM_SubTerminal;
	term	: CM_Terminal;

begin

	term := self.getTerminal();
	
	self.setTerminalConfig(IsSubTerminalAreaDefined, _value);

	if _value then
	
		self.setTerminalConfig(MySubTerminalForExportFull, null);
		self.setTerminalConfig(MySubTerminalForExportMTY, null);
		self.setTerminalConfig(MySubTerminalForImportFull, null);
		self.setTerminalConfig(MySubTerminalForImportMTY, null);
		self.setTerminalConfig(MySubTerminalForStorageFull, null);
		self.setTerminalConfig(MySubTerminalForStorageMTY, null);
		self.setTerminalConfig(MySubTerminalForImportGen, null);
		self.setTerminalConfig(MySubTerminalForExportGen, null);
		self.setTerminalConfig(MySubTerminalForStorageGen, null);
		self.setTerminalConfig(MySubTerminalForOther, null);
		self.setTerminalConfig(MySubTerminalForSourceBulkRoad, null);
		self.setTerminalConfig(MySubTerminalForSourceBulkRail, null);
		self.setTerminalConfig(MySubTerminalForSourceBulkShip, null);
		self.setTerminalConfig(MySubTerminalForSourceBulkPack, null);
		self.setTerminalConfig(MySubTerminalForTargetBulk, null);
		self.setTerminalConfig(MySubTerminalForBOLIn, null);
	
	else
	
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForExportFull, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForExportMTY, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForImportFull, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForImportMTY, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForStorageFull, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForStorageMTY, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForImportGen, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForExportGen, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForStorageGen, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForOther, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForSourceBulkRoad, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForSourceBulkRail, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForSourceBulkShip, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForSourceBulkPack, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForTargetBulk, method, self.currentMethodBeingRun, self, term);
		app.mySaveDataObjsToRestore.restoreSelectedStateData(MySubTerminalForBOLIn, method, self.currentMethodBeingRun, self, term);
	
	endif;

epilog

	abortTransaction;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSystemConfig" id="05715e58-67e6-431a-8180-dc7689d33018">
        <source>setSystemConfig(_code : String; _value : Any) : Any;
//13 November 2008	cnwdw1	
//
vars
	oldSetting: Any;
begin

	oldSetting := app.myRoot.getConfig(_code);
	beginTransaction;
	//getTerminal.setConfig(_code, _value);
	app.myRoot.setConfig(_code, _value, true);
	commitTransaction;
	
	// 12/12/2014 cnwmh5 
