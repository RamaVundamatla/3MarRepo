    <JadeMethod name="subTrxCreateDefaultLocale" id="1b5ac0d9-0c6a-44ce-b146-eefe06603101">
        <source>subTrxCreateDefaultLocale() : CM_Locale protected ;

// ---------------------------------------------------------------------------
// Created:     RBarr 8/8/2006 Create a default locale, based on GC value StandardTextLocale
// ---------------------------------------------------------------------------
vars
	jmtLocale	: CM_Locale;
	localTrx	: Boolean;
begin

	localTrx := (not process.isInTransactionState);
	exclusiveLock(self);
	
	jmtLocale := self.myRoot.allLocales[StandardTextLocaleStr];
	if jmtLocale = null then
		if localTrx then
			beginTransaction;
		endif;
		create jmtLocale persistent;
		jmtLocale.setForCreate(StandardTextLocaleStr, null, false, myRoot);
		if localTrx then
			commitTransaction;
		endif;
	endif;
	
	return jmtLocale;

epilog
	if localTrx then
		// do this regardless to clear any locks
		abortTransaction;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="subTrxLoadFromGlobalConstant" id="73632b3a-9d47-42b3-8a8d-375a5a3699e5">
        <source>subTrxLoadFromGlobalConstant(_category : XLAT_Category; _constant : GlobalConstant): XLAT_TranslatableText ;

// add or update a Translatable Text item(s) from the global constant category
//protect removed as Centreport need access to this using the trxLoadErrMessages for their plugins.
vars
	translationClass	: Class;
	translatableText	: XLAT_TranslatableText;
	number				: Integer;
begin

	if _category.constantCategoryName = EntTableRows then
		// never get here - these are maintained through their own app and deployment process
	else
		translatableText := _category.allTranslatableText[_constant.valueAsInteger];
		
		if translatableText = null then
			create translatableText as _category.myTranslatableTextClass persistent;
		endif;
		translatableText.updateFromConstant(_category, _constant, _category.constantCategoryName);
	
		return translatableText;
	endif;
end;</source>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="XLAT_TranslatableText"/>
    </JadeMethod>
