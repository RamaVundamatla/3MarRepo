    <JadeMethod name="setupCombos" id="34d4f525-f101-4d5c-91b6-fdca163eb588">
        <updating/>
        <source>setupCombos() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth, wa : CM_WeighAuthority;
	authTerm : CM_WeighAuthTerminal;
	iter : Iterator;
	idx : Integer;

begin
	self.cmbCertify.clear;
	self.cmbAuthor.clear;
	foreach weighAuth in app.myRoot.allWeighAuthorities discreteLock do
		if weighAuth.notAvailableForUse then
			continue;
		endif;
		if weighAuth.allWeighAuthTerminals[self.myTerminal] &lt;&gt; null then
			idx := self.cmbCertify.addItem(weighAuth.certifiedName);
			self.cmbCertify.itemObject[idx] := weighAuth;
		endif;
	endforeach;
	authTerm := self.myTerminal.getDefaultWeighAuthority();
	if authTerm &lt;&gt; null then
		weighAuth := authTerm.myWeighAuthority;
		iter := app.myRoot.allWeighAuthorities.createIterator;
		app.myRoot.allWeighAuthorities.startKeyGeq(weighAuth.certifiedName, null, iter);
		while iter.next(wa) do
			if wa.certifiedName &lt;&gt; weighAuth.certifiedName then
				break;
			endif;
			idx := self.cmbAuthor.addItem(wa.authorisedName);
			self.cmbAuthor.itemObject[idx] := wa;
		endwhile;
	endif;
	authTerm := self.myTerminal.getDefaultWeighAuthority();
	if authTerm &lt;&gt; null then
		self.cmbCertify.listIndex := self.cmbCertify.findStringExact(1, authTerm.myWeighAuthority.certifiedName);
		self.cmbCertify_click(self.cmbCertify);
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="69681882-9e81-490c-bd45-c700efed1b24">
        <updating/>
        <source>setupControls() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2010	#cnwdz2	 
31/03/2010	cnwdap1	PAR #23064 Hide certified check box if cargo type cannot be certified
30/06/2016	cnwdap1	TFS #2174 Replace weight text box with measurement table
*/
vars

	stdHeight : Real;
	stdWidth : Real;
	halfWidth : Real;
	vTop : Real;
	vLeft : Real;
	measureType : CM_MeasurementType;
	//weightMeasure : String;					// TFS #2174

begin

	self.setResizeableMarginAndFontSize();
/*	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( stdWidth - self.resizedMargin ) / 2;

	vTop := stdHeight;
	self.lblTotalWeight.move(	self.resizedMargin,
							vTop,
							halfWidth,
							stdHeight);
	
	vLeft := halfWidth + self.resizedMargin;
    //self.txtWeight.move(	vLeft,														// TFS #2174
	//						vTop,														// TFS #2174
	//						halfWidth,													// TFS #2174
	//						stdHeight);													// TFS #2174
	self.tblWeight.move(	vLeft,														// TFS #2174
							vTop,														// TFS #2174
							halfWidth,													// TFS #2174
							stdHeight + 2	);											// TFS #2174
	self.tblWeight.setup(Type_Weight, self.backColor);									// TFS #2174
	self.txtWeight.visible := false;													// TFS #2174
	
	//vTop := self.txtWeight.top + self.txtWeight.height + (5*self.resizedMargin);		// TFS #2174
	vTop := self.tblWeight.top + self.tblWeight.height + (5*self.resizedMargin);		// TFS #2174
	self.lblIsCertified.move(	self.resizedMargin,
								vTop,						   
								halfWidth,
								stdHeight);
						   
	self.chkIsCertified.move(	vLeft,
								vTop,	
								stdHeight,
								stdHeight);	*/
	
	self.doResizeControls(true);
						   
	// PAR #23064
	self.lblIsCertified.visible := self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.canWeightBeCertified;
	self.chkIsCertified.visible := self.lblIsCertified.visible;
	self.chkIsCertified.caption := "";
	// TFS #2174
/*	if self.myTrackedItem &lt;&gt; null then																// TFS #2174
		weightMeasure := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight).shortName;	// TFS #2174
		if weightMeasure &lt;&gt; self.tblTotalWeight.accessCell(1, self.tblTotalWeight.ColumnUnit).text then		// TFS #2174
			self.tblTotalWeight.accessedCell.text := weightMeasure;										// TFS #2174
		endif;																						// TFS #2174
	endif;																							// TFS #2174
	*/
	//26 Jan 2018	NDL	TFS 36697
	if self.myTrackedItem &lt;&gt; null then
		measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight);
	endif;
	if measureType &lt;&gt; null then
		self.tblTotalWeight.setup(Type_Weight, self.tblTotalWeight.backColor);
		self.tblTotalWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.totalWeight) &amp; Space &amp; measureType.shortName);
		self.tblCargoWeight.setup(Type_Weight, self.tblCargoWeight.backColor);
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.weightCargo) &amp; Space &amp; measureType.shortName);
		self.tblTareWeight.setup(Type_Weight, self.tblTareWeight.backColor);
		self.tblTareWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.weightTare) &amp; Space &amp; measureType.shortName);
	endif;
		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="83122749-6af8-4a6f-8c44-238b5f9bf2c6">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/02/2010	#cnwdz2	 
11/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars
	authorised,
	certified	: String;
	authTerm : CM_WeighAuthTerminal;		// TFS 4492
begin
	inheritMethod();
	
	self.setupCmdButtons(2, app.getErrorString(Save), app.getErrorString(Back), null,null,null);
	if self.myTrackedItem &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
	endif;
	// TFS 2357 default authorised and certified by from the terminal config values
	//authorised := self.myTerminal.getConfig(DefaultAuthPersonWeight).String;		// TFS 4492
	//certified := self.myTerminal.getConfig(DefaultWeightCertifiedBy).String;		// TFS 4492
	//self.cmbAuthor.text := authorised;											// TFS 4492
	//self.cmbCertify.text := certified;											// TFS 4492
	self.setupCombos;																// TFS 4492
	authTerm := self.myTerminal.getDefaultWeighAuthority();							// TFS 4492
	if authTerm &lt;&gt; null then														// TFS 4492
		self.cmbCertify.findObject(authTerm.myWeighAuthority);						// TFS 4492
		self.cmbAuthor.findObject(authTerm.myWeighAuthority);						// TFS 4492
	endif;																			// TFS 4492
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
