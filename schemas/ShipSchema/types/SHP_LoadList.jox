    <JadeMethod name="doFilterVisibilityForNote" id="bc04bb33-1857-4253-a85a-b70653197207">
        <source>doFilterVisibilityForNote( _table : CM_DataTable input; _rowIndex : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation	Par 25297

*/

vars

	row : JadeTableRow;

begin

	if self.allColumnFilters = null then
		return;
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	if not self.allColumnFilters.includesFiltersFor( _table ) then
		return;
	endif;
	
	row := _table.accessRow( _rowIndex );
	
	if row = null then
		return;
	endif;
	
	self.allColumnFilters.applyFiltersToRow( 	_table,	//_table : Table;
												_rowIndex,	//rowIndex : Integer;
												row	//_row : JadeTableRow io
												);


epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFldMainClick" id="52615425-2fa1-4a80-a323-ff74f477bf4a">
        <updating/>
        <source>doFldMainClick() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 24/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

vars
//	str : String;
	invalidVoyage : Boolean;
	currentVoyage	: CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	
//	str := app.getErrorString(SHP_Load_List);

	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
//		str := str &amp; currentVoyage.code &amp; " ";
		//10/10/08 cnwdz2 Par 17732
		if invalidVoyage then
			app.msgBox(app.getErrorString(ERR_DELETED_VOYAGE),"",MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.btnCargoUnplan.enabled		:= false;
	self.btnLocateYardEnq.enabled	:= false;
	self.btnLocate.enabled			:= true;
	self.btnSummariseAll.enabled	:= true;
	
	if fldMain.topSheet = self.shtAll then
		self.btnUserColours.enabled := true;
		if self.newQuery  then
//			self.caption := str &amp; app.getErrorString(LOADLIST_ALL);
			if self.tblAll.allTableObjects.size &lt;&gt; 0 then
				if self.cmbVoyageNote.listObject &lt;&gt; null then
					self.doQuerySelectorDLR();
					self.displayAllTable();
					self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; (self.tblAll.rows - self.tblAll.fixedRows).String &amp; ")";
					self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblAll.allSelectedObjects.size.asStringJMT;
					self.btnLocate.enabled := false;
					self.newQuery := false;
				else
					app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only);
				endif;
			else
				fldMain.topSheet := self.shtNonplanned;
				self.btnUserColours.enabled := false;
			endif;
		endif;
	else
		self.btnUserColours.enabled := false;
		self.frmUserColours.visible := false;
	endif;
	if fldMain.topSheet = self.shtDLR then
//		self.caption := str &amp; app.getErrorString(SHP_DLR_NON_PLANNED);
		self.doQuerySelectorDLR();
//		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblDLR.allSelectedObjects.size.asStringJMT;
		self.btnLocate.enabled := false;
	elseif fldMain.topSheet = self.shtTranship then
//		self.caption := str &amp; app.getErrorString(SHP_Tranship_Export_Items);
//		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblTranShip.allSelectedObjects.size.asStringJMT;
		self.btnLocate.enabled := false;
	elseif fldMain.topSheet = self.shtTBA then // TFS 45590
		self.btnLocate.enabled := false;
	elseif fldMain.topSheet = self.shtNonplanned then
//		self.caption := str &amp; app.getErrorString(SHP_NON_PLANNED);
		self.btnLocateYardEnq.enabled := true; 
//		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtPlanned then
//		self.caption := str &amp; app.getErrorString(SHP_PLANNED);
		self.btnCargoUnplan.enabled := true;
//		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblPlanned.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtSummary then
//		self.caption := str &amp; app.getErrorString(SHP_SUMMARY);
		self.btnSummariseAll.enabled	:= false;
	endif;
	
	//25 Jan 2012	NDL	Par 25297 - includes the caption type string data commented out above...
	self.setFormCaption();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCargoUnplan.enabled:= false;
		self.mnuLLUnplan.enabled:= false;
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFunctionForMenu" id="2bb1ac67-12ec-41c3-b0ad-957cf0fece0c">
        <updating/>
        <source>doFunctionForMenu(_function: Integer; _columnKey: Integer) updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tableObj		: CM_DataTable;
	summaryObj		: CMIF_LoadListSummaryObject;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
	rowObj			: JadeTableRow;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	
begin
	tableObj	:=	self.tblSummary;
	startRow	:=	tableObj.fixedRows + 1;
	rowCount	:=	tableObj.rows;
	
	create allSummariesObj transient;
	
	foreach rowPointer in startRow to rowCount do
		rowObj	:=	tableObj.accessRow(rowPointer);
		
		if rowObj.selected then
			summaryObj	:=	rowObj.itemObject.CMIF_LoadListSummaryObject;
			//epr par 29963 9/1/14
			if summaryObj &lt;&gt; null then
				allSummariesObj.add(summaryObj);
			endif;
		endif;
	endforeach;
	
	if allSummariesObj.isEmpty() then
		//nothing to do
		return;
	endif;

	self.handleFunctionForObject(_function, allSummariesObj, _columnKey);
epilog
	delete allSummariesObj;
end;</source>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGetInfoTableData" id="bded8691-31d6-4be5-b0f7-f269ea3ed97d">
        <updating/>
        <source>doGetInfoTableData(_dataTable: CM_DataTable input; _infoTable : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theVjob : CM_VoyageJob;
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	_infoTable.rows := 0;

	if _dataTable.row &lt;= _dataTable.fixedRows then
		return;
	endif;

	theObject := _dataTable.accessRow(_dataTable.row).itemObject;
	if (not global.isValidObject(theObject)) then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
		if self.myCurrentTrackedItem &lt;&gt; null then
			self.btnLocate.enabled := self.myCurrentTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController);
		endif;
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theObject := theObject.CM_WorkListEntry.myTrackedItem;
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
	
	if useTableInfo then

		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else

			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, _infoTable, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_infoTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
