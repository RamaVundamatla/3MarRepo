    <JadeMethod name="displayCommodityLines" id="cd03ba60-fdcc-469c-ae03-af9f58775ae0">
        <source>displayCommodityLines() protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bookingSummary			: CMIF_VoyageBookingSummary;
	tbl						: Table;
	foundColumn,
	foundRow				: Boolean;
	typeCommodity,
	counter,
	total,
	row,
	column,
	numRows,
	numColumns				: Integer;
	iter					: Iterator;
	summaryDict				: CMIF_BookingByPortCommCodeDict;
begin
	tbl := self.tblReport;
	typeCommodity := CMIF_VoyageBookingSummary.TYPE_COMMODITY; //so that loop doesn't have to de-reference class object
	
	summaryDict := self.myJRWVoyageSummary.allVoyageBookingSummary;
	iter := summaryDict.createIterator;
	summaryDict.startKeyGeq(typeCommodity, null, null, iter);
	
	while iter.next(bookingSummary) do
		if bookingSummary.categoryType &lt;&gt; typeCommodity then
			break;
		endif;
		
		foundRow := false;
		foundColumn := false;
		numRows := tbl.rows;
		numColumns := tbl.columns;
		
		foreach row in 1 to numRows do
			if tbl.getCellText(row,1) = bookingSummary.categoryCode then
				foundRow := true;
				break;
			endif;
		endforeach;
		
		foreach column in 1 to numColumns do
			if tbl.getCellText(1, column) = bookingSummary.loadPort then
				foundColumn := true;
				break;
			endif;
		endforeach;
					
		if not foundRow then
			row := tbl.addItem(bookingSummary.categoryCode);
		endif;
		
		if not foundColumn then
			tbl.columns := tbl.columns + 2;
			column := tbl.columns - 1;
			tbl.accessCell(1, column).text := bookingSummary.loadPort;
			tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
			tbl.accessedCell.alignment := Table.Alignment_Center;
			tbl.accessCell(2, column).text := 'C/C';
			tbl.accessCell(2, column + 1).text := 'Actl';	
		endif;
		
		if bookingSummary.colourCodeCount &lt;&gt; null then
			tbl.setCellText(row, column, bookingSummary.colourCodeCount.String);
		endif;
		
		if bookingSummary.actuallyLoadedCount &lt;&gt; null then
			tbl.setCellText(row, column + 1, bookingSummary.actuallyLoadedCount.String);			
		endif;
	endwhile;
	
	numColumns := tbl.columns;
	numRows := tbl.addItem(CMIF_VoyageBookingSummary.Category_TotalCommodity);
	tbl.accessCell(numRows, 1).fontBold := true;
	
	foreach column in 2 to numColumns do
		counter := 0;
		foreach row in 2 to numRows - 1 do
			counter := counter + tbl.getCellText(row, column).Integer;
		endforeach;
		tbl.accessCell(numRows, column).text := counter.String;
		tbl.accessedCell.fontBold := true;
		tbl.accessRow(numRows).backColor := CM_BaseForm.ColourBlueLight;
	endforeach;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displaySummaryLine" id="5ad0f678-859c-4afc-b7dd-f35363c2d377">
        <source>displaySummaryLine(iter : Iterator input; 
					_summaryDict : CMIF_BookingByPortCommCodeDict;
					_categoryType : Integer;
					_categoryStr : String;
					_isFontBold : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     09 May 2003		cnwth2	
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	bookingSummary			: CMIF_VoyageBookingSummary;
	firstTime				: Boolean;
	numColumns,
	column,
	row						: Integer;
	tbl						: Table;
begin

	bookingSummary := _summaryDict[_categoryType, 
									_categoryStr, 
									null];
	
	if bookingSummary = null then 
		return;
	endif;
	
	tbl := self.tblReport;
	numColumns := tbl.columns;
	row := tbl.addItem(bookingSummary.categoryCode);
	if _isFontBold then
		tbl.accessRow(row).backColor := CM_BaseForm.ColourBlueLight;
		tbl.accessCell(row, 1).fontBold := true;
	endif;
	
	_summaryDict.startKeyGeq(_categoryType, 
							_categoryStr, 
							null, 
							iter);
	
	while iter.next(bookingSummary) do : bookingLoop
		if bookingSummary.loadPort = null then
			continue;
		endif;
		if bookingSummary.categoryCode &lt;&gt; _categoryStr then
			break bookingLoop;
		endif;
																	
		foreach column in 1 to numColumns do : columnLoop
			if tbl.accessCell(1, column).text = bookingSummary.loadPort then
				if  bookingSummary.colourCodeCount &lt;&gt; null then
					tbl.accessCell(row, column).text := bookingSummary.colourCodeCount.String;
					tbl.accessedCell.fontBold := _isFontBold;
				endif;
				if  bookingSummary.actuallyLoadedCount &lt;&gt; null then
					tbl.accessCell(row, column + 1).text := bookingSummary.actuallyLoadedCount.String;
					tbl.accessedCell.fontBold := _isFontBold;
				endif;
				break columnLoop;
			endif;	
		endforeach;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="iter" type="Iterator" usage="input"/>
        <Parameter name="_summaryDict" type="CMIF_BookingByPortCommCodeDict"/>
        <Parameter name="_categoryType" type="Integer"/>
        <Parameter name="_categoryStr" type="String"/>
        <Parameter name="_isFontBold" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySummaryLines" id="bfa6ff4c-7926-4444-b4d9-c4acaebc1503">
        <source>displaySummaryLines() protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bookingSummary 			: CMIF_VoyageBookingSummary;
	iter					: Iterator;
	summaryDict				: CMIF_BookingByPortCommCodeDict;
begin
	summaryDict := self.myJRWVoyageSummary.allVoyageBookingSummary;
	iter := summaryDict.createIterator;
	
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_20Integral, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_40Integral, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_TotalIntegral, true);

	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_20General, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_40General, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_TotalGeneral, true);
	
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_20MT, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_40MT, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_ISO, CMIF_VoyageBookingSummary.Category_TotalEmpties, true);
	
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_MOVE, CMIF_VoyageBookingSummary.Category_20GeneralDLR, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_MOVE, CMIF_VoyageBookingSummary.Category_40GeneralDLR, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_MOVE, CMIF_VoyageBookingSummary.Category_20IntegralDLR, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_MOVE, CMIF_VoyageBookingSummary.Category_40IntegralDLR, false);
	self.displaySummaryLine(iter, summaryDict, CMIF_VoyageBookingSummary.TYPE_MOVE, CMIF_VoyageBookingSummary.Category_TotalDLR, true);
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTotalsColumn" id="516bd346-8415-4807-a55a-483610a7f704">
        <source>displayTotalsColumn() protected;
// ---------------------------------------------------------------------------
// Created:     09 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: Table;
	ccTotal,
	actlTotal,
	row,
	column,
	numRows,
	numColumns		: Integer;

begin
	tbl := self.tblReport;

	numRows := tbl.rows;
	numColumns := tbl.columns;

	tbl.columns := tbl.columns + 2;
	column := numColumns + 1;

	tbl.accessColumn(column).width := 40;
//	tbl.accessedColumn.backColor := CM_BaseForm.ColourBlueDark;
	tbl.accessColumn(column + 1).width := 40;
//	tbl.accessedColumn.backColor := CM_BaseForm.ColourBlueDark;

	tbl.accessCell(1, column).text := 'Total';
	tbl.accessedCell.fontBold := true;
	tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	
	tbl.accessCell(2, column).text := 'C/C';
	tbl.accessCell(2, column + 1).text := 'Actl';
		
	foreach row in 3 to numRows do
		actlTotal := 0;
		ccTotal := 0;
		foreach column in 2 to numColumns do
			if column mod 2 = 0 then
				ccTotal := ccTotal + tbl.getCellText(row, column).Integer;				
			else
				actlTotal := actlTotal + tbl.getCellText(row, column).Integer;
			endif;
		endforeach;
		tbl.accessCell(row, numColumns + 1).text := ccTotal.String;
		tbl.accessedCell.fontBold := true;
		tbl.accessCell(row, numColumns + 2).text := actlTotal.String;
		tbl.accessedCell.fontBold := true;		
	endforeach;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoad" id="2a97ef32-3ed2-4a1c-9ab3-f9f5e8d58a9d">
        <updating/>
        <source>doLoad() protected, updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tp			: CM_GenericTablePrint;
	progress	: CMS_Progress;
begin
	self.setupControls();
	self.setupHeader();
	self.setupTable();
	
	app.printer.setHeader(self.frmHeader);

	create tp transient;
	create progress transient;
	tp.printTable(self.tblReport, true, progress);

epilog
	delete tp;
	delete progress;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="run" id="ebceb217-a6cf-43b8-b807-8646fc879ebd">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	self.myJRWVoyageSummary := app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;
	doLoad();
	return null;

epilog
	app.printer.close;
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="b6d079ce-5b35-4fd0-b0da-72944669d33d">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.lblNoData.caption := 'No Data To Display For Voyage Booking Summary';



end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="91222ddf-aaab-48dc-b3bf-22a6e47f0180">
        <updating/>
        <source>setupControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 10;
vars

begin
	self.tblReport.visible := true;
	self.frmTable.visible := true;
	
	self.frmTable.left := Gap;
	self.frmTable.width := self.width - Gap * 2;
	self.frmTable.height := (self.height - self.frmHeader.height) - Gap;
	
	self.tblReport.left := self.tblReport.parent.left;
	self.tblReport.width := self.tblReport.parent.width;
	self.tblReport.height := self.tblReport.parent.height;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="f830c10b-f95c-4861-954b-634a1b35d7af">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left -10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left -15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;

	self.lblHeading1.caption := 'Load Colour Code Booking Summary';
	self.lblHeading1.height := 25;
	self.lblHeading1.fontSize := 23;
	
	self.lblHeading2.top := 55;
	self.lblHeading2.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; self.myJRWVoyageSummary.myVoyage.description;
	self.lblHeading2.height := 20;
	self.lblHeading1.fontSize := 18;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="d1482807-9bc3-4d5a-a93e-fb10075def68">
        <source>setupTable() protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	ColWidth = 120;
vars
	tbl						: Table;
	column,
	numColumns				: Integer;
begin
	tbl := self.tblReport;
	
	tbl.rows := 2;
	tbl.fixedRows := 2;
	tbl.columns := 1;
	tbl.accessColumn(1).width := ColWidth;
	tbl.accessCell(1,1).text := 'Discharge Ports&gt;&gt;';
	tbl.accessCell(2,1).text := 'Categories';
	tbl.gridLines := true;
	tbl.show3D := Table.Show3D_Use3D;
	
	self.displayCommodityLines();
	self.displaySummaryLines();
	self.displayTotalsColumn();
	
	numColumns := tbl.columns;
	foreach column in 2 to numColumns -2 do
		tbl.accessColumn(column).width := ((tbl.width - ColWidth) / numColumns).Integer;	
	endforeach;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
