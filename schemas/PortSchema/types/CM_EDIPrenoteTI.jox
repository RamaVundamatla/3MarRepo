    <JadeMethod name="doNotGeneratePins" id="01988911-cbd5-4105-9ca0-4533988732c8">
        <source>doNotGeneratePins():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2015	cnwndl1	Initial creation	Par 37147
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars

begin

