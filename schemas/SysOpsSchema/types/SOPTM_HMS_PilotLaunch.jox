    <JadeMethod name="doSave" id="cf35bde8-b495-4597-9496-d86f30375a7a">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyPilotLaunch		:	HMS_PilotLaunch;
	theForm				:	SOP_HMS_TableMaintForm;
	theHarbour: HMS_Harbour;			
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_PilotLaunch transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyPilotLaunch := theForm.myProxyObject.HMS_PilotLaunch;
	theForm.tblInput1.setObjectFromTable(pxyPilotLaunch, null, false);
	theHarbour := theForm.cmbHarbour.listObject.HMS_Harbour;
	pxyPilotLaunch.setProxy(app.myRoot, theHarbour);
	self.doSaveResourcesTbl(pxyPilotLaunch);
		
	//Are we adding or updating
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject( pxyPilotLaunch, theForm.myCurrentObject, app.myPassport );
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyPilotLaunch, app.myPassport );
	else
		app.raiseUnexpectedProgramError( class.name,
										 method.name, 
										 '  Invalid mode (' &amp; theForm.mode.String &amp; ')' );
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveResourcesTbl" id="c8dfeb28-b3df-4eea-add8-5fe7765b5994">
        <source>doSaveResourcesTbl(_pxyPilotLaunch : HMS_PilotLaunch);
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm 	: SOP_TableMaintForm;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	obj			: Object;
	harbour	: HMS_Harbour;
	prxyResourceForPilotLaunch	: HMS_ResourceForPilotLaunch;
	arrResource,
	depResource,
	shiftResource :	HMS_Resource;
	
begin

	theForm := self.myForm; 

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		harbour 			:= tmpDataTable.accessRow(idx).itemObject.HMS_Harbour;
		arrResource 		:= tmpDataTable.accessCell(idx, 2).itemObject.HMS_Resource;
		depResource 		:= tmpDataTable.accessCell(idx, 3).itemObject.HMS_Resource;
		shiftResource 		:= tmpDataTable.accessCell(idx, 4).itemObject.HMS_Resource;		

		prxyResourceForPilotLaunch := _pxyPilotLaunch.allResourcesForPilotLaunch[harbour,_pxyPilotLaunch];
		
		if prxyResourceForPilotLaunch = null then
				create prxyResourceForPilotLaunch transient;
		endif;
		prxyResourceForPilotLaunch.setProxy(_pxyPilotLaunch,harbour,arrResource,depResource,shiftResource);

	endforeach;
end;</source>
        <Parameter name="_pxyPilotLaunch" type="HMS_PilotLaunch"/>
    </JadeMethod>
