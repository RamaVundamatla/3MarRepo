    <JadeMethod name="setName" id="b0d89b4d-22e2-477c-b780-b95965044da2">
        <updating/>
        <source>setName( _value : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2013	cnwndl1	Initial creation

*/

vars

begin

	self.name := _value;
	
	// need to replace any double spacing with a single space.
	if self.name &lt;&gt; null then
		while self.name.pos("  ",1) &gt; 0 do
			self.name := self.name.replaceString("  "," ");
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
