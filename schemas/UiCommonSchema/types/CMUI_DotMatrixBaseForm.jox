    <JadeMethod name="printFields" id="b5906e04-fc78-407c-b73e-54fbf48e98d7">
        <updating/>
        <source>printFields() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	obj : Object;
	label : CMUI_Label;
	strObj : CM_StringWithString;
	left : Integer;
	top : Integer;
	str : String;
	specialAttrib : Integer;
	prevBool : Boolean;

begin

	self.allPrintStrings.purge();
	
	foreach obj in self.allLabelsArray do
		label := obj.CMUI_Label;
		if not self.doProcessLabelContents( label ) then
			break;
		endif;
	endforeach;
	
	if not self.allPrintStrings.isEmpty then
		if self.baseLeftOffset &lt;&gt; 0 or self.baseTopOffset &lt;&gt; 0 then
			str := ".";
			top := 1;
			left := 1;
			self.createAndAddPrintLineDetail( str, top, left, 0 );
		endif;
	endif;
	
	foreach obj in self.allPrintStrings do
		strObj := obj.CM_StringWithString;
		// if you change this, you will need to change "getKeyString" as well
		top := strObj.string[1:4].Integer;
		left := strObj.string[5:4].Integer;
		specialAttrib := strObj.string[9:3].Integer;	//31 Jan 2014	NDL	Par 33181
		str := strObj.strString;
		//31 Jan 2014	NDL	Par 33181
		if specialAttrib = self.BOLD_Attribute then
			prevBool := app.printer.drawFontBold;
			app.printer.drawFontBold := true; 
			app.printer.drawTextAt(str, left, top, Black);
			app.printer.drawFontBold := prevBool;
		else
			app.printer.drawTextAt(str, left, top, Black);
		endif;
	endforeach;
	
	if self.myNextPage &lt;&gt; null then
		app.printer.newPage;
		self.myNextPage.printFields();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="printLabelFieldAreaBoundary" id="97302e0c-9c69-45c9-b08b-30fe88a8fcab">
        <source>printLabelFieldAreaBoundary();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwndl1	Initial creation	Par 34611

*/

vars

	obj : Object;
	label : CMUI_Label;
	vLeft : Integer;
	vRight : Integer;
	vTop : Integer;
	vBottom : Integer;
	

begin

	foreach obj in self.allLabelsArray do
		label := obj.CMUI_Label;
		vLeft := label.left.Integer;
		vRight := vLeft + label.width.Integer;
		vTop := label.top.Integer;
		vBottom := vTop + label.height.Integer;
		app.printer.drawLine(vLeft, vTop, vRight, vTop, Black); // top line
		app.printer.drawLine(vLeft, vBottom, vRight, vBottom, Black); // bottom line
		app.printer.drawLine(vLeft, vTop, vLeft, vBottom, Black); // left line
		app.printer.drawLine(vRight, vTop, vRight, vBottom, Black); //right line
	endforeach;




epilog

end;</source>
    </JadeMethod>
