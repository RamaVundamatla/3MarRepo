    </JadeMethod>
    <JadeMethod name="getLocationForVehicleMove" id="f3212035-58f7-4e20-8e84-0d59fe603e8a">
        <source>getLocationForVehicleMove(_vehicle :CM_Vehicle):CM_YardController;
// ---------------------------------------------------------------------------
// Created:     14 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				We are looking to the location to move a vehicle to for cargo
//				located at the receiver location
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------------------------------------
// 08/02/2010	cnwcs5		par 22669 - use interchange area instead of yard interchange area
// 27/05/2010	cnwcs5		par 24292 - use lane capacity (see history for old code)
// 18/06/2010	cnwcs5		par 24418 - check area is OK for vehicles
// -------------------------------------------------------------------------------------------
vars
	ta, taVehicle	:CM_TerminalArea;
	transit,
	found		:Boolean;			// par 24292
	icArea,
	targetICArea:CM_InterchangeArea;// par 24292
	lane		:CM_LaneController;	// par 24292
	count, size,
	capacity	:Integer;			// par 24292
begin 
	// can only move vehicle to an interchange area in yard
	ta 		:= self.myTerminalArea;
	transit	:= self.myTerminal.getConfig (GateTransitIntoYard).Boolean;	// par 24292
	
	if ta = null then
		return null;
	endif;
	
	if _vehicle &lt;&gt; null then											// par 24292
		taVehicle := _vehicle.getTerminalAreaForCurrentLocn;			// par 24292
	endif;																// par 24292

	if ta.isYardInterchangeArea then
		// probably won't happen as cargo won't be in an interchange area (maybe?)
		if taVehicle = ta then											// par 24292
			// already there - use that one
			return _vehicle.myPrimaryActualLocation;					// par 24292
		endif;															// par 24292
		
		return ta.CM_YardInterchangeArea.getLocationforVehicleMove;		// par 24292	
	endif;
	
	if taVehicle &lt;&gt; null and taVehicle.isInterchangeArea and	//20 Nov 2017	NDL	TFS 7460
//	if taVehicle.isInterchangeArea and													// par 24292
		ta.allAssociatedInterchangeAreas.includes (taVehicle.CM_InterchangeArea) then	// par 24292
		// already there
		return _vehicle.myPrimaryActualLocation;										// par 24292
	endif;																				// par 24292
		
	// try moving to interchange area associated with queued location ...
	foreach icArea in ta.allAssociatedInterchangeAreas do
		if not icArea.isOKForVehicles then	// par 24418
			continue;						// par 24418
		endif;								// par 24418
		
		if not icArea.myInTransitToLocation.hasVehicles then	// par 24292
			// if there are already vehciles in transit to the area then we wont
			// put vehciles in lanes automatically. this would be pushing in :-)
			lane := icArea.getFirstAvailalableLane;
			
			if lane &lt;&gt; null then
				// we have a lane with space for the vehicle
				if transit = CM_YardInterchangeArea.Transit_Always then
					// send to ITT for the area
					return icArea.myInTransitToLocation;
				else
					// send directly to lane  
					return lane;
				endif;
			endif;
		endif;																// par 24292
		// we may not find a lane with capacity so keep track of the IC area 
		// with the fewest vehicles in transit to it.  If the IC Area has spare capacity
		// substract this from the number of vehicles in ITT before doing comparision.  This could
		// happen if they have Transit into Yard set to Yes, lane capacity of 5, and no vehicles in the lane
		// but 2 vehicles in ITT - we would want to treat that IC Area as the least busy
		if found then
			continue;
		endif;
		
		size 		:= icArea.myInTransitToLocation.allVehicleMachines.size;
		capacity	:= icArea.getUnusedLaneCapacity;
		
		if capacity &gt; size then
			// lanes not full 
			targetICArea 	:= icArea;
			found			:= true;
		elseif targetICArea = null or size &lt; count then	
			targetICArea 	:= icArea;
			count			:= size;
		endif;	
	endforeach;
	// if we get to here they are full
	if targetICArea &lt;&gt; null then
		// we will put them ITT the ICArea with the fewest vehicles in transit to it
		return targetICArea.myInTransitToLocation;
	endif;
	// we will only get to here if they have no interchange areas defined for the terminal area
	return null;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
