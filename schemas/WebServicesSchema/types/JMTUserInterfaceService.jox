    <JadeWebServicesMethod name="deleteCargoDamage" id="179447c4-d7fc-48e4-aa44-e34334fa0d9c">
        <source>deleteCargoDamage(cargoDamageRequest : WS_CargoDamageUpdateRequest) : WS_Response webService;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2015	cnwmc5	Initial creation
*/

vars

	response 		: WS_Response;
	completedOK 	: Boolean;	
	wsDamage	 	: WS_Damage;
	terminal 		: CM_Terminal;
	ti,
	pxyTI			: CM_TrackedItem;	
	damage			: CM_DamageInstance;
	damageToDelete	: CM_DamageInstance;
	pxyDamage		: CM_DamageInstance;
	isLoadStateSet	: Boolean;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(cargoDamageRequest.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	wsDamage := cargoDamageRequest.damage;

	if wsDamage = null then
		//app.raiseCMException1( ,alertMsg, null, null);
		completedOK := true;
		return response;
	endif;
	
	if wsDamage.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		damageToDelete := app.myPassport.getObjectOfTypeFromOid(wsDamage.cmObjectId,CM_DamageInstance).CM_DamageInstance;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if damageToDelete = null then
			completedOK := true;
			return response;
		endif;
	endif;

	//epr TFS 5535 4/8/17 
	ti:= app.myPassport.getObjectOfTypeFromOid(cargoDamageRequest.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;

	if ti = null then
		completedOK := true;
		return response;
	endif;	
	
	app.cmsBeginLoad(isLoadStateSet);
	pxyTI		:=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadStateSet);
	
	pxyTI.purgeAllDamageInstance();
	foreach damage in ti.allDamageInstances do
		if damage = damageToDelete then
			continue;
		endif;
		
		app.cmsBeginLoad(isLoadStateSet);
		pxyDamage := damage.pxyCreateUpdateProxy();
		app.cmsEndLoad(isLoadStateSet);
		
		pxyDamage.setMyTrackedItem(pxyTI);
	endforeach;
	
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	app.cmsEndLoad(isLoadStateSet);
	delete pxyTI;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoDamageRequest" type="WS_CargoDamageUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeMethod name="deleteCargoEvent" id="ea84adb2-4082-49e4-92cd-7765fde81a55">
        <source>deleteCargoEvent(cargoDeleteRequest : WS_CargoEventUpdateRequest) : WS_Response protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation - generalised KPD's original method to handle subclasses

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	
	eventReq		: CM_Object;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(cargoDeleteRequest.getJMTUpdatePermission);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 47319 11/11/19
	if cargoDeleteRequest.cmObjectId &lt;&gt; null then
		eventReq:=app.myPassport.getObjectOfTypeFromOid(cargoDeleteRequest.cmObjectId,CM_EventRequestTI).CM_Object;
	endif;
	
	if eventReq = null then
		// Perform validation
		eventReq := cargoDeleteRequest.findFirstMatchingCargoEvent();
		if eventReq = null then
			app.raiseCMException1(Matching_found,cargoDeleteRequest.getCMTypeDesc(),null, null);
			completedOK := true;
			return response;
		endif;
	endif;
	
	// Do the delete 
	app.myTrxDA.trxDeleteCMObject(eventReq, app.myPassport);

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
		

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
