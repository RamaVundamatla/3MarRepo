    <JadeMethod name="cloneReferences" id="956fa6fa-e33c-466d-b722-ac6963bf0c0d">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Events; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allUsers.clear();
	_obj.allUsers.copy(self.allUsers);

epilog

end;</source>
