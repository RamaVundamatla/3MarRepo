    <JadeMethod name="trxUpdateAutoplanMulti" id="347a2cf8-bb04-445d-8797-c5ae771e8a08">
        <updating/>
        <source>trxUpdateAutoplanMulti(_theWLEs:CM_WLESet; _moveMode : Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
	alertCreated : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Multi Transaction trx.  This is the type of transaction where we
	// commitTransaction/beginTransaction multiple times for efficiency
	// and concurrency reasons.  We want to dispatch event notifications
	// after the final commit/abort, as we delay all notifications until
	// then.  They will be sent as immediate notifications.
	app.myEventManager.setMultiTransactionTrx;


	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	foreach wle in _theWLEs do
		exclusiveLock(wle);
		beginTransaction;
		app.myUtilityUA.utlUpdateWLEAutoplan(wle,_moveMode, _passport);
		if _passport.noErrors then
			app.cmsCommitTransaction(_passport);
		else
			app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() &amp; ' could not be Auto-Planned', _passport.allErrorWarnings);		
			alertCreated := true;
			app.cmsAbortTransaction;
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_theWLEs" type="CM_WLESet"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateAutoplanTrackedItems" id="bf69379a-d5ba-4c9f-9f5d-4d204ef09b89">
        <updating/>
        <source>trxUpdateAutoplanTrackedItems(params : CMIF_AutoplanParams; _passport : CM_Passport input) : String updating;
//_tiArray : CM_TIArray; _moveMode : Integer; _area : CM_TerminalArea input; _passport : CM_Passport input) : String updating;
//--------------------------------------------------------------
//Created: May 2003 By: cnwgd1
//--------------------------------------------------------------
/*
Date		Who			Reason
18/09/2017	jlgmd1		TFS 6813 - QNS - Jade application slow

*/
vars
	ret : String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813

	beginTransaction;

//	return app.myUtilityUA.utlUpdateAutoplanTrackedItems(_tiArray, _moveMode, null,_area, _passport);
	ret := app.myUtilityUA.utlUpdateAutoplanTrackedItems(params, _passport);
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813

	return ret;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="params" type="CMIF_AutoplanParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
