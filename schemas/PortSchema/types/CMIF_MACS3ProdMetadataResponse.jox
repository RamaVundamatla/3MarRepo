    <JadeMethod name="isJSONFileDataAvailable" id="d59d45b1-e0f2-4299-82e8-c660eee98ac6">
        <source>isJSONFileDataAvailable(): Boolean;
/*

Purpose:			Make sure the MACS3 server has a JSON file for us to download

Parameters:			

Return Value:		

Date				Who		Reason
04 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

constants
	JSON_FILE_TYPE	: String = 'json';

vars
	availableFile	: CMIF_MACS3ContentPxyObj;
begin
	// No files (at all) available
	if self.availableContent.size = 0 then
		return false;
	endif;
	
	foreach availableFile in self.availableContent do
		if availableFile.key = JSON_FILE_TYPE then
			return true;
		endif;
	endforeach;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
