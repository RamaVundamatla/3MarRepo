vars

begin
	self.setLocalLogBackupPath("C:\temp");		//the default...
end;</source>
    </JadeMethod>
    <JadeMethod name="doAbortBackup" id="b9c26ca4-e5df-449f-9f4e-4072742d403f">
        <source>doAbortBackup();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.isSDSSecondaryBackup then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupAbort='&amp;NotifyBackupAbort.String, LogDebug);
		beginTransaction;
		self.sdsCauseEvent(NotifyBackupAbort, false, null);
		commitTransaction;
		app.myDBA.closeCurrentJournal;
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupAbort='&amp;NotifyBackupAbort.String, LogDebug);
		self.causeEvent(NotifyBackupAbort, true, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleLogTransfer" id="f0a7b2a5-bead-4588-ae5e-47335335596b">
        <updating/>
        <source>handleLogTransfer(_logNumber : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// July 2009    cnwrs1      to replace the data being copied par 20382
//16 Dec 2013	cnwrs1		Par 33216 - After JMT 822 upgrade neither JacBackup nor JMTBackup fail to purge expired journal files.
// ---------------------------------------------------------------------------

vars
	dba: JadeDatabaseAdmin;	
	ver: Integer;
	result, out: Integer;
	fileNode: FileNode;
	folder: FileFolder;
	file: File;
	today: Date;
	idx: Integer;
	command,jadeVersion: String;
	kc : CnKarmaCntrl;
begin
	kc := app.myCnKarmaCntrl;
	jadeVersion := app.getSystemVersion;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Processing log transfer event for ('&amp;_logNumber.String&amp;')', LogNormal);

	// Internal server notification - process
	beginTransaction;
	self.logNumber := _logNumber;
	commitTransaction;

	create dba transient;

	// Check that the file verifies OK
	ver := dba.verifyLog(_logNumber, null);
	if ver &lt;&gt; 0 then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;" ERROR: Verification of log file number "&amp;_logNumber.String&amp;" failed.", LogAlways);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;ver.String&amp;" errors were found. Check log jommsg.log for details.", LogAlways);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"        ========================================================================", LogAlways);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"        A FULL SYSTEM BACKUP SHOULD BE PERFORMED AS SOON AS POSSIBLE ", LogAlways);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"        SINCE RECOVERY IS NOW COMPROMISED.", LogAlways);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"        ========================================================================", LogAlways);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;" INFO: log file number "&amp;_logNumber.String&amp;" verified.", LogAlways);				
	endif;

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Backingup logfile ('&amp;_logNumber.String&amp;') to '&amp;self.logLocalBackupPath, LogNormal);				
	create folder transient;
	folder.fileName := self.logLocalBackupPath;
	if not folder.isAvailable then
		folder.make;
		if not folder.isAvailable then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;"Creation of directory "&amp;self.logLocalBackupPath&amp;" failed.", LogAlways); 
			return;
		endif;
	endif;
	delete folder;
	dba.backupJournal(_logNumber, null, self.logLocalBackupPath, self.logVerify, self.logCompress, true); //cnwrs1 July 2009 changed to overwrite any existing journal file
	if jadeVersion[1:1] = '5' then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Backingup logfile ('&amp;_logNumber.String.padLeadingZeros(6)&amp;') to '&amp;self.logLocalBackupPath&amp;' - complete', LogNormal);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Backingup logfile ('&amp;_logNumber.String.padLeadingZeros(10)&amp;') to '&amp;self.logLocalBackupPath&amp;' - complete', LogNormal);				
	endif;
	if self.logRemoteBackupPath &lt;&gt; null then
		create folder transient;
		folder.fileName := self.logRemoteBackupPath;
		if not folder.isAvailable then
			//cnwrs1 Mar 2007 Par 13083
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;"Create remote backup directory "&amp;self.logRemoteBackupPath&amp;" .", LogAlways); 
			foreach idx in 1 to 6 do
				process.sleep(10000);
				if folder.isAvailable then
					break;
				endif;
			endforeach;
			if not folder.isAvailable then
				folder.make;
				if not folder.isAvailable then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;"Creation of directory "&amp;self.logRemoteBackupPath&amp;" failed.", LogAlways); 
				endif;
			endif;
		endif;
		delete folder;
		process.sleep(500);
		create file transient;
		if jadeVersion[1:1] = '5' then
			if self.logCompress then
				file.fileName := self.logLocalBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".lo_";
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy0 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath, LogDebug);
				if not kc.copyFile(file.fileName, self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".lo_", false) then //cnwrs1 par 20382 july 2009
//				if not file.cnEcCopy(self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".lo_") then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy0 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath&amp;" failed.", LogNormal);
				endif;
			else
				file.fileName := self.logLocalBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".log";
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy1 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath, LogDebug);
				if not kc.copyFile(file.fileName, self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".log", false) then //cnwrs1 par 20382 july 2009
//				if not file.cnEcCopy(self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(6)&amp;".log") then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy1 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath&amp;" failed.", LogNormal);
				endif;
			endif;
		else
			if self.logCompress then
				file.fileName := self.logLocalBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".lo_";
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy2 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath, LogDebug);
				if not kc.copyFile(file.fileName, self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".lo_", false) then //cnwrs1 par 20382 july 2009
//				if not file.cnEcCopy(self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".lo_") then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy2 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath&amp;" failed.", LogNormal);
				endif;
			else
				file.fileName := self.logLocalBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".log";
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy3 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath, LogDebug);
				if not kc.copyFile(file.fileName, self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".log", false) then //cnwrs1 par 20382 july 2009
//				if not file.cnEcCopy(self.logRemoteBackupPath&amp;"\db"&amp;_logNumber.String.padLeadingZeros(10)&amp;".log") then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Copy3 "&amp;file.fileName&amp;' to '&amp;self.logRemoteBackupPath&amp;" failed.", LogNormal);
				endif;
			endif;
		endif;
		//cnwrs1 Mar 2007 Par 13083
		if jadeVersion[1:1] = '5' then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Remote backup of logfile ('&amp;_logNumber.String.padLeadingZeros(6)&amp;') to '&amp;self.logRemoteBackupPath&amp;' - complete', LogNormal);
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Remote backup of logfile ('&amp;_logNumber.String.padLeadingZeros(10)&amp;') to '&amp;self.logRemoteBackupPath&amp;' - complete', LogNormal);				
		endif;
		delete file;
	endif;
	//Now purge all log files older than x days in the backup directory
	//Now purge all log files older than x days in the backup directory
	if self.purgeLogDays &gt; 0 then
		if self.purgeDBLogs then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Database logfiles older than ('&amp;self.purgeLogDays.String&amp;')', LogNormal);				
			create folder transient;
			folder.fileName := dba.getCurrentLogDirectory;
			folder.mask := "*.log";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.lastModified.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Database logfile ('&amp;file.name&amp;')', LogNormal);				
					file.cnSetFileAttribute(FileNode.CN_FILE_ATTR_READONLY, false);	//16 Dec 2013	cnwrs1		Par 33216 - After JMT 822 upgrade neither JacBackup nor JMTBackup fail to purge expired journal files.
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access database logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			folder.mask := "*.scan";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.lastModified.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Database log scn file ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access database log scn file ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			delete folder;
		endif;
		if self.purgeLocalLogs then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Backup logfiles older than ('&amp;self.purgeLogDays.String&amp;')', LogNormal);				
			create folder transient;
			folder.fileName := logLocalBackupPath;
			folder.mask := "*.lo_";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Backup logfile ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Backup logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			folder.mask := "*.log";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Backup logfile ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Backup logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			folder.mask := "*.scan";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Backup log scan file ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Backup log scan file ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			delete folder;
		endif;
		if self.purgeRemoteLogs then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Remote Backup  logfiles older than ('&amp;self.purgeLogDays.String&amp;')', LogNormal);				
			create folder transient;
			folder.fileName := logRemoteBackupPath;
			folder.mask := "*.lo_";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Remote Backup logfile ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Remote Backup logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			folder.mask := "*.log";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Remote Backup logfile ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Remote Backup logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			folder.mask := "*.scan";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.timeCreated.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Remote Backup log scan file ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access Remote Backup log scan file ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
			delete folder;
		endif;
	endif;

epilog
	delete folder;
	delete dba;
end;</source>
        <Parameter name="_logNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initBackupServerApp" id="ca7f3b26-5018-40dc-b470-bb6db31ac42e">
        <updating/>
        <source>initBackupServerApp() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;	//cnwrs1 par26681 31 dec 2010
begin
	if not app.isSDSSecondaryDB then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " start Primary log transfer notification", LogDebug);
	
		self.beginNotification(system, JadeDatabaseAdmin.LogTransferEvent, Response_Continuous, null);
		sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);	//cnwrs1 par26681 31 dec 2010
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 1 sched= "&amp;sched.String, LogDebug);
		if sched &lt;&gt; null and sched.status = JACBackupRunning then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 2 sched= "&amp;sched.String&amp;' '&amp;sched.status, LogDebug);
			beginTransaction;
			sched.setStatus(JACBackupFailed);
			commitTransaction;
			self.doAbortBackup();
			sched.backupFinished();
		endif;
		sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 3 sched= "&amp;sched.String, LogDebug);
		if sched &lt;&gt; null and sched.status = JACBackupActivated then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 4 sched= "&amp;sched.String&amp;' '&amp;sched.status, LogDebug);
			beginTransaction;
			sched.setStatus(JACBackupFailed);
			commitTransaction;
			self.doAbortBackup();
		endif;
		self.beginClassNotification(JACBackupSchedule, false, NotifySetStatus, Response_Continuous, 0);
		self.beginClassNotification(JACBackupSchedule, false, NotifySetFinalMessage, Response_Continuous, 0);
		self.beginClassNotification(JACBackupSchedule, false, NotifyBackupFinished, Response_Continuous, 0);
		self.beginClassNotification(JACBackupSchedule, false, NotifyRunOnSecondary, Response_Continuous, 0);
		self.beginNotification(self, NotifySecServerAppStarted, Response_Continuous, null);
		self.beginNotification(self, NotifySecServerAppStopped, Response_Continuous, null);
	
		// beginTimer for checking timed events
		self.beginTimer(1000, Timer_OneShot, Timer_CheckEvent);
		self.setSecondarySDSIsAlive(false);
		// now ask the secondary ControlApp if its running
		if app.isSDSSecondaryBackup then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppRunning='&amp;NotifySecServerAppRunning.String, LogDebug);
			beginTransaction;
			self.sdsCauseEvent(NotifySecServerAppRunning, false, null);
			commitTransaction;
			app.myDBA.closeCurrentJournal();
		endif;
	else	//cnwrs1 par26681 31 dec 2010
		self.beginNotification(system, JadeDatabaseAdmin.LogTransferEvent, Response_Continuous, null);
		sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 11 sched= "&amp;sched.String, LogDebug);
		if sched &lt;&gt; null and sched.status = JACBackupRunning then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 12 sched= "&amp;sched.String&amp;' '&amp;sched.status, LogDebug);
			beginTransaction;
			self.sdsCauseEvent(NotifyBackupServerDoTerminate, false, null);
			commitTransaction;
		endif;
		sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 13 sched= "&amp;sched.String, LogDebug);
		if sched &lt;&gt; null and sched.status = JACBackupActivated then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppStarted='&amp;NotifySecServerAppStarted.String&amp;" 14 sched= "&amp;sched.String&amp;' '&amp;sched.status, LogDebug);
			beginTransaction;
			self.sdsCauseEvent(NotifyBackupServerDoTerminate, false, null);
			commitTransaction;
		endif;
	endif;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " start Backup control app notification", LogDebug);
	self.beginNotification(self, NotifyBackupServerDoTerminate, Response_Continuous, null);
	self.beginNotification(self, NotifyBackupControlApp, Response_Continuous, null);
	self.beginNotification(self, NotifyBackupAbort, Response_Continuous, null);
	self.beginNotification(self, NotifySecServerAppRunning, Response_Continuous, null);
	self.beginNotification(self, NotifyTerminate, Response_Continuous, null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isBackupRunning" id="81b3c0b7-3e8a-4fd6-ad2f-e27105599c34">
        <updating/>
        <source>isBackupRunning(_sched: JACBackupSchedule io) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Apr 2008	cnwkpd1		PAR #16421 - Rework to remove locking on system
//							collections	
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
//	nod: Node;
	pro: Process;
	contApp, splitApp: Boolean;
	message: String;
	invalidProcess : Boolean;
	
begin
	contApp := false;
	splitApp := false;
	
	on Exception do app.handleDeletedObject(exception, pro, invalidProcess);		// PAR #16421

	foreach pro in Process.instances do
		if pro.persistentApp.name = JACBackupControlAppName then
			contApp := true;
		elseif pro.persistentApp.name = JACBackupSplitAppName then
			splitApp := true;
		endif;
		if contApp and splitApp then
			break;
		endif;
	endforeach;

/*	PAR #16421 - Old code replaced	
		
	foreach nod in system.nodes do
		foreach pro in nod.processes do
			if pro.persistentApp.name = JACBackupControlAppName then
				contApp := true;
			elseif pro.persistentApp.name = JACBackupSplitAppName then
				splitApp := true;
			endif;
		endforeach;
	endforeach;
*/

	if not global.isValidObject(_sched) then
		return;
	endif;
	

	// No app but running still a running schedule object
	if not contApp and 
	   _sched.status = JACBackupRunning then
		beginTransaction;
		_sched.setStatus(JACBackupFailed);
		message := _sched.finalMessage &amp; CrLf &amp; 
			"Schedule item was in running state but backup application had terminated." &amp; CrLf &amp;
			"Backup not completed.";
		if splitApp then
			message := _sched.finalMessage &amp; CrLf &amp; 
				"Split applications remained running when checking was done.";
		endif;
		_sched.setFinalMessage(message);
		commitTransaction;
		_sched.backupFinished;
	endif;
end;</source>
        <Parameter name="_sched" type="JACBackupSchedule" usage="io"/>
    </JadeMethod>
    <JadeMethod name="secLogFileCleanup" id="d1075df1-925c-4b7a-aa2d-3b1a8b0db576">
        <source>secLogFileCleanup();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Only called on secondary database to cleanup its journal files.
// 				This is done for the primary during the log file transfer but
//				the primary dosnt have access to the secondary log directory
//				The secondary must look after its own log directory so it does
//				at the end of each backup with this method.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	folder: FileFolder;
	fileNode: FileNode;
	file: File;
	today: Date;
begin
	if self.purgeLogDays &gt; 0 then
		if self.purgeSDSLogs then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Database logfiles older than ('&amp;self.purgeLogDays.String&amp;')', LogNormal);				
			create folder transient;
			folder.fileName := app.myDBA.getCurrentLogDirectory;
			folder.mask := "*.log";						//Just the log files !
			foreach fileNode in folder.files where fileNode.isKindOf(File) do
				file := fileNode.File;
				if file.lastModified.Date + purgeLogDays &lt; today then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Purging Database logfile ('&amp;file.name&amp;')', LogNormal);				
					if file.tryOpen then				//Access rights ?
						file.purge;
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Unable to access database logfile ('&amp;file.name&amp;') - not purged', LogNormal);				
					endif;
				endif;
			endforeach;
		endif;
	endif;
epilog
	delete folder; //Jade 6.1.12 causes exception
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="5cac9c24-1977-4724-9e70-06738e8f9fbd">
        <source>sendEmail(_subject, _message: String);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	boundary,i: Integer;
	file: File;
	attachment: CnAttachment;
	smtp: CnSmtpConnection;
	kc: CnKarmaCntrl;
//	cc: CnCntrl;
begin

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Preparing email for ' &amp; self.emailAddress &amp; ' via ' &amp; self.smtpServer, LogDebug);

    kc := app.myCnKarmaCntrl;    
	if kc = null then
		create kc transient;
	endif;

	create smtp;
	smtp.myCnKarmaCntrl := kc;

	self.beginNotification(smtp, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0); 

	smtp.name := self.smtpServer; 
   
	smtp.sendFrom := self.emailAddress;
	smtp.sendTo := self.emailAddress;

	smtp.subject := _subject;

	if _message &lt;&gt; null then
		smtp.message := _message;
	endif;
 
	smtp.send; //Connect and send email

	app.doWindowEvents(5000);	// to allow email to be sent ???
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Email sent', LogDebug);

end;</source>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
