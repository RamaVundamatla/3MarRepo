    <JadeMethod name="setupForm" id="2613877b-b7cd-4024-b235-4664aefd722f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ratio : Integer;
	
begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
		
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	
//	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA), Response_Continuous, null); // PAR 10328

	self.initFolder();		
	self.initTblWorkEntries();
	self.initTableInfo();
	self.initFrameRake();
	
	self.fldInfo.useSheetBackColors := true;
	self.fldInfo.setDefaultSheetBackColors();
	self.fldInfo.initSheetBackColors();
	
	self.mySDF.caption := null;
	self.mySDF.myTerminal := self.myTerminal;
	self.mySDF.setupFrame();
		
	self.frmModeStatusBar.initFrame();
	self.frmModeStatusBar.myFrameDisplayMode.enabled := false;

	self.mnuToggleMultiSelect.click(mnuToggleMultiSelect);		
	self.mnuToggleToolbar.caption := self.MNU_TOOLBAR_HIDE;

	self.splMain.setLeftToRightRatioAndResize(self.getSpliterRatio(self.splMain));
	
	self.splOperations.setLeftToRightRatioAndResize(self.getSpliterRatio(self.splOperations));
	if self.splOperations.leftToRightRatio = 0 then
		self.mnuHideTreeView.caption := ShowTreeView;
	else
		self.mnuHideTreeView.caption := HideTreeView;			
	endif;
	
	ratio := self.getSpliterRatio(splGridArea);
	if ratio &lt; 1 or ratio &gt; 99 then
		ratio := 10;	// the default
		self.splGridArea.hideLeftControl(true);
		self.mnuToggleLegend.caption := self.MNU_LEGEND_SHOW;
	else
		self.splGridArea.showLeftControl(ratio, true);
		self.mnuToggleLegend.caption := self.MNU_LEGEND_HIDE;
	endif;

	self.splGridAreaRatio := ratio;
	
	
	self.splExtraInfo.setLeftControl(self.frmLeftSplitter);
	self.splExtraInfo.setRightControl(self.tblInfoSmall);
	ratio := self.getSpliterRatio(splExtraInfo);

	if ratio &lt; 1 or ratio &gt; 99 then
		ratio := 80;	// the default
		self.splExtraInfo.hideRightControl(true);
		self.mnuToggleExtraInfo.caption := self.MNU_EXTRAINFO_SHOW;
	else
		self.splExtraInfo.showRightControl(100 - ratio, true);
		self.mnuToggleExtraInfo.caption := self.MNU_EXTRAINFO_HIDE;
	endif;

	self.splExtraInfoRatio := ratio;

	self.lstJobs.setFocus();
	
	self.setMenuVisibility();				//+cnwml2 PAR23715 SFW CCMS1131
	self.frmTableFilter.setupControl(self.tblWorkEntries, null); //05/06/2024	navkc1 CR 63736 Task 63770
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAdditionalInformationForm" id="1b2340e7-4d9b-4276-a917-08c98641f3a2">
        <source>showAdditionalInformationForm();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lAdditionalInfo	: CMUI_AdditionalInfo;
	lRailLine	: Object;
begin

	if self.myCurrentWLE = null or
	   (not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest)) then
		return;
	endif;
	
	lAdditionalInfo := app.loadForm(CMUI_AdditionalInfo, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_AdditionalInfo;
	// Update the navigator
	self.setNavigatorHeading(lAdditionalInfo.caption); 
	lAdditionalInfo.centreWindow;
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// lAdditionalInfo.isModal := true;
	lAdditionalInfo.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;
	lAdditionalInfo.setMyTerminal(self.myTerminal);

	lAdditionalInfo.showModal;

	self.displayExtraInfoForObj(self.myCurrentWLE);
	
end;</source>
    </JadeMethod>
