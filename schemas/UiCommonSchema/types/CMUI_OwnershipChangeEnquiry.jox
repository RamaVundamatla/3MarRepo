    <JadeMethod name="setFilters" id="d1c4d29e-3c7c-4e06-a89b-00d44fd5a174">
        <updating/>
        <source>setFilters()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023 navtnr20	TFS CR 58224	Task 58226: UI - COO Query
*/

vars

begin
	self.filterQueryRefNumber := self.txtRefNumber.text.trimBlanks().toUpper();
	
	self.filterQueryCOOFromStart.setDate(self.mskCOOFromStart.getDate());
	self.filterQueryCOOFromTime.setTime(self.mskCOOFromStartTime.getTime());
	self.filterQueryCOOEndDate.setDate(self.mskCOOFromEnd.getDate());
	self.filterQueryCOOEndTime.setTime(self.mskCOOFromEndTime.getTime());
	
	self.valueOperatorNew := self.frmNewOperator.txtCriteriaValue.text;
	self.valueOperatorOld := self.frmOrgOperator.txtCriteriaValue.text;
	
	self.filterQueryCargoType	:= 	self.valueQueryCargoType;
	self.filterQueryCommodity	:= self.valueQueryCommodity;
	self.filterOperatorNew		:= self.valueOperatorNew;
	self.filterCargoSubType		:= self.valueCargoSubtype;
	self.filterOperatorOld		:= self.valueOperatorOld;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setOperatoNew" id="5efc8986-b830-4338-bee3-49dc58098b65">
        <updating/>
        <source>setOperatoNew()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	event : CM_Operator;
	allCriteriaStr : String;
begin
	criteriaFrame := self.frmNewOperator;
	criteriaFrame.transparent := true;
	criteriaFrame.setMasterControl(null);
	critType := CM_YATypeOperatorItem.firstInstance();
	
	if critType &lt;&gt; null then
		criteriaFrame.setCriteriaType( critType );
		criteriaFrame.setLabelVisible(true);	
		criteriaFrame.setLabel("New Operator");
		criteriaFrame.setWidth(560);			
		criteriaFrame.move(300, 40, 560, 40);
		criteriaFrame.visible := true;
		
	endif;

epilog

end;</source>
    </JadeMethod>
