    <JadeMethod name="setEnableObjects" id="64805e78-0552-46ea-b847-b7e808ae8f5f">
        <updating/>
        <source>setEnableObjects() updating;
/* ---------------------------------------------------------------------------
Created:		November 2004 By Andrew Bishop cnwab1

Purpose:		

---------------------------------------------------------------------------
Changed On	By			Reason
----------	--------	--------------------------------------------------
08/11/2015	cnwdap1		PAR #37149 Enable New button even if no invoice selected
17/03/2017 	cnwma1 	    TFS #3661:ADP - Invoice Management Permissions
29/03/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
19 Sep 2018 cnwma1		ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
10 Oct 2018 cnwma1      ChangeRequest 41380: PEL1 - Resend option for failed SAP WSDLs
12 Nov 2018	cnwma1		ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
15 Nov 2018 cnwma1		Bug 41992: PEL1 - Disputed Invoice process
24/10/2019	JLGNS1		Bug 47154: ADP - Invoice Status Permission (Pending) not working
18/02/2022	navsrk20 	ChangeRequest 52771: EUP - INV - Invoice Notes (UI)
14/03/2022	jlier1		TFS 53286 IFS Integration
07/10/2022  navmv20		ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
24/01/2023	navkc1		TFS CR 55305 Task 55537: UI - Invoice List UI changes
06 June 2023  navmv20   Bug 58388: EUP - Copy Posted Invoices	
01/11/2023	navkc1 		Bug 60895: FR | 54086 - Invoice Maintenance - Changing an Invoice to credit notes
5/12/2023	navra1		TFS 54090 CR 61417 - Task 61418 &amp; 61420
06 May 2024 navnk30		Defect 63947: MTN - (14051) Invalid table row error and 1090 exception on the Invoice List Form when searching for the invoices
NAVAB1 31JUL2025 - changed to use local variable. and added new LINX statuses
*/	
vars
	canMaint ,
	canNew   ,						
	canOverride,
	canReevaluate ,
	canClose ,
	canPost,
	canVoid,
	canApprove,
	canPostDraft,
	canExport,
	canExportToFile,
	canPrepend, 
	canDispute,
	canViewTrans,
	canUpdateInv,
	canOverrideRatesInv,	  //12.11.2018 cnwma1 TFS #41945
	canDoCreditNote,
	canCopyInv			: Boolean; // 24/01/2023	navkc1	TFS CR 55305 TASK 55537
	invoiceSelected 	: Boolean;
	currentInv,currentInvoice      	: CM_Invoice;
	canViewNotes		: Boolean;		//18/02/2022 navsrk20 TFS# 52771
	finIO:   CM_ExtFinanceIO;
	obj : ObjectArray;
	invProcess : CM_InvoiceProcess;
	user : CM_User;
	bank : CM_Bank;
begin
	invoiceSelected	:= self.myCurrentInvoice &lt;&gt; null;
	currentInv      := self.myCurrentInvoice;
	user :=  app.getMyUser();
	bank := self.myCurrentBank;
	if bank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
		bank := self.myCurrentBank;
	endif;
	
	canMaint		:= user.canDo(self.myTerminal,PmAdmInvoicelistMaint) and invoiceSelected;
	canNew 			:= user.canDo(self.myTerminal,PmAdmInvoicelistMaint);		 // PAR #37149
	canOverride 	:= user.canDo(self.myTerminal,PmAdmInvListOverrideRates);	 // 17/03/2016 cnwma1 TFS #3661
	canReevaluate	:= user.canDo(self.myTerminal,PmAdmInvListReEvaluate);   	 // 17/03/2016 cnwma1 TFS #3661
	// TFS 39618 PATCH 1 canClose		:= user.canDo(self.myTerminal,PmAdmInvListStatusClose); 	     // 17/03/2016 cnwma1 TFS #3661
	canExport		:= user.canDo(self.myTerminal,PmAdmInvListExportInv);   		 // 17/03/2016 cnwma1 TFS #3661
	canExportToFile := user.canDo(self.myTerminal,PmAdmInvExportToFile);   		 // 17/03/2016 cnwma1 TFS #3661
	// TFS 39618 PATCH 1 canPost			:= user.canDo(self.myTerminal,PmAdmInvoiceStatusPost);  		 // 17/03/2016 cnwma1 TFS #3661
	// TFS 39618 PATCH 1 canVoid 		:= user.canDo(self.myTerminal,PmAdmInvoiceStatusVoid);  		 // 17/03/2016 cnwma1 TFS #3661
	// TFS 39618 PATCH 1 canPrepend 		:= user.canDo(self.myTerminal, PmAdmInvoiceStatusPrepend);		 // TFS 37560
	// TFS 39618 PATCH 1 canDispute 		:= user.canDo(self.myTerminal, PmAdmInvoiceStatusDisputed);	 // TFS 37560
	canViewTrans    := user.canDo(self.myTerminal, PmTiTransactionView);
	canViewNotes	:= user.canDo(self.myTerminal,PmAdmInvNotesView);		//18/02/2022 navsrk20 TFS# 52771
	canDoCreditNote := user.canDo(self.myTerminal, PmAdmInvoiceCreditNoteMaint); // 25/01/2023	navkc1	TFS CR 55305 TASK 55537
	canCopyInv		:= user.canDo(self.myTerminal, PmAdmInvoiceCopyMaint);		//navtnr20 7-04-2023 	TF 55531
	if bank = null then
		bank := self.myTerminal.getDefaultCompanyBank();
	endif;
	canDispute := bank.userCanSet(CM_Invoice.INVOICE_DISPUTED);  // TFS 39618 PATCH 1 
	canPrepend := bank.userCanSet(CM_Invoice.INVOICE_PREPEND);  // TFS 39618 PATCH 1 
	canVoid := bank.userCanSet(CM_Invoice.INVOICE_VOID);  // TFS 39618 PATCH 1 
	canPost := bank.userCanSet(CM_Invoice.INVOICE_POSTED);  // TFS 39618 PATCH 1 
	canClose := bank.userCanSet(CM_Invoice.INVOICE_PENDING);  // TFS 39618 PATCH 1 		//Bug 47154
	canApprove  := bank.userCanSet(CM_Invoice.INVOICE_APPROVED);   // ### JIRA 35468 31JUL2025 NAVAB1
	canPostDraft  := bank.userCanSet(CM_Invoice.INVOICE_POSTED_DRAFT);     // ### JIRA 35468 31JUL2025 NAVAB1

	
	if invoiceSelected then //12.11.2018 cnwma1 TFS #41945  Added For Pelindo
		canUpdateInv        := currentInv.canUpdate;
		canOverrideRatesInv := currentInv.canOverrideRates ;
	endif;
	//  start navtnr20 7-04-2023 	TF 55531
	//currentInvoice := self.tblData.accessRow(tblData.accessedRow.row).itemObject.CM_Invoice;
	/*  // ### JIRA 35468 28JUL2025 NAVAB1 not needed
	if self.tblData.accessedRow &lt;&gt; null and									//06.05.2024 navnk30 #63947
		self.tblData.accessedRow.row &gt; self.tblData.fixedRows and
		self.tblData.accessedRow.row &lt;= self.tblData.rows then
		currentInvoice := self.tblData.accessedRow.itemObject.CM_Invoice;	//06.05.2024 navnk30 #63947
	endif;
	*/
	
	obj := self.tblData.allSelectedObjects;
	if obj.size = 1 then 
		self.mnuCopySelectedInv.enabled := true; 
		else
		self.mnuCopySelectedInv.enabled := false;
	endif;
	if canCopyInv and currentInv &lt;&gt; null then
		if currentInv.status = CM_Invoice.INVOICE_OPEN 
		or  currentInv.status = CM_Invoice.INVOICE_POSTED_DRAFT  // ### JIRA 35468 31JUL2025 NAVAB1 
		or  currentInv.status = CM_Invoice.INVOICE_PENDING 
		or currentInv.status = CM_Invoice.INVOICE_POSTED then //06/06/2023 navmv20 Bug 58388
			self.mnuCopySelectedInv.visible := true; 
		else
			self.mnuCopySelectedInv.visible := false;
		endif;
	endif;
	// end navtnr20 7-04-2023 	TF 55531
	/*OverRide*/
	self.btnOverRide.enabled 	:= canOverride and canOverrideRatesInv and canUpdateInv;				// 17/03/2016 cnwma1 TFS #3661
	self.mnuInvOverride.visible := self.btnOverRide.enabled;
	
	self.mnuInvOvrTaxCode.visible := self.btnOverRide.enabled; //13/10/2022 navmv20 TFS 55005
	
	/*New*/
	self.btnNew.enabled 		:= canNew;											   	 // PAR #37149
	self.mnuInvNew.visible 		:= self.btnNew.enabled;									 // PAR #37149
	
	/*Update*/
	//self.btnUpdate.enabled 	:= canMaint;    									     //12.11.2018 cnwma1 TFS #41945
	self.btnUpdate.enabled  	:= canMaint and canUpdateInv;							 //12.11.2018 cnwma1 TFS #41945
	self.mnuInvUpdate.visible	:= self.btnUpdate.enabled;
	
	/*ReEvaluate*/
	//self.btnReeval.enabled      := canReevaluate and invoiceSelected and self.myCurrentInvoice.canBeReevaluated;      // 17/03/2016 cnwma1 TFS #3661 	 //12.11.2018 cnwma1 TFS #41945
	self.btnReeval.enabled        := canReevaluate and invoiceSelected and currentInv.canBeReevaluated and canUpdateInv; 					 //12.11.2018 cnwma1 TFS #41945
	self.mnuInvReeval.visible     := self.btnReeval.enabled;
	self.mnuInvRecalc.visible     := self.btnReeval.enabled; // ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
	
	/*Status Pending*/
	//self.btnStatusClose.enabled := canClose and invoiceSelected and self.myCurrentInvoice.canBeClosed; 			 // 17/03/2016 cnwma1 TFS #3661  //12.11.2018 cnwma1 TFS #41945
// TFS 39618		self.btnStatusClose.enabled   := canClose and invoiceSelected and self.myCurrentInvoice.canBeClosed and canUpdateInv;						     //12.11.2018 cnwma1 TFS #41945
// TFS 39618		self.mnuInvClose.visible	  := self.btnStatusClose.enabled; 
	self.mnuInvPending.visible := canClose and invoiceSelected and currentInv.canBeClosed and canUpdateInv; // TFS 39618	

	/*Status Posting*/
	//self.btnStatusPost.enabled :=  canPost and  invoiceSelected and self.myCurrentInvoice.canBePosted; //epr 24/9/15 par 36958 // 17/03/2016 cnwma1 TFS #3661 //12.11.2018 cnwma1 TFS #41945
// TFS 39618	self.btnStatusPost.enabled   :=  canPost and  invoiceSelected and self.myCurrentInvoice.canBePosted and canUpdateInv  ;                     			    //12.11.2018 cnwma1 TFS #41945
// TFS 39618	self.mnuInvPost.visible      :=  self.btnStatusPost.enabled;
	self.mnuInvPost.visible := canPost and  invoiceSelected and currentInv.canBePosted and canUpdateInv  ;// TFS 39618
	/*Status Void*/
	//self.btnStatusVoid.enabled := canVoid and invoiceSelected and self.myCurrentInvoice.canBeVoided; 					// 17/03/2016 cnwma1 TFS #3661            //12.11.2018 cnwma1 TFS #41945
// TFS 39618 861.010	self.btnStatusVoid.enabled   := canVoid and invoiceSelected and self.myCurrentInvoice.canBeVoided and canUpdateInv;   		     			      			 //12.11.2018 cnwma1 TFS #41945
// TFS 39618 861.010	self.mnuInvVoid.visible      := self.btnStatusVoid.enabled;
	self.btnStatusVoid.visible := false; // TFS 39618 861.010 this is used by invoice LINE list
	self.mnuInvVoid.visible := canVoid and invoiceSelected and currentInv.canBeVoided and canUpdateInv; // TFS 39618 861.010
	
	/*Status Suspend*/
	//self.btnStatusSuspens.enabled := canMaint;	//Par17895   				   							 //12.11.2018 cnwma1 TFS #41945
// TFS 39618	self.btnStatusSuspens.enabled   := canMaint and canUpdateInv and self.myCurrentInvoice.canBeSuspended;    //12.11.2018 cnwma1 TFS #41945
// TFS 39618	self.mnuInvSuspense.visible     := self.btnStatusSuspens.enabled;
	self.mnuInvSuspense.visible := canMaint and canUpdateInv and currentInv.canBeSuspended; // TFS 39618
	
	/*Status Prepend*/
// TFS 39618	self.btnStatusPrepend.enabled   := canPrepend and invoiceSelected and									// TFS 37560
// TFS 39618									self.myCurrentInvoice.myVoyage &lt;&gt; null and								// TFS 37560
// TFS 39618								    canUpdateInv and 					        							//12.11.2018 cnwma1 TFS #41945
// TFS 39618									not self.myCurrentInvoice.myVoyage.isUsingDefaultProcessJMT and			//23 Jul 2018	NDL	TFS 39882
// TFS 39618									//(self.myCurrentInvoice.isOpen or self.myCurrentInvoice.isDisputed);	// TFS 37560
// TFS 39618									self.myCurrentInvoice.isOpen;											// 15.11.2015 cnwma1 Bug #41992
// TFS 39618	self.mnuInvPrepend.visible      := self.btnStatusPrepend.enabled;										// TFS 37560
	self.mnuInvPrepend.visible := canPrepend and invoiceSelected and									// TFS 37560
									currentInv.myVoyage &lt;&gt; null and								// TFS 37560
								    canUpdateInv and 					        							//12.11.2018 cnwma1 TFS #41945
									not currentInv.myVoyage.isUsingDefaultProcessJMT and			//23 Jul 2018	NDL	TFS 39882
									//(self.myCurrentInvoice.isOpen or self.myCurrentInvoice.isDisputed);	// TFS 37560
									currentInv.isOpen;
	/*Status Dispute*/
// TFS 39618	self.btnStatusDispute.enabled 	:= canDispute and invoiceSelected and 									// TFS 37560
// TFS 39618									self.myCurrentInvoice.myVoyage &lt;&gt; null and								// TFS 37560
// TFS 39618									canUpdateInv and   														//12.11.2018 cnwma1 TFS #41945
// TFS 39618									not self.myCurrentInvoice.myVoyage.isUsingDefaultProcessJMT and			//23 Jul 2018	NDL	TFS 39882
// TFS 39618									(self.myCurrentInvoice.isOpen or self.myCurrentInvoice.isPrepend);		// TFS 37560
// TFS 39618	self.mnuInvDisputed.visible 	:= self.btnStatusDispute.enabled;										// TFS 37560
	self.mnuInvDisputed.visible := canDispute and invoiceSelected and 									// TFS 37560
									currentInv.myVoyage &lt;&gt; null and								// TFS 37560
									canUpdateInv and   														//12.11.2018 cnwma1 TFS #41945
									not currentInv.myVoyage.isUsingDefaultProcessJMT and			//23 Jul 2018	NDL	TFS 39882
									(currentInv.isOpen or currentInv.isPrepend);		// TFS 37560
	/*Status Posted Draft */
	self.mnuInvPostDraft.visible := canPostDraft and invoiceSelected and currentInv.canBePostDraft() ;  // ### JIRA 35468 31JUL2025 NAVAB1
	/*Status Approved */
	self.mnuInvApproved.visible := canApprove and invoiceSelected and currentInv.canBeApproved() ;  // ### JIRA 35468 31JUL2025 NAVAB1
									
									

	self.btnPrint.enabled 		    := invoiceSelected;
	self.mnuInvPrintDetail.visible  := invoiceSelected;
	self.btnPrintConsol.enabled     := invoiceSelected;
	self.mnuInvPrintConsol.visible  := invoiceSelected;
	self.btnPrintInvoice.enabled    := invoiceSelected;
	self.mnuInvPrintInvoice.visible := invoiceSelected;
	self.btnPrintOneLine.enabled	:= invoiceSelected;
	self.btnInvoiceLines.enabled	:= invoiceSelected;
	self.mnuInvLines.visible		:= invoiceSelected;
	self.mnuApiActivity.visible 	:= invoiceSelected;										//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
	
	/*Audits*/
	self.btnAudits.enabled			:= currentInv &lt;&gt; null and currentInv.hasFinancialAudits;
	self.mnuInvAudits.visible		:= self.btnAudits.enabled;
	
	
	//status close
	// TFS 3065	self.btnStatusClose.enabled :=canMaint and self.myCurrentInvoice.canBeClosed;
	//epr par 36958 from pauls feedback 
// TFS 39618	if self.btnStatusClose.enabled and self.myCurrentInvoice &lt;&gt; null and self.myCurrentInvoice.isVoided then
// TFS 39618		self.btnStatusClose.enabled := canVoid; // 17/03/2016 cnwma1 TFS #3661
// TFS 39618	endif;
// TFS 39618	self.mnuInvClose.visible        := self.btnStatusClose.enabled;
	
	if self.mnuInvPending.enabled and currentInv &lt;&gt; null and currentInv.isVoided then // TFS 39618
		self.mnuInvPending.enabled := canVoid; // TFS 39618
	endif; // TFS 39618
	
	/*Open Schedule*/
	self.btnOpenSchedule.enabled    := canMaint and (currentInv.isPosted or currentInv.isPostedDraft);    // ### JIRA 35468 31JUL2025 NAVAB1
	
	/*Export*/
	self.btnExport.enabled    := canExport and  invoiceSelected and  currentInv.canBeExported; // 17/03/2016 cnwma1 TFS #3661
	if self.btnExport.enabled then
		//jlier1 TFS 53286 14/4/22
		finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIO &lt;&gt; null then
			if finIO.isKindOf(CM_SALInterface) then
				if currentInv.exportedCount &gt; 0 then
					self.btnExport.enabled:=false;
				endif;
			elseif finIO.isKindOf(CM_POBFinanceOneInterface) then //jlier1 TFS 56856 31/3/23 
				self.btnExport.enabled:=currentInv.isReverseCredit;
				canExportToFile:=false;
			endif;
		endif;
	endif;
	
	// 24/01/2023	navkc1	TFS CR 55305 TASK 55537
	//self.mnuContextChgToCrdNote.visible := true; //01/11/2023	navkc1 Bug 60895
	self.mnuContextCrteCrdFrmInv.visible := true;
	self.mnuContextLinkCredit.visible := true;
	self.mnuContextUnlinkCredit.visible := true;
	//self.mnuContextChgToCrdNote.enabled := canDoCreditNote; //01/11/2023	navkc1 Bug 60895
	self.mnuContextCrteCrdFrmInv.enabled := canDoCreditNote;
	self.mnuContextLinkCredit.enabled := canDoCreditNote;
	self.mnuContextUnlinkCredit.enabled := canDoCreditNote;
	
	self.mnuInvExport.visible := self.btnExport.enabled;
		
	/*Export To File*/
	self.btnExport2File.enabled:=   invoiceSelected and  canExportToFile and  currentInv.canBeExported ; // 17/03/2016 cnwma1 TFS #3661
	self.mnuInvExport2File.visible:= self.btnExport2File.enabled;
	
	//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 3rd Jan 2023 - start
	if currentInv &lt;&gt; null and currentInv.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) then
		self.btnExport.enabled := false;
		self.btnExport2File.enabled := false;
	endif;
	//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 3rd Jan 2023 - end
	
	/*View Transaction*/
	self.mnuContextViewTxns.visible :=invoiceSelected and canViewTrans ;
	
	/*View Invoice Notes*/
	self.mnuInvoiceNotes.visible	:= canViewNotes;		//18/02/2022 navsrk20 TFS# 52771
	self.setEnableInvReturn();			//31 Aug 2017	NDL	TFS 6759 - seperated because has to be called from click for multi-select
	self.setEnableInvUpdatePayStatus(); //19.9.2018 cnwma1 TFS #39698
	self.setEnableInvRecheckFin (); 	//12.10.2018 cnwma1 ChangeRequest 41380
	self.mnuInvShowFOActivity.visible:=invoiceSelected and currentInv.allEWSFinanceOneActivities.size &gt; 0 and app.getMyUser.canDo(self.myTerminal,PmAdmEWSMonitorView); //jlier1 TFS 56856 4/4/23
	self.populateCmbStatus(); // TFS 39618
end;</source>
    </JadeMethod>
    <JadeMethod name="setFiltersValue" id="9d337e98-6b7e-482b-aa46-90ef4a080a3c">
        <updating/>
        <source>setFiltersValue() updating;

vars

begin
	if self.cmbDebtor.listObject &lt;&gt; null then
		self.filterDebtor := self.cmbDebtor.listObject.CM_Debtor;
	else
		self.filterDebtor := null;
	endif;
	
	if self.cmbVoyage.listObject &lt;&gt; null then
		self.filterVoyage := self.cmbVoyage.listObject.CM_Voyage;
	else
		self.filterVoyage := null;
	endif;

	if self.cmbCargoID_.listObject &lt;&gt; null then	//Par 17895. September 2008
		self.filterTI := self.cmbCargoID_.listObject.CM_TrackedItem;
	else
		self.filterTI := null;
	endif;
	
	if self.cmbBank.listObject &lt;&gt; null then
		self.filterBussinessUnits := self.cmbBank.listObject.CM_Bank;
	else
		self.filterBussinessUnits := null;
	endif;

	self.filterStatus := self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.listIndex];

	if self.cmbInvoiceType.listObject &lt;&gt; null then
		self.filterType := self.cmbInvoiceType.listObject.CM_InvoiceDesc.number;
	else
		self.filterType := -1;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCaption" id="cd11d3e8-a575-4b84-b59f-aa2320b542aa">
        <updating/>
        <source>setMyCaption() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//28/7/2025 navsaa30 MTN-35313 | Pagination - Invoice List
vars
	theCaption: String;
	numItems : Integer;
	col : Collection;
begin
	col := self.tblData.getCollection();		//navsaa30 #35313
	if col &lt;&gt; null then
		numItems := col.size();
	else
		numItems := self.tblData.rows - self.tblData.fixedRows;
	endif;
	theCaption := app.getErrorString(INV_Invoice_List);

	if self.cmbDebtor.listIndex &gt; 0 then
		theCaption := theCaption &amp; " - " &amp; self.cmbDebtor.text &amp; "/" &amp; self.cmbInvoiceStatus.text &amp; "/" &amp; self.cmbInvoiceType.text;
	elseif self.cmbCargoID_.listIndex &gt; 0 then
		theCaption := theCaption &amp; " - " &amp; self.cmbCargoID_.text &amp;" - "&amp; app.getErrorString(CargoItemInvoices);
	elseif self.cmbVoyage.listIndex &gt; 0 then
		theCaption := theCaption &amp; " - " &amp; self.cmbVoyage.text;
	endif;
	theCaption := theCaption &amp; " (" &amp; numItems.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; ")";
	theCaption := theCaption &amp; " " &amp; self.myCurrentBank.code; // 	TFS 2682
	//self.caption := theCaption;
	self.setCaption(theCaption);

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTI" id="87919878-8614-40b1-892f-4618f7a5c1d1">
        <updating/>
        <source>setMyCurrentTI() updating, protected;
/* ---------------------------------------------------------------------------
Created:	11 September 2008	by cnwvu1

Purpose:	When CargoType or CargoID is changed, we should re-lookup ti
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoTypeId,
	tiId		: String;
	ti			: CM_TrackedItem;
	cargoType	: CM_CargoType;
	cargoOperator : CM_Operator;
	cargoLocation : CM_LocationsController;
	
begin

	
	tiId		:= self.tblInvProperties.getValueByName(ETRow_CargoId).String;
	cargoTypeId	:= self.tblInvProperties.getValueByName(ETRow_CargoType).String;
	cargoType	:= self.cmbCargoTypeInvP.listObject.CM_CargoType;
	
	cargoOperator := self.cmbCargoOper.listObject.CM_Operator;	//13 Dec 2019	NDL	TFS 47954
	cargoLocation := self.cmbCargoLoc.listObject.CM_LocationsController;	//13 Dec 2019	NDL	TFS 47954
	
	if tiId = null or cargoTypeId = null then
		self.myCurrentTI		:= null;
		self.myCurrentCargoType	:= null;
		self.myCurrentTIOperator := null;	//13 Dec 2019	NDL	TFS 47954
		self.myCurrentTILocation := null;	//13 Dec 2019	NDL	TFS 47954
		self.tblInvProperties.setValueByName( ETRow_ReceivedDT, null );
		self.tblInvProperties.setValueByName( ETRow_ReleaseDT, null );
		return;
	endif;

	// so, there is tiId &lt;&gt; null and cargoTypeId &lt;&gt; null
	if self.myCurrentTI &lt;&gt; null 
	and self.myCurrentCargoType &lt;&gt; null
	and self.myCurrentTI.id = tiId 
//	and self.myCurrentCargoType.id.String = cargoTypeId
	and self.myCurrentCargoType.description = cargoTypeId	//17 Dec 2019	NDL	TFS FS 47954
	and self.myCurrentTIOperator = cargoOperator	//13 Dec 2019	NDL	TFS 47954
	and self.myCurrentTILocation = cargoLocation	//13 Dec 2019	NDL	TFS 47954
	then
		return;	// nothing changed, just return
	endif;
	
	self.myCurrentTI		:= null;
	self.myCurrentCargoType	:= null;
	self.tblInvProperties.setValueByName( ETRow_ReceivedDT, null );
	self.tblInvProperties.setValueByName( ETRow_ReleaseDT, null );

	ti := self.getMyTrackedItem( tiId, self.cmbCargoTypeInvP.listObject.CM_CargoType, cargoOperator, cargoLocation  );
	if ti &lt;&gt; null then
		self.myCurrentTI		:= ti;
		self.myCurrentCargoType	:= cargoType;
		self.myCurrentTIOperator := cargoOperator;
		self.myCurrentTILocation := cargoLocation;
		//show dates on the form
		if ti.receivedDT &lt;&gt; null then
			self.tblInvProperties.setValueByName( ETRow_ReceivedDT, ti.receivedDT.asStringJMT() );
		endif;
		if ti.releasedDT &lt;&gt; null then
			self.tblInvProperties.setValueByName( ETRow_ReleaseDT, ti.releasedDT.asStringJMT() );
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyCharge" id="abedb412-dd3c-41a6-9d7b-9f8a6baf98e7">
        <updating/>
        <source>setProxyCharge(_theCharges : CM_ChargeByServiceRateOvrdDict input;_theService: CM_Service; _rateCurrent: Real; 
					_currentlyOverridden: Boolean; _chargeCount: Integer; _rateNew: Real; _isReinstateRate : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//20/03/2018	jlgrh7 TFS 37476 ADP - FW: Cannot Override the rate on Discount Line.
// ---------------------------------------------------------------------------
vars
	pxyCharge:                 CM_Charge;
	keyService:             CM_Service;
	keyOverridden:          Boolean;
	keyRate:                Real;
	newRate:                Real;
	releaseRate:            Boolean;
	count:                  Integer;
	chargeIterator : Iterator;
	somethingToDo : Boolean;
begin
	//releaseRate := _rateNew = -1;							//-TFS37476 	we will accept  "-1"
	releaseRate := _isReinstateRate;						//+TFS37476

	newRate := _rateNew;
	somethingToDo := true;
	
	if releaseRate and not _currentlyOverridden then
		// nothing to do
		somethingToDo := false;
	elseif newRate = _rateCurrent and _currentlyOverridden then
		// also nothing to do
		somethingToDo := false;
	endif;

	chargeIterator := _theCharges.createIterator;
	_theCharges.startKeyGeq(_theService, _rateCurrent, _currentlyOverridden, chargeIterator);

	// we remove the charge from the collection so as remove the possiblility of revisiting it.
	while chargeIterator.next(pxyCharge) do
	
		
		if pxyCharge.service = _theService then
			_theCharges.remove(pxyCharge);
			if somethingToDo then
				if releaseRate then
					pxyCharge.setProxyRateRelease(); 
				else
					pxyCharge.setProxyRateNew(newRate);
				endif;
			endif;
	
		endif;

		count := count + 1;
		if count = _chargeCount then
			break;
		endif;

	endwhile;
epilog
	delete chargeIterator;
end;</source>
        <Parameter name="_theCharges" type="CM_ChargeByServiceRateOvrdDict" usage="input"/>
        <Parameter name="_theService" type="CM_Service"/>
        <Parameter name="_rateCurrent" type="Real"/>
        <Parameter name="_currentlyOverridden" type="Boolean"/>
        <Parameter name="_chargeCount" type="Integer"/>
        <Parameter name="_rateNew" type="Real"/>
        <Parameter name="_isReinstateRate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setQuery" id="224f8548-7987-409f-a2be-26baa9143261">
        <updating/>
        <source>setQuery() updating;
/* ---------------------------------------------------------------------------
Created:	10 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
08/06/2020 		cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
------------------------------------------------------------------------------*/
vars

begin

	if cmbCargoVoyage_.listCount &lt;= 1 then
		self.doCmbVoyageBuild(self.cmbCargoVoyage_,false,null);
	endif;

	self.cmbBank.visible := true;	// all queries are within business unit
	self.lblBank.visible := self.cmbBank.visible;

	self.cmbVoyage.visible 		  := self.btnQueryVoyage.value;
	self.lblVoyage.visible 	      := self.cmbVoyage.visible;
	self.cmbVoyage.listIndex 	  := -1;
	self.cmbDebtor.listIndex 	  := -1;
	//self.chkArchive.visible  	  := self.btnQueryVoyage.value;	//11.9.2023 navhl20 #59376
	self.cmbDebtor.visible 		  := self.btnQueryDebtor.value;
	self.cmbInvoiceStatus.visible := self.btnQueryDebtor.value;
	self.cmbInvoiceType.visible   := self.btnQueryDebtor.value;
	self.cmbInvCategory.visible   := self.btnQueryDebtor.value; //24/02/2023 navmv20 TFS 56403 Task 56404
	self.lblInvCategory.visible   := self.btnQueryDebtor.value; //24/02/2023 navmv20 TFS 56403 Task 56404
	
	self.lblDebtor.visible := self.btnQueryDebtor.value;
	self.lblStatus.visible := self.btnQueryDebtor.value;
	self.lblType.visible   := self.btnQueryDebtor.value;
	
	//self.lblSearchInv.visible := btnQueryInvoice.value;	// 14 Apr 2016	NDL	TFS 1849 //29/03/2023 navmv20 Bug 57023
	self.textSearch.visible :=  btnQueryInvoice.value;
	
	//29/03/2023 navmv20 Bug 57023 - START
	//self.lblExternalNumber.visible := btnQueryInvoice.value; //24/02/2023	navmv20 TFS 56403 Task 56460
	//self.txtExternalNumber.visible := btnQueryInvoice.value; //24/02/2023	navmv20 TFS 56403 Task 56460
	self.lblSearchFor.visible := btnQueryInvoice.value;
	self.cmbSearchFor.visible := btnQueryInvoice.value;
	//self.clickOptInvoice(); // 14 Apr 2016	NDL	TFS 1849
	
	//self.grpSearchBy.visible  := btnQueryInvoice.value;
	//29/03/2023 navmv20 Bug 57023 - END
	self.lblDateRange.visible := self.btnQueryDebtor.value;
	self.mskDateFrom.visible  := self.btnQueryDebtor.value;
	self.mskDateTo.visible    := self.btnQueryDebtor.value;
	
	//10 Aug 2021	NDL	TFS 51702
	self.lblPDateRange.visible := self.btnQueryDebtor.value;
	self.mskPDateFrom.visible  := self.btnQueryDebtor.value;
	self.mskPDateTo.visible    := self.btnQueryDebtor.value;
 
	self.cmbCargoVoyage_.visible:= (self.btnQueryCargo_.value or self.btnQueryBOL.value);
	self.lblCargoVoyage_.visible:=  (self.btnQueryCargo_.value or self.btnQueryBOL.value);
	self.lblCargoID_.visible 	:=  self.btnQueryCargo_.value;
	self.lblCargoSite_.visible	:=  (self.btnQueryCargo_.value or self.btnQueryBOL.value);
	self.lblCargoType_.visible	:=  self.btnQueryCargo_.value;
	self.cmbCargoID_.visible	:=  self.btnQueryCargo_.value;
	self.cmbCargoID_.enabled	:=  self.btnQueryCargo_.value;
	self.cmbCargoSite_.visible	:=  (self.btnQueryCargo_.value or self.btnQueryBOL.value);
	self.cmbCargoType_.visible	:=  self.btnQueryCargo_.value;
 
	// 30931/33528
	self.lblBOL.visible  := self.btnQueryBOL.value;
	self.cmbBOL.visible  := self.btnQueryBOL.value;
	self.lblCnee.visible := self.btnQueryBOL.value;
	self.cmbCnee.visible := self.btnQueryBOL.value;
	
	//03/06/2020 cnwma1 Tfs #49400
	self.lblVoyageGrpCode.visible := self.btnQueryVoyageGrpCode.value;
	self.txtVoyageGrpCode.visible := self.btnQueryVoyageGrpCode.value;
	
	if self.btnQueryDebtor.value then
		self.shtQuery1.caption := app.getErrorString(INV_Invoice_List_By_Debtor);
		self.cmbDebtor.setFocus();
	elseif self.btnQueryCargo_.value then
		self.shtQuery1.caption := app.getErrorString(INV_Query_By_Cargo);
		self.cmbCargoSite_.listIndex:= 1;
		self.cmbCargoSite_.setFocus();
	elseif btnQueryInvoice.value then	
		self.shtQuery1.caption := app.getErrorString(INV_Search_For_An_Invoice);
		self.textSearch.setFocus();
		//self.optSearchInvoice.value := true; //29 Mar 2023 navmv20 Bug 57023
		self.cmbSearchFor.listIndex := self.cmbSearchFor.findStringExact(1,app.getErrorString(Invoice_invoice_number));  //29 Mar 2023 navmv20 Bug 57023
		self.textSearch.dataType := TextBox.DataType_Numeric; //29 Mar 2023 navmv20 Bug 57023
		self.textSearch.maxLength := 9; //29 Mar 2023 navmv20 Bug 57023
	elseif  self.btnQueryVoyage.value then
		self.shtQuery1.caption := app.getErrorString(INV_Invoice_List_By_Voyage);
		self.cmbVoyage.setFocus();
	elseif self.btnQueryBOL.value then		// 30931	set up query by BOL or Consignee
		self.shtQuery1.caption := app.getErrorString(INV_Invoice_By_Bol);  //03/06/2020 cnwma1 Tfs #49400
		self.cmbCargoSite_.listIndex:= 1;
		self.cmbCargoSite_.setFocus();
	elseif self.btnQueryVoyageGrpCode.value then						   //03/06/2020 cnwma1 Tfs #49400
		self.shtQuery1.caption := app.getErrorString(INV_Invoice_By_VoyageGrpCode);
		self.txtVoyageGrpCode.setFocus();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusColour" id="6b8a6c6c-c92c-4f44-8b88-a92c5179b5d3">
        <source>setStatusColour(_theInvoice : CM_Invoice; idx : Integer);
/*
Purpose:			

Date		Who		Reason
07AUG2023	NAVAB1	 BUG 59699
12/03/2024	navkc1 	 Bug 62850: MTN - 14050 error if Status not included in Invoice List screen
*/


vars
	col : Integer;
	invStatus: CM_InvoiceStatus;
	
begin
	col := self.tblData.CM_DataTable.getColumnByRowName(ETRow_Status);
	
	//12/03/2024	navkc1 Bug 62850 - If Status column is not selected in the column organizer, don't need to color it
	if col = null then
		return;
	endif;
	invStatus := _theInvoice.getInvoiceStatusObject(_theInvoice.status);
	self.tblData.accessCell(idx,col).backColor :=invStatus.getStatusColour();
	self.tblData.accessCell(idx,col).foreColor :=self.tblData.accessCell(idx,col).backColor.getInverseColour();
	

epilog	

end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="97127b9d-289a-4695-b93f-2c63182f7786">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 13 December 2022   navmv20  TFS CR 55301 Task 55554: UI - Invoice List changes for Selector
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
// 27/06/2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
vars
begin
	
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmQuery.height := 500; //24/02/2023	navmv20 TFS 56403 Task 56404

	// This needs to be set before the inheritMethod because it is used in it to set mnuContextHide visibility.
	self.useTableInfo	:= true;		// cnwrl1 28/07/2009 PAR 20343
	self.allInvoices.clear(); //13/12/2022 navmv20  CR 55301 Task 55554
	inheritMethod();
	
	self.getXMLSettingsForSetup();

	self.fldQuery.topSheet := self.shtQuery1;
	 // ### TFS BUG 59699 07AUG2023 NAVAB1 self.btnNew.bubbleHelp := "New Invoice Line";

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_InvoiceCreate), Response_Continuous, null);
	self.staStatusBar.visible := true; 		// Par 23340 show select count in status line

	self.setEnableObjects;
	
	//self.cmbVoyage.filterIgnore := true; // ### BUG 56936 06MAR2023 NAVAB1 - has code to constantly rebuild combo, so typing does not work, never has. // ### TFS 59142 (59645) 04Aug2023 NAVPW1
	
	self.showHidePostConfMnu(); // 27/06/2023	navcs2	ChangeRequest 58433: [58454]
end;</source>
    </JadeMethod>
    <JadeMethod name="showAuditForm" id="1b82df2e-1f9a-4ffb-82ba-54a6980c5229">
        <source>showAuditForm();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cma : INV_AuditsInvoices;
	tbl:  Table;
begin

	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentInvoice := self.myCurrentInvoice;
