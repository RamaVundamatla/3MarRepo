<Class name="CM_DataExtractVoyages" id="ffea2281-723e-4717-b7ab-e5073931084b">
    <superclass name="CM_DataExtractClass"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="userData"/>
    <JadeMethod name="extractFieldsBody" id="013e44d3-b2e6-45c5-b904-920725d3d131">
        <source>extractFieldsBody(_terminal: CM_Terminal; _outputFile: File; _counter: Integer io; _breakOut : Boolean output)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	voyage : CM_Voyage;
begin
	foreach voyage in _terminal.allVoyagesByCode do
		if not voyage.isNullVoyage then
			self.extractFieldsFromObject(voyage, _outputFile, _counter, _breakOut);
			if _breakOut then
				return;
			endif;
		endif;
	endforeach;
	
	foreach voyage in _terminal.allVoyagesArchived do
		if not voyage.isNullVoyage then
			self.extractFieldsFromObject(voyage, _outputFile, _counter, _breakOut);		
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
