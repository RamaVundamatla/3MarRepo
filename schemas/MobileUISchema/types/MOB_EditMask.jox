<GUIClass name="MOB_EditMask" id="f4d922c9-be01-430a-91a5-83af00205afe">
    <superclass name="JadeEditMask"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <DevControlTypes name="MOB_EditMask">
