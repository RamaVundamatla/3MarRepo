    <JadeMethod name="getPGateLaneFromAGateLane" id="76e065e0-8445-478d-958b-c3ec14b0c1d7">
        <source>getPGateLaneFromAGateLane() : CM_GateAreaLaneController;
/*

Purpose:			Called from a A Gate Lane Controller to find its equivalent P Gate Lane Controller
					Used for finding Lane Devices as they only exist on PGateLanes not AGateLanes

Parameters:			NONE

Return Value:		CM_GateAreaLaneController	Subsequent Gate area lane controller that is the same as the AGateLane used to call the method

Date		Who		Reason
09 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	aGate							: CM_Gate;
	aGateArea,
	pGateArea						: CM_GateArea;
	aGateAreaUsage,
	gateAreaUsage					: CM_GateAreaUsage;
	locationController				: CM_LocationsController;
	pGateAreaLaneController,
	gateAreaLaneController 			: CM_GateAreaLaneController;
	
begin
	//In case we are calling this from a PGate
	if self.isPGateLane then
		return self;
		
	endif;

	//Get parent gate area
	aGateArea := self.myGridArea.CM_GateArea;
	
	if aGateArea = null then
		return null;
		
	endif;
	
	//Get the area usage from the gate area
	aGateAreaUsage := aGateArea.allGates_IN.first;
	
	if aGateAreaUsage = null then
		return null;
		
	endif;
	
	//Get the Gate from the gate Area usage
	aGate := aGateAreaUsage.myGate;
	
	if aGate = null then
		return null;
		
	endif;
	
	//Foreach gate Area Usage in Gate for the in Areas
	//Keep looping till we find the first P area then capture the gate area from the gate area usage
	foreach gateAreaUsage in aGate.allGateAreas_IN do
		if gateAreaUsage.myGateArea = null then
			continue;
			
		endif;
		
		if gateAreaUsage.myGateArea.areaType = CM_GateArea.AreaType_P then
			pGateArea := gateAreaUsage.myGateArea;
			break;
			
		endif;
	endforeach;
	
	if pGateArea = null then
		return null;
		
	endif;
	
	//Foreach of the LocationControllers (CM_GateAreaLaneController) if the grid row matches and it is a PGate then we have found our equivalent PGateLane for our AGateLane.
	foreach locationController in pGateArea.allLocationsControllers do
		if not locationController.isKindOf(CM_GateAreaLaneController) then
			continue;
			
		endif;
		
		gateAreaLaneController := locationController.CM_GateAreaLaneController;
		
		if gateAreaLaneController.myGridRow.row = self.myGridRow.row and gateAreaLaneController.isPGateLane() then
			pGateAreaLaneController := gateAreaLaneController;
			break;
			
		endif;
		
	endforeach;
	
	return pGateAreaLaneController;

end;</source>
        <ReturnType type="CM_GateAreaLaneController"/>
    </JadeMethod>
