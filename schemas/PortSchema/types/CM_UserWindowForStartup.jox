<Class name="CM_UserWindowForStartup" id="1ebdceb0-c144-443e-95db-8936f00b0b02">
    <superclass name="CM_UserWindow"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Has an instance for every window that the user had open
when they closed the app, if they had saveSettingsOnExit set.</text>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myMenuUserItem" id="bf4aa8a5-f00b-453d-a2cd-0d69f5278eae">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_MenuUserItem"/>
        <access>readonly</access>
        <Inverse name="CM_MenuUserItem::allUserWindowsForStartup"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myUserForStartup" id="a98edbe2-a59b-4a43-ba4f-eb67ac504ea7">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::allUserWindowsForStartup"/>
    </ExplicitInverseRef>
    <JadeMethod name="initForStartup" id="5905ba4e-d5ef-4bf0-a585-5f294f1cf4b7">
        <source>initForStartup(): Boolean;
// ---------------------------------------------------------------------------
// Created:     06 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="1153e4b1-eaa5-497d-9ee2-08f5dae27c29">
        <source>isSameAs(_userWindow: CM_UserWindowForStartup): Boolean;
// ---------------------------------------------------------------------------
// Created:     16 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not inheritMethod(_userWindow)) then
		return false;
	endif;
	
	return (self.myMenuUserItem = _userWindow.myMenuUserItem);

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindowForStartup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="418a4ef6-006e-46d0-b7e6-1a94356ec571">
        <updating/>
        <source>setForCreate(_pxy: CM_UserWindowForStartup; _user: CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate(_pxy);
	
	self.myUserForStartup := _user;

end;</source>
        <Parameter name="_pxy" type="CM_UserWindowForStartup"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8f11095c-12ce-411d-a8d4-8bdbee210653">
        <updating/>
        <source>setForUpdate(_pxy: CM_UserWindowForStartup) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_pxy);
	
	self.myMenuUserItem := _pxy.myMenuUserItem;

end;</source>
        <Parameter name="_pxy" type="CM_UserWindowForStartup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1f83b70e-0c52-44ac-b694-5618293c5df5">
        <updating/>
        <source>setProxy(pUser: CM_User; pWindowName: String; pXMLInfo: String; 
		pTop: Real; pLeft: Real; pWidth: Real; pHeight: Real; pState: Integer;
		_menuUserItem : CM_MenuUserItem) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setProxySuperclass(pUser, pWindowName, pXMLInfo, pTop, pLeft, pWidth, pHeight, pState);
	self.myMenuUserItem	:= _menuUserItem;
	self.myUserForStartup := pUser;
end;</source>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="pWindowName" type="String"/>
        <Parameter name="pXMLInfo" type="String"/>
        <Parameter name="pTop" type="Real"/>
        <Parameter name="pLeft" type="Real"/>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pState" type="Integer"/>
        <Parameter name="_menuUserItem" type="CM_MenuUserItem"/>
    </JadeMethod>
</Class>
