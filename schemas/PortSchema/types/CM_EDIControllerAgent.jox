    <JadeMethod name="getEDIFileType" id="54db30de-4479-41a6-8d6f-1cbef0fd5cc0">
        <updating/>
        <source>getEDIFileType(_ediFile : CM_EDIFile input; _fileType, _version, _sender : String output) protected, updating;
//
// 01 Aug 2012	cnwcs5	par 30136 - change usage for file parameter
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//04 Dec 2014	cnwrs1	PAR #34713 - .NET EDI transform integration
//15 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//25 Mar 2019	jlgzm1	TFS 42276 transformMessage running twice per message
vars
	lines : Integer;
	pos2 : Integer;
	fileLine : String;
	fileExt : String;
	fileName : String;
	dataLine : String;
	binaryLine : Binary;
	transformedMsg : String; //tfs42276
begin
	dataLine := _ediFile.getRawDataString();
	self.getFileTypeFromString(dataLine, fileName, fileExt, _fileType, _version, _sender, transformedMsg);
end;

</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_fileType" type="String" usage="output"/>
        <Parameter name="_version" type="String" usage="output"/>
        <Parameter name="_sender" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getEDIFileTypes_UserDefined" id="47009758-c790-4d33-acee-eaf3517825b1">
        <source>getEDIFileTypes_UserDefined(_coll :CM_ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     Loads user defined file types
//				Copied from CMUI_EDIForm load comboo method
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediFileType			: CM_EDIFileType;
	iter				: Iterator;
begin
	iter := app.myRoot.allEDIFileTypes.createIterator();
	
	while iter.next(ediFileType) do
		//cnwrs1 Mar 2007 Par 13575 only allow user defined types to be selected
		if ediFileType.type &lt;&gt; EDIFileType_UserDefined and
		//Mar 2007 par 13846 this appears to be the only way to load this
		ediFileType.type &lt;&gt; EDIFileType_CSVFESCOBookRef and
		//Mar 2007 it makes sense that all generic types are avilable here
		ediFileType.type &lt;&gt; EDIFileType_CSVMSCLoad and 
		ediFileType.type &lt;&gt; EDIFileType_CSVMSKLoad and 
		ediFileType.type &lt;&gt; EDIFileType_CSVPONLoad and 
		ediFileType.type &lt;&gt; EDIFileType_CSVTOL and 
		ediFileType.type &lt;&gt; EDIFileType_CSVTranship then
			continue;
		endif;
		
		if app.myRoot.canDoEDIFileType(ediFileType.type) then
			_coll.add (ediFileType);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIFile_By_ediClientRef" id="5eaf3e77-2c77-4136-81d2-d9525046104c">
        <source>getEDIFile_By_ediClientRef( _clientRef : String ) : CM_EDIFile;
/*
Purpose:		This method will attempt to get the matching CM_EDIFile for the supplied the EDI Client Referrence.
				This EDI Client Ref can be null in which case null will be returned.
Date				Who		Reason
07 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
25/05/2010			cnwrl1	PAR 24276 - EDI Collection on CM_Root should be on CM_EDIConfig
*/
vars
	clientRef		: String;
	cm_EDIFile		: CM_EDIFile;
	iter1			: Iterator;
	
begin
	clientRef	:= _clientRef.trimBlanks();
	
	if clientRef = null then
		return null;
	endif;
	
//	cm_EDIFile	:= app.myRoot.allEDIFilesByEdiClientRef[clientRef];		// cnwrl1 25/05/2010 PAR 24276 - what it was
//	return cm_EDIFile;													// cnwrl1 25/05/2010 PAR 24276 - what it was
	
	// attempt to find the correct CM_EDIFile
	// cnwrl1 25/05/2010 PAR 24276 - start of coding
	if self.myTerminal.myEdiConfig.allEDIFilesByEdiClientRef.isEmpty then
		return null;
	endif;
	// get the last CM_EDIFile matching the supplied client reference.
	iter1	:= self.myTerminal.myEdiConfig.allEDIFilesByEdiClientRef.createIterator;
	self.myTerminal.myEdiConfig.allEDIFilesByEdiClientRef.startKeyLeq( clientRef, iter1 );
	iter1.back( cm_EDIFile );						// now go back 1 file only (might be at start of collection!)
	if cm_EDIFile &lt;&gt; null and cm_EDIFile.ediClientRef = clientRef then
		return cm_EDIFile;
	else
		return null;
	endif;
	// cnwrl1 25/05/2010 PAR 24276 - end of coding
	
epilog
	delete iter1;
	
end;
</source>
        <Parameter name="_clientRef" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="getEDIFile_EDIData_Status" id="508bf316-660e-494e-b486-2953b9e20ad3">
        <updating/>
        <source>getEDIFile_EDIData_Status() updating;

/*
Purpose:		This method will attempt to get the status of the EDIData for the EDIFile matching
				the EDI Client Referrence on this controller.
				This EDI Client Ref can be null.
				If found then the status code and a translated description will be set up and returned.
				This is for the JMTEDIService getEDIStatus Web message.

Date				Who		Reason
07 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	clientRef	: String;
	ediFile		: CM_EDIFile;
	ediData		: CM_EDIData;
	
begin
	clientRef	:= self.ediClientRef.trimBlanks;
	
	if clientRef = null then
		self.ediStatusCode	:= ediFile.EDI_WEB_STATUS_NO_CLIENTREF.display;			// ie -3

		self.setEdiStatusDesc( self.displayStatus( ediFile.EDI_WEB_STATUS_NO_CLIENTREF ) );
		return;
	endif;
	
	// attempt to find the correct ediFile
	ediFile	:= self.getEDIFile_By_ediClientRef( clientRef );
	
	if ediFile = null then
		self.ediStatusCode	:= ediFile.EDI_WEB_STATUS_EDIFILENOTFOUND.display;		// ie -5
		
		self.setEdiStatusDesc( app.getString( File_Not_Found, clientRef.display ) );
		return;
	endif;
	
	// return the current status and description for this EDI File off the EDI Data if it exists else EDI File.
	ediData	:= ediFile.ediData;
	
	if ediFile.ediData = null then
		self.ediStatusCode	:= ediFile.fileStatus.display;

		self.setEdiStatusDesc( self.displayStatus( ediFile.fileStatus ) );
	else
		self.ediStatusCode	:= ediData.status.display;

		self.setEdiStatusDesc( self.displayStatus( ediData.status ) );
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getErrorDesc" id="4540bb32-3f3c-48cb-8536-0884274eee20">
        <source>getErrorDesc(): String;
//
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
//
vars
	terminal : CM_Terminal;
	terminalCode : String; 
	msg : String;
begin
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	
	msg := "EDI Processing Error " &amp; //app.getErrorString(ERR_EDI_Process) &amp; ' ' &amp; 
			self.class.text.cnEcGetTagValueOfName('display') &amp; 
			' Environment: ' &amp; app.myCnKarmaCntrl.environmentId &amp; 
			" Terminal: " &amp; terminalCode; 
			
	return msg;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileData" id="7d911bef-af63-4fc4-9709-9d910fb5d7dc">
        <source>getFileData(_file :File input; _dataLine : String io);
//
//04 Feb 2015	cnwrs1	Par EDI Refactor for fileload  
//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
vars
	cmifMonitor   : CMIF_Monitor;
	partsInJob    : Integer;
	updateProg    : Boolean;
begin
	app.writeLog(class.name&amp;"::"&amp;method.name&amp;' '&amp;_file.fileName, LogERROR);
	cmifMonitor	:= app.myPassport.myCMIFMonitor;
	updateProg	:= cmifMonitor &lt;&gt; null;
	
	_file.close();
	_file.kind 		:= File.Kind_Unknown_Text;	 // 29/2/16  cnwns1 PAR 36286 unicode version
	_file.mode 	    := File.Mode_Input;
	_file.shareMode := File.Share_Read;
	partsInJob 	    := _file.fileLength();		// returns the size of the file (in file units).
	_dataLine 		:= _file.readString(_file.fileLength());	
	if updateProg then
		cmifMonitor.updateProgressWithCaption('Reading File.', 4, 1, "Loading EDI file Step 1 of 3.");
	endif;
epilog
	_file.close();
end;
</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_dataLine" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFileType" id="d23488d8-9384-4abe-8a63-b4d2fb5e18cc">
        <updating/>
        <source>getFileType(_ediFile : CM_EDIFile input; _fileType, _version, _sender : String output) protected, updating;
//
// 01 Aug 2012	cnwcs5	par 30136 - change usage for file parameter
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//04 Dec 2014	cnwrs1	PAR #34713 - .NET EDI transform integration
//15 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//25 Mar 2019	jlgzm1	TFS 42276 transformMessage running twice per message 
vars
	lines : Integer;
	pos2 : Integer;
	fileLine : String;
	fileExt : String;
	fileName : String;
	dataLine : String;
	binaryLine : Binary;
	transformedMsg : String;
begin
	dataLine := _ediFile.getRawDataString();
	self.getFileTypeFromString(dataLine, fileName, fileExt, _fileType, _version, _sender, transformedMsg);
end;

</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_fileType" type="String" usage="output"/>
        <Parameter name="_version" type="String" usage="output"/>
        <Parameter name="_sender" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFileTypeFromString" id="e7aefbe1-6031-4d19-81b4-d8e5b95a767b">
        <updating/>
        <source>getFileTypeFromString(_messageData : String input;
					  _fileName : String input;
					  _fileExtension : String input;
					  _fileType : String output;
					  _version : String output;
					  _association : String output;
					  _transformedMsg : String output) updating;
/*

Purpose:			Code factored out from getFileType and getFileTypeWeb to handle the recognition of the 
					input message via either mechanism

Parameters:			Message data - entire file contents or input message from web
					File Name - fileName from file or details from web request
					File Ext - Extension from file or details from web request

Return Value:		File Type, Version and association information populated from input parsing

Date			Who		Reason
23 Sep 2014		cnwkpd1	PAR #34713 - .NET EDI transform integration
//20 Oct 2015	cnwrs1	Par37065 - X12 failing with exception is ISA* is bad
//06 May 2016	cnwrs1	TFS 1600 COPARN VGM
19 may 2016		cnwdap1	TFS #1881 BAPLIE/EDI VGM Updates
//10 Jun 2016	cnwrs1	TFS 2150 - create alias for "JMTInternal"
// 18 Aug 2016	cnwrs1	TFS 2553 remove COPARN VGM processing
08 Mar 2018		jlgmd1	TFS #37429 PNL - XML prenote loading in Pack
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
// 04 Jan 2019	NDL		TYFS 42674
25 Mar 2019		jlgzm1	TFS 42276 transformMessage running twice per message
7  Mar 2023		navra1	TFS 56793 PRP - Suzano EDI - Shipment Download
08 Mar 2023 	navsp1  TFS ChangeRequest 56795: PRP - Suzano EDI - Release Order
27 Mar 2023		jlika1	TFS 57276 POB | QShips - Manual Load of XML EDI File.
14 Jun 2023		navdap1	TFS 57074 EUP Manifest EDI Operations / Load Task 58604
12 Jul 2023		navdap1	TFS 58923 EUP CallOff EDI Data Type / EDI Load
15 Jul 2023		navmd1	TFS 59811 Make JSON Transform work again and handle different customers
23 Jul 2024     navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
*/
vars
	messageDataPos,
	messageDataLen,
	unaPos,
	unbPos,
	unhPos,
	int1,
	int2,
	int3,
	lines,
	pos1,
	pos2,
	pos3,
	currentOffset	: Integer;
	data,
	string,
	transIndex,
	fileLine,
	messageLine		: String;
	xmlDoc			: CM_XMLDocument;
	xmlElement		: JadeXMLElement;
	ediTrans		: CMIF_EdiTransformWrap;
	messageData,
	transformedMsg	: String;
	theLines : HugeStringArray;
	x12Delimiter : Character;
	x12SubDelimiter : Character;
	sta: StringArray;
	operatorString : String;
	isXML : Boolean;
	hookLink		: CM_HookLink;
	trxAgent : CMIF_ApiMapper;
	errors : String;
	match			: JadeRegexMatch;
	
begin
	// Initial values
	_fileType := null;
	_version := null;
	_association := null;
	
	// First check if the .NET EDI code can transform this message
	create ediTrans transient;
	if ediTrans.transformMessage(null, null, null, _messageData, transformedMsg) then
		messageData := transformedMsg;
	else
		messageData := _messageData;
	endif;
	_transformedMsg := messageData; //tfs42276

	messageDataLen := messageData.length();
	currentOffset := 1;
	fileLine := messageData;
	
	if (fileLine.pos("&lt;?xml", 1) &gt; 0) then
		//"&lt;?xml version="1.0" encoding="UTF-8"?&gt;"
		_fileType 	:= "XML File";
		_version 	:= EDIFileVersion_XML;
	
		pos1 := fileLine.pos("&lt;?xml", 1);
		string := fileLine[pos1:end];
		
		isXML := true;
		
	elseif _fileExtension.toUpper = "XML" then	//04 Apr 2017	NDL	TFS 3971
		// Need to cater for One Stop
		_fileType := "XML File";
		_version := EDIFileVersion_XML;
		
		string := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;' &amp; fileLine[1:end].trimBlanks;
		
		isXML := true;
		
	else
		unhPos := fileLine.pos("UNH", 1);
		if unhPos &gt; 0 then
			// Remove filler characters
			fileLine := fileLine.replaceString(CrLf, null);
			fileLine := fileLine.replaceString(Cr, null);
			fileLine := fileLine.replaceString(Lf, null);
			fileLine := fileLine.replaceString(ExclaimationMark, null);
			unhPos := fileLine.pos("UNH", 1);
			string := fileLine[unhPos:End];
			if unhPos &gt; 0 then
				int1 := string.pos("+",int1+1);
				int1 := string.pos("+",int1+1);
				int2 := string.pos(":",int1+1);
				int3 := string.pos("'",int1+1);
				if int2 &lt; int3 then
					_fileType := string[int1+1:int2-int1-1];
				endif;
				if string.pos("SMDG15", 1) &gt; 1 then // adm 020709 Par 20141
					_version := EDIFileVersion_911;
				elseif string.pos("SMDG20", 1) &gt; 1 then
					_version := EDIFileVersion_95B;
				elseif string.pos("SMDG22", 1) &gt; 1 then				// TFS #1881
					_version := EDIFileVersion_95B;					// TFS #1881
					_association := "SMDG22";						// TFS #1881
				else
					int1 := string.pos(":",int2+1);
					int2 := string.pos(":",int1+1);
					if int2 &lt; int3 then
						_version := string[int1+1:int2-int1-1];
						if _version = EDIFileVersion_911 and
						   int1 = 0 then
							_version := EDIFileVersion_910;
						endif;
					endif;
				endif;
			endif;
			return;
		endif;	
	
	endif;

	// Moved up because embedded "UNH" character string was appearing in some XML data for milaha TFS 42674
	// Test for know XML formats
/*	fileLine := messageData;
	if (fileLine.pos("&lt;?xml", 1) &gt; 0) then
		//"&lt;?xml version="1.0" encoding="UTF-8"?&gt;"
		_fileType 	:= "XML File";
		_version 	:= EDIFileVersion_XML;
	
		pos1 := fileLine.pos("&lt;?xml", 1);
		string := fileLine[pos1:end];
		
		isXML := true;
		
	elseif _fileExtension.toUpper = "XML" then	//04 Apr 2017	NDL	TFS 3971
		// Need to cater for One Stop
		_fileType := "XML File";
		_version := EDIFileVersion_XML;
		
		string := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;' &amp; fileLine[1:end].trimBlanks;
		
		isXML := true;
		
	endif; */
	
	if isXML then
	
		// Need to parse the entire message before determining 
		on JadeXMLException do xmlExceptionHandler(exception);
	
		create xmlDoc transient;
		self.setMyXMLDocument( xmlDoc );	//27 Jun 2019	NDL	TFS 44895 
		xmlDoc.parseString(string);
	
		if xmlDoc.rootElement &lt;&gt; null then
			// JMTInternal XML?
			if xmlDoc.rootElement.tagName.startsWith(EDIFileVersion_JMTInternal) then
				_version := EDIFileVersion_JMTInternal;
				_fileType := xmlDoc.rootElement.tagName[12:end];
			endif;
			if xmlDoc.rootElement.tagName.startsWith(EDIFileVersion_SystemXML) then
				_version := EDIFileVersion_JMTInternal;
				_fileType := xmlDoc.rootElement.tagName[10:end];
			endif;
			if _version = EDIFileVersion_XML then
				//TOL Prenote?
				xmlElement := xmlDoc.getElementByTagName('MessageType');
				if xmlElement &lt;&gt; null and
				   xmlElement.textData.toUpper.trimBlanks = "ADVNOT" then
					_version := EDIFileVersion_TollNZAdvNot;
				endif;
			endif;
			if _version = EDIFileVersion_XML then
				// Fonterra Pack?
				xmlElement := xmlDoc.rootElement.getElementByTagName('metadata');
				if xmlElement &lt;&gt; null then
					xmlElement := xmlElement.getElementByTagName('requestOrganisation'); //ccms 1976 cnwrs1 10 dec 2010
					
					if xmlElement &lt;&gt; null and
					   xmlElement.textData.toUpper.trimBlanks = "FONTERRA" then
						hookLink	:= app.myRoot.allHookLinks[HookType_EDIFonterraPack, self.myTerminal];	// jlgmd1 TFS 37429 08/03/2018
						if hookLink &lt;&gt; null then
							_version := EDIFileVersion_FonterraPack;
						endif;
					endif;
				endif;
			endif; 
			if _version = EDIFileVersion_XML then
				//Gdansk cars Dec 2007 cnwrs1 ?
				xmlElement := xmlDoc.rootElement.getElementByTagName('Zgloszenie');
				if xmlElement &lt;&gt; null then
					_version := EDIFileVersion_Celina;
				endif;
			endif;
			if _version = EDIFileVersion_XML then
				// DPH Suzano EDI
				if xmlDoc.rootElement.tagName = 'Viagem' then
					xmlElement := xmlDoc.getElementByTagName('Material_Type');
					if xmlElement &lt;&gt; null and
					   xmlElement.textData = 'CE' then
						_version := EDIFileVersion_SuzanoManifest;
					else
						_version := EDIFileVersion_SuzanoPrenote;
					endif;
				else
					if xmlDoc.rootElement.tagName =  'Release_Order' then
						_version := EDIFileVersion_SuzanoRelease;
					endif;
				endif;
			endif;
			//29 Jun 2015	NDL	Par 36543
			if _version = EDIFileVersion_XML then
				//Milaha Customs Release Orders
				//cnwmc5 - 22 Oct 2015 - PAR 37085
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLMilahaCustRel.ROOT_BAYAN
				or xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLMilahaCustRel.ROOT_RELEASE
				or xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLMilahaCustRel.ROOT_AMEND
				or xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLMilahaCustRel.ROOT_CANCEL then
					xmlElement := xmlDoc.rootElement.getElementByTagName('Declaration');
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_Milaha_Customs;
					endif;
				endif;
			endif;
			//07 Aug 2015	NDL	Par 36608
			if _version = EDIFileVersion_XML then
				//Steinweg Cargo Group Assignment
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignments then
					xmlElement := xmlDoc.rootElement.getElementByTagName(CM_EDIFileTypeXMLCargoGrpAssig.TagCargoGroupAssignment);
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_CargoGrpAssign;
					endif;
				endif;
			endif;
			//16 Sep 2015	NDL	Par 36906
			if _version = EDIFileVersion_XML then
				//Steinweg Multi Move group
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLMultiMoveGrp.TagMultiMoveGroups then
					xmlElement := xmlDoc.rootElement.getElementByTagName(CM_EDIFileTypeXMLMultiMoveGrp.TagMultiMoveGroup);
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_MultiMoveGroup;
					endif;
				endif;
			endif;
			//31 Aug 2016	NDL	TFS 2276 / 2565
			if _version = EDIFileVersion_XML then
				//One Stop Pre note
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLOneStopPre.TagContainerMessage then
					xmlElement := xmlDoc.rootElement.getElementByTagName(CM_EDIFileTypeXMLOneStopPre.TagMessageHeader);
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_OneStop;
					endif;
				endif;
			endif;
			//08 Sep 2016	NDL	TFS 2278 / 2670
			if _version = EDIFileVersion_XML then
				//One Stop Customs Response
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLOneStopCust.TagCustomsResponseOneStop then
					xmlElement := xmlDoc.rootElement.getElementByTagName(CM_EDIFileTypeXMLOneStopCust.TagResponseDetail);
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_OneStopCust;
					endif;
				endif;
			endif;
			//03 Oct 2016	NDL	TFS 2718 / 2536
			if _version = EDIFileVersion_XML then
				//One Stop Customs Resopnse
				if xmlDoc.rootElement.tagName = CM_EDIFileTypeXMLOneStopEIDO.TagEIDO then
					xmlElement := xmlDoc.rootElement.getElementByTagName(CM_EDIFileTypeXMLOneStopEIDO.TagEIDOHeader);
					if xmlElement &lt;&gt; null then
						_version := EDIFileVersion_OneStopEIDO;
					endif;
				endif;
			endif;
			if _version = EDIFileVersion_XML then
				//Qships Voyage Resopnse
				xmlElement := xmlDoc.getElementByTagName('GetVoyageExportDataByDomainAndDatesResponse');
				if xmlElement &lt;&gt; null then				   
					_version := EDIFileVersion_XMLQShipsVoyage;
				endif;
			endif;
		endif;
		return;
	endif;

	// If not EDIFACT or XML then try fixed format
	fileLine := messageData.truncatedAt(400);
	if fileLine[1:8] = "$$$HDR**" then
		int1 := fileLine.pos(" ",9);
		if int1 &lt;&gt; 9 then
			_fileType := fileLine[9:int1-9];
		else
			int1 := fileLine.pos(" ",10);
			_fileType := fileLine[10:int1-10];
		endif;
		_version := EDIFileVersion_0;
	
	elseif fileLine[1:8] = "*VSLSTOW" then
		_fileType := "VSLSTOW";
		_association := null;
	
	// US Customs &amp; Border Protection format for Release and Holds
	elseif fileLine[1:3] = "ACR" then
		_fileType := "CAMIR";
	
	elseif fileLine[1:4] = "ISA*" then
		// If it is a US X12 then go back and find ST line to get the file type
		x12SubDelimiter := fileLine[4:1].Character;
		create sta transient;
		messageData[1:107].asStringArrayByDelimiter(sta, x12SubDelimiter);
		if sta.size &gt; 16 then
			x12Delimiter := sta[17].String[2:1].Character;
		endif;
		if x12Delimiter = null and messageData.length &gt; 106 then
			x12Delimiter := messageData[106:1].Character;
		endif;
		fileLine := messageData;
		if x12Delimiter = Cr then
			fileLine := fileLine.replaceString(Lf, null);
		elseif x12Delimiter = Lf then
			fileLine := fileLine.replaceString(Cr, null);
		else
			fileLine := fileLine.replaceString(CrLf, null);
			fileLine := fileLine.replaceString(Cr, null);
			fileLine := fileLine.replaceString(Lf, null);
		endif;
		create theLines transient;
		if fileLine.length &gt; 17 then
			transIndex := fileLine[8:10].trimBlankCharacters;
		endif;
		messageDataPos := 1;
		fileLine.getHugeTokensForDelimiter(x12Delimiter, theLines);
		foreach messageLine in theLines do
			if messageDataPos = 0 then		// have reached the end of the messageData
				break;
			endif;
			if messageLine[1:3] = "ST*" and messageLine.length &gt; 6 then
				transIndex := messageLine[4:3];
				break;
			endif;
		endforeach;
		if transIndex = "301" then
			_fileType := "X12_301";
			_version := EDIFileVersion_X123014010;
		elseif transIndex = "309" then
			_fileType := "X12_309";
			_version := EDIFileVersion_X123094010;
		elseif transIndex = "315" then
			_fileType := "X12_315";
			_version := EDIFileVersion_X123154010;
		elseif transIndex = "322" then
			_fileType := "X12_322";
			_version := EDIFileVersion_X123224010;
		elseif transIndex = "350" then
			_fileType := "X12_350";
			_version := EDIFileVersion_X123504010;
		endif;

	elseif _fileExtension.toUpper = "CSV" then
		
		_fileType := "CSV File";
		
		if _fileName.trimBlanks.toUpper.reverse[1:15].reverse = "PONLOADLIST.CSV" then
			_version := EDIFileVersion_CSVPONLoad;
		elseif _fileName.trimBlanks.toUpper.reverse[1:15].reverse = "MSKLOADLIST.CSV" then
			_version := EDIFileVersion_CSVMSKLoad;
		elseif _fileName.trimBlanks.toUpper.reverse[1:15].reverse = "MSCLOADLIST.CSV" then
			_version := EDIFileVersion_CSVMSCLoad;
		else
			_version := EDIFileVersion_CSV;
		endif;
	
	elseif _fileExtension.toUpper = "XML" then
		_fileType := "XML File";
		_version := EDIFileVersion_XML;
	
	elseif fileLine[4:7].toUpper = "MAFH100" then //gdansk cars dec 2007 cnwrs1
		_fileType := "WWL";
		
	elseif fileLine[1:4].toUpper = "1HDR" then				//navra1 - TFS 56793 - 7th Mar 2023 
		if fileLine.pos("2SHP", 1) &gt; 0  then				//navra1 - TFS 56793 - 7th Mar 2023
			_fileType := "Suzano Manifest";							//navra1 - TFS 56793 - 7th Mar 2023
			_version := EDIFileVersion_SuzanoManifest;		//navra1 - TFS 56793 - 7th Mar 2023
		
		//08Mar2023 navsp1 TFS 56795
		elseif fileLine.pos("2ROH", 1)  &lt;&gt; null then
			_fileType	:=	"Suzano Release";
			_version	:=	EDIFileVersion_SuzanoRelease;
		endif;
		
	else
		// TFS 57074 start
		if _fileExtension = "JSON" then
			create trxAgent transient;
			transformedMsg := trxAgent.transformIncomingMessage(self.transformFor, "SendEDI", messageData, "POST", errors);
			if errors &lt;&gt; null then
				transformedMsg := messageData;
			else
				// /SendEDI encodes the actual message part in a base64 encoded 'message'
				if JadeRegex@findFirst(transformedMsg, 'message\":\"([^\"]+)', false, true, match) then
					transformedMsg := match.at(1).value.base64DecodeToString();
				endif;
			endif;
			_transformedMsg := transformedMsg;
			
			// TFS 58923 start
			pos1 := transformedMsg.pos("CallOff", 1);
			if pos1 &lt;&gt; null then
				_fileType := "CallOff";
			endif;
			if _fileType = null then
			// TFS 58923 end
				pos1 := transformedMsg.pos("transports",1 );	// use messageData here as fileLine has been truncated
				if pos1 &lt;&gt; null then
					pos2 := transformedMsg.pos("transportationMode", pos1);
					if pos2 &lt;&gt; null then
						_fileType := "Transport Manifest";
					else
						// also check for cargo on site file type which has no transports section
						pos2 := transformedMsg.pos("CargoOnSite", 1);
						if pos2 &lt;&gt; null then
							_fileType := "Transport Manifest";
						endif;
					endif;
				endif;
			endif;
			if _fileType = null then						//TFS 63842
				pos1 := transformedMsg.pos("movementID",1 );//TFS 63842
				if pos1 &lt;&gt; null then						//TFS 63842
					_fileType := "OnePort Voyage";			//TFS 63842
				endif;										//TFS 63842
			endif;											//TFS 63842
		endif;
		// TFS 57074 end
		
	endif;

epilog
//	delete xmlDoc;	// now stored on the agent.
	delete ediTrans;
	delete theLines;
	delete sta;
	delete match;
	delete trxAgent;
end;</source>
        <Parameter name="_messageData" type="String" usage="input"/>
        <Parameter name="_fileName" type="String" usage="input"/>
        <Parameter name="_fileExtension" type="String" usage="input"/>
        <Parameter name="_fileType" type="String" usage="output"/>
        <Parameter name="_version" type="String" usage="output"/>
        <Parameter name="_association" type="String" usage="output"/>
        <Parameter name="_transformedMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="9d40e265-48ef-43a8-9ea2-33ade6b634a7">
        <updating/>
        <source>getTIs(_search: Integer; _voyage: CM_Voyage; _operator: CM_Operator; _tiDict: CM_TIByIdDict io) updating;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	opTerm			: CM_OperatorTerminal;
	tmpPortDestCode : String;
begin
	tmpPortDestCode := self.myTerminal.getConfig(PortDestCode).String;
	if _search = CM_EDIData.SEARCH_ONSITE_EXP_TRANSHIP then
		if _voyage = null or _voyage.myCellularVoyageStructure = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not a cellular voyage');
			return;
		endif;
		//if _voyage &lt;&gt; null and _voyage.code &lt;&gt; NULL_VOYAGE_CODE then
		if _voyage &lt;&gt; null and (not _voyage.isNullVoyage) then
			foreach ti in _voyage.allOnsiteTIsByIdCargoType do
				if ti.cargoType = TI_CargoType_Log or
				ti.cargoType = TI_CargoType_LCL then
					continue;
				endif;
				if (_operator = null or (ti.myOperator = _operator)) and
				(ti.isExport or ti.isTranshipItem) then
					if not _tiDict.includesKey(ti.id) then
						_tiDict.add(ti);
					endif;
				endif;
			endforeach;
		elseif _operator &lt;&gt; null then
			opTerm := _operator.allOperatorTerminals[self.myTerminal];
			foreach ti in opTerm.allOnsiteTIsByIdCargoType do
				if ti.cargoType = TI_CargoType_Log or
				ti.cargoType = TI_CargoType_LCL then
					continue;
				endif;
				if (ti.isExport or ti.isTranshipItem) then
					if not _tiDict.includesKey(ti.id) then
						_tiDict.add(ti);
					endif;
				endif;
			endforeach;
		endif;
	elseif _search = CM_EDIData.SEARCH_OUTWARD_RAIL then
		self.doOutwardRailSearch(_voyage, _operator, _tiDict);
		// creating EDI Data for Load List Comparison
	elseif _search = CM_EDIData.SEARCH_TI_FOR_LOAD_LIST_COMPAR then
		self.getTIsForLoadListComparison(_voyage, _tiDict);
	elseif _search = CM_EDIData.SEARCH_ONSITE_FOR_VOYAGE then //cnwrs1 Aug 2009
		if _voyage &lt;&gt; null then
			foreach ti in _voyage.allOnsiteTIsByCargoTypeId do
				_tiDict.add(ti);
			endforeach;
		endif;
	elseif _search = CM_EDIData.SEARCH_TI_FOR_DISCH_LIST_COMPA then //cnwrs1 CCMS 1137 15 June 2010
		if _voyage &lt;&gt; null then
			foreach ti in _voyage.allOnshipTIsByCargoTypeId do
				if ti.dischargePort = tmpPortDestCode then
					_tiDict.add(ti);
				endif;
			endforeach;
		endif;
	else	
	//other search?
	endif;
end;</source>
        <Parameter name="_search" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_tiDict" type="CM_TIByIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTIsForLoadListComparison" id="ed3f2e96-767d-4fbe-8461-bce3476451ea">
        <source>getTIsForLoadListComparison( _voyage: CM_Voyage; _tiDict: CM_TIByIdDict io );
//----------------------------------------------------------------
//	Created:	09 August 2007	by cnwvu1
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	ti	: CM_TrackedItem;
	
begin

	if _voyage = null or _voyage.isNullVoyage then
		app.raiseUnexpectedProgramError(""/*class.name*/, ""/*method.name*/, 'voyage is null');
		return;
	endif;

	if _voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not a cellular voyage');
		return;
	endif;
		
	if _voyage &lt;&gt; null and (not _voyage.isNullVoyage) then
		// onsite
		foreach ti in _voyage.allOnsiteTIsByIdCargoType do
			//if ti.isExport and not _tiDict.includesKey(ti.id) then							// PAR #25021
			if (ti.isExport or ti.isTranshipOutbound) and not _tiDict.includesKey(ti.id) then	// PAR #25021
				_tiDict.add(ti);
			endif;
		endforeach;
		//notified
		foreach ti in _voyage.allNotifiedTIsByIdCargoType do
			//if ti.isExport and not _tiDict.includesKey(ti.id) then							// PAR #25021
			if (ti.isExport or ti.isTranshipOutbound) and not _tiDict.includesKey(ti.id) then	// PAR #25021
				_tiDict.add(ti);
			endif;
		endforeach;
		
	endif;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tiDict" type="CM_TIByIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTestTrain" id="a8cbdf9a-08d5-4392-8843-9688229a4518">
        <source>getTestTrain() : CM_Train;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 October 2007
//
//----------------------------------------------------------------------

vars
	train : CM_Train;
begin
	train := '4264.11'.asOid.CM_Train;
	return train;
epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCutoffEDIDataTypes" id="0f20fbab-5cd3-45e7-9e72-db53cf59750b">
        <source>getVoyageCutoffEDIDataTypes(_coll :IntegerArray input);
/*

Date		Who		Reason
08 March 2017	cnwer1	Initial creation TFS 3642
*/
// 24 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req

vars

begin
	_coll.add(EDIDataType_BookingSingleLine);
	_coll.add(EDIDataType_BookingMultiLine);
	_coll.add(EDIDataType_GateDocument);
	_coll.add(EDIDataType_Prenote);
	_coll.add(EDIDataType_ReleaseRequest);
	_coll.add(EDIDataType_RequestMultiLine);
	_coll.add(EDIDataType_VGM);
	_coll.add(EDIDataType_Stop);
	_coll.add(EDIDataType_TransportManifest);	//30.Aug.2023 navsp1 TFS 57809
	_coll.add(EDIDataType_CallOff);				//30.Aug.2023 navsp1 TFS 57809
epilog

end;</source>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWagonsForTrain" id="e1bf8b33-d548-4769-bf22-044dc891f6de">
        <source>getWagonsForTrain(_train : CM_Train; _wagonCollection : CM_WagonByIdDict io);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 October 2007
//
//----------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	train : CM_Train;
begin
	train := _train;
	if train &lt;&gt; null then
		foreach wagon in train.allWagonsByIdInward where wagon.confirmedOutwards do
			if not _wagonCollection.includes(wagon) then
				_wagonCollection.add(wagon);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagonCollection" type="CM_WagonByIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadAndProcessFileForTerminal" id="e43e0a7c-a471-44f5-9d48-197d6708f867">
        <updating/>
        <source>loadAndProcessFileForTerminal(_file 		: File input; 
							  _ediFileType 	: CM_EDIFileType io;
							  _passport 	: CM_Passport input) : CM_EDIFile updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
cnwdvb1 28 January 2003 
22 Mar 2012	cnwrs1	Par 29295 	Fix up finding EDI file type for CSV and XML files
16 Apr 2012	cnwrs1	Par 29447 	not finding EDI file Type for fixed length
01 Aug 2012	cnwcs5	par 30136 - change usage for _file parameter
12 Jul 2014	cnwrs1	Par 34702 - Add support for JMT XML
15 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
19 Feb 2015	cnwrs1	Par 		EDI Refactor for fileload  
23 Jun 2015	cnwrs1	Par 		EDI Refactor for fileload  
14 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
09 Jul 2024 navmd1	TFS 65114 	Pass Binary message data directly, rather than doing String conversions on it at this level
============================================================================*/
vars
	terminalStr		: String;
	terminal		: CM_Terminal;
	realEdiFile 	: CM_EDIFile;
	fileData 		: String;
	dataClass		: Class;
	fileTypeCode	: Integer;
	realEdiData		: CM_EDIData;
begin
	app.writeLog(class.name&amp;"::"&amp;method.name&amp;' '&amp;_file.fileName, LogERROR);
	if _file.isOpen() then
		app.raiseCMException(VB_FILE_ERROR, "file open", null);	
		return null;
	endif;
	_file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	_file.mode := File.Mode_Input;
	_file.shareMode := File.Share_Exclusive;
	_file.open();
	_file.close();

	self.myCurrentEDIFileFormat := null;
	self.setMyXMLDocument( null );	// 25 Jun 2019	NDL	TFS 44895 - performs the delete if required
	self.getFileData(_file, fileData);
	
	self.getDataTypeCreateEDIObjects(fileData.Binary, _file.fileName, _file.cnEcFileExt.toUpper, _file.timeCreated, false, null, _ediFileType, realEdiFile, realEdiData, true, null); //jlgka1 	TFS 45332
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if realEdiFile &lt;&gt; null and
	   realEdiData&lt;&gt; null then
		if self.tryLock(realEdiData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			self.processFileData(realEdiFile, _passport);
		endif;
	endif;
	return realEdiFile;
epilog
	_file.close();
	self.unlock(realEdiData);
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="loadBayPlanTIs" id="e810e64c-b02d-426d-b42e-be403581617f">
        <updating/>
        <source>loadBayPlanTIs(
	_voyage			: CM_Voyage;
	_planType		: Integer;
	_fileName		: String;
	_shipperCode	: String;
	_recipient		: CM_Operator;
	_cargoOperator	: CM_Operator;		// par 29312 - march 2012
	_fileType		: CM_EDIFileType;
	_useInwardsCode	: Boolean	) : CM_EDIDataBayPlan updating;			// TFS 6851
//----------------------------------------------------------------
//	Created:	23 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 21/03/2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 19/09/2017	jlgdap1	TFS 6851 SSL New paramter to indicate whether to use voyage inward code
vars
	ediDataBayPlan		: CM_EDIDataBayPlan;
begin

	if _voyage = null or _voyage.isNullVoyage() then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Voyage), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Voyage), null, null); // cnwdb2	PAR 35364
		return null;
	elseif _voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not cellular voyage');
		
		return null;
	endif;

	app.myTrxCA.trxCreateEDIDataFromBayPan(	ediDataBayPlan,
											self.myTerminal.myEdiConfig,
											_voyage,
											_planType,
											_fileName,
											_shipperCode,
											_recipient,
											_cargoOperator,	// par 29312 - march 2012
											_fileType,
											app.myPassport,
											self.ediClientRef,
											null,
											null,
											_useInwardsCode	);					// TFS 6851
	
epilog
	return ediDataBayPlan;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_shipperCode" type="String"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_cargoOperator" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_useInwardsCode" type="Boolean"/>
        <ReturnType type="CM_EDIDataBayPlan"/>
    </JadeMethod>
    <JadeMethod name="loadDataFile" id="47ab8858-7354-4578-9a8f-de8fc2e72f96">
        <updating/>
        <source>loadDataFile(_ediFile :CM_EDIFile input; _file :File input) updating, protected;
	
/*
Purpose:	This method will take the input FILE data and break it up into valid lines
			delimited on the appropriate class (or sub-class) delimiters.
			In addition lines will have appropriate data manipulation done on them eg matching up
			of double quotes etc.
			This data is then added to the HugeStringArray theLines which is then added
			to the supplied EDIFile allCompressedFileLines collection.

Date				Who		Reason
21 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
01 Aug 2012			cnwcs5	par 30136 - change usage of _file parameter
*/
//12 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
vars
	cmifMonitor : CMIF_Monitor;
	dataLine : String;
	fileLine : String;
	readAmount : Integer;
	partsInJob : Integer;
	currentOffset : Integer;
	partsDone : Integer;
	linecount : Integer;
	updateProg : Boolean;
begin
	cmifMonitor	:= app.myPassport.myCMIFMonitor;
	updateProg	:= cmifMonitor &lt;&gt; null;
	_file.close();
	_file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	_file.mode := File.Mode_Input;
	_file.shareMode := File.Share_Read;
	partsInJob := _file.fileLength();		// returns the size of the file (in file units).
	dataLine := _file.readString(_file.fileLength());	
	_ediFile.loadRawData(dataLine);
	if updateProg then
		cmifMonitor.updateProgressWithCaption('Reading File.', 4, 2, "Loading EDI file Step 1 of 3.");
	endif;
epilog
	_file.close();
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDeckPlanTIs" id="7a8ec466-8ee8-4c3c-bcd9-4ab44ae69b26">
        <updating/>
        <source>loadDeckPlanTIs(
	_voyage			: CM_Voyage;
	_planType		: Integer;
	_fileName		: String;
	_recipient		: CM_Operator;
	_fileType		: CM_EDIFileType ) : CM_EDIDataDeckPlan updating;
/*
Purpose:
Creates an EDI RORO Deck Plan from a voyage in the database			
Modified version of loadBayPlanTIs
Parameters:			

Return Value:		

Date		Who		Reason
21 December 2011	cnwgb1	Initial creation for CCMS MSL 1009 Par 29024
UNDER CONSTRUCTION

*/
vars
	ediDataDeckPlan		: CM_EDIDataDeckPlan;

begin

	if _voyage = null or _voyage.isNullVoyage() then
	//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
		return null;
	elseif _voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not cellular voyage');
		return null;
	endif;

	app.myTrxCA.trxCreateEDIDataFromDeckPlan(	
        ediDataDeckPlan,
        self.myTerminal.myEdiConfig,
        _voyage,
        _planType,
        _fileName,
        _recipient,
        _fileType,
        app.myPassport,
        self.ediClientRef,
        null,
        null );
	
epilog
	return ediDataDeckPlan;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <ReturnType type="CM_EDIDataDeckPlan"/>
    </JadeMethod>
    <JadeMethod name="loadDeckStowageAdvice" id="7357c540-9a60-4c6c-9d16-dff534cacd1a">
        <updating/>
        <source>loadDeckStowageAdvice(_voyage : CM_Voyage; _fileName : String; _recipient : CM_Operator; _fileType : CM_EDIFileType) : CM_EDIDataDeckStowageAdvice updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
//
vars
	ediDataDeckStowageAdvice : CM_EDIDataDeckStowageAdvice;
begin
	if _voyage = null or _voyage.isNullVoyage() then
	//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
		return null;
	elseif _voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not cellular voyage');
		return null;
	endif;

	app.myTrxCA.trxCreateEDIDataFromDeckStowag(	
        ediDataDeckStowageAdvice,
