<Class name="CM_AutoTaskExpiredWash" id="951be8a4-314e-46dd-b8f7-14f46e82f577">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Check Wash Expired&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myToDoTaskDesc" id="248513b6-13ce-415a-8eea-6f2d12fe8f00">
        <embedded/>
        <type name="CM_ToDoTaskDesc"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getEntryTableViewName" id="063b6440-921e-4cd2-b81a-c6a0bf54c626">
        <source>getEntryTableViewName(): String;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return 'bgpAutoViewExpiredWash';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="99e4bd28-5693-4f08-878c-fa9472ec2075">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _rowName = ETRow_ToDoTaskDesc then
		// Check is valid object.
		if global.isValidObject(self.myToDoTaskDesc) then
			return self.myToDoTaskDesc.code.String &amp; ' ' &amp; self.myToDoTaskDesc.CM_ToDoTaskDesc.description;
		endif;
	endif;
	
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1d496a3a-3a58-471f-a92a-6534f9c3978e">
        <source>pxyCreateUpdateProxy() : SelfType;

// cnwdvb1 19 June 2003 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	task : CM_AutoTaskExpiredWash;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.myToDoTaskDesc := self.myToDoTaskDesc;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b9a1cd12-19e2-49ec-a4a9-2585093f6d93">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskExpiredWash) updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_AutoProcessExpiredWash.name;
	self.myToDoTaskDesc := _pxyAutoTask.myToDoTaskDesc;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskExpiredWash"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="684c5ba0-7a60-4f21-9d17-8788ffa17c9f">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskExpiredWash) updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.myToDoTaskDesc := _pxyAutoTask.myToDoTaskDesc;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskExpiredWash"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="578ddd43-d2b7-488f-8782-cede505b3190">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _rowName = ETRow_ToDoTaskDesc then
		self.myToDoTaskDesc := _value.CM_ToDoTaskDesc;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="02e1014d-a664-4ca0-8582-c0255cc86f64">
        <source>validate();
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
vars

begin
	inheritMethod();
	if self.myToDoTaskDesc = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Do Task Description', ETRow_ToDoTaskDesc, null);
		app.raiseCMException(Input_required_field_toDoDesc, ETRow_ToDoTaskDesc, null); // cnwdb2	PAR 35364

	endif;
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364

	endif;
end;</source>
    </JadeMethod>
</Class>
