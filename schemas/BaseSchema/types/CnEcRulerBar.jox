    <JadeMethod name="drawRuler" id="3b41774c-9d5f-4839-9be5-6c7a1d8a9821">
        <source>drawRuler() protected;
// --------------------------------------------------------------------------------
// Created:		03 December 2001 by cnwdad1
//
// Purpose:		Draw the ruler grade lines and numeric increments across the
//				client width of the control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	STANDARD_CHARACTER	: Character = "m";
	
vars
	rulerObj			: CnEcPicture;
	rulerWidth			: Real;
	characterWidth		: Integer;
	baseLeft			: Real;
	baseTop				: Real;
	gradeHeight			: Real;
	gradeLeft			: Integer;
	gradeTop			: Real;
	counter				: Integer;
	counterString		: String;
	
begin
	// Get the control metrics.
	
	rulerObj		:=	self;
	characterWidth	:=	rulerObj.getTextExtent(STANDARD_CHARACTER);
	rulerWidth		:=	rulerObj.clientWidth() - 6;
	baseLeft		:=	-1;
	gradeHeight		:=	6;
	baseTop			:=	rulerObj.clientHeight();
	
	// Draw the base line for the width of the ruler bar.
	
	rulerObj.drawLine(baseLeft, baseTop, rulerWidth, baseTop, self.gradeColor);
	
	// Now draw the vertical lines, with every tenth being double the height
	// and showing the line count above it.
	
	rulerObj.drawTextAlign	:=	Window.DrawTextAlign_Center;
	
	foreach gradeLeft in baseLeft.Integer to rulerWidth.Integer step characterWidth do
		counter				:=	counter + 1;
		
		if (counter mod(10) = 0) then
			if self.isCompact then
				gradeTop		:=	baseTop + 2;// - gradeHeight - 6;
				counterString	:=	(counter div 10).String;
			else
				gradeTop		:=	baseTop - gradeHeight - 6;
				counterString	:=	counter.String;
			endif;
			
			// Draw the numeric increment text.
			rulerObj.drawTextAt(counterString, gradeLeft, (gradeTop - 14), self.numberColor);
		elseif (counter mod(5) = 0) then
			gradeTop	:=	baseTop - gradeHeight - 3;
		else
			gradeTop	:=	baseTop - gradeHeight;
		endif;
		
		// Draw the vertical grade line.
		
		rulerObj.drawLine(gradeLeft, gradeTop, gradeLeft, baseTop, self.gradeColor);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="move" id="0bd07806-2cd6-4057-ab2f-39567554d38a">
        <source>move(x: Real; y: Real; width: Real; height: Real);
// --------------------------------------------------------------------------------
// Created:		03 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(x, y, width, height);
	
	self.clearGraphics();
	self.drawRuler();
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width" type="Real"/>
        <Parameter name="height" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setIsCompact" id="4a8807d9-39eb-419e-9a72-809982b75351">
        <updating/>
        <source>setIsCompact(pIsCompact:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		03 December 2001 by cnwdad1
//
// Purpose:		Sets the Ruler's isCompact style flag.
//
// Parameters:	pIsCompact - True if the ruler is compact, false if not.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCompact	:=	pIsCompact;
	
	if pIsCompact then
		self.height		:=	15;
	else
		self.height		:=	30;
	endif;
	
	self.clearGraphics();
	self.drawRuler();
end;</source>
        <Parameter name="pIsCompact" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="80d14683-d893-4e22-8dd7-38ad53d9f8ee">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		03 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isCompact then
		self.height		:=	15;
	else
		self.height		:=	30;
	endif;
	
	self.autoRedraw	:=	true;
	self.drawRuler();
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
