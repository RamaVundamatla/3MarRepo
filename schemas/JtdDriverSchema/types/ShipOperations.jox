    <JadeMethod name="stop2" id="dc8329b1-5b1d-4a3f-aa35-8bc0f72561a1">
        <updating/>
        <source>stop2() updating;

begin
	allShipMates.purge;
	if app.isValidObject(mySHP_VoyageOperationsForm) then
		mySHP_VoyageOperationsForm.unloadForm;
	endif;
	mySHP_VoyageOperationsForm:=null;
end;
</source>
