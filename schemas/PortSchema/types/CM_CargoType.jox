    <JadeMethod name="getKPITotalsPerMonths" id="bb7e7317-d33b-4f9d-8c8e-6def7322a5c2">
        <source>getKPITotalsPerMonths(	_kpiCounter 		: CMIF_KPICounter input);
/*

Date		Who		Reason
09 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	iter : Iterator;
	kpiCargoType 	: CMIF_KPICounterCargoType;
	kpiMonth		: CMIF_KPICounterMonth;
	cargoEntity 	: CM_KPICargoEntity;
	cargoDtl 		: CM_KPICargoDtl;
	month,
	year 			: Integer;
begin
	if _kpiCounter = null then
		return;
	endif;
	iter :=self.allKPICargo.createIterator;
	self.allKPICargo.startKeyGeq(_kpiCounter.myTerminal,_kpiCounter.startMonth,iter);
	
	kpiCargoType:= _kpiCounter.allKPICounterCargoTypes[self];
	//reset 
	if kpiCargoType &lt;&gt; null then
		delete kpiCargoType;
	endif;
	
	create kpiCargoType transient;
	kpiCargoType.myCargoType:=self;
	kpiCargoType.myKPICounter:=_kpiCounter;
	
	while iter.next(cargoEntity) do 
		if cargoEntity.myTerminal &lt;&gt; _kpiCounter.myTerminal then
			break;
		endif;
		month:=cargoEntity.dateTime.date.month;
		year:=cargoEntity.dateTime.date.year;
		if cargoEntity.dateTime &gt;= _kpiCounter.endMonth then	
			break;
		endif;
		kpiMonth:= kpiCargoType.allKPICounterMonths[year,month];
		if kpiMonth = null then
			create kpiMonth transient;
			kpiMonth.myKPICounterCargoType:=kpiCargoType;
			kpiMonth.month:=cargoEntity.dateTime.date.month;
			kpiMonth.year:=cargoEntity.dateTime.date.year;
		endif;

		kpiMonth.setFromKPICargo(cargoEntity);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_kpiCounter" type="CMIF_KPICounter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMaximumTemperature" id="6efcaad9-0d44-4ea9-8aa0-320cb613178b">
        <source>getMaximumTemperature() : Real;
/*
Purpose:			

Date		Who		Reason
20 May 2022	navab1	TFS 53105
*/

vars
	commodity : CM_Commodity;
begin
	if self.allCommodities.isNotEmpty then                        
		foreach commodity in self.allCommodities discreteLock do 
			if commodity.hasTemp then
				return commodity.maxTemp;
			endif;
		endforeach;
	endif;
	
	return 0;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="3916dba9-8acd-412e-b371-480b53dd8d45">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk
//
vars

begin
	if _attrName = ETRow_Density then
		return app.convertMeasurementForDisplay(_measureType, self.density) &amp; Space &amp; _measureType;
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTypeFor" id="4114a3ef-213c-47e5-bac8-2f90ec566917">
        <source>getMeasurementTypeFor( _type : String; _totalVersion : Boolean ):CM_MeasurementType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2014	cnwndl1	Initial creation	CCMS 1366

*/

vars

	prod : CM_Product;

begin

	if _totalVersion then
		if _type = Type_Weight then
			if self.myWeightMeasurementType &lt;&gt; null then
				return self.myWeightMeasurementType;
			endif;
		elseif _type = Type_Volume then
			//epr par 37260 21/1/16
			if self.myVolumeMeasurementType &lt;&gt; null then
				return self.myVolumeMeasurementType;
			endif;
		endif;
	endif;
	
	prod := self.mySystemProductType;
	if prod &lt;&gt; null then
		return prod.getDefaultMeasurementForType( _type );
	endif;
	
	return self.getDefaultMeasurementForType( _type );

epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_totalVersion" type="Boolean"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getMinimumTemperature" id="314592b7-bbdd-4ac2-a7ab-023043086f6b">
        <source>getMinimumTemperature() : Real;
/*
Purpose:			

Date		Who		Reason
20 May 2022	navab1	TFS 53105
*/

vars
	commodity : CM_Commodity;
begin
	if self.allCommodities.isNotEmpty then                        
		foreach commodity in self.allCommodities discreteLock do 
			if commodity.hasTemp then
				return commodity.minTemp;
			endif;
		endforeach;
	endif;
	
	return 0;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getName" id="b976d35c-9cbf-43a7-86f9-ef427af1fce4">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return inheritMethod &amp; ' (' &amp; self.description &amp; ')' &amp; Tab &amp; self.abbreviation.display;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNewId" id="194e78f5-d138-4cae-82c2-a2a75ca792a0">
        <source>getNewId(): Integer;
// ---------------------------------------------------------------------------
// Created:     03 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 08/05/2020	jlgadp1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cargoTypeDict 	: CM_CargoTypesByIdDict;
	cargoType		: CM_CargoType;
begin

	cargoTypeDict := app.myRoot.allCargoTypesById;
	cargoType := cargoTypeDict.last;
	
	if cargoType = null then	
		return TI_CargoBOLType_Max + 1;
	else
		if cargoType.id &lt; TI_CargoBOLType_Max then
			//return cargoType.id +1;
			return TI_CargoBOLType_Max + 1; // ### TFS 52851 24Mar2022 NAVPW1
		else
			// TFS 49252 start
			if app.myRoot.isClientCentrePort then
				return cargoType.id +1;
			endif;
			foreach cargoType in cargoTypeDict reversed, discreteLock do
				if cargoType.id &gt; TI_CargoBOLType_Max and cargoType.id &lt; TI_CargoBOLType_JMTMax then
					return cargoType.id + 1;
				endif;
			endforeach;
			return TI_CargoBOLType_Max + 1;
			// TFS 45292 end
		endif;
	endif;
	
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProductFromCode" id="abdef30e-1611-4545-9893-031337ed51fd">
        <source>getProductFromCode(_code : String) : CM_Product;
// ---------------------------------------------------------------------------
// Created:     18 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpProd : CM_Product;
begin
	foreach tmpProd in self.allProducts  discreteLock do
		if tmpProd.code = _code then
			return tmpProd;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getProductTypeString" id="50a37a91-3ffe-4a15-b80f-2ba3e01d011c">
        <source>getProductTypeString() : String;
begin
	if self.isContainer() then // TFS 5426
		return app.getErrorString(ISO_Container); // TFS 5426
	elseif self.productType = ProductType_PieceBreakBulk then
		return ProductType_PieceBreakBulkStr;
	endif;
	if self.productType = ProductType_BreakBulk then
		return ProductType_BreakBulkStr;
	endif;
	if self.productType = ProductType_Bulk then
		return ProductType_BulkStr;
	endif;
	if self.productType = ProductType_Trailer then
		return ProductType_TrailerStr;
	endif;
	if self.productType = ProductType_Vehicle then
		return ProductType_VehicleStr;
	endif;
	if self.productType = ProductType_CargoGroup then	//27 May 2015	NDL	Par 36338
		return ProductType_CargoGroupStr;
	endif;
	return "";		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTerminals" id="cecd0db0-fd94-428a-b445-daae738a416c">
        <source>getSelectedTerminals(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navsj20	TFS 53756

*/
vars
	term 			: CM_Terminal;
	terminals       : String; 
	
begin
	foreach term in self.allTerminals discreteLock do
		terminals&amp;= term.code &amp; " ";
	endforeach;
	return terminals;	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTEUConversionValue" id="f44743f5-6aa6-47b0-b4e3-0baad05e00a3">
        <source>getTEUConversionValue(_index : Integer) : Decimal;
/*

Date		Who		Reason
07 July 2016	cnwer1	Initial creation TFS 2290
28 July 2022	navsrk20	ChangeRequest 53917: MTN - Cargo Types TEUs for GC
*/

vars

begin
	if self.teuConversion.size &gt;= _index then
		if self.teuConversion[_index] = 0 then 		//28.07.2022 navsrk20 TFS 53917
			return 1;								//28.07.2022 navsrk20 TFS 53917
		endif;										//28.07.2022 navsrk20 TFS 53917
		return self.teuConversion[_index];
	endif;
	
	//return null;	//28.07.2022 navsrk20 TFS 53917
	return 1;		//28.07.2022 navsrk20 TFS 53917
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTiBehaviourType" id="f139cfc9-1ac6-4f7c-b388-2565070ea9ae">
        <source>getTiBehaviourType() : Integer;
// -------------------------------------------
// Created 18 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	// Which it shouldn't be
	if self.myTIBehaviourType &lt;&gt; null then
		return self.myTIBehaviourType.behaviourType;
	endif;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUserTerminalsForCargoType" id="10e88b23-4487-4822-857f-cb1e325c492b">
        <source>getUserTerminalsForCargoType( _userTerminalsForCargoType : CM_TerminalSet input );
/* ---------------------------------------------------------------------------
Created:	21 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	term 			: CM_Terminal;
	allUserTerminals: CM_TerminalByCodeDict;
	
begin

	_userTerminalsForCargoType.clear();
	
	create allUserTerminals transient;
	app.getMyUser.getTerminals(allUserTerminals);
	
	//looping through all terminals related to cargo type
	foreach term in self.allTerminals do
		if allUserTerminals.includes(term) then
			_userTerminalsForCargoType.add(term);
		endif;
	endforeach;

epilog
	delete allUserTerminals;

end;</source>
        <Parameter name="_userTerminalsForCargoType" type="CM_TerminalSet" usage="input"/>
