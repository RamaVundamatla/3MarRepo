<Class name="HMS_VesselData">
    <JadeMethod name="importPLXMLReference" id="4a7dbb93-c551-4c97-ba32-9b73f088f59f">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_VesselData::myRoot.name then
		return app.myRoot;
	elseif _name = HMS_VesselData::myDefaultShippingLine.name then
		return app.myRoot.allShippingLines[_theCode];
	elseif _name = HMS_VesselData::myVesselType.name then
		return app.myRoot.allVesselTypes[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
