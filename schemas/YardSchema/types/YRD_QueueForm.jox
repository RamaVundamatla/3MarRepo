    <JadeMethod name="translateForm" id="f5fa7718-15b2-42a3-a09c-6bf860adc8ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 October 2025 13:16:22.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020592, locale);
	btnFullTask.translateCaption(Xlat_0020593, locale);
	btnNewQueue.translateCaption(Xlat_0020594, locale);
	btnPin.translateCaption(Xlat_0020595, locale);
	btnRefresh.translateCaption(Xlat_0020596, locale);
	btnSuspend.translateCaption(Xlat_0020597, locale);
	chkHideSubQTasks.translateCaption(Xlat_0023976, locale);
	clrSelected.translateCaption(Xlat_0020598, locale);
	mnuAlerts.translateCaption(Xlat_0020599, locale);
	mnuAltRTMoveMethod.translateCaption(Xlat_0020600, locale);
	mnuAutoPlan.translateCaption(Xlat_0020601, locale);
	mnuChgRTMoveMethod.translateCaption(Xlat_0020602, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0020603, locale);
	mnuHideOffMachines.translateCaption(Xlat_0020604, locale);
	mnuInspectMachine.translateCaption(Xlat_0020605, locale);
	mnuInspectQueue.translateCaption(Xlat_0020606, locale);
	mnuInspectTask.translateCaption(Xlat_0020607, locale);
	mnuMachCargoOnboard.translateCaption(Xlat_0020608, locale);
	mnuMachLoginAsGdansk.translateCaption(Xlat_0020609, locale);
	mnuMachine.translateCaption(Xlat_0020610, locale);
	mnuMachineDebugLogin.translateCaption(Xlat_0020611, locale);
	mnuMachineDetails.translateCaption(Xlat_0020612, locale);
	mnuMachineLoginAs.translateCaption(Xlat_0020614, locale);
