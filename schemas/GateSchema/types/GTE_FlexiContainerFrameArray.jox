    <JadeMethod name="getIdxByEntity" id="d010af28-4d76-4c1e-809f-2c2816452dbc">
        <source>getIdxByEntity(_entity : CMGTE_Entity) : Integer;

/*

Purpose:		Return the index in the array for a given container id

Date			Who		Reason
14/11/2012		cnwmh5	Initial creation #30733

*/

vars
	contFrm					: GTE_FlexiContainerFrame;
	pxyLink					: CM_ProxyLink;
	max,
	idx						: Integer;
	realGTE					: CMGTE_Entity;
begin

	if _entity.isTransient then
		realGTE:=_entity.pxyGetRealObject;
	else
		realGTE:=_entity;
	endif;
	if realGTE = null then
		return 0;
	endif;
	
	max := self.size();
	foreach idx in 1 to max do
		contFrm := self[idx];
			if realGTE = contFrm.myContainer then
				return idx;
			endif;
	endforeach;
	
	
	return 0;

end;
</source>
        <Parameter name="_entity" type="CMGTE_Entity"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIdxById" id="617cc89d-03e7-4191-9c45-fde85ec0daec">
        <source>getIdxById(_id : String) : Integer;

/*

Purpose:			
	Return the index in the aray for a given container id
Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwas3	Initial creation

*/

vars
	contFrm	: GTE_FlexiContainerFrame;
	found	: Boolean;
	max,
	idx		: Integer;
begin
	max := self.size();
		foreach idx in 1 to max do
			contFrm := self[idx];
			if contFrm.myContainer.isKindOf(CMGTE_Release) then
				if contFrm.id=_id then
					return idx;
				endif;
			elseif contFrm.myContainer.isKindOf(CMGTE_Container) then
				if contFrm.id=_id then
					return idx;
				endif;
			endif;
		endforeach;
	return 0;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
