    <JadeMethod name="getMovementNextGlobal" id="5b7478c3-3827-44cf-8ce2-067e115d7cd5">
        <source>getMovementNextGlobal(_voyagesToIgnore : CM_VoyageSet) : HMS_Movement;
//-----------------------------------------------------------------------
//	Created:	27 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	movement	: HMS_Movement;
//	iter		: Iterator;
	
begin

	movement := self.myNextMovement;
	if movement = null then
		return null;
	endif;
	
	if _voyagesToIgnore &lt;&gt; null and movement.getVoyage &lt;&gt; self.getVoyage then
		// if _voyageArray &lt;&gt; null then need to check if this movement
		// is for a voyage we will be processing later
		if (not _voyagesToIgnore.includes(movement.getVoyage())) then
			return null;
		endif;
	endif;
	
	return movement;

/*


	movement := self.getMovementNext();
	
	iter := self.myVoyageGlobal.allHMSMovements.createIterator();
	
	if movement = null then
		app.writeLog2("Didn't find a 'next movement'... looking at Global Voyage from [" &amp; self.occursOnDTNEW.String &amp; "]", LogAlways);
		
		if self.myVoyageGlobal &lt;&gt; null then
		
			self.myVoyageGlobal.allHMSMovements.startKeyGeq(self.occursOnDTNEW, iter);
			
			// check to see if we should ignore this movement as we will be doing it later
			if _voyageArray &lt;&gt; null then
				while iter.next(movement) do
					if (not _voyageArray.includes(movement.getVoyage())) then
						return null;
					endif;
				endwhile;
			endif;
			
			if movement = null then
				app.writeLog2("Didn't find a 'next movement' on the Global Voyage... looking at subsequent Global Voyage.", LogAlways);
				
				if self.myVoyageGlobal.mySubsVoyageGlobal &lt;&gt; null then
					if self.myVoyageGlobal.mySubsVoyageGlobal.allHMSMovements.size &gt; 0 then
						app.writeLog2("Using the last movement of subsequent Global Voyage [" &amp; self.myVoyageGlobal.mySubsVoyageGlobal.code &amp; "]", LogAlways);
						movement := self.myVoyageGlobal.mySubsVoyageGlobal.allHMSMovements.last();
						if _voyageArray &lt;&gt; null then
							if _voyageArray.includes ( movement.getVoyage()) then
								return null;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if movement = null then
		app.writeLog2("The 'next movement' from movement [" &amp; self.display() &amp; "] is [null]", LogAlways);
	else
		app.writeLog2("The 'next movement' from movement [" &amp; self.display() &amp; "] is [" &amp; movement.display() &amp; "]", LogAlways);
	endif;
	
	return movement;
epilog
	app.writeLog2("Exiting " &amp; class.name &amp; "::" &amp; method.name, LogAlways);
	delete	iter;
*/
end;</source>
        <Parameter name="_voyagesToIgnore" type="CM_VoyageSet"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="getMovementPrevious" id="37bdafc2-b008-4039-abe0-485ce0cf4cda">
