<Class name="CM_RemoteUserQueryHdr" id="63309996-0f80-4351-9c74-ce491ad717c6">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;User Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getMessageResponseType" id="9535dc27-67a0-41c1-befc-2f2592ee82d9">
        <source>getMessageResponseType(): String;

// cnwdvb1 07 May 2003 

vars

begin
	return CM_RemoteDataManager.USERQUERYRSP;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsers" id="1dccec3a-58e0-4161-8bda-a79fa70f1c32">
        <source>getUsers(_error : Integer output; _errorTxt : String output) : String protected;

// cnwdvb1 07 May 2003 

vars

	user		: CM_User;
	iter		: Iterator;
	response	: String;
	term		: CM_Terminal;
	userTerm	: CM_UserTerminal;
	iter2		: Iterator;

begin

	iter := app.myRoot.allUsers.createIterator;	
	term := app.myPassport.myTerminal;
	if term = null then
		_error 		:= Err_InvalidTerminal;
		_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, self.terminal);
		return null;
	endif;
	response := self.formatAsXMLPrefix(XML_BDY) &amp; self.formatAsXMLPrefix(XML_USERS);
	while iter.next(user) do
		// do not use app.isSpecial() here as just
		// determining what data to unload
		if user.code = 'SUPERUSER' then
			continue;
		endif;
		iter2 := user.allUserTerminals.createIterator();
		while iter2.next(userTerm) do
			if userTerm.getMyTerminal = term then
				response := response &amp; self.formatAsXML(XML_USER, user.getDetailForRemoteQuery());
				break;
			endif;
		endwhile; 
		delete iter2;
	endwhile;
	response := response &amp; self.formatAsXMLSuffix(XML_USERS) &amp; self.formatAsXMLSuffix(XML_BDY);
	return response;
epilog
	delete iter;
	delete iter2;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="f3528f8e-7877-4a33-b644-9f780fb5bbe9">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		response := self.getUsers(err, errTxt);
		return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
