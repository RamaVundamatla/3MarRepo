    <JadeMethod name="myToDoTask" id="cf440aec-b57b-4951-9eb6-c03bc6c677e8">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myToDoTask(set : Boolean; _value : CM_ToDoTask io) mapping, updating;
//
//cnwrs1 CCMS 1826 29 July 2010
//
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 15/10/21 	jlier1	TFS 51963
vars

	isInvalid : Boolean;
	type : Integer;
	toDoTask	: CM_ToDoTask;	
begin
	if set then
		self.myToDoTask := _value;
				
	else
		toDoTask := self.myToDoTask;
		if toDoTask = null then
			_value := null;
		else
			on Exception do app.handleDeletedObject(exception, toDoTask, isInvalid);
			type := toDoTask.toDoTaskDescCode;
			if not isInvalid then
				_value := toDoTask;
			else
				_value := null;
			endif;
		endif;
	endif;

epilog
	
	
	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ToDoTask" usage="io"/>
    </JadeMethod>
    <JadeMethod name="noCharge" id="b265e6ab-4b85-43d3-919d-6b2a5d2df131">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>noCharge(set: Boolean; _value: Boolean io) updating, mapping;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(NoChargeFlag);
		else
			flags := flags.getValueWithBitUnset(NoChargeFlag);
		endif;
	else
		_value := (flags.bitAnd(NoChargeFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="prevTransIsChargeableStorage" id="dca87c00-6979-4b62-b3ab-7a37744fa766">
        <source>prevTransIsChargeableStorage() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2023	navkc1	CR 59342  Task 59500: Jade - Storage Charging for Additional Storage

*/

vars

begin
	if self.isKindOf(CM_Storage)
	and self.CM_Storage.startTransaction &lt;&gt; null
	and self.CM_Storage.startTransaction.isKindOf(CM_Storage)
	and self.CM_Storage.startTransaction.isCharged() then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
