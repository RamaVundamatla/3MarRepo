    <JadeMethod name="displayMeasurementFields" id="33fa0852-1cc6-4e7b-b46e-2965e5212f52">
        <updating/>
        <source>displayMeasurementFields() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

begin

	self.weightType := app.getDefaultMeasurementForType(Type_Weight);
	self.heightType := app.getDefaultMeasurementForType(Type_Height);
	self.widthType := app.getDefaultMeasurementForType(Type_Width);
	self.lengthType := app.getDefaultMeasurementForType(Type_Length);
	
	self.tblExtLength.setup(Type_Weight, self.backColor);
	self.tblExtLength.tabKey := J_key_Tab;
	self.tblExtLength.visible := true;
	
	self.tblExtWidth.setup(Type_Weight, self.backColor);
	self.tblExtWidth.tabKey := J_key_Tab;
	self.tblExtWidth.visible := true;
	
	self.tblDeckHeight.setup(Type_Height, self.backColor);
	self.tblDeckHeight.tabKey := J_key_Tab;
	self.tblDeckHeight.visible := true;
	
	self.tblCargoHeight.setup(Type_Height, self.backColor);
	self.tblCargoHeight.tabKey := J_key_Tab;
	self.tblCargoHeight.visible := true;
	
	self.tblMaxCWeight.setup(Type_Weight, self.backColor);
	self.tblMaxCWeight.tabKey := J_key_Tab;
	self.tblMaxCWeight.visible := true;
	
	self.tblTare.setup(Type_Weight, self.backColor);
	self.tblTare.tabKey := J_key_Tab;
	self.tblTare.visible := true;
	
	

epilog

end;</source>
    </JadeMethod>
