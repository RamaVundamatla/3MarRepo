    <JadeMethod name="getDisplayStringForAttribute" id="3bf432e1-d015-40dd-8b4c-c17c9608acf6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     25 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//22 June 2023 navhl20 	ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
//13 Sep 2023  navlw1	Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
//22 Nov 2023  navhl20  Bug 61048: EUP - Spinning wheel appears when performing the Rail Load using WO Operations app.
//06 Mar 2025  navma1   MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------

vars
	train 	: CM_Train;
	wagon 	: CM_Wagon;
	str	    : String;
begin
	if _attrName = ETRow_Train then
		train := self.getMyTrain();
		// 13.09.2023 navlw1 #60382
		if train = null then
			return self.getTrainNumber();
		endif;
		if train &lt;&gt; null then
			return train.code;
		endif;
		return null;
	elseif _attrName = ETRow_Wagon then										//22.6.2023 navhl20 #57758
		str := self.getWagonStrFromWle();									//06.03.2025 navma1 #MTN-34179
		if str &lt;&gt; null then													//22.11.2023 navhl20 #61048
			return str;
		endif;
		
		wagon := self.getMyWagon();											//06.03.2025 navma1 #MTN-34179
		if wagon &lt;&gt; null then
			return wagon.id;
		endif;
		// 13.09.2023 navlw1 #60382 Start
		wagon := getWagonFromTrain();
		if wagon &lt;&gt; null then
			return wagon.id;
		endif;
		// 13.09.2023 navlw1 #60382 End
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="576682ca-2f53-42f1-ba2d-835232344c71">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

