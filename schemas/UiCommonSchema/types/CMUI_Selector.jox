    <JadeMethod name="cmbOperator_closeup" id="1213c462-00cf-4bec-8928-8595f0b2a26f">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_closeup(combobox: ComboBox input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 August 2018
TFS#		: 40200
Function	: Return the combobox drops down, to its original width and left
			: position

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	combobox.left	:= combobox.left + ComboSize60;
	combobox.width	:= combobox.width - ComboSize60;		
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_dropDown" id="717e9fa6-d046-4c89-b829-c81e5ec8d279">
        <controlMethod name="CMUI_ComboBox::dropDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_dropDown(combobox: ComboBox input):Boolean updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 August 2018
TFS#		: 40200
Function	: When the combobox drops down, resize the width of the control and 
			: change its left position order ensure it is able to display its 
			: longest entry

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	combobox.left	:= combobox.left - ComboSize60;
	combobox.width	:= combobox.width + ComboSize60;
	combobox.zOrder(1);
	return true;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
