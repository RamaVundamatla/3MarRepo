    <JadeMethod name="doBtnEventTrans" id="2b51cd95-bfaa-4c86-8288-0bbeb0f99f94">
        <source>doBtnEventTrans();
/*
Purpose:			
Date		Who		Reason
24/02/2017	cnwab1	Initial creation
20/04/2017	cnwdap1	TFS 4174 Additional Information in Voyage Events
*/

vars
	shift : CM_Shift;
	jobSheet : CM_VoyageJobSheet;						// TFS 4174
begin
	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentJob &lt;&gt; null then
			shift := self.myCurrentJob.myShift;
			jobSheet := self.myCurrentJob.myJobSheet.CM_VoyageJobSheet;										// TFS 4174
		endif;
		//self.myAssistant.showEventTransactions(self.myCurrentVoyage, shift);								// TFS 4174
		self.myAssistant.showEventTransactions(self.myCurrentVoyage, shift, jobSheet, self.myCurrentJob);	// TFS 4174
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyages" id="7fa23e64-1e41-4995-be52-f6a24fe2031b">
        <source>doBuildComboVoyages();
//
// Purpose:			
//
// Parameters:			
