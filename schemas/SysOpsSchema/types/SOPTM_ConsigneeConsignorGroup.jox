    <JadeMethod name="setControlsForAddEdit" id="0a9b8f73-8988-40a6-adc4-54be97953f9c">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
				
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
//		form now hides the row by default in the setupThumbnailDetails method.  Consignors are shown on the ConsignorConsignees sheet 01092003
//		theForm.tblInput1.hideRowByName(ETRow_AllConsigneeConsignors,false);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.cnEcResizeContents();
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ConsigneeConsignorGroup);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
//		form now hides the row by default in the setupThumbnailDetails method.  Consignors are shown on the ConsignorConsignees sheet 01092003		
//		theForm.tblInput1.hideRowByName(ETRow_AllConsigneeConsignors,false);
	endif;
	self.enableMulSelect1Contents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="52caf9ac-6342-4a9e-a93d-00895978ee0e">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();  
	theForm := self.myForm;
  	theForm.tblInput1.userInputEnabled := false;
//  theForm.tblInput1.showRowByName('allConsigneeConsignors',false);
	theForm.tblInput1.cnEcResizeContents();
	theForm.shtMultiSelect1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="d0d28617-fae7-48d8-b847-85836e258f9a">
        <source>setupThumbnailDetails() ;

vars
	theForm : SOP_TableMaintForm;
begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ConsignGroupTbl);
	//theForm.zAddColumn('Consignee/or Group Id', 'code',	Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ConsignGroupMaint);
	theForm.shtTblInput1.visible := true;

	theForm.tblInput1.hideRowByName(ETRow_AllConsigneeConsignors, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="f1013382-1537-4f5b-bb09-691791b60342">
        <updating/>
        <source>showThumbnail(pConsignGroup : CM_ConsigneeConsignorGroup) updating;

vars

	theForm : SOP_TableMaintForm;
	list:String;	
	first:Boolean;
	consign:CM_ConsigneeConsignor;	
begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pConsignGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pConsignGroup.description);
	
/*	first := false;
	foreach consign in pConsignGroup.allConsigneeConsignors do
		if (not first) then
			first := true;
			list := consign.code.trimBlanks;
		else
			list := list &amp; ", " &amp; consign.code.trimBlanks;
		endif;
	endforeach;
	theForm.tblInput1.setValueByName(ETRow_AllConsigneeConsignors, list);
*/	
	theForm.mulSelect1.setSelected(pConsignGroup.allConsigneeConsignors);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pConsignGroup" type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
</Class>
