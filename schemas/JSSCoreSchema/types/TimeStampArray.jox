<CollClass name="TimeStampArray">
    <JadeMethod name="jssDoSort" id="b6aa7ed4-19b0-47bf-a341-c61e871a66c9">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestampValue	: TimeStamp;
	sortKeyObj		: Object;

begin
	foreach timestampValue in self do
		pSorterObj.addValue(timestampValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.mySortColl do
		self.add(sortKeyObj.JSSSortKey.getValue.TimeStamp);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
