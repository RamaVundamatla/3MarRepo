    <JadeMethod name="gO_click" id="23b10afd-6e23-4a58-9c41-f313afe7dded">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>gO_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		24 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	listBox1.clear;
	listBox1.addItem("Single Lift Crane");
	listBox1.itemLevel[listBox1.newIndex] := 1;
	listBox1.addItem("Priority 1");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Discharge DLR 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Priority 2");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Discharge DLR 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Priority 3");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Discharge Import 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Priority 4");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Discharge Import 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Priority 5");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Load DLR 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Load Export 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;



	listBox1.addItem("Twin Lift Crane");
	listBox1.itemLevel[listBox1.newIndex] := 1;
	listBox1.addItem("Priority 1");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Discharge DLR 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Discharge DLR 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Discharge Import 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Discharge Import 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Priority 2");
	listBox1.itemLevel[listBox1.newIndex] := 2;
	listBox1.addItem("Load DLR 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Load Export 20");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Load DLR 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	listBox1.addItem("Load Export 40");
	listBox1.itemLevel[listBox1.newIndex] := 3;
	
	end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listBox1_dblClick" id="9e7b9bf4-cafc-4ffb-b138-a65adeeb97a0">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>listBox1_dblClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		24 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	listbox.itemExpanded[listbox.listIndex] := not listbox.itemExpanded[listbox.listIndex];
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
