This form will be used for "previewing" files for reports
whose output was written to a text file rather than printed.

When the form is created, the "self.attr_FileName" must be
set before the form is shown.</text>
    <PrimAttribute name="aFileName" id="b0f61d2e-0c93-4370-b9a2-c1733290b9d4">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="aMyFile" id="41f3aa2f-4080-42e7-babc-503bfa9c6deb">
        <embedded/>
        <type name="File"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="setFile" id="ea7c8656-19b7-4778-aec1-7635f80a7164">
        <updating/>
        <source>setFile(pValue:File) updating;

begin
	self.aMyFile	:=	pValue;
end;</source>
        <Parameter name="pValue" type="File"/>
    </JadeMethod>
</GUIClass>
