    <JadeMethod name="myCurrentStockOrderLine" id="98cd48c0-af76-4e97-8d6d-0ea2605184b7">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myCurrentStockOrderLine(set: Boolean; _value: CM_StockOrderProductLine io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.myCurrentStockOrderObject := _value;
	else
		if self.myCurrentStockOrderObject = null then
			_value := null;
		elseif self.myCurrentStockOrderObject.isKindOf(CM_StockOrderProductLine) then
			_value := self.myCurrentStockOrderObject.CM_StockOrderProductLine;
		else
			_value := null;
		endif;
	endif;

end;</source>
