    <JadeMethod name="eprTestUpdateHold" id="d1a8e9b9-005c-4ab7-a661-84d0bc77f33f">
        <source>eprTestUpdateHold();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	bay,	pxyBay  : CM_Bay;
	pxyHold, realHold, newHold : CM_VesselHold;
	loloStructure : CM_CellularVesselStructure;
	i:Integer;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	
	loloStructure:="7032.19541".asOid.CM_CellularVesselStructure;
	realHold:="4981.309100".asOid.CM_VesselHold;
	beginLoad;
	pxyHold:=realHold.pxyCreateUpdateProxy;
	endLoad;
	//create pxyHold transient;
	pxyHold.setProxy(loloStructure,3);
	i:=5;
	foreach bay in realHold.allBays do
		beginLoad;
		pxyBay:=bay.pxyCreateUpdateProxy;
		endLoad;
	
		pxyBay.setOrdinalBay(i);
		pxyBay.setId(((i*2)-1).padLeadingWith("0",2));
		pxyBay.setMyHold(pxyHold);
		i:=i+1;
		
	endforeach;
	
	i:=6;
	create pxyBay  as CM_BayDefn transient;
	pxyBay.setOrdinalBay(i);
	pxyBay.setId(((i*2)-1).padLeadingWith("0",2));
	pxyBay.setMyHold(pxyHold);
	
/*	create pxyBay  as CM_BayDefn transient;
	pxyBay.setOrdinalBay(7);
	pxyBay.setMyHold(pxyHold);*/
	//insert into 2
/*	create pxyHold transient;
	pxyHold.setProxy(loloStructure,2);
	create pxyBay  as CM_BayDefn transient;
	pxyBay.setOrdinalBay(3);
	pxyBay.setId("05");
	pxyBay.setMyHold(pxyHold);
	create pxyBay  as CM_BayDefn transient;
	pxyBay.setOrdinalBay(4);
	pxyBay.setId("07");
	pxyBay.setMyHold(pxyHold);*/

	
	app.myTrxUA.trxUpdateHoldVessel(pxyHold, newHold,app.myPassport);
	
epilog
	delete pxyHold;
end;</source>
    </JadeMethod>
