18 April 2023	navkc1	Initial creation CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop

*/

vars

begin
	
	// This table is currenly handling MAFI Onboard notification only // 14/04/2023	navkc1	CR 57036 Task 57589
	self.doMAFIOnboardUpdateNotify(table, eventType, theObject, eventTag);
epilog

end;</source>
