    <JadeMethod name="delete" id="c16f3f7e-da5e-469c-96d3-0d56ae10a467">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allTrackedItems.purge;
epilog

end;</source>
