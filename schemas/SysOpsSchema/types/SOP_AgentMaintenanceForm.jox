    <JadeMethod name="addToolbarControls" id="dc2ad916-6c2d-43db-bf32-47ee9961242a">
        <updating/>
        <source>addToolbarControls() updating, protected;
// toolbar buttons
vars

	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete,CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnChangeDebtor, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase,CMUI_Toolbar.Control_Alignment_Right);
	self.btnSaveBase.enabled := false;
	self.btnChangeDebtor.enabled := false;

	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
