/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
14 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	self.frmSaveAs.centreWindow();
