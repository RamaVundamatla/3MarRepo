    <JadeMethod name="validateMe" id="745f778b-8838-452b-806f-d3cd55703f83">
        <source>validateMe() protected;

vars

begin
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Trade Description', null, null);
		app.raiseCMException(Input_required_field_trdeDesc, null, null); // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
