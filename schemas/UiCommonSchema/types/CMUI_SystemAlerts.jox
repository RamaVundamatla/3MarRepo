    <JadeMethod name="addToolbarControls" id="65323014-49f3-41ce-8b1b-fff60d624fd1">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			10 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------
08 Aug 2023 	navma1			Bug 56741: MTN - System Alert Export Button on screen load
---------------------------------------------------------------------------
*/
vars
	queryToolbar,
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);				//08.08.2023 navma1 #56741
	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnTerminal, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSystem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDisasters, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnErrors, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWarnings, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnInfo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReefer, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnEditRemote, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	//par 17755---to show a new button DeleteAll on System Alert form
	toolbar.addButton(self.btnDeleteAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.showCaptions := false;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	queryToolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left); // 31 May 2022 navvt20 53755 
	queryToolbar.positionToolbarControls();
	queryToolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="alertsAreSimilar" id="cb286dd6-325f-4caa-9527-063c888c4948">
        <source>alertsAreSimilar(_testType, _currentType: Integer): Boolean;
//----------------------------------------------------------------
//	Created:	28 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	targetType,
	testType	: Integer;
begin

	targetType	:= _currentType;
	testType	:= _testType;

	if targetType = self.BTN_REEFER then
		if testType = SEVERE_REEFER or testType = SEVERE_REEFER_MAX or testType = SEVERE_REEFER_ALERT then
			return true;
		endif;
	endif;
	
	return false;

end;</source>
        <Parameter name="_testType" type="Integer"/>
        <Parameter name="_currentType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="btnAll_click" id="604569e8-64b1-4923-9d21-b927106fdb6f">
