    <JadeMethod name="getBOLInDetailFromNumber" id="38a9a3dc-4c72-4c31-9d04-2f5a67b3d2df">
        <updating/>
        <source>getBOLInDetailFromNumber(_type : Integer; _number : String) : CM_BOLDtl updating;
// Created:     04 Feb 2010 by cnwjre1, copied from getBookingRefFromCode
vars
	objArr			: ObjectArray;
	bol				: CM_BOL;
	iter			: Iterator;
begin
	iter := self.myTerminal.allBOLsReceivedByTypeNumberDT.createIterator;
	self.myTerminal.allBOLsReceivedByTypeNumberDT.startKeyGeq(_type, _number, null, iter);
	
	create objArr transient;
	
	while iter.next(bol) do
		if bol.number &lt;&gt; _number then
			break;
		endif;
		
		if bol.status &lt;&gt; BOL_STATUS_NORMAL then
			continue;
		endif;
		
		objArr.add(bol);
	endwhile;
	
	if objArr.size = 0 then
		return null;
	elseif objArr.size = 1 and objArr.first.CM_BOL.allBOLDtls.size = 1 then
		return objArr.first.CM_BOL.allBOLDtls.first.CM_BOLDtl;
	else
		return self.pickerWindowForBOLDetails(objArr);
	endif;
epilog
	delete iter;
	delete objArr;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_number" type="String"/>
        <ReturnType type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefFromCode" id="32c8cdeb-342f-4a43-b497-370b5d07414e">
        <updating/>
        <source>getBookingRefFromCode(pCode : String; _showPrenotes : Boolean) : CM_Object updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24 Jul 2008	cnwkpd1		PAR #17611 - Add break from while loop once past 
//							the required key
// 22 Sep 2016	cnwdap1		TFS 2651 Add _showPrenotes parameter to expand items shown, 
//							change returned object to from CM_BookingRefItem to CM_Object
// 22 May 2018	jlgdap1		TFS 38501 new parameter for pickerWindowForObject
// 25 Apr 2024  navlc30 	Bug 64212: MTN - 1086 - Selecting Multiple Prenotes on picker from Road Receive screen using the booking reference id
// ---------------------------------------------------------------------------
vars
	objArr			: ObjectArray;
	tmpBookingRef,
	rtnBookingRef	: CM_BookingRef;
	iter			: Iterator;
	cnt				: Integer;
	selectedObject	: Object;					// TFS 2651
	bookingItem		: CM_BookingRefItem;		// TFS 2651
	copyObjArr		: ObjectArray;				// TFS 2651
	allowMulti		: Boolean;					// TFS 2651
	ti				: CM_TrackedItem;			// TFS 2651
begin
	iter := self.myTerminal.allBookingRefsByRef.createIterator;
	self.myTerminal.allBookingRefsByRef.startKeyGeq(pCode, iter);
	
	create objArr transient;
	
	while iter.next(tmpBookingRef) do
		if tmpBookingRef.bookingReference &lt;&gt; pCode then			// PAR #17611
			break;
		endif;
		
// cnwdad1 15/10/2009 - PAR #21321.
		if tmpBookingRef.status &lt;&gt; BOOKING_REF_ACTIVE then
			continue;
		endif;
		
		objArr.add(tmpBookingRef);
	endwhile;
	
	if objArr.size = 0 then
		return null;
	//elseif objArr.size = 1 and objArr.first.CM_BookingRef.allBookingRefItems.size = 1 then						// TFS 2651
	elseif objArr.size = 1 and objArr.first.CM_BookingRef.allBookingRefItems.size = 1 and not _showPrenotes then	// TFS 2651
		return objArr.first.CM_BookingRef.allBookingRefItems.first.CM_BookingRefItem;
	else
		if _showPrenotes then																// TFS 2651
			create copyObjArr transient;													// TFS 2651
			objArr.copy(copyObjArr);														// TFS 2651
			foreach selectedObject in copyObjArr do											// TFS 2651
				tmpBookingRef := selectedObject.CM_BookingRef;								// TFS 2651
				foreach bookingItem in tmpBookingRef.allBookingRefItems discreteLock do		// TFS 2651
					objArr.add(bookingItem);												// TFS 2651
					foreach ti in bookingItem.allTIs discreteLock do						// TFS 2651
						if ti.isNotified and not ti.isChild then							// TFS 2651
							objArr.addExclusive(ti);										// TFS 2651
							allowMulti := true;												// TFS 2651
						endif;																// TFS 2651
					endforeach;																// TFS 2651
				endforeach;																	// TFS 2651
			endforeach;																		// TFS 2651
			//self.pickerWindowForObject(objArr, allowMulti, selectedObject, null);			// TFS 2651		// TFS 38501
			self.pickerWindowForObject(objArr, allowMulti, selectedObject, null, false);	// TFS 2651		// TFS 38501
			if selectedObject.isKindOf(CM_Object) then										//24.05.2024 navlc30 #64212
				return selectedObject.CM_Object;											// TFS 2651
			else
				return null;
			endif;
		else																				// TFS 2651
			return self.pickerWindowForBookingRefs(objArr);
		endif;																				// TFS 2651
	endif;
epilog
	delete iter;		// PAR #17611
	if objArr &lt;&gt; null then
		delete objArr;
	endif;
	delete copyObjArr;			// TFS 2651
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="_showPrenotes" type="Boolean"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getBulkRelease" id="20e00440-f3f5-499b-b65a-cd0bc69d47da">
        <source>getBulkRelease( _code : String; _selectedBulkRelease : CM_BulkRelease output; isCompleted : Boolean output):Integer;
/*
Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
31/05/2011	cnwndl1	Par 27573	Initial creation	
21/10/2016	cnwdap1	TFS 2831 	Ignore non-active releases
22/05/2018	jlgdap1	TFS 38501 	PEL1 Work Order Changes - new parameter for pickerWindowForObject
12/04/2019	jlgka1	TFS 44368	Add isCompleted flag to identify what error message 
								to display when doing a road gate.
============================================================================*/
vars
	
	allBulkReleases 	: CM_ObjectArray;
	startObject 		: CM_BulkRelease;
	bulkRelease 		: CM_BulkRelease;
	ts 					: TimeStamp;
	iter 				: Iterator;
	selectedObject 		: Object;
	selectedBulkRelease : CM_BulkRelease;
	pickerReturnValue	: Integer;

begin

	//set the date to something big and find the first matching release
	ts.setDate( ("01 Jan 3000").Date );	
	startObject := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(_code, ts);
	create allBulkReleases transient;
	
	//iterate thru getting all road releases with the matching code.
	if startObject &lt;&gt; null then
		iter := self.myTerminal.allBulkReleasesByCodeDate.createIterator;
		iter.startAtObject( startObject );
		while iter.next( bulkRelease ) do
			if bulkRelease.code &lt;&gt; _code then
				break;
			endif;
			if bulkRelease.type &lt;&gt; BR_TYPE_ROAD then
				continue;
			endif;
			if bulkRelease.status &lt;&gt; BR_ACTIVE and bulkRelease.status &lt;&gt; BR_PENDING then	// TFS 2831
				isCompleted := true; 														// jlgka1 TFS 44368
				continue;																	// TFS 2831
			endif;																			// TFS 2831
			allBulkReleases.add( bulkRelease );
		endwhile;
	endif;
	
	if allBulkReleases.isEmpty then
		//we didn't find one, nothing mopre to do.
		_selectedBulkRelease := null;
		return MsgBox_Return_OK;
		
	else
		if allBulkReleases.size = 1 then
			//there was only one, select it and return.
			_selectedBulkRelease := allBulkReleases.first().CM_BulkRelease;
			return MsgBox_Return_OK;
			
		else
			// there are multiple, make the user choose one.
			//pickerReturnValue := self.pickerWindowForObject( allBulkReleases, false, selectedObject, null );			// TFS 38501
			pickerReturnValue := self.pickerWindowForObject( allBulkReleases, false, selectedObject, null, false );		// TFS 38501
			if pickerReturnValue = MsgBox_Return_Cancel then
				//user cancelled, bail
				_selectedBulkRelease := null;
				return MsgBox_Return_Cancel;
			endif;
			
			selectedBulkRelease := selectedObject.CM_BulkRelease;
			if selectedBulkRelease &lt;&gt; null then
				// user selected a specific release.
				_selectedBulkRelease := selectedBulkRelease;
			else
				// user specifically unselected and chose nothing. clear the value and continue.
				_selectedBulkRelease := null;
			endif;
			return MsgBox_Return_OK;
			
		endif;
	endif;

epilog

	delete iter;
	delete allBulkReleases;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_selectedBulkRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="isCompleted" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColourString" id="f774de1a-ced9-47c2-8261-9f1a3a88d03b">
        <source>getColourString(_table : CMUI_ListTable input; _textBox : CMUI_TextBox) : String;
//
// Purpose:				Get colour string from list table or text box, depending on terminal config setting
//
// Parameters:			_table - a CMUI_ListTableColour table with selected colours
//						_textBox - a text box with a colour as a string
//
// Return Value:		the colours
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123 get colour string from list table or text box
//
vars
	selectedColors	: StringArray;
	str, rtnValue	: String;

begin
	if self.myTerminal.getConfig(ValidateColour).Boolean then
		create selectedColors transient;
		_table.getSelectedAsStringArray(selectedColors);
		foreach str in selectedColors do
			if rtnValue &lt;&gt; null then
				rtnValue := rtnValue &amp; " ";
			endif;
			rtnValue := rtnValue &amp; str;
		endforeach;
		return rtnValue;
	else
		return _textBox.text.trimBlanks;
	endif;
epilog
	delete selectedColors;
end;</source>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_textBox" type="CMUI_TextBox"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignFromCombo" id="ad361b37-1ffd-4c93-8fa9-b57b4a6eae1b">
        <source>getConsignFromCombo(pCode : String) : CM_ConsigneeConsignor;
//FD for adding custom details to trackedItem
//One of the item in the CustomDetail ComboBox is from the derogationNumber of Consignor
vars
	code : String;
	int : Integer;
begin
	int := 1;
	if pCode = null then
		return null;
	endif;

	code := pCode.scanUntil(Tab, int);
	code := code.trimRight;

   if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
   		return app.myRoot.allConsigneeConsignorsForDescr[code];
   else
   		return app.myRoot.allConsigneeConsignors[code];
   endif;
end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getDamageCodesForObject" id="dc19b9ce-4bbb-4dd9-b1f5-03174dce1fee">
        <source>getDamageCodesForObject(_masterObject : CM_Object; _damageCollection : Collection input);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
	machType : CM_MachineType;
	type : Integer;
begin
	if _masterObject.isKindOf(CM_TrackedItem) then
		cargoType := _masterObject .CM_TrackedItem.myCargoType;
		cargoType.allDamageDefinitionCodes.copy(_damageCollection);
	elseif _masterObject.isKindOf(CM_WagonMaster) 
		or _masterObject.isKindOf(CM_Wagon) then
		machType := app.myRoot.allMachineTypes[MACHINETYPE_WAGONRAIL];
		machType.CM_MachineType.allDamageDefinitionCodes.copy(_damageCollection);
	elseif _masterObject.isKindOf(CM_TIMaster) then
		cargoType := app.myRoot.allCargoTypesById[_masterObject.CM_TIMaster.cargoType];
		cargoType.allDamageDefinitionCodes.copy(_damageCollection);
	elseif _masterObject.isKindOf(CM_MachineType) then
		//do nothing for now.
	else
		app.raiseUnexpectedProgramError(CMUI_Assistant.class.name, method.name, 'Unknown Object Type for Damage Positions');
		return;
	endif;
epilog
end;</source>
        <Parameter name="_masterObject" type="CM_Object"/>
        <Parameter name="_damageCollection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDamagePositionsForObject" id="abf3a5cc-4e82-4b42-ac8c-993608db9b72">
        <source>getDamagePositionsForObject(_masterObject : CM_Object; _damageCollection : Collection input);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
	machType : CM_MachineType;
	type : Integer;
begin
	
	if _masterObject.isKindOf(CM_TrackedItem) then
		cargoType := _masterObject .CM_TrackedItem.myCargoType;
		cargoType.allDamagePositions.copy(_damageCollection);
	elseif _masterObject.isKindOf(CM_WagonMaster) 
		or _masterObject.isKindOf(CM_Wagon) then
		machType := app.myRoot.allMachineTypes[MACHINETYPE_WAGONRAIL];
		machType.allDamagePositions.copy(_damageCollection);
		//_masterObject.CM_WagonMaster.allDamagePositions.copy(collection);
	elseif _masterObject.isKindOf(CM_MachineType) then
		_masterObject.CM_MachineType.allDamagePositions.copy(_damageCollection);
	elseif _masterObject.isKindOf(CM_TIMaster) then
		cargoType := app.myRoot.allCargoTypesById[_masterObject.CM_TIMaster.cargoType];
		cargoType.allDamagePositions.copy(_damageCollection);
	else
		app.raiseUnexpectedProgramError(CMUI_Assistant.class.name, method.name, 'Unknown Object Type for Damage Positions');
		return;
	endif;
epilog
