        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="14aa33dc-63a4-4040-9ce9-120bcad1bf2f">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutStockOrders,
	stockOrderBlock			: String;
	stockOrderLine			: CM_BOLOutStockOrderLineTI;
	blockLength,
	pos						: Integer;

begin

	bolOutStockOrders := _collectionsBlock.cnEcGetTagValueOfName(self.class.name &amp; 'allBOLOutStockOrderTIs');
	blockLength := bolOutStockOrders.length;
	pos := 1;
	
	while pos &lt; blockLength do
		stockOrderBlock := bolOutStockOrders.cnEcGetNextTagValueOfName('CM_BOLOutStockOrderLineTI', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if stockOrderBlock = null then
			continue;
		endif;
		
		create stockOrderLine persistent;
		stockOrderLine.importMeXML(stockOrderBlock);
		stockOrderLine.setPropertyValue('myStockOrderLine', self); 
	endwhile;
	
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="3a532d4c-79cf-4990-8003-f1fcfb4e9401">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	prodCode			: String;
	product				: CM_Product;
	foundCargoType,
	cargoType			: CM_CargoType;
	op					: CM_Operator;
begin
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.abbreviation = 'BMLT' then
			foundCargoType := cargoType;
			break;
		endif;
	endforeach;
	
	if foundCargoType = null then
		return;
	endif;
	
	prodCode := _referencesBlock.cnEcGetTagValueOfName('myProduct');
	op := self.myStockOrderHeader.myOperator;
	if op &lt;&gt; null then
		self.myProduct := op.allProducts[foundCargoType.id, prodCode];
	else
		self.myProduct := foundCargoType.allProducts[null, prodCode];		
	endif;
end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3e2a1f0a-8b99-4277-b087-e163f14f80d7">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     02 July 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyLine 	: CM_StockOrderProductLine;
	realAlloc,	
	pxyAlloc	: CM_StockOrderLineAlloc;
	completedOK		: Boolean;
	
begin
	pxyLine := inheritMethod();

	pxyLine.myProduct	:= self.myProduct;
	
	// Now attach proxy allocation lines
	foreach realAlloc in self.allStockAllocations do
		pxyAlloc := realAlloc.pxyCreateUpdateProxy;
		pxyAlloc.setMyStockOrderLine(pxyLine);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyLine;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyLine;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f89da1bc-3627-4e7d-8d03-b675a92886e2">
        <updating/>
        <source>setForCreate(_pxyLine: CM_StockOrderProductLine) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bolOutLine		: CM_BOLOutStockOrderLineTI;
	pxyAlloc,
	realAlloc		: CM_StockOrderLineAlloc;
	quantity,
	idx				: Integer;
	
begin
	inheritMethod(_pxyLine);
	
	self.myProduct		:= _pxyLine.myProduct;
	self.reqdQuantity	:= _pxyLine.reqdQuantity;
	self.unitOfMeasure	:= _pxyLine.unitOfMeasure;
	
	foreach pxyAlloc in _pxyLine.allStockAllocations do
		create realAlloc as pxyAlloc.class persistent;
		realAlloc.setForCreate(pxyAlloc);
		realAlloc.setMyStockOrderHeader(self.myStockOrderHeader);
		realAlloc.setMyStockOrderLine(self);
	endforeach;
	
	quantity := self.reqdQuantity.Integer;
	self.allBOLOutStockOrderTIs.purge();
	foreach idx in 1 to quantity do
		create bolOutLine persistent;
		bolOutLine.setForCreate(null, self, null);
	endforeach;

end;</source>
        <Parameter name="_pxyLine" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e2625f31-c5e1-42bf-a420-9fc7efd4db22">
        <updating/>
        <source>setForUpdate(_pxyLine: CM_StockOrderProductLine) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	pxyAlloc,
	realAlloc					: CM_StockOrderLineAlloc;
	numToRemove,
	numRemoved,
	idx,
	newNumOrderLines,
	currentNumOrderLines		: Integer;
	bolOutLine					: CM_BOLOutStockOrderLineTI;
begin
	inheritMethod(_pxyLine);
	
	self.myProduct		:= _pxyLine.myProduct;
	self.reqdQuantity	:= _pxyLine.reqdQuantity;
	self.unitOfMeasure	:= _pxyLine.unitOfMeasure;
	if _pxyLine.allStockAllocations.size = 0 then
		self.allStockAllocations.purge;
	endif;
	// Create/Update remaining lines as appropriate
	foreach pxyAlloc in _pxyLine.allStockAllocations do
		realAlloc := pxyAlloc.pxyGetRealObject;
		if realAlloc = null then
			// Create new line
			create realAlloc as pxyAlloc.class persistent;
			realAlloc.setForCreate(pxyAlloc);
			// Will be added to self.allStockOrderLines further down
		else
			// Update existing line
			realAlloc.setForUpdate(pxyAlloc);
		endif;
		realAlloc.setMyStockOrderHeader(self.myStockOrderHeader);
		realAlloc.setMyStockOrderLine(self);
	endforeach;

	//check for adjusted redq quantity and cull or create bolOut lines as necessary
	//some lines may already be fufilled, so we can't just purge and rebuild - 
	//need to preserve the TI reference if there is one
	currentNumOrderLines := self.allBOLOutStockOrderTIs.size;
	newNumOrderLines := _pxyLine.reqdQuantity.Integer;
	
	if currentNumOrderLines &lt; newNumOrderLines then //create more
		foreach idx in currentNumOrderLines to newNumOrderLines do
			create bolOutLine persistent;
			bolOutLine.setForCreate(null, self, null);
		endforeach;
		
	elseif currentNumOrderLines &gt; newNumOrderLines then
		//cull existing - first try removing unassigned boloutLines, then just remove assigned 
		numToRemove := currentNumOrderLines - newNumOrderLines;
		foreach bolOutLine in self.allBOLOutStockOrderTIs do
			if bolOutLine.myTrackedItem &lt;&gt; null then
				continue;
			endif;
			
			delete bolOutLine;
			numRemoved := numRemoved + 1;
			if numRemoved &gt;= numToRemove then
				return;
			endif;
		endforeach;
		
		//we still havn't removed enough, delete already loaded out lines
		foreach bolOutLine in self.allBOLOutStockOrderTIs do
			delete bolOutLine;
			numRemoved := numRemoved + 1;
			if numRemoved &gt;= numToRemove then
				return;
			endif;
		endforeach;	
	endif;

end;</source>
        <Parameter name="_pxyLine" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_LogStockOrderLine" id="586aa3ad-73ab-4ce7-b453-16dbce8344eb">
        <updating/>
        <source>setFromCMIF_LogStockOrderLine(_cmif : CMIF_LogStockOrderLine) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.comments			:= _cmif.comments;
	self.commentsOperator 	:= _cmif.commentsOperator;	
	self.dischargePort	:= _cmif.dischargePort;

	self.myProduct		:= _cmif.myProduct;
	self.operatorRef1	:= _cmif.operatorRef1;
	self.operatorRef2	:= _cmif.operatorRef2;
	self.reqdQuantity	:= _cmif.reqdQuantity;
	
end;</source>
        <Parameter name="_cmif" type="CMIF_LogStockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setProxyForOrderLine" id="0001d1d3-bbbb-47d7-8ebf-daaab71e3b3e">
        <updating/>
        <source>setProxyForOrderLine(_product : CM_Product;	_reqdQuantity: Real;
		_comments, _commentsOperator, _dischargePort : String;
		_operatorRef1, _operatorRef2 : String; _unitOfMeasure : String) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyDuplicateCheckLine : CM_StockOrderLine;

begin
	self.raiseExceptionIfNotTransient(method);

	self.comments			:= _comments;
	self.commentsOperator 	:= _commentsOperator;	
	self.dischargePort	:= _dischargePort;

	self.myProduct		:= _product;
	self.operatorRef1	:= _operatorRef1;
	self.operatorRef2	:= _operatorRef2;
	self.reqdQuantity	:= _reqdQuantity;
	self.unitOfMeasure	:= _unitOfMeasure;
	
end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_reqdQuantity" type="Real"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_commentsOperator" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_operatorRef1" type="String"/>
        <Parameter name="_operatorRef2" type="String"/>
        <Parameter name="_unitOfMeasure" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateAllocation" id="0b1ae6b7-83bb-4043-899e-f97dc2cbcda5">
        <source>validateAllocation(_allocAmount : Decimal);
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	totAmount : Integer;
begin
	totAmount := (_allocAmount + self.calAllocatedAmount()).Integer;
	if totAmount &gt; self.reqdQuantity then
		app.raiseCMWarning2(AllocateQtyWarning, totAmount.String, self.reqdQuantity.Integer.String,
							ETRow_AllocQuantity, null, self);		
	endif;
end;</source>
        <Parameter name="_allocAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="dd0b854b-09fe-443e-b202-7ffb3190cb98">
        <source>validateMe(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_passport);

	if self.myProduct = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), ETRow_MyProduct, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), ETRow_MyProduct, null); // cnwdb2	PAR 35364
	endif;
	if self.reqdQuantity &lt;= 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Quantity Required', ETRow_ReqdQuantity, null);
		app.raiseCMException(Input_required_field_quanReq, ETRow_ReqdQuantity, null); // cnwdb2	PAR 35364
	endif;
	if self.reqdQuantity &gt; 200 then // PAR16290
		app.raiseCMException(Quantit_high_more_than, ETRow_ReqdQuantity, null); // PAR16290
	endif;	
	
	if self.unitOfMeasure &lt;&gt; null then
		if	self.unitOfMeasure &lt;&gt; BOL_UOM_PIECE_COUNT and
			self.unitOfMeasure &lt;&gt; BOL_UOM_VOLUME and
			self.unitOfMeasure &lt;&gt; BOL_UOM_WEIGHT then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Unit of measure', null, null);
			app.raiseCMException(Input_required_field_unitOfMea, null, null); // cnwdb2	PAR 35364
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
