    <JadeMethod name="adjustWidth" id="b5af4e2c-a904-4614-a246-c3f5709d9936">
        <source>adjustWidth(_row: CM_RowAreaRow input; _width: Real; _previousDistance : Real);

vars

	logController 	: CM_RowController;
	logRestriction	: CM_LocationRestrictLog;
	theMax			: Real;

begin

	foreach logController in _row.allRowControllers do
		logRestriction := logController.CM_LogController.myLocationRestriction.CM_LocationRestrictLog;
		if logRestriction &lt;&gt; null then
			theMax:= (logRestriction.getMaxLength()).max(theMax);
		endif;
	endforeach;
	if _width &gt; theMax then
		inheritMethod(_row, _width, _previousDistance);
	endif;
end;</source>
        <Parameter name="_row" type="CM_RowAreaRow" usage="input"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_previousDistance" type="Real"/>
    </JadeMethod>
    <JadeMethod name="availableLocationsForType" id="85b33875-b95d-47dc-a1fe-9437d150c982">
        <source>availableLocationsForType(_cmifSearchTypes: CMIF_SearchTypes; _locationsArray: Collection input);

vars
	logController	: CM_RowController;

begin

	if	_cmifSearchTypes.myOperator	= null or
		_cmifSearchTypes.mySpecies	= null or
		_cmifSearchTypes.myGrade	= null or
		_cmifSearchTypes.myLength	= null then
		return;
	endif;

	foreach logController in self.allRowControllersById do
		if logController.doesAllowType(_cmifSearchTypes, false) then
			_locationsArray.add(logController);
		endif;
	endforeach;

end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locationsArray" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availableLocationsForTypeSub" id="6989f0a0-255c-47d1-aed4-1d89d4d32eee">
        <source>availableLocationsForTypeSub(_cmifSearchTypes: CMIF_SearchTypes; _locationsArray: Collection input);

vars

	iter 		: Iterator;
	location	: CM_LocationsController;

begin

	if	_cmifSearchTypes.myOperator	= null or
		_cmifSearchTypes.mySpecies	= null or
		_cmifSearchTypes.myGrade		= null or
		_cmifSearchTypes.myLength		= null then
		// Clear so we don't get wrong result.
		_locationsArray.clear;
		return;
	endif;
	iter := _locationsArray.createIterator;		
	while iter.next(location) do
		if not location.doesAllowType(_cmifSearchTypes, false) then
			_locationsArray.remove(location);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locationsArray" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="6c2e4e58-4002-4839-b2d5-e9e9ae104c20">
        <updating/>
        <source>createQuickCargoGC(_numItems : Integer) updating;
/*
Purpose:			
Date				Who			Reason
MAY 2014		CNWAB1		Initial creation
*/


vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI : CM_TrackedItem;
	pxyTI			: CM_Log;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx : Integer;
	commCode : String;
	op : CM_Operator;
begin

 
	aTerm := self.myTerminal;
	aVoy	:= aTerm.getNullVoyage();
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	cargoType	:= CM_Root.firstInstance.allCargoTypesById[TI_CargoType_Log];
	
	if not cargoType.allCommodities.isEmpty() and not cargoType.abbreviation = "CONT" then
		commCode := cargoType.allCommodities.first.code;
	else
		commCode := "GENL";
	endif;
//	cargoType := "2083.342".asOid.CM_CargoType; // BreakBulk
	state := TI_STATE_NORMAL;

	op := app.myRoot.allOperators["FF"];
	
	create moveController transient;
	foreach idx in 1 to _numItems do
		moveController.setMyToPrimaryLocation(self.allLocationsControllers.first);
		tmpID := self.getNextQuickCargoID(cargoType.id);
		
		pxyTI := aTerm.createTI(cargoType, true).CM_Log;
		pxyTI.zSetPxyTerminal(aTerm);
		pxyTI.setMyProduct(op.allProducts.first);
		pxyTI.setMyOperator(op);
		
		pxyTI.setMinMaxSed(5,10);
		pxyTI.setCommodity(commCode);
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.setMyTotalVolume(1767);	// cnwdw1 27868
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
		
		
		pxyTI.setPropertyValue("gradeCode", pxyTI.myLogGrade.code);
		pxyTI.setPropertyValue("speciesCode", pxyTI.myLogSpecies.code);
		pxyTI.setPropertyValue("lengthCode", pxyTI.myLogLength.code);
		pxyTI.setPropertyValue("treatmentCode", pxyTI.myLogTreatment.code);
		pxyTI.setPropertyValue("typeCode", pxyTI.myLogType.code);
		
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	commCode,
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLogRow" id="166c4387-05d2-4579-94d2-59155aaf0590">
        <source>findLogRow(_logRowId : String) : CM_LogController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars
	locn	: CM_LocationsController;
begin
	foreach locn in self.allLocationsControllers do
		if locn.ident = _logRowId and locn.isKindOf(CM_LogController) then
			return locn.CM_LogController;
		endif;
	endforeach;

	foreach locn in self.allEmptyLogControllers do
		if locn.ident = _logRowId and locn.isKindOf(CM_LogController) then
			return locn.CM_LogController;
		endif;
	endforeach;
	
	foreach locn in self.allLCsArchived do
		if locn.ident = _logRowId and locn.isKindOf(CM_LogController) then
			return locn.CM_LogController;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_logRowId" type="String"/>
        <ReturnType type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="getNextQuickCargoID" id="fe1fc369-eb95-4ffe-9a3c-d3bb041f4fda">
        <source>getNextQuickCargoID(_cargoType: Integer): String;
/*
Purpose:			
Date		Who		Reason
14 May 2014	cnwab1	Initial creation
*/

vars

	aTI : CM_TrackedItem;
	nextID, numId : String;
	nextNum : Integer;
begin
	nextNum := 1112221;
	
	while true do
		nextID := "LOG" &amp; nextNum.String;
			if self.myTerminal.allOnsiteTIsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;

epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
