    <JadeMethod name="addFieldValue" id="d07c4161-93d1-438b-9fa1-08fd229a47b8">
        <updating/>
        <source>addFieldValue(_value : String) updating;
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/

vars

begin
	if _value = null then
		return;
	endif;
	
	self.fieldsValues.add(_value);
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceAudit" id="9e0d7c5a-7d6f-41c2-8939-f6f626ba35f5">
        <updating/>
        <source>addInvoiceAudit(_ti : CM_TrackedItem) updating;
/*
------------------------------------------------------------------------
Created:			04 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
07/01/2019  	cnwma1			Bug 48197: SNO - Re: Data Base Lock - URGENT - 835582														
23 Nov 2023		navnk30			ChangeRequest 59299: MTN - Stop Creating Unqualified Audits for invoices when editing cargo items [Performance Improvement]
------------------------------------------------------------------------
*/
vars
	lAudit 		 : CM_AuditTIEdit;
	lSeqNum 	 : Integer;
	lInvoiceLine : CM_InvoiceLine;
	invoice 	 : CM_Invoice;
	invSet		 : CM_InvoiceSet;
	skipCargoItemInvAudits	 : Boolean;
begin
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tracked Item', null, null);
	endif;

	if _ti.invoiceLines.isEmpty then
		return;
	endif;
	if _ti.companyOid = null then
		return;
	endif;
	
	skipCargoItemInvAudits := _ti.myTerminal.getConfig(InvAuditCargoEdits).Boolean;	//23.11.2023 navnk30 #59299
	if skipCargoItemInvAudits then													//23.11.2023 navnk30 #59299
		return;
	endif;
	
	/* 17.01.2020 cnwma1 #48197
	
	create lAudit persistent;
	lSeqNum			   := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036 //_ti.companyOid.getSeqNum(SN_AUDIT);
	lAudit.sequenceNum := lSeqNum;
	lAudit.setTransaction(self);
	lAudit.setTrackedItem(_ti);
	lAudit.setRemarks();
	
	//06.01.2020 cnwma1
	foreach lInvoiceLine in _ti.invoiceLines do	
		
		if lInvoiceLine.bank &lt;&gt; _ti.companyOid then  //Par14964 - somehow containers in POE had invoiceLines with 2 different banks
			continue;
		endif;
		
		if lInvoiceLine.voided then
			continue;
		endif;
		
		invoice := lInvoiceLine.invoice;
		if invoice = null then
			continue;
		endif;
		
		if invoice.unqualifiedAudits.includes(lAudit) then
			continue;
		endif;
		
		exclusiveLock(lInvoiceLine);
		exclusiveLock(invoice);

		invoice.addUnqualifiedAudit(lAudit);
	endforeach;
	*/
	
	//17.01.2020 cnwma1 #48197
	
	create invSet transient;
	
	foreach lInvoiceLine in _ti.invoiceLines do
		if lInvoiceLine.bank &lt;&gt; _ti.companyOid then 
			continue;
		endif;
		
		if lInvoiceLine.voided then
			continue;
		endif;
		
		invoice := lInvoiceLine.invoice;
		if invoice = null then
			continue;
		endif;

		invSet.addNoDuplicates(invoice,false);
	
	endforeach;
	
	if not  invSet.isEmpty then
		create lAudit persistent;
		lSeqNum			   := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); 
		lAudit.sequenceNum := lSeqNum;
		lAudit.setTransaction(self);
		lAudit.setTrackedItem(_ti);
		lAudit.setRemarks();
		
		foreach invoice in invSet do
			exclusiveLock(invoice);
			invoice.addUnqualifiedAudit(lAudit);
		endforeach;
	endif;
	//17.01.2020 cnwma1 #48197
epilog

	delete invSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addTIAudit" id="b3cef621-48b0-4c11-8d54-353a6148b775">
        <source>addTIAudit():CM_AuditObject;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	auditConfig : CM_AuditConfig;
	auditObj : CM_AuditObject;
	formUsed : String;
	
	index : Integer;
	fieldName : String;
	fieldFound : Boolean;
	tmpFieldName : String;
	tmpOldValue : String;
	tmpNewValue : String;

begin

	auditConfig := app.myRoot.allAuditConfigs.getAtKey( CM_Edit.name );
	if auditConfig &lt;&gt; null and auditConfig.isEnabled then
		//Technical solution says "via cargo enquiry update" so only do it if its that screen.
		//But also for weight changes from the "Weigh" form.
		formUsed := self.getExtraData(TrnsExtraDataContext).asStringJMT;
		if formUsed = "CM_ContainerEnqForm" or formUsed = "CMUI_WeightsForm" then
			//The users want the attributes that are recorded in the Edit transactions on TIs created as audits too
			create auditObj persistent;
			if not auditObj.populateFromCMEdit( auditConfig, self ) then
				delete auditObj;
				auditObj := null;
			endif;
			
			if formUsed = "CM_ContainerEnqForm" then
				//specifically check to see if the weight changed, because this would be a manual weight change
				fieldName := CM_TrackedItem::totalWeight.name;
				foreach index in 1 to self.fieldsValues.size do
					self.getFieldValues( index, tmpFieldName, tmpOldValue, tmpNewValue );
					if fieldName = tmpFieldName then	
						fieldFound := true;
						break;
					endif;
				endforeach;
				if fieldFound then
					self.myTrackedItem.recordWeightSetManually( "Weight manually entered in Cargo Enquiry form", tmpOldValue, tmpNewValue, app.myPassport );
				endif;
			endif;
		endif;
	endif;

epilog

	return auditObj;

end;</source>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="addToStockMovement" id="441e8441-5a2b-4e71-9d0d-52b721d7eeab">
        <updating/>
        <source>addToStockMovement(_stkMove: CM_StockMovementLocation) updating;
//--------------------------------------------------------------
//Created: 01 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _stkMove = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to, null stockmove reference for ' &amp; self.String);
		return;
	endif;
	if _stkMove.isInwards then
		self.myStockMovementIn 	:= _stkMove;
	else
		self.myStockMovementOut := _stkMove;
	endif;

end;</source>
        <Parameter name="_stkMove" type="CM_StockMovementLocation"/>
    </JadeMethod>
    <JadeMethod name="cloneForTrackedItemRefs" id="059103af-8c22-43a9-8cd2-9afaeaedc837">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_Edit) updating, protected;
//--------------------------------------------------
// Created:	23 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	if self.fieldsValues &lt;&gt; null then
		delete self.fieldsValues;
	endif;
	self.fieldsValues := _orginalTransaction.fieldsValues.cloneSelf(self.isTransient);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_Edit"/>
    </JadeMethod>
    <JadeMethod name="correctFieldsValues_primitive" id="93e14509-f990-47f7-bc0c-393fff125141">
        <source>correctFieldsValues_primitive( _property : Property; _valueFrom, _valueTo : String ) : Boolean;
// --------------------------------------------------------------------------------------------------------
// Created:     18 Feb 2008 by cnwvu1
//
// Purpose:     Corrects valueFrom in the fieldsValues : BString.
//				_property should be type of Primitive.
// --------------------------------------------------------------------------------------------------------

vars
	typ		: Type;
	
begin

	typ := _property.type;
	if typ = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Property type is null' );
		return false;
	endif;

	if typ.isKindOf(Class) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Property type should be kind of primitive - ' &amp; Property.name );
		return false;
	endif;
	
	return self.fieldsValues.fieldCorrection( _property.name, _valueFrom, _valueTo );

end;
</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_valueFrom" type="String"/>
        <Parameter name="_valueTo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="correctValueFrom_forClass" id="babc9b86-4505-4d39-83c4-7cd8a837d211">
        <source>correctValueFrom_forClass( _obj : CM_Object; _property : Property ) : Boolean;
// --------------------------------------------------------------------------------------------------------
// Created:     18 Feb 2008 by cnwvu1
//
// Purpose:     Corrects valueFrom in the fieldsValues : BString.
//				_property should be type of class.
// --------------------------------------------------------------------------------------------------------

vars
	value	: String;
	typ		: Type;
	
begin

	typ := _property.type;
	if typ = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Property type is null' );
		return false;
	endif;

	if not typ.isKindOf(Class) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Property type should be kind of class - ' &amp; Property.name );
		return false;
	endif;
	
	value := _obj.getAuditTextForProperty( _property );	// gives text type of auditText sort of: myOperator^15^Operator - TIOP^
	value := value.extractValueFromAuditText();			// gives value: Operator - TIOP
	return self.fieldsValues.fieldCorrection( _property.name, value, null );

end;
</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="2ea18c1b-345f-430e-a47a-cec95ea6f641">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isTransient then
		create self.fieldsValues transient;
	else
		create self.fieldsValues persistent;
	endif;
	self.fieldValueVersion := 4;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3a13b76c-dc45-4684-80e5-c4ee94e04baf">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.fieldsValues &lt;&gt; null then
		delete self.fieldsValues;
	endif;
	if self.audit &lt;&gt; null then
		delete self.audit;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="docketCorrectionLocnWV_stock" id="ac6d5d9a-de9c-4691-b772-bf3185ff91cd">
        <updating/>
        <source>docketCorrectionLocnWV_stock( _oldLocation, _newLocation : CM_LocationsController ) updating;
// --------------------------------------------------------------------------------------------------------------------
// Created:     25 Feb 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the log, when Weight or Volume have been changed. 
//				The method is called when Location has been changed by the Docket Correction.
// --------------------------------------------------------------------------------------------------------------------

vars
	tmpLocation		: CM_LocationsController;
	tmpMovement		: CM_StockMovement;
	tmpSOHLocation,
	tmpSOHLocation2	: CM_SOHLocation;
	tmpProduct		: CM_Product;
	tmpBucket		: CM_StockMoveBucket;
	sedMean,
	tmpOldSedMean,
	tmpNewSedMean: Decimal[6,2];
	tmpSOHWeightDiff: Decimal[14,4];
	tmpSOHVolumeDiff: Decimal[16,4];
	tmpOldLength,
	tmpNewLength	: Decimal[6,2];
	tmpOldVolume,
	tmpNewVolume	: Decimal[16,4];

begin

	if self.isKindOf( CM_EditProductCode ) or self.isKindOf( CM_EditOperator ) then
		// CM_EditProductCode and CM_EditOperator have been changed by the docket correction
		app.raiseUnexpectedProgramError( class.name, method.name, 'This method designed only for CM_Edit transaction' );
		return;
	endif;

	if (self.myStockMovementIn &lt;&gt; null) and (self.myStockMovementOut &lt;&gt; null) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'CM_Edit trn: both stockMovementIn and stockMovemetnOut &lt;&gt; null. Log ' &amp; self.myTrackedItem.String );
	endif;
	if (self.myStockMovementIn = null) and (self.myStockMovementOut = null) then
		return;	// when log.length = R (Random) - there are no stockMovements
	endif;

	if self.myStockMovementOut &lt;&gt; null then
		tmpMovement		:= self.myStockMovementOut;
	else
		tmpMovement		:= self.myStockMovementIn;
	endif;

	if (tmpMovement.type &lt;&gt; StkMove_ValueUpdateIn) and (tmpMovement.type &lt;&gt; StkMove_ValueUpdateOut) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong stock move for CM_Edit ' &amp; self.String );
		return;
	endif;

	// ----------------------------------------------------------------------
	//								OLD LOCATION
	// ----------------------------------------------------------------------
	
	// stock reverse for the movement for the oldLocation	
	tmpBucket		:= tmpMovement.myStockMoveBucket;
	tmpLocation		:= tmpBucket.CM_StockMoveLocation.myLocationsController;
	if not tmpLocation.isStockControlled then
		return;
	endif;
	tmpSOHLocation	:= tmpBucket.CM_StockMoveLocation.mySOHLocation;
	tmpProduct		:= tmpSOHLocation.myProduct;
	tmpSOHLocation2 := _oldLocation.getSOHLocationForProduct( tmpProduct );
	if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Incorrect SOHLocation' );
	endif;
	
	// geting sedMean - it is required for Stock Move correction - stockOnHand
	if tmpSOHLocation.myExtension &lt;&gt; null then
		self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
		sedMean	:= tmpOldSedMean;
		if self.fromVolume &lt;&gt; self.totalVolume then	// Volume changed (SED as well)
			if tmpOldSedMean &lt;&gt; null and tmpNewSedMean &lt;&gt; null then
				sedMean := tmpNewSedMean - tmpOldSedMean;
			endif;
		endif;
	endif;

	if self.fromWeight &lt;&gt; self.totalWeight then			// Weight changed
		tmpSOHWeightDiff := self.totalWeight - self.fromWeight;
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, true, 
									0, tmpSOHWeightDiff, 0, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	elseif self.fromVolume &lt;&gt; self.totalVolume then		// Volume changed
		tmpSOHVolumeDiff := self.totalVolume - self.fromVolume;
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, true,
									0, 0, tmpSOHVolumeDiff, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'The method is designed for Weight or Volume (SED) changes only' );
		return;
	
	endif;

	// ----------------------------------------------------------------------
	//								NEW LOCATION
	// ----------------------------------------------------------------------
	tmpSOHLocation := _newLocation.getSOHLocationForProduct( tmpProduct );
	if self.fromWeight &lt;&gt; self.totalWeight then			// Weight changed
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, false, 
									0, tmpSOHWeightDiff, 0, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	else		// Volume changed
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, false,
									0, 0, tmpSOHVolumeDiff, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	endif;
	
	
end;
</source>
        <Parameter name="_oldLocation" type="CM_LocationsController"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionProdWV_stock" id="d4c239fb-df62-4241-b420-4573df2c3cb3">
        <updating/>
        <source>docketCorrectionProdWV_stock( _oldProduct, _newProduct : CM_Product ) updating;
// --------------------------------------------------------------------------------------------------------------------
// Created:     19 Feb 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the log, when Weight or Volume have been changed. 
//				The method is called when Product has been changed by docket correction.
//
// Parameters:	oldProduct  - product from previous transactions
//				_newProduct - new product corrected by DocketCorrection
// --------------------------------------------------------------------------------------------------------------------

vars
	tmpLocation		: CM_LocationsController;
	tmpMovement		: CM_StockMovement;
	tmpSOHLocation,
	tmpSOHLocation2	: CM_SOHLocation;
	tmpProduct		: CM_Product;
	tmpBucket		: CM_StockMoveBucket;
//	tmpType			: Integer;
	//stockOnHandToBeChanged : Boolean;
	sedMean,
	tmpOldSedMean,
	tmpNewSedMean: Decimal[6,2];
	tmpSOHWeightDiff: Decimal[14,4];
	tmpSOHVolumeDiff: Decimal[16,4];
	tmpOldLength,
	tmpNewLength	: Decimal[6,2];
	tmpOldVolume,
	tmpNewVolume	: Decimal[16,4];
	
begin

	if self.isKindOf( CM_EditProductCode ) or self.isKindOf( CM_EditOperator ) then
		// CM_EditProductCode and CM_EditOperator have been changed by the docket correction
		app.raiseUnexpectedProgramError( class.name, method.name, 'This method designed only for CM_Edit transaction' );
		return;
	endif;

	if (self.myStockMovementIn &lt;&gt; null) and (self.myStockMovementOut &lt;&gt; null) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'CM_Edit trn: both stockMovementIn and stockMovemetnOut &lt;&gt; null. Log ' &amp; self.myTrackedItem.String );
	endif;
	if (self.myStockMovementIn = null) and (self.myStockMovementOut = null) then
		return;	// when log.length = R (Random) - there are no stockMovements
	endif;
	
	if self.myStockMovementOut &lt;&gt; null then
		tmpMovement		:= self.myStockMovementOut;
	else
		tmpMovement		:= self.myStockMovementIn;
	endif;

	if (tmpMovement.type &lt;&gt; StkMove_ValueUpdateIn) and (tmpMovement.type &lt;&gt; StkMove_ValueUpdateOut) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong stock move for CM_Edit ' &amp; self.String );
		return;
	endif;

	
	// ----------------------------------------------------------------------
	//								old product
	// ----------------------------------------------------------------------
	
	// stock reverse for the movement for the oldPorduct	
	tmpBucket		:= tmpMovement.myStockMoveBucket;
	tmpLocation		:= tmpBucket.CM_StockMoveLocation.myLocationsController;
	if not tmpLocation.isStockControlled then
		return;
	endif;
	tmpSOHLocation	:= tmpBucket.CM_StockMoveLocation.mySOHLocation;
	tmpProduct		:= tmpSOHLocation.myProduct;
	tmpSOHLocation2 := tmpLocation.getSOHLocationForProduct( _oldProduct );
	if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Incorrect SOHLocation' );
	endif;
	
	// geting sedMean - it is required for correction current stock - stockOnHand
	if tmpSOHLocation.myExtension &lt;&gt; null then
		self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
		sedMean	:= tmpOldSedMean;
		if self.fromVolume &lt;&gt; self.totalVolume then	// Volume changed (SED as well)
			if tmpOldSedMean &lt;&gt; null and tmpNewSedMean &lt;&gt; null then
				sedMean := tmpNewSedMean - tmpOldSedMean;
			endif;
		endif;
	endif;

	if self.fromWeight &lt;&gt; self.totalWeight then			// Weight changed
		tmpSOHWeightDiff := self.totalWeight - self.fromWeight;
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, true, 
									0, tmpSOHWeightDiff, 0, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	elseif self.fromVolume &lt;&gt; self.totalVolume then		// Volume changed
		tmpSOHVolumeDiff := self.totalVolume - self.fromVolume;
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, true, 
									0, 0, tmpSOHVolumeDiff, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'The method is designed for Weight or Volume (SED) changes only' );
		return;
	
	endif;

	// ----------------------------------------------------------------------
	//								new product
	// ----------------------------------------------------------------------
	
	// stock creation for the movement for the newProduct
	tmpSOHLocation := tmpLocation.getSOHLocationForProduct( _newProduct );
	if self.fromWeight &lt;&gt; self.totalWeight then			// Weight changed
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, false, 
									0, tmpSOHWeightDiff, 0, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	else		// Volume changed
		// new product has another volume by the same SED - when length is different (Volume is ccounted by sed and length)
		// Otherwise, we will use tmpSOHVolumeDiff, counted above (it is the same for the new product with the same length).
		tmpOldLength := _oldProduct.CM_ProductLog.logLength;
		tmpNewLength := _newProduct.CM_ProductLog.logLength;
		if tmpOldLength &lt;&gt; tmpNewLength then
			if self.hasSedChanged( tmpOldSedMean, tmpNewSedMean ) then
				tmpOldVolume := global.calcJASVolume( tmpOldSedMean, tmpNewLength );
				tmpNewVolume := global.calcJASVolume( tmpNewSedMean, tmpNewLength );
				tmpSOHVolumeDiff := tmpNewVolume - tmpOldVolume; // volume difference for newProduct
			endif;
			// also, we have to correct volumes in this CM_Edit transaction
			self.savePreviousVersion();
			self.fromVolume	:= tmpOldVolume;
			self.totalVolume:= tmpNewVolume;
			// correcting CM_Edit.fieldsValues
			self.correctFieldsValues_primitive( CM_Log::jasVolume,	tmpOldVolume.roundedTo(3).String, tmpNewVolume.roundedTo(3).String ); //roundedTo(3) because see CM_Log::recalcJASVolume()
			self.correctFieldsValues_primitive( CM_Log::volume,		tmpOldVolume.String, tmpNewVolume.String );
			self.correctFieldsValues_primitive( CM_Log::totalVolume,tmpOldVolume.String, tmpNewVolume.String );
		endif;
		tmpSOHLocation.adjustStockOnHand_docketCorect( self.createdTime, tmpMovement.type, false, 
									0, 0, tmpSOHVolumeDiff, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	endif;
	
end;
</source>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getAllSealNumChanges" id="43a12991-5058-480c-8e06-99c353661c28">
        <source>getAllSealNumChanges(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
//2/10/2019		JLGNS1		ChangeRequest 45790: JMT - Refactor - Seal Transactions
vars
	str : String;
	ti : CM_TrackedItem;
	oldValue,
	newValue : String;
	i : Integer;
	field : String;
begin
	ti := self.myTrackedItem;
	foreach i in 1 to self.fieldsValues.size  do
	
		self.getFieldValues(i, field, oldValue, newValue);
		//17 Sep 2010	NDL	Par 25608	- allow for when the old attributes are removed
		if field = null then
			self.getFieldValuesForSystemSeals(i, field, oldValue, newValue);
		endif;
		
		if field = SealNum or
		   field = SealNumShippers or
		   field = SealNumCustoms or
		   field = AllCustomsSealNumbers or 
		   field = SealNumTerminalOperator or	//ChangeRequest 45790
		   field = SealNumUnknown or 			//ChangeRequest 45790
		   field = SealNumVent then
		   
			if oldValue = null then
				oldValue := app.getErrorString(Null);
			endif;
			if newValue = null then
				newValue := app.getErrorString(Null);
			endif;
			if str = null then
				str := field &amp; ' : ' &amp; oldValue &amp; '=&gt;'&amp; newValue;
			else
				str := str &amp; CrLf &amp;  field &amp; ' : ' &amp; oldValue &amp; '=&gt;'&amp; newValue;
			endif;
		
		endif;
		
	endforeach;
	return str;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailDisplayString" id="52bc32b1-aa45-4304-b994-1ead491eaa1a">
        <source>getDetailDisplayString() : String;

/*

Purpose:			33251 Jan 2014 get the display string for ETRow_Details including formatting the CM_Edit fieldsValues string to show the default system measurement type
					for relevant field values.  Revised to use the array of edit strings so that the attribute name of each edit can be found directly
					without having to do a pos for it in the overall string, which found spurious matches in the text of remarks, description etc.
					Also includes the hideAuditValues processing by attribute name without needing to search the full string.

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2014	cnwjre1	Initial creation
15 Oct     2014 cnwma1 PAR #34973 Editing at the same time of the OD of multiple items
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on, found an edit with no prioir value causing out of string exception
*/

vars
	theTI 	: CM_TrackedItem;
	prod	: CM_Product;
	editStrings	: HugeStringArray;
	resultStrings	: HugeStringArray;
	attributes		: StringArray;
	detailString	: String;
	attrName		: String;
	measureType		: String;
	i				: Integer;
	attrPos			: Integer;
	attrLen			: Integer;
	sepPos			: Integer;
	endPos			: Integer;
	size			: Integer;
	priorValue		: String;
	changedValue	: String;
	returnDetail	: String;
	isContainer		: Boolean;	//07 Sep 2015	NDL	Par 36272

begin
	create editStrings transient;
	if self.fieldsValues &lt;&gt; null then 
			
		//6/3/14 epr BULK CCMS for some very strange reason any edit for BULK cargo was coded to reutrn the weight changed !!! so i removed that 
		self.fieldsValues.getStrings(editStrings);
	endif;
			
	create resultStrings transient;
	if editStrings.size &gt; 0 then
		theTI := self.myTrackedItem;	
		if theTI &lt;&gt; null then
			prod := theTI.getProductForMeasurementConv();
			isContainer := theTI.isKindOf(CM_Container);	//07 Sep 2015	NDL	Par 36272
		endif;
		
		// PAR #31155 CCMS SFW 1321 Imperial Measurements, list of measurement attributes
		create attributes transient;
		attributes.add(ETRow_Weight);
		attributes.add(ETRow_TotalWeight);
		attributes.add(ETRow_WeightTotal);
		attributes.add(ETRow_CargoWeight);
		attributes.add(ETRow_WeightCargo);
		attributes.add(ETRow_WeightDeclared);
		attributes.add(ETRow_UnsplitWeight);
		attributes.add(ETRow_TareWeight);
		attributes.add(ETRow_WeightTare);
		attributes.add(ETRow_TotalVolume);
		attributes.add(ETRow_Volume);
		attributes.add(ETRow_VolumeTotal);
		attributes.add(ETRow_ContainerVolume);
		attributes.add(ETRow_UnsplitVolume);
		attributes.add(ETRow_Height);
		attributes.add(ETRow_Length);
		attributes.add(ETRow_Width);
		attributes.add(ETRow_OverHeight);
		attributes.add(ETRow_OverLengthFront);
		attributes.add(ETRow_OverLengthBack);
		attributes.add("overLengthRear");  //07 Sep 2015	NDL	Par 36272 Put back in again
		attributes.add(ETRow_OverWidthLeft);
		attributes.add(ETRow_OverWidthRight);
		attributes.add(ETRow_HeightCM);
		attributes.add(ETRow_LengthCM);
		attributes.add(ETRow_WidthCM);
		attributes.add(ETRow_Density);
		attributes.add(ETRow_Ventilation);

		foreach detailString in editStrings do
			// strings should be property name &lt;space&gt; [&lt;old value&gt;] =&gt; &lt;new value&gt;
			attrPos := detailString.pos(" ", 1);
			if attrPos &lt; 2 then
				resultStrings.add(detailString);
				continue;
			endif;
			attrName := detailString[1:attrPos - 1];
			attrLen := attrName.length;
			
			if isContainer then	//07 Sep 2015	NDL	Par 36272 
				// We also use these attributes to store the over dimension values on containe
				// so don't show them twice...
				if attrName.isOneOf(ETRow_LengthCM, ETRow_Length, ETRow_Width,
									ETRow_WidthCM, ETRow_Height, ETRow_HeightCM) then
					continue;
				endif;
			endif;
				
			// CCMS JMT 1743/1764 hide audit values if user doesn't have permission to see then
			// and PAR #31155 Format the measurement portions of the detail string
			if attrName = OperatorImportReleasePIN or
			   attrName = OperatorExportReleaseNumber or
		  	   attributes.includes(attrName) then
				measureType := null;
				if attrName.isOneOf(	ETRow_Weight, ETRow_TotalWeight, ETRow_WeightTotal, 
										ETRow_CargoWeight, ETRow_WeightCargo, 
										ETRow_WeightDeclared, ETRow_UnsplitWeight,
										ETRow_TareWeight, ETRow_WeightTare	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Weight).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Weight).shortName;
					endif;
				elseif attrName.isOneOf(	ETRow_TotalVolume, ETRow_Volume, ETRow_VolumeTotal,
											ETRow_ContainerVolume, ETRow_UnsplitVolume	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Volume).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Volume).shortName;
					endif;
				elseif attrName.isOneOf(	ETRow_Length, ETRow_OverLengthFront, ETRow_OverLengthBack,
											ETRow_LengthCM, "overLengthRear" ) then   //15/10/2014 cnwma1 PAR34973
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Length).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Length).shortName;
					endif;
			
				elseif attrName.isOneOf(	ETRow_Height, ETRow_OverHeight, ETRow_HeightCM	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Height).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Height).shortName;
					endif;
	
				elseif attrName.isOneOf(	ETRow_Width, ETRow_OverWidthLeft, ETRow_OverWidthRight,
											ETRow_WidthCM	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Width).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Width).shortName;
					endif;
				elseif attrName = ETRow_Density then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Density).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Density).shortName;
					endif;
				elseif attrName = ETRow_Ventilation then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Displacement).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Displacement).shortName;
					endif;
				endif;

				// find the separator position
				sepPos := detailString.pos(Space &amp; self.S_EDIT_THING &amp; Space, 1);
				// 34390 handle no changedValue where just ' =&gt;' ends this string for whatever reason
				if sepPos = 0 then
					sepPos := detailString.pos(Space &amp; self.S_EDIT_THING, 1);
				endif;
				if sepPos = 0 then		// 34390 safety check
					continue;
				endif;

				// check for the prior value
				if sepPos &lt;= (attrLen + 2) then	//20 Jan 2017	cnwrs1	TFS 3137 if there is no prioir value sepPos can be less than attrLen+2 eg detailString := "field =&gt; 123";
					// no prior value
					priorValue := null;
				else
					priorValue := detailString[attrLen + 2:sepPos - (attrLen + 2)];
					if attrName = OperatorImportReleasePIN then
						if ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinEdit) ) and
						   ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinView) ) then
							priorValue := "*";
						endif;
					elseif attrName = OperatorExportReleaseNumber then
						if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then
							priorValue := "*";
						endif;
					elseif priorValue.Decimal = null or (priorValue.Decimal = NULL_VENTILATION and attrName = ETRow_Ventilation) then
						priorValue := null;
					else
						priorValue := app.convertMeasurementForDisplay(measureType, priorValue.Decimal) &amp; Space &amp; measureType;
					endif;
				endif;
				
				// now the changed value
				endPos := detailString.length + 1;
				if endPos - sepPos - 4 &gt; 0 then
					changedValue := detailString[sepPos + 4:endPos - sepPos - 4];
				else
					changedValue := null;
				endif;
				if attrName = OperatorImportReleasePIN then
					if ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinEdit) ) and
					   ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinView) ) then
					    changedValue := "*";
					endif;
				elseif attrName = OperatorExportReleaseNumber then
					if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then
						changedValue := "*";
					endif;
				else
					changedValue := app.convertMeasurementForDisplay(measureType, changedValue.Decimal) &amp; Space &amp; measureType;
				endif;
				
				// rebuild the string with the adjusted measurement values
				returnDetail := attrName &amp; Space &amp; priorValue &amp; Space &amp; self.S_EDIT_THING &amp; Space &amp; changedValue;
			else
				// not a special attribute, take the details unchanged
				returnDetail := detailString;
			endif;
			resultStrings.add(returnDetail);
		
		endforeach;
	endif;
	
	// code from CM_Strings getAsEditPair to format the result the same way as before
	returnDetail := null;	
	size := resultStrings.size;
	i := 1;
	while i &lt; size + 1 do
		returnDetail := returnDetail &amp; resultStrings[i];
		if i + 1 &lt;= size then
			returnDetail := returnDetail &amp; ": " &amp; resultStrings[i + 1] &amp; CrLf;
		endif;
		i := i + 2;
	endwhile;
	
	returnDetail := returnDetail &amp; " " &amp; self.urNumber.String;

	return returnDetail;	

epilog
	delete editStrings;
	delete resultStrings;
	delete attributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailDisplayStringSQL" id="5a918370-6808-42fb-b6d0-e5739de3be48">
        <source>getDetailDisplayStringSQL():HugeStringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwma1	Initial creation
25 May 2017 cnwma1  TFS #4547:POL - [Fwd: ##4542## : 8.5.1.060 Testing - TFS 2807 Edit transactions missing]
*/


vars
	theTI 	: CM_TrackedItem;
	prod	: CM_Product;
	editStrings	: HugeStringArray;
	resultStrings	: HugeStringArray;
	attributes		: StringArray;
	detailString	: String;
	attrName		: String;
	measureType		: String;
	attrPos			: Integer;
	attrLen			: Integer;
	sepPos			: Integer;
	endPos			: Integer;
	priorValue		: String;
	changedValue	: String;
	returnDetail	: String;
	isContainer		: Boolean;	

begin
	create editStrings transient;
	if self.fieldsValues &lt;&gt; null then 
		self.fieldsValues.getStrings(editStrings);
	endif;
			
	create resultStrings transient;
	if editStrings.size &gt; 0 then
		theTI := self.myTrackedItem;	
		if theTI &lt;&gt; null then
			prod := theTI.getProductForMeasurementConv();
			isContainer := theTI.isKindOf(CM_Container);
		endif;
		
		create attributes transient;
		attributes.add(ETRow_Weight);
		attributes.add(ETRow_TotalWeight);
		attributes.add(ETRow_WeightTotal);
		attributes.add(ETRow_CargoWeight);
		attributes.add(ETRow_WeightCargo);
		attributes.add(ETRow_WeightDeclared);
		attributes.add(ETRow_UnsplitWeight);
		attributes.add(ETRow_TareWeight);
		attributes.add(ETRow_WeightTare);
		attributes.add(ETRow_TotalVolume);
		attributes.add(ETRow_Volume);
		attributes.add(ETRow_VolumeTotal);
		attributes.add(ETRow_ContainerVolume);
		attributes.add(ETRow_UnsplitVolume);
		attributes.add(ETRow_Height);
		attributes.add(ETRow_Length);
		attributes.add(ETRow_Width);
		attributes.add(ETRow_OverHeight);
		attributes.add(ETRow_OverLengthFront);
		attributes.add(ETRow_OverLengthBack);
		attributes.add("overLengthRear");  
		attributes.add(ETRow_OverWidthLeft);
		attributes.add(ETRow_OverWidthRight);
		attributes.add(ETRow_HeightCM);
		attributes.add(ETRow_LengthCM);
		attributes.add(ETRow_WidthCM);
		attributes.add(ETRow_Density);
		attributes.add(ETRow_Ventilation);

		foreach detailString in editStrings do
			// strings should be property name &lt;space&gt; [&lt;old value&gt;] =&gt; &lt;new value&gt;
			attrPos := detailString.pos(" ", 1);
			if attrPos &lt; 2 then
				resultStrings.add(detailString);
				continue;
			endif;
			attrName := detailString[1:attrPos - 1];
			attrLen := attrName.length;
			
			if isContainer then	
				// We also use these attributes to store the over dimension values on containe
				// so don't show them twice...
				if attrName.isOneOf(ETRow_LengthCM, ETRow_Length, ETRow_Width,
									ETRow_WidthCM, ETRow_Height, ETRow_HeightCM) then
					continue;
				endif;
			endif;

			if attrName = OperatorImportReleasePIN or
			   attrName = OperatorExportReleaseNumber or
		  	   attributes.includes(attrName) then
				measureType := null;
				if attrName.isOneOf(	ETRow_Weight, ETRow_TotalWeight, ETRow_WeightTotal, 
										ETRow_CargoWeight, ETRow_WeightCargo, 
										ETRow_WeightDeclared, ETRow_UnsplitWeight,
										ETRow_TareWeight, ETRow_WeightTare	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Weight).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Weight).shortName;
					endif;
				elseif attrName.isOneOf(	ETRow_TotalVolume, ETRow_Volume, ETRow_VolumeTotal,
											ETRow_ContainerVolume, ETRow_UnsplitVolume	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Volume).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Volume).shortName;
					endif;
				elseif attrName.isOneOf(	ETRow_Length, ETRow_OverLengthFront, ETRow_OverLengthBack,
											ETRow_LengthCM, "overLengthRear" ) then 
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Length).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Length).shortName;
					endif;
			
				elseif attrName.isOneOf(	ETRow_Height, ETRow_OverHeight, ETRow_HeightCM	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Height).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Height).shortName;
					endif;
	
				elseif attrName.isOneOf(	ETRow_Width, ETRow_OverWidthLeft, ETRow_OverWidthRight,
											ETRow_WidthCM	) then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Width).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Width).shortName;
					endif;
				elseif attrName = ETRow_Density then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Density).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Density).shortName;
					endif;
				elseif attrName = ETRow_Ventilation then
					if prod &lt;&gt; null then
						measureType := prod.getDefaultMeasurementForType(Type_Displacement).shortName;
					else
						measureType := app.getDefaultMeasurementForType(Type_Displacement).shortName;
					endif;
				endif;

				// find the separator position
				sepPos := detailString.pos(Space &amp; self.S_EDIT_THING &amp; Space, 1);
				// 34390 handle no changedValue where just ' =&gt;' ends this string for whatever reason
				if sepPos = 0 then
					sepPos := detailString.pos(Space &amp; self.S_EDIT_THING, 1);
				endif;
				if sepPos = 0 then		
					continue;
				endif;

				// check for the prior value
				if sepPos &lt;= (attrLen + 2) then	
					// no prior value
					priorValue := null;
				else
					priorValue := detailString[attrLen + 2:sepPos - (attrLen + 2)];
					if priorValue.Decimal = null or (priorValue.Decimal = NULL_VENTILATION and attrName = ETRow_Ventilation) then
						priorValue := null;
					else
						priorValue := app.convertMeasurementForDisplay(measureType, priorValue.Decimal) &amp; Space &amp; measureType;
					endif;
				endif;
				
				// now the changed value
				endPos := detailString.length + 1;
				if endPos - sepPos - 4 &gt; 0 then
					changedValue := detailString[sepPos + 4:endPos - sepPos - 4];
				else
					changedValue := null;
				endif;
			
				changedValue := app.convertMeasurementForDisplay(measureType, changedValue.Decimal) &amp; Space &amp; measureType;
				
				// rebuild the string with the adjusted measurement values
				returnDetail := attrName &amp; Space &amp; priorValue &amp; Space &amp; self.S_EDIT_THING &amp; Space &amp; changedValue;
			else
				// not a special attribute, take the details unchanged
				returnDetail := detailString;
			endif;
			resultStrings.add(returnDetail);
		
		endforeach;
	endif;
	
	
	return resultStrings;

epilog
	delete editStrings;
	delete attributes;
end;</source>
        <ReturnType type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="d8054d11-c8c9-4f43-891e-794550fd61e6">
        <source>getDisplayString(): String;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	lDetail : String;
begin
	// this code was copied from CM_DeliverRquests::ids
	// it gets the strings stored in a binary type
	if self.fieldsValues &lt;&gt; null then
		lDetail := self.fieldsValues.getAsEditPair();
	endif;
	if lDetail &lt;&gt; null then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="73fd991e-175f-4ba5-b929-f695209722c5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/06/2010	cnwndl1	Initial creation	Par 23498
29/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	lDetail : String;
	theTI 	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			// 33251 Jan 2014 this code revised into the following method
			lDetail := self.getDetailDisplayString();		
			return lDetail;
			
		endif;
							
	elseif _attrName = ETRow_EditDetails then
		return self.getDisplayString();
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEditOldContainerId" id="bf72c9c7-0995-4764-ab40-64ffab0e71f0">
        <source>getEditOldContainerId(): String;

vars
	oldValue,
	newValue	:String;
begin
	self.getFieldValuesByField(CM_TrackedItem::id, null, oldValue, newValue);
	
	return oldValue;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEditTransactionsDetailsSQL" id="55c4635e-2d62-4dc0-bad8-f55d22a09542">
        <source>getEditTransactionsDetailsSQL():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2017	cnwma1	Initial creation
25 May 2017 cnwma1  TFS #4547:POL - [Fwd: ##4542## : 8.5.1.060 Testing - TFS 2807 Edit transactions missing]
*/

vars
	tit : CM_TITransaction;
	editStrings,
	formatedString : HugeStringArray;
	str,
	s,
	propertyName,
	beforeValue,
	afterValue : String;

begin
	
	/*create editStrings transient; /25/05/2017 cnwma1 TFS #4547
	// foreach  tit in 	self.allTransactions reversed where tit.isKindOf(CM_Edit) do 
		i := 0;
		foreach i in 1 to self.fieldsValues.size  do
			self.getFieldValuesForSQL(i, field, oldValue, newValue);
			str:= field&amp; "{" &amp; oldValue &amp; "|" &amp; newValue &amp;"}";
			if field &lt;&gt; null then
				editStrings.add(str);
			endif;
		endforeach;
	//endforeach;
	str := null;
	foreach s in editStrings do 
	     str :=str &amp; s &amp;' ' ; 
		
	endforeach;
	str := str.trimRight(); 
	return str;*/
	create editStrings transient;
	
	editStrings:= self.getDetailDisplayStringSQL();
	
	create formatedString transient;
	foreach str in editStrings  do 
		self.splitEditChangeForSQL(str, propertyName, beforeValue, afterValue);
		if propertyName &lt;&gt; null then			
			str:= propertyName&amp; "{" &amp; beforeValue &amp; "|" &amp; afterValue &amp;"}";
			formatedString.add(str);
		endif;
	endforeach;
	
	str := null;
	foreach s in formatedString do 
	     str :=str &amp; s &amp;' ' ; 	
	endforeach;
	str := str.trimRight();
	
	return str;
	
epilog
	delete editStrings;
	delete formatedString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="024182d5-9aab-4d0b-abdf-f15db24208ed">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
	theTI 	: CM_TrackedItem;
	tmpstr: String;
begin
	lDetail := inheritMethod();

	// this code was copied from CM_DeliverRquests::ids
	// it gets the strings stored in a binary type
	if self.fieldsValues &lt;&gt; null then 
		lDetail := lDetail &amp; " " &amp; self.fieldsValues.getAsEditPair();
	endif;
	
	if lDetail &lt;&gt; null then
	
		//if not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinEdit) then	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
		if ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinEdit) )
		and ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinView) ) then	//25 Jan 2011	NDL	Par 26802
			lDetail := self.hideAuditValues( lDetail , OperatorImportReleasePIN , '*');	 //cnwrd1 10.11.08 CCMS JMT 1743/1764 
		endif;
		
		if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
			lDetail := self.hideAuditValues( lDetail , OperatorExportReleaseNumber , '*');	 //cnwrd1 10.11.08 CCMS JMT 1743/1764 
		endif;		
	
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;	

	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRowFullInfo" id="a6f226fd-cbda-4335-b14f-a3160043e49f">
        <source>getEnquiryRowFullInfo(_dataContainer: CM_DataContainer io);
/*
----------   ----------  --------------------------------------------------
Created:	04 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
block : CM_DataContainerBlock;
str	: String;
comment : Any;
theTI		: CM_TrackedItem;
otherTI	: CM_TrackedItem;
product		: CM_Product;
tmpWeight,
tmpVolume,
tmpQuantity	: Decimal[8];
begin
		
	theTI := self.myTrackedItem;
	if theTI &lt;&gt; null then
		product := theTI.myProduct;
	else	
		return;
	endif;
	
	
	create _dataContainer transient;
	
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Edited by user", DC_Label, 1, null);
	block.addNewItem(self.userId, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Item", DC_Label, 1, null);
	block.addNewItem(theTI.id, DC_Data, 1, null);
	
	if product = null then
		return;
	endif;
	/*
	str := 	product.myWeight.displayName &amp; ' ' &amp;
			product.myWeight.multiplyValue(self.fromWeight).String &amp; 
			' =&gt; ' &amp; product.myWeight.multiplyValue(self.totalWeight).String;*/ //30.1.09 cnwrd1 par #18821 --
			
	str := 	product.getMyWeightDisplayName() &amp; ' ' &amp;
			product.getMyWeightDisplayValue(self.fromWeight).String &amp; 
			' =&gt; ' &amp; product.getMyWeightDisplayValue(self.totalWeight).String; //30.1.09 cnwrd1 par #18821 ++
			
	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Action", DC_Label, 1, null);
	block.addNewItem(str, DC_Data, 1, null);
	
	comment := self.getExtraDataComment();
	if comment &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Comments", DC_Label, 1, null);
		block.addNewItem(comment.String, DC_Data, 1, null);
	endif;
	
end;

</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFieldValues" id="4b210a6e-a29f-404d-9190-797e8d64c3fa">
        <source>getFieldValues(_at : Integer; _field, _oldValue, _newValue : String output);
// new version since JMT733 
// will not handle the decoding of fieldValues prior to JMT733
// cnwrs1 Nov 2006 PAR 12951
vars
	str : String;
	pos, pos2 : Integer;
begin

	if self.fieldsValues.size &lt; _at then
		return;
	endif;

// only interested in chenges to ti so no ti no changes
	if self.myTrackedItem = null then
		return;
	endif;
	// get the first full field 
	str := self.fieldsValues.at(_at);
	if str.length &gt; 80 then
		str := str[1:80];
	endif;
	pos2 := 1;
	// get field name which must be a property
	_field := str.cnGetToken(pos2, ' ').trimBlanks();
	if self.myTrackedItem.class.findProperty(_field) = null then
		_field := null;
		return;
	endif;
	pos2 := _field.length()+1;
	pos := str.pos("=&gt;",1);
	// old value should be data after field name and before =&gt; may be null 
	if pos &gt; 2 then
		_oldValue := str[pos2:pos-pos2-1].trimBlanks;
		if (pos+2) &lt; str.length then
			// new data is every thing after the =&gt;
			_newValue := str[pos+2:str.length].trimBlanks;
		endif;
		// process the properties that dont adhear to the standard
		if _field = CM_TrackedItem::myVoyage.name then
			//my Voyage can be either myVoyage Voyage ******** =&gt; Voyage CST5448 or
			// of the format Null Voyage - ******************** =&gt; Voyage - NIG0614
			pos := _oldValue.pos('-',1);
			if pos &gt; 2 then
				// if there is a - in it ignore everything before
				_oldValue := _oldValue[pos+2:_oldValue.length-pos].trimBlanks;
				pos := _newValue.pos('-',1);
				if pos &gt; 2 then
					_newValue := _newValue[pos+2:_newValue.length-pos].trimBlanks;
				endif;
			else
				// else get rid of the word Voyage
				pos := _oldValue.pos('Voyage',1);
				if pos &gt; 0 then //par14336 cnwrs1 June 2007
					_oldValue := _oldValue[pos+7:_oldValue.length-pos].trimBlanks;
				endif;
				pos := _newValue.pos('Voyage',1);
				if pos &gt; 0 then //par14336 cnwrs1 June 2007
					_newValue := _newValue[pos+7:_newValue.length-pos].trimBlanks;
				endif;
			endif;
		endif;
	else
		_newValue := str.cnGetToken(pos2, ' ');
	endif;
end;</source>
        <Parameter name="_at" type="Integer"/>
        <Parameter name="_field" type="String" usage="output"/>
        <Parameter name="_oldValue" type="String" usage="output"/>
        <Parameter name="_newValue" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFieldValuesByField" id="34201c69-573e-4203-bc30-210fe7e53e8e">
        <source>getFieldValuesByField( _property : Property; _obj : CM_Object; _oldValue, _newValue : String output ) : Boolean;
// --------------------------------------------------------------------------------------------------------------------
// Created:     19 Feb 2008 by cnwvu1
//
// 				Note. When property is type of class, we have to send _obj - audited class.
//				For example, working with CM_Edit on the log, we should send that log as _obj.
// --------------------------------------------------------------------------------------------------------------------

vars
	typ			: Type;
	fieldFound	: Boolean;
	i			: Integer;
	fieldName,
	tmpFieldName,
	tmpOldValue,
	tmpNewValue	: String;
	
begin
	
	typ := _property.type;
	if typ = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Property type is null' );
		return false;
	endif;

	if typ.isKindOf(Class) then
		fieldName := _obj.getAuditTextForProperty( _property );	// gives text type of auditText sort of: myOperator^15^Operator - TIOP^
		fieldName := fieldName.extractValueFromAuditText();		// gives fieldName: Operator - TIOP
	else
		fieldName := _property.name;
	endif;
	
	foreach i in 1 to self.fieldsValues.size do
		self.getFieldValues( i, tmpFieldName, tmpOldValue, tmpNewValue );
	//	if fieldName = tmpFieldName then
		if fieldName = tmpFieldName or tmpFieldName = _property.name then	//10 Jan 2016	TFS 3189/2876
			_oldValue	:= tmpOldValue;
			_newValue := tmpNewValue;
			fieldFound := true;
			break;
		endif;
	endforeach;

	return fieldFound;

end;
</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_oldValue" type="String" usage="output"/>
        <Parameter name="_newValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFieldValuesForSystemSeals" id="1d57e78a-ca1e-41f2-9c44-f7e9d497ae9d">
        <source>getFieldValuesForSystemSeals(_at : Integer; _field, _oldValue, _newValue : String output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2010	cnwndl1	Initial creation	Par 25608 - data is in new structure.
												In preparation for when old
												field names are removed
												
							Cobbled version of getFieldValues
//2/10/2019		JLGNS1		ChangeRequest 45790: JMT - Refactor - Seal Transactions
*/

vars
	str : String;
	pos, pos2 : Integer;
begin

	if self.fieldsValues.size &lt; _at then
		return;
	endif;

// only interested in chenges to ti so no ti no changes
	if self.myTrackedItem = null then
		return;
	endif;
	// get the first full field 
	str := self.fieldsValues.at(_at);
	if str.length &gt; 80 then
		str := str[1:80];
	endif;
	pos2 := 1;
	// get field name which must be a property
	_field := str.cnGetToken(pos2, ' ').trimBlanks();
	
	if _field &lt;&gt; SealNum and
	   _field &lt;&gt; SealNumShippers and
	   _field &lt;&gt; SealNumCustoms and
	   _field &lt;&gt; AllCustomsSealNumbers and 		//ChangeRequest 45790
	   _field &lt;&gt; SealNumTerminalOperator and	//ChangeRequest 45790
	   _field &lt;&gt; SealNumUnknown and
	   _field &lt;&gt; SealNumVent then
		_field := null;
		return;
	endif;
	pos2 := _field.length()+1;
	pos := str.pos("=&gt;",1);
	// old value should be data after field name and before =&gt; may be null 
	if pos &gt; 2 then
		_oldValue := str[pos2:pos-pos2-1].trimBlanks;
		if (pos+2) &lt; str.length then
			// new data is every thing after the =&gt;
			_newValue := str[pos+2:str.length].trimBlanks;
		endif;
	else
		_newValue := str.cnGetToken(pos2, ' ');
	endif;
end;</source>
        <Parameter name="_at" type="Integer"/>
        <Parameter name="_field" type="String" usage="output"/>
        <Parameter name="_oldValue" type="String" usage="output"/>
        <Parameter name="_newValue" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFieldValuesString" id="0c77c816-f29e-4d87-9019-8d052f4267ad">
        <source>getFieldValuesString(): String;
/*
Purpose:	PAR 33412		
Date				Who			Reason
MAY 2014		CNWAB1		Initial creation
*/
vars
	lDetail : String;
begin

	if self.fieldsValues &lt;&gt; null then
		lDetail := self.fieldsValues.getAsEditPair();
	endif;
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldValuesVer01" id="c6bf6dfb-928e-460b-8796-b454d7c5ed29">
        <source>getFieldValuesVer01(_at : Integer; _field, _oldValue, _newValue : String output);
// to retrieve values prior to JMT733 
// format is field name in first element
// oldvalue =&gt; newvalue in second element
vars
	str : String;
	pos : Integer;
begin

	if self.fieldsValues.size &lt; _at+1 then
		return;
	endif;

	_field := self.fieldsValues.at(_at);
	
	str := self.fieldsValues.at(_at+1);
	if str.length &gt; 80 then
		str := str[1:80];
	endif;
	pos := str.pos("=&gt;",1);
	if pos &gt; 2 then
		_oldValue := str[1:pos-1].trimBlanks;
		if (pos+2) &lt; str.length then
			_newValue := str[pos+2:str.length].trimBlanks;
		endif;
	endif;
end;


</source>
        <Parameter name="_at" type="Integer"/>
        <Parameter name="_field" type="String" usage="output"/>
        <Parameter name="_oldValue" type="String" usage="output"/>
        <Parameter name="_newValue" type="String" usage="output"/>
    </JadeMethod>
