    <JadeMethod name="ndlx066" id="f13d6d59-249e-45b2-950b-1e6a2fcc6e10">
        <source>ndlx066();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	filter : CMQF_LocationActivity;
	term : CM_Terminal;

begin

	term := "2351.1051".asOid.CM_Terminal;

	create filter transient;
	filter.allTerminals.add( term );
	filter.setPropertyValue( "reportingMonth", 6 );
	filter.setPropertyValue( "startOfYearDate", "01 March 2021".Date );
	
	
	filter.populateFromLocActivities( false );
//	filter.inspectModal;

epilog

	delete filter;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx067" id="9b3316b3-d76d-499c-8e88-3a19972e069f">
        <source>ndlx067();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2021	navndl1	Initial creation	TFS 

*/

vars

	inFile : File;
	line : String;
	timeString : String;
	time : Time;
	startTime : Time;
	endTime : Time;
	
	outFile : File;

begin

	write "Started At " &amp; app.actualTimeServer.String;

	create inFile transient;
	inFile.fileName := "C:\Temp" &amp; '/cn_tranlog_20210616.csv';
	inFile.mode := File.Mode_Input;
	inFile.kind := File.Kind_Unknown_Text;
	
	create outFile transient;
	outFile.fileName := "C:\Temp" &amp; '/cn_tranlog_1355_1720.csv';
	outFile.mode := File.Mode_Output;
	
	
	startTime.setTime(13,55,00,0);
	endTime.setTime(17,20,59,0);
	
	if inFile.tryOpen and outFile.tryOpen then
		while not inFile.endOfFile() do
			line := inFile.readLine();
			if line.length &lt; 50 then
				continue;
			endif;
			timeString := line[10:6];
			if not timeString.isInteger then
				continue;
			endif;
			time.setTime( timeString[1:2].Integer, timeString[3:2].Integer, timeString[5:2].Integer, 0 );
			if time &lt; startTime then
				continue;
			endif;
			if time &gt; endTime then
				continue;
			endif;
			outFile.writeLine( line );
		endwhile; 
		
		inFile.close();
		outFile.close();
		
	else
		write "Failed to open " &amp; inFile.fileName;
		
	endif;
	
	write "Ended At " &amp; app.actualTimeServer.String;

epilog

	delete inFile;
	delete outFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx067A" id="6a602039-6ef9-4b6d-b35f-a2d3a4996e7c">
        <source>ndlx067A();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2021	navndl1	Initial creation	TFS 


Date	Time	Computer	Server	IP Address	App Name	User	Tran Id	Elapsed (msecs)	CPU (msecs)	DB Tran Id	Proc Id	Error?	GetObjs	LockObjs	Unlocks	Creates	Updates	Deletes	Commits	Events	Server Executions	Server Execution Time	LockQ Time	TC AppServer Msgs	TC AppServer Bytes	TC Client Msgs	TC Client Bytes	TC Net Time	Perceived Response	Level

*/

vars
	
/*	inFile : File;
	line : String;
	strArray : CnStringArray;
	
	tranLogObj : DEV_TranLogObj;
	dict : DEV_TranLogObjDateTimeTranId;
	timeString : String; */
	
	form : DEV_TranlogForm;

begin

/*	create inFile transient;
//	inFile.fileName := "C:\Temp/cn_tranlog_1554.csv";
	inFile.fileName := "C:\Temp/cn_tranlog_1433.csv";
	inFile.mode := File.Mode_Input;
	inFile.kind := File.Kind_Unknown_Text;
	
	create dict transient;
	
	if inFile.tryOpen then
		while not inFile.endOfFile() do
			line := inFile.readLine();
			if line.length &lt; 50 then
				continue;
			endif;
			timeString := line[10:6];
			if not timeString.isInteger then
				continue;
			endif;
			create tranLogObj transient;
			tranLogObj.populateFromTranlogLine( line );
			dict.add( tranLogObj );	
		endwhile; 
		inFile.close();
	else
		write "Failed to open " &amp; inFile.fileName;
	endif;
	
	foreach tranLogObj in dict do
		tranLogObj.writeLine();
	endforeach; */
	
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	create form transient;
	form.txtFileName.text := "C:\Temp/cn_tranlog_1433.csv";
	form.show();

epilog

/*	delete strArray;
	delete inFile;
	if not dict.isEmpty then
		dict.purge();
	endif;
	delete dict; */

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx068" id="6e43279a-b08b-4653-8994-24088454b5a9">
        <source>ndlx068();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2021	navndl1	Initial creation	TFS 51420

*/

vars

	lc : CM_LocationsController;
	objArray : ObjectArray;
	lcIter : Iterator;
	lcObj : Object;
	fmIter : Iterator;
	fm : CM_FutureMove;
	ti : CM_TrackedItem;
	offSitePlanned : CM_TISet;
	term : CM_Terminal;
	ta : CM_TerminalArea;
	count : Integer;

begin

	create offSitePlanned transient;
	create objArray transient;
	CM_YardController.allInstances( objArray, 0, true );
	
	lcIter := objArray.createIterator;
	while lcIter.next( lcObj ) do
		lc := lcObj.CM_LocationsController;
		fmIter := lc.allPlannedFutureMoves.createIterator;
		while fmIter.next( fm ) do
			ti := fm.getTrackedItem;
			if ti = null then
				continue;
			endif;
			
			if ti.hasBeenMerged or  ti.isOffSite then
				offSitePlanned.addNoDuplicates( ti, false );
			endif;
		endwhile;
		delete fmIter;
	endwhile;

offSitePlanned.inspectModal;
return;	
	foreach ti in offSitePlanned do
		app.myPassport.setMyTerminal( ti.myTerminal );
		beginTransaction;
		delete ti.allPlannedFutureMoves.first;
		commitTransaction;
	endforeach;

epilog

	delete lcIter;
	delete fmIter;
	delete objArray;
	delete offSitePlanned;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx068A" id="14f02197-b3f1-403b-b1a8-2e5ed2c67b51">
        <source>ndlx068A();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2021	navndl1	Initial creation	TFS 

*/

vars

	objArray : ObjectArray;
	fmObj : Object;
	fmIter : Iterator;
	fm : CM_FutureMoveQueued;
	toDelObjArray : ObjectArray;

begin

	create objArray transient;
	create toDelObjArray transient;
	CM_FutureMoveQueued.allInstances( objArray, 0, true );
	
	fmIter := objArray.createIterator;
	
	while fmIter.next( fmObj ) do
		fm := fmObj.CM_FutureMoveQueued;
		if fm = null then
			continue;
		endif;
		if fm.myWorkListEntry &lt;&gt; null then
			continue;
		endif;
		if not fm.allRTQueueEntries.isEmpty then
			continue;
		endif;
		if fm.myTrackedItem &lt;&gt; null then
			if fm.myTrackedItem.hasBeenMerged then
				toDelObjArray.addExclusive( fm );
			endif;
			continue;
		endif;	
		toDelObjArray.addExclusive( fm );
	endwhile;
	delete fmIter;
	
objArray.inspectModal();
toDelObjArray.inspectModal();

return;	
/*	foreach fmObj in toDelObjArray do
		beginTransaction;
		delete fmObj;
		commitTransaction;
	endforeach; */

epilog

	delete fmIter;
	delete objArray;
	delete toDelObjArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx069" id="325d5f76-e1ef-489f-a0be-3a84453c2026">
        <source>ndlx069();
/*

Purpose:			

Parameters:			

Return Value:		Trucks through the gate per day for a month.

Date		Who		Reason
05 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	term : CM_Terminal;
	startDate : Date;
	endDate : Date;
	iter : Iterator;
	startVvr : CM_VehicleVisitRecord;
	vvr : CM_VehicleVisitRecord;
	vvrIntArray : IntegerArray;
	startTS : TimeStamp;
	startTime : Time;
	dd : Integer;

begin

	startDate.setDate( 01, 06, 2021 );
	endDate.setDate( 30, 06, 2021 );	
	term := CM_Root.firstInstance.allTerminals.getAtKey( "UT" );
	
	create vvrIntArray transient;
	
	startTime.setTime( 0, 0, 0, 0 );
	startTS.setDate( startDate );
	startTS.setTime( startTime );
	
	iter := term.allVehicleVisits.createIterator;
	startVvr := term.allVehicleVisits.getAtKeyGeq( startTS );
	if startVvr &lt;&gt; null then
		iter.startAtObject( startVvr );
		while iter.next( vvr ) do
			if vvr.timeIn.date &gt; endDate then
				break;
			endif;
			dd := vvr.timeIn.date.day;
			if vvrIntArray.size &lt; dd then
				vvrIntArray[dd] := 1;
			else
				vvrIntArray[dd] := vvrIntArray[dd] + 1;
			endif;
		endwhile;
	endif;
	
	vvrIntArray.inspectModal;
	
	
	

epilog

	delete vvrIntArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx075" id="173e196c-fa4e-4783-bee5-39f8e0deebe9">
        <source>ndlx075();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2021	navndl1	Initial creation	TFS 51718

*/

vars

	infoSent : CM_InfoEDISent;
	count : Integer;

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	write app.actualTimeServer;
	
	beginTransaction;
	foreach infoSent in CM_InfoEDISent.instances do
		if infoSent.doXmlInfoDataTruncationForAAT() then
			count := count + 1;
		endif;
		if count &gt;= 10000 then
			break;
		endif;
	endforeach;
	commitTransaction;
	
	//10000, took 25 seconds, without actually updating. 29 seconds overwriting itself. In Dev
	//10000, in stand alone sys, updating new attribute took 1 min 52 seconds
	write app.actualTimeServer;
	
	

epilog

end;</source>
    </JadeMethod>
