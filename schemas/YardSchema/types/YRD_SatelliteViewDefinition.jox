    <JadeMethod name="userNotify" id="fd22b984-4de2-42fc-aaf9-6e766c00c1f7">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 January 2011	cnwer1	Initial creation

*/

vars
	userCode : String;
begin
	if userInfo &lt;&gt; null and userInfo.isKindOf(CM_User) then
		userCode := userInfo.CM_User.code;
	endif;
	if  eventType = self.myTerminal.getTerminalEvent(Event_TAView_Update) and not( self.isEditMode or self.isAddMode) then
	//	app.msgBox(app.getErrorString2(AnotherUserHas_Upd_YourDetails,userCode,"Satellite View Definition" ),app.getErrorString(Warning),MsgBox_OK_Only);
		self.doRefresh();
	elseif eventType = self.myTerminal.getTerminalEvent(Event_TAView_Delete) then
	//	app.msgBox(app.getErrorString2(AnotherUserHas_Del_YourDetails,userCode,"Satellite View Definition" ),app.getErrorString(Warning),MsgBox_OK_Only);
		self.setMyAreaView(null);
		self.doRefresh();
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
