    <JadeMethod name="getCurrentUserTerminal" id="d766307a-6e00-42a2-89d9-031ceff1682e">
        <source>getCurrentUserTerminal() : CM_UserTerminal;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal			: CM_Terminal;
	user				: CM_User;
