    <JadeMethod name="applyDeckingRulesToCellOrder" id="84b14789-360a-4894-9004-d6790e4124f1">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ta	: CM_TerminalArea;
begin
	inheritMethod();
	
/*	
	//IN custom
	if _cmifDeckingOptions.isCustomIn then
		self.myGridObject.allYALocationCellsIn.clear;
		_cmifDeckingOptions.allYALocnCellsInCustom.copy(self.myGridObject.allYALocationCellsIn);
	endif;
	//OUT custom
	if _cmifDeckingOptions.isCustomOut then
		self.myGridObject.allYALocationCellsOut.clear;
		_cmifDeckingOptions.allYALocnCellsOutCustom.copy(self.myGridObject.allYALocationCellsOut);
	endif;
*/	
	//do non-custom options	
	self.myGridObject.applyDeckingRulesToCellOrder();
	
	//fire note here
	ta := self.myGridObject.getGridArea; 
	ta.causeEvent(ta.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE),false,ta);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyRule" id="b97a5e9e-6089-4e63-bd2d-4921855b8c2c">
        <source>createPxyRule(_type, _from, _to: Integer; _isIn: Boolean; _collection: CM_MemberKeyDictionary input) protected;
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule	: CM_YADeckingRule;
begin
	create rule transient;
	rule.setProxyBasic(_type, _from, _to, _isIn);
	_collection.add(rule);
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_collection" type="CM_MemberKeyDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDeckingOptionsForDefault" id="69e1b41b-f36e-44de-b085-7a5d5e2c130b">
        <source>getDeckingOptionsForDefault(): CM_YADeckingOptions;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea		: CM_GridArea;
begin
	//return decking options for the area
	
	gridArea := self.getGridArea();
	if gridArea &lt;&gt; null 
	and gridArea.myYADeckingOptions &lt;&gt; null then
		return gridArea.myYADeckingOptions;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="getDefaultRuleIn" id="02189fbe-63af-408a-9baa-cc23b55cfe18">
        <source>getDefaultRuleIn(_height: Integer): Integer;
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
	rule		: CM_YADeckingRule;
begin
	
	gridArea := self.getGridArea;
	if gridArea &lt;&gt; null then
		rule := gridArea.myYADeckingOptions.allDeckingRulesIn.getAtKeyLeq(_height);
		if rule &lt;&gt; null then
			return rule.deckingRuleType;
		endif;
	endif;
	
	return Height_Then_Next_Row_Pos;
	
end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultRuleOut" id="b6a51fce-236a-4de8-8635-b8492ed79a59">
        <source>getDefaultRuleOut(_height: Integer): Integer;
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
	rule		: CM_YADeckingRule;
begin
	
	gridArea := self.getGridArea;
	if gridArea &lt;&gt; null then
		rule := gridArea.myYADeckingOptions.allDeckingRulesOut.getAtKeyGeq(_height);
		if rule &lt;&gt; null then
			return rule.deckingRuleType;
		endif;
	endif;
	
	return DeckingRule_ReverseOfOther;
	
end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="c0f1e7ba-e62c-4043-b1c0-76afc8e9368b">
        <source>getDisplayString(): String;
//----------------------------------------------------------------
//	Created:	09 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	
	return app.getErrorString(Row) &amp; " " &amp; self.myGridObject.label;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
