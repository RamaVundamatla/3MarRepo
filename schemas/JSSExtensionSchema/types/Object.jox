<Class name="Object">
    <JadeMethod name="jssGetPreviousMethods" id="35953cbd-b151-42e4-952c-7ed26778c51a">
        <source>jssGetPreviousMethods(pTheCallStack:ProcessStackArray io);
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Use this method for debugging to see where a method has been called
//				from.  The pProcessStack array will be populated with all method
//				calls prior to the one from which this method is called.
//
//				NOTE: The pTheProcessStack array will be populated with transient
//				MethodCallDesc objects, so they must be purged before deleting
//				the pTheProcessStack array object.
//
// Parameters:	pTheCallStack - An array of method call (MethodCallDesc) objects.
//
// Returns:		The populated pTheCallStack array.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Get the stack for the current process.

	process.currentStack(pTheCallStack);

	// Cut back the stack to the current method.

	delete pTheCallStack.removeAt(1);		// Remove the current method call.
	delete pTheCallStack.removeAt(1);		// Remove this method call (i.e. self).
end;</source>
        <Parameter name="pTheCallStack" type="ProcessStackArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetSortValue" id="4df9ca7e-cbdf-4d10-ac8e-3e931f871cfc">
        <source>jssGetSortValue():Any;
// --------------------------------------------------------------------------------
// Created:		11 February 2001 by cnwdad1
//
// Purpose:		Returns the value of a member of the JSSSorter's dynamic dictionary.
//				If this method is invoked from any kind of object other that a
//				JSSSortKey instance, a 1086 exception will be raised (Class of
//				object is invalid in this context).
//
//				Note that this is slightly slower than casting an Object to the
//				JSSSortKey class in your logic when iterating through the
//				JSSSorter.mySortColl (DynaDictionary).
//
// Parameters:	None
//
// Returns:		The value of the property corresponding to the type of sort that
//				was requested.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.JSSSortKey.getValue();
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="jssIniString" id="29c9df37-49a5-4ee0-8366-a8bca2f7f66a">
        <source>jssIniString(pSection:String; pItem:String):String; //  serverExecution;

vars
	iniValue		: String;
	errorMessage	: String;

begin
	iniValue	:=	app.getProfileString(global.cnGetServerIniFileName, pSection, pItem, '');

	if iniValue = null then
		errorMessage	:=	'Initialisation warning : ' &amp; '"' &amp; pSection &amp; ':' &amp; pItem &amp; '" not defined in ' &amp; global.cnGetServerIniFileName;
		jssLog(errorMessage);
		write errorMessage;
	endif;
epilog
	return iniValue;
end;</source>
        <Parameter name="pSection" type="String"/>
        <Parameter name="pItem" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssIsGUI" id="5b064dfe-b057-4980-ac05-12738f2fa802">
        <source>jssIsGUI(): Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI object.
//
// Parameters:	None
//
// Returns:		True if he receiver is a GUI object, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsPersistent" id="8bcb2940-8443-4b25-8858-9a59f54ca18a">
        <source>jssIsPersistent():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 September 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is NOT a
//				transient object.  This is the opposite to JADE's "isTransient".
//
// Parameters:	None
//
// Returns:		True if the reciever is persistent, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isTransient());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssLog" id="44232d7e-0604-4304-af3d-d29ce95aef30">
        <source>jssLog(pMessage:String);
// --------------------------------------------------------------------------------
// Created:		20 October 2000 by cnwdad1
//
// Purpose:		Write a message to the CardSchema log.
//
// Parameters:	pMessage - The message to be logged.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/02/2001	cnwdad1		Changed to use the CardSchema log method.
// --------------------------------------------------------------------------------
begin
	if app.myCnCntrl &lt;&gt; null then
		app.myCnCntrl.cnWriteLog(CnCntrl.CnLogComment, pMessage, null);
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssWritePreviousMethods" id="71ff8ee9-5eed-4880-ad4a-8d0ca4d83492">
        <source>jssWritePreviousMethods();
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Use this method for debugging to see where a method has been called
//				from.  The names of each method in the call stack will be written
//				to the JADE Interpreter Output Viewer window.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCallStack	: ProcessStackArray;
	theMethodCall	: MethodCallDesc;
	
begin
	create theCallStack transient;
	self.jssGetPreviousMethods(theCallStack);
	theCallStack.removeAt(1);			// Remove this method call (i.e. self).
	
	foreach theMethodCall in theCallStack do
		write theMethodCall.display();
	endforeach;
epilog
	theCallStack.purge();
	delete theCallStack;
end;</source>
    </JadeMethod>
</Class>
