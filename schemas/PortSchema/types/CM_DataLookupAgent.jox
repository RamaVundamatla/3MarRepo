    <JadeMethod name="resolveCargoType" id="8beee361-29a1-45d4-9eca-033e22b16ebf">
        <source>resolveCargoType(_property : String; _key: String): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36793 - Use Case - System Admin - Commodities Export/Import

*/

vars

begin
    if _key = null or _key = "" then
        return null;
    endif;
	if _property = CM_CargoType::description.name then
		return app.myRoot.allCargoTypesByDescription[_key];
	endif;
    
    return null;
epilog

end;</source>
