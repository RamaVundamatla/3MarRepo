end;
</source>
        <Parameter name="_tasg" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_ild" type="CM_InvoiceLineDesc"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
        <ReturnType type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="addFutureStorageMapping2" id="3523853c-ec73-4488-8a13-4fd01d037876">
        <source>addFutureStorageMapping2(_bank : CM_Bank; _storageGroup : CM_TerminalAreaStorageGroup; _storageDetail : CM_StorageDetail; _calcType : CM_CalculationType; _currentQRM : CM_QuantityRangeMap;
						 _mapType : Integer; _groupType : Integer; _chargeZero : Boolean; _rangeFrom : Integer; _rangeTo : Integer; _invLineDescs : CM_InvoiceLineDescArray input) : CM_FutureStorageMapping;

// recoded after 36257/37434, a copy of CMUI_InvoiceFutureStorageMaps::do Save
vars
	count	: Integer;
	updateMode	: Boolean;
	isVoid	: Boolean;
	ild		: CM_InvoiceLineDesc;
	qm, pxyQM, realqm : CM_QuantityMap;
	qrm,
	pxyQRM : CM_QuantityRangeMap;
	theReturn, mapType : Integer;
	map,
	fsm	: CM_FutureStorageMapping;
	gt : CM_TranMapInvoiceLineGroupType;

begin
	if _currentQRM &lt;&gt; null then
		qm := _currentQRM.myQuantityMap;
		fsm := qm.myFutureStorageMap;
		updateMode := true;
	endif;
	
	if fsm = null then
		foreach map in _storageGroup.allFutureStorageMappings do
			if map.myStorageDetail = _storageDetail then		
				fsm := map;
				break;
			endif;
		endforeach;
		if fsm = null then
			foreach map in _storageGroup.allFutureStorageMappings do
				if map.myStorageDetail = null then		// the default one created with a new storage group
					fsm := map;
					break;
				endif;
			endforeach;
		endif;
		if fsm &lt;&gt; null then
			qm := fsm.myQuantityMap;
		endif;
	endif;
	
	if updateMode then
		beginLoad;
		pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
		if _currentQRM &lt;&gt; null then
			pxyQRM := _currentQRM.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endif;
		endLoad;
	else
		if qm &lt;&gt; null then
			beginLoad;
			pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
			endLoad;
		else
			create pxyQM transient;
			pxyQM.setMyCalculationType(_calcType);
		endif;
		// if the default mapping is found with a 0-max VOID range map, use this as the current quantity map and overwrite the details
		//   to avoid creating a second quantity map with the same range and getting a duplicate key exception
		if fsm &lt;&gt; null and
		   fsm.myStorageDetail = null then
			foreach qrm in fsm.myQuantityMap.allQuantityRanges do
				count := count + 1;
			endforeach;
			if count = 1 and
			   qrm.rangeStart = 0 and
			   qrm.rangeEnd = CM_QuantityRangeMap.MAX_RANGE then
				beginLoad;
				pxyQRM := qrm.pxyCreateUpdateProxy();
				endLoad;
				updateMode := true;
			endif;
		endif;
		if pxyQRM = null then
			create pxyQRM transient;
		endif;
		if fsm = null then
			create fsm transient;
			fsm.setProxy(_storageGroup, null, _storageDetail, null);
		endif;
	endif;
	if pxyQRM = null then
		create pxyQRM transient;
	endif;
	
	mapType := _mapType;
	gt := _bank.getInvLineGroupByType(_groupType);
	
	if fsm.isTransient then
		pxyQM.setProxy(null, _chargeZero, mapType, _calcType, null);
	else
		pxyQM.setProxy(null, _chargeZero, mapType, _calcType, fsm);
	endif;
	if qm &lt;&gt; null then
		pxyQRM.setProxy(qm, _rangeFrom, _rangeTo, 0);
	else
		pxyQRM.setProxy(pxyQM, _rangeFrom, _rangeTo, 0);
	endif;
	pxyQRM.setProxyInvoiceLineTypesFS(_invLineDescs, gt);
	
	map := app.myTrxUA.trxUpdateInvoiceFutureStorage(updateMode, pxyQM,realqm, pxyQRM, fsm, _storageDetail); // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1 - realqm

	return map;
	

epilog
	if global.isValidObject(pxyQRM) then
		delete pxyQRM;
	endif;
	if global.isValidObject(pxyQM) then
		delete pxyQM;
	endif;
	if fsm.isTransient then
		delete fsm;
	endif;
end;
</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_storageGroup" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <Parameter name="_currentQRM" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapType" type="Integer"/>
        <Parameter name="_groupType" type="Integer"/>
        <Parameter name="_chargeZero" type="Boolean"/>
        <Parameter name="_rangeFrom" type="Integer"/>
        <Parameter name="_rangeTo" type="Integer"/>
        <Parameter name="_invLineDescs" type="CM_InvoiceLineDescArray" usage="input"/>
        <ReturnType type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="addGCHoldDefn" id="b765f4ce-c44a-4f25-99ab-7d9c66fb1214">
        <source>addGCHoldDefn(	_gcVesselStruct: CM_GeneralCargoVesselStructure;
				_holdNum: Integer;
				_placeNum: Integer;
				_isOnDeck : Boolean;							// PAR #36766
				_maxWeight : Integer;							// PAR #36766
				_maxVolume: Decimal;
				_maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
				_onShipCrane: Integer;
				_locName: String
				):CM_GCHoldLocationDefn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
*/

vars
	
	proxy : CM_GCHoldLocationDefn;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;

begin

	create proxy transient;
	proxy.setProxy(	_holdNum,	//_hatch : Integer;
					_locName,	//_name : String;
					_placeNum,	//_place : Integer;
					_isOnDeck,	//_isOnDeck : Boolean;			// PAR #36766
					_maxWeight,	//_maxWeight : Integer;			// PAR #36766
					_maxVolume,	//_maxVolume: Decimal;
					_maxHeight,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
					_onShipCrane,// onShipCrane : Integer
					_gcVesselStruct	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
					);
	
	app.myPassport.setWarningsIgnored(true);					// 11/09/2015 cnwmh5	
	
	app.myTrxCA.trxCreateGCHoldLocnDefn(proxy, gcHoldLocnDefn, app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "GC Hold Defn not created : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	
	return gcHoldLocnDefn;
	
epilog

	app.myPassport.setWarningsIgnored(false);					// 11/09/2015 cnwmh5

	delete proxy;

end;</source>
        <Parameter name="_gcVesselStruct" type="CM_GeneralCargoVesselStructure"/>
