    <JadeMethod name="getSnapShotDateTimeLocalTZ" id="cbf37372-3875-4aa8-9e26-a3bf7a35c04c">
        <source>getSnapShotDateTimeLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.snapShotDateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
