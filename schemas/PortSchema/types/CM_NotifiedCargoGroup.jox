    <JadeMethod name="preAssignedCargoIdsInclude" id="619d8c93-337b-44ec-887a-7dd3e379ac7b">
        <source>preAssignedCargoIdsInclude( _str : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	obj : Object;

begin

	obj := self.allPreAssignedCargoIdsDict.getAtKey( _str );
	
	return obj &lt;&gt; null;

epilog

end;</source>
