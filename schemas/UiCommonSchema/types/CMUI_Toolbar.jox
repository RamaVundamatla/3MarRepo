    <JadeMethod name="positionLeftControls" id="a3dac080-3db7-492b-9c30-fe32b92a7dca">
        <source>positionLeftControls(_rightMargin : Real) : Real protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	control,
	lastControl	: CMUI_ToolbarControl;
	leftOffset,
	nextEndPos,
	tmpWidth	: Real;
	moreToShow	: Boolean;
	tbCount : Integer;
begin
	
	leftOffset := ControlGap;
	if self.myMoreToShowButton &lt;&gt; null then
		self.myMoreToShowButton.visible := false;
	endif;
	lastControl := self.allLeftControls.last;
	tbCount:=1;
	foreach control in self.allLeftControls do
		if (not control.getVisibleStatus) then
			continue;
		endif;
		if moreToShow then
			//control.visible := false;
			control.hideForMoreToShow();
			if control.isAvailableForMoreToShow then
				self.allMoreToShowControls.add(control);
			endif;
			continue;
		endif;
		tmpWidth := control.getWidth(self.showCaptions);
		
		if control = lastControl then
			nextEndPos := leftOffset + tmpWidth;
		else
			nextEndPos := leftOffset + tmpWidth + ControlGap + MoreToShowWidth;
		endif;

		if nextEndPos &gt; _rightMargin then
			moreToShow := true;
			//control.visible := false;
			control.hideForMoreToShow();
			if control.isAvailableForMoreToShow then
				self.allMoreToShowControls.add(control);
			endif;
			continue;
		endif;
		if tbCount = 1 then
			leftOffset:=leftOffset + self.horizontalOffsetLeft;
		endif;
		control.left := leftOffset;
		control.visible := true;
		leftOffset := leftOffset + control.getWidth(self.showCaptions) + ControlGap;
		tbCount:=tbCount+1;
	endforeach;

	if (not self.allMoreToShowControls.isEmpty) then
		self.showMoreToShowButton(_rightMargin);
	endif;

	return leftOffset;

end;</source>
        <access>protected</access>
        <Parameter name="_rightMargin" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="positionRightControls" id="eb09564a-c0da-40a5-b612-1d9334a58c05">
        <source>positionRightControls() : Real protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	control		: CMUI_ToolbarControl;
	rightOffset	: Real;

begin
	
	rightOffset := self.clientWidth;
	
	foreach control in self.allRightControls reversed do
		rightOffset := rightOffset - control.getWidth(self.showCaptions) - ControlGap;
		control.left := rightOffset;
	endforeach;
	
	return rightOffset;

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
