    <JadeMethod name="validateCargoMatchForMultiMove" id="9c9056d7-f40e-4ec7-a9cd-ae38791885c2">
        <source>validateCargoMatchForMultiMove( _ti : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2011	cnwndl1	Initial creation	Par 28035

*/

vars
	
begin

	
	// reimplemented on Grid Controller...
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForArchive" id="bbefb8d4-b453-4486-b83d-b8276e490529">
        <source>validateForArchive(_emptySince : TimeStamp);
// ---------------------------------------------------------------------------
// Created:     10 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Jan 2017	cnwrs1	TFS 3209 Par 38563 dont error planning bols that have been satisfied
// ---------------------------------------------------------------------------
vars
	bol : CM_BOL;
	str : String;
	found : Boolean;
begin
	// ensure we have lastest copy
	sharedLock(self);

	if self.status = LC_Status_Archived then
		// row is already archived
		return;
	endif;

	if self.numTIs &lt;&gt; 0 then
		app.raiseCMException1(ArchivedRowCannotHaveTIs, self.getFullId, ETRow_Status, null);
	endif;
	
	if not self.allPlannedBOLs.isEmpty then
		found := false;
		foreach bol in self.allPlannedBOLs do
			if bol.numItems = bol.numTIs then
				found := false;
			else
				str := str &amp; bol.number.String&amp;', ';
				found := true;
			endif;
		endforeach;
		if found = true then
			app.raiseCMException2(ArchivedRowCanNoPlannedDockets, self.getFullId, str, ETRow_Status, null);
		endif;
	endif;

	if _emptySince.isValid and
	   self.lastMoveOutDateTime.isValid and
	   self.lastMoveOutDateTime &gt; _emptySince then
		app.raiseCMException1(ArchivedRowNotEmptySinceTime, self.getFullId, ETRow_Status, null);
	endif;

end;</source>
        <Parameter name="_emptySince" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b45c98e7-a2d7-43f8-83c9-142d99098239">
        <source>validateForCreate(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.validate(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0e3b1c1a-57ce-4d55-a17a-9dffd2c4b492">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//11/04/2019 	JLGNS1	Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
// ---------------------------------------------------------------------------
vars

	queue : CM_RadioTelemetryQueue;
	entry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	
begin

	if self.numTIs &gt; 0 then
		//app.raiseCMException2(ObjectStillHasEntries, self.getID, "Tracked Items", null, null);
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "Tracked Items", null, null);			// cnwjk3 ccms 1018 11/02/10
	endif;

	if self.numPlannedTIs &gt; 0 then
		//app.raiseCMException2(ObjectStillHasEntries, self.getID, "Planned Tracked Items", null, null);
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "Planned Tracked Items", null, null);	// cnwjk3 ccms 1018 11/02/10
	endif;

	if self.numQueuedTIs &gt; 0 then
		//app.raiseCMException2(ObjectStillHasEntries, self.getID, "Queued Tracked Items", null, null);
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "Queued Tracked Items", null, null);		// cnwjk3 ccms 1018 11/02/10
	endif;

	if self.allProductLocations.size &gt; 0 then
		//app.raiseCMException2(ObjectStillHasEntries, self.getID, "Stock-on-Hand Detail", null, null);
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "Stock-on-Hand Detail", null, null);		// cnwjk3 ccms 1018 11/02/10
	endif;
	
	// Par 8830.
	if not self.allPlannedBOLs.isEmpty then
		//app.raiseCMException2(ObjectStillHasEntries, self.getID, "Planned Dockets" ,null, null);
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "Planned Dockets" ,null, null);			// cnwjk3 ccms 1018 11/02/10
	endif;
	
	if self.allWodCargoRequests.isNotEmpty then																										//Bug 44243
		app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), self.allWodCargoRequests.size.String, app.getErrorString(Work_order), null);	//Bug 44243
	endif;																																			//Bug 44243
	
	//08 Jan 2020 NDL 	TFS 48204 - locations on task are not inversed, need to protect the user from deleting locations that are in use by director tasks not yet associated with tis.
	if self.myTerminal &lt;&gt; null and self.myTerminal.radioTelemetry &lt;&gt; null and self.myTerminal.radioTelemetry.masterQueue &lt;&gt; null then
		foreach queue in self.myTerminal.radioTelemetry.masterQueue.allSubQueuesById discreteLock do
			foreach entry in queue.allEntries discreteLock do
				foreach task in entry.allTasks discreteLock do
					if task.sourceLocation = self or task.targetLocation = self then
						app.raiseCMException2(ObjectStillHasEntries, self.getFullId(), "RT Queue Task Entries", null, null);
						return;
					endif;
				endforeach;
			endforeach;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForEmpty" id="a755f1a3-f808-420c-b756-e45f4a17449c">
        <source>validateForEmpty();
//-----------------------------------------------------------------------
//	Created:	29 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin
	
	//status is about to be changed to empty - 
	if self.status &lt;&gt; LC_Status_PhysicallyEmpty 
	and self.totalQuantity &gt; 0 then
		//warn if has items
		app.raiseCMWarning2(WARN_STATUS_CHECK,app.getErrorString(Empty), app.getErrorString(AreaHasItems), null, null, self);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b9926dfb-cce0-46ee-b847-207b55d5afa9">
        <source>validateForUpdate(_realController : CM_LocationsController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.validate(_passport);
	
	if self.status = LC_Status_Archived then
		_realController.validateForArchive(null);
	endif;

	if self.status = LC_Status_PhysicallyEmpty then
		_realController.validateForEmpty();
	endif;
	
end;</source>
        <Parameter name="_realController" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="9acc4dbf-5ffe-4681-b767-48889a10284c">
        <source>validateMoveFrom(control : CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			13 Sept 2001 by cnwdwq1
Purpose:			Superclass method for validating a move.
Parameters:			None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
25/05/2010		cnwdap1			CCMS 1116 Tranship changes - tranships are now just one TI, not two
									No need to worry about ignoring import side
---------------------------------------------------------------------------
*/
vars
	tmpParentID : String;
	tmpTI : CM_TrackedItem;
	ignore : Boolean;
begin

	if control.isPostMoveCleanup or control.isUndoMove then
		//---------------------
		//We are doing a cleanup or an unplan. No "from" validation is required
		//---------------------
		return;
	endif;
	if control.isForcedMove then
		return;
	endif;
	
	tmpTI := control.myTrackedItem;
	
	if control.myToPrimaryLocation &lt;&gt; null
	and tmpTI.isSOB 
	and not control.myToPrimaryLocation.isVoyageController() then
		app.raiseCMException1(DragDrop_SOB_ship_to_yard,tmpTI.id,null, null);
		return;
	endif;

	
	// from loc must have the TI
	if (not self.includesTI(tmpTI, REAL_MODE)) then
		// ### PAR 13150
		ignore := (control.myToPrimaryLocation &lt;&gt; null 
				and control.myToPrimaryLocation.isLogicalDeleteArea());	// PAR #23645 CCMS 1116
				//and control.myTrackedItem.isTranshipImport());		// PAR #23645 CCMS 1116
				
		// PAR 17703
		if not ignore then
			ignore := tmpTI.isGeneratorAttachedToParent();
		endif;
		if not ignore then
			if tmpTI.isChild() then
				//Tell user to move the parent
				if control.myUnpackFromTI = null then //we are doing a unpack its ok
					tmpParentID := tmpTI.getParent().id;
				//	if control.moveMode &lt;&gt; PLANNING_MODE then	//14 July 2014	NDL Par 34559
					if control.moveMode &lt;&gt; PLANNING_MODE and control.moveMode &lt;&gt; QUEUE_MODE then	//30 July 2014	NDL Par 34665
						app.raiseCMException3(ERR_Move_Parent_TI, tmpTI.id, tmpParentID, tmpParentID, null, null);
					endif;
				endif;
			else
				app.raiseCMException1(ERR_TI_NOTIN_COLL, self.getID &amp; " (" &amp; tmpTI.id &amp; ") ", null, null);
			endif;
			return;
		endif;
	endif;

	if control.allOtherTrackedItems.includes(tmpTI) then
		// the below validation has already been done for the original TI
		return;
	endif;	
	
	// if planinning dont need to worry about labour restrictions (only on queue or real move)
	if control.moveMode &lt;&gt; PLANNING_MODE then  
		//------------------
		//Validate for Labour Restriction in the area we are moving FROM
		//------------------
		self.validateMoveLabourRestriction(control);
	endif; 

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveHazardRestriction" id="03eaa77e-27ee-427c-a2af-61795ef85803">
        <source>validateMoveHazardRestriction(_control : CMIF_MoveController);
//
// Purpose:			Check for Hazard restrictions - re-implement in sub-classes as required
//							(currently only inplmented in CM_YardController)
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	// RE-IMPLEMENTED AT CM_YardController LEVEL
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="ff4493e1-977e-4ec6-925a-64fb17e5272e">
        <source>validateMoveLabourRestriction(control: CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			31 July 2001 by cnwdwq1
Purpose:			Implemented in sub-classes where needed
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
