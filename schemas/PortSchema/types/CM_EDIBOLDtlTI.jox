    <JadeMethod name="processAttributeDependencies" id="5c0b1b57-8ed2-43d3-8215-47170370eada">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars

begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then
		_ediUserDefinedAssist.myCurrentBOLDetail := null;
	else
		if self.id = null then
			self.setId(_ediUserDefinedAssist.currentBOLCode);
		endif;
		
	//	if _ediUserDefinedAssist.myCurrentBOLHeader.allDetails[self.id] &lt;&gt; null then
	//		write "Got a duplicate=" &amp; self.id;
	//	endif;
		
		self.myHeader	:=	_ediUserDefinedAssist.myCurrentBOLHeader;	// cnwdad1 01/07/2010 - PAR #24177.
		_ediUserDefinedAssist.myCurrentBOLDetail := self;
	endif;
end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b28b79b8-6c7b-4e56-a8fc-7b71f29d280c">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
		// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="5e36a31f-b015-4a0b-8b16-8e070b1b665f">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyCargoType" id="eeed21bf-3bb9-49f8-85f3-3c81587fce7c">
        <updating/>
        <source>verifyCargoType() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.	
----------   ----------  --------------------------------------------------
*/
vars
	cargoTypeDict		: CM_CargoTypesByIdDict;
	loopCargoType		: CM_CargoType;
	cargoTypeObj		: CM_CargoType;
	cargoTypeDescStr	: String;
begin
	if self.cargoType = null and self.cargoTypeDescr = null then
		return;
	endif;
	
	cargoTypeDict	:=	app.myRoot.allCargoTypesById;
	
	if self.cargoTypeDescr.toUpper().cnContains('CONTAINER') then//special case - phuzzy lojic
		cargoTypeObj	:=	cargoTypeDict[TI_CargoType_Container];
	else	
		cargoTypeObj	:=	cargoTypeDict[self.cargoType];
		
		if cargoTypeObj = null then
			
			cargoTypeDescStr := self.cargoTypeDescr.toUpper();				//03.03.2022 navma1 #52499
			
			foreach loopCargoType in cargoTypeDict do
				if loopCargoType.description.toUpper()  = cargoTypeDescStr  //03.03.2022 navma1 #52499
				or loopCargoType.abbreviation.toUpper() = cargoTypeDescStr  //03.03.2022 navma1 #52499
				then
					self.cargoType		:=	loopCargoType.type;
					self.cargoTypeDescr	:=	loopCargoType.description;
					cargoTypeObj		:=	loopCargoType;
					break;
				endif;
			endforeach;
		else
			self.cargoTypeDescr	:=	cargoTypeObj.description;	//keep them in synch
		endif;
	endif;
	
	if cargoTypeObj = null then
		app.raiseCMException2(ERR_CARGO_FIELD, self.cargoTypeDescr, 'cargo type description', ETRow_CargoTypeDescr, self);
	elseif cargoTypeObj.isNotAvailableForEntry then	//PAR 21733
		app.raiseCMException1(Cargo_type_marked_not_availabl, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
	else
		self.cargoType		:=	cargoTypeObj.type;
		self.cargoTypeDescr	:=	cargoTypeObj.description;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyColour" id="adf27ee5-dccd-4e3b-8777-f908bbef5130">
        <source>verifyColour() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/08/2013	cnwdap1		Initial creation PAR #32123 Check colour is one of the system-defined values
// 27/08/2013	cnwdap1		PAR #32326 Allow for more than one colour being supplied e.g. "BLUE RED"
//
vars
	colours 	: StringArray;																	// PAR #32326
	str 		: String;																		// PAR #32326

begin
	if self.getMyTerminal.getConfig(ValidateColour).Boolean then
		//if self.colour &lt;&gt; null and app.myDutyDocRoot.allVehicleColours[colour] = null then	// PAR #32326
		//	app.raiseCMException1(ERR_INVALID_COLOURCODE, self.colour, "colour", null);			// PAR #32326
		if self.colour &lt;&gt; null then																// PAR #32326
			colours := self.colour.getTokens;													// PAR #32326
			foreach str in colours do															// PAR #32326
				if app.myDutyDocRoot.allVehicleColours[str] = null then							// PAR #32326
					app.raiseCMException1(ERR_INVALID_COLOURCODE, str, "colour", null);			// PAR #32326
				endif;																			// PAR #32326
			endforeach;																			// PAR #32326
		endif;
	endif;
epilog
	delete colours;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCommodity" id="e245c706-a5be-43bd-ba5e-cae3a16b070b">
        <updating/>
        <source>verifyCommodity() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	commodityObj	: CM_Commodity;
	
begin
	if self.commodity = null then
		self.validateCommodityPlus( null );	//02 Mar 2021	NDL	TFS 50740
		return;
	endif;
	
	commodityObj	:=	app.myRoot.allCommodities[self.commodity];

	if commodityObj = null then
		app.raiseCMException2(ERR_FIELD_COMMODITY, self.commodity, ETRow_Commodity, ETRow_Commodity, self); //cnwgb1 PAR 23229 18.3.2010
	else	//02 Mar 2021	NDL	TFS 50740
		self.validateCommodityPlus( commodityObj );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyConsignee" id="6e870cf4-0961-4824-93df-e5fe95daeac2">
        <updating/>
        <source>verifyConsignee() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopConsign,
	consign			: CM_ConsigneeConsignor;
	consignDict		: CM_ConsignByCodeDict;
	consigneeStr	: String;
begin
	if self.consignee = null then
		return;
	endif;
	
	consignDict		:=	app.myRoot.allConsigneeConsignors;
	consign			:=	consignDict[self.consignee];
	
	if consign = null then
		
		consigneeStr	:=  self.consignee.toUpper();								 //03.03.2022 navma1 #52499
		
		foreach loopConsign in consignDict do
			if loopConsign.description.toUpper().cnContains(consigneeStr) then	     //03.03.2022 navma1 #52499  
				self.consignee := loopConsign.code;
				consign := loopConsign;
				break;
			endif;
		endforeach;
	endif;
	
	if consign = null then
		app.raiseCMWarning2(ERR_FIELD_CONSIGNEE, self.consignee, 'consignee', ETRow_Consignee, self, self);
	else	//07 Sep 2021	NDL	TFS 51928
		self.verifyObjectAvailableForEntry( consign );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyConsignor" id="2f64a663-332a-4a88-b829-bd5b0df931ee">
        <updating/>
        <source>verifyConsignor() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopConsign,
	consign			: CM_ConsigneeConsignor;
	consignDict		: CM_ConsignByCodeDict;
	consignorStr	: String;
begin
	if self.consignor = null then
		return;
	endif;
	
	consignDict		:=	app.myRoot.allConsigneeConsignors;
	consign			:=	consignDict[self.consignor];
	
	if consign = null then
		
		consignorStr	:= self.consignor.toUpper;								   //03.03.2022 navma1 #52499
		
		foreach loopConsign in consignDict do
			if loopConsign.description.toUpper().cnContains(consignorStr) then    //03.03.2022 navma1 #52499
				self.consignor := loopConsign.code;
				consign := loopConsign;
				break;
			endif;
		endforeach;
	endif;
	
	if consign = null then
		app.raiseCMWarning2(ERR_FIELD_CONSIGNOR, self.consignor, 'consignor', ETRow_Consignor, self, self);
	else	//07 Sep 2021	NDL	TFS 51928
		self.verifyObjectAvailableForEntry( consign );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="f4e5d0a3-9c19-40fa-b945-a21bb6c8bb1e">
        <updating/>
        <source>verifySelf() updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
14/08/2013	cnwdap1		PAR #32123 Colour validation in EDI
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	terminalObj			: CM_Terminal;
	voyageObj			: CM_Voyage;
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
begin
	terminalObj := self.getMyTerminal();
	
	if terminalObj = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if id.trimBlanks() = null then
		app.raiseCMException2(ERR_FIELD_ID,id, 'ID', ETRow_Id, self);
	endif;
	if CM_EDIDataCargo.hasInstance(self.myEDIData) then
		site := self.myEDIData.CM_EDIDataCargo.createToSite;
	endif;
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState()) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;
	
	self.verifyCargoType();
	self.verifyCommodity();
	self.verifyConsignee();
	self.verifyConsignor();
	self.verifyVolume();
	self.verifyColour();						// PAR #32123
	
	if trxStateEntered then
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyVolume" id="06721558-d4e8-4a9c-a8c5-460297824af2">
        <updating/>
        <source>verifyVolume() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	calcVolume	: Decimal[22,4];
	
begin
	if self.length = null or self.height = null or self.width = null then
		return;
	endif;
	
	calcVolume := ((self.height/100) * (self.width/100) * (self.length/100));
	
	if self.volume &lt;&gt; null and calcVolume &lt;&gt; null and self.volume &lt;&gt; calcVolume then
		app.raiseCMWarning2(ERR_FIELD_VOLUME, self.volume.String, ' calculated volume differs from field value ', ETRow_Volume, self, self);
	elseif self.volume = null and calcVolume &lt;&gt; null then
		self.volume := calcVolume;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
