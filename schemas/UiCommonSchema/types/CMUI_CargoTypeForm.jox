    <JadeMethod name="displayAttributes" id="66b32dc3-a304-45e8-82d6-ab10ad190ed1">
        <source>displayAttributes(_systemProdType : CM_Product; _productType : Integer) protected;
/* ---------------------------------------------------------------------------
Created:	26 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
19/06/2013		cnwdap1		PAR #31754 Default measurement type for proxy product attributes
05/07/2013		cnwdap1		PAR #31954 Don't default measurement type if proxy already has one!!
16/02/2018 		 cnwer1	TFs 7766 tidied up the attributes for bulk and car for web portal 
------------------------------------------------------------------------------*/
vars
	prodAttr		: CM_ProductAttr;
	entRowName		: String;
	allEntRowsForAttributes	: StringArray;
	restrictBulkAttributes	: Boolean;
begin
	
	if _systemProdType = null then	
		return;
	endif;

	self.tblAttributes.rows := self.tblAttributes.fixedRows;
	
	create allEntRowsForAttributes transient;
	self.getAllAttribForSystemProdType(allEntRowsForAttributes);
	
	foreach entRowName in allEntRowsForAttributes do
			
		if _productType = ProductType_Bulk then
			if  (entRowName = ETRow_MyType or entRowName =ETRow_MyLengthString or entRowName = ETRow_MyWidthString or entRowName = ETRow_MyHeightString )   then
				continue;
			endif;
		elseif _productType = ProductType_Vehicle  then
			if entRowName &lt;&gt; ETRow_MyLength and  entRowName &lt;&gt; ETRow_MyWidth and entRowName &lt;&gt; ETRow_MyHeight then
				continue;
			endif;
		endif;
 
		prodAttr := _systemProdType.getProdAttrFromName(entRowName);
		// PAR #31754 set measurement type as necessary on proxy attribute
		// otherwise attribute will have no measurement type, and this causes problems when saving them
		//if prodAttr.isTransient then													// PAR #31954
		if prodAttr.isTransient and prodAttr.myMeasurementType = null then				// PAR #31954
			if prodAttr.name = ETRow_MyHeight then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Height));
			elseif prodAttr.name = ETRow_MyLength then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Length));
			elseif prodAttr.name = ETRow_MyWidth then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Width));
			elseif prodAttr.name = ETRow_MyVolume then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Volume));
			elseif prodAttr.name = ETRow_MyWeight then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Weight));
			elseif prodAttr.name = ETRow_MyDensity then
				prodAttr.CM_ProdAttrDecimal.setMyMeasurementType(app.getDefaultMeasurementForType(Type_Density)); // ### TFS 52193 22Nov2021 NAVPW1
			endif;
		endif;
		// PAR #31754 end
		self.addTblAttributeRow(prodAttr);
	endforeach;
epilog
	delete allEntRowsForAttributes;

end;</source>
        <access>protected</access>
        <Parameter name="_systemProdType" type="CM_Product"/>
        <Parameter name="_productType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayDamageDefinitionCode" id="ac3c9259-bb36-4c70-ab3f-c20ddd63111b">
