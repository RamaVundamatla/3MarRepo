Return Value:		


Date		Who		Reason
11 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	allBehaviourTypes : ObjectArray;
	  obj : Object;
begin
	create allBehaviourTypes transient;
	CM_TIBehaviourType.allInstances(allBehaviourTypes,null,true);
	
	foreach obj in allBehaviourTypes do
		beginTransaction;
		if obj.CM_TIBehaviourType.myGraphic &lt;&gt; null then
			obj.CM_TIBehaviourType.myGraphic.allCommands.purge;
		endif;
		obj.CM_TIBehaviourType.createDefaultGraphic();
		commitTransaction;
	endforeach;
	
epilog
	delete allBehaviourTypes;
end;	</source>
