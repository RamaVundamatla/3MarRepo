    </PrimAttribute>
    <JadeMethod name="controlNamePrefix" id="2a0ab819-85c5-4a1a-9cb4-2fca73992d25">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		18 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "chk";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="1de8407f-26a3-42de-8a34-f5a0cd6e9be9">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="37455b0b-4777-4380-98b0-e06ca92dd58f">
        <updating/>
        <source>gotFocus(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(checkbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="76975dc3-6d2a-4d5f-9e9a-225424d2402c">
        <updating/>
        <source>lostFocus(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(checkbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="2ab2e9ad-3fce-4329-a4ce-d3a9d89036c0">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
			
		if self.alignment = CheckBox.Alignment_Left	 then
			self.drawSolidRectangle(2, 4, 6, 8, Red);
		elseif self.alignment = CheckBox.Alignment_Right then
			self.drawSolidRectangle(self.clientWidth()-6, 4, self.clientWidth()-2, 8, Red);
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
