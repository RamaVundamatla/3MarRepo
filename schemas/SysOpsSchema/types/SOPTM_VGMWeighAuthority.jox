    <JadeMethod name="includeObject" id="b9b1a671-f925-470a-8eec-8620858c1a7e">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_WeighAuthority.notAvailableForUse;
	endif;

epilog

end;</source>
