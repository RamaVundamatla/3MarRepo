    <JadeMethod name="zReceiveAOneStopXMLPrenote" id="79557ee2-3b83-408f-8897-0c709b12a870">
        <source>zReceiveAOneStopXMLPrenote( _index : Integer; tiId : String output; _voyageCode : String ) : CM_EDIFile;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2016	cnwndl1	Initial creation

*/

constants

	TiId1 : String = "GENL7654321";
	
vars

	term : CM_Terminal;
	oper : CM_Operator;
	ediData : String;
	ediFile	: CM_EDIFile;

begin

	term := self.getTerminal;
	oper :=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());

	if _index = 1 then
	
		tiId := TiId1;
	
		ediData := 
'&lt;?xml version="1.0"?&gt;
&lt;ContainerMessage&gt; 
&lt;MessageHeader&gt; 
&lt;LocalDateTimeSent&gt;20141011145306&lt;/LocalDateTimeSent&gt; 
&lt;TransactionDateTime&gt;20141011145306&lt;/TransactionDateTime&gt; 
&lt;EventType&gt;CONTAINERPREADVICE&lt;/EventType&gt; 
&lt;PlaceOfEvent&gt;NPENZ&lt;/PlaceOfEvent&gt; 
&lt;DocumentReferenceNumber&gt;NZPN141014&lt;/DocumentReferenceNumber&gt; 
&lt;SenderID&gt;FLDBO&lt;/SenderID&gt; 
&lt;SenderType&gt;E&lt;/SenderType&gt; 
&lt;SenderEmail&gt;TEST@TEST.COM&lt;/SenderEmail&gt; 
&lt;RecipientID&gt;NPENZ&lt;/RecipientID&gt; 
&lt;DocumentFunction&gt;ORIGINAL&lt;/DocumentFunction&gt; 
&lt;/MessageHeader&gt; 
&lt;Container&gt;
&lt;Number&gt;' &amp; TiId1 &amp; '&lt;/Number&gt; 
&lt;ISO_Code&gt;22G1&lt;/ISO_Code&gt; 
&lt;NOR&gt;FALSE&lt;/NOR&gt; 
&lt;Type&gt;CON&lt;/Type&gt; 
&lt;Tynes&gt;Y&lt;/Tynes&gt; 
&lt;GrossWeight&gt;25473&lt;/GrossWeight&gt; 
&lt;Status&gt;F&lt;/Status&gt; 
&lt;Category&gt;E&lt;/Category&gt; 
&lt;FullEmptyStatus&gt;F&lt;/FullEmptyStatus&gt; 
&lt;LineOperator&gt;MSK&lt;/LineOperator&gt; 
&lt;ArrivalCarrierMode&gt;R&lt;/ArrivalCarrierMode&gt; 
&lt;DepartureCarrierMode&gt;W&lt;/DepartureCarrierMode&gt; 
&lt;OriginCode&gt;UNKNOWN&lt;/OriginCode&gt; 
&lt;DestinationCode&gt;HKHKG&lt;/DestinationCode&gt; 
&lt;UN_LoadPortCode&gt;NZNPE&lt;/UN_LoadPortCode&gt; 
&lt;UN_DischargePortCode&gt;AUSYD&lt;/UN_DischargePortCode&gt;
&lt;UN_FinalDischargePortCode&gt;AUSYD&lt;/UN_FinalDischargePortCode&gt; 
&lt;VGMCertificateStatement&gt; 
&lt;MethodOfWeightCalculation&gt;SM1&lt;/MethodOfWeightCalculation&gt; 
&lt;WeightVerificationDate&gt; 201601211600UTC &lt;/WeightVerificationDate&gt; 
&lt;WeightCertificateIssuingParty&gt; 
&lt;NameofIssuingParty&gt;CONTAINER WEIGHTING LTD&lt;/NameofIssuingParty&gt; 
&lt;Street&gt;STREET&lt;/Street&gt; 
&lt;City&gt;CITY&lt;/City&gt; 
&lt;Country&gt;COUNTRY&lt;/Country&gt; 
&lt;/WeightCertificateIssuingParty&gt; 
&lt;Declarant&gt; 
&lt;NameOfDeclarant&gt;JOE BLOKE&lt;/NameOfDeclarant&gt; 
&lt;CompanyOfDeclarant&gt;J EXPORTER&lt;/CompanyOfDeclarant&gt; 
&lt;DeclarantPhone&gt;0424222333&lt;/DeclarantPhone&gt; 
&lt;DeclarantEmail&gt;JBLOKE@EMAIL.COM&lt;/DeclarantEmail&gt; 
&lt;/Declarant&gt;
&lt;EDISignature&gt;JOE BLOKE &lt;/EDISignature&gt; 
&lt;/VGMCertificateStatement&gt; 
&lt;/Container&gt; 
&lt;Commodity&gt; 
&lt;Code&gt;GENL&lt;/Code&gt; 
&lt;Description&gt;25KG MANNIES X 920 BAGS&lt;/Description&gt; 
&lt;Packages&gt;1&lt;/Packages&gt; 
&lt;GrossWeight&gt;23173&lt;/GrossWeight&gt; 
&lt;/Commodity&gt; 
&lt;ReferenceNumbers&gt; 
&lt;ShippingLineBooking&gt;NZPN141014&lt;/ShippingLineBooking&gt; 
&lt;ShipperCargoReference&gt;NZPN141014&lt;/ShipperCargoReference&gt; 
&lt;/ReferenceNumbers&gt; 
&lt;ArrivalCarrier&gt; 
&lt;ArrivalCarrierTruck&gt; 
&lt;CarrierCode&gt;ROADCARRIER&lt;/CarrierCode&gt;
&lt;/ArrivalCarrierTruck&gt; 
&lt;/ArrivalCarrier&gt; 
&lt;DepartCarrier&gt; 
&lt;DepartCarrierVessel&gt; 
&lt;LloydsNumber&gt;9402029&lt;/LloydsNumber&gt; 
&lt;Name&gt;MAERSK BATUR&lt;/Name&gt; 
&lt;CTO_VoyageOutBound&gt;'&amp;_voyageCode&amp;'&lt;/CTO_VoyageOutBound&gt; 
&lt;ScheduledDeparture&gt;20141111200000&lt;/ScheduledDeparture&gt; 
&lt;/DepartCarrierVessel&gt; 
&lt;/DepartCarrier&gt; 
&lt;Seal&gt; 
&lt;Type&gt;X&lt;/Type&gt; 
&lt;Number&gt;64911&lt;/Number&gt; 
&lt;Condition&gt;IN RIGHT CONDITION&lt;/Condition&gt; 
&lt;/Seal&gt; 
&lt;/ContainerMessage&gt;';

	endif;
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, null, method.name, EDIFileType_XMLOneStopPre, false, true, false, false, null);
		

epilog

	return ediFile;

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="tiId" type="String" usage="output"/>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="zRunCAMS" id="995b0fe7-b5bc-4799-83dd-4c4406ab9002">
        <source>zRunCAMS(_camProtocol :String; _camGroup :CM_CamGroup; _desc :String;_operator :CM_Operator; _expectedOutput :String; _write :Boolean; _c1, _c2, _c3, _c4 :CM_Container input; _useVGM : Boolean) protected;
/*
Date		Who		Reason
11 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 31/05/2016	cnwdap1	TFS #2061 COARRI/CODECO/COPARN/EDI VGM Updates - new _useVGM parameter
//8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B

constants
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	camProtocol			: CM_CamProtocol;
	camTaskHistory		: CM_CamTaskHistory;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	idx					: Integer;
	str,actual, temp	: String;
	array 				: HugeStringArray;
	plus,colon			: Character;
	obj					:Object;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
begin
	create theLines transient;
	startDateTime := _c1.createdTime;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(_camProtocol);
		
	camProtocol := self.getCamProtocol(_camProtocol);
	self.assertIsDeleted(camProtocol);

	if _camProtocol.toUpper.cnContains ("CODECO") then
		camProtocol		:= self.createCamProtocolCodeco (_camProtocol, _camGroup, _desc, "NZCHC", _operator.code, null, true, false);
	elseif _camProtocol.toUpper.cnContains ("COARRI") then
		camProtocol		:= self.createCamProtocolCoarri (_camProtocol, _camGroup, _desc, "NZCHC", _operator.code);
	else
		return;
	endif;
		
	// set all container properties bcak to default values
	beginTransaction;
	_c2.setTemperature (4.0);
	_c1.setPropertyValue (CM_Container:: overLengthFront.name, null);
	_c1.setPropertyValue (CM_Container:: overLengthRear.name, null);
	_c1.setPropertyValue (CM_Container:: overWidthRight.name, null);
	_c1.setPropertyValue (CM_Container:: overWidthLeft.name, null);
	_c1.setPropertyValue (CM_Container:: overHeight.name, null);	
	
	_c1.allTIHazards.sendMsg ("purge");
	
	if _useVGM then																// TFS #2061
		camProtocol.setPropertyValue(CM_CamProtocol::useVGM.name, _useVGM);		// TFS #2061
	endif;																		// TFS #2061
	commitTransaction;			

	if camProtocol.isCoarri then
		if camProtocol.code [camProtocol.code.length] = '2' then
			beginTransaction;
			// multi container per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::singleContainerPerBGM.name, true);	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::decimalCharacter.name, ",");	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::elementSeparator.name, "%");	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::subElementSeparator.name, "&amp;");	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::segmentTerminator.name, ';');	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::escapeCharacter.name, '/');	// single conrtainer per BGM
			commitTransaction;
		elseif camProtocol.code [camProtocol.code.length] = '3' then
			beginTransaction;
//			camProtocol.setPropertyValue (CM_CamProtocol::specialField11.name, true);	// single conrtainer per BGM
			camProtocol.setPropertyValue (CM_CamProtocol::sendCarrier_RFF_CN.name, true);	// send carrier info
			camProtocol.setPropertyValue (CM_CamProtocol::useCarrierForBooking.name, true);	// use carrier ref
			commitTransaction;
			
		endif;
	elseif camProtocol.code [camProtocol.code.length] = '2' then
		beginTransaction;
		//camProtocol.setPropertyValue (CM_CamProtocol::decimalCharacter.name, ",");
		_c2.setTemperature (4.25);
		camProtocol.setPropertyValue (CM_CamProtocol::singleContainerPerBGM.name, false);	// single conrtainer per BGM
		
		_c1.setPropertyValue (CM_Container:: overLengthFront.name, '1.1'.Decimal);
		_c1.setPropertyValue (CM_Container:: overLengthRear.name, 2.2.Decimal);
		_c1.setPropertyValue (CM_Container:: overWidthRight.name, 3.3.Decimal);
		_c1.setPropertyValue (CM_Container:: overWidthLeft.name, 4.4.Decimal);
		_c1.setPropertyValue (CM_Container:: overHeight.name, 5.5.Decimal);
		
		commitTransaction;
		
		self.addTIHazard (_c1, '1.2', false);
		self.addTIHazard (_c1, '1.3', false);

		beginTransaction;
		foreach obj in _c1.allTIHazards do
			obj.CM_TIHazard.allUNDGCodes.add ('UNDG_1');
			obj.CM_TIHazard.allUNDGCodes.add ('UNDG_2');
			break;
		endforeach;
		commitTransaction;

	elseif camProtocol.code [camProtocol.code.length] = '+' then
		// change seperators
		beginTransaction;
		camProtocol.setPropertyValue (CM_CamProtocol::elementSeparator.name, "%");
		_c2.setTemperature (3.4);
		commitTransaction;
	elseif camProtocol.code [camProtocol.code.length-2 :3] = 'COS' then
		beginTransaction;
		camProtocol.setPropertyValue (CM_CamProtocol::tempLeadingZerosNoDecimal.name, true);
		_c2.setTemperature (-5.678);
		commitTransaction;	
	elseif camProtocol.code [camProtocol.code.length] = '3' then
		beginTransaction;
//			camProtocol.setPropertyValue (CM_CamProtocol::specialField11.name, true);	// single conrtainer per BGM
		camProtocol.setPropertyValue (CM_CamProtocol::sendCarrier_RFF_CN.name, true);	// send carrier info
		camProtocol.setPropertyValue (CM_CamProtocol::useCarrierForBooking.name, true);	// use carrier ref
		commitTransaction;
	else

	endif;
	
	// run cams
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	// write contents of file
	if _write then
		write '-------------------------------';
		write camProtocol.description;
		write '--------------------------------';
	endif;
	idx := 0;
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	
	// compare with what we expect
	create array transient;
	
	temp := _expectedOutput;
	temp := temp.replaceString (Lf, null);
	temp := temp.replaceString ("&lt;bk1&gt;", _c1.bookingReference);
	temp := temp.replaceString ("&lt;bk2&gt;", _c2.bookingReference);
	temp := temp.replaceString ("&lt;bk3&gt;", _c3.deliveryRelease);
	temp := temp.replaceString ("&lt;bk4&gt;", _c4.deliveryRelease);
	temp := temp.replaceString ("&lt;bol1&gt;", _c1.billOfLading);
	temp := temp.replaceString ("&lt;bol2&gt;", _c2.billOfLading);
	temp := temp.replaceString ("&lt;bol3&gt;", _c3.billOfLading);
	temp := temp.replaceString ("&lt;bol4&gt;", _c4.billOfLading);
	
	if camProtocol.elementSeparator &lt;&gt; camProtocol.Default_ElementSeperator then
		temp := temp.replaceString (camProtocol.Default_ElementSeperator, camProtocol.elementSeparator);
	endif;
	if camProtocol.escapeCharacter &lt;&gt; camProtocol.Default_EscapeCharacter then
		temp := temp.replaceString (camProtocol.Default_EscapeCharacter, camProtocol.escapeCharacter);
	endif;
	if camProtocol.decimalCharacter &lt;&gt; camProtocol.Default_DecimalCharacter then
		temp := temp.replaceString (camProtocol.Default_DecimalCharacter, camProtocol.decimalCharacter);
	endif;
	if camProtocol.subElementSeparator &lt;&gt; camProtocol.Default_SubElementSeperator then
		temp := temp.replaceString (camProtocol.Default_SubElementSeperator, camProtocol.subElementSeparator);
	endif;
	if camProtocol.segmentTerminator &lt;&gt; camProtocol.Default_SegmentTerminator then
		temp := temp.replaceString (camProtocol.Default_SegmentTerminator, camProtocol.segmentTerminator);
	endif;
	
	temp.getHugeTokensForDelimiter (Cr, array);
	plus		:= camProtocol.elementSeparator;
	colon		:= camProtocol.subElementSeparator;
	foreach str in theLines do
		idx := idx + 1;
		
		if _write then
			//write idx.String &amp; ' ' &amp; str;
			//write array[idx];
			write str;
		endif;
	endforeach;
	
	self.assertNotEqualMsg(theLines.size, 0, 'Nothing extracted');
	idx := 0;
	foreach str in array do
		idx := idx + 1;
		actual :=  theLines[idx];
		if actual.startsWith("UNB") and str.startsWith ("UNB") then 
			// strip off date time part
			actual 	:= self.removeElementFromSegment (5, plus, actual);
			str 	:= self.removeElementFromSegment (5, plus, str);
		elseif actual.startsWith ("DTM") and str.startsWith ("DTM") then
			actual 	:= self.removeElementFromSegment (2, colon, actual);
			str 	:= self.removeElementFromSegment (2, colon, str);
		endif;
		
		self.assertEqualMsg (actual.toUpper, str.toUpper, camProtocol.description &amp; ' record ' &amp; idx.String);
	endforeach;

	self.assertEqualMsg (array.size, theLines.size, 
								"Actual Size " &amp; theLines.size.String &amp; CrLf &amp;
								"Expected Size " &amp; array.size.String);
epilog
	delete array;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_expectedOutput" type="String"/>
        <Parameter name="_write" type="Boolean"/>
        <Parameter name="_c1" type="CM_Container" usage="input"/>
        <Parameter name="_c2" type="CM_Container" usage="input"/>
        <Parameter name="_c3" type="CM_Container" usage="input"/>
        <Parameter name="_c4" type="CM_Container" usage="input"/>
        <Parameter name="_useVGM" type="Boolean"/>
    </JadeMethod>
</Class>
