    <JadeMethod name="setComboValues" id="76206d0e-41fb-438a-86d4-3747bf24da55">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	country : CM_Country;
	dict : CM_CountryByCodeDict;		

begin
	_combo.clear;
	dict := app.myRoot.allCountries;
	
	foreach country in dict discreteLock do																	
		_combo.itemObject[_combo.addItem(country.code &amp; Tab &amp; country.description)] := country;																				
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1c20a5ab-3961-4721-90d1-bc2b31a7da3f">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	country : CM_Country;
	dict : CM_CountryByCodeDict;
	selectionValue, idx : Integer;
	array : ObjectArray;

begin
	dict := app.myRoot.allCountries;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach	country in dict discreteLock do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(country.code) then
			selectionValue := 1;
			array.add(country);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; country.code &amp; " (" &amp; country.description &amp; ")");
		_tbl.accessRow(idx).itemObject := country;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="d755dc79-91ae-4489-a5fe-a706c83f0077">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	country : CM_Country;
	str : String;
	numRows, idx : Integer;
	sa : StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			country := _tbl.accessRow(idx).itemObject.CM_Country;
			sa.add(country.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="6b0af04d-d714-4f88-8c8c-8d23982dc43e">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars

begin
	if _value.isKindOf(CM_Country) then
		if _value &lt;&gt; null then
			return _value.CM_Country.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e07fb6df-7f81-4cde-93e5-b4c83ed62af5">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	invalidObj : Boolean;
	object : CM_Country;
	returnVal : String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_Country) then
			object := _value.CM_Country;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d3dbdb3d-7cd7-4768-8415-d3c006abfc78">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(String) then		
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
