<Class name="AARoot" id="7bd2ede7-cb1b-4a8f-8e0d-d2c899046c88">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="auditor"/>
    <ExplicitInverseRef name="reports" id="83419765-ca3a-4ea7-8d5a-be04700522a7">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="AAProcessByOidDict"/>
        <Inverse name="AAProcess::root"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="users" id="4bce1eb6-3949-408b-932c-dc51a80e1cba">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="AAProcessByOidDict"/>
        <Inverse name="AAProcess::root"/>
    </ExplicitInverseRef>
    <JadeMethod name="addReportName" id="6e1ca495-c808-499d-833e-bbbacb6cc409">
        <updating/>
        <source>addReportName(procOid : String; time : TimeStamp; userName : String) updating;
vars
	proc		: AAProcess;
	reportName	: AALINCReport;
begin

	proc := reports[procOid];
	if proc = null then
		create proc;
		proc.load(procOid, userName, 1);
		reports.add(proc);
	endif;
	
	create reportName;
	reportName.timestamp := time;
	reportName.name := userName;
	proc.reportNames.add(reportName);
	
end;</source>
        <Parameter name="procOid" type="String"/>
        <Parameter name="time" type="TimeStamp"/>
        <Parameter name="userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addUser" id="9014c05d-ffe2-4adc-8f08-f1a614846efd">
        <updating/>
        <source>addUser(procOid : String; userName : String) updating;
vars
	proc	: AAProcess;

begin

	create proc;
	proc.load(procOid, userName, 0);
	users.add(proc);
	
end;</source>
        <Parameter name="procOid" type="String"/>
        <Parameter name="userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getProcessId" id="dd7b1e52-c72e-44a4-8cbb-63dc7250be8f">
        <source>getProcessId(oid : String; time : TimeStamp) : String;
vars
	proc 		: AAProcess;
	reportName	: AALINCReport;
	
begin
	proc := users[oid];
	if proc &lt;&gt; null then
		return proc.name;
	endif;
	proc := reports[oid];
	if proc &lt;&gt; null then
		// return the name the report process assumed prior to specified time
		reportName := proc.reportNames.getAtKeyLeq(time);
		if reportName &lt;&gt; null then
			return reportName.name;
		endif;
	endif;
	
	return null;
end;
</source>
        <Parameter name="oid" type="String"/>
        <Parameter name="time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadUsers" id="9d7458b2-d2f7-46b5-9eb6-f622c5efcf42">
        <updating/>
        <source>loadUsers(file : File; type : Integer) updating;
constants
	Comma 	: String = ",";
	
vars
	record		: String;
	token		: String;
	pos			: Integer;
	timestamp	: TimeStamp;
	procOid		: String;
	userName	: String;
	counter		: Integer;
begin
	beginTransaction;	
	while not file.endOfFile  do
		record := file.readLine();
		pos := 1;
		timestamp := record.scanUntil(Comma, pos).TimeStamp;
		pos := pos + 1;
		procOid := record.scanUntil(Comma, pos);
		if pos &gt; 0 then
			pos := pos + 1;
			userName := record.scanUntil(Comma, pos);
			if type = 0 then
				addUser(procOid, userName);
			else
				addReportName(procOid, timestamp, userName);
			endif;
		endif;
		counter := counter + 1;
	endwhile;
	commitTransaction;
end;
</source>
        <Parameter name="file" type="File"/>
        <Parameter name="type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purgeUsers" id="b9d93fe6-cba0-4aef-bad5-77e24701cbb1">
        <source>purgeUsers();

vars

begin
	users.purge;
	reports.purge;
end;
</source>
    </JadeMethod>
</Class>
