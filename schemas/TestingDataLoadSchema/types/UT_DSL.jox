    <JadeMethod name="addWorkOrderTask" id="9f84ff51-f9cb-4313-b744-effa0d093cf7">
        <source>addWorkOrderTask( _workOrder : CM_WorkOrderTI io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jan 2010	cnwrd1	Initial creation
18 May 2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	terminal 		: CM_Terminal;
	realWorkOrder,
	pxyWorkOrder	:  CM_WorkOrderTI;
	pxyWODtl 		: CM_WorkOrderDtl;
	autoQ,
	autoRTQ 		: Boolean;
	taskType 		: Integer;
	dtRequired,
	dtStart			: TimeStamp;
	toDoTaskID 		: Integer;
	toDoTask 		: CM_ToDoTaskDesc;
	root 			: CM_Root;
	target,
	unpackLoc		: CM_TerminalArea;
begin
		
	root 	 := CM_Root.firstInstance;
	terminal := _workOrder.myTerminal;

	if self.opts.includesKey("targetTA") then
		target := terminal.allTerminalAreas[opts.str('targetTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("unpackTA") then
		unpackLoc := terminal.allTerminalAreas[opts.str('unpackTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("autoRTQ") then
		autoRTQ := opts.bool("autoRTQ");
	endif;
	
	if self.opts.includesKey("dtRequired") then
		dtRequired := opts.str("dtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("dtStart") then
		dtRequired := opts.str("dtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("autoQ") then
		autoQ := opts.bool("autoQ").Boolean;
	endif;
	
	if self.opts.includesKey("toDoTaskID") then
		toDoTaskID:= opts.int("toDoTaskID");
	endif;
	
	if toDoTaskID &lt;&gt; null then
		toDoTask := root.allToDoTaskDescriptions[toDoTaskID];
	endif;
	
	if opts.includesKey("taskType") then
		taskType := opts.int("taskType");
	else
		taskType := WO_TASK_MOVE;
	endif;
	
	
	if _workOrder.isTransient then
		pxyWorkOrder := _workOrder.CM_WorkOrderTI;
	else
		pxyWorkOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrderTI;
	endif;

	
	//WO_TASK_MOVE
	//WO_TASK_TODO
	//WO_TASK_PACK
	//WO_TASK_UNPACK
	
	if taskType = WO_TASK_MOVE then
		create pxyWODtl as CM_WodMove transient;		
	elseif taskType = WO_TASK_TODO then
		create pxyWODtl as CM_WodToDo transient;
	elseif taskType = WO_TASK_PACK then
		create pxyWODtl as CM_WodPack transient;
	elseif taskType = WO_TASK_UNPACK then
		create pxyWODtl as CM_WodUnpack transient;
	else
		// do move?
		create pxyWODtl as CM_WodMove transient;
	endif;
	
	pxyWorkOrder.setProxyWorkOrderTask(
										pxyWODtl,
										dtRequired, 			//required by date/time
										dtStart,			// start at date/time
										autoQ,  		// auto queue task for BGP
										taskType, 		// task type constant
										toDoTask); 		//todo task if needed
		
										
	if taskType = WO_TASK_MOVE then
			pxyWODtl.CM_WodMove.setProxyMove( null, // source loction not used
						 target,
						 autoRTQ,
						 null);	// TFS 53038 05/05/2022 NAVCS2
	elseif taskType = WO_TASK_TODO then
		pxyWODtl.CM_WodToDo.setProxyWodToDo( toDoTask );
	elseif taskType = WO_TASK_PACK then
		
	elseif taskType = WO_TASK_UNPACK then	
		pxyWODtl.CM_WodUnpack.setProxyWodUnpack( unpackLoc );
	endif;
	
	if not _workOrder.isTransient then 
		app.myTrxUA.trxUpdateWorkOrderTasks(pxyWorkOrder, app.myPassport);		
	endif;
	
epilog
	if not _workOrder.isTransient then
		delete pxyWorkOrder;
	endif;
end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrderTI" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addWorkPoint" id="5663f924-a5a8-48ec-b4b1-2b6d5c7cd9ca">
        <source>addWorkPoint(_code : String; _autoDelete : Boolean) : CM_WorkPoint;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars
	pxyWorkPoint , realWorkPoint: CM_WorkPoint;
	obj							: Object;
	objArray					: ObjectArray;
	
	jobSeed						: Integer;
	
begin

	realWorkPoint:= self.getTerminal.allWorkPointsByCode[_code];
	if realWorkPoint &lt;&gt; null then
		if _autoDelete then
			self.deleteWorkPoint(realWorkPoint.code);
			//app.myTrxDA.trxDeleteWorkPoint(realWorkPoint,app.myPassport);
			//self.assertNoTrxErrorsOrWarnings();
		else
			return realWorkPoint;
		endif;
	endif;
	
	
	// 23/04/2018 jlgmh5
	jobSeed := 200;
	if self.opts.includesKey("JobSeed") then
		jobSeed := self.opts.int("JobSeed");
	endif;
	
	create pxyWorkPoint transient;
	
	//pxyWorkPoint.setProxy(_code,"Work point " &amp; _code &amp; " description",Green, jobSeed, 60, 400, self.getTerminal,null);			//26.4.2023 navhl20 #57712[54552]
	pxyWorkPoint.setProxy(_code,"Work point " &amp; _code &amp; " description",Green, jobSeed, 60, 400, self.getTerminal,null,null);		//26.4.2023 navhl20 #57712[54552]
	
	app.myTrxCA.trxCreateWorkPoint(pxyWorkPoint,realWorkPoint,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return realWorkPoint;
epilog
	delete pxyWorkPoint;
	delete objArray;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_autoDelete" type="Boolean"/>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="addWorkPointTransferArea" id="9aa6eec7-7650-42a4-9482-811ce204e70b">
        <source>addWorkPointTransferArea(_name : String; _workPoint: CM_WorkPoint) : CM_WorkPointInterchangeArea;
vars
	pxyWorkPointTA: CM_WorkPointInterchangeArea;
	interchangeArea: CM_InterchangeArea;
	realTA 	: CM_TerminalAreaMaster;
	selectedTAs 	: CM_TerminalAreaSet;
	
begin
	self.deleteTerminalArea(_name);
	
	create pxyWorkPointTA transient;
	create selectedTAs transient;
	
	pxyWorkPointTA.pxyUpdateLaneCount (3);	// cnwcs5 11/09/2009 
	
	pxyWorkPointTA.setProxy(_name, 						// name
						"",							// comment
						self.getTerminal,			// terminal
						_workPoint,
						false,						
						false,						
						selectedTAs,	// allInterchangeAreas
						4);			
	
	
	app.myTrxCA.trxCreateTerminalArea(pxyWorkPointTA, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_WorkPointInterchangeArea;
epilog
	
	delete pxyWorkPointTA;
	delete selectedTAs;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <ReturnType type="CM_WorkPointInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="addYA" id="c3a932e8-e3f7-40f8-9f05-7a4932057f7c">
        <source>addYA(_name: String; _criteria : CMIF_Array; _locations: CM_LCArray) : CM_YardAllocation protected;
//17/10/2017	jlgmh5	Create new version
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
	allowMultiRangeSplit : Integer;
begin
	self.deleteYA(_name);
	
	///proxyYACriteria := self.createYACriterias(criteria1, value1, criteria2, value2, criteria3, value3);
	proxyYA := self.createYA(_name, self.getTerminal(), _locations, YAFillOption_InOrder, YAFillOption_InOrder,false);
	
	///if self.opts.includesKey("AllowMultiRangeSplit") then	//20 Jun 2016	NDL	TFS 2172
	///	allowMultiRangeSplit := self.opts.int("AllowMultiRangeSplit");
	///	proxyYA.setAllowMultiRangeSplit(allowMultiRangeSplit);
	///endif;
		
	app.myTrxCA.trxCreateYardAllocation(proxyYA, _criteria, yardAllocation, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_criteria" type="CMIF_Array"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYA1WithFill" id="dc6a834f-0a6f-406d-9b22-b05099257467">
        <source>addYA1WithFill(name: String; 
	  criteria1: Integer; value1: Any;
	  locations: CM_LCArray;
	  _fillOptionIn, _fillOptionOut: Integer;
	  _separateRanges : Boolean) : CM_YardAllocation protected;
//16 July 2008	cnwdw1	
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
begin

	proxyYACriteria := self.createYACriterias(criteria1, value1, 0, 0, 0, 0);
	proxyYA := self.createYA(name, app.getMyTerminalDO_NOT_USE(), locations, _fillOptionIn, _fillOptionOut,_separateRanges);
	app.myTrxCA.trxCreateYardAllocation(proxyYA, proxyYACriteria, yardAllocation, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(yardAllocation.fillOptionIn, _fillOptionIn);
	self.assertEqual(yardAllocation.fillOptionOut, _fillOptionOut);
	
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="name" type="String"/>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="locations" type="CM_LCArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <Parameter name="_separateRanges" type="Boolean"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYA1WithGroups" id="40547943-691c-4683-be22-7e1d3721cd93">
        <source>addYA1WithGroups(name: String; 
	  criteria1: Integer; value1: Any;
	  _groupIn, _groupOut: CM_YABlockGroupArray;
	  _fillOptionIn, _fillOptionOut: Integer) : CM_YardAllocation protected;
//16 July 2008	cnwdw1	
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
begin

	proxyYACriteria := self.createYACriterias(criteria1, value1, 0, 0, 0, 0);
	proxyYA := self.createYAWithGroups(name, app.getMyTerminalDO_NOT_USE(), _groupIn, _groupOut, _fillOptionIn, _fillOptionOut);
							
	app.myTrxCA.trxCreateYardAllocation(proxyYA, proxyYACriteria, yardAllocation, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="name" type="String"/>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="_groupIn" type="CM_YABlockGroupArray"/>
        <Parameter name="_groupOut" type="CM_YABlockGroupArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYAPriority" id="f3e083fe-5333-4a7d-bf3b-035ce5cb1a48">
        <source>addYAPriority(_criteria: Integer; _value: Any);
//23 July 2010	cnwdw1	
//
// Add a YA priority. It is added to the end of the existing list of priorities
vars
	priorities: CMIF_Array;
	cmif: CMIF_YACriteriaPriority;
	priority: CM_YACriteriaPriority;
	objSet: CM_ObjectSet;
begin
	create priorities transient;
	
	foreach priority in self.getTerminal.allYAPriorities do
		cmif :=	priority.getTransient();
		cmif.setFlag(false, false, false);
		priorities.add(cmif);
	endforeach;
	if _value = null and not _value.isKindOf(String) then
		create objSet transient;
		cmif := self.createYAPriority(_criteria, objSet);
	else
		cmif := self.createYAPriority(_criteria, _value);
	endif;
	priorities.add(cmif);
	
	app.myTrxUA.trxYABuildCriteriaPriorities(priorities, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	priorities.purge;
	delete priorities;
	delete objSet;
end;</source>
        <Parameter name="_criteria" type="Integer"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="addYATemplate" id="8fcb6a2a-b44a-48fa-a40d-399e039bc0df">
        <source>addYATemplate(_name: String; _criteriaType: Integer; _value : Any) : CM_YATemplate;
//17 July 2008	cnwdw1	
//
vars
	proxyYATemplate: CM_YATemplate;
	yATemplate: CM_YATemplate;
	proxyYACriteria: CMIF_Array;
	proxyYA: CM_YardAllocation;
begin
	proxyYA := self.createYAWithOneCriteria(_name, null, _criteriaType, _value, null, proxyYACriteria);

	create proxyYATemplate transient;
	proxyYATemplate.setProxy(_name, proxyYA, self.getTerminal(), YATemplateStatus_Active);
		
	app.myTrxCA.trxCreateYATemplate(proxyYATemplate, proxyYACriteria, yATemplate, app.myPassport);
	
	return yATemplate;

epilog
	delete proxyYA;
	delete proxyYATemplate;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="CM_YATemplate"/>
    </JadeMethod>
    <JadeMethod name="addYardInterchangeArea" id="02299dd5-5282-4a17-b422-591c5886b8c1">
        <source>addYardInterchangeArea(_id :String; _gate :CM_Gate; _laneCount, _capacity :Integer):CM_YardInterchangeArea;
// ---------------------------------------------------------------------------
// Created:     14 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_YardInterchangeArea;
	area	:CM_TerminalAreaMaster;
	lc		:CM_LaneController;
	int		:Integer;
	laneCapacityArray		: IntegerArray;
	accessType				: Integer;
begin

	self.deleteTerminalArea(_id);			// 05/12/2011 cnwmh5 
	
	create proxy transient;
	
	accessType := CM_InterchangeArea.Access_VehicleMachines;
	if self.opts.includesKey("AccessType") then
		accessType := self.opts.int("AccessType");
	endif;
	
	proxy.setProxy (_id, null, self.getTerminal, null, null, accessType,_gate,   null, _laneCount);	
			
	if _laneCount = 0 then
		if not proxy.pxyHasLanesDefined then
			proxy.pxyCreateNewLane (true);
		endif;
	elseif _laneCount &gt; 0 then
	
		if self.opts.includesKey("laneCapacities") then						// 17/02/2016 cnwns1
			laneCapacityArray := self.opts.intArray("laneCapacities");
			self.assertEqualMsg(_laneCount, laneCapacityArray.size, "Lane Capticity (" &amp; laneCapacityArray.size.String &amp; 
				") is not the same size as lane count (" &amp; _laneCount.String &amp; ").");
		endif;
	
		while int &lt; _laneCount do
			int := int + 1;
			
			lc := proxy.pxyCreateNewLane (true);
			
			//lc.setCapacity (_capacity);
			if laneCapacityArray = null or laneCapacityArray.isEmpty() then			// 17/02/2016 cnwns1
				lc.setCapacity (_capacity);
			else
				lc.setCapacity (laneCapacityArray[int]);
			endif;
		endwhile;
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(proxy, area, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return area.CM_YardInterchangeArea;					
epilog
	delete proxy;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_gate" type="CM_Gate"/>
        <Parameter name="_laneCount" type="Integer"/>
        <Parameter name="_capacity" type="Integer"/>
        <ReturnType type="CM_YardInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="allLocationsBetween" id="87ec61b0-b569-47ac-b6a7-b9cd5cab1fce">
        <source>allLocationsBetween(_locations: CM_LCArray io; _topLeft, _bottomRight: CM_GridController);
//08 February 2009	cnwdw1	
// Return a collection with all the locations between topLeft and bottomRight
vars
	terminalArea : CM_TerminalArea;
	row, col: Integer;
begin
	terminalArea := _topLeft.myTerminalArea;
	foreach row in _topLeft.row to _bottomRight.row do
		foreach col in _topLeft.column to _bottomRight.column do
			_locations.add(terminalArea.CM_GridArea.allGridControllersByRowColumn[row, col]);
		endforeach;
	endforeach;	
end;</source>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
        <Parameter name="_topLeft" type="CM_GridController"/>
        <Parameter name="_bottomRight" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="applyAgentToCargo" id="817dce6e-2241-41df-8f44-71e987c1f3bc">
        <source>applyAgentToCargo(_allTIs : CM_TISet; _debtorType : CM_DebtorType; _agent : CM_Object);

/*

Purpose:		Apply the entered customs agent/consignee etc to the selected cargo and
				resync the relevent transactions before showing the current and proforma charges.
				Called from unit test code - copy of code in INV_CashReceiptBOL
Parameters:			

Return Value:		


Date		Who		Reason
13 September 2013	cnwjre1	Initial creation

*/

vars
	pxyTISet	: CM_TISet;
	allChildren	: CM_TISet;
	tiChildren	: CM_TISet;
	ti : CM_TrackedItem;
	child	: CM_TrackedItem;
	pxyTI	: CM_TrackedItem;
	trans	: CM_TITransaction;
	controller : CMIF_TiTransactionResync;

begin

	// apply agent if one has been selected - null entry allows use of existing agent without changing it 
	if _agent &lt;&gt; null then
		// 34800 handle children
		create allChildren transient;
		create tiChildren transient;
		foreach ti in _allTIs do
			tiChildren.clear();
			ti.getAllNestedChildren(tiChildren);
			foreach child in tiChildren do
				allChildren.add(child);
			endforeach;
		endforeach;
		create pxyTISet transient;
		foreach ti in _allTIs do
			// 34800 creating a proxy for a parent also does it for the children
			if allChildren.includes(ti) then
				continue;
			endif;
			pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
			if _debtorType.code = "SDT2" then
				pxyTI.zSetPxyConsignee(_agent.CM_ConsigneeConsignor.code);
			elseif _debtorType.code = "SDT3" then
				pxyTI.zSetPxyConsignor(_agent.CM_ConsigneeConsignor.code);
			elseif _debtorType.code = "SDT6" then
				pxyTI.zSetPxyCustomsAgent(_agent.CM_CustomsAgent);
			elseif _debtorType.code = "SDT7" then
				pxyTI.zSetPxyFreightFowarderCode(_agent.CM_ConsigneeConsignor.code);
			endif;
			pxyTISet.add(pxyTI);
		endforeach;

		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// resync all transactions
	foreach ti in _allTIs do
		create controller transient;
		controller.myTrackedItem := ti;
		if _debtorType.code = "SDT2" then
			controller.updateConsignee := true;
		elseif _debtorType.code = "SDT3" then
			controller.updateConsignor := true;
		elseif _debtorType.code = "SDT6" then
			controller.updateCustomsAgent := true;
		elseif _debtorType.code = "SDT7" then
			//controller.updateCustomsAgent := true;	// NO updateFF
		endif;
		foreach trans in ti.allTransactions do
			controller.allTransactions.add(trans);
		endforeach;
		app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete controller;
	endforeach;
	
epilog

	if pxyTISet &lt;&gt; null then
		pxyTISet.purge();
	endif;
	delete pxyTISet;
	delete allChildren;
	delete tiChildren;
	delete controller;
end;</source>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_agent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="archiveVoyage" id="33868531-b78c-4f29-9634-bb9bcf660da8">
        <updating/>
        <source>archiveVoyage(_voyageCode : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/

vars
	removeEDITrackedItems,
	removeNonWorkedTrackedItems,
	removePreNotifiedTrackedItems,
	removeTBATrackedItems : Boolean;
	removeBookRef : Boolean;
	archiveBookRef : Boolean;
	archiveInt	: CMIF_ArchiveVoyage;
	voyageObj	: CM_Voyage;
	isInError	: Boolean;
	tmpMess : String;
	allVoyages : CM_VoyageArray;
	voy 		: CM_Voyage;
begin

	if _voyageCode = null then
		return;
	endif;

	create allVoyages transient;

	voy := self.getVoyage(_voyageCode);

	if voy = null then
		return;
	endif;
	
	allVoyages.add(voy);
	
	

	foreach voyageObj in allVoyages do
		if not voyageObj.canVoyageBeArchived(tmpMess,true) then //jlier1 JIRA#26774 10/12/24
			isInError	:=	true;		
		endif;
	endforeach;
	
	if isInError then
		return;
	endif;
	
	
	removeEDITrackedItems			:=	true;
	removeNonWorkedTrackedItems		:=	true;
	removePreNotifiedTrackedItems	:=	true;
	removeTBATrackedItems			:=	true;
	removeBookRef					:=  true;

	if self.opts.includesKey("removeEDITrackedItems") then
		removeEDITrackedItems := self.opts.bool("");
	endif;	
	
	if self.opts.includesKey("removeNonWorkedTrackedItems") then
		removeNonWorkedTrackedItems := self.opts.bool("");
	endif;	
	
	if self.opts.includesKey("removePreNotifiedTrackedItems") then
		removePreNotifiedTrackedItems := self.opts.bool("removePreNotifiedTrackedItems");
	endif;	
	
	if self.opts.includesKey("removeTBATrackedItems") then
		removeTBATrackedItems := self.opts.bool("removeTBATrackedItems");
	endif;	
	
	if self.opts.includesKey("removeBookRef") then
		removeBookRef := self.opts.bool("removeBookRef");
	endif;	
	if self.opts.includesKey("archiveBookRef") then
		archiveBookRef := self.opts.bool("archiveBookRef");
	endif;	

	if removeBookRef and archiveBookRef then
		isInError	:=	true;
		return ;
	endif;

	
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Archiving voyage');

	create archiveInt transient;
	//archiveInt.isNoDatesAllowed					:=	self.aIsNoDatesAllowed;
	archiveInt.removeEDITrackedItems			:=	removeEDITrackedItems;
	archiveInt.removeNonWorkedTrackedItems		:=	removeNonWorkedTrackedItems;
	archiveInt.removePreNotifiedTrackedItems	:=	removePreNotifiedTrackedItems;
	archiveInt.removeTBATrackedItems			:=	removeTBATrackedItems;
	archiveInt.removeBookingRefs := removeBookRef;
	archiveInt.archiveBookingRef := archiveBookRef;
	allVoyages.copy(archiveInt.allVoyages);
	
	
	app.myTrxUA.trxUpdateVoyageArchive(archiveInt, app.myPassport);

	/*
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog(app.getErrorString(VoyageArchive), app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
		global.beep;
		app.msgBox('The selected voyage(s) has been successfully archived.', app.getErrorString(VoyageArchived), MsgBox_OK_Only);
	endif;
	*/

epilog
	delete allVoyages;
	delete archiveInt;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertLocationHasTI" id="70ededa6-3bb9-411c-8c8a-b4b366c1aa2b">
        <source>assertLocationHasTI(_location: CM_LocationsController; _ti: CM_TrackedItem);
//04 September 2008	cnwdw1	
//
vars

begin
	self.assertTrueMsg(_location.allTrackedItems.size &gt;= 1, "ti is not in location");
	self.assertTrueMsg(_location.allTrackedItems.includes(_ti), "location does not have the ti");
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="assertStat" id="d2380a14-5f42-4416-afac-71db7c86eca4">
        <source>assertStat(_stats: CM_LocationStatistics; _propertyName: String; _expectedValue: Integer);
//04 September 2008	cnwdw1	
//
vars

begin
	assertTrueMsg(_stats &lt;&gt; null, "Invalid stat record");
	// First check the totals calculated by the movement log
	processMovementLog();
	assertEqualMsg(_stats.getPropertyValue(_propertyName).Integer, _expectedValue, "Invalid "&amp;_propertyName&amp;" stat");
	
	// Second check that totals calculated correctly from scratch
	if _stats.myParent.isKindOf(CM_YABlock) then
		calculateYABlockStats(_stats.myParent.CM_YABlock.myYardAllocationIn);
	elseif _stats.myParent.isKindOf(CM_GridRow) then
		calculateTerminalAreaStats(_stats.myParent.CM_GridRow.myGridArea);
	else
		assertFalseMsg(true, "Invalid location statistics record"&amp;_stats.myParent.String);
	endif;
	assertEqualMsg(_stats.getPropertyValue(_propertyName).Integer, _expectedValue, "Invalid "&amp;_propertyName&amp;" stat");
end;</source>
        <Parameter name="_stats" type="CM_LocationStatistics"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_expectedValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assignTiToRoadWLE" id="9f8c5824-772f-4622-b05e-fd2150f8f262">
        <source>assignTiToRoadWLE(_ti: CM_TrackedItem; _wle: CM_WorkListEntry);
/*

*/
vars
	controller	: CMIF_MoveController;
begin

	create controller transient;
	controller.setMoveMode(REAL_MODE);
	controller.setMyToPrimaryLocation(_wle.job.CM_RoadJob.myVehicle.locationsController);
	controller.setMyTrackedItem(_ti);
	controller.setMyWorkListEntry(_wle);
	
	app.myTrxUA.trxUpdateWLEAssignTI(controller, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete controller;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="autoplanDischargeItems" id="53700795-8d81-4fcd-883f-7032225bf13a">
        <source>autoplanDischargeItems(_voyage : CM_Voyage; _terminalArea : CM_TerminalArea; _crane : CM_Crane);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwmh5	Initial creation

*/

vars
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	trackedItem : CM_TrackedItem;
begin
	
	location := _terminalArea.allLocationsControllers.first;

	jobSheet := _voyage.allJobSheets[_crane.id];
	foreach job in _voyage.allVoyageJobs  discreteLock do
	
		// Discharge ONLY
		if not job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		
		//### for each ti 
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				self.movePlannedWLE(wle.myTrackedItem, location, wle);
			endforeach;
		endforeach;
	endforeach;
	
	// CHECK DISCHARGE
	if not self.opts.includesKey("DontCheckHere") then
		foreach job in _voyage.allVoyageJobs  discreteLock do
		
			// Discharge ONLY
			if not job.CM_VoyageJob.isDischarge then
				continue;
			endif;
			
			foreach wle in job.workListEntries do
				trackedItem := wle.myTrackedItem;
				if trackedItem &lt;&gt; null then
					self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null), trackedItem.id &amp; " Did not plan discharge");
				endif;
				
			endforeach;
		endforeach;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="autoplanTIs" id="f61d0d9e-de0e-4485-82d3-b2de5393b1d5">
        <source>autoplanTIs(_tiArray	: CM_TIArray);
/*
Purpose:			
Date		Who		Reason
23 September 2013	cnwab1	Initial creation
*/

vars
	
	params : CMIF_AutoplanParams;
	moveMode : Integer;
	ignoreErrors : Boolean;
	
begin

	moveMode := PLANNING_MODE;
	if self.opts.includesKey("MoveMode") then	//20 Jun 2016	NDL	TFS 2172
		moveMode := self.opts.int("MoveMode");
	endif;
	if self.opts.includesKey("IgnoreErrors") then	//20 Jun 2016	NDL	TFS 2172
		ignoreErrors := self.opts.bool("IgnoreErrors");
	endif;

	create params transient;
	_tiArray.copy(params.allTrackedItems);
	params.moveMode := moveMode;
	params.myTerminalArea := null;
	params.showWarningWhenNoPlan := false;
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	
	if not ignoreErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog
	delete params;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="autoplanWLE" id="fa7d1ab6-408c-4482-904d-7fd392e70f9d">
        <source>autoplanWLE( _wle : CM_WorkListEntry);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2013	cnwrd1	Initial creation

*/

vars
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin
	create wleArray transient;
	create wlesWithWarnings transient;
	wleArray.add(_wle);

	app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, QUEUE_MODE, app.myPassport);		
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="calculateTerminalAreaStats" id="595c0905-a14b-4f54-b0c2-f1fad951aedc">
        <source>calculateTerminalAreaStats(_ta: CM_TerminalArea);
//04 September 2008	cnwdw1	
//
vars
	termAreaSet : CM_TerminalAreaSet;
	yaBlockSet: CM_YABlockSet;
	oa: ObjectArray;
begin
	create termAreaSet transient;
	termAreaSet.add(_ta);
	create yaBlockSet transient;
	app.myTrxUA.trxCalcLocationStats(termAreaSet,yaBlockSet, oa, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete yaBlockSet;
	delete termAreaSet;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="calculateYABlockStats" id="c692e9b6-dd90-4785-a78e-b03d7e99cbab">
        <source>calculateYABlockStats(_ya: CM_YardAllocation);
//04 September 2008	cnwdw1	
//
vars
	yaBlock: CM_YABlock;
	yaBlockSet: CM_YABlockSet;
	termAreaSet : CM_TerminalAreaSet;
	oa: ObjectArray;
begin
	create yaBlockSet transient;
	foreach yaBlock in _ya.allYABlocksIn do
			yaBlockSet.add(yaBlock);
	endforeach;
	create termAreaSet transient;
	app.myTrxUA.trxCalcLocationStats(termAreaSet, yaBlockSet, oa, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete yaBlockSet;
	delete termAreaSet;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="checkTIForTxnOfType" id="7d381d17-86dc-48ab-b214-10b385511b4b">
        <source>checkTIForTxnOfType(_ti : CM_TrackedItem; _txnType : Integer);

/*

Purpose:		Check ti for transaction types passed to it	

Date			Who		Reason
15/08/2012  	cnwmh5	Initial creation

*/

vars

	tiTransaction		: CM_TITransaction;
	msg					: String;
	
begin
	
	tiTransaction := _ti.getLastTransOfType(_txnType);
	if tiTransaction = null then
		msg := app.myRoot.allTransactionTypes[_txnType].description &amp; " transaction not created for " &amp; _ti.id;
	endif;
	self.assertNullMsg(msg, msg);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txnType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkTIsForTxnOfType" id="446fc36f-895a-43cd-bd0f-de71356b9a0c">
        <source>checkTIsForTxnOfType(_tis : Collection; _txnType : Integer);

/*

Purpose:		Check tis for transaction types passed to it	

Date			Who		Reason
15/08/2012  	cnwmh5	Initial creation

*/

vars

	obj					: Object;
	ti					: CM_TrackedItem;
	
	iter				: Iterator;
	
begin
	
	iter := _tis.createIterator;
	while iter.next(obj) do
		ti := obj.CM_TrackedItem;
		self.checkTIForTxnOfType(ti, _txnType);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_tis" type="Collection"/>
        <Parameter name="_txnType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkTrxResult" id="826e7987-071a-4342-ba5a-36e4df71fbd1">
        <source>checkTrxResult();
//17 November 2008	cnwdw1	
// 05/08/2011 cwnmh5 Change to use class version of opts
// 13/08/2012 cnwmh5 Change to exit if Jade error found irrespective of whether self.IgnoreErrors is set
vars
	error : CM_Error;
begin
	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;
	
	if not self.opts.bool( self.IgnoreErrors ) then
		self.assertNoTrxErrorsOrWarnings();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkVoyageMyVessel" id="8c4d278d-8876-46a3-bc8c-3693c622f20d">
        <source>checkVoyageMyVessel(_voyage : CM_Voyage; _proxy : Boolean);

/*

Purpose:		Check that the created voyages myVessel is getting set correctly.  Currently have an issue where overnight it's not getting 
				updated correctly, but running it through the GUI and from a script it works.  So issue is overnight and this is for logging
				the details as it runs to see if there is a pattern.


Date			Who		Reason
20/June/2013	cnwmh5	Initial creation

*/

vars

	vessel 					: CM_Vessel;
	terminal				: CM_Terminal;

	terminalDtls			: String;
	myVesselDtls			: String;
	vesselDtls				: String;
	proxyDtls				: String;
	
begin

	terminalDtls := null;
	terminal := _voyage.getMyTerminal();
	if terminal &lt;&gt; null then
		terminalDtls := terminal.code &amp; Tab &amp; terminal.name;
	endif;
	
	myVesselDtls := null;
	if _voyage.myVessel &lt;&gt; null then
		myVesselDtls := _voyage.myVessel.code &amp; Tab &amp; _voyage.myVessel.name;
	endif;
	
	vesselDtls := null;
	vessel := app.myRoot.allVessels[_voyage.vesselCode];
	if vessel &lt;&gt; null then
		vesselDtls := vessel.code &amp; Tab &amp; vessel.name;
	endif;	
	
	if _proxy then
		proxyDtls := 'Proxy';
	else
		proxyDtls := "Real";
	endif;
	
	app.writeLog(proxyDtls &amp; Tab &amp; "terminal: " &amp; Tab &amp; terminalDtls &amp; Tab &amp; 'voyage: ' &amp; _voyage.code &amp; Tab &amp; _voyage.description &amp; Tab &amp; 'voyage vessel: ' &amp; Tab &amp; 
		_voyage.vesselCode &amp; Tab &amp; _voyage.vesselName &amp; Tab &amp; 'voyage myVessel: ' &amp; Tab &amp; myVesselDtls &amp; Tab &amp; "vessel: " &amp; Tab &amp; vesselDtls, LogINFO);
	

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_proxy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanupOfflineActors" id="0d07d18e-9ee9-411a-9aeb-a9e3f31c39b2">
        <source>cleanupOfflineActors();
// call at either the start or end of processing to remove all CM_OfflineFutureActors with no-longer valid parents
vars
	root	: CM_Root;
	futureActor	: CM_OfflineFutureActor;
begin
	root := app.myRoot;

	beginTransaction;
	foreach futureActor in root.allOfflineFutureActors do
		if not global.isValidObject(futureActor.myParentObject) then
			delete futureActor;
		endif;
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="clearBOLStopWithExpiry" id="1202f327-e841-4c28-b839-b970add48073">
        <source>clearBOLStopWithExpiry( _bol : CM_BOLIn input; _stopTable : CM_StopsTable; _expiryDate: Date);
// ---------------------------------------------------------------------------
// Created:	25 February 2015 By Graeme Black cnwgb1
// Status: 	Working on it
// Purpose:	
// ---------------------------------------------------------------------------
vars
    stop: CM_Stops;
begin
	if _stopTable &lt;&gt; null and not _stopTable.allowClearanceExpiryDate then	
        return;
    endif;
	stop := _bol.allStops[_stopTable.id];
	if stop = null then
		return;
	endif;    
	beginTransaction;
        stop.setClearanceExpiryDate(_expiryDate);
	commitTransaction;
epilog
end;</source>
        <Parameter name="_bol" type="CM_BOLIn" usage="input"/>
