    <JadeMethod name="resetTable" id="1911c65a-9924-409f-a1b5-589e1c2867f1">
        <updating/>
        <source>resetTable() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
//	jdtCurrent.clear;
	jdtCurrent.listCollection(app.myServerAppObject.allBackupSchedulesByStartTS, false, 1);
	jdtCurrent.refresh();
	
	self.setValidObjects();

	btnEdit.enabled		:=	false;
	btnReset.enabled	:=	false;
	btnDel.enabled		:=	false;
end;</source>
