        <source>setForUpdate(_proxyJob: CM_Job; _theTerminal: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin
	self.isPackParentJob := _proxyJob.CM_WOPackJob.isPackParentJob;
	inheritMethod(_proxyJob, _theTerminal);
epilog

end;</source>
        <Parameter name="_proxyJob" type="CM_Job"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
