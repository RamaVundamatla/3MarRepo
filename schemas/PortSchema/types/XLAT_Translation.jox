    <JadeMethod name="delete" id="0a0aa1e0-d029-4f95-8522-395d6fd80b77">
        <updating/>
        <source>delete() updating;

vars
	keyword : XLAT_Keyword;
	
begin
	foreach keyword in allKeywords do
		keyword.removeTranslation(myRoot.allXLAT_Categories[myTranslatableText.myConstantCategoryName], myTranslatableText,self); //12/Aug/08 cnwdz2 par17718
	endforeach;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
end;</source>
    </JadeMethod>
    <JadeMethod name="ex1035handler" id="fc1f0d34-59b7-45ee-89e4-1384eb316ee4">
        <source>ex1035handler(e:Exception):Integer protected;

// Skip String Too Long exceptions while parsing for keywords

constants 
	StringTooLong = 1035;
vars
begin
	if e.errorCode = StringTooLong then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeywords" id="1d227105-2a01-4451-94b8-5e758ba84b16">
        <source>getKeywords(_keywords:StringArray input);

// extract tokens for keyword indexing

constants
	WhiteSpace = #"09 0A 0B 0C 0D 20";
	MaxLength = 30;	// length limit on XLAT_Keyword::text
vars
	tokens 		: CnStringArray;
	shortTokens : CnStringArray;
	token		: String;
begin

	on Exception do ex1035handler(exception);

	// get tokens from text property
	create tokens transient;
	if text.trimBlanks &lt;&gt; null then
		text.replaceString(",", Tab).getWords(tokens);
	endif;
	

	// repeat for shortText property
	create shortTokens transient;
	if shortText.trimBlanks &lt;&gt; null then
		shortText.replaceString(",", Tab).getWords(shortTokens);
	endif;

	// copy to return collection, without duplicates
	_keywords.clear;

	foreach token in tokens where not _keywords.includes(token) do
		_keywords.add(token[1:MaxLength]);
	endforeach;

	foreach token in shortTokens where not _keywords.includes(token) do
		_keywords.add(token[1:MaxLength]);
	endforeach;
	
epilog
	delete tokens;
	delete shortTokens;
end;</source>
        <Parameter name="_keywords" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getName" id="f089869b-f483-4deb-8a55-e44658a49846">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     19 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; self.myTranslatableText.myConstantCategoryName &amp; '  ' &amp; self.myTranslatableText.number.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSubstitutes" id="fee3f09b-9ae4-4b87-b541-a31de0481633">
        <source>getNumberOfSubstitutes(_useShort : Boolean) : Integer;

/* ---------------------------------------------------------------------------
Created:	RBarr	8/8/06
Purpose:	Returns the number of %s subsititutions in a message
-------------------------------------------------------------------------------*/

begin
	if _useShort and shortText &lt;&gt; null then
		return shortText.getNumSubstituteParams;	
	else
		return text.getNumSubstituteParams;	
	endif;
end;</source>
        <Parameter name="_useShort" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTextWithSubstitutedParams" id="7764c3f5-73a9-41df-92fb-49c0eb8f63bf">
        <source>getTextWithSubstitutedParams(params : HugeStringArray) : String;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.useShortErrorMsg and self.shortText &lt;&gt; null then
		return self.shortText.substituteParams(params);
	endif;

	return self.text.substituteParams(params);

end;</source>
        <Parameter name="params" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslationText" id="a2763976-8bcc-426b-96d6-af9f778609a1">
        <source>getTranslationText(_shortText : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     04 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _shortText and self.shortText &lt;&gt; null then
		return self.shortText;
	endif;
	return self.text;
end;</source>
        <Parameter name="_shortText" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchKeywords" id="c35e5f04-0eab-44d6-b1aa-00dcc2d36f23">
        <source>matchKeywords(_keywords : StringArray; _matchAll : Boolean):Boolean;

vars
	text 	: String;
	found	: Boolean;
begin
	
	foreach text in _keywords do

		found := allKeywords[text] &lt;&gt; null;	// XLAT_KeywordByTextDict
		
		if _matchAll = true and not found then
			return false;
		endif;

		if not _matchAll and found then
			return true;
		endif;
		
	endforeach;

	return _matchAll;
	
end;</source>
        <Parameter name="_keywords" type="StringArray"/>
        <Parameter name="_matchAll" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
