    <JadeMethod name="getJobTypeDescription" id="30dd8146-669b-4334-8fa1-3bd65c952c4e">
        <source>getJobTypeDescription(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/02/2017	cnwdap1		Initial creation TFS 3489 LNX DLR/SOB
//
vars
	isDLR, isSOB : Boolean;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	str : String;

begin
	wle := self.workListEntries.first;
	if wle &lt;&gt; null then
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.getTransitStatus = TI_TransitStatusDLR then
				isDLR := true;
			elseif ti.isSOB then
				isSOB := true;
			endif;
		endif;
	endif;
	
	if self.jobType = JOB_TYPE_DISCHARGE then
		str := app.getErrorString(SHP_Discharge);
		if isDLR then
			str := str &amp; " DLR";
		elseif isSOB then
			str := app.getErrorString(SHP_Shift_On_Board);
		endif;
		return str;
	elseif self.jobType = JOB_TYPE_LOAD then
		str := app.getErrorString(SHP_Load);
		if isDLR then
			str := str &amp; " DLR";
		endif;
		if self.hasBulkRelease then
			str := str &amp; " BR";
		endif;
		return str;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleLinkingOnsiteCargo" id="03d8ccb2-6b9b-4636-b05a-ac5b41db49df">
        <updating/>
        <source>handleLinkingOnsiteCargo(_jobParams : CMIF_VoyageJobParams) updating;
//
// Purpose:			If the TI associated with this job is a prenote, look for on-truck cargo for the prenote
//					This cargo needs to be planned to the same place as the prenote
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11 February 2022	navdap1		Initial creation TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
//
vars
	ti, onsiteTi : CM_TrackedItem;
	iter : Iterator;
	wle : CM_VoyageWLE;
	otherWle : CM_WorkListEntry;
	roadWle : CM_YardWLE;

begin
	if not self.isDirectDelivery then
		return;
	endif;
	
	// releases only
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
	foreach ti in self.allReleaseTrackeditems do
		if ti.isPreNote then
			// look for onsite cargo on a truck, that has the same cargo type and id as this prenote
			iter.reset;
			self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(ti.cargoType, ti.id, iter);
			while iter.next(onsiteTi) do
				if onsiteTi.cargoType &lt;&gt; ti.cargoType or onsiteTi.id &lt;&gt; ti.id then
					break;
				endif;
				if not onsiteTi.myPrimaryActualLocation.isVehicle then
					continue;
				endif;
				
				roadWle := null;
				foreach otherWle in onsiteTi.allWorklistEntries where otherWle.isRoad do
					roadWle := otherWle.CM_YardWLE;
					break;
				endforeach;
				// got one - add it to this job, create wle for it, and adjust the job original amount
				onsiteTi.setDirectDelivery(true, false);
				self.allReleaseTrackeditems.add(onsiteTi);
				create wle persistent;
				wle.setMyTrackedItem(onsiteTi);
				wle.setWeight(onsiteTi.weight);
				if onsiteTi.totalQuantity &gt; null then
					wle.setQuantity(onsiteTi.totalQuantity);
				endif;
				wle.setLocations(onsiteTi.locationId, ti.plannedLocnId);
				wle.setJob(self);
				wle.updateRequest(self.allRequests.first);
				if ti.isBulkByQuantity then
					wle.setSubSeqNum(ti.totalQuantity);
					self.originalJobAmount := self.originalJobAmount + onsiteTi.totalQuantity;
				else
					wle.setSubSeqNum(ti.weight.Integer);
					self.originalJobAmount := self.originalJobAmount + onsiteTi.weight.Integer;
				endif;
				
				// plan this TI
				onsiteTi.moveToLocation(_jobParams.myLocation, self, wle, null, PLANNING_MODE, true, true, false, false, false, false, wle.quantity, wle.weight, null, null, null, app.myPassport);
				
				// also attach the new wle to the onsite ti's yard wle as a direct delivery child
				if roadWle &lt;&gt; null then
					wle.setMyDirectDeliveryParentWLE(roadWle);
				endif;
			endwhile;
		endif;
	endforeach;
epilog
	delete iter;
end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams"/>
    </JadeMethod>
    <JadeMethod name="handleRemoveUnactionedWLEs" id="9505a2db-5184-41a0-b4ea-f61f4c891d65">
        <updating/>
        <source>handleRemoveUnactionedWLEs(_removeRequests : CM_RequestSet input; _removeWLEs : CM_WLEArray) updating;
//
// Purpose:			FOR DIRECT DELIVERY VOYAGE HOLD JOBS ONLY
//					Don't purge requests that are linked to completed WLEs on myself
//					Update my status to Completed if all remaining WLEs are complete
//					For all TIs that are linked to incomplete WLEs to be removed, remove the TI's Direct Delivery flag
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/02/2022	navdap1		Initial creation TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
//
vars
	wle : CM_WorkListEntry;

begin
	if not self.isDirectDeliveryJob then
		return;
	endif;
	
	// Don't purge requests that are linked to completed WLEs on myself
	foreach wle in self.workListEntries do
		if wle.status = WLE_COMPLETED and _removeRequests.includes(wle.myRequest) then
			_removeRequests.remove(wle.myRequest);
		endif;
	endforeach;
	
	// Need to turn off the Direct Delivery flag for all WLEs that are about to be removed
	foreach wle in _removeWLEs where wle.status &lt;&gt; WLE_COMPLETED do
		if wle.myTrackedItem.directDelivery then
			wle.myTrackedItem.setDirectDelivery(false, false);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_removeRequests" type="CM_RequestSet" usage="input"/>
        <Parameter name="_removeWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="isDirectDeliveryJob" id="5cb62ac1-9d25-48d5-acf1-4782f548de53">
