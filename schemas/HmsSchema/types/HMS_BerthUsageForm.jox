//--------------------------------------------------
// 23 Feb 2012	NDL	Par 29120
vars

	date : Date;
	first : Date;
	last : Date;

begin

	date := app.actualTimeServer.date;
	if cmbYear.listIndex &gt; 0 then
		date.setDate(01,date.month,cmbYear.text.Integer);
	endif;
	first.setDate(01,date.month,date.year);
	last.setDate(01,date.month + 1,date.year);
	last := last - 1;
	//self.cmbMonth.listIndex := app.actualTimeServer.date.month;
	self.cmbMonth.listIndex := date.month;
	self.txtFromDate.setDate(first);
	self.txtToDate.setDate(last);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnThisYear_click" id="30e5e886-d657-470b-bd53-68ae7b498aa8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnThisYear_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
// 23 Feb 2012	NDL	Par 29120
vars

	year : Integer;
	date : Date;
	newDate : Date;

begin

	year := app.actualTimeServer.date.year;

	self.cmbYear.listIndex := self.cmbYear.findString(1, year.String);
	
	date := self.txtFromDate.getDate();
	if date &lt;&gt; null then
		newDate.setDate(01,date.month,year);
		self.txtFromDate.setDate(newDate);
	endif;
	
	date := self.txtToDate.getDate();
	if date &lt;&gt; null then
		newDate.setDate(01,date.month + 1,year);
		self.txtToDate.setDate(newDate - 1);
	endif;
	
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickOptions" id="7cb69131-fac6-4ef4-a147-9b4f707cc1e2">
        <source>clickOptions();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

begin

	if self.optMonthRange.value then
		self.grpDateRange.enabled := false;
		self.grpMonthRange.enabled := true;
	else
		self.grpDateRange.enabled := true;
		self.grpMonthRange.enabled := false;
	endif;
epilog

end;</source>
