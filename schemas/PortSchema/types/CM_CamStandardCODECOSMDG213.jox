    <JadeMethod name="getMessageType" id="8c860c47-6174-46db-a354-7e0214602a76">
        <source>getMessageType(_transaction: CM_TITransaction; _messageTypeArray: IntegerArray input; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input);
		
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
04/11/2019		jlgdi1		46578		Add CODECO_CANCEL msg type to the list of messages to process when required conditions are met
****************************************************/
vars
	trackedItem	: CM_TrackedItem;
	voyage 		: CM_Voyage;
begin
	_messageTypeArray.clear;
	if _transaction.type = TRANS_TYPE_DAMAGED then
		_messageTypeArray.add(CODECO_DAMAGED);
	elseif _transaction.type = TRANS_TYPE_REPAIR then
		_messageTypeArray.add(CODECO_REPAIRED);
	elseif _transaction.isCamsShipReceiveType() then  
		trackedItem := _transaction.myTrackedItem;
		if trackedItem &lt;&gt; null and not trackedItem.isRehandle then
			voyage := _transaction.getMyVoyage();
			if voyage &lt;&gt; null and voyage.isBarge then 
				_messageTypeArray.add(CODECO_GATEIN);
			endif;
		endif;
	elseif _transaction.isCamsShipReleaseType() then  
		trackedItem := _transaction.myTrackedItem;
		if trackedItem &lt;&gt; null and not trackedItem.isRehandle then
			voyage := _transaction.getMyVoyage();
			if voyage &lt;&gt; null and voyage.isBarge then 
				_messageTypeArray.add(CODECO_GATEOUT);
			endif;
		endif;
	elseif (_transaction.type = TRANS_TYPE_RCVROADCANCELLED) and (self.hasRoadReceiveBeenProcessed(_transaction)) then 
		_messageTypeArray.add(CODECO_CANCEL);		
	else
		inheritMethod(_transaction, _messageTypeArray, _camProtocol,_camAgent);
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXlatedVoyageCodes" id="8451f7ab-1cd3-4d46-83da-2247aa187fb6">
        <source>getXlatedVoyageCodes(_operatorCode : String; _inVoyageCode : String; _outOpVoyageCode, _outVoyVoyageCode : String io; _terminal: CM_Terminal);
		
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/

vars
	voyOperator : CM_Operator;
	opOperator 	: CM_Operator;
	matchFound 	: Boolean;
	voyage 		: CM_Voyage;
begin
	if _inVoyageCode.trimBlanks &lt;&gt; null then
		voyage := _terminal.lookupVoyage(_inVoyageCode, null, true);
		if voyage &lt;&gt; null then
			voyOperator := voyage.myOperator;
			if voyOperator &lt;&gt; null then
				_outVoyVoyageCode := voyOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
			else 
				_outVoyVoyageCode := _inVoyageCode.trimBlanks;
			endif;
		endif;
		opOperator := app.myRoot.allOperators[_operatorCode];
		if opOperator &lt;&gt; null then
			_outOpVoyageCode := opOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
		else 
			_outOpVoyageCode := _inVoyageCode.trimBlanks;
		endif;
	endif;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_inVoyageCode" type="String"/>
        <Parameter name="_outOpVoyageCode" type="String" usage="io"/>
        <Parameter name="_outVoyVoyageCode" type="String" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
