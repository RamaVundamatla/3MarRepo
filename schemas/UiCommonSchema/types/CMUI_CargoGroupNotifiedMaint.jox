    <JadeMethod name="setTableFromObjectSpecial" id="a7b86d88-b977-4413-96d0-3aed23758bc8">
        <source>setTableFromObjectSpecial(	pTbl : CM_EntryTable input;
							pAttrName : String;
							pRow : Integer;
							pObj : Object
							): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2018	jlgndl1	Initial creation	TFS 39186
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/

vars

	string : String;
	rtnValue : Boolean;
	cg : CM_CargoGroup;
	
begin
	
	cg := pObj.CM_CargoGroup;

	rtnValue := true;

	if pAttrName = ETRow_CargoGroupId then
		string := cg.id;
		
	elseif pAttrName = ETRow_CargoType then
		if cg.myCargoType &lt;&gt; null then
			string := cg.myCargoType.abbreviation;
			self.cmbCargoType.listIndex := self.cmbCargoType.findObject( cg.myCargoType );
		endif;
		
/*	elseif pAttrName = ETRow_CargoSubType then
		if cgn.myCargoSubType &lt;&gt; null then
			string := cgn.myCargoSubType.description;
			self.cmbSubCargoType.listIndex := self.cmbSubCargoType.findObject( cgn.myCargoSubType );
		endif;
*/		
	elseif pAttrName = ETRow_Operator then
		if cg.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				string := cg.myOperator.description;					// TFS 53362
			else														// TFS 53362
				string := cg.myOperator.code;
			endif;														// TFS 53362
			self.cmbOperator.listIndex := self.cmbOperator.findObject( cg.myOperator );
		endif;
	
	elseif pAttrName = ETRow_MinWeight then
		self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MinWeight, cg.minWeight, app.getDefaultMeasurementForType(Type_Weight) );
	
	elseif pAttrName = ETRow_MaxWeight then
		self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MaxWeight, cg.maxWeight, app.getDefaultMeasurementForType(Type_Weight) );
		
	else
		rtnValue := false;
		
	endif;
			
			
	if string &lt;&gt; null then
		pTbl.setValue(pRow, string);
	endif;
	
	return rtnValue;

epilog

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="06f1b60d-973e-47a9-8161-b83091acb362">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

begin

	inheritMethod();
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		self.setCaption( app.getErrorString1( Cargo_groups_notifie_within, self.myCargoGroupAssignment.id ) );
		self.btnNewTV.enabled := self.myCargoGroupAssignment.isSelectable;	//03 Oct 2018 - ( They can't add cargo so no point if its not selectable )
	else
		self.setCaption( app.getErrorString( Cargo_group_notified ) );
	endif;
	
	self.sptThumbEdit.showRightControl(67, true);

	self.populateEditCombos();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="13613477-ef62-4747-80fa-b103f3cec43b">
        <updating/>
        <source>showThumbnailData( _cg : CM_CargoGroup ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	canUpdate : Boolean;
	invalid : Boolean;
	edition : Integer;

begin

	canUpdate := _cg &lt;&gt; null;

	self.btnEditTV.enabled := canUpdate and self.allowUpdate;
	self.btnDeleteTV.enabled := canUpdate and self.allowUpdate;

	self.tblCGNInput.visible := false;

	self.resize();
	self.sptThumbEdit.cnEcResizeContents();
	
	on Exception do app.handleDeletedObject( exception, _cg, invalid );
	edition := _cg.edition;
	if invalid then
		self.tblCGNid.clear;
		self.tblThumb.clear;
		self.btnEditTV.enabled := false;
		self.btnDeleteTV.enabled := false;
		return;
	endif;
	
	self.populateCargoIdsTbl( _cg );

	if _cg = null then
		return;
	endif;
	
	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	
	self.showThumbnailForDef(ETDef_CGNData, _cg);
	
	self.tblThumb.cnEcResizeContents();
	
epilog

end;</source>
        <Parameter name="_cg" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5033063d-3441-44c3-9a49-943606d13d8d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:50:44.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022876, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="f79b2d11-4fd4-43b9-9d8e-3ce505492141">
        <updating/>
        <source>zDoAdd() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	invalid : Boolean;
	edition : Integer;

begin

	if self.myCargoGroupAssignment = null then
		invalid:= true;
	else
		on Exception do app.handleDeletedObject( exception, self.myCargoGroupAssignment, invalid );
		edition := self.myCargoGroupAssignment.edition;
	endif;
	if invalid then 
		self.btnNewTV.enabled := false;
		return;
	endif;
		
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyUpdate" id="cf4b0000-5453-40ef-a78e-bb2d26082882">
        <updating/>
        <source>zTblDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	invalid : Boolean;
	edition : Integer;
	cga : CM_CargoGroupAssignment;
	rowIndex : Integer;
	cg : CM_CargoGroup;
	string : String;

begin

	rowIndex := self.tblData.row;

	inheritMethod(eventType, theObject, eventTag);
	
	if theObject &lt;&gt; null and theObject.isKindOf( CM_CargoGroupAssignment ) then
		cga := theObject.CM_CargoGroupAssignment;
		if self.myCargoGroupAssignment &lt;&gt; cga then
			return;
		endif;
		
		on Exception do app.handleDeletedObject( exception, cga, invalid );
		edition := cga.edition;
		if invalid then 
			self.btnNewTV.enabled := false;
			return;
		endif;
		on Exception do null;
		
		if rowIndex &lt;= self.tblData.fixedRows or rowIndex &gt; self.tblData.rows then
			return;
		endif;
		
		self.tblData.column := 1;
		self.tblData.row := rowIndex;
		self.tblData.click( self.tblData );
		
	endif;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
