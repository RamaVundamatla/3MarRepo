<Class name="JSSCTPersistentServiceObject" id="609efcba-ca08-4152-bc60-1d43725b432b">
    <superclass name="JSSPersistentServiceObject"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <JadeMethod name="getPublicInterface" id="b03c9801-534f-4aa2-b12e-39ccb402c16e">
        <source>getPublicInterface(): JSSCTChangeTrackingInterface;
/*
*/
begin
	return(self.getServiceManager().JSSChangeTrackingServiceMgr.getPublicInterface());
end;</source>
        <ReturnType type="JSSCTChangeTrackingInterface"/>
    </JadeMethod>
    <JadeMethod name="monitor" id="5222ef60-2335-4161-9f22-49d81914010b">
        <source>monitor(pMessage: String);
/*
*/
vars
	ts: TimeStamp;
	notifier: JSSCTNotificationObject;
	processOidString: String;
begin
	notifier := JSSCTNotificationObject.firstInstance;
	notifier.causeEvent(JSSCT_Monitor_Note, true,
							ts.date.format("ddMMMyy ") &amp;
							ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
//							process.number.String &amp; " | " &amp;
							processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
							pMessage[1:2000]);

	//	log this message
	self.getPublicInterface().myJadeLog.logServer(pMessage);
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</Class>
