    <JadeMethod name="doFind" id="2e938e0a-c679-4d0e-9fcf-2c0799b74e68">
        <source>doFind();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	text : String;
	pos : Integer;
	restrictSearchTo : String;
	helpRequested : Boolean;
	helpStr : String;
	
begin
	if self.myTerminal = null then
		app.msgBox("Must select a terminal", "Error", MsgBox_OK_Only );
		return;
	endif;
	
	text := self.txtFind.text.trimBlanks;
	if text = null then
		app.msgBox("No 'Find' text entered", "Error", MsgBox_OK_Only );
		return;
	endif;
	
	helpRequested := text.trimBlanks.pos("?",1) &gt;= 1;
	if not helpRequested then
		pos := text.pos(" ",1);
		if pos &gt; 1 and pos &lt; text.length then
			restrictSearchTo := text[1:pos-1].toUpper.trimBlanks;
			text := text[pos+1:end].trimBlanks;
			if text = null then
				app.msgBox("No 'Find' text entered", "Error", MsgBox_OK_Only );
				return;
			endif;
		endif;
		
	elseif helpRequested then
		if text.trimBlanks.toUpper.pos("F",1) &gt; 0 then
			restrictSearchTo := "F";
			text := "?";
		endif;
	endif;
	
	if restrictSearchTo = "F" then
		self.openForm(restrictSearchTo, text);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getQuickAccess" id="240fca26-c1fd-4364-931f-b383d3c2aa06">
        <source>getQuickAccess(_byKeyText : String; _byPermission : Integer) : CM_QuickAccess protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	user : CM_User;
	quickAccess : CM_QuickAccess;

begin
	user := app.getMyUser;
	
	if user &lt;&gt; null and not user.allUserQuickAccess.isEmpty then
		//if the user has their own Quick Accesses, try these first
		if _byKeyText &lt;&gt; null then
			quickAccess := user.allUserQuickAccess.getAtKey( _byKeyText );
		elseif _byPermission &gt; 0 then
			quickAccess := user.getQuickAccessByPermission( _byPermission );
		endif;
	endif;
	
	if quickAccess = null then
		// No quick access found yet, try the default ones
		if _byKeyText &lt;&gt; null then
			quickAccess := app.myRoot.allSystemQuickAccess.getAtKey( _byKeyText );
		elseif _byPermission &gt; 0 then
			quickAccess := app.myRoot.getQuickAccessByPermission(_byPermission);
		endif;
	endif;
	
	return quickAccess;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_byKeyText" type="String"/>
        <Parameter name="_byPermission" type="Integer"/>
        <ReturnType type="CM_QuickAccess"/>
    </JadeMethod>
    <JadeMethod name="openForm" id="55c10d5c-ab64-45ed-b780-a5589500aab9">
        <source>openForm(_restrictSearchTo : String; _text : String) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	textString : String;
	keyText, dataText, modeText, baseText, tableName, rowName, valueName : String;
	spacePos, dataPos, modePos, tablePos, rowPos, valuePos : Integer;
	menuAction : CMUI_MenuAction;
	baseForm : CM_BaseForm;
	quickAccess : CM_QuickAccess;
	result : String;
	closeForm : Boolean;
	
begin
	// format is &lt;formname&gt; D=&lt;data - cargo id etc&gt; M=&lt;mode - U for update or Q for query&gt; T=&lt;tablename&gt; R=&lt;entrowname&gt; V=&lt;new value for ent row&gt;
	// F CARGO D=DAVE2006172 M=Q T=tblData R=billOfLading
	// will open the Cargo Enquiry form, enquire on DAVE2006172, and find the billOfLading value for DAVE2006172 from the data table (lower left table)
	// F CARGO D=DAVE2006172 M=U T=tblEdit1 R=billOfLading V=TESTBOL
	// will open the Cargo Enquiry form, enquire on DAVE2006172, go in to edit mode, change the billOfLading value in tblEdit1 to TESTBOL and save
	// F CARGO D=DAVE2006172 M=U T=tblEdit1 R=myOperator|billOfLading V=MSL|TESTBOL
	// will change operator to MSL and bill of lading to TESTBOL
	// For checkboxes, use Y or 1 to set and 0 to unset
	self.txtResult.text := null;
	
	// do we have to close the form afterwards?
	textString := _text;
	if _text[_text.length:1] = "X" then
		closeForm := true;
		spacePos := _text.reversePos(" ");
		textString := _text[1:_text.length-2];
	endif;
	spacePos := textString.pos(" ", 1);
	if spacePos &gt; 1 then
		keyText := textString[1:spacePos].trimBlanks;
		baseText := textString[spacePos:end].trimBlanks;
	else
		keyText := textString;
	endif;
	
	if baseText &lt;&gt; null then
		dataPos := textString.pos("D=", 1);
		if dataPos = null then
			app.msgBox("Incorrect format used, no data key found", "Error", MsgBox_OK_Only);
			return false;
		endif;
		
		modePos := textString.pos("M=", 1);
		if modePos = null then
			app.msgBox("Incorrect format used, no mode found", "Error", MsgBox_OK_Only);
			return false;
		endif;
		
		tablePos := textString.pos("T=", 1);
		if tablePos = null then
			app.msgBox("Incorrect format used, no table name found", "Error", MsgBox_OK_Only);
			return false;
		endif;
		
		rowPos := textString.pos("R=", 1);
		if rowPos = null then
			app.msgBox("Incorrect format used, no row name found", "Error", MsgBox_OK_Only);
			return false;
		endif;
		
		valuePos := textString.pos("V=", 1);
	else
		app.msgBox("Incorrect format used, no table name supplied", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	dataText := textString[dataPos+2:(modePos - dataPos - 3)];
	modeText := textString[modePos+2:1];
	tableName := textString[tablePos+2:(rowPos - tablePos - 3)];
	if valuePos = null then
		rowName := textString[rowPos+2:textString.length - rowPos - 1];
	else
		rowName := textString[rowPos+2:valuePos - rowPos - 3];
		valueName := textString[valuePos+2:textString.length - valuePos - 1];
	endif;
	
	quickAccess := self.getQuickAccess(keyText,0);	
	
	if quickAccess = null then
		self.buildQuickAccessFormsHelp( _restrictSearchTo, textString );
		return true;
	else
		if quickAccess.isForm then
			//to open new forms that have menus items
			menuAction := quickAccess.getMenuAction(self.myTerminal);
			if not quickAccess.allowsOption then
				baseText := null;
			endif;
			
			if menuAction &lt;&gt; null then
				baseForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
				if baseForm &lt;&gt; null then
					baseForm.show();
					baseForm.zAutomationAction(dataText, modeText, tableName, rowName, valueName, result);
					if closeForm then
						baseForm.unloadForm();
					endif;
					if result &lt;&gt; null then
						self.txtResult.text := result;
					endif;
					return true;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="c127a984-49e6-4280-a818-40fa51c7ce05">
        <updating/>
        <source>setMyTerminal() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	term : CM_Terminal;

begin

	if self.cmbTerminal.listIndex &gt; 0 then
		term := self.cmbTerminal.itemObject[ self.cmbTerminal.listIndex ].CM_Terminal;
	endif;
	
	self.myTerminal := term;
	
	if term = null then
		app.msgBox("Must select a terminal", "Error", MsgBox_OK_Only );
	endif;
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.myAssistant.setMyTerminal( term );
	self.setStatusCaption(null,0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusCaption" id="961012d4-977c-43b4-b6a4-8b83c232c229">
        <source>setStatusCaption(_string : String; _colour : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars

begin
	self.stlStatus.caption := _string;
	self.stlStatus.foreColor := _colour;
	//self.doWindowEvents(1);	// We only need to redraw the status bar, so just do that, its quicker
	self.stlStatus.refreshNow();
epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setUpForm" id="248abf21-4f40-4397-a77e-7b86166cd389">
        <updating/>
        <source>setUpForm(_term : CM_Terminal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	user : CM_User;
	iter : Iterator;
	userTerm : CM_UserTerminal;
	term : CM_Terminal;
	index : Integer;

begin
	user := app.getMyUser;
	
	if user = null then
		app.msgBox("No user found", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm;
		return;
	endif;
	if user.allUserTerminals.isEmpty then
		app.msgBox("No user terminals found", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm;
		return;
	endif;
	
	iter := user.allUserTerminals.createIterator;
	while iter.next( userTerm ) do
		term := userTerm.myTerminal;
		index := self.cmbTerminal.addItem( term.name );
		self.cmbTerminal.itemObject[ index ] := term;
	endwhile;
	
	if _term &lt;&gt; null then
		self.cmbTerminal.listIndex := self.cmbTerminal.findObject( _term );
	else
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			self.cmbTerminal.listIndex := self.cmbTerminal.findObject( term );
		else
			self.cmbTerminal.listIndex := 1;
		endif;
	endif;
	if self.cmbTerminal.listCount = 1 then
		self.cmbTerminal.enabled := false;
	endif;
	
	self.setMyTerminal();
	
	self.setStatusCaption( null, 0 );
	
	self.txtFind.text := "?";

epilog
	delete iter;	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="txtFind_change" id="9cbb1eaf-7c15-47b4-8482-a9591e115526">
