    <JadeMethod name="tblInput1_dblClick" id="4d25c9eb-87df-4371-a651-c2f907a68991">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput1_dblClick(table: CM_EntryTable input) updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 25/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 09/03/2018	jlfdap1		TFS 37427 PEL1 Voyage Status Enhancements
// 14/01/2019	jlgsl4		TFS 39618 - LNX - Invoice Approved Status
// 06/07/2022 	navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
// 04/07/2022   navds20		ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 18/07/23 	navcs2 		Bug 58916: MTN - External Web Service API Endpoint issues
// 09/08/2023	navkc1		CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status
// 31/08/2023 	navra1 		TFS 59839 - POB | QShips Integration - Editable Last Run Time
// 06/11/2023	navkc1 Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
// 09/09/2024	navdap1		TFS 66034 NSW OnePort Integration Post-Dev Demo Issues
// 08 Aug 2025	navhl20 	Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	row	: Integer;
	pCaption,pHint : String;
	hazard : CM_HazardClass;				// PAR #36421
	symbols : ObjectArray;					// PAR #36421
	

begin
	row := table.getRow(ETRow_HookCode);
	
	if table.row = row and row &gt; 0 then
		self.showHookCodeMaintForm();
		return;
	endif;

    row:= table.getRow(ETRow_TerminalsLastSuccessDT);                                                                                                                                       //MTN-36362
    if (self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService)) and table.row = row and row &gt; 0 then                                                                                         //MTN-36362
        self.myCurrentTableItem.SOPTM_ExtWebService.doShowLastSuccDTForm();                                                                                                                 //MTN-36362
    endif;                                                                                                                                                                                  //MTN-36362
    
	//navra1 - TFS 59839 - 29th Aug 2023 - start
	row := table.getRow(ETRow_LastSuccessfullTS);
	if (self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService)) and table.row = row and row &gt; 0 then
		if self.myProxyObject &lt;&gt; null and (self.myProxyObject.isKindOf(CM_QshipsWebServiceDef) or self.myProxyObject.isKindOf(CM_APIEndpointServiceDef))	// TFS 66034
			and table.userInputEnabled then
			if app.myCurrentUserCan(self.getMyTerminal, PmAdmAllowEditQShipLastSuccTS) then			
				table.showCalenderTimeForm(row, self.COLUMN_VALUE);
			else
				app.msgBox("You do not have necessary permissions to edit the last successful TS", "Error", MsgBox_OK_Only);
			endif;			
		endif;
	endif;
	//navra1 - TFS 59839 - 29th Aug 2023 - end
	
	//11 Jun 2018	NDL	TFS 39140
	row := table.getRow(ETRow_ProcessTerminal);
	if (self.myCurrentTableItem.isKindOf(SOPTM_VoyageProcess))
	and table.row = row and row &gt; 0 and self.mode &lt;&gt; self.Mode_Update then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_VoyageProcess) then
			self.myCurrentTableItem.SOPTM_VoyageProcess.doShowProcessTerminalForm( self, self.myCurrentObject.CM_VoyageProcess );
		endif;
	endif;
	
	//16 May 2018	NDL	TFS 38560
	row := table.getRow(ETRow_ProcessHarbour);
	if (self.myCurrentTableItem.isKindOf(SOPTM_VoyageProcess))
	and table.row = row and row &gt; 0 and self.mode &lt;&gt; self.Mode_Update then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_VoyageProcess) then
			self.myCurrentTableItem.SOPTM_VoyageProcess.doShowProcessHarbourForm( self, self.myCurrentObject.CM_VoyageProcess );
		endif;
	endif;
	
	//08 Feb 2019	NDL	TFS 43240
	row := table.getRow(ETRow_AddReportsForm);
	if (self.myCurrentTableItem.isKindOf(SOPTM_VoyageProcess))
	and table.row = row and row &gt; 0 and self.mode &lt;&gt; self.Mode_Update then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_VoyageProcess) then
			self.myCurrentTableItem.SOPTM_VoyageProcess.doShowAddReportsForm( self, self.myCurrentObject.CM_VoyageProcess );
		endif;
	endif;
	
	//26 Nov 2014	NDL	Par 35295
	row := table.getRow(ETRow_DefineAreas);
	if (self.myCurrentTableItem.isKindOf(SOPTM_SubTerminal))
	and table.row = row and row &gt; 0 then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_SubTerminal) then
			self.myCurrentTableItem.SOPTM_SubTerminal.doShowAreaDefinitionForm( self.myCurrentObject.CM_SubTerminal );
		endif;
	endif;
	
	//06 Mar 2018	NDL	TFS 37437
	row := table.getRow(ETRow_DefineRates);
	if (self.myCurrentTableItem.isKindOf(SOPTM_WorkPoint))
	and table.row = row and row &gt; 0 and table.accessRow(row).visible then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_WorkPoint) then
			self.myCurrentTableItem.SOPTM_WorkPoint.doShowRateDefinitionForm( self.myCurrentObject.CM_WorkPoint );
		endif;
	endif;
	
	row := table.getRow(ETRow_Symbols);											// PAR #36421
	if self.myCurrentTableItem.isKindOf(SOPTM_HazardClass) 						// PAR #36421
	and table.row = row and row &gt; 0 then										// PAR #36421
		hazard := self.myCurrentObject.CM_HazardClass;							// PAR #36421
		self.myAssistant.showPhotosForm(null, hazard, null, null, symbols, null);			// PAR #36421	//08.08.2025 navhl20 #35650
	endif;																		// PAR #36421
	
	// TFS 57207 start
	// 18/07/23 navcs2 Bug 58916
	// 24 Sep 2024 jlier1  TFS 65950: CR 65949 NSW | Dynamics Integration - External Web Service Definition Changes
	row := table.getRow(ETRow_Endpoints);
	if (self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService))
	and table.row = row and row &gt; 0 then	
		self.myCurrentTableItem.SOPTM_ExtWebService.doShowEndpointForm( );
	endif;
	// TFS 57207 end
	
    if self.mode = self.Mode_View then
		return;
    endif;  

	row := table.getRow(ETRow_LocationIds);
	
	if table.row = row and row &gt; 0 then
	    pHint := 'Enter the Location IDs to mask with, Each id should be on a separate line.';
	    pCaption := 'Location ID';
		self.myAssistant.showIdMaskWindow(tblInput1, row,pCaption,pHint);
		return;
	endif;
	
	row := table.getRow(ETRow_NotRailIds);
	
	if table.row = row and row &gt; 0 then
	    pHint := 'Enter the Not Rail Release Id to mask with, Each id should be on a separate line.';
	    pCaption := 'Not Rail Release ID';
		self.myAssistant.showIdMaskWindow(tblInput1, row,pCaption,pHint);
		return;
	endif;
	
	row := table.getRow(ETRow_NotRoadIds);
	
	if table.row = row and row &gt; 0 then
	    pHint := 'Enter the Not Raod Release Id to mask with, Each id should be on a separate line.';
	    pCaption := 'Not Road Release ID';
		self.myAssistant.showIdMaskWindow(tblInput1, row,pCaption,pHint);
		return;
	endif;
	
	if(self.myCurrentTableItem.isKindOf(SOPTM_FaultType)) then	
		self.myCurrentTableItem.SOPTM_FaultType.doShowEmailRecipientSelector();
	endif;
	
	// 21/05/2009 cnwar2 CCMS1040/#19796
	row := table.getRow(ETRow_CriteriaDblClick);
	if (self.myCurrentTableItem.isKindOf(SOPTM_ReceivalRestriction))
	and table.row = row and row &gt; 0 then
		self.myCurrentTableItem.SOPTM_ReceivalRestriction.doShowCriteriaForm();
	endif;
	
	//jlier1 JIRA-35632 22/8/25
	row := table.getRow(ETRow_Criteria);
	if (self.myCurrentTableItem.isKindOf(SOPTM_BestPickPriority))
	and table.row = row and row &gt; 0 then
		self.myCurrentTableItem.SOPTM_BestPickPriority.doShowCriteriaForm();
	endif;
	
	// TFS 37427 Email options, Event types and HMS resources
	row := table.getRow(ETRow_EmailOptions);
	if table.row = row and row &gt; 0 then
		if self.myCurrentTableItem.isA(SOPTM_VoyageStatus) then // TFS 39618
			self.myCurrentTableItem.SOPTM_VoyageStatus.doShowEmailForm();
		else // TFS 39618
			self.myCurrentTableItem.SOPTM_InvoiceStatus.doShowEmailForm(); // TFS 39618
		endif; // TFS 39618
	endif;
	
	row := table.getRow(ETRow_VoyageEvents);
	if table.row = row and row &gt; 0 then
		self.myCurrentTableItem.SOPTM_VoyageStatus.doShowEventSelectForm();
	endif;
	
	row := table.getRow(ETRow_HmsResourcesEst);
	if table.row = row and row &gt; 0 then
		self.myCurrentTableItem.SOPTM_VoyageStatus.doShowHMSSelectEstForm();
	endif;
	// TFS 37427 end
	
	//01 Aug 2018	NDL	TFS 39900
	row := table.getRow(ETRow_HmsResourcesApp);
	if table.row = row and row &gt; 0 then
		self.myCurrentTableItem.SOPTM_VoyageStatus.doShowHMSSelectAppForm();
	endif; 
	
	// START 24.06.2022 navtnr20 TFS 53697 
	row := table.getRow(ETRow_DefineMatchingCriteria);
	if (self.myCurrentTableItem.isKindOf(SOPTM_VehicleBookingType))
	and table.row = row and row &gt; 0 then
		// 06/11/2023	navkc1 Bug 61094 - Allow user to set criteria while adding new Timeslot type
		//if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_VehicleBookingTimeSlotType) then
			self.myCurrentTableItem.SOPTM_VehicleBookingType.doShowObjectCriteriaLineForm( self.myCurrentObject.CM_VehicleBookingTimeSlotType );
		//endif;
	endif;	
	// END	24.06.2022 navtnr20 TFS 53697 
	
	// start TFS 53862 navds20 04/07/2022
	row := table.getRow(ETRow_SetCriteria);
	if (self.myCurrentTableItem.isKindOf(SOPTM_Stops))
	and table.row = row and row &gt; 0 then
		// 06/11/2023	navkc1 Bug 61094 - Allow user to set criteria while adding new stop
		//if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_StopsTable) then
			self.myCurrentTableItem.SOPTM_Stops.doShowObjectCriteriaLineForm( self.myCurrentObject.CM_StopsTable);
		//endif;
	endif;
	// start TFS 53862 navds20 04/07/2022
	
	//09/08/2023	navkc1	CR 59580	Task 59588
	row := table.getRow(ETRow_SetCriteria);
	if (self.myCurrentTableItem.isKindOf(SOPTM_ShippingLineStatus))
	and table.row = row and row &gt; 0 then
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_ShippingLineStatus) then
			self.myCurrentTableItem.SOPTM_ShippingLineStatus.doShowObjectCriteriaLineForm();
		endif;
	endif;
epilog
	delete symbols;					// PAR #36421
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInput1_queryRowColChg" id="4b114e1d-1534-4152-858c-33852adf358c">
