    <JadeMethod name="trxUpdateUserEmail" id="6cf8c8b1-7027-4f07-b350-f71ea78cf238">
        <updating/>
        <source>trxUpdateUserEmail(_user : CM_User; _email : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2017	jlger1	Initial creation

*/

vars
	pxyEmailAddress,
	newEmail,
	existingEmail : CM_EmailAddress2;
	pxyUser 	: CM_User;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _email = null then
		app.raiseCMException(Input_required_field_emlAddres,
					  null, 
					  null);
		return;
	endif;
	
	
	beginTransaction;	
	
	existingEmail := app.myRoot.allEmailAddressesByAddress[_email];
	if existingEmail = null then
		//create new email
		create pxyEmailAddress transient;
		pxyEmailAddress.setProxyForEmailAddress(_email.trimBlanks.truncatedAt(30), _email, 0);
		app.myUtilityCA.utlCreateEmailAddress2(pxyEmailAddress, newEmail, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
	else
		//nothing to do
		if _user.myEmailEntity = existingEmail then
			return;
		endif;
		 existingEmail.validateForWebPortal();
		if app.myPassport.hasErrors then
			return;
		endif;
		newEmail:=existingEmail;
		
	endif;
		
	if newEmail &lt;&gt; null then
		beginLoad;
		pxyUser:=_user.pxyCreateUpdateProxy;
		endLoad;
		pxyUser.setEmail(newEmail);
		app.myUtilityUA.utlUpdateUser(pxyUser, null, _passport);
	endif;
epilog
	delete pxyEmailAddress;
	delete pxyUser;
	self.finaliseActivityWithPassport(_passport);
end;</source>
