    <JadeMethod name="setIsAnyIdAnyAmt" id="3afffba9-0047-426d-846c-a92376750d03">
        <updating/>
        <source>setIsAnyIdAnyAmt(_resDet : CM_ReserveDetail; _ct : CM_CargoType) updating;
/*

Purpose:			Code copied from CMUI_ReleaseCargoForm::initDetailsForByTypeByWeight &amp; CMUI_ReleaseCargoForm::setByTypeByWeight &amp; 
					CMUI_ReleaseCargoForm::doSave (Only some code needed, used this more for CMUI_Picker::setProxyGTEForJobCreation). Code needs merging and attributes added.

Parameters:			_resDet	CM_ReserveDetail	The reserve detail to use to check for any id any amount
					_ct		CM_CargoType		The cargo type to use to check for any id any amount

Return Value:		NONE

Date				Who		Reason
17 January 2025		navpw1	Initial creation JIRA: MTN-33825
13 February 2025	navpw1	JIRA: MTN-33961 - Setting isAnyId &amp; isAnyAmount from the reserve detail by default

*/

vars
	vbsProcess	: CM_VBSProcess;
	bulkRelease	: CM_BulkRelease;
	vbtsi		: CM_VehicleBookingTimeSlotItem;
	vvr			: CM_VehicleVisitRecord;
	
begin
	vvr := self.myVehicleVisitRecord;
	if _ct = null or _ct.id = TI_CargoType_Container then
		//releaseQty and releaseWeight are applicable only for General cargo
		return;
	endif;
	
	if _resDet = null or vvr = null then
		return;
	endif;
	
	vbsProcess := self.myTerminal.getMyVBSProcess();
	bulkRelease := _resDet.myReserveHeader;
	
	if bulkRelease = null then
		return;
	endif;
	
	if not bulkRelease.releaseByType then
		return;
	endif;
	
	if vvr &lt;&gt; null then
		vbtsi := _resDet.allVehicleBookingTimeSlotItems.first; //Assumption that the first vehicle booking time slot item connected to the reserve detail is the one we expected. Need to find a way to verify this.
		self.myVbtsi := vbtsi;
		
	endif;
	
	if vvr = null then
		return;
	endif;
	
	if _resDet.byTypeByWeight then
		self.isAnyId := true;
		self.isAnyAmount := true;
		
		if vbsProcess &lt;&gt; null and
			vbsProcess.isVbsSlotValidation and vbtsi &lt;&gt; null and vbtsi.maxWeight &gt; 0
		then
			self.releaseWeight := vbtsi.maxWeight;
			self.numItems := 1;
		endif;
		
	else//Release by quantity
		self.numItems := _resDet.totalRequested;
		self.releaseQuantity := _resDet.totalRequested;
		self.isAnyId := _resDet.defaultAnyId;				// ### JIRA: MTN-33825 13Feb2025 NAVPW1
		self.isAnyAmount := _resDet.defaultAnyAmount;		// ### JIRA: MTN-33825 13Feb2025 NAVPW1
		
		if vbsProcess &lt;&gt; null and
			vbsProcess.isVbsSlotValidation and vbtsi &lt;&gt; null and vbtsi.maxWeight &gt; 0
		then
			self.isAnyId := true;
			self.isAnyAmount := true;
			self.releaseWeight := vbtsi.maxWeight;
			self.numItems := 1;
		else
			if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and
				vbtsi &lt;&gt; null and vbtsi.quantity &gt; 0
			then
				self.numItems := vbtsi.quantity;
				self.releaseQuantity := vbtsi.quantity;
			endif;
			self.releaseWeight := null;
		endif;
	endif;
	
end;</source>
        <Parameter name="_resDet" type="CM_ReserveDetail"/>
        <Parameter name="_ct" type="CM_CargoType"/>
    </JadeMethod>
