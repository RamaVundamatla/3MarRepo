    <JadeMethod name="xCreateDeckJobSheet" id="f4a0ad3f-f6f2-4e4f-9164-72aef7be9ab0">
        <source>xCreateDeckJobSheet(_vesselName, _voyageCode,_wpCode : String) : CM_VoyageDeckJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	workPoints : ObjectArray;
	workPoint : CM_WorkPoint;
	voyage 		: CM_Voyage;
		vessel  : CM_Vessel;
operator : CM_Operator;
begin
	
	workPoint:=self.addWorkPoint(_wpCode, true);
	
	if workPoint = null then
		return null;
	endif;
	

	self.deleteVessel(_vesselName);
	operator := app.myRoot.allOperators["ANL"];
	vessel := self.addVesselLOLOholdsRORO(_vesselName,operator);
	
	if vessel = null then
		return null;
	endif;
	
	self.deleteVoyage(_voyageCode);
	voyage := self.addVoyageWithConRORO(_voyageCode, _vesselName, "ANL", "DOUG", null, 0, false, true);
	
	if voyage = null then
		return null;
	endif;
	
	create workPoints transient;
	workPoints.add(workPoint);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	return voyage.allJobSheets[workPoint.code].CM_VoyageDeckJobSheet;

epilog
	delete workPoints;
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_wpCode" type="String"/>
        <ReturnType type="CM_VoyageDeckJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xCreateDeckLayerLayoutCargo" id="afe55ab5-48f5-4ac9-abd9-94a1354c5a7d">
        <source>xCreateDeckLayerLayoutCargo(_deck : CM_DeckVessel);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	pxyLayerLayout, realLayerLayout: CM_DeckLayerLayout;
	newDeckItems : ObjectArray;
begin
	// ## PROXY
	create pxyLayerLayout transient;
	pxyLayerLayout.setProxy("Layer 1", "Layer One", null, _deck.myDeckLayout, true,ROROLayerType_Cargo);

	// ## CREATE
	app.myTrxCA.trxCreateDeckLayerLayout(pxyLayerLayout, realLayerLayout, false, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realLayerLayout, " realLayerLayout ");
	
	app.myTrxUA.trxUpdateROROLayerToTop(realLayerLayout, app.myPassport); 
	
	self.assertNoTrxErrorsOrWarnings();
	
	create newDeckItems transient;
	pxyLayerLayout := app.createUpdateProxy(realLayerLayout).CM_DeckLayerLayout;
	
	app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 100, 100, 5, 5, true, DeckItemLayoutType_Locn, 1, newDeckItems, app.myPassport); 
	
	self.assertNoTrxErrorsOrWarnings();
	

epilog
	delete pxyLayerLayout;
	delete newDeckItems;
end;</source>
        <Parameter name="_deck" type="CM_DeckVessel"/>
    </JadeMethod>
    <JadeMethod name="xCreateGCDischargJobForRORO" id="a38de14e-62ef-4ae4-a619-e3c8513cfe25">
        <updating/>
        <source>xCreateGCDischargJobForRORO(_voyage: CM_Voyage input; _workPoint: CM_WorkPoint; _deck: CM_DeckVoyage input; _x, _y: Integer; _cargoType: CM_CargoType; _count: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2012	cnwdw1	Initial creation
*/
vars
	roroLCs : CM_VoyageROROControllerArray;
