    <JadeMethod name="qrySOHLocation" id="ad1d70e1-d4c4-4fb2-ba16-c8a06aa4b32d">
        <updating/>
        <source>qrySOHLocation(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

vars
	numSelected		: Integer;
	jrwTrans		: CM_JRWOld;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	self.myRWLogDocket := self.createJRWTransient(CM_JRWOld).CM_JRWOld;
	jrwTrans := self.myRWLogDocket.CM_JRWOld;	
	jrwTrans.allSOHLocations.clear();
	_filter.filterObjects(jrwTrans.allSOHLocations, _passport);
	
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;

	if _filter.isKindOf(CMQF_SOHLocationLog) then 
		jrwTrans.showWeightColumn := _filter.CMQF_SOHLocationLog.showWeightColumn;
	endif;
	
	numSelected := jrwTrans.allSOHLocations.size; //which should always be 1, but whatever...
	
epilog
	
	return numSelected;
end;</source>
