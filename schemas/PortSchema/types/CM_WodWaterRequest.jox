    <JadeMethod name="createPxyHMSResourceProformas" id="ac312174-836b-40a2-a854-ca6dbb9c6c99">
        <source>createPxyHMSResourceProformas(_hmsUsed: HMS_ResourceUsedSet input; _movement: HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2018	jlgndl1	Initial creation	TFS 40933

*/

vars

	pxyResUsed : HMS_ResourceUsed;
	
begin
	
	create pxyResUsed transient;
	pxyResUsed.setProxy(	_movement.myHarbour,	//_harbour : HMS_Harbour;
							self.myHMSResourceType,	//_resourceType : HMS_ResourceType;
							self.myHMSResource,	//_rescource : HMS_Resource;
							null,	//_pxyVTMISTrans : HMS_VTMISTransaction;
							self.fromDateTime,	//_fromDateTime : TimeStamp;
							self.toDateTime,	//_toDateTime : TimeStamp;
							self.unitsUsed,	//_unitsUsed : Real;
							false,	//_poc : Boolean;
							self,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281 
							null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
							);
	pxyResUsed.setMyVoyageMovement( _movement );
	_hmsUsed.add(pxyResUsed);
		
epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
