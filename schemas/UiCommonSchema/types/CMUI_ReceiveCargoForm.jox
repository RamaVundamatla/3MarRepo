    </JadeMethod>
    <JadeMethod name="onContainerIdChange" id="b7b75636-c739-4f91-8d53-cdb4be199d1a">
        <updating/>
        <source>onContainerIdChange(_id: String; _ti : CM_TrackedItem) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/06/2009	cnwjk3	Initial creation
22/09/2016	cnwdap1	TFS 2651 If we have a booking and prenote isn't for this booking, ignore it
*/
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	cargoTypeID : Integer;
	cargoType  : CM_CargoType;
	prenote	: CM_TrackedItem;
	parent,
	proxyParent : CM_TrackedItem;
begin
	inheritMethod(_id, _ti);
	
	if self.isGeneralCargo() then
		cargoType := self.cmbType.getObject.CM_CargoType;
		if cargoType &lt;&gt; null then
			cargoTypeID:= cargoType.id;
		endif;
	else
		cargoTypeID:=TI_CargoType_Container;
	endif;
	
	//epr TFS 3880 4/4/17
	proxyParent:= self.getProxyParentTI();
	if proxyParent &lt;&gt; null then
		parent:=proxyParent.pxyGetRealObject;
	endif;
	prenote:=self.myTerminal.findPrenoteCargo(_id,cargoTypeID,parent,null);			//navra1 - TFS 60776 - 10th Oct 2023
		
	if prenote &lt;&gt; null and self.myBookingRefItem &lt;&gt; null and prenote.myBookingRefItem &lt;&gt; self.myBookingRefItem then		// TFS 2651
		prenote := null;																								// TFS 2651
	endif;																												// TFS 2651
	if prenote = null then
		return;
	endif;
	
	if  self.isFullContainer() and prenote.getCommodityObject().isEmpty then
		app.msgBox(app.getErrorString(WARNING_ID_MT_PRE_CONTAINER),app.getFormCaptionsString(Xlat_0010505), MsgBox_Exclamation_Mark_Icon);
	
	elseif self.isEmptyContainer() and not prenote.getCommodityObject().isEmpty then
		app.msgBox(app.getErrorString(WARNING_ID_NONMT_PRE_CONTAINER),app.getFormCaptionsString(Xlat_0010505), MsgBox_Exclamation_Mark_Icon);
	
	endif;

	self.setFieldsFromPreNote(prenote);

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="onDestinationChanged" id="7654ec74-24df-4bcd-a813-f1c19cf0bdff">
        <source>onDestinationChanged(_combo : ComboBox) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwjk3	Initial creation

*/

vars
	voyage			: CM_Voyage;
	operator 		: CM_Operator;
	dischargePort	: CM_Port;
	destination		: CM_Port;
begin
	destination := _combo.listObject.CM_Port;
	
	if destination = null then
		return;
	endif;
	
	voyage := self.cmbVoyageCode.listObject.CM_Voyage;
	operator := self.cmbOperatorCode.listObject.CM_Operator;
	if operator &lt;&gt; null then
		dischargePort := operator.getDischargePortFromDest(destination.code, voyage, null);	
		if dischargePort &lt;&gt; null then
			self.cmbDischargePort.setObject(dischargePort);
		endif;	
	endif;

epilog

end;</source>
