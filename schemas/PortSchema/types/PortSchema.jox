vars

begin
	// is called from initialize in DevSchema for initailizeDatabase creation.
	if app.myRoot &lt;&gt; null then
		return app.myRoot.getConfig(PicAppLogoJMT130X080).Binary;
	else
		return null;
	endif;
end;</source>
