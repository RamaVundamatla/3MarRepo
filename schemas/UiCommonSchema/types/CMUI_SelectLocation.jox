    <JadeMethod name="setColorsFromController" id="81ac57c8-9bf3-4f65-a672-3919a350c7fb">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
