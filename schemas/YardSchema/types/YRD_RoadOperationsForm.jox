    <JadeMethod name="moveTrackedItem" id="aa51c669-4eb8-4309-b567-b678999bf4de">
        <updating/>
        <source>moveTrackedItem(pToLocation : CM_LocationsController ; _wle : CM_WorkListEntry; _table : CM_DataTable input) updating, protected;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	moveController	: CMIF_MoveController;
	result		: Integer;
begin

	if app.myMoveController = null then
		return;
	endif;

	if pToLocation = null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, 'No Target Location found.', null, null);	
		return;
	endif;

	moveController := app.myMoveController;
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		//moveController.setJobForMove(_wle.job);
	endif;

	moveController.setMyToPrimaryLocation(pToLocation);
		
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	app.myMoveController := null;
	if moveController &lt;&gt; null then
		delete moveController;
	endif;
	_table.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <Parameter name="pToLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optGate_change" id="1508786d-d997-4bc3-b5e7-df51407313d4">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optGate_change(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
10 Jan 2022		navlw1		TFS# 52455 Initial creation
04 Feb 2022 	navlw1 		TFS# 52770 STWR - Review of 52455 (Error message being displayed when it shouldn't)

*/

vars

begin
	if optionbutton.value = true and self.allGates.isEmpty then // 04 Feb navlw1 TFS# 52770
		// check to see if we have gates selected 
		app.msgBox("No Gates have been selected. Please select at least one gate from show search available gates.", "No Gates Selected",  MsgBox_Information_Icon + MsgBox_OK_Only);
		optNone.value := true;
	endif;
epilog

end;</source>
