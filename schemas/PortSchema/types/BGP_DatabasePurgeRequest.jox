    <JadeMethod name="validateForCreate" id="37ccf9ed-fce0-4fdd-8f65-4f34e9b2b616">
        <source>validateForCreate();
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
//
//23/05/2012	cnwrs1	Par 29613
//20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//13 Feb 2023 	navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 	navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	ts				: TimeStamp;
	requestLimit,
	instancesSize	: Integer;
begin

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Terminal), null, self);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), null, self); // cnwdb2	PAR 35364
	endif;
	
	if not self.archiveDate.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
	endif;
	
	ts := app.actualTimeServer();
//	if self.archiveDate &gt; ts.Date then
//		app.raiseCMException(ERR_INVALID_TIMESTAMP, null, null);
//	endif;
	if self.purgeNavisSmartActivity then // ### TFS 50669 24AUG2021 NAVAB1
		if ts.date.cnEcAddDays(-7) &lt; self.archiveDate then // ### TFS 50669 24AUG2021 NAVAB1
			app.raiseCMException(Navis_smart_view_only_delet_ol, null, null); // ### TFS 50669 24AUG2021 NAVAB1
		endif;
		
	endif;	
	if self.archiveDate.cnEcAddMonths(3) &gt; ts.date then
		//app.raiseCMWarning1(Full_Replacement_Message, 'Date entered is less than 3 months old', null, null, self.myTerminal);//- cnwmd1, Par 20524
		app.raiseCMWarning(Date_less_than_three_months, null, null, self.myTerminal); //+ cnwmd1, Par 20524
	endif;
	
	requestLimit := self.getRequestLimit();
	instancesSize := self.class.instances.size + 1;	//SFW 1121 cnwrs1 Sept 2011
	if (requestLimit &gt; 0 and requestLimit &lt; instancesSize) then
		//app.raiseCMException1(Full_Replacement_Message, 'INFO &gt;&gt; Cannot create ' &amp; self.class.name &amp; ' as limit of ' &amp; requestLimit.String &amp; ' has been surpassed' , null, null); //- cnwmd1, Par 20524
		app.raiseCMException2(Cannot_create_limit_surpassed, self.class.name, requestLimit.String, null, null); //+ cnwmd1, Par 20524
	endif;
	
	if not self.purgeArchivedVoyages and
	not self.purgeArchivedLocations and
	not self.purgeEmptyBOLIns and
	not self.purgeOffsiteTis and
	not self.purgePrenotedTis and
	not self.purgeBookingRefTis and
	not self.purgeNavisSmartActivity and 			// ### TFS 50669 06AUG2021 NAVAB1
	not self.purgeNonContainerDiscrepancies and
	not self.purgeSundry and
	not self.purgeXlations and
	not self.purgeDDExtractHistory and
	not self.purgeLockTransactions and
	not self.purgeEDIData and
	not self.purgeMachineHistory and
	not self.purgeMenuUserItems and 				//par17772 cnwrs1 Aug 2008
	not self.purgeLogCheckScaleHdr and 				//par17772 cnwrs1 Aug 2008
	not self.purgeVehicleBookings and				//15 Apr 2013	NDL	Par 31393
	not self.purgeVehicleVisit and 					//par17772 cnwrs1 Aug 2008
	not self.purgeCargoPhotos and 					//01/12/2009 cnwdz2 par21808
	not self.purgeEventRequests and 				//23/05/2012	cnwrs1	Par 29613
	not self.purgeDutyDocs and						//21 Dec 2012	NDl	Par 30901
	not self.purgeReleasedCargoGroups and 			//22 Jun 2015	NDL	Par 36338	
	not self.purgeYardAllocationLogTrans and
	not self.truncateEDIInfoXML and					//13 Sep 2021	NDL	TFS 51718
	not self.purgeSecGateUnknTrucks and				// ### TFS 51994 01Oct2021 NAVPW1
	not self.purgeInterTerminalRailBOLs and 		//par16530 cnwrs1 May 2008
	not self.purgeAttachmentCargoTypes and 		// 13/02/2023 navhl20 #54900[56518]
	not self.purgeAttachmentContract and 		// 13/02/2023 navhl20 #54900[56518]
	not self.purgeAttachmentInvoices and 		// 13/02/2023 navhl20 #54900[56518]
	not self.purgeAttachmentVoyages and 		// 13/02/2023 navhl20 #54900[56518]
	not self.purgeAttachmentWorkOrders and 		// 13/02/2023 navhl20 #54900[56518]
	not self.purgeWorkOrderJobSheets and		//21.7.2023 navhl20 #58158
	not self.purgeReleaseRequests and              //16/09/2022 navmv20 TFS 53403
	not self.purgeVisitPhotos and					//11.08.2025 navhl20 #35650
	not self.purgeAgGatewayMessages then					//navra1 - MTN-35875- 5th Sep 2025-2
		app.raiseCMException(NoItemsSelected, null, null);
	endif;
	
	if not app.isAppropriateBGPRunning(self.class.name) then
		// app.raiseCMException1(Full_Replacement_Message, '(' &amp; self.class.text.cnEcGetTagValueOfName('display') &amp; ') -' &amp; app.getErrorString(Request_Cannot_Be_Created), null, null);	// cnwrl1 09/11/2009 PAR 17334 - what it was
		app.raiseCMException1( Request_Cannot_Be_Created, self.class.text.cnEcGetTagValueOfName('display'), null, null );
	endif;
	

end;</source>
    </JadeMethod>
</Class>
