    <JadeMethod name="validateForRT" id="a8be2754-a5d6-4206-9fbc-6eef043e2e88">
        <source>validateForRT( _queryName : String );
// -----------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
// -----------------------------------------------------------------

vars
	criteriaLine	: CM_SelectorCriteriaLine;
	
begin
	foreach criteriaLine in self.allCriteriaLines do 
		criteriaLine.validateForRT( _queryName );
	endforeach;

end;
</source>
        <Parameter name="_queryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b0acbe96-c254-4a0c-8eb0-8432e762420d">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     26 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyQueryLine		: CM_SelectorCriteriaLine;
begin
	foreach pxyQueryLine in self.allCriteriaByPropertyName do
		pxyQueryLine.validateForUpdate();	
	endforeach;

end;</source>
