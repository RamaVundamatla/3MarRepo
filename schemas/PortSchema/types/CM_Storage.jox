    <JadeMethod name="getCargoStartTime" id="877f60a9-7830-4de0-8db4-8e38d8228357">
        <source>getCargoStartTime(_calcType : Integer; _dateTime : TimeStamp) : TimeStamp;
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
vars
	voyage	: CM_Voyage;
	startTime	: TimeStamp;
begin
	startTime := _dateTime;
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				startTime := voyage.shipExchangeDate;
				if startTime = null then		// old voyage
					startTime := _dateTime;
				endif;
			endif;
		endif;
	endif;
	
	return startTime;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCargoStartTimeFSD" id="c314651f-5669-4b1e-8080-dd3ec19176be">
        <source>getCargoStartTimeFSD(_dateOption : Integer; _dateTime : TimeStamp) : TimeStamp;	
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Nov 2012	cnwjre1	CCMS 1295 Free storage days, nominated cargo/voyage start time
18 Feb 2021 cnwma1  Bug 50821: STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel onto Steinweg's Terminal, either Import or Transshipment.
01/06/2023	navkc1	CR 57995 Task 57996: JADE - Storage Config - Storage Receival Date - Now that we have option for Road and Rail Receival Type, include them in this method
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	logMessage	: String;
	voyage	    : CM_Voyage;
	startTime	: TimeStamp;
	ti          : CM_TrackedItem;
	dateOption	: Integer;					// 01/06/2023	navkc1	CR 57995 Task 57996
	child		: Boolean;					// 01/06/2023	navkc1	CR 57995 Task 57996
	unpackTrans	: CM_Unpack;				// 01/06/2023	navkc1	CR 57995 Task 57996
	parentTI	: CM_TrackedItem;			// 01/06/2023	navkc1	CR 57995 Task 57996
	wagonEvent	: CMEVT_WagonTransaction;	// 01/06/2023	navkc1	CR 57995 Task 57996
	truckEvent	: CMEVT_TruckEvent;			// 01/06/2023	navkc1	CR 57995 Task 57996
begin
	startTime  := _dateTime;
	dateOption := _dateOption;
	logMessage := method.qualifiedName &amp; " _dateOption="  &amp;_dateOption.String &amp; " _dateTime=" &amp; _dateTime.String;
	ti         := self.myTrackedItem;    //18.02.2021 cnwma1 #50821
	
	//01/06/2023	navkc1	CR 57995 Task 57996 
	unpackTrans := ti.getMyUnpackedFromTransaction();
	
	//01/06/2023	navkc1	CR 57995 Task 57996 - // If it has an unpack transaction, it was once a child.
	if unpackTrans &lt;&gt; null or ti.isChild() then
		child := true;
	endif;
	
	//01/06/2023	navkc1	CR 57995 Task 57996
	if child or (ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_SHIP and ti.receiptTransportMode &lt;&gt; 0) then
		dateOption := ti.getStorageReceivalDateOption(ti.receiptTransportMode, child);
	endif;
	
	//01/06/2023	navkc1	CR 57995 Task 57996 This TI is/was a child, we might want the actual discharge date
	if child then
		if dateOption = Storage_UnpackSameAsParent then
			
			parentTI := ti.myParent;
			// Not unpacked yet, return parent's day
			if parentTI &lt;&gt; null then
				return parentTI.getStartTimeFSD(_dateOption, _dateTime);
			// already unpacked, get parent from unpack transaction, return parent's day
			else
				parentTI := unpackTrans.getOtherTrackedItem();
				if parentTI &lt;&gt; null then
					return parentTI.getStartTimeFSD(_dateOption, _dateTime);
				endif;
			endif;
		elseif dateOption = Storage_UnpackActualUnpack then
			// Already unpacked
			if unpackTrans &lt;&gt; null then
				startTime := unpackTrans.dateTime;
			// Not unpacked yet
			else
				startTime := _dateTime;
			endif;
		endif;
	// 01/06/2023	navkc1	CR 57995 Task 57996 - Road/Rail receive
	elseif ti.receiptTransportMode = TI_TRANSMODE_ROAD or ti.receiptTransportMode = TI_TRANSMODE_RAIL then
		 // 01/06/2023	navkc1	CR 57995 Task 57996 - Truck/Wagon Receival
		if dateOption = Storage_RoadActualReceival or dateOption = Storage_RailActualReceival then
			startTime := ti.receivedDT;
		// 01/06/2023	navkc1	CR 57995 Task 57996 - Truck unload
		elseif dateOption = Storage_RoadActualUnload then
			truckEvent := ti.getLastTruckEventOfType(EVT_TruckCargoReceive);
			if truckEvent &lt;&gt; null then
				startTime := truckEvent.dateTime;
			endif;
		// 01/06/2023	navkc1	CR 57995 Task 57996 - Wagon unload
		elseif dateOption = Storage_RailActualUnload then
			wagonEvent := ti.getLastWagonEventOfType(EVT_WagonCargoReceive);
			if wagonEvent &lt;&gt; null then
				startTime := wagonEvent.dateTime;
			endif;
		endif;
	elseif _dateOption &gt; 0 then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if ti &lt;&gt; null and
		   ti.isExport and
		   ti.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				logMessage := logMessage &amp; " voyage=" &amp; voyage.code;
				// 30731 extend the test to use all of the free storage date options
				if _dateOption = Voyage_Ship_Exchange_Start then
					startTime := voyage.shipExchangeDate;
				elseif _dateOption = Voyage_Pilot_On_Board then
					startTime := voyage.pilotOnBoardDT;
				elseif _dateOption = Voyage_Anchor_Down then
					startTime := voyage.shipAnchorDownDT;
				elseif _dateOption = Voyage_Arrival then
					startTime := voyage.arrivedDT;
				elseif _dateOption = Voyage_Labour_On_Board then
					startTime := voyage.labourOnBoard;
				// 34917 more options added
				elseif _dateOption = Voyage_Rec_Labour_Ashore then
					startTime := voyage.labourOnShore;
				elseif _dateOption = Voyage_Rec_Ship_Exch_End then
					startTime := voyage.shipExchangeCompleteDT;
				elseif _dateOption = Voyage_General_Landing then				 //15 Mar 2016	NDL	TFS 1407
					//startTime.setDate( voyage.getGeneralLandingDate(true) );   //18.02.2021 cnwma1 #50821
					if ti &lt;&gt; null then                                           //18.02.2021 cnwma1 #50821
						startTime.setDate( ti.generalLandingDate);     		     //18.02.2021 cnwma1 #50821
						startTime.setTime(null);
					endif;
				elseif _dateOption = Voyage_Rec_First_Day_Avail then	//14 Dec 2016	NDL	TFS 3119/3038
					startTime.setDate( voyage.dateFirstAvailable);
					startTime.setTime(null);
				endif;
				if startTime = null then	// voyage date not set
					startTime := _dateTime;
				endif;
			endif;
		endif;
	endif;
	
	logMessage := logMessage &amp; " returning " &amp; startTime.String;
	app.invLog(logMessage, LogINFO.String);
	return startTime;
end;</source>
        <Parameter name="_dateOption" type="Integer"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDaysSinceReceival" id="9af8e1ef-45dc-41f9-9ea0-0023a0bbaa07">
        <source>getDaysSinceReceival() : Integer;
/*
Purpose:			
Date		Who		Reason
29 April 2015	cnwab1	Initial creation
20 May	 2024   navrv30 Bug 64181: EUP - 4013 error in UAT system
*/

vars
	calcType : CM_CalculationType;
	bank : CM_Bank;
	calcCode : Integer;
	days : Integer;
	endTime	: TimeStamp;
	tempDateTime : TimeStamp;

begin
	bank := self.getBusinessUnitObject();
	if bank &lt;&gt; null then
		calcCode := INV_CALC_TYPE_DAYS_SINCE_RECVL;
		// PAR 35469 calcType := bank.getCalcTypeForTransaction(self);
		calcType := self.getCalcTypeForTransaction(); // PAR 35469 
		if calcType &lt;&gt; null then
			calcCode := calcType.calculationType;
		endif;
		//20 May	 2024   navrv30 Bug 64181
		if self.dateTime.isValid() then
			tempDateTime := self.dateTime;
		else
			tempDateTime := self.createdTime;
		endif;
		if calcCode = INV_CALC_TYPE_DAYS_SINCE_RECVL then
			days := bank.evaluateDays(self.getStartDateTime(calcCode), tempDateTime).Integer;
		elseif calcCode = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			days := bank.evaluateDays(self.getStartDateTime(calcCode), tempDateTime).Integer;
		elseif calcCode = INV_CALC_TYPE_DAYS_ONSITE_AT then
			days := bank.evaluateDaysOnsite(self.getStartDateTime(calcCode), tempDateTime).Integer;
		//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
		elseif calcCode = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   calcCode = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
			endTime := self.getEndDateTime(calcCode);
			days := bank.evaluateDays(self.getStartDateTime(calcCode), endTime).Integer;
		else
			days := days.max((tempDateTime.date - self.getStartDateTime(calcCode).date)); // DEFAULT
		endif;
	else
		days := days.max((tempDateTime.date - self.getStartDateTime(calcCode).date));  // DEFAULT
	endif;
	
	return days;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForInvLineUsedCOO" id="b4ae5476-a7b5-4805-bb7f-f773861f0ce5">
        <source>getDebtorForInvLineUsedCOO(_invLineDesc: CM_InvoiceLineDesc; _didWeUseCOO : Boolean output): CM_Debtor;
/*
Purpose:			

Date		Who		Reason
07 February 2024	navab1	CR 58263 TASK 58264
*/

vars

	ti				: CM_TrackedItem;
	debtorToUse		: CM_Debtor;
	incoTerm		: CM_InvoiceINCOTerm;
	incoMapping		: CM_InvoiceINCOMapping;
	debtorType		: CM_DebtorType;
	stoExpDetl : CM_StorageExpiryDetail;
	cooHeader : CM_OwnershipChange;
begin
	
	ti := self.myTrackedItem;
	
	_didWeUseCOO := false;
	
	stoExpDetl := ti.getStorageExpiryDetaiForOp(self.operatorCode, self.dateTime);
	if stoExpDetl = null then
		return null; // CR 64873 TASK 65509 02AUG2024 NAVAB1
	endif;
	
	cooHeader := stoExpDetl.myOwnershipChange;
	if cooHeader = null then
		return null; // CR 64873 TASK 65509 02AUG2024 NAVAB1
	endif;

	if cooHeader.myOperatorStorage &lt;&gt; null then
		debtorToUse := cooHeader.myOperatorStorage.debtor;
		if debtorToUse &lt;&gt; null then
			_didWeUseCOO := true;
		endif;
	endif;
	
	if debtorToUse = null then
		incoTerm := cooHeader.myIncoterm;
		if incoTerm &lt;&gt; null then
			incoMapping := incoTerm.allINCOTermMappingsByInvLnType[_invLineDesc];
			
			if incoMapping &lt;&gt; null then
				debtorType := incoMapping.myDebtorType;
				
				if debtorType &lt;&gt; null then
					debtorToUse := _invLineDesc.getDebtorFromTIForCOO(ti, debtorType, self.dateTime); // CR 64873 TASK 65509 02AUG2024 NAVAB1
					if debtorToUse &lt;&gt; null then
						_didWeUseCOO := true;
					endif;
				endif;
				
			endif;
		else
			return null; // CR 64873 TASK 65509 02AUG2024 NAVAB1
		endif;
	endif;
	
	
	if debtorToUse = null then
		return null; // CR 64873 TASK 65509 02AUG2024 NAVAB1
	else
		return debtorToUse;
	endif;

epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_didWeUseCOO" type="Boolean" usage="output"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForInvoiceLine" id="669b52c3-784a-442a-9b85-7cc90a52171b">
        <source>getDebtorForInvoiceLine(_invLineDesc: CM_InvoiceLineDesc): CM_Debtor;
/*

Purpose:				For Future Storage transaction, we check whether there is a COO done in the TI.
						If so, get the debtor from COO

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 	ChangeRequest 58261 Task 58262: Jade - COO Storage Debtor
// ### TFS CR 58263 TASK 58264 23JAN2024 NAVAB1 - moved up from sub class
23 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	ti				: CM_TrackedItem;
	debtorToUse		: CM_Debtor;
	incoTerm		: CM_InvoiceINCOTerm;
	incoMapping		: CM_InvoiceINCOMapping;
	debtorType		: CM_DebtorType;
	stoExpDetl 		: CM_StorageExpiryDetail;
	cooHeader 		: CM_OwnershipChange;
	doLog 			: Boolean; 
begin 	
	doLog := app.canLogExtraDetail(); //27.02.2025 navah1	#34141
	
	ti := self.myTrackedItem;
	
	stoExpDetl := ti.getStorageExpiryDetaiForOp(self.operatorCode, self.dateTime);
	if stoExpDetl = null then
		return inheritMethod(_invLineDesc);
	endif;
	
	cooHeader := stoExpDetl.myOwnershipChange;
	if cooHeader = null then
		return inheritMethod(_invLineDesc);
	endif;

	if cooHeader.myOperatorStorage &lt;&gt; null then
		debtorToUse := cooHeader.myOperatorStorage.debtor;
	endif;
	
	if debtorToUse = null then
		incoTerm := cooHeader.myIncoterm;
		if incoTerm &lt;&gt; null then
			incoMapping := incoTerm.allINCOTermMappingsByInvLnType[_invLineDesc];
			
			if incoMapping &lt;&gt; null then
				debtorType := incoMapping.myDebtorType;
				
				if debtorType &lt;&gt; null then
					debtorToUse :=  _invLineDesc.getDebtorFromTIForCOO(ti, debtorType, self.dateTime); // ### JIRA 33015 04OCT2024 NAVAB1
				endif;
				
			endif;
		else
			return inheritMethod(_invLineDesc);
		endif;
	else
		if doLog then
			app.invLog("CONT - COO STORAGE OPERATOR used to derive debtor " &amp; debtorToUse.name &amp; " for '" &amp; self.getNiceName(), LogINFO.String);
		endif;
	endif;
	
	
	if debtorToUse = null then
		return inheritMethod(_invLineDesc);
	else
		if debtorToUse &lt;&gt; null then
			if debtorToUse.isSuspended then
				if doLog and debtorToUse &lt;&gt; null then
					app.invLog(debtorToUse.name &amp; " is suspended, not used", LogINFO.String);
				endif;
				debtorToUse := null;
			endif;
		endif;
		
		if debtorToUse = null then	
			debtorToUse := _invLineDesc.getDefaultDebtorFromTran(doLog,self);
		endif;
		
		if debtorToUse &lt;&gt; null then
			if doLog then
				app.invLog("Debtor used is " &amp; debtorToUse.name &amp; " for '" &amp; self.getNiceName(), LogINFO.String);
			endif;
		
		endif;
		
		return debtorToUse;
	endif;
	
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="94c7c6d7-7638-4cb9-9deb-5b7ce4916fc8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498
*/
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
//29 Mar 2016	cnwer1 TFS 1693 weight convert display issues
//29/02/2023	navkc1 CR 61899 Task 61901: Jade - Storage Logic Changes
vars

	lDetail, suffix : String;
	invLine : CM_InvoiceLine;
	calcType : CM_CalculationType;
	qty : Real;
	daysStored : Integer;
	days : Integer;
	storageConfig : CM_StorageConfig;
	amount : Decimal[14,3];
	amountUnit : String;
	storageDetail : CM_StorageDetail; //29/02/2023	navkc1 CR 61899 Task 61901
	includeFirstDay : Boolean;
	ti : CM_TrackedItem; //29/02/2023	navkc1 CR 61899 Task 61901
begin

	if _attrName = ETRow_Details or
	   _attrName = ETRow_Storage then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			
			if not self.allInvoiceLines.isEmpty then
				// get the number of days stored from the invoice line(s) quantity
				foreach invLine in self.allInvoiceLines discreteLock do
					// PAR DCT 24239
					if invLine.status = CM_InvoiceLine.STATUS_VOIDED then
						continue;
					endif;
					if calcType = null then
						calcType := invLine.getCalcType();
					endif;
					qty := qty + invLine.quantity;
					daysStored := daysStored  + invLine.calculateStorageDays();
				endforeach;
				// where the invoice line quantity includes volume/weight etc, undo the calculation to get the original number of days
				if calcType &lt;&gt; null then
					//epr TFS 1693 29/3/16 
					if calcType.calculationType = INV_CALC_TYPE_DAYS_VOLUME or calcType.calculationType =  INV_CALC_TYPE_CARGOVOLUMECONVT then
						amount:= self.totalVolume;
						amountUnit:="m3";
						if calcType.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then
							if calcType.myMeasurementType &lt;&gt; null then
								amount:= amount/calcType.myMeasurementType.conversionRate;
								amountUnit:= calcType.myMeasurementType.shortName;
							endif;
						endif;					
						lDetail := lDetail &amp; 'Volume (' &amp; amount.asStringJMT &amp; ' ' &amp; amountUnit &amp; ') * days stored (' &amp; daysStored.String &amp; ') = ' &amp; qty.String;
					elseif calcType.calculationType = INV_CALC_TYPE_DAYS_WEIGHT or calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
						if calcType.isUseCargoWeight() then
							amount := self.cargoWeight; //02/10/2025	navkc1 JIRA 36149
						else
							amount:= self.totalWeight;
						endif;
						amountUnit:="kg";
						if calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
							if calcType.myMeasurementType &lt;&gt; null then
								amount:= amount/calcType.myMeasurementType.conversionRate;
								amountUnit:= calcType.myMeasurementType.shortName;
							endif;
						endif;
					
						lDetail := lDetail &amp; 'Weight ('  &amp; amount.asStringJMT &amp; ' ' &amp; amountUnit &amp; ') * days stored (' &amp; daysStored.String &amp; ') = ' &amp; qty.String;
					elseif  calcType.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT then
						amount:= self.totalLength;
						if  calcType.myMeasurementType &lt;&gt; null then 
							amount:= amount/calcType.myMeasurementType.conversionRate;
							amountUnit:= calcType.myMeasurementType.shortName;
						endif;
								
						lDetail := lDetail &amp; 'Length ('  &amp; amount.asStringJMT &amp; ' ' &amp; amountUnit &amp; ') * days stored (' &amp; daysStored.String &amp; ') = ' &amp; qty.String;
					
					elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
						lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " TEU days";
					elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
						lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " Revenue/Tonne days";
						
					// Only show 'days' if the calc type in the invoice line is for days
					elseif calcType.isStorageCalculation() then
						lDetail := lDetail &amp; "Stored for " &amp; daysStored.String &amp; " days"; 
					else // TFS 4709
						 // If the calc type is not days the quantity shown is an accumulation of all the invoice line quantities
						 // So change it to be the difference in days between this and the previous transaction
						if self.startTransaction &lt;&gt; null and self.getBusinessUnitObject() &lt;&gt; null then
							daysStored := self.getBusinessUnitObject().evaluateDays(self.startTransaction.dateTime,self.dateTime).Integer;
							lDetail := lDetail &amp; "Stored for " &amp; daysStored.String &amp; " days"; // Only show 'days' if the calc type is for days
						else
							lDetail := lDetail &amp; "Invoice Quantity of " &amp; qty.String;
						endif;
					endif;
				endif;
			endif;

			if calcType = null then		// from 34735 if invoice lines are all null, no output was shown - it should drop into this code
				if self.startTransaction &lt;&gt; null then
					// if no invoice lines (so either in free storage period or no charging from transaction map),
					//	do the same as the CM_InvoiceLine quantity calculation to get the number of days
					// 31932 if this is the free storage transaction - noCharge = true, .startTransaction is not a CM_Storage
					//		then use the cargo item free storage period
					if self.noCharge and
					   self.myTerminal &lt;&gt; null and
					   self.myTerminal.myStorageConfig &lt;&gt; null and
					   not self.startTransaction.isKindOf(CM_Storage) then
					   
					   if self.myWorkOrderDtl &lt;&gt; null // TFS 43405 JLGAB1
					   and self.myWorkOrderDtl.isWorkOrderForRelease() then// TFS 43405 JLGAB1
							suffix := " "; // TFS 43405 JLGAB1
						   
					   else
							if self.myTrackedItem &lt;&gt; null then
								suffix := " free days, no charge."; // TFS 4709
								days := self.myTrackedItem.getFreeStorageDays();
							endif;
						endif;
					endif;
					if days = 0 then					
						suffix := " days";
						if self.noCharge then
							suffix := " days, no charge."; // TFS 4709
						   if self.myWorkOrderDtl &lt;&gt; null then // TFS 43405 JLGAB1
								suffix := suffix &amp; " " &amp; self.myWorkOrderDtl.getDisplayString(true) &amp; " Work Order"; // TFS 43405 JLGAB1
							endif;
						endif;
						
						days := self.getDaysSinceReceival();
						storageConfig := null; // TFS 1479 - AB found during testing
						if self.myTerminal &lt;&gt; null then // TFS 1479 - AB found during testing
							storageConfig := self.myTerminal.myStorageConfig;
						endif;
						
						//29/02/2023	navkc1 CR 61899 Task 61901
						ti := self.myTrackedItem;
						if ti &lt;&gt; null then
							storageDetail := ti.getMatchingFreeStorageDetail(null);
						endif;
						
						//29/02/2023	navkc1 CR 61899 Task 61901
						if storageDetail &lt;&gt; null then
							includeFirstDay := storageDetail.includeFirstDay;
						elseif storageConfig &lt;&gt; null then
							includeFirstDay := storageConfig.includeFirstDay;
						endif;
						
						// TFS 1479 if includeFirstDay and the storage is for no days disokay as for 1 day
						if //storageConfig &lt;&gt; null and
						   //storageConfig.includeFirstDay and
						   includeFirstDay and //29/02/2023	navkc1 CR 61899 Task 61901
						   days &lt;= 0 then
							days := 1;
						endif;
					endif;
		
 // TFS 4709					if calcType &lt;&gt; null and calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
 // TFS 4709						lDetail := lDetail &amp; "Stored for " &amp; days.String &amp;  " TEU days, no charge.";
 // TFS 4709					else
						lDetail := lDetail &amp; "Stored for " &amp; days.String &amp; suffix;  // TFS 4709 " days, no charge.";
 // TFS 4709					endif;
				else
					lDetail := lDetail &amp; "Stored for &lt;undefined&gt;";
				endif; 
			endif;
			if lDetail &lt;&gt; "" then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			else
				lDetail := self.urNumber.String;
			endif;			
			
			return lDetail;
			
		endif;
	elseif _attrName = ETRow_LocationId then	//15 Mar 2016	NDL	TFS 1407
		return self.location;						
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndDateTimeFSD" id="e09794f1-207f-4930-a723-59858552db13">
        <source>getEndDateTimeFSD(_calcType: Integer; _storageConfig: CM_StorageConfig): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2016	cnwndl1	Initial creation	TFS 3119 - moved down from CM_TITransaction
18 Feb 2021 cnwma1  Bug 50821: STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel onto Steinweg's Terminal, either Import or Transshipment.
29/02/2023	navkc1 CR 61899 Task 61901: Jade - Storage Logic Changes
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	logMessage	: String;
	includeLastDay,
	found	    : Boolean;
	dateOption	: Integer;
	voyage	    : CM_Voyage;
	endTime	    : TimeStamp;
	ti          : CM_TrackedItem;
	storageDetail : CM_StorageDetail;
	
begin
	endTime    := self.dateTime;
	logMessage := method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " self.dateTime=" &amp; self.dateTime.String;
	ti         := self.myTrackedItem;
	
	//29/02/2023	navkc1 CR 61899 Task 61901
	if ti &lt;&gt; null then
		storageDetail := ti.getMatchingFreeStorageDetail(null);
	endif;
	
	//29/02/2023	navkc1 CR 61899 Task 61901
	if storageDetail &lt;&gt; null then
		includeLastDay := storageDetail.includeLastDay;
	elseif _storageConfig &lt;&gt; null then
		includeLastDay := _storageConfig.includeLastDay;
	endif;
	
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
		dateOption := Voyage_Ship_Exchange_End;
	elseif _storageConfig &lt;&gt; null then
		if self.startTransaction &lt;&gt; null and self.startTransaction.isKindOf(CM_ReceiveShip) then
			dateOption := _storageConfig.shipReceivalType;
		else
			dateOption := _storageConfig.shipReleaseType;
		endif;
	elseif _calcType = INV_CALC_TYPE_DAYS_SINCE_RECVL 
	or  _calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM  	//28 Jun 2018	NDL	TFS 39338
	or  _calcType = INV_CALC_TYPE_DAYSINCE_REC_TEU
	or	_calcType = INV_CALC_TYPE_DAYSINCE_REC_RT 	//08 May 2018	NDL	TFS 38525
	or  _calcType = INV_CALC_TYPE_DAYS_WEIGHT
	or  _calcType = INV_CALC_TYPE_DAYS_VOLUME then
		endTime := self.dateTime;
	endif;
	
	if dateOption &gt; 0 then
		// if the item is still on-site don't get the voyage date, code below will use the transaction date instead
		if ti &lt;&gt; null and
		   ti.isExport and
		   ti.site = TI_SITE_ONSITE then
		// do nothing
		else
			voyage := self.getVoyage();
		endif;
		if voyage &lt;&gt; null then
			// 30731 add all of the free storage date options
			if dateOption = Voyage_Ship_Exchange_End then
				if voyage.shipExchangeCompleteDT &lt;&gt; null then
					endTime := voyage.shipExchangeCompleteDT;
					found := true;
				endif;
			elseif dateOption = Voyage_First_Day_Avail then
				if voyage.dateFirstAvailable &lt;&gt; null then
					endTime.setDate(voyage.dateFirstAvailable);
					found := true;
				endif;
			elseif dateOption = Voyage_Labour_Ashore then
				if voyage.labourOnShore &lt;&gt; null then
					endTime := voyage.labourOnShore;
					found := true;
				endif;
			elseif dateOption = Voyage_Departed then
				if voyage.departedDT &lt;&gt; null then
					endTime := voyage.departedDT;
					found := true;
				endif;
			elseif dateOption = Voyage_Pilot_Return then
				if voyage.shipPilotReturnDT &lt;&gt; null then
					endTime := voyage.shipPilotReturnDT;
					found := true;
				endif;
			// 34917 more options added
			elseif dateOption = Voyage_Rel_Labour_Onboard then
				if voyage.labourOnBoard &lt;&gt; null then
					endTime := voyage.labourOnBoard;
					found := true;
				endif;
			elseif dateOption = Voyage_Rel_Ship_Exch_Start then
				if voyage.shipExchangeDate &lt;&gt; null then
					endTime := voyage.shipExchangeDate;
					found := true;
				endif;
			elseif dateOption = Voyage_General_Landing then		//15 Mar 2016	NDL	TFS 1407
				/*18.02.2021 cnwma1 #50821
				if voyage.getGeneralLandingDate(true) &lt;&gt; null then
					endTime.setDate(voyage.getGeneralLandingDate(true));
					found := true;
				endif;
				*/
				//18.02.2021 cnwma1 #50821
				if ti &lt;&gt; null then
					if ti.generalLandingDate.isValid then
						endTime.setDate(ti.generalLandingDate);
						found := true;
					endif;
				endif;
				//18.02.2021 cnwma1 #50821
			endif;
		endif;
	endif;
	
	if found then
		logMessage := logMessage &amp; " endTime from voyage=" &amp; endTime.String;
	endif;

	//if _storageConfig &lt;&gt; null and
	   if not found and
			not includeLastDay then //29/02/2023	navkc1 CR 61899 Task 61901
		//if not _storageConfig.includeLastDay then
			endTime := endTime.addDays(-1);	// take the date back one day 
			logMessage := logMessage &amp; " not config includeLastDay, days-1";
		endif;
	//endif;

	logMessage := logMessage &amp; " returning endTime=" &amp; endTime.String;
	app.invLog(logMessage, LogINFO.String);
	return endTime;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="8c7ebf06-e72e-4cef-a7db-a16b6f7aaa6e">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bank : CM_Bank;
	calcCode : Integer;
	lDetail : String;
	days : Integer;
	calcType		: CM_CalculationType;
	daysStored		: Integer;
	invLine : CM_InvoiceLine;
	qty : Real;
	endTime	: TimeStamp;
begin
	lDetail := inheritMethod();
	
	if not self.allInvoiceLines.isEmpty then
		//th2 15/01/2007 PAR#13255
		/* AKB WAS 2007OCT
		calcType := self.invoiceLine.getCalcType();
		if calcType &lt;&gt; null then
			if calcType.calculationType = INV_CALC_TYPE_DAYS_VOLUME then
				if self.totalVolume &lt;&gt; null and self.invoiceLine.quantity &lt;&gt; null then //avoid division by 0
					daysStored := (self.invoiceLine.quantity / self.totalVolume).Integer;
				endif;
				lDetail := lDetail &amp; 'Volume (' &amp; self.totalVolume.String &amp; 'm3) * days stored (' &amp; daysStored.String &amp; ') = ' &amp; self.invoiceLine.quantity.String;
			elseif calcType.calculationType = INV_CALC_TYPE_DAYS_WEIGHT then
				if self.totalWeight &lt;&gt; null and self.invoiceLine.quantity &lt;&gt; null then //avoid division by 0
					daysStored := (self.invoiceLine.quantity / self.totalWeight).Integer;
				endif;
				lDetail := lDetail &amp; 'Weight (' &amp; self.totalWeight.String &amp; 'kg) * days stored (' &amp; daysStored.String &amp; ') = ' &amp; self.invoiceLine.quantity.String;
			else
				lDetail := lDetail &amp; "Stored for " &amp; self.invoiceLine.quantity.String &amp; " days";
			endif;
		endif;
		NOW */
		foreach invLine in self.allInvoiceLines discreteLock do
			// PAR DCT 24239
			if invLine.status = CM_InvoiceLine.STATUS_VOIDED then
				continue;
			endif;
			if calcType = null then
				calcType := invLine.getCalcType();
			endif;
			qty := qty + invLine.quantity;
		
		endforeach;
		if calcType &lt;&gt; null then
			if calcType.calculationType = INV_CALC_TYPE_DAYS_VOLUME then
				if self.totalVolume &lt;&gt; null and qty &lt;&gt; null then //avoid division by 0
					daysStored := (qty / self.totalVolume).Integer;
				endif;
				lDetail := lDetail &amp; 'Volume (' &amp; self.totalVolume.String &amp; 'm3) * days stored (' &amp; daysStored.String &amp; ') = ' &amp; qty.String;
			elseif calcType.calculationType = INV_CALC_TYPE_DAYS_WEIGHT then
				if self.totalWeight &lt;&gt; null and qty &lt;&gt; null then //avoid division by 0
					daysStored := (qty / self.totalWeight).Integer;
				endif;
				lDetail := lDetail &amp; 'Weight (' &amp; self.totalWeight.String &amp; 'kg) * days stored (' &amp; daysStored.String &amp; ') = ' &amp; qty.String;
			// PAR 24015
			elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " TEU days";
			elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
				lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " Revenue/Tonne days";
			else
				lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " days";
			endif;
		endif;
		
	else
		if self.startTransaction &lt;&gt; null then

/* WAS PAR 19601			
			days := days.max((self.dateTime.date - self.getStartDateTime().date)); // PAR 11255
NOW  */			
			bank := self.getBusinessUnitObject();
			if bank &lt;&gt; null then
				calcCode := INV_CALC_TYPE_DAYS_SINCE_RECVL;
				// PAR 35469 calcType := bank.getCalcTypeForTransaction(self);
				calcType := self.getCalcTypeForTransaction(); // PAR 35469 
				if calcType &lt;&gt; null then
					calcCode := calcType.calculationType;
				endif;
				if calcCode = INV_CALC_TYPE_DAYS_SINCE_RECVL then
					days := bank.evaluateDays(self.getStartDateTime(calcCode), self.dateTime).Integer;
				elseif calcCode = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
					days := bank.evaluateDays(self.getStartDateTime(calcCode), self.dateTime).Integer;
				elseif calcCode = INV_CALC_TYPE_DAYS_ONSITE_AT then
					days := bank.evaluateDaysOnsite(self.getStartDateTime(calcCode), self.dateTime).Integer;
				//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
				elseif calcCode = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
					   calcCode = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
					endTime := self.getEndDateTime(calcCode);
					days := bank.evaluateDays(self.getStartDateTime(calcCode), endTime).Integer;
				else
					days := days.max((self.dateTime.date - self.getStartDateTime(calcCode).date)); // DEFAULT
				endif;
			else
				days := days.max((self.dateTime.date - self.getStartDateTime(calcCode).date));  // DEFAULT
			endif;
// PAR 19601 to here
			
			// PAR 24015
			if calcType &lt;&gt; null and calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				lDetail := lDetail &amp; "Stored for " &amp; days.String &amp;  " TEU days, no charge.";
			elseif calcType &lt;&gt; null and calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
				lDetail := lDetail &amp; "Stored for " &amp; qty.String &amp; " Revenue/Tonne days, no charge";
			else
				lDetail := lDetail &amp; "Stored for " &amp; days.String &amp;  " days, no charge.";
			endif;
		else
			lDetail := lDetail &amp; "Stored for &lt;undefined&gt;";
		endif; 
	endif;
	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationStr" id="5da7c899-9ab3-41ba-aa56-50aa20375f78">
