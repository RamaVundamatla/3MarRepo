    <JadeMethod name="availableCargoTypes" id="5d2f8f5d-2eb8-4ad8-974a-ef5f2ba4aa69">
        <source>availableCargoTypes(_classColl: ClassColl input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2014	cnwrd1	Initial creation
*/
// 22 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation

vars


begin
	_classColl.add(CM_Container);
	_classColl.add(CM_TILC);
	_classColl.add(CM_Generator);
end;

</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
