    <JadeMethod name="setForCreate" id="7d437476-3ebb-42d4-b45c-87a205624d31">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);
	
	if _proxy.myOutputFormat_SS &lt;&gt; null then
		// local to snapshot
		self.myOutputFormat_SS := _proxy.myOutputFormat_SS;
	else
		// global XTAB
		self.setMyCM_Root( app.myRoot );
	endif; 
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9844f2f2-8f87-436a-ab64-094760793a2d">
        <updating/>
        <source>setForUpdate(_proxy :CM_OutputFormat_XTAB)updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/08/2010	cnwcs5		par 23706 - new property (hideRepeatedRowValues)
// ---------------------------------------------------------------------------
vars
	tab, pxyTab,
	row, pxyRow,
	col, pxyCol		:CM_XTABGrouping;
	field, pxyField	:CM_XTABField;
begin
	self.raiseExceptionIfTransient (method);
	
	self.exclusiveLock (self);
	
	inheritMethod (_proxy);
	
	self.mode						:= _proxy.mode;
	self.type						:= _proxy.type;	//24 Nov 2009	NDL	CCMS 1028
	self.displayTotalColumn			:= _proxy.displayTotalColumn;
	self.displayTotalRow			:= _proxy.displayTotalRow;
	self.grandTotalColumnHeading	:= _proxy.grandTotalColumnHeading;
	self.grandTotalRowHeading		:= _proxy.grandTotalRowHeading;
	self.showRepeatedRowValues		:= _proxy.showRepeatedRowValues;	// 18/08/2010 cnwcs5 par 23706

	// clear out all current children and re-create them later
	self.allTabs.purge;
	self.allRows.purge;
	self.allColumns.purge;
	self.allFields.purge;
	
	// create tabs
	foreach pxyTab in _proxy.allTabs do
		tab := pxyTab.cloneSelf (false);
		
		self.allTabs.add (tab);
	endforeach;
	// create rows
	foreach pxyRow in _proxy.allRows do
		row := pxyRow.cloneSelf (false);
		
		self.allRows.add (row);
	endforeach;
	// create columns
	foreach pxyCol in _proxy.allColumns do
		col := pxyCol.cloneSelf (false);
		
		self.allColumns.add (col);
	endforeach;
	// create fields
	foreach pxyField in _proxy.allFields do
		field := pxyField.cloneSelf (false);
		
		self.allFields.add (field);
	endforeach;
	
	// cnwrl1 13/01/2009
	// cause the required user notification immediately
	self.causeEvent( EVENT_SummaryTable_Update, false, process.userCode );
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
    <JadeMethod name="setGrandTotalColumnHeading" id="853760db-dff8-4182-9ca4-97e663b1e0ee">
