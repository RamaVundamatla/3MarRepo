    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="create" id="006a6df1-8b9e-4610-825c-767f71803aff">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.permissionView	:= PmAdmCalendarView;
	self.permissionMaint := PmAdmCalendarMaint;

epilog

end;</source>
