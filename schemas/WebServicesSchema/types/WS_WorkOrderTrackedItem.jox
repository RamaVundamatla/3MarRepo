    <JadeMethod name="delete" id="c2db54bd-cd89-4eaa-96e8-d6c3cac25160">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 December 2025	navpw1	Initial creation JIRA: MTN-36359 - Fixing up leaked transients

*/

vars

begin
	delete self.cargoType;
	delete self.product;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="af36a46b-3e25-4f2c-9757-2e676f8f3f76">
        <updating/>
        <source>setProxyFromObject(_object: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	realCargoType : CM_CargoType;
	realProduct	  : CM_Product;
begin
	inheritMethod(_object);
	
	self.billOfLading		:= _object.billOfLading;
	self.bookingReference	:= _object.bookingReference;

	self.commodity			:= _object.commodity;
	self.currentLocation	:= _object.getPrimaryLocationId(REAL_MODE);
	self.id 				:= _object.id;
	self.imexStatus			:= _object.getImExStatusString;
	self.operatorCode		:= _object.operatorCode;
	self.site				:= _object.site;
	self.totalQuantity		:= _object.totalQuantity;
	self.totalWeight		:=  _object.totalWeight.asStringJMT	;
	
	
	realCargoType := _object.myCargoType;
	if realCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(realCargoType);
	endif;
	
	realProduct := _object.myProduct;
	if realProduct &lt;&gt; null then
		create self.product transient;
		self.product.setProxyFromObject(realProduct);
	endif;
	
	if _object.myVoyage &lt;&gt; null then
		self.voyageCode := _object.myVoyage.code;
	endif;
	

	self.loadPort 		:= _object.loadPort;
	self.dischargePort	:= _object.dischargePort;
epilog

end;</source>
        <Parameter name="_object" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
