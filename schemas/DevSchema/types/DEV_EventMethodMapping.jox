<Class name="DEV_EventMethodMapping" id="3c3a01f9-59d1-4f7e-95bc-3d8f448eeb7f">
    <superclass name="DEV_SchemaObjectEntity"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="myClass" id="b37fb95c-92af-4ae5-a25a-811f1bb921aa">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_Class"/>
        <access>readonly</access>
        <Inverse name="DEV_Class::allEventMethodMappings"/>
        <Inverse name="DEV_Class::allEventMethodMappingsOrd"/>
    </ExplicitInverseRef>
    <PrimAttribute name="value" id="52b95f9a-c05e-4bb5-b413-884dfe1880df">
        <type name="String"/>
