    <JadeMethod name="initDataExtractFields_Stop" id="bfd0b155-2c6f-4413-a8d5-fd6de2187be9">
        <source>initDataExtractFields_Stop(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName	 : String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	
	fieldName := CM_TrackedItem::allStops.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_Stops, fieldName, "Stops Details");
	
	fieldName := CM_Stops::id.name;
	childField := self.initDataExtractField(null, CM_Stops.name, null, fieldName, INTEGER, "Stop ID", "Unique identification number of a stop", INTEGER, INTEGER_POSSIBLEVAL);	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_Stops::getMyStopTablDesc.name;
	childField := self.initDataExtractField(null, CM_Stops.name, null, fieldName, STRING, "Stop Description", "Stop descriptino", STRING, "No more than 30 characters and/or digits");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
epilog

end;</source>
