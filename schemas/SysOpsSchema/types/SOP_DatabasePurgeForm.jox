        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="1ee7fc33-9e19-48d6-8249-448f5e9a5063">
        <source>doDelete();
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
// 14/05/2012	cnwcs5	par 29450 - change in signature for trxDeleteActivityHistory
//								  - minor performance tweaks
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

	obj		: Object;
	coll	: CM_ActivityByCreatedTsTypeDict;	// par 29450
	msg		: String;
	size	: Integer;
	tempColl	: CM_ActivityByCreatedTsTypeDict;
	today : Date;
	excludedCount : Integer;
	genSysAct : CM_ActivityHistoryGeneralSys;
	actHist : CM_ActivityHistory;
	isDevEnviron : Boolean;
	
begin
	
	//06Mar 2015	NDL	Par 34583
	executeWhen JMTDevelopmentEnvironment;
	isDevEnviron := true;
	endExecuteWhen;
	
	create coll transient;
	
	if isDevEnviron then
		self.tblActivity.allSelectedObjects.copy (coll);
	else
		//06 Mar 2015	NDL	Par 34583
		today := app.actualTimeServer.Date;//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		create tempColl transient;
		self.tblActivity.allSelectedObjects.copy (tempColl);
		foreach actHist in tempColl discreteLock do
			if actHist.activityType = ActivityHistoryGeneralSys then
				if actHist.CM_ActivityHistoryGeneralSys.earliestDeleteDate &gt; today then
					if genSysAct = null then
						genSysAct := actHist.CM_ActivityHistoryGeneralSys;
					endif;
					excludedCount := excludedCount + 1;
					continue;
				endif;
			endif;
			coll.add(actHist);
		endforeach;
		if excludedCount &gt; 0 then
			msg := excludedCount.String &amp; " " &amp; genSysAct.getTypeDescription &amp; " Activity History(s) were unable to be deleted because they are less than 90 days old.";
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
		
	endif;

	size := coll.size;
	
	if size &gt; 0  then
		if size = 1 then
			msg := app.getErrorString2(ConfirmDelete, 'this', 'Activity History');
		else
			msg := app.getErrorString2(ConfirmDelete, 'these ' &amp; size.String, ' History Activities');
		endif;
		
		if app.msgBox(msg, app.getErrorString(Delete_Activity_History), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
			app.mousePointer := MousePointer_HourGlass;
			app.myTrxDA.trxDeleteActitivityHistory(coll,app.myPassport);
		endif;
	endif;

epilog
	delete coll;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doHistoryOptionSet" id="4dbab69e-a9b8-4f26-938b-d8e19e3ebb59">
        <updating/>
        <source>doHistoryOptionSet(_menuItem:MenuItem input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2010 by cnwdad1
//
// Purpose:		Sets the history option (menu) settings.
//
// Parameters:	_menuItem - A reference to the Menu Item that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				#userId		Initial creation (PAR #25672).
// --------------------------------------------------------------------------------
begin
	// You can only unset an item by setting another one. 
	if _menuItem.checked then
		return;
	else
		_menuItem.checked := true;
	endif;
	
	if self.mnuHistoryWeek1 &lt;&gt; _menuItem then
		self.mnuHistoryWeek1.checked	:=	false;
	endif;
	
	if self.mnuHistoryMonth1 &lt;&gt; _menuItem then
		self.mnuHistoryMonth1.checked	:=	false;
	endif;
	
	if self.mnuHistoryMonth3 &lt;&gt; _menuItem then
		self.mnuHistoryMonth3.checked	:=	false;
	endif;
	
	if self.mnuHistoryAll &lt;&gt; _menuItem then
		self.mnuHistoryAll.checked	:=	false;
	endif;
	
	self.doRefresh();
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="ad19b34c-cb52-4806-9fc5-788e315981bd">
        <updating/>
        <source>doRefresh() updating, protected;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/09/2010	cnwdad1		PAR #25672. Changed from show last 500, to using new
//							menu options for 1 week, 1 month, 3 months or all.
// 06/05/2013	cnwcs5		par 29777 - imporve performance.  Took out porgress display since we 
//							don't have to troll through the whole collection
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	activity		: CM_ActivityHistory;
	terminal		: CM_Terminal;
	ts				: TimeStamp;
	historyLabel	: String;
	coll			: MemberKeyDictionary;
	iter			: Iterator;
	count			: Integer;
begin
	inheritMethod();
	
	if self.fldPurge.topSheet &lt;&gt; self.fldPurgeSheet2 then
		// don't load till it is visible
		self.fldPurgeSheet2.tag 	:= self.RELOAD_TABLE;
		self.fldPurgeSheet2.caption := app.getErrorString(Garbage_Collection_History);
		return;		
	endif;
	
	self.fldPurgeSheet2.tag 	:= null;

	
	self.tblActivity.clearAllData();
	
	terminal := self.cmbTerminals.listObject.CM_Terminal;
	
	if terminal = null then
		return;
	endif;
	
	if self.mnuHistoryAll.checked then
		ts				:= null;
		historyLabel	:= app.getString(CM_LIT_ALL);
	else
		ts	:= app.actualTimeServer();
		
		if self.mnuHistoryWeek1.checked then
			ts				:=	ts.addDays(-7);
			historyLabel	:=	app.getString(Week_1);
			
		elseif self.mnuHistoryMonth1.checked then
			ts				:=	ts.addMonths(-1);
			historyLabel	:=	app.getString(Month_1);
			
		elseif self.mnuHistoryMonth3.checked then
			ts				:=	ts.addMonths(-3);
			historyLabel	:=	app.getString(Months_3);
		endif;
		
		ts.setTime (null);
	endif;
	
	coll := terminal.allActivityHistoryByType;
	iter := coll.createIterator;
	
	coll.startKeyLeq (ActivityHistoryDBPurge, app.actualTimeServer, iter);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// Note: actual order of items in table is handled by column organisor but read backwards so that 
	// the first 15000 are the most recent
	while iter.back (activity) do
		if iter.getCurrentKey (1).Integer &lt;&gt; ActivityHistoryDBPurge then
			break;
		endif;

		if ts &lt;&gt; null and iter.getCurrentKey (2).TimeStamp &lt; ts then
			break;
		endif;
		
		self.displayHistory(activity);

		count := count + 1;
		
		if count &gt; 15000 then	//11 Jun 2012	NDL	 Par 29671 - this is better than doing removes in displayHistory;
			break;
		endif;
	endwhile;
			
	self.fldPurgeSheet2.caption := app.getErrorString(Garbage_Collection_History) &amp; ' ' &amp; terminal.name &amp; " (" &amp; historyLabel &amp; ")";

	self.setCaption(app.getErrorString(Garbage_Collection) &amp;  ' - ' &amp; terminal.code);
	self.setNavigatorHeading(self.caption);
	self.showRequest();
	
	self.tblActivity.colourRows (self.colorRow1, self.colorRow2);	// par 29777
	
epilog	
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="77170e25-6a04-458b-9709-8249536d09b2">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	
	self.fldPurge.top 		:= self.topMargin;
	self.fldPurge.height 	:= self.clientHeight - self.topMargin;
	
	self.sptActivity.cnEcResizeContents();
	self.tblDatabasePurge.resetSize();
end;</source>
    </JadeMethod>
    <JadeMethod name="doRunPurge" id="6904fbcf-3a1d-4c3f-906b-175506176d7d">
        <updating/>
        <source>doRunPurge() protected, updating;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
////23/05/2012 cnwrs1 Par 29613
//9/11/17	  jlgns1  TFS 6960 QNS - Disk space issues and house keeping inside JMT
//13 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//20 Sep 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//06 May 2025 navma1  MTN-34768 MTN - Manual Garbage collection of Cargo Photos does not work
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

	isVoyage, isLocation,
	isDocket, isOffsite,
	isPrenote, isBookingRef,
	isNSActivity,
	isDiscrep, isMachine,
	isSundry, isXlation,
	isDDExtractHistory, isLockTransactions,
	isEDIData, isYardAllocationLogs, isMenuUserItems, 
	isLogCheckScaleHdr , isVehicleVisit, isCargoPhoto, isEventRequests 	: Boolean; 		//par16530 cnwrs1 may 2008
	isDutyDocs, isVehicleBookingSlots, isCargoGroups,
	isInterTerminalRailBOLs 											: Boolean;
	isPurgeSecGateUnknTrucks											: Boolean; 		// ### TFS 51994 29Sep2021 NAVPW1
	date																: Date;
	terminal															: CM_Terminal;
	whatIsRunning,
	msg																	: String;
	result																: Integer;
	maxDurationMinutes													: Integer;		//TFS 6960
	isTruncateEDIInfoXML 												: Boolean;		//13 Sep 2021	NDL	TFS 51718
	purgeReleaseRequests                                                : Boolean;      //16/09/2022 navmv20 TFS 53403
	purgeAttachCargoTypes   											: Boolean;   
	purgeAttachContracts   												: Boolean;  
	purgeAttachInvoices  								 				: Boolean;   
	purgeAttachVoyages  												: Boolean;  
	purgeAttachWorkOrders   											: Boolean;
	purgeWorkOrderJobSheet												: Boolean;
	purgeVisitPhotos													: Boolean;
	purgeAgGatewayMessages												: Boolean;			//navra1 - MTN-35875- 5th Sep 2025-2
begin
	terminal	:= self.cmbTerminals.listObject.CM_Terminal;
	if terminal = null then
		return;
	endif;

	date := self.tblDatabasePurge.getValueAsDate(ETRow_Date);

	isNSActivity := self.tblDatabasePurge.getValueByName(ETRow_NavisSmartActivity).Boolean; // ### TFS 50669 06AUG2021 NAVAB1
	if isNSActivity then 																	// ### TFS 50669 02AUG2021 NAVAB1
		whatIsRunning := CrLf &amp; app.getErrorString(Archive_navis_smart_activit); 			// ### TFS 50669 02AUG2021 NAVAB1
	endif;
	isVoyage := self.tblDatabasePurge.getValueByName(ETRow_ArchivedVoyages).Boolean;
	if isVoyage then
		whatIsRunning := CrLf &amp; app.getErrorString(Archived_Voyages);
	endif;
	isLocation := self.tblDatabasePurge.getValueByName(ETRow_ArchivedLocations).Boolean;
	if isLocation then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Archived_Locations);
	endif;
	isDocket := self.tblDatabasePurge.getValueByName(ETRow_ReceivalDockets).Boolean;
	if isDocket then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Receival_Dockets);
	endif;
	isOffsite := self.tblDatabasePurge.getValueByName(ETRow_OffsiteTrackedItems).Boolean;
	if isOffsite then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Off_Site_Deleted_Tracked_Items);
	endif;
	isPrenote := self.tblDatabasePurge.getValueByName(ETRow_Prenotes).Boolean;
	if isPrenote then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Prenotes);
	endif;
	isBookingRef := self.tblDatabasePurge.getValueByName(ETRow_BookingRef).Boolean;
	if isBookingRef then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(BookingRef);
	endif;
	isDiscrep := self.tblDatabasePurge.getValueByName(ETRow_Discrepancies).Boolean;
	if isDiscrep then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Non_Container_Discrepancies);
	endif;
	isMachine := self.tblDatabasePurge.getValueByName(ETRow_MachineHistory).Boolean;
	if isMachine then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Machine_History);
	endif;
	isDDExtractHistory := self.tblDatabasePurge.getValueByName(ETRow_DdExtractHistory).Boolean;
	if isDDExtractHistory then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(DDExtract_History);
	endif;
	isSundry := self.tblDatabasePurge.getValueByName(ETRow_Sundry).Boolean;
	if isSundry then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Sundry);
	endif;
	isEDIData := self.tblDatabasePurge.getValueByName(ETRow_EdiData).Boolean;
	if isEDIData then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(EDI_Data);
	endif;
	isLockTransactions := self.tblDatabasePurge.getValueByName(ETRow_LockTransactions).Boolean;
	if isLockTransactions then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Lock_transactions);
	endif;
	isXlation := self.tblDatabasePurge.getValueByName(ETRow_Xlation).Boolean;
	if isXlation then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(PurgeTranslations);
	endif;
	isYardAllocationLogs := self.tblDatabasePurge.getValueByName(ETRow_YardAllocationLogs).Boolean;
	if isYardAllocationLogs then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(PurgeYardAllocationLogs);
	endif;
	isMenuUserItems := self.tblDatabasePurge.getValueByName(ETRow_MenuUserItems).Boolean;
	if isMenuUserItems then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(SavedReports); 		//par17772 cnwrs1 aug 2008
	endif;
	isLogCheckScaleHdr := self.tblDatabasePurge.getValueByName(ETRow_LogCheckScaleHdr).Boolean;
	if isLogCheckScaleHdr then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Check_scale_header); //par17772 cnwrs1 aug 2008
	endif;
	//PAR1772 cnwsh3 14 October 2008  Purge Vehice Visits
	isVehicleVisit := self.tblDatabasePurge.getValueByName(ETRow_VehicleVisitRecords).Boolean;
	if isVehicleVisit then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Vehicle_visit_records);
	endif;
	
	//15 Apr 2013	NDL	Par 31393
	isVehicleBookingSlots := self.tblDatabasePurge.getValueByName(ETRow_VehicleBookingSlots).Boolean;
	if isVehicleBookingSlots then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Purge_vehicl_schedu_bookin_slo);
	endif;
	
	//21 Dec 2012	NDL	Par 30901
	isDutyDocs := self.tblDatabasePurge.getValueByName(ETRow_DutyDocs).Boolean;
	if isDutyDocs then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Duty_documents);
	endif;
	
	//22 Jun 2015	NDL	Par 36338
	isCargoGroups := self.tblDatabasePurge.getValueByName(ETRow_ReleasedCargoGroups).Boolean;
	if isDutyDocs then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Cargo_groups);
	endif; 
	
	//01/12/2009 cnwdz2 par21808
	isCargoPhoto := self.tblDatabasePurge.getValueByName(ETRow_CargoPhotos).Boolean;
	if isCargoPhoto then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Cargo_Photos);
	endif;
	//epr TFS 4157 28/4/17
	isInterTerminalRailBOLs:= self.tblDatabasePurge.getValueByName(ETRow_InterTermRailBOLs).Boolean;
	if isInterTerminalRailBOLs then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; self.tblDatabasePurge.getHeadingByName(ETRow_InterTermRailBOLs);
	endif;
	//13 Sep 2021	NDL	TFS 51718
	isTruncateEDIInfoXML := self.tblDatabasePurge.getValueByName(ETRow_TruncateEDIInfoXML).Boolean;
	if isTruncateEDIInfoXML then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Truncate_EDIInfo_XML);
	endif;	
	// ### TFS 51994 01Oct2021 NAVPW1
	isPurgeSecGateUnknTrucks := self.tblDatabasePurge.getValueByName(ETRow_SecGateUnknTrucks).Boolean;
	if isPurgeSecGateUnknTrucks then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Security_Gate_Unknown_Trucks);
	endif;
	
	//16/09/2022 navmv20 TFS 53403 - start
	purgeReleaseRequests :=self.tblDatabasePurge.getValueByName(ETRow_ReleaseRequests).Boolean;
	if purgeReleaseRequests then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Release_Requests);
	endif;
	//16/09/2022 navmv20 TFS 53403 - end
	
	//13/02/2023 navhl20 #54900[56518]
	purgeAttachCargoTypes :=self.tblDatabasePurge.getValueByName(ETRow_AttachFilesCargoTypes).Boolean;
	if purgeAttachCargoTypes then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Attachment_files_cargotypes);
	endif;
	
	//13/02/2023 navhl20 #54900[56518]
	purgeAttachContracts :=self.tblDatabasePurge.getValueByName(ETRow_AttachFilesContracts).Boolean;
	if purgeAttachContracts then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Attachment_files_contracts);
	endif;
	
	//13/02/2023 navhl20 #54900[56518]
	purgeAttachInvoices :=self.tblDatabasePurge.getValueByName(ETRow_AttachFilesInvoices).Boolean;
	if purgeAttachInvoices then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Attachment_files_invoices);
	endif;
	
	//13/02/2023 navhl20 #54900[56518]
	purgeAttachVoyages :=self.tblDatabasePurge.getValueByName(ETRow_AttachFilesVoyages).Boolean;
	if purgeAttachVoyages then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Attachment_files_voyages);
	endif;
	
	//13/02/2023 navhl20 #54900[56518]
	purgeAttachWorkOrders :=self.tblDatabasePurge.getValueByName(ETRow_AttachFilesWorkOrders).Boolean;
	if purgeAttachWorkOrders then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Attachment_files_workorders);
	endif;
	
	//21.7.2023 navhl20 #58158
	purgeWorkOrderJobSheet :=self.tblDatabasePurge.getValueByName(ETRow_WorkOrderJobSheets).Boolean;
	if purgeWorkOrderJobSheet then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Workorder_sheets);
	endif;
	
	//11.08.2025 navhl20 #35650
	purgeVisitPhotos := self.tblDatabasePurge.getValueByName(ETRow_VisitPhotos).Boolean;
	if purgeVisitPhotos then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Visit_photos);
	endif;
	
	//navra1 - MTN-35875- 5th Sep 2025-2
	purgeAgGatewayMessages := self.tblDatabasePurge.getValueByName(ETRow_AgGatewayMessages).Boolean;
	if purgeAgGatewayMessages then
		whatIsRunning := whatIsRunning &amp; CrLf &amp; app.getErrorString(Aggateway_messages);
	endif;
	
	maxDurationMinutes := self.tblDatabasePurge.getValueByName(ETRow_MaxDurationMinutes).Integer;
	
	msg := app.getErrorString1(Activate_Database_Purge, terminal.name);
	msg := msg &amp; CrLf &amp; app.getErrorString(DateStr) &amp; ' ' &amp; date.shortFormatJMT();
	msg := msg &amp; CrLf &amp; whatIsRunning;
	
	if not app.msgBox(msg, app.getErrorString(Database_Purge), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;	
	
	while true do
		app.myTrxCA.trxCreateDBPurgeRequest(	app.myPassport.myUser,
												terminal,
											 	date,
											 	isVoyage,
											 	isLocation,
											 	isDocket,
											 	isOffsite,
											 	isPrenote,
												isBookingRef,
											 	isNSActivity,  				// ### TFS 50669 02AUG2021 NAVAB1
											 	isDiscrep,
											 	isMachine,
											 	isSundry, 
												isXlation,
											 	isDDExtractHistory, 
											 	isLockTransactions,
											 	isEDIData,
												isYardAllocationLogs,
												isMenuUserItems,
												isLogCheckScaleHdr,
												isVehicleVisit,
												isEventRequests,			// 06.05.2025 navma1 #MTN-34768
												isCargoPhoto,				// 06.05.2025 navma1 #MTN-34768
												isDutyDocs,
												isVehicleBookingSlots,
												isCargoGroups,				 //22 Jun 2015	NDL	Par 36338
												isInterTerminalRailBOLs,
												isTruncateEDIInfoXML,		 //_truncateEDIInfoXML : Boolean;	//13 Sep 2021	NDL	TFS 51718
												maxDurationMinutes,			 //TFS 6960
												isPurgeSecGateUnknTrucks, 	 // ### TFS 51994 29Sep2021 NAVPW1
												purgeReleaseRequests,        // 16/09/2022 navmv20 TFS 53403
												purgeAttachCargoTypes,  	 // 13/02/2023 navhl20 #54900[56518]
												purgeAttachContracts,  	     // 13/02/2023 navhl20 #54900[56518]
												purgeAttachInvoices,  		 // 13/02/2023 navhl20 #54900[56518]
												purgeAttachVoyages,   		 // 13/02/2023 navhl20 #54900[56518]
												purgeAttachWorkOrders, 		 // 13/02/2023 navhl20 #54900[56518]
												purgeWorkOrderJobSheet,		//21.7.2023 navhl20 #58158
												purgeVisitPhotos,			//11.08.2025 navhl20 #35650
												purgeAgGatewayMessages,			//navra1 - MTN-35875- 5th Sep 2025-2
											 	app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
	endwhile;
	self.clearErrorWarnings();
	self.fldPurgeSheet2.setFocus();

epilog	
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowActivityHistoryDetails" id="e90677f6-46f7-4582-a9dd-68dd574926af">
        <source>doShowActivityHistoryDetails() protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetails	: CMUI_SystemAlertsDetails;
	activity 	: CM_ActivityHistory;
begin
	activity := self.tblActivity.accessRow(self.tblActivity.row).itemObject.CM_ActivityHistory;
	if activity = null then
		return;
	endif;
	if not activity.hasExtraDetail() then
		app.msgBox(app.getErrorString(No_Extra_Detail), app.getErrorString(No_Extra_Detail), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// Update the navigator

	create lDetails;
	lDetails.centreWindow;
//	lDetails.myActivityHistory := activity;
	lDetails.myObject := activity;
	lDetails.setMyTerminal(self.myTerminal);
	lDetails.setFocus();
	lDetails.show;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="31cd1448-022b-4320-b9bf-8d242545f18b">
        <updating/>
        <source>doUserNotify(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
// 06/05/2013	cnwcs5		par 29777 - imporve performance.
vars
	terminal	: CM_Terminal;
	event		: Integer;	
begin
	if _eventType = BGP_Object.BGP_DisplayUpdate then
		self.showRequest();
		return;
	endif;
	
	if self.fldPurgeSheet2.tag = self.RELOAD_TABLE then
		// don't bother it will be reloaded later
		return;
	endif;
	
	terminal := self.cmbTerminals.listObject.CM_Terminal;
	
	if terminal = null then
		return;
	endif;
	
	event := terminal.getEventFromTerminalEvent(_eventType);
	
	if event = EventTerminalActivityAdd then
		self.displayHistory(_userInfo.CM_ActivityHistory);
		
	elseif event = EventTerminalActivityDelete then
		self.tblActivity.removeDeletedObject(_userInfo.CM_ActivityHistory);
	endif;
	
	self.tblActivity.colourRows (self.colorRow1, self.colorRow2);	// par 29777
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
