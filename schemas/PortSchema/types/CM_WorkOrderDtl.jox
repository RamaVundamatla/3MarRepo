    <JadeMethod name="doActionTask" id="e8aed623-67cb-4763-9578-425ce0977640">
        <updating/>
        <source>doActionTask(_woActionIF : CMIF_WorkOrderAction;
		     _realJob	 : CM_Job io;
			 _passport   : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars

begin

	self.status := WO_STATUS_ACTIONED;
	
	// Create Update Transaction 
	if self.createTransWhenAction then
		// Create An Update Transaction
		self.createWOTransaction(self.TRANS_UPDATED, null, null);
	endif;
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Update);
epilog

end;</source>
