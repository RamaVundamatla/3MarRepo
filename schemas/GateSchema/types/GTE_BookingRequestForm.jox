    <JadeMethod name="setupContextMenuItems" id="5330e0c2-0b4e-46b6-8ee7-cf325fb15754">
        <updating/>
        <source>setupContextMenuItems(table : CM_DataTable input) updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
// 11/03/2010	cnwcs5	par 22605 - view permission
// 13/06/2013	cnwcs5	par 31670 - show receiedv/prenotes processing
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	proxy 	: CM_BookingRefItem;
	detail 	: CM_ReserveDetail;
begin
	
	self.mnuShowPrenoted.visible := true;
	self.mnuShowReceived.visible := true;
	self.mnuShowReleased.visible := true;
	self.mnuShowReserved.visible := true;
	
	self.mnuShowPrenoted.enabled := false;
	self.mnuShowReceived.enabled := false;
	self.mnuShowReleased.enabled := false;
	self.mnuShowReserved.enabled := false;
	self.mnuActsApplied.visible := false; //27 Sep 2016	NDL	TFS 2649 / 2001
	
	self.mnuEditEquip.visible 	:= true;							//+cnwml2 PAR19782 CCMS SFW 1079
	self.mnuDeleteEquip.visible := true;							//+cnwml2 PAR19782 CCMS SFW 1079
	self.mnuReserve.visible 	:= true;							//+cnwml2 PAR19782 CCMS SFW 1079
	
	self.mnuAddEquip.enabled 	:= btnAddDetail.enabled;			// 11/03/2010 cnwcs5 par 22605
	self.mnuEditEquip.enabled 	:= btnEditDetail.enabled;			// 11/03/2010 cnwcs5 par 22605
	self.mnuDeleteEquip.enabled := btnDeleteDetail.enabled;			// 11/03/2010 cnwcs5 par 22605
	
	self.mnuExportBooking.visible := true;
	
	
	if self.chkReceiveAsStoc.value then
		self.mnuExportBooking.enabled := true;
	else
		self.mnuExportBooking.enabled := false;
	endif;
	
	
	if table.allSelectedObjects.size &gt; 0  then
		proxy := table.allSelectedObjects.first.CM_BookingRefItem;		

		if proxy &lt;&gt; null then
			// Released Menu
			if proxy.hasReleasedCargo() then
				self.mnuShowReleased.enabled := true;
			endif;
			
			if proxy.hasReceivedCargo() then
				self.mnuShowReceived.enabled := true;
			endif;
			
			if proxy.hasPrenotedCargo() then
				self.mnuShowPrenoted.enabled := true;
			endif;
						
			// Reserved Menu - set fields from Reserve Details
			detail := proxy.myReserveDetail;
			if detail &lt;&gt; null then
				//if detail.allTrackedItems.size &gt; 0 then
				if detail.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
					self.mnuShowReserved.enabled := true;
				endif;
			endif;
			
			if proxy.myBookingRefItemActions &lt;&gt; null then
				self.mnuActsApplied.userObject := proxy.myBookingRefItemActions;
				self.mnuActsApplied.visible := true;
			endif;
		
		endif;
		
		//+cnwml2 PAR19782 CCMS SFW 1079 start
		if table.allSelectedObjects.size &gt; 1 then
			self.mnuEditEquip.visible 	:= false;
			self.mnuReserve.visible 	:= false;
		endif;
		
		if self.mnuReserve.visible then							// 11/03/2010 cnwcs5 par 22605
			self.mnuReserve.enabled := btnReserve.enabled;		// 11/03/2010 cnwcs5 par 22605
		endif;													// 11/03/2010 cnwcs5 par 22605
	else
		self.mnuEditEquip.enabled 	:= false;
		self.mnuDeleteEquip.enabled := false;
		self.mnuReserve.enabled		:= btnReserve.enabled;		// 11/03/2010 cnwcs5 par 22605
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f67ff24f-1072-4d43-9a6b-24253b51ac87">
        <updating/>
        <source>setupForm() updating;

// 10/03/2010	cnwcs5	par 22605 - set view/update access
vars
	addCaption : String;
	blankLength : Integer;
begin
	self.isRoll 				:= false;
	self.btnEnquiry.visible 	:= false;
	self.chkReconciled.enabled 	:= false;

	self.frmRemarks.zOrder(1);

	self.initTblBookingItems(ETDef_BookReqItem);

	self.myAssistant.listTablePackLocations(self.lstPackLocations);

	self.loadCombos;
	self.loadBooking;
	self.loadBookingItemTable();
	
	
	self.chkAdditionalReq.value := false;
	
	self.showHideAdditionalDetails();
	
	self.frmRemarks.top			:= self.txtRemarks.top;
	self.frmRemarks.left		:= self.txtRemarks.left;
	self.frmRemarks.backColor	:= self.backColor;
	
	self.setCaption(null);
	//bit of trickery to get the chk box to display in the groupbox with out a line through it
	blankLength := self.getTextExtent(" ");
	self.grpAdditional.caption		:= addCaption.padBlanks((self.chkAdditionalReq.width/blankLength).Integer);
	self.grpAdditional.borderStyle	:= Control.BorderStyle_3DSunken;
	self.grpLine.borderStyle 		:= Control.BorderStyle_3DSunken;							//+cnwml2 PAR19782 CCMS SFW 1079
	self.grpLine1.borderStyle 		:= Control.BorderStyle_3DSunken;							//+cnwml2 CCMS MSL 1012
	//self.grpBooking.borderStyle:=Control.BorderStyle_3DSunken;
	self.grpEquipment.borderStyle	:=Control.BorderStyle_3DSunken;
	
	self.canReserve := app.myCurrentUserCan (self.myTerminal, PmGteBookingRefReserve);	// 11/03/2010 cnwcs5 par 22605
	self.canUpdateNonPendingBooking	:= app.myCurrentUserCan (self.myTerminal, PmGteBookingRefNonPendMaint); // 11/03/2010 cnwcs5 par 22605
	self.canUpdate	:= app.myCurrentUserCan (self.myTerminal, PmGteBookingRefMaint);	// 11/03/2010 cnwcs5 par 22605
	
	if self.canUpdate then	// 10/03/2010 cnwcs5 par 22605
		self.setControlsForAddEdit;											// 10/03/2010 cnwcs5 par 22605
	else																	// 10/03/2010 cnwcs5 par 22605
		self.setControlsForView;											// 10/03/2010 cnwcs5 par 22605
	endif;																	// 10/03/2010 cnwcs5 par 22605
	
	chkNoEmptiesOut.zOrder(1);	// 01/03/2010 cnwcs5 par 22605
	chkReceiveAsStoc.zOrder(1);
	self.grpPack.zOrder(1);
	self.beginClassNotification(CM_BookingRef, false, Any_System_Event, Response_Continuous, null); //cnwrd1 	
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpAdditional.enabled:= false;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showHazardDetailsForm" id="188ad0ac-b64b-465a-8f0f-5555465b2c5f">
        <updating/>
        <source>showHazardDetailsForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars
	hazards : ObjectArray;
	obj : Object;

begin
	create hazards transient;
	foreach obj in self.lstHazards.allSelectedObjects do	
		hazards.add(obj);
	endforeach;
	self.myAssistant.showHazardousDetailsForm(self.myTerminal, null, null, self.myProxyBookingRef, hazards, false, self, self.myMasterMenuAction);
epilog
	delete hazards;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideAdditionalDetails" id="7f7ac19f-ff00-497f-bd77-b864332e64be">
        <updating/>
        <source>showHideAdditionalDetails()updating;

// 10/03/2010	cnwcs5	par 22605 - do not disable labels

constants 
	GapBetweenFrames = 5;
	DetailsHeight = 180;
vars
	addHeight,
	remHeight,
	btnHeight,
	minHeight : Real;
	addCaption: String;
	newHeight : Real;
begin
	if not self.chkAdditionalReq.value 
	and self.hasAdditionalDetails then
		self.chkAdditionalReq.value := true;
	endif;
	addHeight := self.grpAdditional.height;
	//remHeight := self.frmRemarks.height;
	btnHeight := self.frmButtons.height;

	self.grpAdditional.top:=self.grpBooking.top + self.grpBooking.height + GapBetweenFrames;
	if chkAdditionalReq.value then
		self.grpAdditional.visible := true;
		self.minimumHeight := 520;
		//self.frmRemarks.top := self.frmAdditional.top + addHeight + GapBetweenFrames;
		self.chkAdditionalReq.top:=self.grpAdditional.top - 5;
		self.chkAdditionalReq.left:=self.grpAdditional.left +10;
		self.chkAdditionalReq.zOrder(1);
		
		addHeight:= grpAdditional.height + GapBetweenFrames;
	else
		self.grpAdditional.visible := false;
		self.minimumHeight := 520 - addHeight.Integer - 5;
		self.chkAdditionalReq.top:=self.grpAdditional.top - 5;
		self.chkAdditionalReq.left:=self.grpAdditional.left +10;
		addHeight:= self.chkAdditionalReq.height + GapBetweenFrames;
	//	self.frmRemarks.top := self.frmBooking.top + self.frmBooking.height + GapBetweenFrames; 
	endif;
	
	self.grpEquipment.top := self.chkAdditionalReq.top  +  addHeight;//self.frmAdditional.top  + frmAdditional.height ;
	
	//cnwjo3 par 20606.  No point in setting the height smaller
	newHeight := self.grpEquipment.top + DetailsHeight + btnHeight + 25;
	if newHeight &gt; self.height then
		self.height := newHeight;
	endif;
	
	
	self.grpEquipment.height 	:= self.grpEquipment.top - self.frmButtons.top;		
	self.chkAdditionalReq.zOrder(1);
	
	self.showHideControlsEmpties();
	if not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		self.cmbTranshipPort.visible := false;
		//self.lblTranshipToPor.visible := false;	par 22605
	else
		self.cmbTranshipPort.visible := true;
		//self.lblTranshipToPor.visible := true;	par 22605
	endif;
	
	/*/+cnwml2 PAR20164 SFW CCMS 1091 start
	if self.chkNoEmptiesOut.value then
		self.grpBulkRel.enabled := true;
		self.lblRelease.visible := true;
		self.lblRelVa.visible := true;
	else
		self.grpBulkRel.enabled := false;
		self.lblRelease.visible := false;
		self.lblRelVa.visible := false;
	endif;*/
	//+cnwml2 PAR20164 SFW CCMS 1091 end
		
end;
</source>
    </JadeMethod>
    <JadeMethod name="showHideControlsEmpties" id="0875268a-61b5-486f-8027-08e342a00e61">
        <source>showHideControlsEmpties();
//17 September 2009	cnwml2
//10/03/2010	cnwcs5	par 22605 - do not disable labesl

vars

begin 
	if self.myProxyBookingRef &lt;&gt; null then
		if self.myProxyBookingRef.allReleaseRequests.first &lt;&gt; null then
			if self.myProxyBookingRef.isManagedEmptyRelease then //cnwrd1 par 23922 ccms 1091 11.10.2010
				if self.myProxyBookingRef.isReleaseEmptiesAllowed() then	// PAR 21656 19/02/2010. Packing release (Nelson Warehousing) has nothing to do with release empties out
					self.chkNoEmptiesOut.value := true;					
				endif;
			else
				//we arnt managing our own releases.
				self.chkNoEmptiesOut.value := false;	//cnwrd1 par 23922 ccms 1091 11.10.2010				
			endif;
		endif;
	endif;

	//setting to true	
	cmbCarrier.enabled			:= self.chkNoEmptiesOut.value;	// 	par 22605
	chkNoFullsIn.enabled	    := self.chkNoEmptiesOut.value;	// 	par 22605
	cmbDelivRelReasn.enabled	:= self.chkNoEmptiesOut.value;	// 	par 22605
	cmbLoadPort.enabled			:= self.chkNoEmptiesOut.value;	// 	par 22605
	cmbPoolPartner.enabled		:= self.chkNoEmptiesOut.value;	// 	par 22605
	cmbTransType.enabled		:= self.chkNoEmptiesOut.value;	// 	par 22605
	txtDispatchLocn.readOnly	:= not self.chkNoEmptiesOut.value;	// 	par 22605
	
	self.cmbLoadPort.enabled := self.chkNoEmptiesOut.value and self.chkNoFullsIn.value;
	
	self.txtPackLocations.enabled := self.chkNoEmptiesOut.value; // cnwrd1 ccms pol 2103 par 27856 14.7.2011
	self.dtPackBy.enabled := self.chkNoEmptiesOut.value;
	self.txtDelReleaseNo.enabled := self.chkNoEmptiesOut.value;
	
	self.lblRelease.visible := self.chkNoEmptiesOut.value;							
	self.lblRelVa.visible := self.chkNoEmptiesOut.value;								
	self.lblRelease.visible 	:= self.chkNoEmptiesOut.value;
	self.lblRelVa.visible 		:= self.chkNoEmptiesOut.value;
	self.lblReserve.visible 	:= self.chkNoEmptiesOut.value;
	self.lblReserveVal.visible 	:= self.chkNoEmptiesOut.value;
	self.lblMax.visible 		:= self.chkNoEmptiesOut.value;
	self.lblMaxVal.visible 		:= self.chkNoEmptiesOut.value;

	//epr par 36556 6/4/15
	self.cmbPackAs.enabled := true;
	
	self.cmbFromVoyage.enabled := self.chkRecieveAsTran.value;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="splitOrRollVoyage" id="d1ae4ed3-1982-43a1-b855-7c3bff036e80">
        <updating/>
        <source>splitOrRollVoyage(_isSplit : Boolean)updating;

vars
	form : Form;
	//typeStr : String;
	modalResult : Integer;
begin

	if self.myCurrentBookingRef =  null then
		return;
	endif;
	
	/*if _isSplit then
		
		typeStr:="split";
	else
		typeStr:="roll";
	endif;*/
	
	//-cnwml2 PAR24322
	/*if self.myCurrentBookingRef.myVoyage = null or self.myCurrentBookingRef.myVoyage.isNullVoyage then
		app.raiseCMException1(Must_spec_voyage_before_split, self.myCurrentBookingRef.bookingReference.asStringJMT(), null, null);
		return;
	endif;*/
	self.hideUpdateMessage := true;
	form	:= 	app.loadForm(GTE_BookingRollSplitForm,
					GTE_Assistant,
					false, false, true,
					self.myTerminal,
					null);
	form.GTE_BookingRollSplitForm.setIsSplit(_isSplit);
	if self.myCurrentBookingRef &lt;&gt; null then
		form.GTE_BookingRollSplitForm.setBookingRef(self.myCurrentBookingRef);
	endif;
	
	modalResult:=form.showModal;
	
	if modalResult = IDCANCEL then
		/*if isNewItem then
			delete pxyBookingRefItem;
		endif;*/
		return;
	endif;

	//form.GTE_BookingRollSplitForm.setupForm;
end;
</source>
        <Parameter name="_isSplit" type="Boolean"/>
    </JadeMethod>
