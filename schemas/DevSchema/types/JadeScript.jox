    <JadeMethod name="djwCountTis" id="98556f66-caec-4a21-9aec-3204f792e890">
        <source>djwCountTis();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2012	cnwdw1	Initial creation
*/
vars
	ti: CM_TrackedItem;
	c: Integer;
	e: Integer;
begin
	app.initialize();
	foreach ti in app.myRoot.allTerminals.first.allOnsiteTIsByCargoTypeId do
		c := c + 1;
		if ti.myTranshipDetail &lt;&gt; null and ti.myTranshipDetail.myDischargePort = null then	
		   e := e + 1;
		app.msgBox(ti.id, "TI", MB_OK);
		endif;
	endforeach;
	app.msgBox(e.String, "Count", MB_OK);
end;</source>
    </JadeMethod>
    <JadeMethod name="djwRefactor1" id="710c195e-c9dd-4f6d-94d4-613b8a49875e">
        <source>djwRefactor1();
//01 August 2008	cnwdw1	
// Refactor CM_YACriteriaType subclasses
vars
	file : File ;
	coll: ClassColl;
	klass: Class;
	methSet: MethodSet;
	meth: Method;
	src: String;
	pos: Integer;

begin
	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput('c:\dev\refactor1.scm');
	
	file.writeLine('jadeVersionNumber "' &amp; app.getSystemVersion &amp; '";');
	file.writeLine("schemaDefinition");
	file.writeLine("PortSchema" &amp; " subschemaOf " &amp; "BaseSchema" &amp; " partialDefinition;");

	create coll transient;
	CM_YACriteriaType.getSubclasses(coll);

	file.writeLine("typeDefinitions");
	foreach klass in coll do
		meth := klass.getMethod("getDataDisplay");
		if meth &lt;&gt; null then
			file.writeLine(klass.name &amp; " partialDefinition");
			file.writeLine(Tab &amp; "(");
			file.writeLine(Tab &amp; "jadeMethodDefinitions");
			file.writeLine(Tab &amp; Tab &amp;  CM_YACriteriaType::getDataDisplay.makeHeader&amp;";");	
			file.writeLine(Tab &amp; Tab &amp;  CM_YACriteriaType::getDisplay.makeHeader&amp;";");	
			file.writeLine(Tab &amp; ")");
		endif;
	endforeach;	
	
	file.writeLine("typeSources");
	foreach klass in coll do
		meth := klass.getMethod("getDataDisplay");
		if meth &lt;&gt; null then
			file.writeLine(Tab &amp; klass.name &amp; " (");
			file.writeLine(Tab &amp; "jadeMethodSources");
			
			file.writeLine("getDataDisplay");
			file.writeLine("{");
			file.writeLine(CM_YACriteriaType::getDataDisplay.makeHeader&amp;";");
			file.writeLine("//01 August 2008	cnwdw1");
			file.writeLine("begin");
			file.writeLine(Tab &amp; "return pDataObj.CM_YADataObjects.getDataDisplay(self);");
			file.writeLine("end;");
			file.writeLine("}");
			
			file.writeLine("getDisplay");
			file.writeLine("{");
			file.writeLine(CM_YACriteriaType::getDisplay.makeHeader&amp;";");	
			pos := meth.getSource().pos(":="&amp;Tab&amp;"dataObj", 1);
			if pos &gt; 1 then
				file.writeLine("//01 August 2008	cnwdw1");
				file.writeLine("begin");
				pos := pos+3;
				src := meth.getSource().scanUntil(";", pos);
				file.writeLine(Tab &amp; "return "&amp;src&amp;";");
				file.writeLine("end;");
			else
				src := meth.getSource();
				file.writeLine("//"&amp;src);
			endif;
				
			file.writeLine("}");
			
			file.writeLine(Tab &amp; ")");
		endif;
	endforeach;

epilog
	delete file;
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="dphTFS4285" id="e225bcf5-196b-4976-8053-a1857319398d">
        <source>dphTFS4285();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2017	cnwma1	Initial creation  4285:DPH - Future Storage (Priority A)

*/

vars
	fs : CM_FutureStorage;
	ts : TimeStamp;
	date: Date;
	time :Time;
	deleted : Integer;
	ilDeleted : Integer;
	lFile        : File;
	fa : CM_FutureStorageProcess;
	ti : CM_TrackedItem;
	tit : CM_TITransaction;
	i : Integer;
	invLineSet : CM_ObjectSet;
begin

	date := "01/01/2000".Date;
	time := "00:00:00.000".Time;
	
	ts.setDate(date);
	ts.setTime(time);

	//beginTransaction;
	foreach fs in CM_FutureStorage.instances where fs.chargeDateTime &lt; ts do

		if not fs.allInvoiceLines.isEmpty then
			ilDeleted := ilDeleted + fs.allInvoiceLines.size();
			//fs.allInvoiceLines.purge;
		endif;
		//delete fs;
		
		deleted := deleted +1;
		if deleted mod 5000 = 0 then
			
			//commitTransaction;
			//beginTransaction;
		endif;
	
	endforeach;
	//commitTransaction;
	create lFile transient;
	lFile.fileName := "C:\TEMP\pen136.csv";
	lFile.open;
	lFile.writeLine("Total Deleted :" &amp;","&amp; deleted.asStringJMT &amp;","&amp; "Invoice Lines Deleted : " &amp;","&amp; ilDeleted.asStringJMT);
	app.msgBox("Total Deleted :" &amp;","&amp; deleted.asStringJMT &amp;","&amp; "Invoice Lines Deleted : " &amp;","&amp; ilDeleted.asStringJMT,"",0);
	lFile.close;
	delete lFile;
			   
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dphTFS42851" id="e14064fa-6700-4b37-876a-2f8fd24e77d8">
        <source>dphTFS42851();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2017	cnwma1	Initial creation

*/

vars
	invoice : CM_Invoice;
	invLine : CM_InvoiceLine;
	date: Date;
	time :Time;
	ilDeleted : Integer;
	ts,ts2 : TimeStamp;
	tranSet : ObjectSet;
	obj : Object;
begin
	app.initialize();
	
	date := "01/06/2017".Date;
	time := "00:00:00.000".Time;
	ts.setDate(date);
	ts.setTime(time);
	
	invoice := "2216.6784".asOid.CM_Invoice;
	create tranSet transient;
	beginTransaction;
	foreach  invLine in invoice.invoiceLines where  invLine.chargeTime &lt; ts do
		ilDeleted := ilDeleted + 1;
		if invLine.myTransactionTI &lt;&gt; null then
		 tranSet.add(invLine.myTransactionTI);
		endif;
	

		delete invLine;
	
	endforeach;
	
	invoice.fromDT.setDate("03/06/2017".Date);
	invoice.fromDT.setTime("00:01:00:000".Time);
	tranSet.purge;
	
	commitTransaction;
	
	
	app.msgBox("Total Deleted :" &amp; ilDeleted.asStringJMT,"",0 );
	
epilog
	delete tranSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="dphTFS42852" id="0c73ed38-9c57-403b-b123-adb3ec4997bc">
        <source>dphTFS42852();
