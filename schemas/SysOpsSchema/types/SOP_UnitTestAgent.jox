<Class name="SOP_UnitTestAgent" id="cb3887a8-6b63-42ec-9075-2b4b3cfd9ba6">
    <superclass name="CM_UnitTestAgent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="sopGetEntTableDef" id="bcdc1f74-bab7-4882-902a-f6ec04177b26">
        <source>sopGetEntTableDef(_class : Class): String;

/*

Purpose:		

Date			Who		Reason
28/01/2015		cnwmh5	Initial creation

*/

vars

	item			: SOP_TableMaintItem;
	
	entTableName	: String;

begin
	
	create item as _class transient;
	entTableName := item.getEntTableDef();
	return entTableName;
	
epilog
	
	delete item;

end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
