    <JadeMethod name="displayRowBookingRef" id="980dfd25-7a12-44ff-b516-e9184231be09">
        <source>displayRowBookingRef(_bookingRef: CM_BookingRef): String;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.isDataFiltered then
		// data is filtered
		if self.filterVoyageCode &lt;&gt; null and 
		   self.filterVoyageCode &lt;&gt; _bookingRef.voyageCode then 
		   	return null;
		endif;
	endif;
	
	return inheritMethod(_bookingRef);

end;</source>
