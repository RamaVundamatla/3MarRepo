    <DbClassMap file="query"/>
    <JadeMethod name="translateToDisplayValue" id="67aa4b4f-85eb-43f8-9b08-fbb426aa3870">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			Translate the value to a value that can be displayed

Parameters:			_value	Any	The value to convert to a string

Return Value:		String	The returned string


Date		Who		Reason
28 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	return _value.String.formatWithEllipsis(1, 100, true);

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
