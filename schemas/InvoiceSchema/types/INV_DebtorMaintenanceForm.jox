    <JadeMethod name="doBuildComboParents" id="9ce8d728-5220-4792-bbb2-6824f034bfa1">
        <source>doBuildComboParents() protected;

//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow
vars
	debtorParent,
	debtorNode:   CM_DebtorNode;
	theBank : CM_Bank;
	rdg, rootRDG : CM_RootDebtorGroup;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	self.cmbParent.clear;
	
	foreach debtorNode in theBank.debtorNodes do
		if debtorNode.checkParentage(self.myDebtorNode) then	//TFS 6921
		//dont add if it is self or children of self			//TFS 6921
			//if debtorNode = self.myDebtorNode then // and not self.updateMode = self.UpdateMode_New then ** revisit this
			// exclude possibility of assigning group to itself when editing
			continue;
		endif;
		if debtorNode.isRDT() then
			continue;
		endif;
		
		if debtorNode = rdg then
			self.cmbParent.addItem("");
		else
			self.cmbParent.addItem(debtorNode.name);
		endif;
		self.cmbParent.itemObject[self.cmbParent.newIndex] := debtorNode;
	endforeach;

	if self.myDebtorNode &lt;&gt; null then
		debtorParent := self.myDebtorNode.myParentDebtorNode;				
	endif;
	rootRDG := app.myRoot.myRootCompany.getRootDebtorGroup();
	
	if debtorParent &lt;&gt; null and debtorParent &lt;&gt; rootRDG then
		self.cmbParent.listObject := debtorParent;
	endif;

	self.cmbParent.lostFocus(self.cmbParent);

end;</source>
        <access>protected</access>
    </JadeMethod>
