    <JadeMethod name="addDeliveryParty" id="4d7c5c3b-dc22-4f53-ae5a-324b150147a3">
        <source>addDeliveryParty(_code, _name : String; _terminal : CM_Terminal) : CM_DeliveryParty;
/*

Purpose:			Creates a Delivery Party for the Unit test terminal and creates a default address

Parameters:			_code		String	Code used for Delivery Party
					_name		String	Name used for Delivery Party
					_terminal	String	Terminal to use for Delivery Party

Return Value:		CM_DeliveryParty	The created delivery party

Date		Who		Reason
08 July 2022	navpw1	Initial creation TFS: 53953
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
*/

vars
	pxyAddress			: CM_Address;
	pxyDeliveryParty,
 	realDeliveryParty	: CM_DeliveryParty;
	terminalSet			: CM_TerminalSet;
	
begin
	create pxyAddress transient;
	//pxyAddress.setProxy(_code &amp; "1", "Unit Test Address 1", "5 Sir Gil Simpson Drive", "Burnside", "", "Canterbury", "8061", "NZ", "Christchurch", "", true, null);
	//pxyAddress.setProxy(_code &amp; "1", "Unit Test Address 1", "5 Sir Gil Simpson Drive", "Burnside", "", "Canterbury", "8061", "NZ", "Christchurch", "", true, false, null); //02/09/22	navkc1	#54564(54372.020)
	pxyAddress.setProxy(_code &amp; "1", "Unit Test Address 1", "5 Sir Gil Simpson Drive", "Burnside", "", "Canterbury", "8061", "NZ", "Christchurch",  "", "", true, false, null); //navra1 - TFS 57086 - 1st May 2023
	
	create terminalSet transient;
	terminalSet.add(_terminal);
	
	create pxyDeliveryParty transient;
	pxyDeliveryParty.setProxy(_code, _name, false, terminalSet);
	
	pxyDeliveryParty.allAddresses.add(pxyAddress);
	
	app.myTrxCA.trxCreateDeliveryParty(pxyDeliveryParty, realDeliveryParty, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return realDeliveryParty;
	
epilog
	delete pxyAddress;
	delete pxyDeliveryParty;
	delete terminalSet;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_DeliveryParty"/>
    </JadeMethod>
