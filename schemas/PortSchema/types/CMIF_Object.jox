    <JadeMethod name="formatAuditText" id="aa567b54-6746-4df6-a71c-46f96439303a">
        <source>formatAuditText( _name : String; _value : String ) : String;

/*

Purpose:		This is based on the CM_Object::formatAuditText method and is being
				used to get the value of the property in a known format.

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	return	_name &amp; AuditStringSeparator &amp;
			_value.length.display &amp; AuditStringSeparator &amp;
			_value &amp; AuditStringSeparator;
	
epilog
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
