    <JadeMethod name="createNextPage" id="185c150b-f787-4907-b87e-5132a92b1489">
        <updating/>
        <source>createNextPage( _docItems : CM_DutyDocItemByCargoId )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901
16 July		2014	cnwma1 PAR#34407 Duty Doc bill print issues

*/

vars

	nextPage : CMUI_AjmanCustoms;
	item : CM_DutyDocItem;
	count : Integer;
	nextPageItems : CM_DutyDocItemByCargoId;

begin

	//create nextPage transient;
	nextPage := CMUI_AjmanCustoms.createPrintForm;
	nextPage.initiateForm( self.baseLeftOffset, self.baseTopOffset );
	self.myNextPage := nextPage;

	_docItems.copy( nextPage.allDutyDocItems );
	
	nextPage.lblD.caption := self.lblD.caption;	// Field 1
	nextPage.lblC.caption := self.lblC.caption;	// Field 2
	nextPage.lblB.caption := self.lblB.caption;	// Field 3
	nextPage.lblA.caption := self.lblA.caption;	// Field 4
	nextPage.lblG.caption := self.lblG.caption;	// Field 5
	nextPage.lblF.caption := self.lblF.caption;	// Field 6 
	nextPage.lblE.caption := self.lblE.caption;	// Field 7
	nextPage.lblJ.caption := self.lblJ.caption;	// Field 8
	nextPage.lblI.caption := self.lblI.caption;	// Field 9
	nextPage.lblH.caption := self.lblH.caption;	// Field 10
	nextPage.lblM.caption := self.lblM.caption;	// Field 11
	nextPage.lblL.caption := self.lblL.caption;	// Field 12
	nextPage.lblK.caption := self.lblK.caption;	// Field 13o
	nextPage.lblP.caption := self.lblP.caption;	// Field 14
	nextPage.lblO.caption := self.lblO.caption;	// Field 15
	nextPage.lblN.caption := self.lblN.caption;	// Field 16
	nextPage.lblP.caption := self.lblP.caption;	// Field 17
	nextPage.lblO.caption := self.lblO.caption;	// Field 18	
	nextPage.lblN.caption := self.lblN.caption;	// Field 19
	nextPage.lblQ.caption := self.lblQ.caption;	// Field 20	
	nextPage.lblR.caption := self.lblR.caption;	// Field 21
	
	nextPage.lblBE.caption := self.lblBE.caption;	// Field 38
	nextPage.lblBF.caption := self.lblBF.caption;	// Field 39
	
	nextPage.lblBM.caption := self.lblBM.caption;	// Field 45
	nextPage.lblBN.caption := self.lblBN.caption;	// Field 46
	nextPage.lblBO.caption := self.lblBO.caption;	// Field 47
	nextPage.lblBP.caption := self.lblBP.caption;	// Field 48
	nextPage.lblBQ.caption := self.lblBQ.caption;	// Field 49
	nextPage.lblBG.caption := self.lblBG.caption;	// Field 50
	nextPage.lblBH.caption := self.lblBH.caption;	// Field 51
	nextPage.lblBI.caption := self.lblBI.caption;	// Field 52
	nextPage.lblBJ.caption := self.lblBJ.caption;	// Field 53
	nextPage.lblBK.caption := self.lblBK.caption;	// Field 54
	nextPage.lblBL.caption := self.lblBL.caption;	// Field 55
	nextPage.lblAN.caption := self.lblAN.caption;	// Field 56
	nextPage.lblAO.caption := self.lblAO.caption;	// Field 57
	nextPage.lblAP.caption := self.lblAP.caption;	// Field 58
	nextPage.lblAQ.caption := self.lblAQ.caption;	// Field 59
	nextPage.lblAR.caption := self.lblAR.caption;	// Field 60
	nextPage.lblAS.caption := self.lblAS.caption;	// Field 61	
	nextPage.lblAT.caption := self.lblAT.caption;	// Field 62
	nextPage.lblAU.caption := self.lblAU.caption;	// Field 63	
	nextPage.lblAV.caption := self.lblAV.caption;	// Field 64
	nextPage.lblAW.caption := self.lblAW.caption;	// Field 65
	nextPage.lblAX.caption := self.lblAX.caption;	// Field 66
	nextPage.lblAY.caption := self.lblAY.caption;	// Field 67
	nextPage.lblAZ.caption := self.lblAZ.caption;	// Field 68		
	nextPage.lblBA.caption := self.lblBA.caption;	// Field 69
	nextPage.lblBB.caption := self.lblBB.caption;	// Field 70
	nextPage.lblBC.caption := self.lblBC.caption;	// Field 71
	nextPage.lblBD.caption := self.lblBD.caption;	// Field 72

	nextPage.pageNo := self.pageNo + 1;
//	nextPage.lblBR.caption := nextPage.pageNo.String;	// Page No
	nextPage.setTotalPages( nextPage.pageNo );
	
	foreach item in nextPage.allDutyDocItems do 
		count := count+ 1;
		if count &lt;7 then
			// the first six will fit on this page
			nextPage.setFromDutyDocItem( item, count );
		else
			//create a new page for the rest
			 if count = 7 then
				create nextPageItems transient;
			endif;
			nextPageItems.add( item );

		endif;
	endforeach;
	if nextPageItems &lt;&gt; null then
		nextPage.createNextPage( nextPageItems ); //16 July 2014 cnwma1 PAR#34407
	endif;

epilog

	delete nextPageItems;

end;</source>
        <access>protected</access>
        <Parameter name="_docItems" type="CM_DutyDocItemByCargoId"/>
    </JadeMethod>
    <JadeMethod name="doProcessLabelContents" id="75cb6775-60d4-42d2-9091-2884bcf901bc">
        <updating/>
        <source>doProcessLabelContents(_label: CMUI_Label input): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	top : Integer;
	topOffset : Real;
	lineHeight : Integer;
	labelStrings : CnStringArray;
	labelStr : String;

begin
	
	if self.itemLabelArray.includes( _label ) then	// the multi line single label data;
		
		top := _label.top.Integer;
		lineHeight := _label.getTextHeight( "X" );
		topOffset := ( _label.height / 6 ); //we have to fit up to 6 lines in the box
		
		labelStrings := _label.caption.cnGetTokens( self.separator );
		if labelStrings = null or labelStrings.isEmpty then
			return true;
		endif;
		
		foreach labelStr in labelStrings do
			self.createOneLineItemLabelText( _label, labelStr, top );
			top := top + topOffset.Integer;
		endforeach;
		return true;
		
	else
		return inheritMethod(_label);
		
	endif;

epilog

	delete labelStrings;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPageHeight" id="547e2d9b-b9f3-441e-991f-e598b282922d">
        <source>getPageHeight(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901
*/

vars

begin
	if app.isDevelopmentSystem and app.printer.getPrinterName[1:5].toUpper &lt;&gt; "EPSON" then
		return inheritMethod();
	endif;

	return 3050;	//	305.0 mm

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="f22df22c-5d98-4a16-affc-d19ef9fa4cf6">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	obj : Object;
	label : CMUI_Label;

begin

	self.allLabelsArray.add( self.lblA );	// Field 4
	self.allLabelsArray.add( self.lblB );	// Field 3
	self.allLabelsArray.add( self.lblC );	// Field 2
	self.allLabelsArray.add( self.lblD );	// Field 1
