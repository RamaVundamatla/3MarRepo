    <JadeMethod name="displayEntry" id="b0c2050d-f2fe-40f7-b76d-52c357754a77">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _resource : HMS_Resource; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _resource = null then
		return null;
	endif;

	if _resource.isNotAvailableForEntry then // CCMS 1350
		if self.myObject &lt;&gt; _resource then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	return _resource.description &amp; ' ('&amp; _resource.code &amp; ')';	
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="485896b9-24f2-44c8-bbed-6a608174710c">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars
	res : HMS_Resource;
begin

	self.allTempResources.clear; // PAR 31709
	
	if self.myResourceType &lt;&gt; null then
		if self.myHarbour = null then
			return self.myResourceType.allResources;
		else
			foreach res in self.myResourceType.allResources discreteLock where res.myHarbour = self.myHarbour do
				self.allTempResources.add(res);
			endforeach;
			return self.allTempResources;
		endif;
	elseif self.myHarbour &lt;&gt; null then 
		return self.myHarbour.allResources;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
