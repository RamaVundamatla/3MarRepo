    <JadeMethod name="tblData_dblClick" id="a6233a26-a04f-42af-ace9-472b67785487">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars

begin
	if table.row = table.fixedRows then
		if table.sortColumn[1] &gt; 0 then
			table.accessCell(1,table.sortColumn[1]).fontBold := false;
		endif;
		table.CM_DataTable.resortTableByColumn(table.column);
		table.accessCell(1,table.column).fontBold := true;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="83e0fe29-1134-42c3-a0c2-41f61607e470">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	contract            : CM_InvoiceContract;
	detail              : CM_InvoiceContractDetails;
	rate				: CM_InvoiceContractRate;
	rateEntry			: CM_InvoiceContractRateEntry;
	rateSet             : CM_InvoiceContractRateSet;
	service 			: CM_Service;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	service := self.cmbService.listObject.CM_Service;
	create rateSet transient;
	
	foreach contract in self.allInvoiceContracts do
		foreach detail in contract.allInvoiceContractDetails do
			foreach rate in detail.allInvoiceContractRates do
				if service &lt;&gt; null and rate.myService = service then
					rateSet.add(rate);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	foreach rate in rateSet do
		foreach rateEntry in rate.allInvoiceContractRateEntries do
			str := rateEntry.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := rateEntry;
		endforeach;
	endforeach;
epilog
	delete rateSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c797db14-8656-435f-bb66-bf2f3d5e1ed9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 April 2023 08:55:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025887, locale);
	btnClear.translateCaption(Xlat_0025888, locale);
	btnClose.translateCaption(Xlat_0025889, locale);
	btnSave.translateCaption(Xlat_0025890, locale);
	btnSearch.translateCaption(Xlat_0025891, locale);
	grpSelectedRE.translateCaption(Xlat_0025892, locale);
	lblNewFrom.translateCaption(Xlat_0025893, locale);
	lblNewRate.translateCaption(Xlat_0025894, locale);
	lblNewTo.translateCaption(Xlat_0025895, locale);
	lblService.translateCaption(Xlat_0025896, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025897, locale);
	mnuContextMenu.translateCaption(Xlat_0025898, locale);
	mnuInspectObject.translateCaption(Xlat_0025899, locale);
end;</source>
    </JadeMethod>
</GUIClass>
