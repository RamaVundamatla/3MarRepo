    <JadeMethod name="getWagonsFromPositions" id="c626fc53-abfa-4bb9-97c0-d0d9d0769f8f">
        <source>getWagonsFromPositions( _integerArray : IntegerArray; _wagonSet : CM_WagonSet io; _errString : String output ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwndl1	Initial creation

*/

vars

	train : CM_Train;
	size : Integer;
	int : Integer;
	wagon : CM_Wagon;
	
begin

	train := self.mySelectedTrain;
	if train = null then
		return;
	endif;
	
	size := train.allWagonsByOrderInward.size;
	foreach int in _integerArray do
		if int &lt;= size then 
			wagon := train.allWagonsByOrderInward[int];
		else
			wagon := null;
		endif;
		if wagon = null then
			if _errString = null then
				_errString := int.String;
			else
				_errString := _errString &amp; ", " &amp; int.String;
			endif;
		else
			if not _wagonSet.includes(wagon) then
				_wagonSet.add(wagon);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_integerArray" type="IntegerArray"/>
        <Parameter name="_wagonSet" type="CM_WagonSet" usage="io"/>
        <Parameter name="_errString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWarnings" id="4f2d70de-d854-494b-bc69-fe185b1dec8d">
        <updating/>
        <source>getWarnings( train : CM_Train ) : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwndl1	Initial creation CCMS 1067

18 Feb 2010		RJS	 - change to return boolean if errors/warnings found or not

*/

vars

	localCollection : CM_ErrorSet;
	localStringArray : String200Array;
	changeDetected : Boolean;
	pos : Integer;
	error : CM_Error;
	clonedError : CM_Error;
	warningsIgnored : Boolean;
	
begin

	warningsIgnored := app.myPassport.warningsIgnored;	//18 Dec 2009	NDL Par 22035

	create localCollection transient;
	
	if not self.allWarnings.isEmpty then
		self.allWarnings.copy(localCollection);
	endif;
	self.allWarnings.clear();
	
	if train &lt;&gt; null then
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		on Exception do warningExcHandler(exception, app.myPassport);
		//train.validateUsingGaugeClearance(REAL_MODE);
		//train.validateUsingGaugeClearance(QUEUE_MODE);	// 05 Oct 2009	NDL 	Par 20842
		//train.validateUsingGaugeClearance(PLANNING_MODE);	// 05 Oct 2009	NDL 	Par 20842
		train.validateUsingTrackClearance();//par 23112
		train.getPositionalLoadErrors(false);
		foreach error in app.myPassport.allErrorWarnings do
			//clone the errors
			create clonedError transient;
			clonedError.set(error.errorCode,	//pErrorCode : Integer;
							error.text,	//pText : String;
							error.warningOnly,	//pWarning : Boolean;
							error.fieldName,	//pField : String;
							error.myUserObject,	//pObject : Object;
							error.mySubject	//_subject : CM_Object
							);
			//16 Oct 2009	NDL Par 21325
			if allWarnings.includesErrorLikeThis(clonedError) then
				// already got one like this.
				delete clonedError;
				continue;
			endif;
		
			self.allWarnings.add(clonedError);
		endforeach;
		app.myPassport.clearErrorsWarnings();
	endif;
	
	if self.allWarnings.isEmpty and localCollection.isEmpty then
		//both empty, no change
		changeDetected := false;
	elseif self.allWarnings.size &lt;&gt; localCollection.size then
		//different size, somethings changed
		changeDetected := true;
	else
		//same size, but check to see if any have changed
		create localStringArray transient;
		foreach error in localCollection do
			localStringArray.add( (error.errorCode.String &amp; error.text).String[1:200] );
		endforeach;
		foreach error in self.allWarnings do
			if not localStringArray.includes( (error.errorCode.String &amp; error.text).String[1:200] ) then
				changeDetected := true;
				break;
			endif;
		endforeach; 
	endif;
	
	if changeDetected then
		resize();
	endif;
	
	return (self.allWarnings.isNotEmpty());

epilog

	app.myPassport.setWarningsIgnored(warningsIgnored);	//18 Dec 2009	NDL Par 22035
	if not localCollection.isEmpty then
		localCollection.purge();
	endif;
	delete localCollection;
	delete localStringArray;

end;</source>
        <access>protected</access>
        <Parameter name="train" type="CM_Train"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="290d6d27-1f24-4658-aa2e-e31ef7a67214">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

