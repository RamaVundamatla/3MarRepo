    <JadeMethod name="getReceivalsOutstanding" id="955f492e-664f-47e1-8bc2-b2ab27ef94f7">
        <source>getReceivalsOutstanding() : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 27 October 2010
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
// 27/10/2010   cnwsh3		CCMS1989 - Get the number of items still to be received(delivered).
// 							Used for reports so may not have references.  If more items have been received than expected then there are 
//							considered no receivals outstanding at this stage.  May need more rules or new funtions to tighten this up.
//							but for reporting puposes we just want a figure of outstanding deliveries.
//----------------------------------------------------------------------
vars
	int : Integer;
begin
	int := self.getTotalQuantity() - self.allTIs.size;
	
	if int &lt; 0 then
		int := 0;
	endif;
	
	return int;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReceivedTrackedItems" id="b4e09a88-1e0d-45dd-858b-8c6d141f0b62">
        <source>getReceivedTrackedItems(_coll :Collection input);
/*

Purpose:			Get all received items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
12 Jun 2013	cnwcs5	Initial Creation - par 31670
01 Apr 2019	jlgzm1	tfs43864 improveing booking screen performance

*/
vars
	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	iter		: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			booking.getReceivedTrackedItems (_coll);
			return;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		_coll.add (ti);
	endwhile;
	
	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		_coll.add (ti);
	endwhile;
	//tfs43864 end
	
epilog

	delete iter;

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRecievedCount" id="dc1f45fa-9a78-4fed-b7de-952ae9162bb0">
        <source>getRecievedCount():Integer;
/*

Purpose:			Get number of received items

Parameters:			null

Return Value:		total number of received items

Date		Who		Reason
27 Nov 2009	cnwndl1	Initial creation	CCMS 1028
12 Jun 2013	cnwcs5	par 31670 - check prenoted, use quantity
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/
vars
	ti 			: CM_TrackedItem;
	qty, total	: Integer;
	booking		: CM_BookingRef;
	iter		: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			return booking.getRecievedCount;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0, iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		//get total quantity
		qty := iter.getCurrentKey(3).Integer;
			if qty = 0 then 
				// just in case we have old data with no totalQuantity
				qty := 1;
			endif;
			total := total + qty;
	endwhile;

	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		//get total quantity
		qty := iter.getCurrentKey(3).Integer;
			if qty = 0 then 
				// just in case we have old data with no totalQuantity
				qty := 1;
			endif;
			total := total + qty;
	endwhile;
	//tfs43864 end

	return total;
epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
