    <JadeMethod name="clearSelected" id="f30149f0-82ef-4ef4-a88e-e345d2f1ea5c">
        <updating/>
        <source>clearSelected() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Clears the selected day (i.e. the receiver).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.borderStyle	:= Window.BorderStyle_Single;
	self.bevelInner		:= Frame.Bevel_None;
	self.bevelOuter		:= Frame.Bevel_None;
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="c4bb515c-e330-461e-a003-3537a641ceb5">
        <updating/>
        <source>click(frame: Frame input) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
   	inheritMethod(frame);
   	
   	if self.dayNo &lt;&gt; 0 then
   		self.myCalendar.dayClick(self.dayNo);
   	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="d037cfb9-383b-4a0c-899a-ddcc14a0f67e">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    self.borderStyle 		:= Window.BorderStyle_Single;
    self.bevelInner 		:= Frame.Bevel_None;
    self.bevelInnerWidth 	:= 2;
    self.bevelOuter 		:= Frame.Bevel_None;
    self.bevelOuterWidth 	:= 2;
    self.boundaryBrush 		:= Frame.BoundaryBrush_Solid;
    self.boundaryWidth 		:= 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="d587d55e-cfbb-4503-8598-89aceb3dbbfd">
        <updating/>
        <source>dblClick(frame: Frame input) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
   	inheritMethod(frame);
   	
   	if self.dayNo &lt;&gt; 0 then
   		self.myCalendar.dayDblClick(self.dayNo);
   	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="a24f3a4f-2939-4255-b854-0a7ab52d2031">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(frame, button, shift, x, y);

	if self.dayNo &lt;&gt; 0 then
		self.myCalendar.mouseDown(self.myCalendar, button, shift, x, y);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refreshCaption" id="57f9f65c-199f-4e12-b4a2-18444c940c3f">
        <updating/>
        <source>refreshCaption() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Refreshes the receiver's caption.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	displayDate		: Date;
	displayMonth	: Integer;
	displayYear		: Integer;
	captionArrayObj	: StringArray;
	captionValue	: String;

begin
	if self.dayNo = 0 then
		self.caption := null;
		return;
	endif;

	self.caption := self.dayNo.String;

	self.myCalendar.getDisplayMonth(displayMonth, displayYear);
	displayDate.setDate(self.dayNo, displayMonth, displayYear);

	create captionArrayObj transient;
	self.myCalendar.getEventsForDate(displayDate, captionArrayObj, null);

	foreach captionValue in captionArrayObj do
		if captionValue &lt;&gt; null then
			self.caption := self.caption &amp; CrLf &amp; captionValue;
		endif;
	endforeach;
epilog	
	delete captionArrayObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableColors" id="b6837750-080b-4bea-a857-de3317a15eab">
        <updating/>
        <source>setAvailableColors(pAvailableColor:Integer; pAvailableTextColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Sets the back color and text color for an available day.
//
// Parameters:	pAvailableColor - The background color.
//				pAvailableTextColor - The text color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.availableColor &lt;&gt; pAvailableColor then
		self.availableColor			:=	pAvailableColor;
	endif;
	
	if self.availableTextColor &lt;&gt; pAvailableTextColor then
		self.availableTextColor		:=	pAvailableTextColor;
	endif;
end;</source>
        <Parameter name="pAvailableColor" type="Integer"/>
        <Parameter name="pAvailableTextColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDay" id="7361744e-6b64-48da-8bab-12952bce6519">
        <updating/>
        <source>setDay(pDayNumber : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets the receiver as the currently selected day.
//
// Parameters:	pDayNumber - The day number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dayNo := pDayNumber;
	
	if self.dayNo = 0 then
		self.caption := null;
	else
		self.caption := self.dayNo.String;
	endif;
end;</source>
        <Parameter name="pDayNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHighlightColors" id="fbb901bd-531d-443f-82bc-9a1586e35ae6">
        <updating/>
        <source>setHighlightColors(pHighlightColor:Integer; pHighlightTextColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Sets the back color and text color for a highlighted day.
//
// Parameters:	pHighlightColor - The background color.
//				pHighlightTextColor - The text color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.highlightColor &lt;&gt; pHighlightColor then
		self.highlightColor			:=	pHighlightColor;
	endif;
	
	if self.highlightTextColor &lt;&gt; pHighlightTextColor then
		self.highlightTextColor		:=	pHighlightTextColor;
	endif;
end;</source>
        <Parameter name="pHighlightColor" type="Integer"/>
        <Parameter name="pHighlightTextColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCalendar" id="980d5430-221c-472e-ae11-ae440ebd6327">
        <updating/>
        <source>setMyCalendar(pCalendarObj:CnEcCalendarControl) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's calendar control.
//
// Parameters:	pCalendarObj - A reference to the calendar control. 
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    if self.myCalendar &lt;&gt; pCalendarObj then
    	self.myCalendar := pCalendarObj;
    	self.setAvailableColors(pCalendarObj.availableColor, pCalendarObj.availableTextColor);
    	self.setHighlightColors(pCalendarObj.highlightColor, pCalendarObj.highlightTextColor);
    	self.setUnavailableColors(pCalendarObj.unavailableColor, pCalendarObj.unavailableTextColor);
    endif;
end;</source>
        <Parameter name="pCalendarObj" type="CnEcCalendarControl"/>
    </JadeMethod>
    <JadeMethod name="setUnavailableColors" id="8b1f0e63-9f26-4814-8998-dc8742ef8666">
        <updating/>
        <source>setUnavailableColors(pUnavailableColor:Integer; pUnavailableTextColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Sets the back color and text color for an unavailable day.
//
// Parameters:	pUnavailableColor - The background color.
//				pUnavailableTextColor - The text color.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.unavailableColor &lt;&gt; pUnavailableColor then
		self.unavailableColor		:=	pUnavailableColor;
	endif;
	
	if self.unavailableTextColor &lt;&gt; pUnavailableTextColor then
		self.unavailableTextColor	:=	pUnavailableTextColor;
	endif;
end;</source>
        <Parameter name="pUnavailableColor" type="Integer"/>
        <Parameter name="pUnavailableTextColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSelected" id="56e6fe60-c3c7-4520-a240-565de42d2647">
        <updating/>
        <source>showSelected() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Set's the receiver's properties to indicate that it is now the
//				currently selected day.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.borderStyle	:= Window.BorderStyle_None;
    self.bevelOuter		:= Frame.Bevel_Raised;
    self.bevelInner		:= Frame.Bevel_Inset;
end;</source>
    </JadeMethod>
    <JadeMethod name="toggleColor" id="2abfdae5-4ca8-458d-8289-d5267342ca80">
        <updating/>
        <source>toggleColor() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Toggle's the receiver's available colors between being highlighted
//				or not.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    if self.backColor = self.myCalendar.availableColor then
    	self.backColor	:=	self.myCalendar.highlightColor;
    	self.foreColor	:=	self.myCalendar.highlightTextColor;
    	
    elseif self.backColor = self.myCalendar.highlightColor then
    	self.backColor	:=	self.myCalendar.availableColor;
    	self.foreColor	:=	self.myCalendar.availableTextColor;
    	
    endif;
end;</source>
    </JadeMethod>
