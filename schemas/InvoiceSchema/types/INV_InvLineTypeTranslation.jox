    <JadeMethod name="showThumbnailData" id="bef86e5e-80f1-41b8-9731-49bcae18a2d4">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
/*

Purpose:			Sets the thumbnail up with the data from the object selected in the table

Parameters:			obj	Object The object to use to show data on the thumbnail

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	invoiceLineNarration, 
	realInvoiceLineNarration  	: CM_InvoiceLineNarration;
	
begin
	invoiceLineNarration := obj.CM_InvoiceLineNarration;
	
	if invoiceLineNarration.isTransient() then
		realInvoiceLineNarration := invoiceLineNarration.pxyGetRealObject();
	else
		realInvoiceLineNarration := invoiceLineNarration;
	endif;
	
	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvLineTranslations, invoiceLineNarration);
	
	self.doCmbLocalesBuild();
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="46ecd5be-3049-42e1-9e50-682224f92e79">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 September 2022 08:52:19.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025024, locale);
end;</source>
    </JadeMethod>
</GUIClass>
