    <JadeMethod name="utlCreateSlotDefn" id="21e7a335-d6c3-4d9c-9d4c-f1f834511756">
        <source>utlCreateSlotDefn(_proxySlotDefn:CM_SlotDefn; _newSlotDefn:CM_SlotDefn output;_realBay : CM_Bay;_onDeck : Boolean;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cellId,tierId : String;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valSlotDefn(_proxySlotDefn);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newSlotDefn as CM_SlotDefnVessel persistent;
	_newSlotDefn.setMyBay(_realBay, _onDeck);
	_newSlotDefn.setForCreate(_proxySlotDefn,_passport);
	_newSlotDefn.setFortyFrontBack(_proxySlotDefn.fortyFront, _proxySlotDefn.fortyBack); // PAR 9001 AKB2004SEP
	if _onDeck then
		_newSlotDefn.setCellAndTierDefn(_realBay.allCellsOnDeckByOrdinal[_newSlotDefn.ordinalCell],_realBay.allTiersOnDeck[_newSlotDefn.ordinalTier]);
	else
		_newSlotDefn.setCellAndTierDefn(_realBay.allCellsUnderDeckByOrdinal[_newSlotDefn.ordinalCell],_realBay.allTiersUnderDeck[_newSlotDefn.ordinalTier]);
	endif;

//	_newSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);

end;</source>
        <Parameter name="_proxySlotDefn" type="CM_SlotDefn"/>
        <Parameter name="_newSlotDefn" type="CM_SlotDefn" usage="output"/>
        <Parameter name="_realBay" type="CM_Bay"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSlotReqBackEnd" id="199ebbe4-0d79-4f75-8cea-fd95a8e77903">
        <source>utlCreateSlotReqBackEnd(_realSlotController: CM_SlotController input; _frontSlotRequest: CM_SlotRequest; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	20 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
//	front has already been validated
//	app.myValCA.valSlotRequest(_frontSlotRequest,_realSlotController);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_realSlotController.createAftSlotRequest(_frontSlotRequest, _passport);		

end;</source>
        <Parameter name="_realSlotController" type="CM_SlotController" usage="input"/>
        <Parameter name="_frontSlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSlotRequest" id="a2a13ecb-6bb4-4abd-b49b-f00bf6641493">
        <source>utlCreateSlotRequest(_proxySlotRequest:CM_SlotRequest; _newSlotRequest:CM_SlotRequest output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valSlotRequest(_proxySlotRequest);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

//	app.setContinueCMExceptions(false);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	create _newSlotRequest persistent;
	_newSlotRequest.setForCreate(_proxySlotRequest);
	// DO NOT use SETFORTY - the 40 backend has already been taken care of, mainly in the update not here in the create
//	if _newSlotRequest.isLoad then
//		_newSlotRequest.setFortyFoot(_newSlotRequest.fortyFront);	
//	else
//		if not _realSlotController.allTrackedItems.isEmpty then
//			_newSlotRequest.setFortyFoot(_realSlotController.allTrackedItems.first.isAttributeTrue(TI_Attrib_IsForty));	
//		endif;
//	endif;
	// ################################
	// This will update the display on screen of this slot
//	_newSlotRequest.mySlotController.myBayVoyage.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), 
//		false, _newSlotRequest.mySlotController);

// PAR 21746	if not(_newSlotRequest.isDischarge or _newSlotRequest.fortyBack) then
	if not(_newSlotRequest.isDischarge or _newSlotRequest.getAttrIsBackend() ) then // PAR 21746
	//only require load fronts at present
		_newSlotRequest.mySlotController.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(Event_SlotRequest_Create), false, _newSlotRequest);
	endif;
	
end;</source>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_newSlotRequest" type="CM_SlotRequest" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSlotRequestAttribute" id="147f4a41-b8f7-4975-9384-41c7b6604065">
        <updating/>
        <source>utlCreateSlotRequestAttribute(_theSlot, _theSlotAlt : CM_SlotController; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _theEditions : CM_ObjectByOidEditionDict; _attribute : String; _verifyOnly: Boolean; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	04 May 2005	by Jason Chapman  (cnwjc2)
//
// Purpose:		Probably only suited to EDI stow advice	processing	
// 
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	tmpSlot,
	tmpSlotAlt				: CM_SlotController;
	tmpSlotRequest,
	tmpSlotRequestAlt,
	otherRequest,
	aSlotReqDisch,
	aSlotReqLoad, pxySlotVerify 			: CM_SlotRequest;
	tmpVoyage				: CM_Voyage;
	eventUpdateVoyageArea	: Integer;
begin


// PAR 24041 moved down after verify		self.initialiseActivity();

	//app.setContinueCMExceptions(true);

	if _theSlot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theSlots', null, null);
		return;
	endif;
	tmpSlot := _theSlot;
	
	if _theEditions = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theEditions', null, null);
		return;
	endif;
	
	if _loadCC &lt;&gt; null then
		_loadCC.validateReferences(_passport);
		if _passport.hasErrors then
			if not _verifyOnly then // PAR 24041
				return;
			endif;
		endif;
	endif;

	// ========================================
	// Do validation
	// ========================================
	app.myValCA.valCreateSlotRequestAttribute(_theSlot, _theSlotAlt, _isLoad, _loadCC, _theEditions, _attribute, _passport);
	// PAR 24041 from here
	pxySlotVerify := tmpSlot.updateSlotRequestCreateProxy(true, _isLoad, _attribute, _loadCC, _passport); // PAR 26516 'verify' set to always be true
	app.myValCA.valSlotRequest(pxySlotVerify);
	// PAR 24041 to here
	
	if _verifyOnly then
		return;
	endif;
	
	//self.initialiseActivity(); // PAR 24041 moved to here after the verify Removed PAR 30133  cnwgb1 15.8.2012
	
	if _passport.hasErrors then
		return;
	endif;
	
	// ========================================
	// Now do the updates
	// ========================================
	
	tmpSlot := _theSlot;
	tmpSlotRequest := tmpSlot.updateSlotRequestAttribute(_isLoad, _attribute, _loadCC, _passport);

	if _passport.hasErrors then
		return;
	endif;
	//set other stuff here? from _loadCC
	
	if tmpSlotRequest &lt;&gt; null then
	tmpSlotRequest.setEDIAttributes(_verifyOnly, _loadCC);
	endif;
	
	if _loadCC.isForty then
		tmpSlotRequest := tmpSlot.updateSlotRequestAttribute(_isLoad, CM_SlotRequest.Attribute_Forty, _loadCC, _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	self.updateObjectEdition(tmpSlot);	// par 30292

	// #### Are there any auto link slot requests? If yes then link them together!
	tmpSlotAlt := _theSlotAlt;
	if _passport.noErrors and tmpSlotAlt &lt;&gt; null then
		//for EDI this is always a discharge
		// here we update using (not _isLoad) as these linked requests
		// will be the opposite of the orig requests.
		tmpSlotRequestAlt := tmpSlotAlt.updateSlotRequestAttribute((not _isLoad), _attribute, _loadCC, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
				
		if _attribute = CM_SlotRequest.Attribute_Erase then
			return;
		endif;


		//set other stuff here? from _loadCC
		tmpSlotRequestAlt.setEDIAttributes(_verifyOnly, _loadCC);
	
		if _loadCC.isForty then
			tmpSlotRequestAlt := tmpSlotAlt.updateSlotRequestAttribute((not _isLoad), CM_SlotRequest.Attribute_Forty, _loadCC, _passport);
		endif;
	
		if _passport.hasErrors then
			return;
		endif;
		
		if _isLoad then
			otherRequest := tmpSlot.mySlotRequestLoad;
		else
			otherRequest := tmpSlot.mySlotRequestDischarge;
		endif;

		if otherRequest.fortyBack then // never link to a 40 backend
			app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getID, null, null);
			return;
		endif;

		if otherRequest.isLinked() then
			app.raiseCMException1(ErrSlotRequestAlreadyLinked, tmpSlot.getID, null, null);
			return;
		endif;

		aSlotReqDisch := null;
		aSlotReqLoad := null;

		if _isLoad then
			aSlotReqDisch := tmpSlotRequestAlt;
			aSlotReqLoad := otherRequest;
		else
			aSlotReqLoad := tmpSlotRequestAlt;
			aSlotReqDisch := otherRequest;
		endif;

/* PAR 24248 no need to link this DLR from EDI.
		if aSlotReqDisch &lt;&gt; null and aSlotReqLoad &lt;&gt; null then
			app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(aSlotReqLoad, aSlotReqDisch, _passport);
			if _passport.hasErrors then
				return;
			endif;
		endif;
		*/
 		
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	// update ok so send out notes for updated objects

	eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	tmpVoyage := tmpSlot.myVoyage;
	tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlot);

	if tmpSlotAlt &lt;&gt; null then
		tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlotAlt);
	endif;
epilog
	delete pxySlotVerify;
end;</source>
        <Parameter name="_theSlot" type="CM_SlotController"/>
        <Parameter name="_theSlotAlt" type="CM_SlotController"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSlotRequestLink" id="92a63ca2-a564-4689-967d-e7f78bb2533c">
        <source>utlCreateSlotRequestLink(_theRequests:CMIF_SlotRequestController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	leftSlotRequest, rightSlotRequest :CM_SlotRequest;
	realLeftSlotRequest, realRightSlotRequest :CM_SlotRequest;
	expectedEdition:Integer;
	aTI : CM_TrackedItem;
	imex : Integer;
	idx : Integer;
	realSlotController : CM_SlotController;
begin
	self.initialiseActivity();


	app.setContinueCMExceptions(true);

	if _theRequests.allProxySlotRequests.size &lt;&gt; _theRequests.allLinkedProxySlotRequests.size then
		app.raiseCMException2(ERR_INVALID_VALUE,"selected requests", "You have selected different numbers of slot requests to link.", null, null);
		return;	
	endif;
	foreach leftSlotRequest in _theRequests.allProxySlotRequests do
		idx := idx + 1;
		rightSlotRequest := _theRequests.allLinkedProxySlotRequests[idx];
		leftSlotRequest.validateRequestLink(rightSlotRequest);
	endforeach;
//	app.myValUA.valSlotRequest(realSlotRequest, _proxySlotRequest);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
	endif;
	
	if _passport.noErrors then
		// de link
		idx := 0;
		foreach leftSlotRequest in _theRequests.allProxySlotRequests do
			idx := idx + 1;
			realLeftSlotRequest := leftSlotRequest.pxyGetRealObject.CM_SlotRequest;
			app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(realLeftSlotRequest,null,_passport);
		endforeach;
		// re link
		idx := 0;
		foreach leftSlotRequest in _theRequests.allProxySlotRequests do
			idx := idx + 1;
			rightSlotRequest := _theRequests.allLinkedProxySlotRequests[idx];
			
			realLeftSlotRequest := leftSlotRequest.pxyGetRealObject.CM_SlotRequest;
			realRightSlotRequest := rightSlotRequest.pxyGetRealObject.CM_SlotRequest;
			app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(realLeftSlotRequest,realRightSlotRequest,_passport);
		endforeach;
	endif;
epilog
end;</source>
        <Parameter name="_theRequests" type="CMIF_SlotRequestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSlotRequestRORO" id="214119ac-b6f9-4656-a0cc-620376b8a463">
        <source>utlCreateSlotRequestRORO(_proxySlotRequest:CM_RORORequest; _newSlotRequest:CM_RORORequest output; _passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
*/

vars
	cancelSave	: Boolean;
	voyage		: CM_Voyage;
	event		: Integer;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valSlotRequestRORO(_proxySlotRequest);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

//	app.setContinueCMExceptions(false);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	create _newSlotRequest as _proxySlotRequest.class persistent;
	_newSlotRequest.setForCreate(_proxySlotRequest);
	// 28747 Dec 2011 raise notes for location side view form update
	voyage := _newSlotRequest.myROROController.myVoyage;
	event := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	voyage.causeEvent(event, false, _newSlotRequest.myROROController);

end;</source>
        <Parameter name="_proxySlotRequest" type="CM_RORORequest"/>
        <Parameter name="_newSlotRequest" type="CM_RORORequest" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
