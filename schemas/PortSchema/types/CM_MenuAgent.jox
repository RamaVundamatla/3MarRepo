    <JadeMethod name="trxCreateSpecialToolbarButtons" id="dddc948e-da20-40ec-83ce-40116e9a83d1">
        <source>trxCreateSpecialToolbarButtons();
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 21/11/25 navsaa30 MTN-36586 MTN | Add a new Portia Assistant icon to the existing MTN application UI
vars
	newTool			: CM_MenuToolbar;
	root			: CM_Root;
	menuEntity		: CM_MenuEntity;
	foundSpecial	: Boolean;
begin
	root := app.myRoot;
	beginTransaction;
	
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_SEP]; 
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicToolBarSpaceSmall,
					PicToolBarSpaceSmall,
					'Separator',
					null,
					CM_MenuToolbar.MENU_ID_SEP,
					MenuType_DetailSystem,
					root);
	
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_EXIT];
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicExitUp,
					PicExitDown,
					'Exit',
					'Exit Master Terminal',
					CM_MenuToolbar.MENU_ID_EXIT,
					MenuType_DetailSystem,
					root);
	
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_LOGOFF];
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicLogOffUp,
					PicLogOffDis,
					'Log Off',
					'Log Off',
					CM_MenuToolbar.MENU_ID_LOGOFF,
					MenuType_DetailSystem,
					root);
					
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_NAV];
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicNavigateUp,
					PicNavigateDown,
					'Show Navigator',
					'Show Navigator',
					CM_MenuToolbar.MENU_ID_NAV,
					MenuType_DetailSystem,
					root);
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_BOT];			//navsaa30 #36586 21/11/25 
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicPortIA,
					PicPortIA,
					'PortIA',
					'Kaleris Assisstant',
					CM_MenuToolbar.MENU_ID_BOT,
					MenuType_DetailSystem,
					root);
					
	newTool := root.allToolbarEntities[CM_MenuToolbar.MENU_ID_HELP];
	if newTool = null then
		create newTool persistent;
	endif;
	
	newTool.setToolbar(PicHelpUp,
					PicHelpDown,
					'Help',
					'Master Terminal Help',
					CM_MenuToolbar.MENU_ID_HELP,
					MenuType_DetailSystem,
					root);

	
	commitTransaction;
end;</source>
    </JadeMethod>
