    <JadeMethod name="convertPropertyToString" id="4f466d34-39e6-44cd-93db-9a004c5a40d2">
        <source>convertPropertyToString(_receiverType, _etRowConstantName, _propertyName, propertyType : String) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/
constants
	SignatureLine : String = "(_object:";
	VarsLine      : String = "vars" &amp; CrLf ;
	InvalidLine   : String = "invalidObj : Boolean;" &amp; CrLf &amp; "displayString : String;" &amp; CrLf;
	//InvalidLine1   : String = "dt : String;" &amp; CrLf;
	BeginLine     : String = "begin " &amp; CrLf;
	ReturnLine    : String = Tab &amp; "return ";
	EpilogLine    : String = "epilog" &amp; CrLf;
	EndLine       : String = "end;";
vars
	//tmp,
	methodSignature : String;
	methodSource    : String;
	referenceProp   : String;
	returnStatement : String;
begin
	methodSignature :=  SignatureLine &amp; _receiverType &amp; ") : String;" &amp; CrLf;
	methodSource := self.ExtractFieldValueMethodName &amp; methodSignature &amp; VarsLine &amp; Tab &amp; InvalidLine &amp; BeginLine;
	
	if _receiverType = String.name then
		methodSource := methodSource &amp; ReturnLine &amp;"_object;" &amp; CrLf &amp; EpilogLine &amp; EndLine;
		return methodSource;
	endif;
	
	//it is an attribute or method on _receiverType
	referenceProp := "_object";
		
	methodSource := methodSource &amp; Tab &amp; "if " &amp; referenceProp &amp; " = null then" &amp; CrLf &amp; 
								   Tab &amp; Tab &amp; "return null;" &amp; CrLf &amp;
								   Tab &amp; "endif;" &amp; CrLf &amp; CrLf;
								   
   	methodSource := methodSource &amp; Tab &amp; "on Exception do app.handleDeletedObject(exception, " &amp; referenceProp &amp; ", invalidObj);" &amp; CrLf &amp;
								   Tab &amp; referenceProp &amp; ".edition;" &amp; CrLf &amp;
								   Tab &amp; "if invalidObj then" &amp; CrLf &amp;
								   Tab &amp; Tab &amp; "return null;" &amp; CrLf &amp;
								   Tab &amp; "endif;" &amp; CrLf &amp; CrLf;							   
								   
	returnStatement := ReturnLine;
	if _etRowConstantName &lt;&gt; null then
		methodSource := methodSource &amp; "displayString := " &amp; referenceProp &amp; '.getDisplayStringForAttribute("' &amp; _etRowConstantName &amp; '", false);' &amp; CrLf;
		
		if propertyType = self.DATE then
			methodSource := methodSource &amp; "displayString := displayString.Date.formatAsYYYYMMDDCSV" &amp; ";" &amp; CrLf;
		elseif propertyType = self.TIME then
			methodSource := methodSource &amp; "displayString := displayString.Time.formatAsHHMMSSmmm" &amp; ";" &amp; CrLf;
		elseif propertyType = self.TIMESTAMP then	
			methodSource := methodSource &amp; "displayString := displayString.TimeStamp.formatAsYYYYMMDDHHMMSSMMM" &amp; ";" &amp; CrLf;
		endif;
		
		returnStatement := returnStatement &amp; "displayString;" &amp; CrLf;
	
	else
		if propertyType = self.STRING then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ";" &amp; CrLf;
		elseif propertyType = self.DATE then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".formatAsYYYYMMDDCSV" &amp; ";" &amp; CrLf; 	
		elseif propertyType = self.TIME then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".formatAsHHMMSSmmm" &amp; ";" &amp; CrLf; 			
		elseif propertyType = self.TIMESTAMP then	
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".formatAsYYYYMMDDHHMMSSMMM" &amp; ";" &amp; CrLf; 		
		elseif propertyType = self.BOOLEAN then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".getYesNo" &amp; ";" &amp; CrLf; 
		elseif propertyType = self.BINARY then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".base64Encode" &amp; ";" &amp; CrLf; 
		elseif propertyType = self.INTEGER then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".asStringJMT" &amp; ";" &amp; CrLf; 		
		elseif propertyType = self.DECIMAL then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".asStringJMT" &amp; ";" &amp; CrLf; 	
		elseif propertyType = self.REAL then
			returnStatement := returnStatement &amp; referenceProp &amp; "." &amp; _propertyName &amp; ".asStringJMT" &amp; ";" &amp; CrLf; 	
		endif;
	endif;
	
	methodSource := methodSource &amp; returnStatement &amp; EpilogLine &amp; EndLine;
	return methodSource;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_receiverType" type="String"/>
        <Parameter name="_etRowConstantName" type="String"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="propertyType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createField" id="e4cc5f59-e784-4f80-aa6e-300a2954da6d">
        <source>createField(_proxyField: CM_DataExtractField) : CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	field : CM_DataExtractField;
begin

	create field persistent;
	field.setForCreate(_proxyField);
	field.setDataExtractClass(self);
	return field;

end;</source>
        <Parameter name="_proxyField" type="CM_DataExtractField"/>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="createOutputFile" id="c8c2bc3f-b34d-4816-b3e6-a03612597008">
        <source>createOutputFile(_outputFolder : String) : File protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	#cnwdz2	 

*/

vars
	fileName,
	filePath : String;
	date     : Date;
	time     : Time;
	file     : File;
begin
	fileName := date.formatAsYYYYMMDD() &amp; "_" &amp; time.formatAsHHMMSS() &amp; "_" &amp; self.className &amp; ".csv"; 
	fileName := fileName.removeString(" ");
	if _outputFolder.endsWith("\") then
		filePath := _outputFolder &amp; fileName;
	else
		filePath := _outputFolder &amp; "\" &amp; fileName;
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.msgBox(app.getErrorString1(FileUnavailable, file.fileName),app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		//app.raiseCMException1(FileUnavailable, file.fileName, null, null);
		return null;
	endif;
	
	file.purge();
	return file;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_outputFolder" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="doExtractData" id="8ff9eebb-30d1-4596-ac90-6f0e9f97bdc2">
        <source>doExtractData(_terminal : CM_Terminal; _outputFile : File; _counter : Integer io; _breakOut : Boolean output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars

begin
	self.extractFieldsHeader(_outputFile);
	self.extractFieldsBody(_terminal, _outputFile, _counter, _breakOut);
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doExtractDoc" id="1492bab6-4e83-47d7-a90f-092903a7ba33">
        <source>doExtractDoc(_outputFile: File);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	#cnwdz2	 

*/

vars
	fieldName : String; 
	field     : CM_DataExtractField;
begin
	_outputFile.writeLine("Column Heading,Description,JMT Field Type,Possible Values");
	foreach fieldName in self.extractOrder do 
		field   := self.allDataExtractFields[fieldName];
		field.doExtractDoc(_outputFile);
	endforeach;		
epilog
	
end;</source>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="extractFieldsBody" id="6a6164d9-1af4-4b21-ba85-fa2bf3dc4258">
        <source>extractFieldsBody(_terminal : CM_Terminal; _outputFile : File; _counter : Integer io; _breakOut : Boolean output) abstract, protected;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="extractFieldsFromObject" id="26000f6b-7b80-497d-8e82-8c38305b01f9">
        <source>extractFieldsFromObject(_object : CM_Object; _outputFile : File; _counter : Integer io; _breakOut : Boolean output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/

vars
	invalidCont  : Boolean;
	cmifMonitor  : CMIF_Monitor;
	monitorReturnValue : Integer;
begin	
	if _object = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _object, invalidCont);
	_object.edition;
	if invalidCont then
		return;
	endif;

	if (_counter mod 5) = 0 then
		cmifMonitor := app.myPassport.myCMIFMonitor;
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.updateProgress(self.getDisplayString(), null, _counter);
			
			monitorReturnValue := cmifMonitor.monitorReturnValue;
			if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				_breakOut := true;
				CM_BreakOutException.raise_(cmifMonitor.monitorReturnValue, 'Breaking Out');
				return;
			endif;
		endif;
	endif;
	
	self.extractFieldsInOrder(_object, _outputFile);
	
	_counter := _counter + 1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="extractFieldsHeader" id="cf005605-c332-4916-ab11-44b6ccb58e4e">
        <source>extractFieldsHeader(_outputFile : File) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	fieldName    : String;
	headerString : String;
	headerLine   : String;
	field        : CM_DataExtractField;
	lineEnd      : Integer;
begin
	foreach fieldName in self.extractOrder do
		field   := self.allDataExtractFields[fieldName];
		if field.isCollection then
			continue;
		endif;
		headerString := self.tidyUpStringForCSVOutput(field.niceName);
		if headerString[1] &lt;&gt; '"' then // if the first two characters are uppercase ID then excel won't work correctly.
			headerLine := headerLine &amp; '"' &amp; headerString &amp; '"' &amp; ",";	
		else
			headerLine := headerLine &amp; headerString &amp; ",";	
		endif;
	endforeach;
	_outputFile.writeLine(headerLine);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="extractFieldsInOrder" id="e07e4b1c-31f7-40b7-9b28-990859042406">
        <source>extractFieldsInOrder(_object : CM_Object; _outputFile : File) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	#cnwdz2	 

*/

vars
	field     : CM_DataExtractField;
	fieldName,
	fieldString,
	fieldLine    : String;
begin
	on Exception do self.handleInvalidObject(exception);
	
	foreach fieldName in self.extractOrder do 
		field   := self.allDataExtractFields[fieldName]; 	
		
		fieldString := null;
		fieldString := field.doExtractData(_object, _outputFile);
		if field.isCollection then
			continue;
		endif;
		fieldString := self.tidyUpStringForCSVOutput(fieldString);					
		fieldLine   := fieldLine &amp; fieldString &amp; ",";			
	endforeach;
	_outputFile.writeLine(fieldLine);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
