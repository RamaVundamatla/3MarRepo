        <controlMethod name="Table::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	x1 : Real;
	y1 : Real;
begin
	
	x1 := x;
	y1 := y;
	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	if self.frmInfoDrag.visible then
		self.frmInfoDrag.move(x1,y1,self.frmInfoDrag.width,self.frmInfoDrag.height);
	endif;
end;</source>
