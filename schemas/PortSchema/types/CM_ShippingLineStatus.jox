    <JadeMethod name="getAuditText" id="d857f3ee-d6d6-4041-90f1-47b95494a8ea">
        <source>getAuditText(): String;
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.myCriteria &lt;&gt; null then
		tmpStr := self.myCriteria.getCriteriaSummary(",");
		if tmpStr &lt;&gt; null then
			txt := txt &amp; 'All Criteria'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="431514f3-5d6a-4483-9365-1036abfa6ce9">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars
	propName	: String;
begin
	propName := _property.name;
	
	if propName = CM_ShippingLineStatus::type.name then
		return self.formatAuditText(propName, self.getTypeIntToString(self.type));
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaDisplay" id="fcc77aaa-c6f3-4a56-8fa2-19b793cf5380">
        <source>getCriteriaDisplay() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	criteria : CM_ShippingLineStatusCriteria;
begin
	criteria := self.myCriteria;
	
	if criteria = null or criteria.getCriteriaSummary(", ") = null then
		return app.getErrorString(Criter_not_config_double_click);
	else
		return criteria.getCriteriaSummary(", ").formatWithEllipsis(1, 100, true);
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9474b74f-9666-4455-bf07-c4bbf72f5c9a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars

begin
	if _attrName = ETRow_NafeList then
		return self.notAvailForEntry.getYesNo();
	elseif _attrName = ETRow_Type then
		return self.getTypeIntToString(self.type);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeIntToString" id="a489859a-d9f3-4a96-8efd-f8d15b17d7d0">
        <source>getTypeIntToString(_type : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars

begin
	if _type = CM_ShippingLineStatus.Type_Exempt then
		return app.getErrorString(Exempt);
	elseif _type = CM_ShippingLineStatus.Type_NotExempt then
		return app.getErrorString(Not_exempt);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeStringToInt" id="dea6c365-fedd-4e02-b331-d6cedd609bfe">
        <source>getTypeStringToInt(_typeString : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars

begin
	if _typeString = app.getErrorString(Exempt) then
		return CM_ShippingLineStatus.Type_Exempt;
	elseif _typeString = app.getErrorString(Not_exempt) then
		return CM_ShippingLineStatus.Type_NotExempt;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_typeString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="7b58bc40-18de-427e-b0ca-8d996ea7d1f7">
        <source>getYADisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria
*/

vars

begin
	return self.code &amp; Tab &amp; self.description &amp; " (" &amp; self.myTerminal.code &amp; ")";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
