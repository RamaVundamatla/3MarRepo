    <JadeMethod name="doOutputLogInfo" id="05f60885-1c4e-4a09-8f57-51c6fe72ca01">
        <updating/>
        <source>doOutputLogInfo() updating, protected;
//----------------------------------------------------------------
//	Created:	11 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// adm 060509 Par 18990 clear log firat
vars
	i : Integer;
begin
	logMessage := null;
	if global.isValidObject(self.myBGPObject) then
		self.myBGPObject.causeEvent(BGP_Object.BGP_OutputInfo, true, process);
		while logMessage.length = 0 do    //if logMessage is not populated wait a little longer
			app.doWindowEvents(10);  //damn, don't like app.doWindowEvents but self.doWindowEvents doesn't fire causeEvent/Notification
			i := i + 1;
			if i &gt; 500 then
				break;
			endif;
		endwhile;
		app.msgBox(logMessage, 'Info',MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessRequest" id="71464c3f-92f1-425a-9cba-26715270f0c8">
        <updating/>
        <source>doProcessRequest() protected, updating;

// cnwdvb1 27 June 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	selectedObjects : ObjectSet;
	obj : Object;
	isFutureStorage : Boolean;
	futureHandler	: CM_OfflineFutureActorHandler;
	invalidObj 	: Boolean;
begin

	//epr TFS 4474 2/6/17
	on Exception do app.handleDeletedObject(exception,obj,invalidObj);
	create selectedObjects transient;
	create futureHandler transient;
	foreach obj in self.tblRequest.allSelectedObjects do
		if obj.isKindOf(CM_OfflineFutureActor) then
			isFutureStorage:=true;
			futureHandler.processOfflineFutureActorTrx(obj.CM_OfflineFutureActor);
		endif;
	endforeach;
	
	if isFutureStorage then
		self.doDisplay();
		return;
	endif;
	

	if global.isValidObject(self.mySelectedRequest) then
		app.myTrxUA.trxUpdateBGPRequest(self.mySelectedRequest, false, 0, null, app.myPassport);
		self.mySelectedRequest.initRequestEvent(false, true, null);
		self.doDisplay();
	endif;
epilog
	delete selectedObjects;
end;</source>
        <access>protected</access>
    </JadeMethod>
