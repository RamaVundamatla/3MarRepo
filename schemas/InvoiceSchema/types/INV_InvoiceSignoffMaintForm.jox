        <source>cmbJobTitle_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	text : String;
	index : Integer;

begin

	text := combobox.text;
	if combobox.findStringExact(1,text) &lt; 1 then
		index := combobox.addItem( text );
		combobox.listIndex := index;
	endif;
	self.tblEntDetail.setValueByControlName(combobox.name, text);

epilog

end;</source>
