    <JadeMethod name="setType" id="4892524b-876b-4445-8218-d7f0661dbe9e">
        <updating/>
        <source>setType(auditType: Integer) updating;

begin
	// Lock self before comparing values to ensure we have the latest edition.
	// We assume that we're called within a transaction, so the lock will be
	// released at commit/abort transaction.
	exclusiveLock(self);
	if auditType = AuditDeleted and self.type = AuditUpdated then
		self.auditText := null;
	endif;
	self.type := auditType;
end;</source>
        <Parameter name="auditType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="subjectBeingDeleted" id="e4efc0e0-2fe1-438a-a94c-8dea1623e68d">
        <updating/>
        <source>subjectBeingDeleted() updating;

vars
	cls : Class;
	usrTag, clsTag : String;
	subj : CM_Object;
	invalid : Boolean;
	
begin

	on Exception do app.handleDeletedObject( exception, subj, invalid );
	
	subj := self.mySubject;
	if subj = null then
		return;
	endif;
	usrTag := self.getUserTag;
	cls := subj.class;
	if cls = null then
		clsTag := null;
	else
		clsTag := TagClassStart &amp; cls.name &amp; TagEnd;
	endif;
	self.subjectIdString := clsTag &amp; usrTag &amp; subj.auditIdDisplay;
end;</source>
    </JadeMethod>
    <JadeMethod name="typeCode" id="15675c28-31ac-45ac-bd94-c5f3d40e533d">
        <methodInvocation>mapping</methodInvocation>
        <source>typeCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.type = AuditUpdated then
		_value := 'Updated';
	elseif self.type = AuditCreated then
		_value := 'Created';
	elseif self.type = AuditDeleted then
		_value := 'Deleted';
	elseif self.type = AuditInformation then
		_value := 'Info';
	else
		_value := '&lt;unknown&gt;';
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="260114b0-1f63-459d-9403-516f7f96a5b5">
        <updating/>
        <source>updateForCreate(subject : CM_Object; auditType : Integer; pAuditConfig : CM_AuditConfig) updating;

// Should be called only on a create
// 12/12/2014  cnwdb2	PAR 35364

vars
	ts : TimeStamp;
	aUser : CM_User;
begin
	if app.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "app myRoot", null, null);
		app.raiseCMException(Input_required_field_appMyRoot, null, null); // cnwdb2	PAR 35364
		
		return;
	endif;

	//ccms1107 / PAR 20627 Sep 2009. Setting Key fields should be first
	ts := app.serverTimestampAtTrxStart;
	if (ts = null) or (not ts.isValid) then
		self.timestamp := app.actualTimeServer;
	else
		self.timestamp := ts;
	endif;
	
	self.type := auditType;
	
	aUser := app.getMyUser();
	
	if aUser = null  then
		//epr TFS 37199 15/3/18
		if  not app.isBackGroundApp then
			self.myUser := null;
			self.userCode := process.userCode;
		endif;
	elseif aUser.isTransient then
		self.myUser := null;
		self.userCode := aUser.code;
	else
		//epr TFS 37199 15/3/18
		self.setMyUser(aUser);
	endif;
	
	self.myAuditConfig := pAuditConfig;

	self.mySubject := subject;

end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="auditType" type="Integer"/>
        <Parameter name="pAuditConfig" type="CM_AuditConfig"/>
    </JadeMethod>
    <JadeMethod name="userBeingDeleted" id="71f878f4-c0e8-4032-b378-c881ce2be3ca">
        <updating/>
        <source>userBeingDeleted() updating;
// 12/12/2014  cnwdb2	PAR 35364
vars
	usrTag, clsTag, subjString : String;
	usr : CM_User;
	
begin
	if app.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "app.myRoot", null, null);
		app.raiseCMException(Input_required_field_appMyRoot, null, null); // cnwdb2	PAR 35364

		return;
	endif;
	usr := self.myUser;
	if usr = null then
		return;
	endif;
	// save our user's details in the subject string
	clsTag := self.getClassTag;
	subjString := self.getSubjectIdString;
	usrTag := TagUserStart &amp; usr.userName &amp; TagEnd;
	self.subjectIdString := clsTag &amp; usrTag &amp; subjString;

	// disassociate ourself from our user...
	if self.myUser &lt;&gt; null and self.userCode &lt;&gt; null then
		self.userCode := self.myUser.code;
	endif;
	self.myUser := null;

	// ...and move ourself into the root object's collection
	// of all audits with no related user object
//	self.myRootWhenUserIsNull := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="userCode" id="00956f83-ffcc-40f8-9bff-8d6659e28ae5">
        <methodInvocation>mapping</methodInvocation>
        <source>userCode(set : Boolean; _value : String io) mapping;
// ---------------------------------------------------------------------------
// Created:     24 November 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		return;
	endif;
	
	if self.userCode = null and
	   self.myUser &lt;&gt; null then
		_value := self.myUser.code;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
