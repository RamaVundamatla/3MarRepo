    <JadeMethod name="includeCargo" id="4dfd5317-c39b-4b5a-a2f7-9837be91830d">
        <source>includeCargo(	_cargoType : CM_CargoType; 
				_operatorCode : String; 
				_cargoGroup : CM_CargoGroup; 
				_subType : CM_Product; 
				_commodities : String;
				_voyage : CM_Voyage; 
				_markNum : String; 
				_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/11/2024	navkc1 JIRA Bug MTN-33448: First Warehouse location is not considering the cargo group

*/

vars
	
begin
	
	if 	_ti.myCargoType &lt;&gt; _cargoType or 
		_ti.operatorCode &lt;&gt; _operatorCode or
		(_cargoGroup &lt;&gt; null and _ti.myCargoGroup &lt;&gt; _cargoGroup) or
		(_subType &lt;&gt; null and _ti.myProduct &lt;&gt; _subType) or
		(_commodities &lt;&gt; null and _ti.commodity &lt;&gt; _commodities) or
		(_voyage &lt;&gt; null and _ti.myVoyage &lt;&gt; _voyage) or
		(_markNum &lt;&gt; null and _ti.markNumber &lt;&gt; _markNum) 
															then
		return false;
	endif;
	
	
	return true;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_subType" type="CM_Product"/>
        <Parameter name="_commodities" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_markNum" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesDupsAndNonDups" id="f5f8f79d-1d13-4c00-86e5-64571a4c1187">
        <source>includesDupsAndNonDups( _firstCargoTypeAllowsDups : Boolean output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2018	jlgndl1	Initial creation	TFS 42242

*/

vars

	firstCargoType : CM_CargoType;
	cargoType : CM_CargoType;
	iter : Iterator;
	resDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;

begin

	_firstCargoTypeAllowsDups := false;
	if self.myOriginatingBulkRelease = null then
		return false;
	endif;
	
	iter := self.myOriginatingBulkRelease.allReserveDetails.createIterator();
	while iter.next( resDetail) do
		if not resDetail.isAllocationById then
			//its by type...  nothing here for us.
			continue;
		endif;
		ti := resDetail.CM_ReserveTI.getTI;
		if not ti.isOnSite then
			continue;
		endif;
		if not ti.isTiAvailableForAnyIdSelection then
			continue;
		endif;
		lc := ti.myPrimaryActualLocation.CM_LocationsController;
		if lc.isVehicle
		or lc.isMachineController
		then
			//not one we want to allow
			continue;
		endif;
		cargoType := ti.myCargoType;
		if firstCargoType = null then
			firstCargoType := cargoType;
			_firstCargoTypeAllowsDups := cargoType.allowDuplicates;
		else
			if _firstCargoTypeAllowsDups &lt;&gt; cargoType.allowDuplicates then
				return true;
			endif;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_firstCargoTypeAllowsDups" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAnyAmount" id="591ac947-acab-46bf-9275-a3ede2adb615">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isAnyAmount(set: Boolean; _value: Boolean io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 March 2017		cnwndl1	Initial creation	TFS 3813
17 October 2022		jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

begin
	if set then
		self.isAnyAmount := _value;
		return;
	endif;
	
	if self.isAnyAmount then
		_value := true;
		return;
	endif;

	if not isAnyId then	// Has to be an any id first
		_value := false;
		return;
	endif;
	
	if self.myGateEntity &lt;&gt; null and self.myGateEntity.isKindOf( CMGTE_Release) then
		_value := self.myGateEntity.CMGTE_Release.getIsAnyAmount;
		return;
	endif;
	
	_value := false;
	return;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
