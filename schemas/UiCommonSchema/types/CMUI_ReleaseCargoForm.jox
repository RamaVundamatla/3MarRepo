    <JadeMethod name="cmbType_hasLostFocus" id="4c4e8bc8-f226-4dd3-8d57-d42edcf70cd4">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
//14 October 2009	cnwml2


vars	
begin
	//cnwjo3 par 23536
	if self.myBulkRelease &lt;&gt; null then
		if not self.myBulkRelease.releaseByType then
			self.setAvailableTIs(self.myBulkRelease);
		endif;
	endif;
	
	
	
	if self.cmbType.getObject &lt;&gt; null then
		//+cnwml2 PAR23874
		if not self.allSearchTIs.isEmpty then
			if self.cmbType.getObject &lt;&gt; self.allSearchTIs.first.CM_TrackedItem.myCargoType then
				self.allSearchTIs.clear();
			endif;
		endif;
		self.btnCargoIDsearch.enabled := true;

	else
		if self.myBulkRelease = null then //epr par 35154 18/11/14
			self.allSearchTIs.clear();		//+cnwml2 PAR23874
			self.btnCargoIDsearch.enabled := false;
		endif;		
	endif;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
