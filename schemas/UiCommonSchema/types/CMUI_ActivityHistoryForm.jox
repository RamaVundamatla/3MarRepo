    <JadeMethod name="updateTableColumnFilters" id="6737c06f-1ee6-42a0-8f07-54c488b706ff">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2016	cnwndl1	Initial creation	Make Activity History form use column organiser

*/

vars

begin
	
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );



epilog

