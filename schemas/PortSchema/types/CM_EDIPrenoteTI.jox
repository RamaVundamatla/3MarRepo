    <JadeMethod name="getIsoTypeObj" id="9dbc7edb-02e5-47cf-b771-a82ce9fd30ac">
        <source>getIsoTypeObj():CM_ISOType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2020 cnwma1  Bug 50156: POL-Generator Prenote failing to load as cargo Type defaulting incorrectly
28 Nov 2024 navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
*/

vars
	loopIsoType,
	isoTypeObj 	 : CM_ISOType;
	isoTypeDict  : CM_ISOTypeByCodeDict;
	isoTypeUpper : String;
begin

epilog
	
	if self.isoType &lt;&gt; null then
		isoTypeDict := app.myRoot.allISOTypes;
		
		isoTypeObj  := isoTypeDict[self.isoType];
		
		if isoTypeObj = null then
			
			isoTypeUpper := self.isoType.toUpper;									//28.11.2024 navma1 #MTN-19124
			
			foreach loopIsoType in isoTypeDict do
				if loopIsoType.description.toUpper.cnContains(isoTypeUpper) then	//28.11.2024 navma1 #MTN-19124
					isoTypeObj :=loopIsoType;
					
					return isoTypeObj;
				endif;
			endforeach;
		endif;
	endif;
	
	return isoTypeObj;
end;</source>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
