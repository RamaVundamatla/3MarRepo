    <JadeMethod name="doDelete" id="06d02aa8-091a-46bb-a1bc-709239b50db6">
        <source>doDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	lc : CM_RackShelfController;
	index : Integer;
	msg : String;

begin

	index := self.lstShelves.row;
	if index &gt; 0 and index &lt;= self.lstShelves.rows then
		lc := self.lstShelves.accessRow(index).itemObject.CM_RackShelfController;
	endif;


	if lc = null then
		msg := app.getErrorString(Nothing_Selected);
		app.msgBox( msg, app.getErrorString(Nothing_Selected), MsgBox_OK_Only );
	else
		self.lstShelves.removeItem(index);
		delete lc;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="6cb814a9-7f3f-464c-a483-4cdfb41c7817">
        <updating/>
        <source>doNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	lastCurrentSub : CM_RackShelfController;
	newLc : CM_RackShelfController;
	newIndex : Integer;
	msg : String;
	form : SOP_BlockLocationDetailForm;

begin

	lastCurrentSub := self.myRackLocation.allSubLocations.last.CM_RackShelfController;
	if lastCurrentSub = null then
		newIndex := 1;
	else
		newIndex := lastCurrentSub.locationOrdinal + 1;
	endif;
	
	create newLc transient;
	newLc.setDefaultProxy( newIndex, self.myRackLocation, null );

	create form transient;
	form.setLocationProxy(newLc, self.myTerminal, self );
	if form.showModal = IDOK then
		newLc.setProxy(	null,	//blockAreaProxy : CM_IrregularBlockArea;
						form.txtName.text,	//id: String;
						newLc.region,	//region: PointArray;
						form.clrColour.getColor,	//_colour : Integer;
						form.txtDefCapacity.text.Integer,	//_defaultCapacity : Integer;
						newLc.locationType,	//_locationType : Integer;
						form.txtMaxWeight.getConvertedValue,	//_maximumWeight : Real;
						form.cmbICArea.listObject.CM_InterchangeArea	//_myICArea : CM_InterchangeArea
						);
	endif;
	
	self.populateData();

epilog

	delete form;

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="f3326e7a-348f-477e-bc1b-6a2136436abc">
        <updating/>
        <source>doUpdate()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	lc : CM_RackShelfController;
	index : Integer;
	msg : String;
	form : SOP_BlockLocationDetailForm;

begin

	index := self.lstShelves.row;
	if index &gt; 0 and index &lt;= self.lstShelves.rows then
		lc := self.lstShelves.accessRow(index).itemObject.CM_RackShelfController;
	endif;

	if lc = null then
		msg := app.getErrorString(Nothing_Selected);
		app.msgBox( msg, app.getErrorString(Nothing_Selected), MsgBox_OK_Only );
	else
		create form transient;
		form.setLocationProxy(lc, self.myTerminal, self );
		if form.showModal = IDOK then
			lc.setProxy(	lc.myTerminalArea.CM_IrregularBlockArea,	//blockAreaProxy : CM_IrregularBlockArea;
							form.txtName.text,	//id: String;
							lc.region,	//region: PointArray;
							form.clrColour.getColor,	//_colour : Integer;
							form.txtDefCapacity.text.Integer,	//_defaultCapacity : Integer;
							lc.locationType,	//_locationType : Integer;
							form.txtMaxWeight.getConvertedValue,	//_maximumWeight : Real;
							form.cmbICArea.listObject.CM_InterchangeArea	//_myICArea : CM_InterchangeArea
							);
		endif;
	endif;
	
	self.populateData();

epilog

	delete form;

end;</source>
    </JadeMethod>
