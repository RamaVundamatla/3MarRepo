    <JadeMethod name="listBoxPortsOfCall" id="488946ed-3ebb-4226-8e79-1c1964039569">
        <source>listBoxPortsOfCall(_listBox : CMUI_ListBox; _allPortRotations:CM_PortRotationArray );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2009	cnwer1	Initial creation

*/

vars
	portRotation : CM_PortRotation;
	port : CM_Port;
begin
	_listBox.clear;
	if _allPortRotations &lt;&gt; null then
		foreach portRotation in _allPortRotations do
			port:=portRotation.myPort;
			_listBox.addTreeObject(self.displayEntryPort(port),port,1,true);
			foreach port in portRotation.allTranshipPorts do
				_listBox.addTreeObject(self.displayEntryPort(port),port,2,true);
			endforeach;
		endforeach;
		
	endif;
epilog

end;</source>
        <Parameter name="_listBox" type="CMUI_ListBox"/>
        <Parameter name="_allPortRotations" type="CM_PortRotationArray"/>
    </JadeMethod>
    <JadeMethod name="listBoxRORODecks" id="d5bfb9a3-f5b7-4823-84ba-cd7dcb91c661">
        <source>listBoxRORODecks(	_lstBox : CMUI_ListBox input;
					_roroStructure : CM_Object;
					_selectedDeck	: CM_Deck);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	subDeck,
	deck : CM_Deck;
	idx  : Integer;
	iter, subDeckIter  : Iterator;
begin
	_lstBox.clear;
	_lstBox.sorted:=false;

	if _roroStructure.isKindOf(CM_ROROVesselStructure) then
		iter:=_roroStructure.CM_ROROVesselStructure.allDecks.createIterator;
	elseif _roroStructure.isKindOf(CM_ROROVoyageStructure) then
		iter:=_roroStructure.CM_ROROVoyageStructure.allDecks.createIterator;
	endif;
	
	while iter.next(deck) do	
		_lstBox.addItem(deck.code);
		_lstBox.itemObject[_lstBox.newIndex]:=deck;
		_lstBox.itemLevel[_lstBox.newIndex]:=1;
		_lstBox.itemExpanded[_lstBox.newIndex]:=true;
		
		delete subDeckIter;
		subDeckIter:=deck.getSubDeckCollection.createIterator;
		while subDeckIter.next(subDeck) do
			_lstBox.addItem(subDeck.code);
			_lstBox.itemObject[_lstBox.newIndex]:=subDeck;
			_lstBox.itemLevel[_lstBox.newIndex]:=2;
			_lstBox.itemExpanded[_lstBox.newIndex]:=true;
		endwhile;
		
	endwhile;
	
	if _selectedDeck &lt;&gt; null then
		_lstBox.listObject:=_selectedDeck;
		//if it is a multi select list box just setting the list object does not
		// show the visual selection !!!!! if it isn't multi select is does
		_lstBox.itemSelected[_lstBox.listIndex]:=true;
	endif;

epilog
	delete iter;
	delete subDeckIter;
end;</source>
        <Parameter name="_lstBox" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_roroStructure" type="CM_Object"/>
        <Parameter name="_selectedDeck" type="CM_Deck"/>
    </JadeMethod>
