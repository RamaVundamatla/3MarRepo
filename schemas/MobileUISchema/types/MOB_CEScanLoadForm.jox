    <JadeMethod name="doPreRowColChange" id="198514e6-efa5-40b8-874a-beb79a2c8b7e">
        <source>doPreRowColChange(tbl : Table input):Boolean;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	strLocation 	: String;
	location 		: CM_LocationsController;
	obj  			: Object;
	cmif 			: CMIF_TIGenCargo;
	selectedRows    : IntegerArray;
	rowPointer      : Integer;
begin

	if tbl.selected then
		//20/05/2009 cnwdz2 ccms1801
		create selectedRows transient;
		self.tbl_Items.getAllSelectedRows(selectedRows);
		
		foreach rowPointer in selectedRows do
			strLocation := tbl.accessCell(rowPointer, 2).text.trimBlanks.toUpper;
	//		strLocation := tbl.accessCell(tbl.row, 2).text.trimBlanks; // dh par 17068
			tbl.accessCell(rowPointer, 2).text := strLocation;
			if strLocation &lt;&gt; null then
				location := self.myMobileDataAgent.findAndVerifyLocation(strLocation);
				if location &lt;&gt; null then
					obj := tbl.accessRow(rowPointer).itemObject;
					if obj &lt;&gt;  null then
						cmif := obj.CMIF_TIGenCargo;
						cmif.setMyNewLocation(location);
					endif;
				else
					return false;
				endif;
			endif;
		endforeach;
	endif;

	return true;
epilog
	delete selectedRows;
end;</source>
        <Parameter name="tbl" type="Table" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="b3db19b7-6dde-43de-bef8-d136092cda78">
        <source>doSave(): Boolean;
/*
	Created on 23 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	id : String;
	result 	: Integer;
	selectedCMIFs : CMIF_Array;
begin
	if not self.doPreRowColChange(self.tbl_Items) then
		return false;
	endif;
	//20/05/2009 cnwdz3 ccms1801
	create selectedCMIFs transient;
	self.tbl_Items.getAllSelectedObjects(selectedCMIFs);
	while true do
		if self.myMobileDataAgent.doSaveCMIFs(selectedCMIFs,id) then			
			break;
		else
			if app.myPassport.hasErrors then
				result := app.showErrorWarningDialog('Errors for item ' &amp; id &amp; '; Warnings for all items', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			else
				result := app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			endif;
			if app.myPassport.noErrors
			and result = IDOK then
		// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;	
	endwhile;
	return true;
epilog
	delete selectedCMIFs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doScanEnterItem" id="fe12dd85-50b3-4f96-95eb-ac26cac28abd">
        <updating/>
        <source>doScanEnterItem()updating;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	id 			: String;
	
begin
	if not doPreRowColChange(tbl_Items) then
		return;
	endif;

	id := self.txt_CargoID.text.trimBlanks.toUpper();
	// Check the scanned item is validate PAR 17308
	if not self.validateCargoID(id) then
		self.txt_CargoID.text := '';
		self.txt_CargoID.setFocus();
		return;
	endif;
	
	if self.itemAlreadyInTable(id, tbl_Items) then
		app.msgBox(app.getErrorString(Duplicate_entry), '', MsgBox_OK_Only);
		self.txt_CargoID.text := '';
		self.txt_CargoID.setFocus();
		return;
	endif;
	
	self.createCmifTIFromID(id);
	self.loadTable(tbl_Items);
	self.txt_CargoID.text := '';
	self.txt_CargoID.setFocus();
end;</source>
    </JadeMethod>
