//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/10/2009	cnwdap1		PAR #21334 Make release form non-modal
// 25/02/2014	cnwdap1		PAR #33582 Security Gate no vehicle changes
// 14/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// 31 Aug 2023 	navhl20 	Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
// ---------------------------------------------------------------------------

vars

begin
	
	//if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then		// PAR #33582
