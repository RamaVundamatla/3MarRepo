    <JadeMethod name="displayPlanningNotes" id="46826c84-5443-4d8c-a7ea-e578e9cde1f3">
        <source>displayPlanningNotes(dateOfNote : Date);
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	height 			: Real;
	histString		: String;
	iter			: Iterator;
	planningNote	: HMS_PlanningNote;
begin
	height := self.txtRemarks.parent.height - self.lblMeterMarks.height - 20;
	self.txtPlanningHist.top :=self.frmMarksToolbar.height;  // ### TFS 50421 17SEP2021 NAVAB1  self.lblMeterMarks.height + 7;
	self.txtPlanningHist.height := height / 2;
	self.txtPlanningHist.visible := true;
	self.txtPlanningHist.readOnly := true;
	self.txtPlanningHist.backColor := LightYellow;
	self.txtRemarks.top := self.txtPlanningHist.top + self.txtPlanningHist.height;
	self.txtRemarks.height := height / 2 ;

	iter := self.myHarbour.allHMSPlanningNotes.createIterator();
	
	self.myHarbour.allHMSPlanningNotes.startKeyGtr (dateOfNote, iter);
	while iter.back (planningNote) do
		if dateOfNote = planningNote.dateOfNote then
			histString := histString &amp; planningNote.myUser.getDisplayDetails(true) &amp; " " &amp; planningNote.createdTime.display &amp; CrLf;
			histString := histString &amp; planningNote.text &amp; CrLf;
		endif;
	endwhile;
	self.txtPlanningHist.text := histString;
	self.txtRemarks.setFocus();
epilog
	delete iter;
end;</source>
        <Parameter name="dateOfNote" type="Date"/>
    </JadeMethod>
