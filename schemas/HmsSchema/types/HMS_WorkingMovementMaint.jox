    <JadeMethod name="setColumnIndex" id="247b946f-cc2d-408b-b149-0f17448ef2f7">
        <updating/>
        <source>setColumnIndex() updating, protected;
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
// 15 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblResources;
	
	self.aColResourceType := tmpTable.getColumnByRowName(ETRow_MyResourceType);
	self.aColResource := tmpTable.getColumnByRowName(ETRow_MyResource);
	self.aColDateFrom := tmpTable.getColumnByRowName(ETRow_FromDate);
	self.aColDateTo := tmpTable.getColumnByRowName(ETRow_ToDate);
	self.aColTimeFrom := tmpTable.getColumnByRowName(ETRow_FromTime);
	self.aColTimeTo := tmpTable.getColumnByRowName(ETRow_ToTime);
	self.aColUnitsUsed := tmpTable.getColumnByRowName(ETRow_UnitsUsed);
	self.aColQtyUnits := tmpTable.getColumnByRowName(ETRow_QuantityUnits);	
	self.aColInvNo := tmpTable.getColumnByRowName(ETRow_MyVTMISTransaction);	
	self.aColCreateCharge := tmpTable.getColumnByRowName(ETRow_CreateCharge);	
	self.aColPartOfContract := tmpTable.getColumnByRowName(ETRow_PartOfContract);
	tmpTable := self.tblPilotLaunch; // TFS 44438
	self.aColPilot := tmpTable.getColumnByRowName(ETRow_MyPilot); // TFS 44438
	self.aColPilotLaunch := tmpTable.getColumnByRowName(ETRow_MyPilotLaunch); // TFS 44438			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultActOrderTimes" id="242d5b29-cfeb-4637-8b9c-37ff0d397998">
        <updating/>
        <source>setDefaultActOrderTimes() updating, protected;

vars
 	baseTime:		TimeStamp;
 	launchOffset:	Time;
 	launchActual:	TimeStamp;
 	linesOffset:	Time;
 	linesActual:	TimeStamp;
 	tugsOffset:		Time;
 	tugsActual:		TimeStamp;
	harbour:		HMS_Harbour;	
begin
 	// Set harbour and terminal references
 	harbour	:=	self.myTerminal.myHarbour;
	
 	if harbour = null then
 		return;
 	endif;
	
	if aMySelectedMovement = null then
		return;
	endif;
	
	baseTime	:=	self.aMySelectedMovement.occursOnDT;

    // Set actual times
    // Lines actual

    if txtLineRelative.text.Integer &lt; 0 then
    	linesOffset.setTime(0,((txtLineRelative.text.Integer) * -1), 0, 0);
    	linesActual	:=	baseTime-linesOffset;
    else
    	linesOffset.setTime(0, txtLineRelative.text.Integer, 0, 0);
    	linesActual	:=	baseTime + linesOffset;
    endif;
// cnwdad1 18/06/2009 - PAR #19942.
    //txtLineOrderAct.text	:=	linesActual.Time.userFormat($CM_HMS_Time24Hour);
	txtLineOrderAct.text	:=	linesActual.Time.format(app.getTimeShortFormat(false));

       // Launch actual
	if txtLaunchRel.text.Integer &lt; 0 then
    	launchOffset.setTime(0,((txtLaunchRel.text.Integer) * -1), 0, 0);
    	launchActual	:=	baseTime - launchOffset;
    else
    	launchOffset.setTime(0, txtLaunchRel.text.Integer, 0, 0);
    	launchActual	:=	baseTime + launchOffset;
    endif;
// cnwdad1 18/06/2009 - PAR #19942.
    //txtLOrderActual.text	:=	launchActual.Time.userFormat($CM_HMS_Time24Hour);
	txtLOrderActual.text	:=	launchActual.Time.format(app.getTimeShortFormat(false));

    // Tugs actual

    if txtTugRelative.text.Integer &lt; 0 then
    	tugsOffset.setTime(0,((txtTugRelative.text.Integer) * -1), 0, 0);
    	tugsActual	:=	baseTime - tugsOffset;
    else
    	tugsOffset.setTime(0, txtTugRelative.text.Integer, 0, 0);
    	tugsActual	:=	baseTime + tugsOffset;
    endif;
// cnwdad1 18/06/2009 - PAR #19942.
    //txtTugOrderAct.text	:=	tugsActual.Time.userFormat($CM_HMS_Time24Hour);
	txtTugOrderAct.text	:=	tugsActual.Time.format(app.getTimeShortFormat(false));
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultMarksForBerth" id="98f7f22e-ae38-4adf-8aaa-31f6cb3b18cb">
        <updating/>
        <source>setDefaultMarksForBerth(berth:	HMS_Berth) :Integer updating, protected;

vars
	centreOfBerth:		Integer;
begin
	// Calculate centre of berth
	centreOfBerth:=berth.startPosition+((berth.length/2).Integer);
	return centreOfBerth;
end;</source>
        <access>protected</access>
        <Parameter name="berth" type="HMS_Berth"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultRelOrderTimes" id="ff384893-cc0a-4db4-a728-9c34ab1734d6">
        <updating/>
        <source>setDefaultRelOrderTimes() updating, protected;
//
// Changed On	By			Reason
// ==========	========	=====================================================
// 17/08/2012	cnwdap1		PAR #30145 Allow Pilot on Shift Movements if configured
vars
 	baseTime:		TimeStamp;
	movePrevious:	CMIF_HMS_WorkingMovement;
	berthTo, berthFrom : HMS_Berth;
	harbour:		HMS_Harbour;	
begin
 	// Set harbour and terminal references
 	harbour:= self.myTerminal.myHarbour;
 	if harbour = null then
 		return;
 	endif;
	if aMySelectedMovement = null then
		return;
	endif;
	baseTime:=aMySelectedMovement.occursOnDT;


	// Set basetime offsets

	if aMySelectedMovement.requiresMarineServices = false then
		//This movement does not need pilot or tugs (e.g. Sea to Roadstead)
		shtMarineService.enabled:= false;
	endif;

 	// Set references
 	movePrevious:=aMySelectedMovement.getMovementPrevious;
 	berthTo:=aMySelectedMovement.myBerth;
 	if movePrevious&lt;&gt;null then
 		berthFrom:=movePrevious.myBerth;
 	endif;

	// [ARRIVAL]
	if aMySelectedMovement.moveType=HMSMovementTypeArrival or 
		//We are 'shifting' into the harbour from anchorage etc.)
		(aMySelectedMovement.moveType=HMSMovementTypeShift and berthFrom.noMarineServices = true) then
		// Default lines order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[1]&gt;-1 then
    		txtLineRelative.text:="+" &amp; harbour.defaultOrderTimesArrive[1].String;
   		else
    		txtLineRelative.text:=harbour.defaultOrderTimesArrive[1].String;
		endif;
		// Default pilot launch order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[2]&gt;-1 then
    		txtLaunchRel.text:="+" &amp; harbour.defaultOrderTimesArrive[2].String;
   		else
    		txtLaunchRel.text:=harbour.defaultOrderTimesArrive[2].String;
		endif;
		cmbLaunchPosn.listIndex:=AlongSide;
		cmbLaunchPosn.text:=cmbLaunchPosn.itemText[cmbLaunchPosn.listIndex];

		// Default tugs order time [ARRIVAL]
		if harbour.defaultOrderTimesArrive[3]&gt;-1 then
    		txtTugRelative.text:="+" &amp; harbour.defaultOrderTimesArrive[3].String;
   		else
    		txtTugRelative.text:=harbour.defaultOrderTimesArrive[3].String;
		endif;
		cmbTugPosn.listIndex:=OnStation;
		cmbTugPosn.text:=cmbTugPosn.itemText[cmbTugPosn.listIndex];

	//[DEPARTURE]
	elseif aMySelectedMovement.moveType=HMSMovementTypeDeparture  or
		//We are departing to an anchorage etc
		(aMySelectedMovement.moveType=HMSMovementTypeShift and berthTo.noMarineServices = true) then

		// Default lines order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[1]&gt;-1 then
    		txtLineRelative.text:="+" &amp; harbour.defaultOrderTimesDepart[1].String;
   		else
    		txtLineRelative.text:=harbour.defaultOrderTimesDepart[1].String;
		endif;
		// Default pilot launch order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[2]&gt;-1 then
    		txtLaunchRel.text:="+" &amp; harbour.defaultOrderTimesDepart[2].String;
   		else
    		txtLaunchRel.text:=harbour.defaultOrderTimesDepart[2].String;
		endif;
		cmbLaunchPosn.listIndex:=OnStation;
		cmbLaunchPosn.text:=cmbLaunchPosn.itemText[cmbLaunchPosn.listIndex];
		// Default tugs order time [DEPARTURE]
		if harbour.defaultOrderTimesDepart[3]&gt;-1 then
    		txtTugRelative.text:="+" &amp; harbour.defaultOrderTimesDepart[3].String;
   		else
    		txtTugRelative.text:=harbour.defaultOrderTimesDepart[3].String;
		endif;
		cmbTugPosn.listIndex:=AlongSide;
		cmbTugPosn.text:=cmbTugPosn.itemText[cmbTugPosn.listIndex];
	//[SHIFT: Except those to and from anchorages etc]
	elseif aMySelectedMovement.moveType=HMSMovementTypeShift then
		// Default lines order time [SHIFT]
		if harbour.defaultOrderTimesShift[1]&gt;-1 then
    		txtLineRelative.text:="+" &amp; harbour.defaultOrderTimesShift[1].String;
   		else
    		txtLineRelative.text:=harbour.defaultOrderTimesShift[1].String;
		endif;
		// Default pilot launch order time [SHIFT]
			// Not required
			// PAR #30145 can now be configured to allow pilot details on shift movements
			if not self.myTerminal.getConfig(PilotOnShiftMovement).Boolean then
				cmbLaunchPosn.enabled:=false;
				cmbPilotLaunch.enabled:=false;
				txtLaunchRel.enabled:=false;
				txtLOrderActual.enabled:=false;
			endif;

		// Default tugs order time [SHIFT]
		if harbour.defaultOrderTimesShift[2]&gt;-1 then
    		txtTugRelative.text:="+" &amp; harbour.defaultOrderTimesShift[2].String;
   		else
    		txtTugRelative.text:=harbour.defaultOrderTimesShift[2].String;
		endif;
		cmbTugPosn.listIndex:=AlongSide;
		cmbTugPosn.text:=cmbTugPosn.itemText[cmbTugPosn.listIndex];
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormReadOnly" id="f05689bf-dc10-4171-8d18-ca26ccc28b59">
        <updating/>
        <source>setFormReadOnly() updating, protected;
