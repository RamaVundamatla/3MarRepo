    <JadeMethod name="utlUpdateCodeGeneric" id="e1f2610f-f64a-46f9-b6d0-2249e2775ed1">
        <source>utlUpdateCodeGeneric(_proxyCodeGeneric:CM_CodeGeneric; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars
	realCodeGeneric	: CM_CodeGeneric;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	_proxyCodeGeneric.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyCodeGeneric.pxyGetRealObjectAndEdition(realCodeGeneric, expectedEdition);
	
	if realCodeGeneric = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CodeGeneric.name, null, null);
		return;
	endif;

	app.myValUA.valCodeGeneric(realCodeGeneric, _proxyCodeGeneric);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realCodeGeneric);

	if _passport.noErrors and realCodeGeneric.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Log CodeGroup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCodeGeneric, true);
	endif;
	
	if _passport.noErrors then
		realCodeGeneric.setForUpdate(_proxyCodeGeneric);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCodeGeneric, false);
	endif;

end;</source>
