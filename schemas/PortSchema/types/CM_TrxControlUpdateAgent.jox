        <updating/>
        <source>trxUpdateHMSWorkingVoyages(_cmifViewController : CMIF_HMS_ViewController input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	// Always initialize the activity first
