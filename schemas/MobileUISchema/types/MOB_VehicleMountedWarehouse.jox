    <JadeMethod name="doLoadDirectorCargo" id="864800f8-b5ee-45d2-b7eb-f70381d03a79">
        <source>doLoadDirectorCargo(task : CM_RTQueueTask) protected;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars
	allDirectorCargo : CM_TIArray;
	ti : CM_TrackedItem;
begin
	
	if task = null then
		return;
	endif;
	self.frmDirector.userObject:=task;
	create allDirectorCargo transient;
	task.getDirectorTaskCargo(null,allDirectorCargo,null); //epr TFS 6863 14/9/17 
	
	foreach ti in allDirectorCargo do
		app.myVMAgent.loadRTTableFromDTORTEntry(self.tblDirector,ti);
	endforeach;
epilog
	delete allDirectorCargo;
end;</source>
