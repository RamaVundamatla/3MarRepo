begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;
	
	app.myUtilityUA.utlUpdateDataDumpExtrClassCmpt(
			_extractClass, _expectedEdition,
			_updateExtractedUpTo, _extractedFromDateTime, _extractedUpTo,
			_startTs, _finishTs, _numCreates, _numUpdates, _numDeletes,
			_systemAlertCreated, _userCode, _userName, _deleteOids, _addOids, _updateOids, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
