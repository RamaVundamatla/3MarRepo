    <JadeMethod name="zDoAdd" id="73a66e85-9839-495c-ba34-54a12a7aa1d9">
        <updating/>
        <source>zDoAdd() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
----------   ----------  --------------------------------------------------
*/
vars
	frm			: GTE_ReleaseRequests;
	bulkRelease	: CM_BulkRelease;

begin
	//+cnwml2 PAR23230
	//when the user attempts to add an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;


	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	
	create bulkRelease transient;//form cleans this up
	self.myAssistant.releaseRequestAdd(bulkRelease, self.cmbType.listData(), self.myMasterMenuAction,null);			//14.6.2023 navhl20 #58634
	
end;




</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="5961ec18-2c98-4fa8-9dce-93ca278524de">
        <updating/>
        <source>zDoEdit() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
*/
vars
	bulkRelease	: CM_BulkRelease;
	
begin
	//+cnwml2 PAR23230
	//when the user attempts to edit an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;

	if (self.allowUpdate = false) or
	   (self.mode &lt;&gt; Mode_View) then 
		//Must not be already editing an object
		return;
	endif;
	
	//Check here to prevent case of user clicking edit button on form straightaway. //PAR15335
	if not self.myCurrentObject.isKindOf(CM_BulkRelease) then
	// can also have CM_Reserve objects on screen
		return;
	endif;
	
	bulkRelease := self.myCurrentObject.CM_BulkRelease;
	
	if bulkRelease.isForBookingRef() then	// editing enhanced booking request, instead of bulk release. PAR 20296, Sep 2009
		self.myAssistant.GTE_Assistant.doAddEditBookRequest(bulkRelease.myBookingRefStock);
		
	else	// usual way for bulk release editing
		self.myAssistant.GTE_Assistant.releaseRequestUpdate(bulkRelease, self.myMasterMenuAction,null);			//14.6.2023 navhl20 #58634
	
	endif;
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyCreate" id="6b87fb0a-7efb-4394-b855-81d246ce47b9">
        <updating/>
        <source>zTblDataSysNotifyCreate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	bulkRelease 		: CM_BulkRelease;
begin
	inheritMethod(eventType, theObject, eventTag);

	//epr par 12715 11/10/06 
	//when a new bulk release is created need to add the bulk release no to the bulk release no combo box
	
	if theObject &lt;&gt; null and theObject.isKindOf(CM_BulkRelease) then
		bulkRelease:=theObject.CM_BulkRelease;
		self.updateBulkReleaseCombo(bulkRelease);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
