    <JadeMethod name="clickDoSave" id="e7736924-3e10-4571-b1e0-80b6e453d2b0">
        <updating/>
        <source>clickDoSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	systemQuickAccess : CM_QuickAccessSystem;
	userQuickAccess : CM_QuickAccess;
	shortCut : String;
	desc : String;
	pxyQuickAccess : CM_QuickAccessUser;
	load : Boolean;
	pos : Integer;
	char : Character;

begin

	shortCut := self.txtShortCut.text.trimBlanks;
	desc := self.txtDescription.text.trimBlanks;
	
	if self.permissionInt &lt; 1 then
		app.msgBox(app.getErrorString(Nothing_Selected),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	if shortCut = null then
		app.msgBox(app.getErrorString(Short_value_required),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	if desc = null then
		app.msgBox(app.getErrorString(Input_required_field_Desc),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	
	foreach pos in 1 to shortCut.length do
		char := shortCut[pos].Character;
		if not char.isAlpha and not char.isNumeric then
			app.msgBox(app.getErrorString1(Short_value_not_includ_charac, char.String),app.getErrorString(Error),MsgBox_OK_Only);
			return;
		endif;
	endforeach;
	
	systemQuickAccess := app.myRoot.getQuickAccessByPermission( self.permissionInt ).CM_QuickAccessSystem;
	if systemQuickAccess = null then
		app.msgBox(app.getErrorString(Matchi_system_quick_access_fou),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	
	userQuickAccess := self.myUser.allUserQuickAccess.getAtKey( shortCut );
	if userQuickAccess &lt;&gt; null and userQuickAccess.permissionInteger &lt;&gt; self.permissionInt then
		app.msgBox(app.getErrorString(Have_alrea_used_this_short_val),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	
	userQuickAccess := self.myUser.getQuickAccessByPermission( self.permissionInt ).CM_QuickAccess;
	if userQuickAccess = null or userQuickAccess.isKindOf( CM_QuickAccessSystem ) then
		//new user one
		userQuickAccess := null;
		create pxyQuickAccess transient; 
	else
		//update existing user one
		app.cmsBeginLoad(load);
		pxyQuickAccess := userQuickAccess.pxyCreateUpdateProxy().CM_QuickAccessUser;
		app.cmsEndLoad(load);
	endif;
	
	pxyQuickAccess.setProxy(	desc,	//_helpDescription : String;
								self.permissionInt,	//_permissionInteger : Integer;
								shortCut,	//_shortCode : String;
								systemQuickAccess.isForm,	// : Boolean;
								systemQuickAccess.allowsOption,	// : Boolean;
								self.myUser	//_user : CM_User
								);
								
	if userQuickAccess = null then
		//new user one
		app.myTrxCA.trxCreateQuickAccess(pxyQuickAccess, userQuickAccess, app.myPassport);
	else
		//update existing user one
		app.myTrxUA.trxUpdateQuickAccess(pxyQuickAccess, app.myPassport);
	endif;
	
	if app.myPassport.hasErrors then
		app.msgBox(app.myPassport.getAllErrorsWarningsAsString,app.getErrorString(Error),MsgBox_OK_Only);
	endif;
	
	self.populateTblUser( null );

epilog

	delete pxyQuickAccess;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickDoUseDefault" id="2553ab09-952a-4968-8df4-6c493b45de79">
        <updating/>
        <source>clickDoUseDefault() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	userQuickAccess : CM_QuickAccess;
	deleteObj : CM_Object;

begin

	if self.permissionInt &lt; 1 then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	userQuickAccess := self.myUser.getQuickAccessByPermission( self.permissionInt ).CM_QuickAccess;
	if userQuickAccess = null or userQuickAccess.isKindOf( CM_QuickAccessSystem ) then
		app.msgBox( app.getErrorString(Using_sytem_default_access), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	deleteObj := userQuickAccess;
	app.myTrxDA.trxDeleteCMObject(deleteObj, app.myPassport);
	
	if app.myPassport.hasErrors then
		app.msgBox(app.myPassport.getAllErrorsWarningsAsString,app.getErrorString(Error),MsgBox_OK_Only);
	endif;
	
	self.populateTblUser( null );
	
	self.tblSystem_click( self.tblSystem );


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickTblUser" id="d9a5f060-f295-4a39-93f9-ced7b559d0c3">
        <updating/>
        <source>clickTblUser() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	quickAccess : CM_QuickAccess;
	systemQuickAccess : CM_QuickAccess;
	userQuickAccess : CM_QuickAccess;

begin

	rowIndex := self.tblUser.row;
	quickAccess := self.tblUser.accessRow( rowIndex ).itemObject.CM_QuickAccess;
	
	foreach rowIndex in 2 to self.tblSystem.rows do
		self.tblSystem.accessRow(rowIndex).selected := false;
	endforeach;
	foreach rowIndex in 2 to self.tblUser.rows do
		self.tblUser.accessRow(rowIndex).selected := false;
	endforeach;
		
	if quickAccess &lt;&gt; null then
		foreach rowIndex in 2 to self.tblSystem.rows do
			systemQuickAccess := self.tblSystem.accessRow(rowIndex).itemObject.CM_QuickAccess;
			if systemQuickAccess.permissionInteger = quickAccess.permissionInteger then
				self.tblSystem.accessRow(rowIndex).selected := true;
				self.tblSystem.row := rowIndex;
				self.tblSystem.topRow := rowIndex;
				break;
			endif;
		endforeach;
	else
		self.tblSystem.row := 1;
		self.tblSystem.topRow := 1;
	endif;
	
	self.displayQuickAccess(quickAccess);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayQuickAccess" id="a4da1e63-4591-47c4-b8c4-c89608191e7e">
        <updating/>
        <source>displayQuickAccess( _quickAccess : CM_QuickAccess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

begin

	if _quickAccess = null then
		self.txtShortCut.text := null;
		self.txtDescription.text := null;
		self.permissionInt := 0;
		self.btnDefault.enabled := false;
		self.btnUpdate.enabled := false;
	else
		self.txtShortCut.text := _quickAccess.shortCode;
		self.txtDescription.text := _quickAccess.helpDescription;
		self.permissionInt := _quickAccess.permissionInteger;
		self.btnDefault.enabled := _quickAccess.isUser;
		self.btnUpdate.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="_quickAccess" type="CM_QuickAccess"/>
    </JadeMethod>
