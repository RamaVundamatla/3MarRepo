    <JadeMethod name="cnEcHasSubmenu" id="579dac7b-b63d-442c-a371-f852ff29be3c">
        <source>cnEcHasSubmenu():Boolean;
// --------------------------------------------------------------------------------
// Created:		18 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has any
//				submenu items.
//
// Parameters:	None
//
// Returns:		True if the receiver has submenus, otherwise false;
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.hasSubMenu;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsSeparator" id="7f51c629-61f0-417d-9fbc-0497f0dc03e9">
        <source>cnEcIsSeparator():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a menu
//				separator.
//
// Parameters:	None
//
// Returns:		True if the Menu Item is a menu separator, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.caption = self.CNEC_MENU_SEPARATOR);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
