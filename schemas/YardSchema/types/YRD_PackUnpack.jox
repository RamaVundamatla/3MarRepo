    <JadeMethod name="setWeightByRow" id="f9047061-e616-46a3-83e7-fbaaa02a7735">
        <source>setWeightByRow(_entRowName : String; _updatedWeight : Decimal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2024	navnk30 Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
20 Nov 2025	navah1	MTN-36555: STWO - Incorrect Total Weight Calculation for MAFI When Packing Multiple Cargo Items
*/

vars
	rowName,
	weightDefault,
	weightStr		: String;
	rowId			: Integer;
	
begin
	if _entRowName &lt;&gt; ETRow_WeightTotal and _entRowName &lt;&gt; ETRow_CargoWeight then
		return;
	endif;
	weightDefault := app.getDefaultMeasurementForType(Type_Weight).shortName;
	rowName := Prefix_Weight &amp; _entRowName &amp; "_" &amp; weightDefault;
	rowId	:= tblContainer.getRow(rowName);
	weightStr := app.convertMeasurementForDisplay(weightDefault, _updatedWeight) &amp; Space &amp; weightDefault;
	//self.tblContainer.accessCell(rowId, CM_EntryTable.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(weightStr); //26.11.2025 navah1 #MTN-36555
	if rowId &lt;&gt; 0 then //26.11.2025 navah1 #MTN-36555
		self.tblContainer.accessCell(rowId, CM_EntryTable.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(weightStr);
	endif;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_updatedWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="619b1b19-00f8-4cb4-b279-996b0617ae0b">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 13 Apr 2024 navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
// ---------------------------------------------------------------------------

vars
	a : Integer;
begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	inheritMethod();
	
	//10 Dec 2013	NDL	Par 32854
	//Users who sign up from 8.3.1 onwards don't get to see
	//the old style create and make LCL forms
	if app.myRoot.isDeprecated("8.3.1") then
		self.mnuEnhanced.checked := true;
	endif;
	
	self.doCmbBRBuild();
	self.cmbBooking.style := ComboBox.Style_DropDown;				//+cnwml2 PAR26130
	self.getXMLSettingsForSetup();									// 37288
	// 37288
	self.chbFilter.bubbleHelp := "Show only parent and child cargo matching the Packing Release criteria.";

	//	self.initDataTable(self.tblUnpacked, ETDef_PackItems);		// cnwrl1 10/11/2010 PAR 23899 - what it was
//	self.initDataTable(self.tblPacked, ETDef_PackItems);		// cnwrl1 10/11/2010 PAR 23899 - what it was
	// make the columns common with the cargo enquiry form with no cargo type selected.
	self.initDataTable(self.tblUnpacked, ETDef_CargoEnqDefaultData);
	self.initDataTable(self.tblPacked, ETDef_CargoEnqDefaultData);
	self.initTableQuery();
	self.initTableContainer();

	self.sptMain.top := self.frmToolbar.height;
	self.sptRight.setLeftToRightRatio(75);
	//center the query frame
	self.frmQuery.boundaryWidth := 4;
	self.frmQuery.top := 100;
	self.frmQuery.left := (self.width / 2) - ( self.frmQuery.width / 2);
	self.frmQuery.zOrder(1);
	
	self.tblPacked.accessColumn(1).sortOrder := 1;
	self.tblUnpacked.accessColumn(1).sortOrder := 1;
	self.setNavigatorHeading(self.myTerminal.code);
	self.isSelectorCapable := true;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCreateLCL.enabled:= false;
		self.btnMakeLCL.enabled:= false;
		self.btnMakeHaz.enabled:= false;
		self.mnuCreateAttachments.enabled:= false;
		self.mnuCreateCargoUnpack.enabled:= false;
		self.mnuEditContainer.enabled:= false;
	
		foreach a in 1 to self.tblContainer.rows do
			self.tblContainer.disableRow(a);
		endforeach;
		self.tblContainer.enableRowByName(ETRow_ContainerID);
		self.tblContainer.enableRowByName(ETRow_CargoTypeNonQuery);
	endif;
	self.btnInstruction.enabled	:= false;	//07.10.2022 navtnr20 TFS 54967
	self.beginClassNotification(CMUI_AttachBreakBulkModal, true, CMUI_AttachBreakBulkModal.LCLCargosCreated, Response_Continuous, 0);		//13.04.2024 navnk30 #63247
	self.beginClassNotification(CMUI_ReceiveCargoForm, true, CMUI_AttachBreakBulkModal.LCLCargosCreated, Response_Continuous, 0);			//13.04.2024 navnk30 #63247
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelector" id="dbab2c76-230d-4edb-be22-48f4565f662a">
        <updating/>
        <source>showSelector() protected, updating;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theSelector				: CMUI_Selector;
begin
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	
	if theSelector = null then
		return;
	endif;
	
	theSelector.myTerminal := self.myTerminal;
	//get the first cargoType selected to find appropriate selector mode, else just open in TI mode
	if self.cmbQryTermArea.listObject &lt;&gt; null then
		theSelector.myDefaultTerminalArea := self.cmbQryTermArea.listObject.CM_TerminalArea;
	endif;
	
	if self.cmbQryCargoType.listObject &lt;&gt; null then
		theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type, self.cmbQryCargoType.listObject.CM_CargoBOLType.id];
	endif;
	
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
