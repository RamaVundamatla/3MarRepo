	_time			:= self.xmlStruct.findStructure(XML_TIME).tagData;
	_terminal		:= self.xmlStruct.findStructure(XML_TERMINAL).tagData;

epilog
	
	return canContinue;
	
end;</source>
        <Parameter name="_messageId" type="String" usage="output"/>
