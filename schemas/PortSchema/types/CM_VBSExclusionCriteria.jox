    <JadeMethod name="hideTheVbsAssocForm" id="c109d7ce-415d-4c27-8ad1-94b361c0c99e">
        <source>hideTheVbsAssocForm( _vvr : CM_VehicleVisitRecord ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

	allCargo : CM_TIArray;
	iter : Iterator;
	gteEntity : CMGTE_Entity;
	ti : CM_TrackedItem;

begin

	if not self.myVehicleBookingTerminal.myTerminal.isVehicleBookingEnabled then
		// should never be called if VBS is OFF, but if it is, then HIDE the form
		return true;
	endif;
	
	if _vvr = null then
		// should never be the case, but if it is, then HIDE the form
		return true;
	endif;
	
	//Get all of the real cargo items directly associated with the vvr.
	//( As we are coming into teh terminal through the gate )
	create allCargo transient;
	iter := _vvr.allGateEntities.createIterator;
	while iter.next( gteEntity ) do
		ti := gteEntity.getTI();
		if ti &lt;&gt; null then
			allCargo.add( ti );
		endif;
	endwhile;
	
	//If there is no real cargo show do NOT hide the form
	if allCargo.isEmpty then
		return false;
	endif;
	
	foreach ti in allCargo discreteLock do
		if not self.matches(ti) then
			//At least one piece does not match teh criteria, do NOT hide the form
			return false;
		endif;
	endforeach;
	
	// We have cargo AND All the cargo matches the criteria, HIDE the form
	return true;

epilog

	delete allCargo;
	delete iter;

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
