    <JadeMethod name="translateToSearchValue" id="05320792-4ed2-4539-8182-c0a99a46d4d8">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars

