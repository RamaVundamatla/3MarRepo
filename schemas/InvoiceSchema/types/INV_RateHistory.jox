		self.cmbTradeGroup.listIndex := -1;				// TFS 37794
		self.cmbTradeDebtor.listIndex := -1;			// TFS 37794
		self.cmbDebtor.listIndex := -1;					// TFS 37794
		self.cmbDebtorService.listIndex := -1;			// TFS 37794
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVesselType.listIndex := -1;								
		self.cmbVesselTypeService.listIndex := -1;
		
		self.cmbVisitType.listIndex := -1;							
