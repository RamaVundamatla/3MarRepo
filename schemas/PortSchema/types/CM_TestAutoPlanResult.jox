    <JadeMethod name="setBaseDetails" id="e6ec0164-5db1-467a-b4ac-08d418593c69">
        <updating/>
        <source>setBaseDetails(	_myTrackedItem : CM_TrackedItem;
				_cmifYAPlanScenario  : CMIF_YAAutoPlanSenario;
				_myPrimeYardAllocation : CM_YardAllocation;
				_log : StringArray512;
				_myTestAutoPlanRoot : CM_TestAutoPlanRoot
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

		self.myTrackedItem := _myTrackedItem;
		self.myCMIF_YAAutoPlanScenario:=_cmifYAPlanScenario;
		self.myPrimeYardAllocation := _myPrimeYardAllocation;
		self.myTestAutoPlanRoot := _myTestAutoPlanRoot;
		
		self.log.clear();
		if not _log.isEmpty then
			_log.copy(self.log);
		endif;

epilog

end;</source>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_cmifYAPlanScenario" type="CMIF_YAAutoPlanSenario"/>
        <Parameter name="_myPrimeYardAllocation" type="CM_YardAllocation"/>
        <Parameter name="_log" type="StringArray512"/>
        <Parameter name="_myTestAutoPlanRoot" type="CM_TestAutoPlanRoot"/>
    </JadeMethod>
</Class>
