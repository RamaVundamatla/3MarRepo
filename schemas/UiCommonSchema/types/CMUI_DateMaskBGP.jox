    <JadeMethod name="lostFocus" id="3dca3294-e757-4b50-a172-7504bc3dd475">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;
// cnwdvb1 17 December 2002 
vars

begin
	inheritMethod(editMask);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doLostFocus(self);
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyFrame" id="d3abc18c-d49b-4edd-ade6-3dcef8e7dd51">
        <updating/>
        <source>setMyFrame(_frame : CMUI_BGPAutoScheduleFrame) updating;
// cnwdvb1 17 December 2002 
vars

begin
	self.myFrame := _frame;
end;</source>
        <Parameter name="_frame" type="CMUI_BGPAutoScheduleFrame"/>
    </JadeMethod>
