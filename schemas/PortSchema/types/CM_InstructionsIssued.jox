    <JadeMethod name="getPackingType" id="c173a633-8999-4ed5-8c23-03d82d24424b">
        <source>getPackingType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023 navhl20 Bug 61873: FR | 53891 - Mobile App changes for Delivery Dispatch (EP Tickets)

*/

vars
	rel		: CM_BulkRelease;
begin
	if self.myParent = null then
		return null;
	endif;
	
	if self.myParent.isKindOf(CM_ReserveDetail) then
		rel := self.myParent.CM_ReserveDetail.myReserveHeader;
		if rel.type = BR_TYPE_PACKING then
			return self.myParent.CM_ReserveDetail.packType;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParentType" id="385950ca-e148-4298-b3b1-b74ef1e3f297">
        <source>getParentType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navma1 ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
06 Nov 2023	navnk30	Bug 61056: EUP - Reference and Linked To columns are blank for the Cargo item instructions
*/

vars
	str : String;
begin

	if self.myParent = null then
		return "";
	endif;
	
	if self.myParent.isKindOf(CM_WorkOrder) then
		return 'WorkOrder';
	elseif self.myParent.isKindOf(CM_WorkOrderDtl) then
		return 'WorkOrder Task';
	elseif self.myParent.isKindOf(CM_BOL) then
		return 'Bill Of Lading';
	elseif self.myParent.isKindOf(CM_BOLDtl) then
		return 'Bill Of Lading Item';
	elseif self.myParent.isKindOf(CM_BulkRelease) then
		return 'Release Request';
	elseif self.myParent.isKindOf(CM_ReserveDetail) then
		return 'Release Request Item';
	elseif self.myParent.isKindOf(CM_BookingRef) then
		return 'Booking';
	elseif self.myParent.isKindOf(CM_BookingRefItem) then
		return 'Booking Item';
	elseif self.myParent.isKindOf(CM_ToDoTask) then
		return 'ToDo Task';
	elseif self.myParent.isKindOf(CM_TrackedItem) then			//06.11.2023 navnk30 #61056
		return 'Tracked Item';
	endif;
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReferenceId" id="42a0ee95-01fd-4391-b6e5-d00c0b6cff61">
        <source>getReferenceId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
06 Nov 2023	navnk30	Bug 61056: EUP - Reference and Linked To columns are blank for the Cargo item instructions

*/

vars
	obj	: CM_Object;
begin
	obj := self.myParent;
	if obj = null then
		return "";
	elseif obj.isKindOf(CM_WorkOrder) then
		return obj.CM_WorkOrder.getDisplayDetails(true);
	elseif obj.isKindOf(CM_WorkOrderDtl) then
		return obj.CM_WorkOrderDtl.taskID;
	elseif obj.isKindOf(CM_BulkRelease) then
		return obj.CM_BulkRelease.code;
	elseif obj.isKindOf(CM_ReserveDetail) then
		return obj.CM_ReserveDetail.getCargoID();
	elseif obj.isKindOf(CM_BookingRef) then
		return obj.CM_BookingRef.bookingReference;
	elseif obj.isKindOf(CM_BookingRefItem) then
		return obj.CM_BookingRefItem.getShortDisplay();
	elseif obj.isKindOf(CM_BOL) then
		return obj.CM_BOL.number;
	elseif obj.isKindOf(CM_BOLDtl)
			and obj.CM_BOLDtl.myBOL &lt;&gt; null then
		return obj.CM_BOLDtl.myBOL.number;
	elseif obj.isKindOf(CM_TrackedItem) then			//06.11.2023 navnk30 #61056
		return obj.CM_TrackedItem.id;
	else
		return "";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1dfc12c2-a3f6-4d8b-971d-b7ad29d9755b">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	pxy : CM_InstructionsIssued;
begin
	pxy :=  inheritMethod();
	pxy.externalInstruction := self.externalInstruction;
	pxy.internalInstructions := self.internalInstructions;
	pxy.myInstructionType := self.myInstructionType;
	pxy.myParent := self.myParent;
	
	return pxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
