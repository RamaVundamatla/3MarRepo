    <JadeMethod name="cmsBeginLoad" id="4b5dea19-abf5-4e84-9264-4fd2f4ca0686">
        <source>cmsBeginLoad(_loadStateSet : Boolean output);
// ---------------------------------------------------------------------------
// Created:     26 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not process.isInLoadState) then	
		_loadStateSet := true;
		beginLoad;
	endif;

end;</source>
