<GUIClass name="CMUI_PictureViewer" id="3483f3c7-c44b-4ef4-b844-bb914e892bd6">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnClose" id="9093833e-f60e-488d-8653-68cd00246bd6">
        <embedded/>
        <type name="CMUI_Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picView" id="a97e34c5-56b0-4f9b-b5d3-32357cffe2fa">
        <embedded/>
        <type name="Picture"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnClose_click" id="3d7cf47d-ebd7-4ced-9575-b4e3bf581395">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 08 December 2005
//
//********************************************************************
vars

begin
	self.doBtnCloseClick();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnCloseClick" id="24acc5b6-e4fe-42de-b1ec-432d78586cc7">
        <updating/>
        <source>doBtnCloseClick() updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 08 December 2005
//
//********************************************************************
vars

begin

	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="dc0741b3-c91e-49b7-a7b0-6ca019c99c94">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	topPos	: Real;	// The top position for the bottom button

begin
	inheritMethod();
	topPos := self.height - WinBottomMargin - btnClose.height - 10;

	btnClose.move(self.width - WinRightMargin - btnClose.width,
				  topPos,
				  btnClose.width, btnClose.height);
				  
	picView.move(WinLeftMargin, WinTopMargin,
				 self.width - WinRightMargin - WinLeftMargin,
				 topPos - WinTopMargin - VerticalSpacing);


end;</source>
    </JadeMethod>
    <JadeMethod name="setPicture" id="03ddfad2-536c-4fac-88df-ada02b2e677f">
        <source>setPicture(pPic : Binary);
// ---------------------------------------------------------------------------
// Created:     18 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.picView.picture := pPic;
	
end;</source>
        <Parameter name="pPic" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6ddbff56-82ed-44a7-a320-768e9c0c3cd9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007946, locale);
	btnClose.translateCaption(Xlat_0000640, locale);
end;</source>
    </JadeMethod>
</GUIClass>
