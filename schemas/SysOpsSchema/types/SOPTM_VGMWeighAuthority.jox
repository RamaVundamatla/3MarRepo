    <JadeMethod name="loadCombos" id="7f48e17e-e150-42d4-be02-51571aa6cf7f">
        <source>loadCombos();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	self.myForm.cmbSolasType.clear;
	self.myForm.cmbSolasType.addItem(null);
	self.myForm.cmbSolasType.addItem("SM1");
	self.myForm.cmbSolasType.addItem("SM2");	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="67f11f71-b5e5-4a95-9993-f78e6c27a1a0">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/06/2017	cnwdap1		Initial creation TFS 4492
//
vars
	form : SOP_TableMaintForm;
	row : Integer;
	terminal : CM_Terminal;
	failedDAC : CM_DataAccessController;

begin
	form := self.myForm;
	form.tblData1.userInputEnabled := true;
	form.tblInput1.userInputEnabled := true;	
	form.shtDataTable1.visible := true;
	form.shtDataTable1.enabled := true;
	
	self.loadCombos();
	
	if form.mode = form.Mode_Add then
		form.tblInput1.clearValues;
		form.tblInput1.enableRowByName(ETRow_WeightCertifiedBy);
		form.tblInput1.enableRowByName(ETRow_WeightAuthorisedBy);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_EmailAddress);
		form.tblInput1.enableRowByName(ETRow_EmailAddress2);
		form.tblInput1.enableRowByName(ETRow_IsDefault);
		form.tblInput1.enableRowByName(ETRow_Phone);
		form.tblInput1.enableRowByName(ETRow_Phone2);
		form.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
		
		self.showThumbnail_Terminal(null);
	else
		self.showThumbnail(form.myProxyObject.CM_WeighAuthority);

		// cannot update Certified By or Authorised By
		form.tblInput1.disableRowByName(ETRow_WeightCertifiedBy);
		form.tblInput1.disableRowByName(ETRow_WeightAuthorisedBy);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_AddressLine1);
		form.tblInput1.enableRowByName(ETRow_EmailAddress);
		form.tblInput1.enableRowByName(ETRow_EmailAddress2);
		form.tblInput1.enableRowByName(ETRow_IsDefault);
		form.tblInput1.enableRowByName(ETRow_Phone);
		form.tblInput1.enableRowByName(ETRow_Phone2);
		form.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
	endif;
	
	foreach row in form.tblData1.fixedRows + 1 to form.tblData1.rows do
		terminal := form.tblData1.accessRow(row).itemObject.CM_Terminal;
		if not terminal.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			form.tblData1.accessedRow.enabled := false;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="f0c97479-336d-41af-be09-702c827056d1">
