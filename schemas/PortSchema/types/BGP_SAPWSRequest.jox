    <JadeMethod name="sendRejectionEmail" id="720a7648-743e-41ba-b170-60f911f11c36">
        <source>sendRejectionEmail(_obj : CM_Object;_reasons : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 October 2018	jlgma1	ChangeRequest 41462: PEL1 - SAP Integration - Rejection Email

*/

vars
	cashRec 	: CM_CashReceipt;
	invoice 	: CM_Invoice;
	debtor  	: CM_Debtor;
	paymentype 	: Integer;
	debtorEmail : String;
	financeEmail: String;
	terminal 	: CM_Terminal;
	subject  	: String;
	strNbr      : String;
	type        : String;
begin
	if _obj.isKindOf(CM_CashReceipt) then
		cashRec     := _obj.CM_CashReceipt;
		debtor      := cashRec.getDebtor;
		terminal 	:= cashRec.myTerminal;
		strNbr   	:= cashRec.externalInvoiceNumber;
		type        := app.getErrorString(Cash_receipt);
	elseif _obj.isKindOf(CM_Invoice) then
		invoice 	:= _obj.CM_Invoice;
		debtor  	:= invoice.debtor;
		terminal 	:= invoice.myTerminal;
		//strNbr      := invoice.externalFinancialId;
		strNbr      := invoice.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
		type        := app.getErrorString(Invoice);
	endif;
	
	debtorEmail := debtor.getEmailAddress();
	financeEmail := terminal.getConfig(EmailForFinance).String;
	subject      := type &amp; ": " &amp; strNbr &amp;Tab &amp; app.getErrorString(Debtor_GC) &amp; ": "&amp; debtor.name &amp;Tab &amp; "Rejected";
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  debtorEmail,		// _toAddress
										  app.myRoot.getConfig(AutoSendersEmailAddress).String,					// _fromAddress
										  financeEmail,		// _ccAddresses
										  null,		// _bccAddresses
										  subject,			// _sendSubject
										  _reasons,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_reasons" type="String"/>
    </JadeMethod>
    <JadeMethod name="setActivityHistory" id="659c5e78-399f-4d6d-86dc-c561cb78ba17">
        <source>setActivityHistory(_pxyActivityHistory : CM_ActivityHistoryExtInterface input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars

begin
	if self.myInvoice &lt;&gt; null then
		if self.myInvoice.myVoyage &lt;&gt; null then
			_pxyActivityHistory.setVoyageCode(self.myInvoice.myVoyage.code);
		endif;
		_pxyActivityHistory.setDebtorCode(self.myInvoice.debtor.decfinName);
	elseif self.myCashReceipt &lt;&gt; null then
		if self.myCashReceipt.myVoyage &lt;&gt; null then
			_pxyActivityHistory.setVoyageCode(self.myCashReceipt.myVoyage.code);
		endif;
		_pxyActivityHistory.setDebtorCode(self.myCashReceipt.getDebtor.decfinName);
	endif;
	
	if self.myInvoice &lt;&gt; null and self.myInvoice.getSapVesselCargo = "Cargo" then
		_pxyActivityHistory.setIsCargoTransaction(true);
	elseif self.myWorkOrder &lt;&gt; null and not self.myWorkOrder.isVoyageWorkOrder then
		_pxyActivityHistory.setIsCargoTransaction(true);
	endif;
epilog

end;</source>
        <Parameter name="_pxyActivityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a80c8772-b9dc-4840-a995-6b450294f76f">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input) updating;
/*
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
25 Jul 2018 cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
14 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
31 Aug 2018 cnwma1 ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
*/
vars

begin
	inheritMethod(_proxySelf);
	self.daysLookback 				:= self.daysLookback;
	self.fromCurrency 				:= _proxySelf.fromCurrency;
	self.toCurrency 			   	:= _proxySelf.toCurrency;
	self.myWorkOrder 			 	:= _proxySelf.myWorkOrder;
	self.myCashReceipt	            := _proxySelf.myCashReceipt;
	
	self.myInvoice	     			:= _proxySelf.myInvoice;				
	self.myTerminal                 := _proxySelf.myTerminal;

	self.isSAPAutoEstReq 		   	:= _proxySelf.isSAPAutoEstReq;			 //001
	self.isSAPPreBillCheckLimitReq 	:= _proxySelf.isSAPPreBillCheckLimitReq; //002
	self.isSAPPostBillEstReq 	   	:= _proxySelf.isSAPPostBillEstReq;       //003
	self.isSAPReleaseHoldDebit  	:= _proxySelf.isSAPReleaseHoldDebit;  	 //004
	self.isSAPAutoInvReq            := _proxySelf.isSAPAutoInvReq;           //005
	self.isSAPPreBillInvoiceReq     := _proxySelf.isSAPPreBillInvoiceReq;    //006
	self.isSAPPostBillInvReq        := _proxySelf.isSAPPostBillInvReq;       //007
	self.isSAPGetExchangeRate 		:= _proxySelf.isSAPGetExchangeRate;  	 //008
	self.isSAPCancelEstimate 		:= _proxySelf.isSAPCancelEstimate;		 //009
	self.isSAPCancelPaymentCode 	:= _proxySelf.isSAPCancelPaymentCode; 	 //010
	self.isSAPPreBillProdDataReq    := _proxySelf.isSAPPreBillProdDataReq;
	self.isSAPDataKinerja           := _proxySelf.isSAPDataKinerja;  
	self.isSAPDataTPP               := _proxySelf.isSAPDataTPP;
	self.isManual					:= _proxySelf.isManual;
	
	_proxySelf.allInvoiceLines.copy( self.allInvoiceLines );	//10 May 2019	NDL	TFS 44248
	
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsGetExchangeRate" id="9da8c598-8128-4b92-8a92-37c1ca7ed0c5">
        <updating/>
        <source>setIsGetExchangeRate(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
37189.008 Request Exchange Rate
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate
*/

vars

begin
	self.isSAPGetExchangeRate := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateActivityHistory" id="d976829a-f705-4366-a4e1-caffddb47db5">
        <source>updateActivityHistory(_agent : CM_SAPWSConsumerAgent ;_response : CMIF_SAPWSResponse);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2018	 cnwma1	ChangeRequest 38633: PEL1 - SAP Send Invoice and Associated Data Interfaces
12 November 2018  	 cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
17 Dec 		2018	 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
23 Jan 2019			 cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
01 May 2019			 jlgdap1 TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
*/

vars
	desc,
	respStatus,
	invoiceID,
	estimationID : String;
	pxyActivityHistory : CM_ActivityHistoryExtInterface;
	success : Boolean;	//21 Nov 2018	NDL	 TFS 42116
	logStr  : String;
	voyage  : CM_Voyage;
	voyCode,
	msg		: String;
begin
	
	if _agent = null then
		return;
	endif;
	if _agent.myLastActivityHistory &lt;&gt; null then
		
		if self.myInvoice &lt;&gt; null then
			invoiceID := self.myInvoice.exportCurrencyCode.String;
			
			logStr    := "Invoice : "&amp; invoiceID;
			if self.myInvoice.myVoyage &lt;&gt; null then
				voyage  := self.myInvoice.myVoyage;
				voyCode := voyage.code; 
			endif;
		endif;
	
		if self.myCashReceipt &lt;&gt; null then
			estimationID := self.myCashReceipt.externalInvoiceNumber ; 
			logStr       := "Estimate : "&amp; estimationID;
			
			if self.myCashReceipt.myCashInvoice &lt;&gt; null then  //28.01/2019 cnwma1 TFS #42942         
				invoiceID := self.myCashReceipt.myCashInvoice.exportCurrencyCode.String;
				logStr    := "Invoice : "&amp; invoiceID;
			endif;
		endif;
			
		success := false;	//21 Nov 2018	NDL	 TFS 42116
		if _response &lt;&gt; null then
			if _response.status = "X" then
				respStatus := "Success";
				success := true;	//21 Nov 2018	NDL	 TFS 42116
			elseif _response.status = "E" then
				respStatus := "Error";
			elseif _response.status = " " then
				respStatus := "Error";
			endif;
		else
			respStatus := "Error";
		endif;
		
		if respStatus = null then
			respStatus := "Error";
		endif;
		if  self.isSAPAutoEstReq then
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL11 &amp; " ["&amp;respStatus &amp;'] Estimation :'	&amp; estimationID ;
		elseif self.isSAPReleaseHoldDebit then
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL12 &amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif self.isSAPAutoInvReq then           
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL13 &amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif self.isSAPPreBillCheckLimitReq then 
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL14 &amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif self.isSAPPreBillInvoiceReq  then   
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL15 &amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif self.isSAPPostBillEstReq	then       
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL16 &amp; " ["&amp;respStatus &amp;'] Estimation :'	&amp; estimationID ;
		elseif self.isSAPPostBillInvReq then     
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL17 &amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif self.isSAPGetExchangeRate then      
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL18 &amp; " ["&amp;respStatus &amp;"]";
		elseif  self.isSAPCancelEstimate then      
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL110&amp; " ["&amp;respStatus &amp;'] Estimation :'  &amp; estimationID ;
		elseif  self.isSAPCancelPaymentCode then		
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL111&amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif  self.isSAPPreBillProdDataReq then
			desc  := _agent.definitionName  &amp; " " &amp; BGP_SAPWSRequest.WSDL112&amp; " ["&amp;respStatus &amp;'] Invoice :'  	&amp; invoiceID    ;
		elseif	self.isSAPDataKinerja then			
				if self.myInvoice &lt;&gt; null then
					desc  :=_agent.definitionName  &amp; " sent Performance Kinerja ["&amp;respStatus &amp;'] , ' &amp; voyCode ;    //17.12.2018 cnwma1 TFS #38638
				else
					desc  := _agent.definitionName  &amp; " sent Performance Kinerja ["&amp;respStatus &amp;'] , Daily' ;         //17.12.2018 cnwma1 TFS #38638
				endif;
		elseif  self.isSAPDataTPP then
			desc  := _agent.definitionName  &amp; " sent SAP TPP Daily";
		else
			desc := null;
		endif;
		
		beginLoad;
			pxyActivityHistory :=_agent.myLastActivityHistory.pxyCreateUpdateProxy().CM_ActivityHistoryExtInterface;
		endLoad;
		pxyActivityHistory.setDescription(desc);
		
		//21 Nov 2018	NDL	 TFS 42116
		pxyActivityHistory.setSuccess( success );
		if success then
			pxyActivityHistory.setReferenceID( _response.getReferenceId() );
		endif;
		
		//12.11.2018 cnwma1 TFS #41945
		if self.myInvoice &lt;&gt; null then
			pxyActivityHistory.setMyInvoice(self.myInvoice);
		elseif self.myCashReceipt &lt;&gt; null then
			pxyActivityHistory.setMyCashReceipt(self.myCashReceipt);
		endif;	
		//30 Sep 2019	NDL:	TFS 46758
		if not self.allInvoiceLines.isEmpty then
			pxyActivityHistory.setInvoiceLines( self.allInvoiceLines );
		endif;
		
		self.setActivityHistory(pxyActivityHistory);			// TFS 44298
		
		app.myTrxUA.trxUpdateActivityHistory(pxyActivityHistory, app.myPassport);
		if app.myPassport.hasErrors then
			msg := method.qualifiedName &amp; 
			'  ' &amp; "**SAP**Update Activity History"    &amp;
			'  ' &amp; logStr &amp;
			'  ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
			app.writeLog(msg,LogINFO);
		endif;
	endif;
	
epilog
	delete pxyActivityHistory;
end;</source>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent"/>
        <Parameter name="_response" type="CMIF_SAPWSResponse"/>
    </JadeMethod>
</Class>
