    <JadeMethod name="doBuildComboTrainStatus" id="900afed9-b9b4-424b-acf6-d50e0090a669">
        <source>doBuildComboTrainStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	navsp1	Initial creation TFS#53619

*/

vars
	status : Integer;
begin
	self.cmbStatus.clear;
	self.cmbStatus.sorted := false;
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Created),TrainStatus_Created );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Inbound),TrainStatus_Inbound );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Arrived),TrainStatus_Arrived );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Working),TrainStatus_Working );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Complete),TrainStatus_Complete );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Departed),TrainStatus_Departed );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Closed),TrainStatus_Closed );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Cancelled),TrainStatus_Cancelled );
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeTrackClearance" id="ec038684-8857-4f04-81f4-00bcfa5cb346">
        <source>doChangeTrackClearance();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2009	cnwndl1	Initial creation

*/

vars

	trackClearance : CM_TrackClearance;
	feetInches	: String;
	
begin

	trackClearance := cmbGaugeClear.listObject.CM_TrackClearance;
	
	//if Gauge clearance is used on the train, then these values
	//overwrite the specific max height and max width attributes of the train.
	if trackClearance = null then
	//	self.txtMaxHeight.enabled := true;
	//	self.txtMaxWidth.enabled := true;	
	//	self.txtMaxWeight.enabled := true;
		//09 Sep 2013	NDL	Par 32172
		self.tblHeight.enabled := true;
		self.tblWidth.enabled := true;
		self.tblWeight.enabled := true;
		self.chkNoEmptyWagons.enabled := true;
	else
		//self.txtMaxHeight.enabled := false;
		//txtMaxHeight.text := trackClearance.maxHeight.asStringMeasurementJMT();
		//09 Sep 2013	NDL	Par 32172
		self.tblHeight.enabled := false;
		if trackClearance.maxHeight &gt; 0 then
			self.tblHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, trackClearance.maxHeight.Decimal) &amp; Space &amp; self.heightType.shortName);
		endif;
		//self.txtMaxWidth.enabled := false;
		//txtMaxWidth.text := trackClearance.maxWidth.asStringMeasurementJMT();
		//09 Sep 2013	NDL	Par 32172
		self.tblWidth.enabled := false;
		if trackClearance.maxWidth &gt; 0 then
			self.tblWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, trackClearance.maxWidth.Decimal) &amp; Space &amp; self.widthType.shortName);
		endif;
		//self.txtMaxWeight.enabled := false;
		//self.txtMaxWeight.text := trackClearance.maxWeight.asStringMeasurementJMT(); // PAR 23176
		//09 Sep 2013	NDL	Par 32172
		self.tblWeight.enabled := false;
		if trackClearance.maxWeight &gt; 0 then
			self.tblWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, trackClearance.maxWeight.Decimal) &amp; Space &amp; self.weightType.shortName);
		endif;
			
		self.chkNoEmptyWagons.enabled := true; // PAR 23176
		self.chkNoEmptyWagons.value := trackClearance.noEmptyWagons; // PAR 23176
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doColorCodeWagons" id="180864bc-7090-4523-9b53-c5277c457a6f">
