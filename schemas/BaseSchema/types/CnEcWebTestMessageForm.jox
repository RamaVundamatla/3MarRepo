    <JadeMethod name="btnCancel_click" id="a59eabfb-9cfe-4bcf-b875-1d11d440abf0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	0;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="ec06b8b0-e884-4591-b369-e9d80c5482d0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if self.doFormUpdate() then
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnReadFile_click" id="375ed490-db72-492b-bf14-bca1821d11ad">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReadFile_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileOpen	: CMDFileOpen;
	theFile		: File;
	messageData	: String;

begin
	app.mousePointer	:=	Busy;

	create fileOpen transient;
	fileOpen.allowMultiSelect	:=	false;
	fileOpen.defaultExt			:=	".xml";
	fileOpen.fileMustExist		:=	true;
//	fileOpen.filter				:=	"XML Message (*.xml)|*.xml|Text (*.txt)|*.txt|All files (*.*)|*.*";
//	fileOpen.filterIndex		:=	1;
	fileOpen.cnEcSetFilters(true, 1, CNEC_FILE_FILTER_XML, CNEC_FILE_FILTER_TEXT);

	if fileOpen.open = 0 then
		create theFile transient;
		theFile.kind		:=	File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
		theFile.fileName	:=	fileOpen.fileName;
		messageData			:=	theFile.readString(theFile.fileLength());
		theFile.close();

		txtMessageData.text	:=	messageData.trimBlanks;
	endif;
epilog
	delete fileOpen;
	delete theFile;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="ef8a48da-40e2-489f-88f5-707243a4c092">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.doLoadMessageProperties();
	modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="077bf1d4-34c1-49a4-b264-02cdc8a7ce1f">
        <updating/>
        <source>doFormUpdate():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageName				: String;
	webServerName			: String;
	webServerPath			: String;
	messageData				: String;

begin
	messageName				:=	txtName.text.trimBlanks();
	webServerName			:=	txtServerName.text.trimBlanks();
	webServerPath			:=	txtServerPath.text.trimBlanks();
	messageData				:=	txtMessageData.text.trimBlanks();

	if self.aMyTestMessage = null then
		self.aError	:=	self.aMyTA.valTestMessageCreate(	messageName,
															messageData,
															webServerName,
															webServerPath);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxTestMessageCreate(messageName,
															messageData,
															webServerName,
															webServerPath,
															self.aMyTestMessage);
		endif;
	else
		self.aError	:=	self.aMyTA.valTestMessageUpdate(	self.aMyTestMessage,
															messageData,
															webServerName,
															webServerPath);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxTestMessageUpdate(self.aMyTestMessage,
															self.aObjectEdition,
															messageData,
															webServerName,
															webServerPath);
		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadMessageProperties" id="8fd6b4f9-03b3-45f3-9f3d-64b19c41ea8d">
        <updating/>
        <source>doLoadMessageProperties() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Populate the receiver's controsl with the Test Message details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testMessage	: CnEcWebTestMessage;

begin
	if self.aMyTestMessage = null and self.aMyTestMessageToClone &lt;&gt; null then
		testMessage	:=	self.aMyTestMessageToClone;
	else
		testMessage					:=	self.aMyTestMessage;
		self.aMyTestMessageToClone	:=	null;
	endif;

	self.setFormCaption(CAPTION_NAME, (testMessage = null), (not self.aMyTestMessageToClone = null));

	if testMessage = null then
		txtName.readOnly		:=	false;
	else
		txtName.text			:=	testMessage.messageName;
		txtServerName.text		:=	testMessage.webServerName;
		txtServerPath.text		:=	testMessage.webServerPath;
		txtMessageData.text		:=	testMessage.messageData;
		txtName.readOnly		:=	(self.aMyTestMessageToClone = null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTestMessage" id="52ebe528-824b-4839-a86c-130b8f75da4b">
        <updating/>
        <source>setTestMessage(pTestMessage:CnEcWebTestMessage) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Set a reference to the web test message being edited.
//
// Parameters:	pTestMessage - The web test message to edit.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyTestMessage	:=	pTestMessage;
	self.resynchObjAndSetEdition(pTestMessage);
end;</source>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
    </JadeMethod>
    <JadeMethod name="setTestMessageToClone" id="8d1222b6-54b9-4053-baa1-22657b4ed868">
        <updating/>
        <source>setTestMessageToClone(pMessageToClone:CnEcWebTestMessage) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Set a reference to a web test message to be cloned.
//
// Parameters:	pMessageToClone - The web test message to clone.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyTestMessageToClone	:=	pMessageToClone;
end;</source>
        <Parameter name="pMessageToClone" type="CnEcWebTestMessage"/>
    </JadeMethod>
</GUIClass>
