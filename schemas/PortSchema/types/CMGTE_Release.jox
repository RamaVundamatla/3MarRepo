    <JadeMethod name="getDensity" id="f2b95c21-30ae-4866-8ac2-db0771ede47d">
        <source>getDensity() : Decimal;
/*

Date		Who		Reason
24 June 2014	cnwer1	Initial creation PAR 34406

*/

vars
	density : Decimal[14,4];
begin
	if self.myProduct &lt;&gt; null then 																								//PAR #33606
		density:=self.myProduct.getDensityValue;																														//PAR #33606
	endif;
	if density = null then
		if self.myCargoType &lt;&gt; null and self.myCargoType.mySystemProductType &lt;&gt; null  then
			density:= self.myCargoType.mySystemProductType.getDensityValue;
		endif;
	endif;
	
	return density;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
