    <JadeMethod name="displayTaskStops" id="79aa84a6-d724-4233-8250-56594f91b9cc">
        <source>displayTaskStops( _obj : Object ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation

*/

vars

	edition : Integer;
	invalid : Boolean;
	str : String;
	index : Integer;
	rowObj : Object;

begin

	if _obj = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, _obj, invalid);
	edition := _obj.edition;
	if invalid then
		return null;
	endif;
	
	if CM_StopsTable.hasInstance(_obj) then
		return _obj.CM_StopsTable.heading;
	elseif CM_ToDoTaskDesc.hasInstance(_obj) then
		//05 Oct 2016	NDL	TFS 2001 / 2792
		if self.mulSelect.myAvailableListBox.findObject(_obj) &gt; 0 then
			str := null;
			if  self.myDocumentActionsObj &lt;&gt; null then
				if self.myDocumentActionsObj.allTaskDescsToAdd.includes(_obj.CM_ToDoTaskDesc) then
					index := self.myDocumentActionsObj.allTaskDescsToAdd.indexOf(_obj.CM_ToDoTaskDesc);
					if self.myDocumentActionsObj.allTaskRemarkToAdd &lt;&gt; null 
					and self.myDocumentActionsObj.allTaskRemarkToAdd.size &gt;= index
					then
						str := self.myDocumentActionsObj.allTaskRemarkToAdd[index];
					endif;
				endif;
			endif;
			index := self.tblRemarks.addItem( _obj.CM_ToDoTaskDesc.description &amp; Tab &amp; str );
			self.tblRemarks.accessRow(index).itemObject := _obj;
		else
			foreach index in 1 to self.tblRemarks.rows do
				rowObj := self.tblRemarks.accessRow(index).itemObject;
				if rowObj &lt;&gt; null and rowObj = _obj then
					self.tblRemarks.removeItem(index);
					break;
				endif;
			endforeach;
		endif;
		
		return _obj.CM_ToDoTaskDesc.description;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="8f0e0db6-4dc8-40a0-95a0-f1335fe6d31f">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792

					Called from the tblRemarks table, but also from within the mulSelect CMUI_MultiSelectGroupBox class

*/

vars

	itemSelected : Object;
	index : Integer;

begin
	
	if _control = self.mulSelect.myRemoveSelectedBtn then
		itemSelected := self.tblRemarks.accessRow( self.tblRemarks.row ).itemObject;
		if itemSelected &lt;&gt; null then
			index := self.mulSelect.mySelectedListBox.findObject( itemSelected );
			if index &gt; 0 then
				self.tblRemarks.removeItem( self.tblRemarks.row );
				self.mulSelect.takeOutItem(  self.mulSelect.mySelectedListBox, itemSelected );
				self.mulSelect.addItem(  self.mulSelect.myAvailableListBox, itemSelected );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doFilterAvailable" id="5a2bc9ff-1f3c-4382-a62f-55b01b98b0cc">
        <source>doFilterAvailable( _initialSetup : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars

	availableSet : CM_ObjectSet;
	user : CM_User;
	taskDict : CM_ToDoTaskDescByCode;
	taskDesc : CM_ToDoTaskDesc;
	filterText : String;
	stopTablesDict : CM_StopsTableByIdDict;
	stopTable : CM_StopsTable;
	cargoType : CM_CargoType;
	criteria : CM_YACriteria;

begin

	create availableSet transient;
	user := app.getMyUser;
	filterText := self.txtFilter.text.toUpper.trimBlanks;
	
	if self.myDocumentActionsObj &lt;&gt; null then
		cargoType := self.myDocumentActionsObj.getCargoType();
	endif;

	if self.showStops then
		if self.canUpdate then
			stopTablesDict := user.getStopsToMaintForTerminal(self.myTerminal);
		else
			stopTablesDict := user.getStopsToViewForTerminal(self.myTerminal);
		endif;
		foreach stopTable in stopTablesDict do
			if filterText &lt;&gt; null and stopTable.heading.toUpper.pos(filterText, 1) &lt; 1 then
				continue;
			endif;
			if stopTable.requiresInfoString &lt;&gt; null then
				continue;
			endif;
			//if cargoType &lt;&gt; null and not stopTable.allCargoTypesNew.includes( cargoType ) then	//20 Jul 2022	navsj20	TFS 53862
			if cargoType &lt;&gt; null and stopTable.myStopCriteria &lt;&gt; null then
				foreach criteria in stopTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType
				and not criteria.myYAData.CM_YADataObjects.allObjects.includes( cargoType ) do	//27 Jul 2022	navsj20	TFS 53862
					continue;
				endforeach;		//27 Jul 2022	navsj20	TFS 53862
			endif;
			availableSet.addNoDuplicates( stopTable, false );
		endforeach;
		
	elseif self.showTasks then
		create taskDict transient;
		user.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
		foreach taskDesc in taskDict do
			if filterText &lt;&gt; null and taskDesc.description.toUpper.pos(filterText, 1) &lt; 1 then
				continue;
			endif;
			if cargoType &lt;&gt; null and not taskDesc.allCargoTypes.includes( cargoType ) then
				continue;
			endif;
			availableSet.addNoDuplicates( taskDesc, false );
		endforeach;
	
	endif;
	
	self.mulSelect.setAvailable( availableSet, _initialSetup );

epilog

	delete taskDict;
	delete availableSet;

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="bbe1a6ef-499b-4c83-bd44-a0e6313b11f3">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001
05 Oct 2016	NDL	TFS 2001 / 2792
19/10/2016	cnwdap1	TFS 2652 Fix sort order of tasks and remarks
*/

vars

	objSet : ObjectSet; 
	objArray : ObjectArray;
	strArray : HugeStringArray;
	rowIndex : Integer; 
	arrayIndex : Integer;

begin
	self.mulSelect.mySelectedListBox.sorted := false;
	self.mulSelect.mySelectedListBox.sortAsc := false;
	if self.showStops then
		create objSet transient;
		self.mulSelect.getSelected( objSet );
		self.myDocumentActionsObj.setStopTablesToAdd( objSet );
	elseif self.showTasks then
		create objArray transient;
		create strArray transient;
		// TFS 2652 19/10/2016 mulSelect.getSelected returns things sorted in sorted order			// TFS 2652
		// If you haven't selected things in sorted order, this will break the link to remarks		// TFS 2652
		/*self.mulSelect.getSelected( objArray );													// TFS 2652
		foreach arrayIndex in 1 to objArray.size do													// TFS 2652
			rowIndex := arrayIndex + 1;																// TFS 2652
			if rowIndex &lt;= self.tblRemarks.rows then												// TFS 2652
				strArray[arrayIndex] := self.tblRemarks.accessCell(rowIndex,2).text;				// TFS 2652
			else																					// TFS 2652
				strArray[arrayIndex] := null;														// TFS 2652
			endif;																					// TFS 2652
		endforeach;*/																				// TFS 2652
		foreach arrayIndex in self.tblRemarks.fixedRows + 1 to self.tblRemarks.rows do				// TFS 2652
			objArray.addExclusive(self.tblRemarks.accessRow(arrayIndex).itemObject);				// TFS 2652
			strArray.add(self.tblRemarks.accessCell(arrayIndex, 2).text);							// TFS 2652
		endforeach;																					// TFS 2652
		self.myDocumentActionsObj.setTaskDescsToAdd( objArray, strArray );
	endif;
	
	inheritMethod();

epilog
	
	delete objSet;
	delete objArray;
	delete strArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="3bf31ad2-0fc3-47c4-991c-a0ad3c56cc4a">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();

	self.frmSelect.left := 1;
	self.frmSelect.top := 1;
	self.frmSelect.width := self.clientWidth - 2;
	self.frmSelect.height := self.clientHeight - 35;
	self.mulSelect.height := self.frmSelect.height - 60;
	
	//05 Oct 2016	NDL	TFS 2001 / 2792
	if self.tblRemarks.visible then
		self.mulSelect.mySelectedListBox.visible := false;
		self.tblRemarks.parent := self.mulSelect;
		self.tblRemarks.top := self.mulSelect.mySelectedListBox.top;
		self.tblRemarks.left := self.mulSelect.mySelectedListBox.left;
		self.tblRemarks.width := self.mulSelect.mySelectedListBox.width;
		self.tblRemarks.height := self.mulSelect.mySelectedListBox.height;
	endif;
	
	self.frmFilter.left := self.mulSelect.left;
	self.frmFilter.width := self.mulSelect.width;

	self.btnFilter.left := self.frmFilter.width - self.btnFilter.width - 5;
	self.txtFilter.left := 0;
	self.txtFilter.width := self.btnFilter.left - 5;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="173af763-ae06-45de-925b-beabd2002ba9">
        <updating/>
        <source>setBaseData( 	_documentActionsObj : CM_DocumentActions;
				_isTasks : Boolean;
				_isStops : Boolean
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

begin

	self.myDocumentActionsObj := _documentActionsObj;
	
	if _isTasks then
		self.showTasks := true;
	elseif _isStops then
		self.showStops := true;
	endif;

epilog

end;</source>
        <Parameter name="_documentActionsObj" type="CM_DocumentActions"/>
        <Parameter name="_isTasks" type="Boolean"/>
        <Parameter name="_isStops" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d1f8f36d-bd7d-42c0-ab4e-c59d84b9db0b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

begin

	self.minimumWidth := 420;
	self.minimumHeight := 300;

	self.canUpdate := app.getMyUser.canDo( self.myTerminal, PmAdmDocActionsMaint );

	inheritMethod();
	
	if self.left &lt; app.mainForm.left then
		self.left := app.mainForm.left + self.left;
	endif;
	if self.top &lt; app.mainForm.top then
		self.top := app.mainForm.top + self.top;
	endif; 
	
	self.setupMulSelect();
	
	self.btnOk.enabled := self.canUpdate;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMulSelect" id="22062f1b-be7c-4f9d-8fbe-22f3681d0e29">
        <updating/>
        <source>setupMulSelect() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	availableSet : CM_ObjectSet;

begin

	self.mulSelect.caption := null;
	self.mulSelect.distanceFromBottom 	:= 5;
	self.mulSelect.distanceFromRight 		:= 5;
	self.mulSelect.lockBottom 				:= false;
	self.mulSelect.lockRight				:= false;
	self.mulSelect.stretchHeight 			:= false;
	self.mulSelect.stretchWidth 			:= true;
	self.mulSelect.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.mulSelect.formDisplayEntryMethodName := CMUI_DocumentActionsSelectForm::displayTaskStops.name;
	
	if self.showStops then
		self.mulSelect.availableHeading := app.getErrorString(Available_stops);
		self.mulSelect.selectedHeading := app.getErrorString(Selected_stops);
	elseif self.showTasks then
		self.mulSelect.availableHeading := app.getErrorString(Available_tasks);
	//	self.mulSelect.selectedHeading := app.getErrorString(Selected_tasks);
	endif;
	
	self.mulSelect.myBaseForm	:= self;
	self.mulSelect.mySelectedListBox.sorted := true;
	self.mulSelect.cnEcResizeContents();
	self.mulSelect.readOnly := not self.canUpdate;
	
	self.doFilterAvailable( true );
	
	if self.showStops then
		self.mulSelect.setSelected( self.myDocumentActionsObj.allStopTablesToAdd );
		self.tblRemarks.visible := false;	//05 Oct 2016	NDL	TFS 2001 / 2792
		
	elseif self.showTasks then
		self.mulSelect.setSelected( self.myDocumentActionsObj.allTaskDescsToAdd );
		//05 Oct 2016	NDL	TFS 2001 / 2792
		self.tblRemarks.visible := true;
		self.tblRemarks.fixedColumns := 1;
		self.tblRemarks.columns := 2;
		self.tblRemarks.rows := self.myDocumentActionsObj.allTaskDescsToAdd.size + 1;
		self.tblRemarks.fixedRows := 1;
		self.tblRemarks.setCellText(1,1,app.getErrorString(Selected_tasks) &amp; Tab &amp; app.getErrorString(Remarks));
		self.tblRemarks.accessColumn(2).inputType := Table.InputType_TextBox;
		self.doResize();
		
	endif;
	
	

epilog

	delete availableSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblRemarks_dblClick" id="6a923bc4-ec6f-44ac-99d0-36a2ec900237">
