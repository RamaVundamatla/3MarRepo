    <JadeMethod name="doMnuGridHideDirections" id="affb6656-88b2-4a8e-9309-93456fa15830">
        <updating/>
        <source>doMnuGridHideDirections() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgmp6	Initial creation	TFS7084

*/

vars

begin
	if self.mnuGridHideDirections.caption = self.MNU_DIRECTIONS_SHOW then
		self.mnuGridHideDirections.caption := self.MNU_DIRECTIONS_HIDE;
		self.xmlDirections := true;
	else
		self.mnuGridHideDirections.caption := self.MNU_DIRECTIONS_SHOW;
		self.xmlDirections := false;
	endif;

	self.doRefresh();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuGridHideLegendClick" id="7506d4d9-61b5-48a2-b1a7-238a196cc741">
        <updating/>
        <source>doMnuGridHideLegendClick() updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	saveWidth	: Real;

begin

	if self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW then
		// save and reset the width as if showing for thw first time
		// then Jade appears to get some odd width 
		saveWidth := self.dkbColorLegend.width;
		self.dkbColorLegend.visible := true;

//		app.doWindowEvents(0); // PAR 10112  &lt;&lt;&lt; We need this left in so that the scrolling frame clientHeight and width are reset by Jade.
		self.refreshNow();
	
		self.dkbColorLegend.width := saveWidth;
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
	else
		self.dkbColorLegend.visible := false;
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
		self.refreshNow();
	endif;
	
	self.xmlLegend := self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW;
	self.doResize();

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuGridHideMacroClick" id="b9dee804-1276-42a9-8390-66b830efea67">
        <updating/>
        <source>doMnuGridHideMacroClick() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW then
		self.dkcExtraInfo.visible := true;
//		app.doWindowEvents(0); // PAR 10112  &lt;&lt;&lt; We need this left in so that the scrolling frame clientHeight and width are reset by Jade.
		self.refreshNow();
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
		if self.frmPopupInfo.visible then
			if self.frmPopupInfo.userObject &lt;&gt; null then
				self.showExtraInfoForObject(self.frmPopupInfo.userObject);
				self.tblGridAreaInfo.refreshNow();
			endif;
			self.frmPopupInfo.visible := false;
		endif;
	else
		self.dkcExtraInfo.visible := false;
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;

	self.xmlMacro := self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW;

	self.doResize();

end;</source>
    </JadeMethod>
