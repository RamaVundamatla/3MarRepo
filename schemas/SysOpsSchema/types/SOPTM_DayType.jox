    <JadeMethod name="doSave" id="2db5df72-91cf-4d76-bec5-6f304fe09c51">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	proxyDayType : CM_DayType;
	lCode : String;
	lDescription : String;
	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DayType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyDayType := theForm.myProxyObject.CM_DayType;
	proxyDayType.setProxy(lCode, lDescription);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateDayType(proxyDayType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDayType(proxyDayType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
