    <JadeMethod name="getReference" id="f93b090e-1b7a-446b-82fa-5c8350679563">
        <source>getReference(): String;
/*

Purpose:			

Parameters:			Report writer field.  Do not remove or rename.

Return Value:		

Date		Who		Reason
03 November 2014	cnwndl1	Initial creation	Par 35160

*/

vars

	invalidObject : Boolean;
	eventRequestStop : CM_EventRequestStops;

begin
	
	on Exception do app.handleDeletedObject( exception, self.myToDoTask, invalidObject );
	
	if self.myToDoTask &lt;&gt; null and self.myToDoTask.isKindOf( CM_TiToDoTask ) then
		eventRequestStop := self.myToDoTask.CM_TiToDoTask.findEventRequestStop();
	endif;
	
	if eventRequestStop &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, eventRequestStop, invalidObject );
		return eventRequestStop.reference;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseRequestNo" id="cdf2ae6b-1397-44e9-97e6-e58a75dce100">
        <source>getReleaseRequestNo() : String;

vars
	
begin
	// cnwrl1 23/04/2010 PAR 23768
	// This method which used to return the myTrackedItem.deliveryRelease has been changed to
	// return myTrackedItem.getReleaseRequestsList, this is what is displayed on Cargo Enquiry form.
	// but we do not want the appended release type. 
	if self.myTrackedItem = null then
		return null;
	endif;
	
	return self.myTrackedItem.getReleaseRequestsList( false );
	
	/* cnwrl1 23/04/2010 PAR 23768 - what it was
	If this is still required use method getDeliveryRelease
	// PAR 22386
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.deliveryRelease;
	endif;
	cnwrl1 23/04/2010 PAR 23768 - end of what it was */
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
