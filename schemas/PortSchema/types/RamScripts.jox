    <JadeMethod name="addOneETROW" id="07266439-74a2-4a4c-9e3a-04a6c3a59aa1">
        <source>addOneETROW();
/*
Purpose:			

Date		Who		Reason
06 December 2022	navab1
*/

vars
	entTblAgent : EntTableAgent;
	tmpArray : StringArray;
	
begin
	app.initialize();
	
	create entTblAgent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create tmpArray transient;	
	tmpArray.add("ETRow_CalcTypeDescStatic"); 
	tmpArray.add("ETRow_CalcTypeTypeStatic"); 
	tmpArray.add("ETRow_TaxExtRefStatic "); 
	tmpArray.add("ETDef_InvListDataTableLines"); 
