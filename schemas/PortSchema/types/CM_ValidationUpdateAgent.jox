        <source>valVoyageOpCargoReceive(_theController:CMIF_OpCargoRecController);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theVoyage : CM_Voyage;
	anOp : CM_Operator;

begin
	theVoyage := _theController.myVoyage;
	
	if theVoyage = null then
	else
		theVoyage.validateForStopReceival(_theController);
	endif;
	
	foreach anOp in _theController.allOperators do
		anOp.validateForStopReceival(_theController);
	endforeach;
end;</source>
