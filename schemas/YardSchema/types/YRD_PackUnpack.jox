    <JadeMethod name="getXMLSettingsForSetup" id="c9ca5aae-fa9a-4857-b5cf-a797157f7fe1">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// 37288 get the saved Filter option value
vars
	userWindow		: CM_UserWindow;
	xml, xmlValue : String;

begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	if userWindow = null then  
		return;
	endif;
	xml := userWindow.xmlInfo;

 	xmlValue := xml.cnEcGetTagValueOfName("Filter");
	self.chbFilter.value := xmlValue.Boolean;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleSysNotification" id="de1ead6c-9a10-4ff8-9177-685a1e402f95">
        <updating/>
        <source>handleSysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 September 2003	cnwth2
//
// Purpose:    
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin

	if theObject.isKindOf(CM_TrackedItem) then
		self.handleTrackedItemNotification(eventType, theObject, eventTag);	
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTrackedItemNotification" id="f291b4f7-1bcc-4f6d-a502-8e3f45861792">
        <updating/>
        <source>handleTrackedItemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected ;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 16 February 2004
//
//********************************************************************
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
13 Apr 2024	navnk30	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL

*/

vars
	numRows,
	row				: Integer;
	tbl				: CM_DataTable;
	ti				: CM_TrackedItem;
	inTable			: Boolean;
begin
	// PAR 14575
	if eventType = Object_Delete_Event then
		// PAR #24795 - check packed table first, because it is likely to be smaller
		if self.tblPacked.findObjectInRow(theObject, row) then
			self.tblPacked.removeItem(row);
			self.disarmNotesForObject(theObject);
			return;
		endif;
		if self.tblUnpacked.findObjectInRow(theObject, row) then
			self.tblUnpacked.removeItem(row);
			self.disarmNotesForObject(theObject);
			return;
		endif;
		
		return;
	
	elseif eventType = Object_Update_Event then
		if theObject = self.myTI then
//			self.displayTableTrackedItem();				//13.04.2024 navnk30 #63247
			self.displayTableTrackedItem(null);			//13.04.2024 navnk30 #63247
			return;
		endif;

		// PAR #24795 - check packed table first, because it is likely to be smaller
		if self.tblPacked.findObjectInRow(theObject, row) then
			self.tblPacked.removeItem(row);
			self.disarmNotesForObject(theObject);
			self.addTblDataRow(row, theObject.CM_TrackedItem, self.tblPacked);
			self.tblPacked.accessRow(row).backColor := self.colorRow1;
			return;
		endif;

		if self.tblUnpacked.findObjectInRow(theObject, row) then
			self.tblUnpacked.removeItem(row);
			self.disarmNotesForObject(theObject);
			if self.myFilterObject.doesObjectMatchQuery(theObject.CM_TrackedItem) then
				self.addTblDataRow(row,theObject.CM_TrackedItem, self.tblUnpacked);
				self.tblUnpacked.accessRow(row).backColor := self.colorRow1;
			endif;
			return;
		endif;
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="daa2ad14-aac6-4125-8d26-256dca1a5346">
        <source>initDataTable( _tbl : CM_DataTable input; _entDef : String );
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := _tbl;
	theTable.rows := theTable.fixedRows;
	
//	entTableDef := app.myController.getEntTableDef(ETDef_PackItems);	// cnwrl1 10/11/2010 PAR 23899 - what it was
	entTableDef := app.myController.getEntTableDef( _entDef );
	
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.multiSelect := CM_DataTable.MultiSelect_Simple;
	
end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initFrmPackComplete" id="e805deb5-4473-4334-bb8a-b952b67d5a6e">
        <source>initFrmPackComplete();
//----------------------------------------------------------------
//	Created:	29 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//"Do you want to create a PackComplete transaction now?"

// cnwrl1 07/04/2009 PAR 19359 - align the controls better.

vars
	
begin
	self.lblPackComplete.caption	:= app.getErrorString( CreatePackCompleteNow );
	
//	self.frmPackComplete.width		:= Frame_Width;			// was 300
//	self.frmPackComplete.height		:= Frame_Height;		// was 130
//	self.lblPackComplete.width		:= Label_Width;			// was 280
//	self.lblNewOperator.left		:= self.lblPackComplete.left;
//	self.cmbNewOperator.width		:= Combo_Width;			// was 195
//	self.btnPackComOK.move(75, 85, 70, 25);				// was ( 70, 85, 70, 25 )
//	self.btnPackComCancel.move(165, 85, 70, 25);			// was ( 160, 85, 70, 25 )
	self.btnPackComCancel.caption	:= app.getErrorString(Close);
	self.frmPackComplete.backColor	:= self.backColor;
	
	if self.myTI &lt;&gt; null then
		self.cmbNewOperator.setObject(self.myTI.myOperator);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.cmbPSubTerminal.listIndex = CNEC_NULL_INDEX then
			self.cmbPSubTerminal.cnEcSetObjectIndex(self.myTI.mySubTerminal);
		endif;
	endif;
	
	self.frmPackComplete.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="initFrmUnpackComplete" id="0170a306-57bf-423c-b0a6-df4e51cd631b">
        <source>initFrmUnpackComplete();
//----------------------------------------------------------------
//	Created:	May 2007 cnwrs1
//----------------------------------------------------------------
//"Do you want to create an UnpackComplete transaction now?"

// cnwrl1 07/04/2009 PAR 19359 - align the controls better.

vars
	configOption : Boolean;
	cmdty : CM_Commodity;
begin
	self.lblUnpckComplete.caption	:= app.getErrorString( CreateUnpackCompleteNow );
	
//	self.frmUnpckComplete.width		:= Frame_Width;			// was 300
	self.frmUnpckComplete.height	:= Frame_Height;		// was 130
//	self.lblUnpckComplete.width		:= Label_Width;			// was 280
//	self.lblUnpckOperator.left		:= self.lblUnpckComplete.left;
//	self.cmbUnpckOperator.width		:= Combo_Width;			// was 195
//	self.btnUnpckComOK.move(75, 85, 70, 25);				// was ( 70, 85, 70, 25 )
//	self.btnUnpckComCanc.move(165, 85, 70, 25);			// was ( 160, 85, 70, 25 )
	self.btnUnpckComCanc.caption	:= app.getErrorString(Close);
	self.frmUnpckComplete.backColor	:= self.backColor;
	
	if self.myTI &lt;&gt; null then
		self.cmbUnpckOperator.setObject(self.myTI.myOperator);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.cmbUSubTerminal.listIndex = CNEC_NULL_INDEX then
			self.cmbUSubTerminal.cnEcSetObjectIndex(self.myTI.mySubTerminal);
		endif;
	endif;
	
	self.lblCompletion.visible := false;
	self.lblDischargePort.visible := false;
	self.lblVoyage.visible := false;
	self.cmbDischargePort.visible := false;
	self.cmbVoyage.visible := false;
	self.chkClearSeals.visible := false;
	self.chkClearBooking.visible := false;	//08 Jul 2011	NDL	Par 26476
	
	self.frmUnpckComplete.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableContainer" id="b6d8072b-a13d-4765-a95c-a309a85fb2d5">
        <updating/>
        <source>initTableContainer() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------

vars

begin
	
	self.initTableEntDef(self.tblContainer,ETDef_ContainerInfo);

	//self.tblContainer.disableRowByName(ETRow_Id);
	self.tblContainer.disableRowByName(ETRow_IsoType);
	self.tblContainer.disableRowByName(ETRow_IsoGroup);
	self.tblContainer.disableRowByName(ETRow_Status);
	self.tblContainer.disableRowByName(ETRow_WeightMax);
	self.tblContainer.disableRowByName(ETRow_VolumeMax);	//#25592 02/11/2010
	
	//22 Sep 2010	NDL	Par 25608 - now uses "DtRow_"
	self.tblContainer.hideRowByName(ETRow_SealNum, false);
	self.tblContainer.hideRowByName(ETRow_PrevSealNum, false);
	self.tblContainer.hideRowByName(ETRow_SealNumShippers, false);
	self.tblContainer.hideRowByName(ETRow_SealNumCustoms, false);
	self.tblContainer.hideRowByName(ETRow_SealNumVent, false);
	self.tblContainer.hideRowByName(ETRow_SealNumTerminalOperator, false);
	self.tblContainer.hideRowByName(ETRow_SealNumUnknown, false);
	
	self.loadSealTypeTables();		//+cnwml2 PAR23715 SFW CCMS1131
	//self.tblContainer.accessColumn(CM_EntryTable.ColumnValue).backColor := 15007709;	//used to be 11336640
	if self.myTI &lt;&gt; null then			//+cnwml2 PAR25258
		self.cmbCargoType.setObject(self.myTI.myCargoType);
	else
		self.cmbCargoType.setObject(app.myRoot.allCargoTypesById[self.myTerminal.defaultCargoType]);	//+cnwml2 PAR23431
	endif;
	self.cmbCargoType.lostFocus(self.cmbCargoType);			//+cnwml2 PAR25258

	self.loadCombos();				//+cnwml2 SFW CCMS 1063 PAR25852
	
	//+cnwml2 SFW CCMS 1063 PAR25852
	//Hide Reefer Fields for a start
	self.tblContainer.hideRowByName(ETRow_AllowableTimeOffPower, false);
	self.tblContainer.hideRowByName(ETRow_CarriageTemp, false);
	self.tblContainer.hideRowByName(ETRow_PackDate, false);
	self.tblContainer.hideRowByName(ETRow_PackTime, false);
	self.tblContainer.hideRowByName(ETRow_PackTemp, false);
	self.tblContainer.hideRowByName(ETRow_CO2, false);
	self.tblContainer.hideRowByName(ETRow_O2, false);
	self.tblContainer.hideRowByName(ETRow_CurtainsIn, false);
	self.tblContainer.hideRowByName(ETRow_Humidity, false);
	self.tblContainer.hideRowByName(ETRow_Ventilation, false);	
	self.tblContainer.hideRowByName(ETRow_CoolingType, false);	
	self.tblContainer.hideRowByName(ETRow_VoltageType, false);	


end;</source>
    </JadeMethod>
    <JadeMethod name="initTableEntDef" id="7b561e16-85e8-48d7-ba0e-253391ae05bf">
        <updating/>
        <source>initTableEntDef(_theTable : CM_EntryTable; _entDef : String) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	aTS 			: TimeStamp;	
begin


	theTable := _theTable;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(_entDef); 
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

//	theTable.left	:= 0;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	//theTable.parentBottomMargin := 10;

	theTable.resetSize();




end;</source>
        <Parameter name="_theTable" type="CM_EntryTable"/>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTableQuery" id="55c22949-5fc0-4ec0-845b-4b4bbed75954">
        <updating/>
        <source>initTableQuery() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entDef				: EntTableDef;
	theTable			: CM_EntryTable;
	aTS 				: TimeStamp;
	entView				: EntTableView;	
begin
	theTable := self.tblQuery;
	

	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entDef := self.getTblQueryDef;
	theTable.setEntTableDef(entDef, null, 'entTableDefSetupWarning');

	theTable.resetSize();

	//self.tblQuery.accessColumn(CM_EntryTable.ColumnValue).backColor := 11661310;
	entView := entDef.allEntTableViews['SystemCargoTypeView'];	
	theTable.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, null);
	//used to be 8045818
end;</source>
    </JadeMethod>
    <JadeMethod name="insertSealType" id="21436164-3539-4db6-ba5d-653013fd3bca">
        <source>insertSealType(_tbl : CM_EntryTable io; _sealType : CM_SealType; _atRow : Integer);
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars
	aRow : Integer;
	jRow :JadeTableRow;
	ti 	: CM_TrackedItem;
	sealTI : CM_SealTI;
	dateEntered : Boolean;
	aControl : Control;
	tranSealTi : CM_SealTI;	//06 Dec 2010	NDL	Par 26506
	sealValue : String;	//06 Dec 2010	NDL	Par 26506
begin
	_tbl.addAttributeAt("DtRow_" &amp; _sealType.sealType, _sealType.description, Table.InputType_TextBox, null, true, _atRow);
	
	ti := self.cmbTrackedItem.listObject.CM_TrackedItem;
	
	if ti &lt;&gt; null then
		sealTI := ti.getSealTI(_sealType);		//06 Dec 2010	NDL	Par 26506 - moved up
	endif;
	
	//06 Dec 2010	NDL	Par 26506
	if sealTI = null and ti &lt;&gt; null then
		tranSealTi := ti.getTransSealTiFromOldDataStruc(_sealType);
		sealTI := tranSealTi;
	endif;
	if sealTI &lt;&gt; null then
		sealValue := sealTI.getSealValueAsString;
	else
		sealValue := null;
	endif;
	
	if _sealType &lt;&gt; null then
		if ti &lt;&gt; null then
			//_tbl.setValueByName("DtRow_" &amp; _sealType.sealType, ti.getSealValue(_sealType));
			_tbl.setValueByName("DtRow_" &amp; _sealType.sealType, sealValue);	//06 Dec 2010	NDL	Par 26506
		else
			_tbl.setValueByName("DtRow_" &amp; _sealType.sealType, null);
		endif;			
	endif;
	aRow := _tbl.getRowByName( "DtRow_" &amp; _sealType.sealType );
	jRow := _tbl.accessRow(aRow);
	jRow.backColor := self.colorValueColumn;
	
	if _sealType.allowMultipleSealNums then
		aControl := self.allSealTypeControls["tblSeals" &amp; _sealType.sealType];
		if aControl &lt;&gt; null then
			_tbl.setControl(aRow, aControl);
		endif;
	endif;
	
	if ti &lt;&gt; null then
		//sealTI := ti.getSealTI(_sealType);
		if sealTI &lt;&gt; null then
			//if not _sealType.allowMultipleSealNums then
			if not _sealType.allowMultipleSealNums and _sealType.savePreviousSeal then	// 22 Sep 2010	NDL	Par 25608
				if sealTI.previousSeal &lt;&gt; null then
					_tbl.addAttributeAt("DtRow_" &amp; "PreviousSeal_" &amp; _sealType.description, "Previous " &amp; _sealType.description, Table.InputType_TextBox, null, true, _atRow + 1);
					_tbl.setValueByName("DtRow_" &amp; "PreviousSeal_" &amp; _sealType.description, sealTI.previousSeal);
					aRow := _tbl.getRowByName( "DtRow_" &amp; "PreviousSeal_" &amp; _sealType.description);
					jRow := _tbl.accessRow(aRow);
					//jRow.backColor := self.READ_ONLY_COLOUR;
					jRow.enabled := false;
				endif;
			endif;
		endif;
	endif;

epilog

	delete tranSealTi;

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="inspectTableObject" id="4b586e31-bfc9-41fb-a12b-157c5119e791">
        <updating/>
        <source>inspectTableObject(tbl : Table)updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 23 December 2003
//
//********************************************************************
vars
	obj : Object;
begin
	obj := 	tbl.accessedRow.itemObject;
	if obj &lt;&gt; null then
		obj.inspect;
	endif;
end;</source>
        <Parameter name="tbl" type="Table"/>
    </JadeMethod>
    <JadeMethod name="isReefer" id="8e3466da-96c4-4c24-a506-d895e46d1763">
        <source>isReefer();
//11 November 2010	cnwml2
//+cnwml2 SFW CCMS 1063 PAR25852
vars
	commodity : CM_Commodity;
begin
	commodity := self.cmbCommodity.listObject.CM_Commodity;
	
	if commodity &lt;&gt; null then
		if commodity.hasTemp then
			self.tblContainer.showRowByName(ETRow_AllowableTimeOffPower, false);
			self.tblContainer.showRowByName(ETRow_CarriageTemp, false);
			self.tblContainer.showRowByName(ETRow_PackDate, false);
			self.tblContainer.showRowByName(ETRow_PackTime, false);
			self.tblContainer.showRowByName(ETRow_PackTemp, false);
			self.tblContainer.showRowByName(ETRow_CO2, false);
			self.tblContainer.showRowByName(ETRow_O2, false);
			self.tblContainer.showRowByName(ETRow_CurtainsIn, false);
			self.tblContainer.showRowByName(ETRow_Humidity, false);
			self.tblContainer.showRowByName(ETRow_Ventilation, false);	
			self.tblContainer.showRowByName(ETRow_CoolingType, false);	
			self.tblContainer.showRowByName(ETRow_VoltageType, false);
		else
			self.tblContainer.hideRowByName(ETRow_AllowableTimeOffPower, false);
			self.tblContainer.hideRowByName(ETRow_CarriageTemp, false);
			self.tblContainer.hideRowByName(ETRow_PackDate, false);
			self.tblContainer.hideRowByName(ETRow_PackTime, false);
			self.tblContainer.hideRowByName(ETRow_PackTemp, false);
			self.tblContainer.hideRowByName(ETRow_CO2, false);
			self.tblContainer.hideRowByName(ETRow_O2, false);
			self.tblContainer.hideRowByName(ETRow_CurtainsIn, false);
			self.tblContainer.hideRowByName(ETRow_Humidity, false);
			self.tblContainer.hideRowByName(ETRow_Ventilation, false);	
			self.tblContainer.hideRowByName(ETRow_CoolingType, false);	
			self.tblContainer.hideRowByName(ETRow_VoltageType, false);		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f887555a-2cc6-4aba-9086-aa1cd9209439">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
//-----------	----------	--------------------------------------------------
// 09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
begin
	if self.doCheckKeyDownSpecial(keyCode, YRD_PackUnpack::tblContainer_cellInputReady.name) then	// PAR #31155
		keyCode := 0;																				// PAR #31155
		return;																						// PAR #31155
	endif;																							// PAR #31155
	
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelector();
		else
			self.frmQuery.visible := (not self.frmQuery.visible);
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadBookingItems" id="45874eab-2718-4844-8512-9d0ebf81d12a">
        <source>loadBookingItems(_br : CM_BookingRef; _brItem : CM_BookingRefItem);
//15 March 2010	cnwml2


vars

begin
	if _br = self.cmbBookingItem.myBookingRef then  // store the booking ref so don't reload if it has not changed
		return;
	endif;
	self.cmbBookingItem.clear;
	self.cmbBookingItem.setMyBookingRef(_br);
	self.cmbBookingItem.setObject(_brItem);

epilog

end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="7961b374-05d7-4da7-9bfc-911255fb67b2">
        <source>loadCombos();
//11 November 2010	cnwml2
//+cnwml2 SFW CCMS 1063 PAR25852
vars

begin
	//Cooling Type Combo
	self.cmbCoolingType.clear();
	self.cmbCoolingType.addItem(ContainerCooledNullStr);
	self.cmbCoolingType.addItem(ContainerAirCooledStr);
	self.cmbCoolingType.addItem(ContainerWaterCooledStr);
	
	//Voltage Type Combo
	self.cmbVoltageType.clear();
	self.cmbVoltageType.addItem(ContainerVoltNullStr);
	self.cmbVoltageType.addItem(ContainerSingleVoltStr);
	self.cmbVoltageType.addItem(ContainerDualVoltStr);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="47adff6d-38ac-4479-98b0-25980fc9d163">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 24/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
//
// 20/07/2010	cnwdad1		PAR #24868 - For Port Otago, default the Pack Sub-
//							Terminal to the setting for "Export Full".
//
// 22/07/2013	cnwdap1		PAR #31196 Remove redundant parameter to comboBoxTrackedItemCmbPack method
// 20 May 2022	navak20		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 19 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// ---------------------------------------------------------------------------
vars
	subTerminalObj	: CM_SubTerminal;
	defSubTermObj	: CM_SubTerminal;
	
begin
	self.doResetSearch();//this loads combos used for query
	self.doLoadCmbCommodity(self.cmbCommodity);
	self.doLoadCmbCompTrans();					//+cnwml2 PAR24046
	
	self.doShowExportBookings();				// PAR #23925 CCMS MES 1076
	

	self.doLoadCmbVoyage();
	self.doLoadCmbDepot(self.cmbDepot);
	self.doLoadCmbDestPort();				//+cnwml2 PAR24740
	self.doLoadCmbDisPort();
	self.doLoadCmbOperator(self.cmbOperatorRight);
	self.doLoadCmbContentsStatus();
	self.doLoadCmbImEx();
	
	self.doLoadCmbCustomDetails();
	
	self.doLoadShippingLine();			// May 20, 2022 navak20 TFS 53204
	self.doLoadCountryOfOrigin();		// 19.08.2022 navak20 TFS 54441
	
	//self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, TI_CargoType_Container, TI_STATE_NORMAL, self.myTI, null);	// PAR #31196
	// from 37288 this has already been called from cmbCargoType_lostFocus from initTableContainer from setupForm, for the default cargo type,
	//	so only do it again if this default cargo type is not Container
	if self.myCargoType = null or
	   (self.myCargoType.id &lt;&gt; TI_CargoType_Container) then
		self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, TI_CargoType_Container, self.myTI, null, null);					// PAR #31196, extra parameter for 37288
	endif;
	
	if self.myTI &lt;&gt; null then //form is being initiated with a TI from yard areas screen
		self.cmbTrackedItem.text := self.myTI.id;
		self.doDisplayTrackedItem(false);
	else
		self.setState(STATE_DISABLED);
	endif;
	if self.myFilterObject = null then
		create self.myFilterObject transient;
	endif;
	self.tblContainer.changeMode := tblContainer.ChangeMode_FirstOnly;
	
// cnwdad1 17/04/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		self.cmbSubTerminal.automaticCellControl	:=	true;
		
		if self.myTI = null then
			subTerminalObj	:=	null;
		else
			subTerminalObj	:=	self.myTI.mySubTerminal;
		endif;
		
		self.myAssistant.comboBoxSubTerminal(self.cmbSubTerminal, subTerminalObj, self.myTerminal);
		self.myAssistant.comboBoxSubTerminal(self.cmbUSubTerminal, subTerminalObj, self.myTerminal);
		
// cnwdad1 20/07/2010 - PAR #24868 - Check for Port Otago and get Default S-T for Export Full.
		if app.myRoot.client = Client_PortOtago then
			defSubTermObj	:=	self.myTerminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal;
			self.myAssistant.comboBoxSubTerminal(self.cmbPSubTerminal, defSubTermObj, self.myTerminal);
		else
			self.myAssistant.comboBoxSubTerminal(self.cmbPSubTerminal, subTerminalObj, self.myTerminal);
		endif;
	else
		self.tblPacked.hideColumnByColName(ETRow_MySubTerminal);
		self.tblUnpacked.hideColumnByColName(ETRow_MySubTerminal);
		self.tblContainer.hideRowByName(ETRow_MySubTerminal, false);
		self.lblPSubTerminal.visible	:=	false;
		self.cmbPSubTerminal.visible	:=	false;
		self.lblUSubTerminal.visible	:=	false;
		self.cmbUSubTerminal.visible	:=	false;
	endif;

	if self.myInitialisationLC &lt;&gt; null then
		self.cmbQryTAType.setIndexFromObject(self.myInitialisationLC.myTerminalArea.myType);
		self.cmbQryTAType_click(self.cmbQryTAType);
		self.cmbQryTermArea.setIndexFromObject(self.myInitialisationLC.myTerminalArea);
		self.cmbQryTermArea_click(self.cmbQryTermArea);
		self.cmbQryRow.setIndexFromObject(self.myInitialisationLC);
		self.frmQuery.visible := (self.cmbQryRow.listObject = null);
	endif;
	
	if not self.allInitialisationTIs.isEmpty() then
		self.frmQuery.visible := false;
		self.displayInitialisationTIs();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSealTypeTables" id="46642e41-88ad-4bee-9317-583bc9f64b68">
        <source>loadSealTypeTables();
//+cnwml2 PAR23715 SFW CCMS1131

vars
	sealType : CM_SealType;
	seal : CM_SealTI;
	aSealTypeControl : CM_Table; 
	controlId : Integer;
begin
	self.allSealTypeControls.clear();
	controlId := 13000; // What?
	foreach sealType in app.myRoot.allSealTypes discreteLock do
		if sealType.allowMultipleSealNums then
			controlId := controlId + 1;
			aSealTypeControl := self.tblSeals.loadControl( controlId ).CM_Table;
			aSealTypeControl.name := "tblSeals" &amp; sealType.sealType;
			aSealTypeControl.setEventMapping( "lostFocus", "tblSeals_lostFocus");
			aSealTypeControl.setEventMapping( "gotFocus", "tblSeals_gotFocus");
			aSealTypeControl.inputType := Table.InputType_TextBox;
			aSealTypeControl.userInputEnabled := true;
			aSealTypeControl.rows := 10;
			self.allSealTypeControls.add( aSealTypeControl);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
