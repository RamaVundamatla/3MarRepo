        <Parameter name="_iconAttributes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="62d01973-7c17-4b52-9f3b-0008a9fcc8a7">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 07/11/2012	cnwcs5		par 30475 - get rid of all location restrictions exceptio log
// ---------------------------------------------------------------------------

vars
	theController 		: CM_LocationsController;
	theLogController 	: CM_LogController;
	lPercentFull 		: Integer;
	theLogLocRest 		: CM_LocationRestrictLog;	// par 30475
	block 				: CM_DataContainerBlock;
	
begin
	theController := self.getPrimaryLocation(REAL_MODE);
	
	if theController.isKindOf(CM_LogController) then
		theLogController := theController.CM_LogController;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Number_Of_Logs), DC_Label, 1, null);
		block.addNewItem(theLogController.numTIs.String, DC_Data, 1, null);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Cargo_Volume), DC_Label, 1, null);
		block.addNewItem(theLogController.totalVolume.jasVolumeString, DC_Data, 1, null);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Average_SED), DC_Label, 1, null);
		block.addNewItem(theLogController.averageSED.sedString, DC_Data, 1, null);

		lPercentFull 	:= 0;
		theLogLocRest 	:= theLogController.myLocationRestriction.CM_LocationRestrictLog;	// par 30475
		
		if theLogLocRest &lt;&gt; null then
			if theLogLocRest.estimatedMaxVolume &lt;&gt; 0 then
				lPercentFull := (theLogController.totalVolume / theLogLocRest.estimatedMaxVolume).Integer;
			endif;
			
			block := _dataContainer.addNewBlock;
			
			block.addNewItem(app.getErrorString(CM_Cargo_Volume) &amp; " %", DC_Label, 1, null);
			block.addNewItem(lPercentFull.String, DC_Data, 1, null);
		
			block := _dataContainer.addNewBlock;
			
			block.addNewItem(app.getErrorString(CM_Restriction_GC), DC_Label, 1, theLogLocRest);
			block.addNewItem(theLogLocRest.id.String, DC_Data, 1, theLogLocRest);
		endif;
	endif;

	if self.myOperator &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Operator_GC), DC_Label, 1, self.myOperator);
		block.addNewItem(self.myOperator.description.String &amp; " (" &amp; self.myOperator.code.String &amp; ")", DC_Data, 1, self.myOperator);
	endif;
	
	if self.myVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, self.myVoyage);
		block.addNewItem(self.myVoyage.description.String &amp; " (" &amp; self.myVoyage.code.String &amp; ")", DC_Data, 1, self.myVoyage);
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
