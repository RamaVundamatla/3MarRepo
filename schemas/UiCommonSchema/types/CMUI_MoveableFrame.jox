    <JadeMethod name="create" id="4fd991d6-086f-42d4-858a-1a31c4dbcdef">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
vars

begin
	self.bevelInnerWidth 	:= 1;
	self.bevelOuterWidth 	:= 1;
	self.borderStyle 		:= Frame.BorderStyle_None;
	self.boundaryBrush 		:= 0;
	self.boundaryWidth 		:= 4;
	self.caption 			:= null;
end;</source>
    </JadeMethod>
    <JadeMethod name="inDragMode" id="b7ef000f-880e-4f8b-ab4e-59dcb2cd88cc">
        <methodInvocation>mapping</methodInvocation>
        <source>inDragMode(set: Boolean; _value: Boolean io) mapping, protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.enableEvent('mouseMove', _value);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="load" id="bd6fed29-7d44-4a99-a75c-b8e72eede3cf">
        <source>load();
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="c09aac5a-5843-4241-9699-e05bab562ef4">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if button = MouseButton_Left then
		inheritMethod(frame, button, shift, x, y);
		
		// save x,y relative to parent window
		self.mouseDownX := x + self.left;
		self.mouseDownY := y + self.top;
		self.zOrder(1); // AKB2003DEC added;
		self.inDragMode := true;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="cdd9c649-a9d1-4590-9dd1-ca0a9ff96401">
        <updating/>
        <source>mouseEnter(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	app.mousePointer := Window.MousePointer_Size;
	inheritMethod(frame);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseLeave" id="101318e8-ada7-4d23-8e78-52ffc36161b1">
        <updating/>
        <source>mouseLeave(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := Window.MousePointer_Default;
	if self.inDragMode then
		self.inDragMode := false;
	endif;
	inheritMethod(frame);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="3d0668c9-1ffc-496a-9c44-ce3269dc6273">
        <updating/>
        <source>mouseMove(frame: CMUI_MoveableFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpX, tmpY,
	parentX,
	parentY			: Real;

begin

	if frame.inDragMode then
		// convert x,y to be relative to parent window
		parentX := x + frame.left;
		parentY := y + frame.top;
		
		tmpX := frame.left + parentX - frame.mouseDownX;
		tmpY := frame.top + parentY - frame.mouseDownY;
		
		frame.move(tmpX, tmpY, frame.width, frame.height);

		frame.mouseDownX := parentX;
		frame.mouseDownY := parentY;
	endif;
	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="CMUI_MoveableFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="de595a40-1220-4cb4-bd87-7bb92c809659">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(frame, button, shift, x, y);
	
	self.inDragMode := false;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="ec93d312-664b-4cdb-b9ce-231399ea66c3">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	parentWidth, 
	parentHeight 		: Integer;
	theParent			: Window;
begin
	inheritMethod();
	theParent := self.parent;
	if (not Form.hasInstance(theParent)) then
		if (not Frame.hasInstance(theParent)) then
			app.writeStatement( theParent.name &amp; "/" &amp; self.name &amp; " " &amp;  self.class.name &amp; "::" &amp; method.name &amp; " 1. PARENT NOT HANDLED: " &amp; theParent.class.name &amp; ' ' &amp; theParent.name);
		endif;
		return;
	endif;
	
	parentWidth := theParent.Form.clientWidth;
	parentHeight := theParent.Form.clientHeight;
	
	// ## Move Area Selector
	// ### LEFT
	if parentWidth &lt; self.clientWidth then
		self.left := 1;
	elseif (self.clientWidth + self.left) &gt; parentWidth then
		self.left := parentWidth - self.clientWidth - 10;
	endif;
	// ### TOP
	if parentHeight &lt; self.clientHeight then
		self.top := 1;
	elseif (self.clientHeight + self.top) &gt; parentHeight then
		self.top := parentHeight - self.clientHeight - 10;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="965b5f3d-4e66-42d4-a282-f23ddb107690">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	//cnwmc5 - PAR 31051
	if not self.isInPainter then
		if app.isUsingSkin() and not self.isKindOf(CMUI_ResizableRectFrame) then	//cnwmc5 PAR 31678
			self.bevelInnerWidth 	:= 0;
			self.bevelOuterWidth 	:= 0;
			self.borderStyle 		:= 0;
			self.boundaryBrush 		:= 0;
			self.boundaryWidth 		:= 0;
			self.skinCategoryName	:= 'search';
		endif;
	endif;
	
	self.inDragMode := false;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
