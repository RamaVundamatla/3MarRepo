end;</source>
        <Parameter name="_req" type="BGP_AuditRequest"/>
    </JadeMethod>
    <JadeMethod name="createUpdateAuditFromRequest" id="43b62c72-ab01-43b0-8da7-112061cf15f7">
        <source>createUpdateAuditFromRequest(_req : BGP_AuditRequest);

vars

	anAudit 		: CM_AuditObject;
	tmpAuditConfig	: CM_AuditConfig;
	deltaBeforeText,	
	deltaAfterText	: String;

begin

	if not self.getAuditConfigForClass( _req.mySubject, _req.mySubject.class, tmpAuditConfig) then
		return;
	endif;
	if self.doTextComparison(null,_req.beforeText, _req.afterText, deltaBeforeText, deltaAfterText) then
		anAudit := self.createAuditObject(_req.mySubject, AuditUpdated, tmpAuditConfig, _req.extraInfo);
		anAudit.setAuditText(deltaBeforeText);
		anAudit.setPostAuditText(deltaAfterText);
	endif;

end;</source>
        <Parameter name="_req" type="BGP_AuditRequest"/>
    </JadeMethod>
    <JadeMethod name="createUpdateFromRequest" id="ef4c6090-bd7a-4359-8031-aad4c5c244a0">
        <source>createUpdateFromRequest(_req : BGP_AuditRequest);

vars

	anAudit 			: CM_AuditObject;
	tmpAuditConfig		: CM_AuditConfig;
	currentValueString	: String;

begin

	if not self.getAuditConfigForClass( _req.mySubject, _req.mySubject.class, tmpAuditConfig) then
		return;
	endif;
	anAudit := self.auditedObjects[_req.mySubject];
	if anAudit = null then
		anAudit := createAuditObject(_req.mySubject, AuditUpdated, tmpAuditConfig, _req.extraInfo);
	else
		if anAudit.type = AuditCreated then
			return;
		endif; 
	endif;
	anAudit.addToText(_req.beforeText, _req.afterText);	

end;</source>
        <Parameter name="_req" type="BGP_AuditRequest"/>
    </JadeMethod>
    <JadeMethod name="doTextComparison" id="2a6d0ef7-1896-4502-9536-c810f115404a">
        <source>doTextComparison(_subject		    : CM_Object;
				 _beforeText,
				 _afterText 		: String;
				 _returnBefore,
				 _returnAfter 		: String io) : Boolean;
/*
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/
vars
	aoiChild,
	aoi					: CM_AuditObjectImage;
	aop 				: CM_AuditPropertyImage;
	deltaChildBefore,
	deltaChildAfter 	: String;
	auditChildSubjects  : StringArray;
	callerContext 	    : String;	//02 Apr 2019	NDL	TFS 44140
begin

	create aoi transient;
	aoi.initialise(null, AuditUpdated, null, _beforeText, _afterText);

	aoi.getAuditText(_returnBefore, _returnAfter);
	if _returnBefore &lt;&gt; _returnAfter then
		//epr TFS 43546 22/2/19
		create auditChildSubjects transient;
		if _subject &lt;&gt; null then
			_subject.getAuditChildSubjects(auditChildSubjects);
		endif;	
		
		if auditChildSubjects.isNotEmpty then							//31.03.2025 navma1 #MTN-34387
			// nothing to audit - before and after are the same
			foreach aop in aoi.allPropertyImages discreteLock do
				if auditChildSubjects.includes(aop.name) then
					delete aoiChild;
					create aoiChild transient;
					aoiChild.initialise(null,AuditUpdated, null, aop.beforeValue, aop.afterValue);
					aoiChild.getAuditText(deltaChildBefore, deltaChildAfter);
					if deltaChildBefore &lt;&gt; deltaChildAfter then
						aop.updateBeforeValue(deltaChildBefore);
						aop.updateAfterValue(deltaChildAfter);
					endif;
				endif;
			endforeach;
		endif;
		
		aoi.getAuditText(_returnBefore, _returnAfter);
		
		//02 Apr 2019	NDL	TFS 44140 - adds in the active form
		callerContext := aoi.getCallerContextString;
		if callerContext &lt;&gt; null then
			_returnAfter := _returnAfter &amp; callerContext;
		endif;
		
		return true;
	endif;
	
	return false;
epilog	
	delete aoiChild;
	delete aoi;	
	delete auditChildSubjects;

end;</source>
        <Parameter name="_subject" type="CM_Object"/>
        <Parameter name="_beforeText" type="String"/>
        <Parameter name="_afterText" type="String"/>
        <Parameter name="_returnBefore" type="String" usage="io"/>
        <Parameter name="_returnAfter" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditConfigForClass" id="f21a8b91-9487-410d-983a-28863ebed6f0">
        <source>getAuditConfigForClass(pObject : CM_Object; pClass : Class; pAuditConfig : CM_AuditConfig output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     Checks if a class is to be auditted or not.
//				NOTE: Refer to text on this class for the procedure to follow
//				to setup a class for auditting.
//
// Parameters:  The class to check.
//
// Returns:     True if the class is to be audited.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/08/2008	cnwdad1		PAR #17673 - Added CM_LabourRestriction class.
// 24/02/2010	cnwdad1		PAR #21298 - Added CM_WagonMaster class.
// 09/05/2012	cnwcs5		CCMS 2122 - added CM_EDIParty calss
//05 May 2013	cnwrs1		add Xlation Class
//11 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//21/09/2016	CNWMA1	TFS #2675 PAR #38206 POL - Bookings window - Audit trail menu Audit window
//09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// 15 May 2017	cnwrs1	TFS 3698 add CM_Product and CM_FTPEntity auditing
// 10 Oct 2017	jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
// 21 Jan 2019	jlgmd1		TFS #43007 - Remove Teklogix
// 17 Jun 2019	jlgsl4		TFS 43207 - LNX - Audits on Invoice Process and Status Maintenance
// 12 Jul 2019	jlgdi1		TFS 45301 Added CM_CashPayment class
// 28 Jan 2021	NDL			TFS 50152 - Major re-write to use new collection of Audits on CM_Object etc.
// ---------------------------------------------------------------------------
vars

	tmpClass	: Class;
	dummyObj : CM_Object;
	
begin

	if pClass.schema.name &lt;&gt; PortSchema.name then
		return false;
	endif;
	
	//28 Jan 2021	NDL	TFS 20152
	if pObject &lt;&gt; null then
		//better for performance
		tmpClass := pObject@auditClass;
	elseif pClass &lt;&gt; null then
		//apparently type methods handle null instances!
		dummyObj := pClass.firstInstance.CM_Object;
		tmpClass := dummyObj@auditClass;
	endif;

	if tmpClass = null then
		return false;
	endif;
	
	pAuditConfig := self.allAuditConfigs[tmpClass.name];
	if pAuditConfig = null then
		executeWhen JMTDevelopmentEnvironment;
		write method.qualifiedName &amp; " - No Audit Config exists for '" &amp; tmpClass.name &amp; "', trying to audit a  '"
				&amp; pClass.name &amp; "' object - run DevSchemaJadeScript::pwCreateAuditConfigs() to build it, or correct " &amp; pClass.name &amp; "::auditClass method";
		endExecuteWhen;
		//pAuditConfig := app.myRoot.createAuditConfig(tmpClass);
	endif; 
	
	//21 Jan 2021	NDL	TFS 50152
	if pAuditConfig = null or ( pAuditConfig &lt;&gt; null and not pAuditConfig.isEnabled ) then
		return false;
	endif;

	return true;
	
epilog
	
end;</source>
        <Parameter name="pObject" type="CM_Object"/>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pAuditConfig" type="CM_AuditConfig" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentValueString" id="bbacc1ba-97e3-4ad6-adb2-929877c44075">
        <source>getCurrentValueString(_currentValue : Any) : String protected;

vars

	currentValueString : String;

begin

	if _currentValue = null then
		currentValueString := "null";
	elseif _currentValue.isKindOf(CM_Object) then
		currentValueString := _currentValue.CM_Object.auditIdDisplay;
	else
		currentValueString := _currentValue.String;
	endif;
	return currentValueString;

end;</source>
        <access>protected</access>
        <Parameter name="_currentValue" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseAudit" id="fd7525d1-a027-4d12-a4c8-1bc596d5c7dd">
        <updating/>
        <source>initialiseAudit() updating;
// 09/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126
begin

	self.auditedObjects.clear;
	self.allAuditTALocations.clear;	// CCMS CPL 2017/PAR 27126

end;</source>
    </JadeMethod>
    <JadeMethod name="isAnAuditedClass" id="35c0e62b-e355-4021-8b03-4e911c3bef97">
        <source>isAnAuditedClass(pClass : Class) : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     Checks if a class is to be auditted or not.
//				NOTE: Refer to text on this class for the procedure to follow
//				to setup a class for auditting.
//
// Parameters:  The class to check.
//
// Returns:     True if the class is to be audited.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpAuditConfig : CM_AuditConfig;
	
begin

	if pClass.schema.name &lt;&gt; PortSchema.name then
		return false;
	endif;

	return self.getAuditConfigForClass( null, pClass, tmpAuditConfig);	

end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
