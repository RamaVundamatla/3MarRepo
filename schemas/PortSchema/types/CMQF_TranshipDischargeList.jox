<Class name="CMQF_TranshipDischargeList" id="766f31b5-e556-45ea-802b-07714398a9f7">
    <superclass name="CMQF_Tranship"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="1db53c73-c382-4969-be9f-667926178b1d">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
*/
vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
	
begin
	//search improt ti's for selected voyage
	if self.getMyVoyage &lt;&gt; null then
		foreach ti in self.getMyVoyage.allImportTIs discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.sumWeight := self.sumWeight + ti.totalWeight;
				endif;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
