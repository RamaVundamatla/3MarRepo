<GUIClass name="CM_MenuEntityIconList" id="fb6244ae-17fb-4de6-83a0-a69235583ce5">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

This form lists all the pictures stored on the CM_MenuEntityIcons form, so that the details can be checked.</text>
    <ImplicitInverseRef name="btnRefresh" id="59fc5b07-fc64-4529-97c0-ea6d79b1c1f4">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblMain" id="cd5b0e0f-6cff-4df2-add9-9af6ae8d913c">
        <embedded/>
        <type name="CM_Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnRefresh_click" id="fc809709-7e92-4316-b496-32dee04a8c65">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
19 October 2021	navab1	TFS 51853
*/

vars

begin
	self.populateTable();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialiseTable" id="1c330b39-6e38-41e2-9359-a5071bde66cb">
        <source>initialiseTable();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

	table : CM_Table;
begin
	table := self.tblMain;
	
	table.selectMode	:= Table.SelectMode_CurrentRow;
	
	
	table.columns := 7;
	table.rows := 0;
	
	table.addItem("Name" &amp; Tab &amp; "Disk Name" &amp; Tab &amp; "Description" &amp; Tab &amp; "Icon" &amp; Tab &amp;  "Pic Up" &amp; Tab &amp;  "Pic Down" &amp; Tab &amp; "Picture");
	table.fixedRows := 1;

	table.sortColumn[1] := 3;
	table.sortAsc[1] := table.sortAsc[1] ;
	table.resort;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="1eea1d2a-8054-45bc-baeb-f694374c3380">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

begin
	self.setupForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="49c558e8-ff6b-4c04-8aa2-c455dfe90e1e">
        <source>populateTable();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

	iter01 : Iterator;
	men : CM_MenuEntityPicture;
	oArray : ObjectArray; 
	idx, count : Integer;
	xml : String;
	root : CM_Root;
	pic : Binary;
	
	linecolr : Integer;
	classs : Class;
begin
	root := CM_Root.firstInstance;
	
	app.mousePointer := Form.MousePointer_HourGlass;

	self.tblMain.rows := 1;
	
	create oArray transient;
	CM_MenuEntityPicture.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do


		
		idx := self.tblMain.addItem(men.name &amp; Tab &amp;
										men.bubbleHelp &amp; Tab &amp; 
										men.description &amp; Tab &amp;
										men.tag &amp; Tab &amp; 
										men.helpKeyword &amp; Tab &amp; 
										men.hyperlink &amp; Tab );

		
		self.tblMain.accessCell(idx,7).picture := men.picture;
		self.tblMain.accessedCell.alignment := Table.Alignment_Center_Top;
		self.tblMain.accessRow(idx).height := 33;
		

		
	endwhile;

epilog
	delete oArray;
	
	app.mousePointer := Form.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="25f5498d-b2c4-465a-b6c8-90f366f8d340">
        <source>setupForm();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

begin
	self.initialiseTable();
	
	self.populateTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblMain_dblClick" id="dabfab3e-4784-49c7-b846-d1d2e05ed7b1">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
19 October 2021	navab1	TFS 51853
*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	table.sortColumn[1] := table.column;
	table.sortAsc[1] := not table.sortAsc[1] ;
	table.resort;
	

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
