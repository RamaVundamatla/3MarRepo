    <JadeMethod name="updateObject" id="a3c50e5c-095e-458a-bb7e-7a56edfdf0ae">
        <updating/>
        <source>updateObject(_obj : CM_Object) updating;
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpObj : CM_Object;
	tmpBOL : CM_BOLIn;
	tmpTi : CM_TrackedItem;
	idx : Integer;
	visibleTable	: CM_DataTable;
	tableObject		: CM_Object;
begin

	if (not self.allNotableObjects.includes(_obj)) then
		return;
	endif;
	
	if self.myCurrentGCVoyage = null then
		return;
	endif;

	if CM_TrackedItem.hasInstance(_obj) then
		tmpTi := _obj.CM_TrackedItem;
		if self.optBOL.value then	
			// displaying bols not cargo
			return;
		endif;		
	elseif CM_BOLIn.hasInstance(_obj) then
		tmpBOL := _obj.CM_BOLIn;
		if self.optCargo.value then
			// displaying cargo not bols
			return;
		endif;
	else
		return;
	endif;
	
	tmpObj := _obj;

	if tmpTi &lt;&gt; null and self.tblNNCargo.visible then
		if self.tblNNCargo.findObjectInRow(tmpTi, idx) then
			if (not tmpTi.isNoNumber) then
				if idx = self.tblNNCargo.row then
					self.tblNNCargoInfo.rows := self.tblNNCargoInfo.fixedRows;
				endif;
				self.tblNNCargo.removeItem(idx);
			else
				self.tblNNCargo.accessCell(idx, 1).text := tmpTi.getAttributeStringForDefArray(self.tblNNCargo.allTblDataEntRows);		
			endif;
		elseif tmpTi.isNoNumber then
			self.addItemObjectToTable(tmpObj, self.tblNNCargo);										
		endif;
	endif;

	if self.tblPlanned.visible then
		if self.tblPlanned.findObjectInRow(tmpObj, idx) then
			if (not self.includeObject(tmpObj)) then
				if idx = self.tblPlanned.row then
					self.tblPlannedInfo.rows := self.tblPlannedInfo.fixedRows;
				endif;				
				self.tblPlanned.removeItem(idx);
			elseif tmpBOL &lt;&gt; null and tmpBOL.hasPlannedOnShipCargo()
			or tmpTi &lt;&gt; null and tmpTi.myPrimaryPlannedLocation &lt;&gt; null and tmpTi.isOnShip then
				self.tblPlanned.accessCell(idx, 1).text := tmpObj.getAttributeStringForDefArray(self.tblPlanned.allTblDataEntRows);		
			else
				if idx = self.tblPlanned.row then
					self.tblPlannedInfo.rows := self.tblPlannedInfo.fixedRows;
				endif;	
				self.tblPlanned.removeItem(idx);
			endif;
		elseif tmpBOL &lt;&gt; null and tmpBOL.hasPlannedOnShipCargo()
		or tmpTi &lt;&gt; null and tmpTi.myPrimaryPlannedLocation &lt;&gt; null and tmpTi.isOnShip then
			self.addItemObjectToTable(tmpObj, self.tblPlanned);								
		endif;
	endif;

	if self.tblNonPlanned.visible then
		if self.tblNonPlanned.findObjectInRow(tmpObj, idx) then
			if (not self.includeObject(tmpObj)) then
				self.tblNonPlanned.removeItem(idx);
			elseif tmpBOL &lt;&gt; null and tmpBOL.hasNonPlannedOnShipCargo()
			or tmpTi &lt;&gt; null and tmpTi.myPrimaryPlannedLocation = null and tmpTi.isOnShip then
				self.tblNonPlanned.accessCell(idx, 1).text := tmpObj.getAttributeStringForDefArray(self.tblNonPlanned.allTblDataEntRows);		
			else
				if idx = self.tblNonPlanned.row then
					self.tblNonPlannedInf.rows := self.tblNonPlannedInf.fixedRows;
				endif;					
				self.tblNonPlanned.removeItem(idx);
			endif;
		elseif tmpBOL &lt;&gt; null and tmpBOL.hasNonPlannedOnShipCargo()
		or tmpTi &lt;&gt; null and tmpTi.myPrimaryPlannedLocation = null and tmpTi.isOnShip then
			self.addItemObjectToTable(tmpObj, self.tblNonPlanned);					
		endif;
	endif;
	
	if self.tblOnShip.visible then
		if self.tblOnShip.findObjectInRow(tmpObj, idx) then
			if (not self.includeObject(tmpObj)) then
				self.tblOnShip.removeItem(idx);
			elseif tmpBOL &lt;&gt; null and tmpBOL.hasCargoForSite(TI_SITE_ONSHIP)
			or tmpTi &lt;&gt; null and tmpTi.isOnShip then
				self.tblOnShip.accessCell(idx, 1).text := tmpObj.getAttributeStringForDefArray(self.tblOnShip.allTblDataEntRows);
			else
				if idx = self.tblOnShip.row then
					self.tblOnShipInfo.rows := self.tblOnShipInfo.fixedRows;
				endif;						
				self.tblOnShip.removeItem(idx);
			endif;
		elseif tmpBOL &lt;&gt; null and tmpBOL.hasCargoForSite(TI_SITE_ONSHIP)
		or tmpTi &lt;&gt; null and tmpTi.isOnShip then
			self.addItemObjectToTable(tmpObj, self.tblOnShip);		
		endif;
	endif;

	if self.tblOnSite.visible then			
		if self.tblOnSite.findObjectInRow(tmpObj, idx) then
			if (not self.includeObject(tmpObj)) then
				self.tblOnSite.removeItem(idx);
			elseif tmpBOL &lt;&gt; null and tmpBOL.hasCargoForSite(TI_SITE_ONSITE) 
			or tmpTi &lt;&gt; null and tmpTi.isOnSite then
				self.tblOnSite.accessCell(idx, 1).text := tmpObj.getAttributeStringForDefArray(self.tblOnSite.allTblDataEntRows);		
			else
				if idx = self.tblOnSite.row then
					self.tblOnSiteInfo.rows := self.tblOnSiteInfo.fixedRows;
				endif;							
				self.tblOnSite.removeItem(idx);
			endif;
		elseif tmpBOL &lt;&gt; null and tmpBOL.hasCargoForSite(TI_SITE_ONSITE)
		or tmpTi &lt;&gt; null and tmpTi.isOnSite then
			self.addItemObjectToTable(tmpObj, self.tblOnSite);
		endif;
	endif;
	
	visibleTable := self.getTopTable();

	if visibleTable &lt;&gt; null
	and visibleTable.row &gt; visibleTable.fixedRows then
		tableObject := visibleTable.accessRow(visibleTable.row).itemObject.CM_Object;
		if tableObject = tmpObj then
			visibleTable.rowColumnChg(visibleTable);
		endif;
	endif;

	// display the sheet caption to include the number of items in the table
	self.displaySheetCaptions();	
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="updateXMLStrForTable" id="6104bf71-9d83-4046-84cb-584103f61a76">
        <updating/>
        <source>updateXMLStrForTable(_theTable: CM_DataTable input) updating, protected;
//--------------------------------------------------
// Created:	08 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tagPrefix,
	tagSuffix,
	tmpStr,	
	defName,
	replaceStr,
	tmpDefStr,
	tmpXMLStr 	: String;
	pos,
	startPos	: Integer;
begin

	if _theTable.myEntTableDef = null then
		return;
	endif;
	
	if _theTable.myEntTableDef.name = ETDef_GCVoyageData then
		self.xmlStrTI := _theTable.getXmlStrForColumns(true);
	else
		// Must be BOL
		self.xmlStrBOL := _theTable.getXmlStrForColumns(true);
	endif;
	
//	tmpXMLStr := _theTable.getXmlStrForColumns();
	
//	if self.xmlStrDataTables = null then
//		self.xmlStrDataTables := global.formatAsXMLPrefix(self.XMLTag_MultiDefTables) &amp; tmpXMLStr &amp; global.formatAsXMLSuffix(self.XMLTag_MultiDefTables);			
		return;
//	endif;
	
/*	startPos := 1;
	defName := _theTable.myEntTableDef.name;
	tmpDefStr := self.xmlStrDataTables.cnEcGetNextTagValueOfName(_theTable.XMLTag_Table &amp; _theTable.name, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		//tagPrefix := J_key_LessThan.Character &amp; _theTable.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
		//tagSuffix := global.formatAsXMLSuffix(_theTable.XMLTag_EntTblDef &amp; defName).trimBlanks;	
		startPos := 1;
		tmpDefStr := tagPrefix &amp; self.xmlStrDataTables.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		if tmpDefStr &lt;&gt; null then
			startPos := 1;
			tmpStr := tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;
			replaceStr := tagPrefix &amp; tmpStr &amp; tagSuffix;		
			self.xmlStrDataTables := self.xmlStrDataTables.replaceString(tmpDefStr, replaceStr);
		else
			startPos := 1;
			tmpStr := tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_Table &amp; _theTable.name, startPos).trimBlanks;
			startPos := 1;
			pos := self.xmlStrDataTables.pos('&lt;'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', startPos);
			self.xmlStrDataTables.scanWhile('&lt;'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', pos);			
			self.xmlStrDataTables := self.xmlStrDataTables.cnEcInsertInto(tmpStr, pos, pos);
		endif;

	else
		startPos := 1;
		self.xmlStrDataTables.scanWhile('&lt;'&amp; XMLTag_MultiDefTables &amp; '&gt;', startPos);
		self.xmlStrDataTables := self.xmlStrDataTables.cnEcInsertInto(tmpXMLStr, startPos, startPos);
	endif;*/

end;</source>
        <access>protected</access>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
