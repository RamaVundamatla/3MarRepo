    <JadeMethod name="getTableDisplay" id="486e778d-df35-4ee3-9db2-d8bf87646d15">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Returns a tab-delimited string for displaying the receiver in a table.
//
// Parameters:	None
//
// Returns:		The atb-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
// --------------------------------------------------------------------------------
vars
	displayValue	: String;
	dsLevel 	: String;		//28 June 2022 navhl20 TFS 53862
begin
	// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//displayValue	:=	app.getDamageDescrForLoc(self.damageLocation) &amp;
	
	//Start 28 June 2022 navhl20 TFS 53862
	if self.myDamageSeverity &lt;&gt; null then
		dsLevel	:= self.myDamageSeverity.level.String;
	endif;
	//End 28 June 2022 navhl20 TFS 53862
	
	displayValue	:=	app.getDamageDescrForPosition(self.myDamagePosition) &amp;
						Tab &amp; self.myDamageDefinition.description &amp;
						//Tab &amp; self.severity.String;		//24 June 2022 navhl20 TFS 53862
						Tab &amp; dsLevel;		//24 June 2022 navhl20 TFS 53862
	
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
