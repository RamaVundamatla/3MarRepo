    <JadeMethod name="validateForUpdate" id="ba03d29f-72b5-49d4-a21e-4327354ac35b">
        <source>validateForUpdate();
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myMachine = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Machine',null,null);
		app.raiseCMException(Input_required_field_machine,null,null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.reportedTS = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reported Date/Time', null, null);
		app.raiseCMException(Input_required_field_rptDteTme, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if not self.reportedTS.isValid then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reported Date/Time',null,null);
		app.raiseCMException(Input_required_field_rptDteTme,null,null);
		return;
	endif;
	
	if self.myFaultQuestion = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Fault Type',null,null);
		app.raiseCMException(Input_required_field_faultType,null,null); // cnwdb2	PAR 35364


		return;
	endif;
	
	
	if self.myReportedByUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Reported by User',null,null);
		app.raiseCMException(Input_required_field_rprtByUsr,null,null); // cnwdb2	PAR 35364
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
