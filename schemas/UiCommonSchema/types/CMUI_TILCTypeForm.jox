    <JadeMethod name="tblDataDisplayColourColumn" id="feb57a3b-7560-4e69-9d5f-754977554583">
        <source>tblDataDisplayColourColumn(_rowIdx, _colour : Integer);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cell : JadeTableCell;	
	col : Integer;
begin
	col := self.tblData.getColumnByRowName(ETRow_Colour);
//	return;
	if _rowIdx &gt; self.tblData.fixedRows
	and col &gt; 0 then	
		cell := self.tblData.accessCell(_rowIdx, col);
		cell.text := null;
		cell.backColor := _colour;
	endif;	
					
end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="a2e2a0c9-6e76-4cce-b36c-67c891feaa37">
