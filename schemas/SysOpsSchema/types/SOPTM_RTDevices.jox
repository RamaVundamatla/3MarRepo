    <JadeMethod name="doSave" id="42aa49ca-c3ac-4499-82d6-954c6d705b56">
        <updating/>
        <source>doSave(): Boolean updating;
// 17/08/2016 cnwrh7	TFS	2501
vars

	theForm 				: SOP_TableMaintForm;
	id, type				: String;
	rtnValue				: Boolean;
	tbl 					: CM_EntryTable;
	computerName,
	model					: String;
	isPasswordCompulsory,
	useSerialConnection		: Boolean;
	useLocalTCPConnection : Boolean;	// +17/08/2016 cnwrh7	TFS	2501
	theClass				: Class;
	cameraType			: Integer;	//08 Dec 2010	NDL Par 23831
	labelPrinter			: CM_PrinterDef;
	radioDevice			:CM_RadioTelemetryDevice;										//+TFS2501
begin
	theForm := self.myForm;		
	tbl := theForm.tblInput1;
	radioDevice := theForm.myProxyObject.CM_RadioTelemetryDevice;	//+TFS2501
	
	id := tbl.getValueByName(ETRow_Id2).String;
	type := tbl.getValueByName(ETRow_Type2).String;
	model := tbl.getValueByName(ETRow_Model).String;
	computerName := tbl.getValueByName(ETRow_ComputerName).String;
	isPasswordCompulsory := tbl.getValueByName(ETRow_PasswordRequired).String = 'Yes';
	useSerialConnection := tbl.getValueByName(ETRow_UseSerialConnection).Boolean;
	useLocalTCPConnection := tbl.getValueByName(ETRow_UseTCPConnection).Boolean;	//+ 17/08/2016 cnwrh7	TFS	2501
	labelPrinter := theForm.cmbPrinters.listObject.CM_PrinterDef;
	
	
	
	if radioDevice &lt;&gt; null then																	//+TFS2501 Only can do option for TCPIP /Serial Port
		if radioDevice.useLocalTCPConnection then
			if useSerialConnection and  useLocalTCPConnection then
				app.raiseCMException (Unsele_tcp_connec_opt,null, null);
			endif;
		endif;
		if radioDevice.useSerialConnection then
			if useSerialConnection and  useLocalTCPConnection then
				app.raiseCMException  (Unsele_serial_connec_opt,null, null);
			endif;
		endif;
	endif;
	
	//08 Dec 2010	NDL	Par 23831
	
	if theForm.cmbCameraType.listIndex &gt; 0 then
		cameraType := theForm.cmbCameraType.itemData[ theForm.cmbCameraType.listIndex ];
	else
		cameraType := 0;
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			//create theForm.myProxyObject as self.rtDeviceClass(type) transient;
			theClass := self.rtDeviceClass(type);
			if theClass &lt;&gt; null then
				create theForm.myProxyObject as theClass transient;
			else
			//	app.raiseCMException1(REQUIRED_FIELD,'Device Category',null,null);
				app.raiseCMException(Input_required_field_DevCate,null,null); // cnwdb2	PAR 35364
			endif;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	if type = RTDevice_HandHeld then
		self.setProxyForHandHeld(id, model, computerName, isPasswordCompulsory, useSerialConnection, useLocalTCPConnection, cameraType, labelPrinter);	// +17/08/2016 cnwrh7	TFS	2501
	elseif type = RTDevice_Scanner then
		self.setProxyForScanner(id, model, computerName, useSerialConnection, useLocalTCPConnection);		//+ 17/08/2016 cnwrh7	TFS	2501
	elseif type = RTDevice_Vehicle then
		self.setProxyForVehicle(id, model, computerName, useSerialConnection, useLocalTCPConnection);		// +17/08/2016 cnwrh7	TFS	2501
	endif;
	
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateRTDevice(self.myForm.myProxyObject.CM_RadioTelemetryDevice, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateRTDevice(self.myForm.myProxyObject.CM_RadioTelemetryDevice, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
