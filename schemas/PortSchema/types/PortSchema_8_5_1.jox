    <JadeMethod name="adjustVoyageEventsAmount" id="f4550fac-e769-425a-aa6f-e56ed1b586c0">
        <source>adjustVoyageEventsAmount(_controller: CnEcReleaseController);
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation CCMS 2533 tfs 721 par 36902

*/

vars
	voyEvent : CMEVT_VoyageEvent;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting Voyage Events numMoves to Amount", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting Voyage Events numMoves to Amount") ;	
	endif;
	
	beginTransaction;
	foreach voyEvent in CMEVT_VoyageEvent.instances do
		voyEvent.setAmount(voyEvent.numMoves);
	endforeach;
	commitTransaction;
	
	
	app.writeLog(method.qualifiedName &amp; " Converting Voyage Events numMoves to Amount complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting Voyage Events numMoves to Amount complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
