    <JadeMethod name="pxyCreateUpdateProxy" id="44cadfb2-14c5-4531-82a2-2c3f65f20b83">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 07 November 2006
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 				: CM_BulkArea;
	proxyLocation		: CM_BulkLocation;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.maxVolume	:= maxVolume;
	proxy.minVolume	:= minVolume;
	proxy.maxWeight	:= maxWeight;
	proxy.minWeight	:= minWeight;


	proxyLocation := myLocationsController.pxyCreateUpdateProxy;
	proxyLocation.setMyTerminalAreaProxy(proxy);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ccceba26-1d0a-4036-aa71-3b8b7d7add54">
        <updating/>
        <source>setForCreate(_proxy :CM_BulkArea input; _passport : CM_Passport input) updating;
//setForCreate(proxy : CM_BulkArea; _passport : CM_Passport input) updating;

// Created:		R Barr 3/11/2006 Comalco

vars
	locationsController	: CM_BulkLocation;
begin
	maxVolume := _proxy.maxVolume;
	minVolume := _proxy.minVolume;
	maxWeight := _proxy.maxWeight;
	minWeight := _proxy.minWeight;

	create locationsController persistent;
	locationsController.setForCreate(null, self);


	inheritMethod(_proxy, _passport);
end;</source>
        <Parameter name="_proxy" type="CM_BulkArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
