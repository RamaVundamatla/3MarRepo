    <JadeMethod name="translateForm" id="d86295e3-f58a-4e7b-90f3-b47c4976c50a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 March 2017 09:30:46.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021416, locale);
	btnAvailTemp.translateCaption(Xlat_0021417, locale);
	btnChildTemp.translateCaption(Xlat_0021418, locale);
	btnDocActions1.translateCaption(Xlat_0021922, locale);
	btnDocActions2.translateCaption(Xlat_0021923, locale);
	btnExChildTemp.translateCaption(Xlat_0021420, locale);
	btnSelectedTemp.translateCaption(Xlat_0021421, locale);
	chkByCont.translateCaption(Xlat_0021422, locale);
	frmChildTemp.translateCaption(Xlat_0021423, locale);
	frmContAvail.translateCaption(Xlat_0021424, locale);
	frmContSel.translateCaption(Xlat_0021425, locale);
	frmExChild.translateCaption(Xlat_0021426, locale);
	lblBookings.translateCaption(Xlat_0021427, locale);
	lblContFind.translateCaption(Xlat_0021626, locale);
	lblNoChild.translateCaption(Xlat_0021428, locale);
	lblNoContAvail.translateCaption(Xlat_0021429, locale);
	lblNoContSel.translateCaption(Xlat_0021430, locale);
	lblNoExChild.translateCaption(Xlat_0021431, locale);
	shtChildTemp.translateCaption(Xlat_0021432, locale);
	shtContAvail.translateCaption(Xlat_0021433, locale);
	shtContSel.translateCaption(Xlat_0021434, locale);
	shtExChild.translateCaption(Xlat_0021522, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtContFind_gotFocus" id="a545b787-80a4-4c6f-9c0c-cbf5166fa206">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtContFind_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.txtContFind.text = self.lblContFind.caption.toUpper then
		self.txtContFind.selStart := 0;
		self.txtContFind.selLength := self.lblContFind.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtContFind_keyPress" id="06932343-10fd-47fb-ac90-2bbfcee2dbc6">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtContFind_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2016	cnwndl1	Initial creation	TFS 3000

*/

vars

begin

	if keyCharCode = J_key_Enter then
		self.doClickFindCont();
		//19 Dec 2016	NDL	TFS 3000
		if self.fldContainers.topSheet = self.shtContSel then
			self.txtContFind.setFocus();
			keyCharCode := null;
			self.txtContFind.gotFocus( self.txtContFind );
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtContFind_lostFocus" id="b29c6c7a-7186-4a9d-91c4-a4953f944e8a">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtContFind_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.txtContFind.text.trimBlanks = self.lblContFind.caption.toUpper then
		//do nothing
	elseif self.txtContFind.text.trimBlanks = null then
		self.txtContFind.text := self.lblContFind.caption.toUpper;
	else
		//do nothing
	endif;
	
	self.txtContFind.selStart := 0;
	self.txtContFind.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
