<PrimType name="Decimal">
    <JadeMethod name="amountInArabicWords" id="a865042a-3c53-4dc8-a7c1-85e33954b368">
        <source>amountInArabicWords(_currencyCode : StringUtf8):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Nov 2021 navma1	ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/

vars
	arabicHelper : CMIF_NumberToArabicWords;
begin
	if not  app.isUnicode then
		return app.getErrorString1(ERR_Unicode_Method_Only,method.getNiceName());
	endif;
	
	create arabicHelper transient;
	
	return arabicHelper.convertToArabic(self,_currencyCode).String;
epilog
	delete arabicHelper;
end;</source>
        <Parameter name="_currencyCode" type="StringUtf8"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="amountInBahasaWords" id="4d43f49b-e6fa-4bb3-9af2-539f0cd12fba">
        <source>amountInBahasaWords():String;
/*

Purpose:			To convert numbers in JMT to 'Bahasa' words.

Parameters:			

retValue :=  Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38913

*/

constants

	//Base numbers in 'Bahasa'
	NumOne : String = "satu";
	NumTwo : String = "dua";
	NumThree : String = "tiga";
	NumFour : String = "empat";
	NumFive : String = "lima";
	NumSix : String = "enam";
	NumSeven : String = "tujuh";
	NumEight : String = "delapan";
	NumNine : String = "sembilan";
	NumTen : String = "sepuluh";
	
	// These are the generic numeric terms in 'Bahasa'
	Teen : String = " belas"; // as in 12 - 19
	Tens : String = " puluh";  // Tens  I.e. the equivalent of 'ty' on the end of sixty
	Hundred : String = " ratus";
	Thousand : String = " ribu";
	Million : String = " juta";
	Billion : String = " miliar";
	Trillion : String = " triliar";
	
	//These are the numbers that are the special cases in 'Bahasa'
	NumEleven : String = "sebelas";
	NumOneHundred : String = "seratus";
	NumOneThousand : String = "seribu";
	
vars

	baseIntValue : Integer64;
	header : Decimal[23,0];
	footer : Decimal[23,0];
	
	retValue : String;

begin

	baseIntValue := self.rounded64;

	if baseIntValue = 1 then
		retValue :=  NumOne;
	elseif baseIntValue = 2 then
		retValue :=  NumTwo;
	elseif baseIntValue = 3 then
		retValue :=  NumThree;
	elseif baseIntValue = 4 then
		retValue :=  NumFour;
	elseif baseIntValue = 5 then
		retValue :=  NumFive;
	elseif baseIntValue = 6 then
		retValue :=  NumSix;
	elseif baseIntValue = 7 then
		retValue :=  NumSeven;
	elseif baseIntValue = 8 then
		retValue :=  NumEight;
	elseif baseIntValue = 9 then
		retValue :=  NumNine;
	elseif baseIntValue = 10 then
		retValue :=  NumTen;
	elseif baseIntValue = 11 then
		retValue :=  NumEleven;
	elseif baseIntValue &lt; 20 then // 12 13 14 15 16 17 18 19
		footer := baseIntValue - 10;
		retValue :=  footer.amountInBahasaWords() &amp; Teen;  
	elseif baseIntValue &lt; 100 then	// 20 - 99 
		header := (baseIntValue div 10);
		footer := (baseIntValue mod 10);
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Tens;
		else
			retValue :=  header.amountInBahasaWords() &amp; Tens &amp; " " &amp; footer.amountInBahasaWords();
		endif;	
	elseif  baseIntValue &lt; 200 then	// 100 - 199 
		header := 100;
		footer := baseIntValue - 100;
		if footer = 0 then
			retValue :=  NumOneHundred;
		else
			retValue :=  NumOneHundred &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif  baseIntValue &lt; 1000 then	// 200 - 999 
		header := (baseIntValue div 100);
		footer := (baseIntValue mod 100);
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Hundred;
		else
			retValue :=  header.amountInBahasaWords() &amp; Hundred &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif baseIntValue &lt; 2000 then	//	1000 - 1999
		header := 1000;
		footer := baseIntValue - 1000;
		if footer = 0 then
			retValue :=  NumOneThousand;
		else
			retValue :=  NumOneThousand &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif baseIntValue &lt; 1000000 then	//	2000 - 999,999
		header := baseIntValue div 1000;
		footer := baseIntValue mod 1000;
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Thousand;
		else
			retValue :=  header.amountInBahasaWords() &amp; Thousand &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif baseIntValue &lt; 1000000000 then	// 1,000,000 - 999,999,999
		header := baseIntValue div 1000000;
		footer := baseIntValue mod 1000000;
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Million;
		else
			retValue :=  header.amountInBahasaWords() &amp; Million &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif baseIntValue &lt; 1000000000000 then	// 1,000,000,000 - 999,999,999,999
		header := baseIntValue div 1000000000;
		footer := baseIntValue mod 1000000000;
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Billion;
		else
			retValue :=  header.amountInBahasaWords() &amp; Billion &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	elseif baseIntValue &lt; 100000000000000000 then	// 1,000,000,000,000 - 99,999,999,999,999,999
		header := baseIntValue div 1000000000000;
		footer := baseIntValue mod 1000000000000;
		if footer = 0 then
			retValue :=  header.amountInBahasaWords() &amp; Trillion;
		else
			retValue :=  header.amountInBahasaWords() &amp; Trillion &amp; " " &amp; footer.amountInBahasaWords();
		endif;
	endif;
	
	return retValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="amountInIndoBahasa" id="bdb2850e-0306-4b4f-8dd4-73f81997a45e">
        <source>amountInIndoBahasa():String;
/*

Purpose:			To convert numbers in JMT to 'Bahasa' words and then add 'Rupiah' on the end.

Parameters:			

retValue :=  Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38913

*/

constants
	
vars

	
	fullString : String;
	firstChar : String;
	retValue : String; 
	

begin
	
	fullString := self.amountInBahasaWords();
	if fullString.length &gt; 1 then
		firstChar := fullString[1:1].toUpper;
		retValue := firstChar &amp; fullString[2:end] &amp; " rupiah";
	endif;

	return retValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asCSVFormatString" id="48dc0d06-567b-4907-bcce-649d4000d099">
        <source>asCSVFormatString() : String;
//
//05 Jul 2012	cnwrs1	Par 29894 - write negative numbers out as negative not zero
//
vars
	rtnString : String;
begin
	rtnString := self.cnEcStripDecimalZeros().String;
	if (not rtnString.isInteger) then
		rtnString := self.asStringJMTWithPrecision($CM_Decimal1LeadingZero.decimalPlaces, true);
	endif;
	return rtnString;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asCurrencyJMT" id="526fcdc1-33cd-4101-adcb-998c314b8999">
        <source>asCurrencyJMT():String;
// --------------------------------------------------------------------------------
// Created:		30 March 2008 by cnwdad1
//
// Purpose:		Returns the receiver formatted as currency, i.e. with $ and commas
//				(or periods) as required.
//
//				*** THIS HAS NOT BEEN TESTED FOR INTERNATIONALISATION ***
//
// Parameters:	None
//
// Returns:		The receiver, formatted as currency.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	retString : String;
	defCurrencySymbol : String;
	jmtCurrSymbol : String;
	
begin
//	return self.currencyFormat();

	//31 May 2015	NDL	par 31635
	retString := self.currencyFormat;	// format using the locale

	defCurrencySymbol := app.getMyLocaleInfoJMT.currencyInfo.symbol;	// get the Locale currency symbol i.e. '$'
	jmtCurrSymbol := app.myRoot.getInvoiceCurrencySymbol().Character.String; // get the JMT currency value for the Term
	
	if jmtCurrSymbol &lt;&gt; defCurrencySymbol then
		retString := retString.replaceString(defCurrencySymbol,jmtCurrSymbol);
	endif;
	
	return retString;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asCurrencyJMTWords" id="01121067-20a7-4eeb-9656-4f4e61aa9796">
        <source>asCurrencyJMTWords():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2012	cnwndl1	Initial creation	Par 30183

*/


vars

	currencyFormat : CurrencyFormat;
	dollarsBit : Integer;
	rawString : String;
	decimalPos : Integer;
	numPlaces : Integer;
	rawCentsBitString : String;
	centsBit : Integer;
	returnStr : String;
	
begin

	dollarsBit := self.wholeValue();
	rawString := self.String;
	decimalPos := rawString.pos(".",1);
	if decimalPos &lt; 1 or decimalPos = rawString.length then
		centsBit := 0;
	else
		currencyFormat := app.currentLocaleInfo.currencyInfo;
		numPlaces := currencyFormat.intlDecimalPlaces;
		rawCentsBitString := rawString[decimalPos + 1 : end].padZeros( numPlaces );
		centsBit := rawCentsBitString[1:numPlaces].Integer;
	endif;
	
	if dollarsBit = 0 then
		returnStr := centsBit.asWords &amp; " " &amp; app.getErrorString(Num_Cents);
	else
		returnStr := dollarsBit.asWords &amp; " " &amp; app.getErrorString(Num_Dollars);
		if centsBit &gt; 0 then
			returnStr := returnStr &amp; " " &amp; app.getErrorString(Num_And) &amp; " " &amp; centsBit.asWords &amp; " " &amp; app.getErrorString(Num_Cents);
		endif;
	endif;
	
	if returnStr &lt;&gt; null then
		returnStr := returnStr[1:1].toUpper &amp; returnStr[2:end];
	endif;
	
	return returnStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asCurrencyJMTWords2" id="7a74587e-a9ca-4340-9e71-8b4375e2a7ae">
        <source>asCurrencyJMTWords2():String;
// ---------------------------------------------------------------------------
// Created:     Sept 2013 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 32567 new method for QNPS
// ---------------------------------------------------------------------------
/*

Purpose:	This version of currency as words drops the 'and' between the numbers except for 'and 99 cents'.
				It also moves the 'Dollars' to the front of the words.
				It also removes all commas
*/


vars

	currencyFormat : CurrencyFormat;
	dollarsBit : Integer;
	rawString : String;
	decimalPos : Integer;
	numPlaces : Integer;
	rawCentsBitString : String;
	centsBit : Integer;
	returnStr : String;
	idx, idy : Integer;
	usedAND : Boolean;
	lastTwoInt : Integer;
begin

	dollarsBit := self.wholeValue();
	rawString := self.String;
	decimalPos := rawString.pos(".",1);
	if decimalPos &lt; 1 or decimalPos = rawString.length then
		centsBit := 0;
	else
		currencyFormat := app.currentLocaleInfo.currencyInfo;
		numPlaces := currencyFormat.intlDecimalPlaces;
		rawCentsBitString := rawString[decimalPos + 1 : end].padZeros( numPlaces );
		centsBit := rawCentsBitString[1:numPlaces].Integer;
	endif;
	
	//02 Oct 2013	NDL	Par 32567 - Midnight cowboy changes
	if dollarsBit = 0 then
		//we have strainght cents, no and required
		returnStr := centsBit.asWords2() &amp; " " &amp; app.getErrorString(Num_Cents);
	else
		returnStr := dollarsBit.asWords2();
		if centsBit &gt; 0 then
			//full value includes cents, thats where the and goes...
			returnStr := returnStr  &amp; " " &amp;  app.getErrorString(Num_And)  &amp; " " &amp; centsBit.asWords2() &amp; " " &amp; app.getErrorString(Num_Cents);
		else
			//we have a value with no cents on the end.  If the last 2 dollar digits are zeros. Nothing to do.
			//Otherwise insert an 'and' before the words representing the last two digits.
			if dollarsBit &gt; 100 then
				lastTwoInt := dollarsBit mod 100;
				if lastTwoInt &gt; 0 then
					idx := returnStr.reversePos( " " &amp; lastTwoInt.asWords2() );
					returnStr := returnStr[1:idx] &amp;  app.getErrorString(Num_And) &amp;  returnStr[idx:end] ;
				endif;
			endif;
		endif;
	endif;
	
	if returnStr &lt;&gt; null then
		returnStr := returnStr[1:1].toUpper &amp; returnStr[2:end];
		
		returnStr := app.getErrorString(Num_Dollars) &amp; " " &amp; returnStr;
		returnStr := returnStr[1:1].toUpper &amp; returnStr[2:end];
	endif;
	
	return returnStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHoursMinutes" id="a34e2b46-a001-46c3-bee6-1b4c2ef9a0f4">
        <source>asHoursMinutes():String;
/*
	Purpose:		Convert receiver to hh:mm			
	Return Value:	Receiver converted to hh:mm	

Date			Who		Reason
01 August 2008	concms1	Initial creation
*/

vars
	str		:String;
	value	:Decimal[23,2];
begin
	if self = null then
		return null;
	endif;
	
	str := self.Integer.String &amp; 'h';						// hours
	str := str &amp; (((self - self.Integer)*60).rounded.String).padLeadingZeros(2) &amp; 'm';	// minutes
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHrsMins" id="37d48c91-5375-431d-a486-063b73383757">
        <source>asHrsMins() : String;

/*

Purpose:	Convert a decimal to hours, minutes.  
			Hours are represented before the decimal point
			Minutes are represented after the decimal point

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwmd1	Initial creation

*/

vars
	str		:String;
	value	:Decimal[23,2];
	hrs, mins : Integer;
begin
	if self = null then
		return null;
	endif;
	
	hrs := self.Integer;
	mins := ((self - self.Integer) * 100).Integer;
		
	return hrs.String &amp; 'h ' &amp; mins.String &amp; 'm';
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
