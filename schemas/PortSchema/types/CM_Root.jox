    <JadeMethod name="initCollection" id="18320e33-402c-4ce4-a12d-85bdb39d5a09">
        <updating/>
        <source>initCollection(pClass : Class; pController : CnEcReleaseController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     Populate the collection on self with all instances of
//				the class passed in (NB: will also do sub-classes)
//
// Parameters:  The class name to set the collection for
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oa	: ObjectArray;
	o	: Object;

begin

	pController.logEntry('CM_Root::initCollection for (' &amp; pClass.getName &amp; ')');
	
	create oa transient;
	pClass.allInstances(oa, 0, true);
	
	beginTransaction;

	foreach o in oa do
		o.sendMsg('setMyRoot');
	endforeach;
	
	commitTransaction;

epilog
	delete oa;
	
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pController" type="CnEcReleaseController"/>
    </JadeMethod>
