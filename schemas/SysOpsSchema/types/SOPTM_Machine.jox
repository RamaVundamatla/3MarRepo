    <JadeMethod name="displayInterfaceHistory" id="2d4e3d5e-ac8a-4fb2-9862-4d4d5f383e8b">
        <source>displayInterfaceHistory() protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	index				: Integer;
	table				: CM_DataTable;
	interfaceHistory	: CM_InterfaceHistory;
	
begin
	table			:= self.myForm.tblDataView3;
	table.rows		:= table.fixedRows;
	table.column	:= table.fixedColumns + 1;
	self.myForm.setColorsForTable( table );
	
	foreach interfaceHistory in self.allMachineInterfaceHistories discreteLock, reversed do
		index	:= table.addItem( interfaceHistory.getDisplayString );
		table.accessRow( index ).itemObject	:= interfaceHistory;
	endforeach;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayMoveHistory" id="1f332b2e-b7a2-4cce-ba12-302a168f6e6d">
        <source>displayMoveHistory() protected;
// ---------------------------------------------------------------------------
// Created:     22 February 2006	cnwhjg1
//
// Purpose:     
// 19/10/2017	cnwma1		TFS# 7249: QNS - Machine History move. Error (14051)
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	table		: CM_DataTable;
	hist		: CM_MachineHistory;
	
begin
	table 			:= self.myForm.tblDataView1;
	table.rows 		:= 1;
	table.column 	:= 1;
	
	self.myForm.setColorsForTable(table);
	
	foreach hist in self.allMachineMoveHistory discreteLock, reversed do 
		idx := table.addItem(hist.getDisplayString());
		
		// 19.10.2017 cnwma1 TFS #7249 
		if idx &gt;= JadeTableRowLimit then
			/*	self.myForm.shtViewTable1.caption	:= app.getErrorString2(	Move_History_Of,
															JadeTableRowLimit.asStringJMT,
															self.allMachineMoveHistory.size.display );*/
				app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)
					,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);
			break;
		endif;
		// 19.10.2017 cnwma1 TFS #7249 
		table.accessRow(idx).itemObject := hist;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActionBtnSetDefault1" id="a3b332ba-6a3a-498c-a2b6-61032d9fc62a">
        <updating/>
        <source>doActionBtnSetDefault1(pObj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm			: SOP_TableMaintForm;
	pMachine		: CM_Machine;
	pMachineType	: CM_MachineType;
	taSet			: CM_TerminalAreaSet;

begin
	
	theForm := self.myForm;
	if theForm.mode = theForm.Mode_View then 
		return;
	endif;
	pMachine := pObj.CM_Machine;
	if pMachine = null then
		return;
	endif;
	theForm := self.myForm;
	pMachineType := app.myRoot.allMachineTypes[pMachine.machineType];
	if pMachineType = null then
		return;
	endif;

	create taSet transient;
	pMachine.getTerminalAreasFromType(pMachineType.allAllowedTATypes , taSet);
	theForm.mulSelect1.setSelected(taSet);
epilog
	delete taSet;
end;</source>
        <Parameter name="pObj" type="Object"/>
    </JadeMethod>
