    <JadeMethod name="timerEvent" id="b012f360-a45b-47e2-baf6-b63eb09d0e88">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	offset1,offset2,offset3,offset4,offset5,offset6,aColour : Integer;
	
begin
		theColour := theColour + 1;
		if theColour = 7 then
			theColour := 1;
		endif;
		self.accumColor(offset1,1);
		self.accumColor(offset2,2);
		self.accumColor(offset3,3);
		self.accumColor(offset4,4);
		self.accumColor(offset5,5);
		self.accumColor(offset6,6);

		self.label_1.backColor := self.colours[offset1];
		self.label_2.backColor := self.colours[offset2];
		self.label_3.backColor := self.colours[offset3];
		self.label_4.backColor := self.colours[offset4];
		self.label_5.backColor := self.colours[offset5];
		self.label_6.backColor := self.colours[offset6];
		
		self.refreshNow();

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
