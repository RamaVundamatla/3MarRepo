    <JadeMethod name="save" id="2faec16a-6cc9-4552-84da-c0dbfecddcdb">
        <updating/>
        <source>save() updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	workbookDefn : WorkbookDefinition;
	obj	: Object;
	blnNew : Boolean;
begin

	beginTransaction;
		if myExcelWorkbookDefnDA.myWorkbookDefinition = null then
			create workbookDefn;
			myExcelWorkbookDefnDA.setMyWorkbookDefinition(workbookDefn);
			blnNew:= true;
		else
			workbookDefn := myExcelWorkbookDefnDA.myWorkbookDefinition;
		endif;
		// Tell host schema to save the extract options and return the oid of the options object
		obj := myExcelWorkbookDefnDA.myControllingAppsDA.invokeMethod(myExcelWorkbookDefnDA.myControllingAppsContext,myExcelWorkbookDefnDA.myControllingAppsStoreMeth, workbookDefn.myApplicationExtractOptions, true).Object; 
		// Now Save the Workbook Definition values
		workbookDefn.setValues(myExcelWorkbookDefnDA.myRoot,
			workbookName, 			
			workbookDescription,
			workbookDataWorksheet,
			workbookHideDataSheet,	
			workbookTopWorksheet,
			obj,
			myExcelWorkbookDefnDA.myAssociatedObject,
			myExcelWorkbookDefnDA.associatedObjectName,
			myExcelWorkbookDefnDA.associatedObjectType);
	commitTransaction;
	
	if blnNew then
		if tryLock(workbookDefn,Reserve_Lock,Session_Duration,LockTimeout_Server_Defined) then
			lock(workbookDefn,Reserve_Lock,Session_Duration,LockTimeout_Server_Defined);
		else
			app.msgBox("Another user is updating this workbook definition" &amp; CrLf 
				&amp; "Try again later", "Workbook Definition is Locked", MsgBox_OK_Only);
			return;	
		endif;	
	endif;
epilog

end;</source>
    </JadeMethod>
