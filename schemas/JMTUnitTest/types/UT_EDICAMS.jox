    <JadeMethod name="tCodeco_CCMS_SCT_2058" id="3fb96541-6a90-4c0d-9da7-5765f8f78d34">
        <updating/>
        <source>tCodeco_CCMS_SCT_2058()updating;
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwcs5
// Purpose:     gate in 2x containers
//				gate out 2x containers
//				run codeco and check results are the same after soft coding special characters
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 31/05/2016	cnwdap1	TFS #2061 COARRI?CODECO?COPARN?EDI VGM Updates - new parameter for zRunCams method
// 11 Jun 2019	jlgsl4	TFS 41215 - add pre-road-receive seal to Codeco
// 10 Sep 2019	cnwrs1	TFS 46030
// ---------------------------------------------------------------------------
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	DestPort		= "NZZQN";
	DischPort		= "NZAKL";
	ContainerName1	= 'UTUT000001';
	ContainerName2	= 'UTUT000002';
	ContainerName3	= 'UTUT000003';
	ContainerName4	= 'UTUT000004';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_GRP";
	CamProtocol 	= "UT_CODECO_2058";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';
vars
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4 : CM_Container;
	operator 	: CM_Operator;
	voyage 		: CM_Voyage;
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	gate			: CM_Gate;
	booking			: CM_BookingRef;
	oldValue :Boolean;
	isDoClearanceCheck : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	beginTransaction;
	oldValue := operator.getConfig (RequiresImportOperatorPIN).Boolean;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	// delete bookings we will use
	self.deleteBooking("BK001");
	self.deleteBooking("BK002");
	self.deleteBooking("BK003");
	self.deleteBooking("BK004");
	self.deleteBooking("CMS0001");
	self.deleteBooking("CMS0002");
	
	self.deleteVehicle (TRUCK);
	
	voyage := self.createVesselVoyage ( VoyageName,BoatName, operator);
	
	// make sure translations don't stuff us up
	self.deleteEDIOutwardXlation (DestPort, XLATION_TYPE_PORT_BYOP, operator, null);
	self.deleteEDIOutwardXlation (DischPort, XLATION_TYPE_PORT_BYOP, operator, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	gate := self.getSingleGate;
	self.assertNotNull (gate);

//	self.createCargoTransactions (bs, gate, ContainerName1, ContainerName2, operator);
	container1 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	container2 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
		
	container3 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BEER", voyage.code);
	container4 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "APPL", voyage.code);
	
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR001');
	container2.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR002');
	container3.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR003');
	container4.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR004');
	
	container1.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK001');
	container2.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK002');
	container3.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK003');
	container4.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK004');

	booking := container1.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR001');
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK001');

	endif;
	booking := container2.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR002');
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK002');

	endif;
	booking := container3.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR003');
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK003');

	endif;
	booking := container4.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR004');
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK004');

	endif;

	commitTransaction;	

	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);

	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);

	// RUNS CAMS
	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_UN+", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN_plus, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN2, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_ECN", camGroup, "MOT-ECN CODECO", operator, self.zCodeco_ECN, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Codeco", operator, self.zCodeco_ANL, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Codeco", operator, self.zCodeco_CMA, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_COL", camGroup, "Columbus Codeco", operator, self.zCodeco_COL, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Codeco", operator, self.zCodeco_CON, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Codeco", operator, self.zCodeco_COS, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR2, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR3, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag CODECO", operator, self.zCodeco_HLC, false, container1, container2, container3, container4, false );	
	self.zRunCAMS (CamProtocol&amp; "_HSD", camGroup, "HSD Codeco", operator, self.zCodeco_HSD, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Codeco", operator, self.zCodeco_MSC, false, container1, container2, container3, container4, false );	
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Codeco", operator, self.zCodeco_MSK, false, container1, container2, container3, container4, false );	
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Codeco", operator, self.zCodeco_NYK, false, container1, container2, container3, container4, false );	
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Codeco", operator, self.zCodeco_OOCL, false, container1, container2, container3, container4, false );	
	//self.zRunCAMS (CamProtocol&amp; "_PANDO", camGroup, "PON Codeco", operator, self.zCodeco_PANDO, false, container1, container2, container3, container4 );	
	self.zRunCAMS (CamProtocol&amp; "_SWIRE", camGroup, "Swires Codeco", operator, self.zCodeco_SWIRE, false, container1, container2, container3, container4, false );	
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Codeco Zim", operator, self.zCodeco_ZIM, false, container1, container2, container3, container4, false );	
	// add some hazards, seals, dimensions
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, oldValue);
	commitTransaction;

	delete operatorDict;
	delete freightForwarders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_ECNMOT" id="4c36340b-c3b5-43a3-b56f-0dd1e9c21423">
        <updating/>
        <source>tCodeco_ECNMOT()updating;
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 11 Jun 2019	jlgsl4	TFS 41215 - add pre-road-receive seal to Codeco
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	DestPort		= "NZZQN";
	DischPort		= "NZAKL";
	ContainerName1	= 'UTUT000001';
	ContainerName2	= 'UTUT000002';
	ContainerName3	= 'UTUT000003';
	ContainerName4	= 'UTUT000004';
	ContainerName5	= 'UTUT000005';
	ContainerName6	= 'UTUT000006';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT-ECN2";
	CamProtocol 	= "UT_ECN_CODECO";
	CamProtocol2 	= "UT_ECN_CODECO2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';

vars
	runDateTime : TimeStamp;
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4, container5, container6 : CM_Container;
	operator, defaultOperator 	: CM_Operator;	// par 29517
	voyage, defaultVoyage 		: CM_Voyage;	// par 29517
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	gate			: CM_Gate;
	oldValue :Boolean;
	isDoClearanceCheck : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	self.deleteBooking("CMS0001");
	self.deleteBooking("CMS0002");
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	beginTransaction;
	oldValue := operator.getConfig (RequiresImportOperatorPIN).Boolean;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	self.setTerminalConfig(DoNotCreateBulkRelease, false);

	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);

	self.deleteVehicle (TRUCK);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage ( VoyageName, BoatName,operator);
		
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	gate := self.getSingleGate;
	self.assertNotNull (gate);

//	self.createCargoTransactions (bs, gate, ContainerName1, ContainerName2, operator);
	container1 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null);	// par 29517 // TFS 41215
	container2 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
		
	container3 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BEER", voyage.code);
	container4 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "APPL", voyage.code);

	beginTransaction;
	container2.setPropertyValue (CM_Container::vehicle.name, null);
	container2.setPropertyValue (CM_Container::carrier.name, null);
	container3.setPropertyValue (CM_Container::deliveryRelease.name, "UT003");
	container4.setPropertyValue (CM_Container::deliveryRelease.name, "UT004");
	container4.setPropertyValue (CM_Container::releaseVehicle.name, null);
	container4.setPropertyValue (CM_Container::releaseCarrier.name, null);
	commitTransaction;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamProtocol(CamProtocol2);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol		:= self.createCamProtocolCodeco (CamProtocol, camGroup, "MOT-ECN CODECO", "NZCHC",operator.code, null, true, false);
		
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCodeco_ECNMOT1); 

	// now try for null voyage
	camProtocol		:= self.createCamProtocolCodeco (CamProtocol2, camGroup, "MOT-ECN CODECO", "NZCHC",operator.code, null, true, false);

	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container1 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container1 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container1 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
		
	// run cams
	defaultVoyage	:= self.getTerminal.getConfig (DefVoyage).CM_Voyage;		// par 29517
	defaultOperator	:= self.getTerminal.getConfig (DefOperator).CM_Operator;	// par 29517

	process.sleep (1000);

	container5 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName5, operator, "2232", "REEF", defaultVoyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215	
	container6 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName6, operator, "2200", "BEER", defaultVoyage.code);
	
	beginTransaction;
	container5.setPropertyValue (CM_Container::deliveryRelease.name, "UT005");
	container6.setPropertyValue (CM_Container::deliveryRelease.name, "UT006");
	commitTransaction;
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.last;
	self.assertNotNull(camTaskHistory);

	self.zCheckOutput (camProtocol, camTaskHistory, self.zCodeco_ECNMOT2 (defaultOperator.code)); 
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, oldValue);
	commitTransaction;
	
	delete operatorDict;
	delete freightForwarders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_ECNMOTSTPF" id="a37a29db-5818-4043-9222-1acb78fc90f7">
        <updating/>
        <source>tCodeco_ECNMOTSTPF() updating;
//
//27 May 2016	cnwrs1	ECN MOT with STPF (Single Transaction Per File)
// 11 Jun 2019	jlgsl4	TFS 41215 - add pre-road-receive seal to Codeco
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	DestPort		= "NZZQN";
	DischPort		= "NZAKL";
	ContainerName1	= 'UTUT000001';
	ContainerName2	= 'UTUT000002';
	ContainerName3	= 'UTUT000003';
	ContainerName4	= 'UTUT000004';
	ContainerName5	= 'UTUT000005';
	ContainerName6	= 'UTUT000006';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT-ECN2";
	CamProtocol3	= "UT_ECN_CODECO3";
	CamProtocol4 	= "UT_ECN_CODECO4";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';

vars
	runDateTime : TimeStamp;
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4, container5, container6 : CM_Container;
	operator, defaultOperator 	: CM_Operator;	// par 29517
	voyage, defaultVoyage 		: CM_Voyage;	// par 29517
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol3 	: CM_CamProtocol;
	camProtocol4 : CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	gate			: CM_Gate;
	oldValue :Boolean;
	isDoClearanceCheck : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	self.deleteBooking("CMS0001");
	self.deleteBooking("CMS0002");
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	beginTransaction;
	oldValue := operator.getConfig(RequiresImportOperatorPIN).Boolean;
	operator.setConfig(RequiresImportOperatorPIN, false);
	commitTransaction;
	self.setTerminalConfig(DoNotCreateBulkRelease, false);

	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);

	self.deleteVehicle(TRUCK);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage(VoyageName,BoatName,  operator);
		
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	gate := self.getSingleGate;
	self.assertNotNull(gate);

//	self.createCargoTransactions (bs, gate, ContainerName1, ContainerName2, operator);
	container1 := self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // par 29517 // TFS 41215
	container2 := self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
		
	container3 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BEER", voyage.code);
	container4 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "APPL", voyage.code);

	beginTransaction;
	container2.setPropertyValue(CM_Container::vehicle.name, null);
	container2.setPropertyValue(CM_Container::carrier.name, null);
	container3.setPropertyValue(CM_Container::deliveryRelease.name, "UT003");
	container4.setPropertyValue(CM_Container::deliveryRelease.name, "UT004");
	container4.setPropertyValue(CM_Container::releaseVehicle.name, null);
	container4.setPropertyValue(CM_Container::releaseCarrier.name, null);
	commitTransaction;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol3);
	self.deleteCamProtocol(CamProtocol4);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol3 := self.getCamProtocol(CamProtocol3);
	self.assertIsDeleted(camProtocol3);

	camProtocol3 := self.createCamProtocolCodeco(CamProtocol3, camGroup, "MOT-ECN CODECO", "NZCHC",operator.code, null, true, true);
		
	// run cams
	endDateTime := startDateTime.addMinutes(1);
//	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol3);
	self.runCamsNow(startDateTime, camProtocol3);
	
	camTaskHistory := camProtocol3.taskHistoryByProtocolSeq[camProtocol3, 1];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol3, camTaskHistory, self.zCodeco_ECNMOT3A); 
	camTaskHistory := camProtocol3.taskHistoryByProtocolSeq[camProtocol3, 2];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol3, camTaskHistory, self.zCodeco_ECNMOT3B); 
	camTaskHistory := camProtocol3.taskHistoryByProtocolSeq[camProtocol3, 3];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol3, camTaskHistory, self.zCodeco_ECNMOT3C); 
	camTaskHistory := camProtocol3.taskHistoryByProtocolSeq[camProtocol3, 4];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol3, camTaskHistory, self.zCodeco_ECNMOT3D); 

	// now try for null voyage
	camProtocol4 := self.createCamProtocolCodeco(CamProtocol4, camGroup, "MOT-ECN CODECO", "NZCHC",operator.code, null, true, true);

	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container1 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container1 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container1 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
		
	// run cams
	defaultVoyage	:= self.getTerminal.getConfig(DefVoyage).CM_Voyage;		// par 29517
	defaultOperator	:= self.getTerminal.getConfig(DefOperator).CM_Operator;	// par 29517

	process.sleep(1000);

	container5 := self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName5, operator, "2232", "REEF", defaultVoyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	container6 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName6, operator, "2200", "BEER", defaultVoyage.code);
	
	beginTransaction;
	container5.setPropertyValue(CM_Container::deliveryRelease.name, "UT005");
	container6.setPropertyValue(CM_Container::deliveryRelease.name, "UT006");
	commitTransaction;
	
	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol4);
	self.runCamsNow(startDateTime, camProtocol4);
	
	camTaskHistory := camProtocol4.taskHistoryByProtocolSeq[camProtocol4, 1];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol4, camTaskHistory, self.zCodeco_ECNMOT4A(defaultOperator.code)); 
	camTaskHistory := camProtocol4.taskHistoryByProtocolSeq[camProtocol4, 2];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol4, camTaskHistory, self.zCodeco_ECNMOT4B(defaultOperator.code)); 
	camTaskHistory := camProtocol4.taskHistoryByProtocolSeq[camProtocol4, 3];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol4, camTaskHistory, self.zCodeco_ECNMOT4C(defaultOperator.code)); 
	camTaskHistory := camProtocol4.taskHistoryByProtocolSeq[camProtocol4, 4];
	self.assertNotNull(camTaskHistory);
	self.zCheckOutput(camProtocol4, camTaskHistory, self.zCodeco_ECNMOT4D(defaultOperator.code)); 
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setConfig(RequiresImportOperatorPIN, oldValue);
	commitTransaction;
	
	delete operatorDict;
	delete freightForwarders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_HSD" id="f204efbb-8bf0-46d0-965b-960a7c9f913d">
        <source>tCodeco_HSD();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     14 February 2011 by cnwcs5 CCMS JMT 1977/PAR 26531
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// ---------------------------------------------------------------------------
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'HSDVOYAGE';				// all upper case!
	BoatName		= 'HSDBOAT';
	ContainerName	= 'HSDPACK001';
	TestOperator	= 'HSD';
	BlockStackName	= 'BLOCKSTACK';
	PackAreaName	= 'PACKAREA';
	CamGroup 		= "UT_HSD";
	CamProtocol 	= "UT_HSD CODECO";
	PackRequest		= 'UT_PACK0012345678';
	QueueName		= "UT_QUEUE";
	MachineName		= "FKP";
	DepotSubTerminal = 'UT_Depot';				// 'UT_DEPOT' 			// 17/02/2011 cnwmh5 - Sub Terminal already exists
	WhouseSubTerminal = 'UT_Warehouse';			// 'UT_WAREHOUSE' 		// 17/02/2011 cnwmh5
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	pack :CM_Depot;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	packRequest :CM_BulkRelease;
	machine :CM_Machine;
	queue :CM_SubQueue;
	tas :StringArray;
	count :Integer;
	st, depot, warehouse :CM_SubTerminal;
	exportMTY, 
	importMTY,
	storageMTY,
	storageGen,
	sourceBulkRoad,
	sourceBulkRail,
	sourceBulkPack,
	targetBulk						: CM_SubTerminal;								// 29/04/2014 cnwmh5
    resetSubTermAreaDefined : Boolean;
	theLines : HugeStringArray;
	subTerminal : CM_SubTerminal;
	transObj : CM_TITransaction;
begin
	create theLines transient;
	if self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(false);	
	endif;

//	=========== stuff we need to get started =============================================================================	
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	foreach st in self.getTerminal.allSubTerminals do
		if st.type = SubTermType_Depot_Int then
			depot := st;
			break;
		endif;
	endforeach;			
	
	if depot = null then
		depot := self.addSubTerminal (DepotSubTerminal, SubTermType_Depot_Int);
	endif;
	
	foreach st in self.getTerminal.allSubTerminals do
		if st.type = SubTermType_Warehouse_Int then
			warehouse := st;
			break;
		endif;
	endforeach;			
	
	if warehouse = null then
		warehouse := self.addSubTerminal (WhouseSubTerminal, SubTermType_Warehouse_Int);
	endif;
	
	self.setTerminalConfig(MySubTerminalForExportMTY, depot);
	self.setTerminalConfig(MySubTerminalForImportMTY, depot);
	self.setTerminalConfig(MySubTerminalForStorageMTY, depot);
	self.setTerminalConfig(MySubTerminalForStorageGen, depot);
	self.setTerminalConfig(MySubTerminalForSourceBulkRoad, depot);	
	self.setTerminalConfig(MySubTerminalForSourceBulkRail, depot);	
	self.setTerminalConfig(MySubTerminalForSourceBulkPack, depot);	
	self.setTerminalConfig(MySubTerminalForTargetBulk, warehouse);
	
//	=========== DELETES =============================================================================	
	// delete packing request
	self.deleteReleaseRequest (PackRequest);
	packRequest := self.getReleaseRequest (PackRequest);
	self.assertIsDeleted(packRequest);
	// delete voyage
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	// delete vessel
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	// delete machine
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);
	self.deleteRTDevice("81");
	// delete queue
	self.deleteQueue (QueueName);
	queue := self.getQueue (QueueName).CM_SubQueue;
	self.assertIsDeleted(queue);
	// delete block stack
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	// delete pack area
	self.deleteTerminalArea(PackAreaName);
	pack := self.getTerminalArea(PackAreaName).CM_Depot;
	self.assertIsDeleted(pack);
	// delete cam protocol
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	// delete cam group
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
//	=========== CREATES =============================================================================	
	// create vessel
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	// create voyage
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName, BoatName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	// create block stack
	bs := self.addBlockStack(BlockStackName, 0, null);
	self.assertNotNull (bs);
	// create pack area
	pack := self.addPackArea(PackAreaName, 0, null);
	self.assertNotNull (pack);
	// add machine rule between 2 areas - will get deleted if one area deleted
	self.addMachineRule (bs, pack, RTMoveMethod_24);
	// create queue
	queue := self.addQueueToTA (QueueName, BlockStackName);
	assertNotNull (queue);
	// create machine
	create tas transient;
	tas.add(bs.id); tas.add(pack.id);
	machine := self.addForkLift (MachineName, 81, tas, queue.id);
	assertNotNull(machine);
	// Add the container and move to block stack
	container 	:= self.addContainerForExport(ContainerName, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, null, voyage.code, null,	null).CM_Container;			
	tempStr		:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	
	self.assertNotNullMsg(container, tempStr);
	self.move(container, bs);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern), null);
//	transObj2 := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern), null);
/*	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Depot_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;*/
	beginTransaction;
	transObj.CM_SubTermReleaseDepotIntern.setPropertyValue(CM_SubTermReleaseDepotIntern::mySubTerminal.name, depot);
//	transObj2.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminal.name, subTerminalDepot);
	commitTransaction;

	// create the CAMS protocol
	create operatorDict transient; 
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);

	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveMarine).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveWHouse).asStringJMT);
	
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseMarine).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseWHouse).asStringJMT);
	
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseIntern).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseIntern).asStringJMT);
	
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Pack).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Unpack).asStringJMT);

	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["HSD Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
//	=========== CREATE THE PACK REQUEST AND MOVE CARGO TO PACKING AREA =============================================================================	
	packRequest := addReleaseByTypeRequest(PackRequest, BR_TYPE_PACKING, TI_CargoType_Container, "2200");
	assertEqual(packRequest.status, BR_ACTIVE);
	beginTransaction;
	packRequest.setPropertyValue (CM_BulkRelease::myOperator.name, operator);	// quick and dirty
	commitTransaction;
	// create internal move to pack area
	self.createInternalDeliveryMove (packRequest, bs, pack, queue, '2200', null);
	// complete the job
	self.machineLogon (machine);
	// accept the task
	self.machineAcceptTask (machine, queue.allEntries.first.getFirstUncompletedTask);
	// do the pickp
	self.machineDirector (machine, container);
	// do the setdown
	self.machineSetdown (machine, container, PackAreaName);
	self.machineLogOff (machine);

//	=========== RUN CAMS =============================================================================	
//	startDateTime := app.actualTimeServer.addMinutes (-60);
	endDateTime := startDateTime.addMinutes (1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	
	assertEqualMsg(camProtocol.taskHistoryByProtocolSeq.size, 1, "Should be one and only one item in the Protocol History");
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	self.assertEqual(theLines.size, 14);
	
	foreach tempStr in theLines do
		idx := idx + 1;
		if tempStr.startsWith ('TDT+1') then
			self.assertEqual(tempStr, "TDT+1+" &amp; PackRequest &amp;"+3++INTERNAL-MOVE+++'");
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual (count, 1);
epilog

	self.machineLogOff (machine);
	
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete tas;
	delete lRegisteredCargoTypes;
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( true );
	endif;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_IsCustomsProtocol" id="dfa486ee-98f4-4e84-a835-e04f8bca68f1">
        <updating/>
        <source>tCodeco_IsCustomsProtocol()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	BlockStackName		= 'BS53181';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_CODECO";
	ContainerName1		= 'UTOP000001';	
	DRIVER				= 'UT_DRIVER';
	FacilityCode 		= "UT_FACILITY";
	ForeignCode			= "12022022";	
	LocalVoyageCode 	= "UT_VOYXLATION";
	LocalVesselCode 	= "UTSTRA";
	ManifestCode		= "UTMANIFEST";
	RecipientCode 		= "UT_RECIPIENT";
	ReleaseReqNo 		= "RELREQ53181";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";	
	TRUCK				= 'UT_TRUCK';	
vars
	bs 					: CM_BlockStack;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	dischargePort 		: CM_Port;
	destination 		: CM_Port;
	endDateTime 		: TimeStamp;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	gate				: CM_Gate;
	gateArea 			: CM_GateArea;
	gateEntity 			: CMGTE_Entity;
	isDoClearanceCheck 	: Boolean;
	locations 			: CM_LCArray;	
	operator			: CM_Operator;
	operatorDict 		: CM_OperatorByCodeDict;
	operatorCount		: Integer;			
	releaseRequest 		: CM_BulkRelease;
	runDateTime 		: TimeStamp;
	startDateTime 		: TimeStamp;
	source 				: CM_LocationsController;
	ti 					: CM_TrackedItem;
	truck 				: CM_Vehicle;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;	
	vvr 				: CM_VehicleVisitRecord;
	yaName 				: String;
	ya 					: CM_YardAllocation;	
	strategy			: Integer;
	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);	
	startDateTime := app.actualTimeServer;
	self.disableAllYA(true);
	strategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA).Integer;
	deleteReleaseRequest(ReleaseReqNo);
	deleteVehicle(TRUCK);
	self.deleteContainer(ContainerName1);

	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
	
	self.deleteVoyage(LocalVoyageCode);
	voyage := self.getVoyage(LocalVoyageCode);
	self.assertIsDeleted(voyage);
	
	self.createVoyageVessel(LocalVoyageCode, LocalVesselCode, voyage, vessel);
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	destination := voyage.myTrade.allPortRotations.last.myPort;	
	operatorCount := voyage.allOperators.size;
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	operator := voyage.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer(ContainerName1, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	assertFalse(ya.isDisabled);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "UT20");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts(ReleaseReqNo, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());

	gate := self.getSingleGate;
	self.assertNotNull(gate);
	gateArea := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	
	ti := self.getTrackedItem(ContainerName1);
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TRUCK, "", DRIVER, ti.CM_Container, true, gate , null);
	truck := self.getVehicle(TRUCK);
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	foreach gateEntity in vvr.allGateEntities do
		self.moveQueuedCargo(gateEntity.myYardRequest.allWorkListEntries.first);
	endforeach;
	self.roadExit(vvr);
	
	
	beginTransaction;
	releaseRequest.getDeliveryRequest(false).setBulkReleaseTI(ti);
	releaseRequest.setProxyFromComparison("Voyage", voyage.code);
	releaseRequest.setProxyFromComparison("Discharge Port", dischargePort.code);
	releaseRequest.setProxyFromComparison("Destination", destination.code);
	commitTransaction;

		
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	 
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodeco(CamProtocol, camGroup, "STANDARD CODECO SMDG162", "NZCHC", operator.code, null, true, false);
	
	beginTransaction;
	camProtocol.setIsCustomsProtocol(true);
	commitTransaction;
	
	// Is Customs Protocol is SET run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_IsCustomsProtocol); 	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete locations;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, strategy);
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_IsCustomsProtocol213" id="dd563246-8c71-4400-9f44-e9abaefff8a8">
        <updating/>
        <source>tCodeco_IsCustomsProtocol213()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	BlockStackName		= 'BS53181';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_CODECO";
	ContainerName1		= 'UTOP000001';	
	DRIVER				= 'UT_DRIVER';
	FacilityCode 		= "UT_FACILITY";
	ForeignCode			= "12022022";	
	LocalVoyageCode 	= "UT_VOYXLATION";
	LocalVesselCode 	= "UTSTRA";
	ManifestCode		= "UTMANIFEST";
	RecipientCode 		= "UT_RECIPIENT";
	ReleaseReqNo 		= "RELREQ53181";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";	
	TRUCK				= 'UT_TRUCK';	
vars
	bs 					: CM_BlockStack;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	dischargePort 		: CM_Port;
	destination 		: CM_Port;
	endDateTime 		: TimeStamp;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	gate				: CM_Gate;
	gateArea 			: CM_GateArea;
	gateEntity 			: CMGTE_Entity;
	isDoClearanceCheck 	: Boolean;
	locations 			: CM_LCArray;	
	operator			: CM_Operator;
	operatorDict 		: CM_OperatorByCodeDict;
	operatorCount		: Integer;			
	releaseRequest 		: CM_BulkRelease;
	runDateTime 		: TimeStamp;
	startDateTime 		: TimeStamp;
	source 				: CM_LocationsController;
	ti 					: CM_TrackedItem;
	truck 				: CM_Vehicle;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;	
	vvr 				: CM_VehicleVisitRecord;
	yaName 				: String;
	ya 					: CM_YardAllocation;	
	strategy			: Integer;
	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);	
	startDateTime := app.actualTimeServer;
	self.disableAllYA(true);
	strategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA).Integer;
	deleteReleaseRequest(ReleaseReqNo);
	deleteVehicle(TRUCK);
	self.deleteContainer(ContainerName1);

	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
	
	self.deleteVoyage(LocalVoyageCode);
	voyage := self.getVoyage(LocalVoyageCode);
	self.assertIsDeleted(voyage);
	
	self.createVoyageVessel(LocalVoyageCode, LocalVesselCode, voyage, vessel);
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	destination := voyage.myTrade.allPortRotations.last.myPort;	
	operatorCount := voyage.allOperators.size;
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	operator := voyage.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer(ContainerName1, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	assertFalse(ya.isDisabled);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "UT20");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts(ReleaseReqNo, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());

	gate := self.getSingleGate;
	self.assertNotNull(gate);
	gateArea := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	
	ti := self.getTrackedItem(ContainerName1);
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TRUCK, "", DRIVER, ti.CM_Container, true, gate , null);
	truck := self.getVehicle(TRUCK);
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, gateArea, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gateArea, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	foreach gateEntity in vvr.allGateEntities do
		self.moveQueuedCargo(gateEntity.myYardRequest.allWorkListEntries.first);
	endforeach;
	self.roadExit(vvr);
	
	
	beginTransaction;
	releaseRequest.getDeliveryRequest(false).setBulkReleaseTI(ti);
	releaseRequest.setProxyFromComparison("Voyage", voyage.code);
	releaseRequest.setProxyFromComparison("Discharge Port", dischargePort.code);
	releaseRequest.setProxyFromComparison("Destination", destination.code);
	commitTransaction;

		
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	 
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodeco(CamProtocol, camGroup, "STANDARD CODECO SMDG213", "NZCHC", operator.code, null, true, false);
	
	beginTransaction;
	camProtocol.setIsCustomsProtocol(true);
	commitTransaction;
	
	// Is Customs Protocol is SET run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_IsCustomsProtocol213); 	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete locations;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, strategy);
	self.disableAllYA(false);
end;</source>
