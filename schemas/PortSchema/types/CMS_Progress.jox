    <JadeMethod name="btnCancel_click" id="a9ec0390-ff2d-4a69-ad6f-037e7b91d6c8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars
	pe : CM_ProgressException;

begin
	//PAR 2699 AJA 8/4/99: Set aborted flag if cancel button pressed
	self.aborted	:=	true;
	
	if raiseExceptionOnAbort then
		create pe;
		pe.errorCode	:=	1;
		pe.continuable	:=	true;		// cnwdad1 17/07/2008 - PAR #17109.
		raise pe;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDetails_click" id="7d5c8125-3e86-4acf-91a2-d2bac8902e4b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDetails_click(btn: Button input) updating;

vars

begin

	if height &lt;= 120 then
		height := 260;
		btn.caption := "&gt;&gt; &amp;Details";
	else
		btn.caption := "&lt;&lt; &amp;Details";
		height := 120;
	endif;
	app.doWindowEvents(0);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="a70c3173-aed8-4c49-81fe-c6d99ba5d578">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	raiseExceptionOnAbort := true;
	centreWindow;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAction" id="e1a2ba1b-d974-44d6-ac7f-3407bf1706a8">
        <source>setAction(str : String);
// Aug 2010 25273 speed up rate extract, problem was building up txtDetails.text with too much text
//  so add a limit (gets slower after tens of thousands of characters)
constants
	MaxLength = 20000;
vars
	temp	: String;
begin

	lblAction.caption := str;
	temp := txtDetails.text;
	if temp = "" or
	   temp.length &gt; MaxLength then
		temp := str;
	else
		temp :=  str &amp; CrLf &amp; temp ;
	endif;
	txtDetails.text := temp;

	// app.doWindowEvents can have undesirable side effects.
	// if the progress dialog isn't reponding to a 'doWindowEvents' call it may
	// be because you have created it during a modal show.  In that case you
	// should call app.doWindowEvents(0) ONCE after you have shown the 
	// progress dialog.
	//   Hughan
	//app.doWindowEvents(0);
	doWindowEvents(0);

end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setBackground" id="63799284-c674-4192-8e3a-dddab340d501">
        <updating/>
        <source>setBackground(_bc : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.lblAction.transparent := true;
	self.backColor := _bc;
	self.progress.backColor := _bc;
end;</source>
        <Parameter name="_bc" type="Integer"/>
    </JadeMethod>
</GUIClass>
