    <JadeMethod name="setForInterTerminal" id="80bb8abb-a783-43a4-b427-209d8580bd00">
        <updating/>
        <source>setForInterTerminal()updating;
//--------------------------------------------------------------
//Created: 07 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if (not self.chkInterTerminal.value) then
		self.tblSelection.hideRowByName(ETRow_Terminal, true);
		self.modeInterTerminal := false;
		self.optNoNumber.visible := true;
	else
		self.tblSelection.showRowByName(ETRow_Terminal, true);
		self.modeInterTerminal := true;	
		self.optNoNumber.visible := false;
		if self.optNoNumber.value then
			self.optLot.value := true;
			self.doOptLotClick();
		endif;
	endif;
	self.tblSelection.adjustHeight(1000);
	self.cmbVoyageGlobal.click(cmbVoyageGlobal);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="e2e09050-dbc2-49b0-a3d4-1c887751d5e4">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars
	proxyUserWindow	: CM_UserWindowForOpen;

begin

	if self.visible and app.getMyUser &lt;&gt; null then
	
		proxyUserWindow := app.getUserWindow(self.name, true);
		//create proxyUserWindow transient;
		if proxyUserWindow &lt;&gt; null then
			proxyUserWindow.setProxy(app.getMyUser, self.name, self.getXMLSettingsForSave, self.top, self.left, self.width, self.height, self.windowState);
		endif;
		
		//app.myTrxUA.trxUpdateUserWindow(app.getMyUser, proxyUserWindow, app.myPassport);
	endif;

	self.doFind();



end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1fe5eede-ccfa-411d-b43c-411073c943df">
        <updating/>
        <source>setupForm() updating;

vars
//	idx		: Integer;
//	gVoy	: CM_VoyageGlobal;
//	gVoyDict: CM_VoyageGlobalByCodeDict;
	entTableControl	: EntTableDef;
//	voy		: CM_Voyage;
begin


	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.terminologyForOperator := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[BOLType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');

	entTableControl := app.myController.getEntTableDef(ETDef_OffloadSelection);
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblSelection.resetSize();
	self.tblSelection.optimiseHeadingColumn();
	
	entTableControl := app.myController.getEntTableDef(ETDef_OffloadToLocation);
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblActionData.resetSize();
	self.tblActionData.optimiseHeadingColumn();
		
	self.tblSelection.setDistanceFromRight(5);
	self.tblSelection.setDistanceFromBottom(150);
	self.tblSelection.lockBottom := false;
	self.tblSelection.lockRight := false;
	self.tblSelection.stretchHeight := false;
	self.tblSelection.stretchWidth := true;
	self.tblSelection.optimiseRowHeight := true;
//	self.tblSelection.cnEcResizeContents();

	self.tblSelectData.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	self.tblSelectData.setDistanceFromRight(5);
	self.tblSelectData.setDistanceFromBottom(100);
	self.tblSelectData.lockBottom := false;
	self.tblSelectData.lockRight := false;
	self.tblSelectData.stretchHeight := true;
	self.tblSelectData.stretchWidth := true;
	self.tblSelectData.optimiseRowHeight := true;
	self.tblSelectData.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblSelectData.autoSize := Table.AutoSize_Column;


	self.txtDetail.distanceFromRight := 5;
	self.txtDetail.distanceFromBottom := 100;
	self.txtDetail.lockBottom := false;
	self.txtDetail.lockRight := false;
	self.txtDetail.stretchHeight := true;
	self.txtDetail.stretchWidth := true;
	self.txtDetail.left := tblSelectData.left;
	
	self.tblActionData.setDistanceFromRight(5);
	self.tblActionData.setDistanceFromBottom(70);
	
	self.tblActionData.lockBottom := true;
	self.tblActionData.lockRight := false;
	self.tblActionData.stretchHeight := false;
	self.tblActionData.stretchWidth := true;
	self.tblActionData.optimiseRowHeight := true;
	self.tblActionData.cnEcResizeContents();
	
	centreWindow;
	
	// sgp 30 May 2003 : moved to loadDataForFirstTime
/*	self.doOptDocketClick();
	self.optDocket.value := true;
	
	gVoyDict := app.myRoot.allVoyagesGlobal;
	
	foreach gVoy in gVoyDict do
		if gVoy.isArchived then
			continue;
		endif;
		foreach voy in gVoy.allVoyages do
			if voy.myTerminal = self.myTerminal then
				idx := self.cmbVoyageGlobal.addItem(gVoy.code &amp; '  ' &amp; gVoy.vesselName);
				self.cmbVoyageGlobal.itemObject[idx] := gVoy;
				break;
			endif;
		endforeach;
	endforeach;
*/
	
//	self.cmbVoyageGlobal.listCollection(app.myRoot.allVoyagesGlobal, true, 0);			
//	self.myAssistant.comboBoxTerminal(cmbTerminal, self.myTerminal);
	
	self.setButtons(false);
	self.setCaption(self.caption);

	if app.getMyUser.canDo(self.myTerminal, PmLogOffloadInterTerminal) then
		self.chkInterTerminal.enabled := true;
	endif;
	
	self.setForInterTerminal();
				
end;</source>
    </JadeMethod>
