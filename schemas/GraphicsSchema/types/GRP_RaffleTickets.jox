    <JadeMethod name="button1_click" id="49df675f-f691-4b21-a307-d402cd6837aa">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		16 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doPrint;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="be4fa494-2d78-45b1-9e17-d838d093e23a">
        <source>doPrint();
// ---------------------------------------------------------------------------
// Created:		16 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	x,y,theWidth,theHeight,ticketNumber, idx, many : Integer;
begin
	app.printer.setMargins(Print_Landscape,1,1,1,1);
	app.printer.printPreview := true;
	theWidth := self.frmRaffle.clientWidth;
	theHeight := self.frmRaffle.clientHeight;

	many := 350;
	self.lblOF300.caption := "of " &amp; many.String;	
	
	
	foreach ticketNumber in 1 to many do
		idx:= idx + 1;
		if idx = 1 then
			x := 10;
			y := 10;
		elseif idx = 2 then
			x := 10 + theWidth + 20;
			y := 10;
		elseif idx = 3 then
			x := 10;
			y := 10 + theHeight + 20;
		elseif idx = 4 then
			x := 10 + theWidth + 20;
			y := 10 + theHeight + 20;
		elseif idx = 5 then
			x := 10;
			y := 10 + theHeight + 20 + theHeight + 20;
		elseif idx = 6 then
			x := 10 + theWidth + 20;
			y := 10 + theHeight + 20 + theHeight + 20;
			idx := 0;
		endif;		
		self.frmRaffle.move(x,y,theWidth, theHeight);
		self.lblNumber1.caption := ticketNumber.padLeadingWith("0",3);
		self.lblNumber2.caption := ticketNumber.padLeadingWith("0",3);
		app.printer.setPrintPosition(y);				
		app.printer.print(self.frmRaffle);
		if idx = 0 then
			app.printer.newPage();
		endif;
	endforeach;
epilog
	app.printer.close;
	
	end;</source>
    </JadeMethod>
</GUIClass>
