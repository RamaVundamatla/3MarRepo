    <JadeMethod name="buildQuickAccessFormsHelp" id="a69c3a21-ae10-424a-8240-82866c2d0c2b">
        <source>buildQuickAccessFormsHelp( _restrictSearchTo : String; _keyText : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2014	cnwndl1	Initial creation
08 Apr 2025 naviv1		MTN-34407 - MTN | Remove old Windows CE based Handheld and Vehicle apps from Quick Find
*/

vars

	permissionsArray : IntegerArray;
	term : CM_Terminal;
	permission : Integer;
	quickAccess : CM_QuickAccess;
	helpStr : String;
	newLine : String;
	codeStr : String;
	hideHHandVM : Boolean;
begin

	term := self.myTerminal;
	hideHHandVM := app.myRoot.getConfig(HideAccessHHandVMApps).Boolean;

	create permissionsArray transient;
	permissionsArray.add(PmShipGCOperationsView);
	permissionsArray.add(PmGteBookingRefView);
	permissionsArray.add(PmGteMTReleaseView);
	permissionsArray.add(PmAdmCargoEnquiryView);
	permissionsArray.add(PmYardCargoReviewView); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmAdmCustDocEnqView); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmAdmEdiopersView);
	permissionsArray.add(PmGteInOutFastView);
	permissionsArray.add(PmAdmInvoicelistView); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmAdmInvoicelinesView); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmInvContractEnqView); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmShipJobOperationsMaint);
	permissionsArray.add(PmVoyagePlanningView);
	//permissionsArray.add(PmShipOperationsView);  
	permissionsArray.add(PmAdmOrdworkView);
	permissionsArray.add(PmAdmLclpackView);
	permissionsArray.add(PmGtePreNoteView);
	permissionsArray.add(PmAdmRailopsView);
	permissionsArray.add(PmAdmRoadopsdualView);
	permissionsArray.add(PmVoyageROROPlanningView);
	permissionsArray.add(PmAdmQueueView);
	permissionsArray.add(PmAdmSatelliteView);
	permissionsArray.add(PmAdmSelectorView);
	permissionsArray.add(PmAdmSystemTableView);
	permissionsArray.add(PmAdmTabledefineView);
	permissionsArray.add(PmAdmTermareadefView);				// TFS 48992
	if term.isVehicleBookingEnabled then
		permissionsArray.add(PmGteVehSchView);
	endif;
	permissionsArray.add(PmGteVisitRecordView);
	permissionsArray.add(PmShipVoyageEnquiryView);
	permissionsArray.add(PmShipOperationsView);  
	permissionsArray.add(PmAdmWorkOrderEnquiry ); // 10 Sept 2024	navab1	CR 66065
	permissionsArray.add(PmAdmWorkOrderOperations);   // 10 Sept 2024	navab1	CR 66065
	
	// to add standard forms, add the permission here, and to "PortSchema::PortSchemaRelease::createSystemQuickAccessObjects"

	
	// Qick open Forms
	foreach permission in permissionsArray do
		if app.myCurrentUserCan(term, permission) then
			quickAccess := self.getQuickAccess( null, permission );
			if quickAccess = null then
				app.msgBox("Quick Access permission " &amp; permission.String &amp; " not found " &amp; method.qualifiedName, "Developer Warning", MsgBox_OK_Only);
				continue;
			endif;
			codeStr := quickAccess.shortCode;
			if quickAccess.allowsOption then
				codeStr := codeStr &amp; " " &amp; app.getErrorString(GC_Opt);
			endif;
			if quickAccess &lt;&gt; null then
				newLine := " " &amp; _restrictSearchTo &amp; " " &amp; codeStr &amp; "	" &amp; app.getErrorString(OpensANew) &amp; " '" &amp; quickAccess.helpDescription &amp; "' " &amp; app.getErrorString(GC_Form) &amp; CrLf;
				helpStr := helpStr &amp; newLine;
			endif;
		endif;
	endforeach;
	
	helpStr := helpStr &amp; CrLf;
	
	if not hideHHandVM then		//JIRA-34407 
		//Quick open Apps
		quickAccess := self.getQuickAccess( null, PmAdmHandHeldLogonAs );
		if quickAccess &lt;&gt; null then	
			helpStr := helpStr &amp; " " &amp; _restrictSearchTo &amp; " " &amp; quickAccess.shortCode &amp; "	" &amp; app.getErrorString(GC_Starts) &amp; " " &amp; quickAccess.helpDescription &amp; CrLf;
		endif;

		if app.myCurrentUserCan(term, PmAdmVehicleRTLogonAs) then
			quickAccess := self.getQuickAccess( null, PmAdmVehicleRTLogonAs );
			if quickAccess &lt;&gt; null then
				helpStr := helpStr &amp; " " &amp; _restrictSearchTo &amp; " " &amp; quickAccess.shortCode &amp; " " &amp; app.getErrorString(GC_MachineID) &amp; "	" &amp; app.getErrorString(GC_Starts) &amp; " " &amp; quickAccess.helpDescription &amp; CrLf;
			endif;
		endif;
	endif;
	
	//Quick open personal translations
	helpStr := helpStr &amp; CrLf;
	helpStr := helpStr &amp; " " &amp; _restrictSearchTo &amp; " " &amp; self.USER &amp; "	" &amp; app.getErrorString(Personalise_quick_open) &amp; CrLf;
	
	
	//message on the main form for unknowm request.
	if _keyText &lt;&gt; null and _keyText.trimBlanks &lt;&gt; "?" then
		self.setStatusCaption( _restrictSearchTo &amp; " " &amp; _keyText &amp; ", " &amp; app.getErrorString(Not_known), 0 );
	endif;
	
	app.msgBox(helpStr, app.getErrorString(Valid_quick_open_requests), MsgBox_OK_Only );
	
epilog

	delete permissionsArray;

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_keyText" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkCurrentTerminal" id="92fb5170-cbfc-45bb-8d93-93c1fe33b7ae">
        <source>checkCurrentTerminal( _term : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2014	cnwndl1	Initial creation

*/

vars

	currentTerm : CM_Terminal;

begin

	currentTerm := self.cmbTerminal.listObject.CM_Terminal;
	if currentTerm &lt;&gt; _term and _term &lt;&gt; null then
		setStatusCaption("Warning : Find is not set for terminal " &amp; _term.code, Red);
	else
		setStatusCaption(null, 0);
	endif;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
