    <JadeMethod name="unplanDRSplit" id="f9f77858-8315-4f02-80ac-1493fcd4da3d">
        <updating/>
        <source>unplanDRSplit(_mergeWLE : CM_WorkListEntry input): Boolean updating;
/*

Purpose:			Handles the unplanning, merging and deleting of Direct Release WLEs
					where the cargo was to be split. The WLEs on both sides of the move
					need to be merged back together.
					Expected that self is the destination wle for the direct release
					ie self.myFutureMove is not null

Parameters:			_mergeWLE : a wle that is to be merged into

Return Value:		true if wles unplanned succesfully

Date				Who		Reason
25 June 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk
27 August 2019		jlgzm1	TFS 42878 Direct Release Between Road and Voyage 

*/


vars
	drWle 			: CM_WorkListEntry;
	targetMergeWLE 	: CM_WorkListEntry; // Wle merging self into (target end of move)
	sourceMergeWLE 	: CM_WorkListEntry; // Wle merging into on other (source) end of move
	deleteSelf 		: Boolean; //should self be deleted
	
	terminal 		: CM_Terminal;
	updateEvent 	: Integer;
	deleteEvent		: Integer;
	invalidObj		: Boolean;			// TFS 42878
	theFM			: CM_FutureMove;	// TFS 42878
	
begin

	if not process.isInTransactionState then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process not in transaction state');
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self, invalidObj); // TFS 42878
	
	//If we're not Direct Release, or splittable then we cant merge
	if not self.isDRLinkedByFM 
	   or self.myTrackedItem = null 
	   or not self.myTrackedItem.canMergeBreakBulk then
		return false;
	endif;	
	
	// Get terminal events to be used later
	terminal := self.getMyTerminal;
	if terminal &lt;&gt; null then
		updateEvent := terminal.getTerminalEvent(WLE_Update_Event);
		deleteEvent := terminal.getTerminalEvent(WLE_Delete_Event);
	endif;
	
	deleteSelf := true; // want to delete self unless told otherwise
	
	drWle := self.getDRLinkedWLE();
	
	//Handle source end of the move
	
	if _mergeWLE &lt;&gt; null and _mergeWLE.job &lt;&gt; self.job then
		sourceMergeWLE := _mergeWLE;
	elseif drWle.job &lt;&gt; null then
		sourceMergeWLE := drWle.job.getUnplannedWLEForTI(self.myTrackedItem);
	endif;
	
	if sourceMergeWLE &lt;&gt; null then
		// if wle is already linked for direct release, we can't merge into it
		if not sourceMergeWLE.isDRLinkedByFM then
			sourceMergeWLE.setQuantity(sourceMergeWLE.quantity + self.quantity);
			sourceMergeWLE.setWeight(sourceMergeWLE.weight + self.weight);
			if sourceMergeWLE.job &lt;&gt; null then
				sourceMergeWLE.causeEvent(updateEvent, false, sourceMergeWLE);
				if sourceMergeWLE.job.isVoyageTypeJob then
					app.myEventManager.createSingleObjInfoNoteEvt(sourceMergeWLE.job.getMyVoyageObject, updateEvent, sourceMergeWLE);
				endif;
			endif;
			drWle.causeEvent(deleteEvent, false, drWle);
			if drWle.job &lt;&gt; null and drWle.job.isVoyageTypeJob then
				app.myEventManager.createSingleObjInfoNoteEvt(drWle.job.getMyVoyageObject, deleteEvent, drWle);
			endif;
			delete drWle;
		endif;
	endif;
	
	// Handle target end of the move (self's end)
	
	if self.job &lt;&gt; null and self.job.isRoadJob and self.myRequest &lt;&gt; null then
		targetMergeWLE := self.job.getUnplannedWLEForRequest(self.myRequest);
		if targetMergeWLE = null then
			// we're either the last wle left, or will become the last unplanned wle
			// so we don't want to be deleted, just reset to default
			deleteSelf := false;
			if self.myRequest.isKindOf(CM_TIRequest) and
			   (self.myRequest.allWorkListEntries.size = 1 or
			   self.myTrackedItem = self.myRequest.CM_TIRequest.trackedItem) then
				self.setMyTrackedItem(self.myRequest.CM_TIRequest.trackedItem);
			else
				self.myTrackedItem := null;
			endif;
			self.causeEvent(updateEvent, false, self);
		else
			targetMergeWLE.setQuantity(targetMergeWLE.quantity + self.quantity);
			targetMergeWLE.setWeight(targetMergeWLE.weight + self.weight);
			if self.myRequest.isKindOf(CM_TIRequest) then
				targetMergeWLE.setMyTrackedItem(self.myRequest.CM_TIRequest.trackedItem);
			endif;
			targetMergeWLE.causeEvent(updateEvent, false, targetMergeWLE);
		endif;
		
	endif;
	
	// Delete the FutureMove
	if self.myFutureMove &lt;&gt; null then 	// TFS 42878
		theFM := self.myFutureMove;		// TFS 42878
	else
		theFM := self.myFutureMoveDR;	// TFS 42878
	endif;
	if theFM &lt;&gt; null then				// TFS 42878
		if theFM.isFutureMoveQueued and	// TFS 42878
		   theFM.CM_FutureMoveQueued.myFutureMovePlanned = null then	// TFS 42878
			while not self.allRTQueueEntries.isEmpty do					// TFS 42878
				self.allRTQueueEntries.last.deleteEntry(false, null);	// TFS 42878
			endwhile;
		endif;
		theFM.erase(NORMAL_ERASE);	// TFS 42878
	endif;
	
	// Delete self
	if deleteSelf then
		self.causeEvent(deleteEvent, false, self);
		if self.job &lt;&gt; null and self.job.workListEntries.size = 1 then
			self.job.erase(NORMAL_ERASE);
		endif;
		delete self;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_mergeWLE" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unplanForDRHoldJob" id="bc8fc00a-78fd-4de8-b080-362afefd322c">
        <updating/>
        <source>unplanForDRHoldJob(_mergeWLE : CM_WorkListEntry input): Boolean updating;
/*

Purpose:			Handles the unplanning, unlinking, and deleting of Direct Release WLEs
					planned to a hold voyage job.
					Expected that self is the destination wle for the direct release
					ie self.myFutureMove is not null

Parameters:			_mergeWLE : the other wle that needs merging.

Return Value:		true if wles unplanned succesfully

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872  Direct Release Between HOLD Voyages and Rail
04 September 2019	jlgzm1	TFS 42878 Direct Release Between Road and Voyage

*/

vars
	vWLE 		: CM_WorkListEntry;
	yWLE		: CM_WorkListEntry;
	theFM 		: CM_FutureMove;
	plannedFM	: CM_FutureMovePlanned; // TFS 42878
	tmpLC 		: CM_LocationsController;
	height 		: Integer;
	locations 	: CM_LCArray;
	mergeWLEs 	: CM_WLEArray;
	tmpWLE 		: CM_WorkListEntry;
	deleteSelf	: Boolean;
	terminal 	: CM_Terminal;
	updateEvent : Integer;
	deleteEvent	: Integer;
	deletedVWle : Boolean;
	request		: CM_Request;
begin
	if not process.isInTransactionState then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process not in transaction state');
		return false;
	endif;
	
	vWLE := self.getDRLinkedWLE();
	
	if vWLE = null then
		return false;
	endif;
	
	if vWLE.job = null or not vWLE.job.isKindOf(CM_VoyageHoldJob) then
		return false;
	endif;
	
	if self.myFutureMove = null or self.myTrackedItem = null then
		return false;
	endif;
	
	// Get terminal events to be used later
	terminal := self.getMyTerminal;
	if terminal &lt;&gt; null then
		updateEvent := terminal.getTerminalEvent(WLE_Update_Event);
		deleteEvent := terminal.getTerminalEvent(WLE_Delete_Event);
	endif;
	
	deleteSelf := true; // want to delete self unless told otherwise
	
	theFM := self.myFutureMove;
	if theFM.isFutureMoveQueued and theFM.CM_FutureMoveQueued.myFutureMovePlanned = null then	// TFS 42878
		create plannedFM; // TFS 42878
	endif;
	theFM.setMyWorkListEntryDR(null, true);
	theFM.setMyWorkListEntry(vWLE, false);
	theFM.setLocations(null);
	
	create locations transient;
	// need to find the location controller the long way, because
	// getTargetLocation will return the final destination of the direct release move
	// not the location we want
	vWLE.job.getMyTerminal.findLocationFromString(vWLE.locationTarget, true, tmpLC, height);
	if tmpLC &lt;&gt; null then
		locations.add(tmpLC);
		theFM.setLocations(locations);
	endif;
	
	if plannedFM &lt;&gt; null then		// TFS 42878
		plannedFM.setFromFMQueued(theFM.CM_FutureMoveQueued); // TFS 42878
		theFM.erase(NORMAL_ERASE);	// TFS 42878
	endif;
	
	// Deal with merging/deleting on the voyage side of move
	if self.myTrackedItem.canMergeBreakBulk then
		if _mergeWLE &lt;&gt; null and _mergeWLE.isKindOf(CM_VoyageWLE) and 
		   not _mergeWLE.isDRLinkedByFM and
		   _mergeWLE &lt;&gt; vWLE then
			_mergeWLE.setQuantity(_mergeWLE.quantity + vWLE.quantity);
			_mergeWLE.setWeight(_mergeWLE.weight + vWLE.weight);
				
			if _mergeWLE.job &lt;&gt; null then
				_mergeWLE.causeEvent(updateEvent, false, _mergeWLE);
				app.myEventManager.createSingleObjInfoNoteEvt(_mergeWLE.job.getMyVoyageObject, updateEvent, _mergeWLE);
			endif;
			
			vWLE.causeEvent(deleteEvent, false, vWLE);
			app.myEventManager.createSingleObjInfoNoteEvt(vWLE.job.getMyVoyageObject, deleteEvent, vWLE);
			delete vWLE;
			deletedVWle := true;
		else
			create mergeWLEs transient;
			vWLE.job.getWLEsForTI(self.myTrackedItem, mergeWLEs);
			tmpWLE := null;
			
			foreach tmpWLE in mergeWLEs do
				if tmpWLE.myFutureMove &lt;&gt; null and tmpWLE &lt;&gt; vWLE then
					break;
				endif;
				tmpWLE := null;
			endforeach;
			
			if tmpWLE &lt;&gt; null then
				tmpWLE.setQuantity(tmpWLE.quantity + vWLE.quantity);
				tmpWLE.setWeight(tmpWLE.weight + vWLE.weight);
				if tmpWLE.job &lt;&gt; null then
					tmpWLE.causeEvent(updateEvent, false, tmpWLE);
					app.myEventManager.createSingleObjInfoNoteEvt(tmpWLE.job.getMyVoyageObject, updateEvent, tmpWLE);
				endif;
					
				if vWLE.myFutureMove &lt;&gt; null then
					vWLE.myFutureMove.erase(NORMAL_ERASE);
				endif;
				
				vWLE.causeEvent(deleteEvent, false, vWLE);
				app.myEventManager.createSingleObjInfoNoteEvt(vWLE.job.getMyVoyageObject, deleteEvent, vWLE);
				delete vWLE;
				deletedVWle := true;
			endif;
		endif;
	endif;
	
	// if vwle not deleted, then send sys update notification
	if not deletedVWle then
		vWLE.causeEvent(updateEvent, false, vWLE);
		app.myEventManager.createSingleObjInfoNoteEvt(vWLE.job.getMyVoyageObject, updateEvent, vWLE);
	endif;

	// If we're a road job, then need to do a bit extra
	if self.job &lt;&gt; null and self.job.isRoadJob and self.myRequest &lt;&gt; null then
		request := self.myRequest;
		foreach tmpWLE in self.job.workListEntries discreteLock do
			if tmpWLE = self
			or tmpWLE.myRequest &lt;&gt; request
			or tmpWLE.status = WLE_COMPLETED
			or tmpWLE.myFutureMove &lt;&gt; null
			or tmpWLE.myFutureMoveDR &lt;&gt; null then
				continue;
			endif;
			
			yWLE := tmpWLE;
			break;
		endforeach;
		
		if yWLE = null then
			// we're either the last wle left, or will become the last unplanned wle
			// so we don't want to be deleted, just reset to default
			deleteSelf := false;
			if self.myRequest.isKindOf(CM_TIRequest) and
			   (self.myRequest.allWorkListEntries.size = 1 or
			   self.myTrackedItem = self.myRequest.CM_TIRequest.trackedItem) then
				self.setMyTrackedItem(self.myRequest.CM_TIRequest.trackedItem);
			else
				self.myTrackedItem := null;
			endif;
			self.causeEvent(updateEvent, false, self);
		else
			yWLE.setQuantity(yWLE.quantity + self.quantity);
			yWLE.setWeight(yWLE.weight + self.weight);
			if self.myRequest.isKindOf(CM_TIRequest) then
				yWLE.setMyTrackedItem(self.myRequest.CM_TIRequest.trackedItem);
			endif;
			yWLE.causeEvent(updateEvent, false, yWLE);
		endif;
	endif;
	
	while not self.allRTQueueEntries.isEmpty do					// TFS 42878
		self.allRTQueueEntries.last.deleteEntry(false, null);	// TFS 42878
	endwhile;
	
	// Delete self
	if deleteSelf then
		if self.job &lt;&gt; null and self.job.workListEntries.size = 1 then
			self.job.erase(NORMAL_ERASE);
		endif;
		self.causeEvent(deleteEvent, false, self);
		delete self;
	endif;
	
	return true;
	
epilog
	delete locations;
	delete mergeWLEs;
end;</source>
        <Parameter name="_mergeWLE" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unqueueUnplanMyTrackedItem" id="d8643f6a-f5c4-43c0-b942-284cda8873cc">
        <source>unqueueUnplanMyTrackedItem(_passport : CM_Passport input)protected;
//--------------------------------------------------
// Created:	14 June 2004 By: cnwgd1
//--------------------------------------------------
//Called by self.erase() to unqueue and unplan ti from wagon or vehicle
//otherwise ti remains queued/planned until rake is cleared or vehicle leaves the terminal
vars
	control : CMIF_MoveController;
begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	// only unqueue/unplan moves associated with this wle
	if self.myFutureMove = null then
		return;
	endif;

	create control transient;
	control.setMoveMode(QUEUE_MODE);
	control.setMyTrackedItem(self.myTrackedItem);
	control.setMyToPrimaryLocation(null);
	control.setMyWorkListEntry(self);
	control.isForcedMove := true;
	control.isSystemMove := true;
	
	// unqueue ti
	app.myUtilityUA.utlUpdateMoveTIUndo(control, _passport);	
	
	// myFutureMove ref will be reset to the associated planned FM
	if self.myFutureMove = null then
		return;
	endif;
	// now unplan ti
	control.setMoveMode(PLANNING_MODE);	
	app.myUtilityUA.utlUpdateMoveTIUndo(control, _passport);	

epilog
	delete control;	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateJobStatus" id="cbb4dc16-9332-47b3-83b9-8704246ba2bc">
        <source>updateJobStatus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwjk3	ccms 1071

*/

vars

begin
	if self.job &lt;&gt; null then
		self.job.updateStatus();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTIWithRequestInfo" id="09bcc245-bcf6-43c7-b9fe-ac850480c091">
        <source>updateTIWithRequestInfo(rem : String);
/*
Method:			updateTIWithRequestInfo();	
Author:     cnwspg1 created on 25 January 2000
Description: Method call from rail on a dd event (real mode) for ISO_REQUESTs
Assumes that this is a YardWLE etc

Fixes:
Date        User      Description
--------    --------  ------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

constants

vars
	yRequest : CM_YardRequest;
	tiUpdateCntrl : CMIF_TIUpdateController;
begin
	yRequest := self.myRequest.CM_YardRequest;
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	if yRequest.consignee.trimBlanks &lt;&gt; "" then
		self.myTrackedItem.setConsignee(yRequest.consignee.trimBlanks, tiUpdateCntrl, app.myPassport);
	endif;

	self.myTrackedItem.setRemarks(rem, true);
epilog
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="rem" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForAssignTI" id="ffe3b7f6-d1bf-4a55-972d-4ee3b20852dc">
        <source>validateForAssignTI(_theTI : CM_TrackedItem);
//--------------------------------------------------------------
//Created: 20 February 2003 By: cnwgd1
//
// 09/05/2013	cnwpjs1		PAR #31294
//--------------------------------------------------------------
vars
	type 	: Integer;
	release : CM_BulkRelease;
	hasChassis : Boolean;
	inChassis : CM_TILC;
begin
	inheritMethod(_theTI);

	type := self.getRequestType();
	if type &lt;&gt; REQ_ISO_RELEASE and type &lt;&gt; REQ_TI_RELEASE then
		app.raiseCMException1(ERR_WLE_INVALID_TYPE, self.id, null, null);	
	endif;
	

	if _theTI.releaseRequest &lt;&gt; null then
		if self.myRequest &lt;&gt; _theTI.releaseRequest then
		//Need method to determin the relase type at some stage, give "unknown" now until we can sort it.
			app.raiseCMException3(TI_TestReqOnOtherRelease, _theTI.id, _theTI.releaseRequest.getId(), self.id, null, null);
		endif;
	endif;

		
	//if _theTI &lt;&gt; null and self.myTrackedItem  &lt;&gt; null and _theTI &lt;&gt; self.myTrackedItem then
	if _theTI &lt;&gt; null and _theTI &lt;&gt; self.myTrackedItem then		// 27/03/2009 cnwar2 #19203
		if _theTI.jobRoadRelease &lt;&gt; null
		or  ( _theTI.jobRailRelease &lt;&gt; null	and not _theTI.myCargoType.allowDuplicates )//18 Jul 2018	NDL	TFS 39778
		then
			app.raiseCMException1(ERR_TI_HAS_REL_JOB, _theTI.id, null, null);
		endif;
	endif;
	
	// PAR 16929 AKB2008JUN
	if _theTI &lt;&gt; null then
		if self.myRequest.myTerminal &lt;&gt; _theTI.myTerminal 
		and _theTI.myTerminal &lt;&gt; null 
		and self.myRequest.myTerminal &lt;&gt; null then
				app.raiseCMException1(INVALID_MOVE_REQUEST, " This is an inter terminal move. '" &amp; _theTI.id &amp; "' is in terminal " &amp; _theTI.myTerminal.code &amp; " needs to be in  terminal " &amp; self.myRequest.myTerminal.code &amp;".", null, null);
	
		endif;
	endif;
	
	//epr CCMS 2437 par 35139 29/10/14
	if self.isChassisToRelease then
		//check if has in Chassis that is not complete i.e. still on truck that it is the same id
		// if not then give warning
		
		inChassis:=self.job.CM_RoadJob.getChassis(true,hasChassis);
		if inChassis &lt;&gt; null and  inChassis &lt;&gt;_theTI and inChassis.myPrimaryActualLocation = self.job.CM_RoadJob.myVehicle.locationsController then
			//raise warning
			app.raiseCMWarning2(Release_chassis_different,_theTI.id,inChassis.id,null,null,null);
		endif;
	endif;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1f023428-4e66-44c2-96bf-96a01a1e87bb">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
//This function checks that the current data held in the row is all right
//from a programatic viewpoint to delete.
//The RULES are:
//If a Release is a generic type, and no assignment, then who cares?
//If a Release is a TI type, TI must NOT be in a ROAD TRANSFER AREA. (ie,
//the TI must be somewhere else in the YARD.
//If a Receipt is a TI, its locn MUST be in a DELETION style TerminalArea,
//as that is the only way to DELETE an erroneous Tracked Item.

// 26 August 2009	cnwcs5	ccms 1061 - changed checking if ti is on vehicle
vars
	locnFlag	: Boolean;
	stackLocn 	: CM_LocationsController;
	typeStr		: String;
	recRequest	: CM_ReceivalRequest;
begin
	if self.myRequest.isKindOf(CM_ReceivalRequest) then
		recRequest := self.myRequest.CM_ReceivalRequest;
		if recRequest.hasReceivedTIs() then
			app.raiseCMException1(WLE_CantDelete, self.id, null, null);
			return;
		endif;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		if self.myRequest.isReleaseType then
			//--------------
			//Does have a tracked item, check its location. If IN a Road Trans
			//area, then QUIT (is assumed to be ON TRUCK if so!).
			//--------------
			stackLocn := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
			if stackLocn &lt;&gt; null then
				//epr par 34615
				if self.isReleaseToChassis then
					if stackLocn = self.job.CM_RoadJob.myVehicle.myUnknownChassis then
						//raise exception
						app.raiseCMException1(Not_delete_cargo_on_unknown_tr, self.myTrackedItem.id, null, null);
						return;
					endif;
				endif;		
				
				if CM_VehicleController.hasInstance (stackLocn) then	// cnwcs5 26/08/2009 - specifically handle a vehicle controller.
					if self.job.isRoadJob then
						//epr par 34523 1/8/14
						if stackLocn = self.job.CM_RoadJob.myVehicle.locationsController then
							app.raiseCMException1(VB_WLEREL_IN_RTA, self.myTrackedItem.id, null, null);
							return;
						endif;
					else
						app.raiseCMException1(VB_WLEREL_IN_RTA, self.myTrackedItem.id, null, null);
						return;
					endif;
					
				endif;
				
			endif;
			
			
		endif;
		
	else
		//epr par 34626 23/7/14
		if self.isChassisToRelease then
			if  self.job.CM_RoadJob.myVehicle.myUnknownChassis &lt;&gt; null then
				if not self.job.CM_RoadJob.myVehicle.myUnknownChassis.allTrackedItems.isEmpty then
					app.raiseCMException1(Not_delete_cargo_on_unknown_tr, self.job.CM_RoadJob.myVehicle.myUnknownChassis.allTrackedItems.first.id, null, null);
				endif;
			endif;
		endif;
					
	endif;

	typeStr := self.getRequestTypeString() &amp; ' ' &amp; self.typeString;
	
	app.raiseCMWarning2(CONF_DELETE, typeStr, self.job.jobId, null, null, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDeleteCurrentEntry" id="0f111e0d-c6d3-4aca-bab1-8f5255c1b02d">
        <source>validateForDeleteCurrentEntry();
/*

Purpose:				Perform additional validation for deleting wle as part of deleteCurrentEntry from road operations

Parameters:			

Return Value:		

Date					Who		Reason
22 November 2024		jlizm1	Initial creation MTN 33235 Delete current entry reverting already exported cargo

*/

vars
	ti : CM_TrackedItem;
	
begin
	if self.status = WLE_COMPLETED then
		
		if self.isRoad and self.isReceipt and self.myTrackedItem &lt;&gt; null then
			// aparently want to be able to cancel visit after truck unloaded, but want to stop cancels reverting
			// cargo back to prenote after it's loaded on a voyage
			ti :=  self.myTrackedItem;
			if ti.isOnShip then
				app.raiseCMException1(Unable_cancel_road_wle_ship, self.id, null, null);
				return;
			elseif ti.isOnWagon then
				app.raiseCMException1(Unable_cancel_road_wle_wagon, self.id, null, null);
				return;
			endif;
			
		endif;
	endif;
	
	self.validateForDelete();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReturnWorkEntry" id="eb31f052-4d67-4f5b-8d9b-f942dde179e0">
        <source>validateReturnWorkEntry();
//--------------------------------------------------------------
//Created: 11 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();

	// wle must be rail and it must be worked and completed for it to be returned as a 
	if (not self.job.isRelease) then
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'of type Completed Release', null, null);
	endif;

	if self.status &lt;&gt; WLE_COMPLETED then
		app.raiseCMException3(ERR_WLE_INCORRECT_STATUS, '"Return Work Entry"', '[' &amp;self.getFullDescription&amp;']', 'Complete', null, null);
	endif;
	
	app.raiseCMWarning1(ConfirmReturnWorkEntry, self.id, null, null, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="voidRoadReceiveInvoiceLine" id="3b341dc5-fbcb-4ef8-b854-0958f5a50527">
        <source>voidRoadReceiveInvoiceLine(_tiTransaction : CM_TITransaction);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2019	jlgdi1	Initial creation
*/

vars
	invoiceLine : CM_InvoiceLine;
	
begin
	foreach invoiceLine in _tiTransaction.allInvoiceLines do
		invoiceLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
	endforeach;
end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
