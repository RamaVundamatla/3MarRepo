    <JadeMethod name="processEDITIs" id="559a5f85-f3e4-4b84-9ee3-d471d7155935">
        <updating/>
        <source>processEDITIs(_verifyOnly : Boolean; _passport: CM_Passport input) protected, updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
19 Apr 2016	cnwrs1	TFS 1600 	VERMAS EDI
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Nov 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
07 Nov 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	pxyCargoItem 	: CM_TrackedItem;
	realCargoItem 	: CM_TrackedItem;
	ediTI 			: CM_EDITrackedItem;
	ediVGMTI 		: CM_EDIVGMTI;
	terminal 		: CM_Terminal;
	done, 
	todo 			: Integer;
	skipCount		: Integer;
	errorSet 		: CM_ErrorSet;
	progressTS 		: TimeStamp;
	newStatus 		: Integer;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	create errorSet transient;
	
	todo := self.allEDITrackedItems.size;
	done := null;
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	foreach ediTI in self.allEDITrackedItems do
		_passport.warningsAcknowledged := true;
		app.setContinueCMExceptions(true);
		_passport.setWarningsIgnored(true);
		
		beginLoad;
		ediVGMTI := ediTI.CM_EDIVGMTI;
	
		done := done + 1;
		self.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		if ediVGMTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			skipCount := skipCount + 1;
			continue;
		endif;
		if ediVGMTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or ediVGMTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then		//cnwmc5 - 4 Sep 2015 - PAR 36764
			if ediVGMTI.id.trimBlanks = null then
				app.raiseCMException2(ERR_FIELD_ID, ediVGMTI.id, 'ID', ETRow_Id, ediVGMTI);
			endif;
			realCargoItem := terminal.allOnsiteTIsByCargoTypeId[ediVGMTI.cargoType, ediVGMTI.id];
			if realCargoItem = null then
				realCargoItem := terminal.allNotifiedTIsByCargoTypeId[ediVGMTI.cargoType, ediVGMTI.id];
			endif;
			if realCargoItem = null then
				app.raiseCMException2(ERR_FIELD_ID, ediVGMTI.id, 'ID', ETRow_Id, ediVGMTI);
			else
				if realCargoItem.isEmpty then
					app.raiseCMException5(ERR_NotFull, ediVGMTI.id, null, ediVGMTI.id, realCargoItem.commodity, null, ETRow_Commodity, ediVGMTI);
				endif;
				pxyCargoItem := realCargoItem.pxyCreateUpdateProxy();
				ediVGMTI.setVGMProxy(pxyCargoItem);
				app.myTrxUA.trxUpdateEDIVGMTI(_verifyOnly, ediVGMTI, pxyCargoItem, _passport);
			endif;
		else
			app.raiseCMException1(EDI_Action_Is_Invalid, ediVGMTI.messageMode, ETRow_MessageMode, null);
		endif;
		_passport.moveErrorsToSet(errorSet);
		endLoad;
		delete pxyCargoItem;
	endforeach;
	
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	newStatus := self.getStatusFromEDITrackedItems(false); 

	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);
epilog
	endLoad;
	if _verifyOnly then
		errorSet.purge;	//clear out the errors
	endif;
	delete errorSet;
end;</source>
        <access>protected</access>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateEdiTI" id="41cb62d5-bef9-4b36-b5c2-1305fe97e922">
        <source>validateEdiTI(_ediVGMTI : CM_EDIVGMTI; _terminal : CM_Terminal; _passport: CM_Passport io) protected;
//
//19 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	action : String;
	foundTi : CM_TrackedItem;
	prxyTi : CM_TrackedItem;
	ediVGMTI : CM_EDIVGMTI;
	valUpdateCntrl : CMIF_TIUpdateController;
	newStatus : Integer;
//	errorSet : CM_ErrorSet;
begin
	app.setContinueCMExceptions(true);		// get as many error messages in 1 go as possible
	ediVGMTI := _ediVGMTI;				// to reduce dereferencing set a local variable
	// check that the action is valid
	action := ediVGMTI.messageMode;
	
	if action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD and
	   action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
//	   action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
		app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, ediVGMTI);
//		return;
	endif;
	
	// find ti
	foundTi	:= _terminal.lookupTrackedItem(ediVGMTI.id, ediVGMTI.cargoType, null, null, false);
	
/*	if action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			app.raiseCMException1(Delete_Ti_Does_Not_Exists,
									ediVGMTI.id,
									TrackedItem,
									ediVGMTI);
		return;
	endif;*/
	
	// now an action of Add or Update are treated as if it is the "correct" one
	// ie we do not care what action the user entered we only care if the train exists or not.
	if foundTi = null then
		app.raiseCMException3(CargoItemNotFound, ediVGMTI.cargoTypeDescr, ediVGMTI.id, '', null, ediVGMTI);
//		return;
	else
		//epr TFS 1816 9/6/16
		if foundTi.myVoyage &lt;&gt; null then
			self.checkEDICutoff (foundTi.voyageCode, foundTi.operatorCode, ediVGMTI);
		endif;
		
		prxyTi := app.createUpdateProxy(foundTi).CM_TrackedItem;
		valUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, ediVGMTI);
		ediVGMTI.setVGMProxy(prxyTi);
		app.myValUA.valTrackedItem(prxyTi, valUpdateCntrl, app.myPassport);
	endif;
	if _passport.hasErrors() then
		newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS; 
	elseif _passport.hasWarnings() then
		newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS; 
	else
		newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED; 
	endif;
//	_passport.moveErrorsToSet(errorSet);
	if newStatus &lt;&gt; ediVGMTI.status then
		app.myTrxUA.trxUpdateEDITIStatus(ediVGMTI, newStatus, _passport);
	endif;
epilog
	delete prxyTi;
	delete valUpdateCntrl;
end;</source>
        <access>protected</access>
        <Parameter name="_ediVGMTI" type="CM_EDIVGMTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="1dfb5394-3dd4-44ce-9159-0272be4193fb">
        <updating/>
        <source>verifyAll() updating;
//
//15 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	errorCount, newStatus,
	oldStatus				: Integer;
	str						: String;
begin 
	// need to decide whether we want to reset to verifying if old status was partially loaded?
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_VERIFYING); 

	app.myPassport.clearErrorsWarnings();
	
	errorCount := self.verifyEDIData();
	
	if errorCount = 0 then
		str := self.class.name &amp; " " &amp; method.qualifiedName;
		
		self.cnStartTransaction(str[1:50]);
		
		errorCount := self.verifyEDIDataTIs(app.myPassport);
	endif;
	
	// it is possible at this point that we have had a fatal error which stops the entire file
	// being processed
	oldStatus := self.status;
	
	if oldStatus = CM_EDIFile.EDI_STATUS_FATAL_ERRORS then 
//		oldStatus = CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X then
		newStatus := oldStatus;
	else
		newStatus := self.getStatusFromEDITrackedItems(true); 
	endif;
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);		
epilog
	if str &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="1f6d3133-0c07-43c4-abce-cfb1464d7dc3">
