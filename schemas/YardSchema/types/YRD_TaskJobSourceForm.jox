        <updating/>
        <source>txtCargoIDs_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		06 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if not self.canSourcesBeRemoved and self.initialTiTextList &lt;&gt; null then
		if keyCode = J_key_Back then
			if txtCargoIDs.selStart &lt;= self.initialTiTextListLength then
				keyCode := null;
			endif;
		else
			if txtCargoIDs.selStart &lt; self.initialTiTextListLength then
				keyCode := null;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
