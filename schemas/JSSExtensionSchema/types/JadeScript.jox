    <JadeMethod name="findPossibleTransLeaksOneCls" id="11848c12-fc67-4575-8509-ad76357c63e8">
        <source>findPossibleTransLeaksOneCls();
// --------------------------------------------------------------------------------
// Created:		23 August 2002 by cnwkpd1
//
// Purpose:		This method will scan through the meta schema data looking for
//				methods which create transient instances of a given class, and also
//				highlight if the instances do not appear to be being deleted.
//
//				Simply change the SchemaToCheck and ClassToCheck constants to the 
//				appropriate class, and execute.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SCHEMA_TO_CHECK	: String = "JSSExtensionSchema";

vars
	theSchema			: Schema;
	theClass			: Class;
	allSchemaClasses	: ClassColl;
	 
begin
	theSchema	:=	rootSchema.getSchema(SCHEMA_TO_CHECK);
	
	if theSchema = null then
		theSchema	:=	currentSchema;
	endif;
	
	write "&lt;&lt;&lt; Checking transients in schema: " &amp; theSchema.name &amp; " &gt;&gt;&gt;";
	allSchemaClasses	:=	theSchema.allClasses();
	
	foreach theClass in allSchemaClasses do
		if (not theClass.isSystemObject)
		and theClass.schema = theSchema
		then
			write "- Checking transients in class: " &amp; theClass.name;
			self.findPossibleTransientLeaks(theClass);
		endif;
	endforeach;
	
	write "&lt;&lt;&lt; Finished checking for undeleted transients &gt;&gt;&gt;";
end;</source>
    </JadeMethod>
    <JadeMethod name="findPossibleTransientLeaks" id="7874f47e-472d-4dae-b16b-d41375e6ab0e">
        <source>findPossibleTransientLeaks(pTheClass : Class);
// --------------------------------------------------------------------------------
// Created:		23 August 2002 by cnwkpd1
//
// Purpose:		This method will scan through the meta schema data looking for
//				methods which create transient instances of a given class, and also
//				highlight if the instances do not appear to be being deleted.
//
// Parameters:	None
//
// Returns:		pTheClass - The class to scan.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allTypeUsages		: TypeUsageSet;
	theReference		: TypeUsage;
	theIterator			: Iterator;
	message				: String;
	methodName			: String;
	methodSource		: String;
	variableName		: String;
	theScript			: Script;
	counter				: Integer;
	allTokens			: HugeStringArray;
	token				: String;
	isCreated			: Boolean;
	isDeleted			: Boolean;
	isDeletedInEpilog	: Boolean;
	isInEpilog			: Boolean;
 
begin
	if pTheClass = null then
		return;
	endif;
	
	// Get all the references to the named class.
	allTypeUsages	:=	pTheClass.getPropertyValue("scriptRefs").TypeUsageSet;
 
	// Look for all usages of this class as a local variable.
	theIterator	:=	allTypeUsages.createIterator();
	
	while theIterator.next(theReference) do
		if theReference.isKindOf(JadeLocalVar) then
			// Get details of local variable name and method source.
			variableName	:=	theReference.name;
			theScript		:=	theReference.schemaScript;
			methodName		:=	theScript.schemaType.name &amp; "::" &amp; theScript.name;
			methodSource	:=	theScript.getSource();
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");

 			// Break method source into tokens.
			allTokens	:=	methodSource.getHugeTokens();

			isInEpilog			:=	false;
			isCreated			:=	false;
			isDeleted			:=	false;
			isDeletedInEpilog	:=	false;

			counter	:=	1;	
			
			while counter &lt;= allTokens.size() do
				token	:=	allTokens[counter];
				
				if token = "epilog" then
					isInEpilog	:=	true;
					
				elseif token = "create" then
					if allTokens[counter + 1] = variableName
					and allTokens[counter + 2] &lt;&gt; "persistent"
					and (pTheClass.transient
					or allTokens[counter + 2] = "transient")
					then
						isCreated	:=	true;
					endif;
					
					counter	:=	counter + 1;		// skip next token.
					
				elseif token = "delete" then
					if allTokens[counter + 1] = variableName then
						isDeleted	:=	true;
						
						if isInEpilog then
							isDeletedInEpilog	:=	true;
						endif;
					endif;
					
					counter	:=	counter + 1;		// skip next token.
				endif;
				
				counter	:=	counter + 1;
			endwhile;

   			if isCreated then
				message	:=	"     " &amp; methodName &amp; " - local variable " &amp; variableName &amp; " created";
				
				if (not isDeleted) then
					message			:=	message &amp; " but not deleted";
					message[1:4]	:=	"****";
				else
					if isDeletedInEpilog then
						message	:=	message &amp; ", deleted in epilog";
					else
						message			:=	message &amp; ", should be deleted in epilog";
						message[1:2]	:=	"--";
					endif;
				endif;
				
				write message;
			endif;

			delete allTokens;    
		endif;
	endwhile;
epilog
	delete theIterator;
	delete allTokens;
end;</source>
        <Parameter name="pTheClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="test_Alert_Sounds" id="13bd498e-b409-4ef4-bcc4-eba716d60e29">
