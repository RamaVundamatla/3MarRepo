    <JadeMethod name="setComboValues" id="21e40b13-a8c2-4e99-bfda-e1e48665b02f">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars
	ta : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	iter : Iterator;
begin

	_combo.clear;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	foreach ta in tmpTerm.allTerminalAreas discreteLock do
		_combo.itemObject[_combo.addItem(ta.id)] := ta;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="f3e8829e-bc4f-43db-9901-6eb80a85bc8f">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars
	ta : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	iter : Iterator;
	selectionValue	: Boolean;
begin

	_tbl.rows := _tbl.fixedRows;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	foreach ta in tmpTerm.allTerminalAreas discreteLock do
		
		selectionValue := false;
		if _operator &lt;&gt; null then
			if _operator &lt;&gt; null and 
			   _operator.CM_QStringIsOneOf.allSelectionValues.includes(ta.id) then
				selectionValue := true;
			endif;
			
			_tbl.accessRow(_tbl.addItem(selectionValue.cnEcGetTableCheckBoxValue &amp; Tab &amp; ta.id)).itemObject := ta;
		endif;
		
		if _tbl.rows &gt;= JadeTableRowLimit then		
			break;
		endif;
			
	endforeach;
	
	if _tbl.rows &gt;= JadeTableRowLimit then		
		app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="3fc2236b-e7ac-4e95-b7b8-d6a0ad3eb66b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	str : String;
	numRows : Integer;
	idx : Integer;
	ta : CM_TerminalArea;
	taStrArray : StringArray;  

begin

	create taStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			ta := _tbl.accessRow(idx).itemObject.CM_TerminalArea;
			taStrArray.add(ta.id);
		endif;
	endforeach;
	
	_op.setSearchValue(taStrArray);

epilog

	delete taStrArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="a8d70f2e-d191-4268-83d5-ffa57ad9ba00">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ta : CM_TerminalArea;

begin
	if _value.isKindOf(CM_TerminalArea) then	
		if _value &lt;&gt; null then
			ta := _value.CM_TerminalArea;
			return ta.id;
		else
			return null;
		endif;
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e2b05273-2f22-4dc0-aff1-04ffed54a884">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	invalidObj 		: Boolean;
	object			: CM_TerminalArea;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		elseif _value.isKindOf(CM_TerminalArea) then
			object := _value.CM_TerminalArea;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
		
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.id;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="282b0802-9326-442e-99cf-acf7c4ebd95c">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS	TFS 50906

*/

vars
	pos : Integer;

begin
	if _value.isKindOf(CM_TerminalArea) then
		return _value.CM_TerminalArea.id;
	elseif _value.isKindOf(String) then
		pos := _value.String.pos(Space, 1);
		if pos &lt;&gt; null then
			return _value.String[1:pos-1];
		else
			return _value.String;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
