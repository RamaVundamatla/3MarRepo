    <JadeMethod name="doClearAutoMovements" id="b6db5021-9c96-4753-bf51-89aab08e7c83">
        <source>doClearAutoMovements();
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

begin
	self.txtMinsOffset.text := "0";
	self.cmbDischargeTAType.clear();
	self.cmbDischargeTA.clear();
	self.cmbDischargeLC.clear();
	self.cmbVoyageDateType.clear();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="621717bd-184a-4ee0-9705-4ddfd1ed3253">
        <updating/>
        <source>doDelete() updating;
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

begin
	if self.fldDetails.topSheet = self.shtMovements
	or self.fldDetails.topSheet = self.shtClosure then
		self.doDeleteAutoMovements();
	elseif self.fldDetails.topSheet = self.shtComparison then // ### TFS CR 64614 TASK 64642 18JUL2024 NAVAB1
		self.doDeleteAutoComparison();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteAutoComparison" id="ed033056-d389-4246-946a-1c58972bf06d">
        <updating/>
        <source>doDeleteAutoComparison() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64614 TASK 64642
*/

vars
	realAM : CM_EDIComparisonConfig;
	theReturn : Integer;
begin
	realAM := self.myTerminal.myEDIComparisonConfig;
	if realAM = null then
		return;
	endif;
		
	while true do
		app.myTrxDA.trxDeleteEDICompCon(realAM, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			
			self.doClearAutoComparison();
			
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("EDI Auto Comparison", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteAutoMovements" id="7e9d1aa8-8d8f-41be-a34f-75a4e117b661">
        <updating/>
        <source>doDeleteAutoMovements() updating;
/*
Purpose:					

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	realAM : CM_EDIAutoMovements;
	theReturn : Integer;
begin
	realAM := self.myTerminal.myEDIAutoMove;
	if realAM = null then
		return;
	endif;
		
	while true do
		app.myTrxDA.trxDeleteEDIAutoMove(realAM, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			
			self.doClearAutoMovements();
			
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("EDI Auto Movements", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayAutoCompData" id="43533d67-e8cb-4a42-9554-69bee0216a14">
        <source>doDisplayAutoCompData();
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64642
*/

vars
	autoComp : CM_EDIComparisonConfig;
begin
	autoComp := self.myTerminal.myEDIComparisonConfig;
	
	if autoComp &lt;&gt; null then
		self.chkDoAutoComp.value := autoComp.doAutoComparison;
		self.setupCompFieldsDB(autoComp);

		if autoComp.myEmailTemplate &lt;&gt; null then
			self.lblEmail.caption := "Email has been set";
		else
			self.lblEmail.caption := "No email has been set";
			
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayAutoData" id="603c4df3-4217-437a-8d97-756875139ba7">
        <source>doDisplayAutoData();
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	autoMove : CM_EDIAutoMovements;
	lc : CM_LocationsController;
	invalid : Boolean;
	voyageStatus : CM_VoyageStatus;
begin
	on Exception do app.handleDeletedObject(exception, voyageStatus, invalid);

	
	autoMove := self.myTerminal.myEDIAutoMove;
	if autoMove &lt;&gt; null then
		self.txtMinsOffset.text := autoMove.minutesOffset.String;
		
		lc := autoMove.myTranshipDischargeLC;
		if lc &lt;&gt; null then
			
			self.cmbDischargeTAType.listObject := lc.myTerminalArea.myType;
			self.cmbDischargeTAType.lostFocus(self.cmbDischargeTAType);
			self.cmbDischargeTA.listObject := lc.myTerminalArea;
			self.cmbDischargeTA.lostFocus(self.cmbDischargeTA);
		
			self.cmbDischargeLC.listObject := lc;
		
		endif;
		self.cmbVoyageDateType.text := autoMove.getVoyageDateTypeStr(autoMove.voyageDateType);
		
		 // ### TFS CR 64616 TASK 64652 16JUL2024 NAVAB1
		 voyageStatus := autoMove.myVoyageStatusForClosure;
		if voyageStatus &lt;&gt; null then
			self.cmbVoyageStatus.text := voyageStatus.description;
			if invalid then
				self.cmbVoyageStatus.listIndex := -1;
			endif;
		endif;
	else
		self.txtMinsOffset.text := "0";
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="eb49d071-4f3b-40e6-9b08-eb891ab0e495">
        <updating/>
        <source>doSave() updating;
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

begin
	if self.fldDetails.topSheet = self.shtMovements 
	or self.fldDetails.topSheet = self.shtClosure	then // ### TFS CR 64616 TASK 64652 16JUL2024 NAVAB1
		self.doSaveAutoMovements();
	else
		self.doSaveAutoComparison(); // ### TFS CR 64614 TASK 64642 17JUL2024 NAVAB1
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAutoComparison" id="66869bb2-3ea9-449c-ab34-97be81763312">
        <updating/>
        <source>doSaveAutoComparison() updating;
/*
Purpose:					

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64642
12 Feb 2025		navtr3	NSW| Auto Voyage Configuration screen - Issue with save
*/

vars
	pxyAM, realAM : CM_EDIComparisonConfig;
	theReturn : Integer;
	titleStr : String;
	ignoreFields, compFields	: StringArray;

begin

	if self.myTerminal.myEDIComparisonConfig = null then
		create pxyAM transient;
	
	else
		pxyAM := app.createUpdateProxy(self.myTerminal.myEDIComparisonConfig).CM_EDIComparisonConfig;
		if self.myProxyEmailTemplate = null then
			self.myProxyEmailTemplate := app.createUpdateProxy( self.myTerminal.myEDIComparisonConfig.myEmailTemplate).CM_EmailTemplate;
		endif;
	
	endif;
	
	//Clears the right filter list and prepares actual ignore list before saving
	self.msgCompFields.clearRightFilter(); //12.02.2025 navtr3 #33972
	
	create ignoreFields transient;
	create compFields transient;
	self.getCompFields(compFields, ignoreFields);
		
	pxyAM.setProxy(self.myTerminal, self.myProxyEmailTemplate, self.chkDoAutoComp.value, compFields, ignoreFields  );
		
		
	while true do
		if self.myTerminal.myEDIComparisonConfig = null then
			app.myTrxCA.trxCreateEDICompCon(pxyAM, realAM, app.myPassport);
		else
			app.myTrxUA.trxUpdateEDICompCon(pxyAM, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("EDI Auto Comparison", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;		
	
epilog
	delete pxyAM;
	self.myProxyEmailTemplate := null; // deletimg the proxy config will delete the proxy email template
	delete compFields;
	delete ignoreFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAutoMovements" id="8a3e74a2-6b09-467d-98a5-400b92886fd2">
        <updating/>
        <source>doSaveAutoMovements() updating;
/*
Purpose:					

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	pxyAM, realAM : CM_EDIAutoMovements;
	theReturn : Integer;
	titleStr : String;
begin
	 // ### TFS CR 64616 TASK 64652 16JUL2024 NAVAB1
	 titleStr := "EDI Auto";
	if self.fldDetails.topSheet = self.shtMovements then
		titleStr := "EDI Auto Movements";
	elseif self.fldDetails.topSheet = self.shtClosure	then 
		titleStr := "EDI Auto Voyage Completion";
	endif;
	
	if self.myTerminal.myEDIAutoMove = null then
		create pxyAM transient;
	
	else
		pxyAM := app.createUpdateProxy(self.myTerminal.myEDIAutoMove).CM_EDIAutoMovements;
	
	endif;
		
	pxyAM.setProxy(self.myTerminal, self.txtMinsOffset.text.Integer, self.cmbVoyageDateType.listData, self.cmbDischargeLC.listObject.CM_LocationsController, self.cmbVoyageStatus.listObject.CM_VoyageStatus  );
		
		
	while true do
		if self.myTerminal.myEDIAutoMove = null then
			app.myTrxCA.trxCreateEDIAutoMove(pxyAM, realAM, app.myPassport);
		else
			app.myTrxUA.trxUpdateEDIAutoMove(pxyAM, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(titleStr, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;		
	
epilog
	delete pxyAM;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowAudits" id="80f6401d-087a-46ed-b6a5-b4b1d46fb38d">
        <source>doShowAudits();
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

	autoMove : CM_EDIAutoMovements;
	autoComp : CM_EDIComparisonConfig;
begin
	if self.fldDetails.topSheet = self.shtMovements 
	or self.fldDetails.topSheet = self.shtClosure	then // ### TFS CR 64616 TASK 64652 16JUL2024 NAVAB1
		autoMove := self.myTerminal.myEDIAutoMove;
		if autoMove = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		app.viewAuditFormModal(autoMove, self.myAssistant.class, self.myTerminal);
	elseif self.fldDetails.topSheet = self.shtComparison then
		autoComp := self.myTerminal.myEDIComparisonConfig;
		if autoComp = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		app.viewAuditFormModal(autoComp, self.myAssistant.class, self.myTerminal);
	
	else
		global.beep;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="46ccfaa2-9003-4f1c-8f43-069cef4a45b0">
        <updating/>
        <source>doShowEmailForm() updating;
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	form : SHP_AutoVoyageConfig;
	issue : CM_EDIComparisonConfig;
	emailAdding : Boolean;
	modalResult : Integer;
begin
	form := self;
	issue := self.myTerminal.myEDIComparisonConfig;
	
	if issue = null then
		create self.myProxyEmailTemplate transient;
	else
		delete self.myProxyEmailTemplate;
		self.myProxyEmailTemplate := app.createUpdateProxy( issue.myEmailTemplate).CM_EmailTemplate;
	endif;
	
	self.emailChanged := false;

	modalResult := form.myAssistant.showEDIEmailOptions(self.myProxyEmailTemplate, false);
	
	if modalResult = IDOK then
		self.emailChanged := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCompDescForKey" id="19913ba3-1cda-4456-a5e2-47eb3e19c596">
        <source>getCompDescForKey(_key : String) : CM_StateString;
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64642
*/

vars
	str, grop : String;
	strState : CM_StateString;
begin

	foreach strState in self.allComparisonFieldsObjects as CM_StateString do
		if strState.key = _key then
			return strState;
		endif;
	endforeach;


epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="CM_StateString"/>
    </JadeMethod>
    <JadeMethod name="getCompFieldForMSG" id="956959bb-46cd-4d13-b1c3-ac45733f6812">
        <updating/>
        <source>getCompFieldForMSG(_row, _grp : String) updating;
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64642
*/

vars
	str : String;
		compItem : CM_StateString; //CM_Association;
begin
	str := app.getEntTableRowTranslation(_row, _grp);
	create compItem transient;
	compItem.set(_row, str, null);
	self.allComparisonFieldsObjects.add(compItem);

epilog

end;</source>
        <Parameter name="_row" type="String"/>
        <Parameter name="_grp" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCompFields" id="3e1a1a26-cdf0-4811-a4b6-e752372c6e2a">
        <source>getCompFields(_compFields : StringArray input; _ignoreFields : StringArray input);
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO - CR 64614 TASK 64642
*/

vars
	objSet : ObjectSet;
	obj : Object;
	int : Integer;
	str : String;
begin
	create objSet transient;
	self.msgCompFields.getSelected(objSet);
	foreach obj in objSet do
	
		str := obj.CM_StateString.key;
		//_compFields.add(str);							//navra1 - MTN-33038 - 14th Oct 2024
		_ignoreFields.add(str);							//navra1 - MTN-33038 - 14th Oct 2024
	endforeach;
	
	objSet.clear();
	self.msgCompFields.getAvailable(objSet);
	foreach obj in objSet do
	
		str := obj.CM_StateString.key;
		//_ignoreFields.add(str);						//navra1 - MTN-33038 - 14th Oct 2024
		_compFields.add(str);							//navra1 - MTN-33038 - 14th Oct 2024
	endforeach;
end;</source>
        <Parameter name="_compFields" type="StringArray" usage="input"/>
        <Parameter name="_ignoreFields" type="StringArray" usage="input"/>
    </JadeMethod>
