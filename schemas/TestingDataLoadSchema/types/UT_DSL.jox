    <JadeMethod name="ediLoad" id="8ca0efab-e6b8-40de-982f-5f06f55da911">
        <source>ediLoad(_text: String; _fileType: Integer; _userDefinedName: String): CM_EDIFile;
//17 December 2008	cnwdw1	
//
/*

Date		Who		Reason
25 Feb 2009	cnwkpd1	7.7.1 release - reworked to remove reference to CardSchema method
22 Mar 2012	cnwrs1	Par 29295 allow CSV and XML files to come thru un defined
09 Oct 2014	cnwkpd1	Tidy up temporary files from bin directory

*/

vars
	loadFile: File;
	fileName: String;
	fileType : Integer;
	ediFile	: CM_EDIFile;
begin
	fileType := _fileType;
	if fileType = EDIFileType_Unknown then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".edi";
	elseif _fileType = EDIFileType_CSV then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".csv";
		fileType := EDIFileType_Unknown;
	elseif _fileType = EDIFileType_XML then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".xml";
		fileType := EDIFileType_Unknown;
	else
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".csv";
	endif;
	
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	//return self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);
	ediFile := self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);				// 08/04/2013 cnwmh5
	/////self.assertNoTrxErrorsOrWarnings();
	
	// Physically delete the temporary file
	on FileException do xHandleFileException(exception, fileName);
	loadFile.purge();
	
	return ediFile;
	
epilog
	delete loadFile;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadFile" id="831ea72d-9ce3-4156-ab7f-4bc0119124da">
        <source>ediLoadFile(_fileName: String; _fileType: Integer; _userDefinedName: String): CM_EDIFile protected;
//17 December 2008	cnwdw1	
//
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	ediAgent: CM_EDIControllerAgent;
	ediFile: CM_EDIFile;
	ediFileType : CM_EDIFileType;
	loadFile: File;
	expectErrors : Boolean;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.fileName := _fileName;

	ediFileType := app.myRoot.allEDIFileTypes[_fileType, _userDefinedName];
	if ediFileType = null then
		ediFileType := app.myRoot.allEDIFileTypeUsersByName[_userDefinedName];
	endif;
	ediFile := ediAgent.loadAndProcessFileForTerminal(loadFile,  ediFileType, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	return ediFile;
epilog
	delete ediAgent;
	delete loadFile;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadFileName" id="89380c5d-cd4a-48b6-9fac-de18b806efc7">
        <source>ediLoadFileName(_text: String; _fileType: Integer; _userDefinedName, _fileName: String): CM_EDIFile;
//17 December 2008	cnwdw1	
//
/*

Date		Who		Reason
25 Feb 2009	cnwkpd1	7.7.1 release - reworked to remove reference to CardSchema method
22 Mar 2012	cnwrs1	Par 29295 allow CSV and XML files to come thru un defined
09 Oct 2014	cnwkpd1	Tidy up temporary files from bin directory

*/

vars
	loadFile: File;
	fileName: String;
	fileType : Integer;
	ediFile	: CM_EDIFile;
begin
	fileType := _fileType;
	if fileType = EDIFileType_Unknown then
		fileName := "EDI_LOAD " &amp; _fileName &amp; ".edi";
	elseif _fileType = EDIFileType_CSV then
		fileName := "EDI_LOAD " &amp; _fileName &amp; ".csv";
		fileType := EDIFileType_Unknown;
	elseif _fileType = EDIFileType_XML then
		fileName := "EDI_LOAD " &amp; _fileName &amp; ".xml";
		fileType := EDIFileType_Unknown;
	else
		fileName := "EDI_LOAD " &amp; _fileName &amp; ".csv";
	endif;
	
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	//return self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);
	ediFile := self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);				// 08/04/2013 cnwmh5
	/////self.assertNoTrxErrorsOrWarnings();
	
	// Physically delete the temporary file
	on FileException do xHandleFileException(exception, fileName);
	loadFile.purge();
	
	return ediFile;
	
epilog
	delete loadFile;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadVerifyDBLoadActualBasic" id="b40cca3a-c29f-4c4f-ac1c-be17384599de">
        <source>ediLoadVerifyDBLoadActualBasic(_ediText, _userDefinedName, _fileName: String; _ediFileType: Integer; _verify: Boolean; _dbLoad: Boolean; _makeActual: Boolean; _makeActualWithMerge: Boolean; _ediFile: CM_EDIFile): CM_EDIFile protected;
/*

Purpose:		Load edi file, verify it, db load it and or make actual	
				Currently doesn't handle assertIsOneOf

Date			Who		Reason
13/02/2013		cnwmh5	Initial creation

*/

vars
	
	ediFile 			: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	
	tempStr				: String;
	
begin

	//  now load the extracted details into voyage3
	//create ediControllerAgent transient;
	//ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276

	// maybe doing these things one a time and don't need to load the edi file again
	if _ediFile &lt;&gt; null then
		ediFile := _ediFile;
	endif;	
	
	if ediFile = null then
		ediFile := self.ediLoadFileName(_ediText, _ediFileType, _userDefinedName, _fileName);		
		self.assertNotNull(ediFile);
	endif;
	
	if _verify then
		self.ediVerify(ediFile);
		tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	endif;
	
	if _dbLoad then
		self.ediDBLoad(ediFile);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	endif;

	if _makeActual then
		self.ediMakeActual(ediFile);
		tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);
	endif;
	
	if _makeActualWithMerge then
		self.ediMakeActualWithMerge(ediFile);
		tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);
	endif;
	
	/////self.assertNoTrxErrorsOrWarnings();					// 08/04/2013 cnwmh5	
	
	return ediFile;

epilog

	//delete ediControllerAgent;

end;</source>
        <access>protected</access>
        <Parameter name="_ediText" type="String"/>
        <Parameter name="_userDefinedName" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_ediFileType" type="Integer"/>
        <Parameter name="_verify" type="Boolean"/>
        <Parameter name="_dbLoad" type="Boolean"/>
        <Parameter name="_makeActual" type="Boolean"/>
        <Parameter name="_makeActualWithMerge" type="Boolean"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadVerifyDBLoadActualSetup" id="ac2db1cc-2295-4ac9-971f-1715d31ee358">
        <source>ediLoadVerifyDBLoadActualSetup(_ediText, _userDefinedName, _fileName: String; _ediFileType: Integer; _verify: Boolean; _dbLoad: Boolean; _makeActual: Boolean; _makeActualWithMerge: Boolean; _ediFile: CM_EDIFile): CM_EDIFile;
/*


Date			Who		Reason
07/08/2018		jlgmh5	Initial creation

*/

vars
	
	ediFile 			: CM_EDIFile;
	
	
begin

	ediFile:= self.ediLoadVerifyDBLoadActualBasic(_ediText, _userDefinedName, _fileName, _ediFileType, _verify, _dbLoad,
		_makeActual, _makeActualWithMerge, _ediFile);

	
	return ediFile;

epilog

end;</source>
