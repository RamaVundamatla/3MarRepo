    <JadeMethod name="createUsedComponent" id="f65e3df4-901f-40c9-acce-45590ce4e254">
        <source>createUsedComponent(pTheComponent:JSSLKComponent):JSSLKUsedComponent;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Creates a Used Component object to map a Component to a Customer.
//
// Parameters:	pTheComponent - The Component to map to a Customer.
//
// Returns:		A reference to the newly created Used Component object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedComponent	: JSSLKUsedComponent;
	
begin
	theUsedComponent	:=	self.allUsedComponents[pTheComponent];
	
	if theUsedComponent = null then
		create theUsedComponent;
		theUsedComponent.updateMe(pTheComponent, self);
	endif;
	
	return theUsedComponent;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent"/>
        <ReturnType type="JSSLKUsedComponent"/>
    </JadeMethod>
    <JadeMethod name="generateLicenseKey" id="c7d88b1a-355f-42de-9039-2b7509a65a6a">
        <updating/>
        <source>generateLicenseKey() updating;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Generates a license key for the Product/Customer combination.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theKey				: JSSLKey;
	allOptions			: BooleanArray;
	theUsedComponent	: JSSLKUsedComponent;
	highestId			: Integer;
	componentId			: Integer;
	
begin
	highestId	:=	self.myProduct.getHighestComponentId();
	create allOptions transient;
	
	foreach componentId in 1 to highestId do
		allOptions.atPut(componentId, false);
	endforeach;
	
	create theKey transient;
	
	foreach theUsedComponent in self.allUsedComponents do
		componentId	:=	theUsedComponent.myComponent.componentId;
		
		allOptions.replace(componentId, true);
	endforeach;
	
	if theKey.generateKey(self.myCustomer.customerName, self.myProduct.productCode, self.expiryDate, allOptions ) then
		self.licenseKey	:=	theKey.data1;
	endif;
epilog
	delete theKey;
	delete allOptions;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="5eb79eb6-13af-4a03-b58d-9ba9dfbaa52b">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Returns a string to use for the GUI interface to display the receiver's
//				details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: String;
	
begin
	returnValue	:=	self.myProduct.productName &amp; " " &amp; self.myProduct.productVersion;
	
	if self.expiryDate = null then
		returnValue	:=	returnValue &amp; " (Never expires)";
	else
		returnValue	:=	returnValue &amp; " (Expires " &amp; self.expiryDate.shortFormat() &amp; ")";
	endif;
epilog
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductName" id="1f25dcce-c3ea-4b04-946c-1183bb0004fb">
        <source>getProductName():String;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Returns the name of the Product that is mapped to a Customer.
//
// Parameters:	None
//
// Returns:		The Product name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myProduct.productName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isExpired" id="43c7bc1c-b72a-43f8-8359-96ff22bf8fc5">
        <source>isExpired():Boolean;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the license key has
//				expired.
//
// Parameters:	None
//
// Returns:		True if the Product license has expired, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentDate	: Date;
	
begin
	currentDate	:=	app.actualTimeServer().date();
	
	if self.expiryDate = null then
		return false;
	else
		return (self.expiryDate &lt; currentDate);
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensed" id="06020537-94ea-4f7e-96a1-91af50dfb0bb">
        <source>isLicensed():Boolean;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a license key has been
//				generated for the Product/Customer combination.
//
// Parameters:	None
//
// Returns:		True if the license key has been generated, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.licenseKey &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExpiryDate" id="cd2cfd0c-20e3-4505-8faf-83a0593a250e">
        <updating/>
        <source>setExpiryDate(pExpiryDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Sets the expiry date of the Product license.
//
// Parameters:	pExpiryDate - The expiry date of the Product license.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.expiryDate &lt;&gt; pExpiryDate then
		self.expiryDate	:=	pExpiryDate;
	endif;
end;</source>
        <Parameter name="pExpiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="e4c1baec-7220-49e8-86da-0a4f194b9640">
        <updating/>
        <source>updateMe(pTheProduct:JSSLKProduct; pExpiryDate:Date; pTheCustomer:JSSLKCustomer) updating;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pTheProduct - The Product that is being mapped to a Company.
//				pExpiryDate - The expiry date of the Product license.
//				pTheCustomer - The customer which the Product is being mapped to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateMe(pTheProduct, pExpiryDate, pTheCustomer) then
		// Update general properties and references.
		
		if self.expiryDate &lt;&gt; pExpiryDate then
			self.expiryDate	:=	pExpiryDate;
		endif;
		
		// Update any key properties and references.
		
		if self.myProduct &lt;&gt; pTheProduct then
			self.myProduct	:=	pTheProduct;
		endif;
		
		// Update inverse references.
		
		if self.myCustomer &lt;&gt; pTheCustomer then
			self.myCustomer	:=	pTheCustomer;
		endif;
	endif;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
        <Parameter name="pExpiryDate" type="Date"/>
        <Parameter name="pTheCustomer" type="JSSLKCustomer"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a3791dde-6e1a-416f-9352-dcc11879f901">
        <source>validateMe(pTheProduct:JSSLKProduct; pExpiryDate:Date; pTheCustomer:JSSLKCustomer):Boolean;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Validates the receiver's properties.
//
// Parameters:	pTheProduct - The Product that is being mapped to a Company.
//				pExpiryDate - The expiry date of the Product license.
//				pTheCustomer - The customer which the Product is being mapped to.
//
// Returns:		True if the data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
        <Parameter name="pExpiryDate" type="Date"/>
        <Parameter name="pTheCustomer" type="JSSLKCustomer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
