    <JadeMethod name="initialize" id="4265bd91-9b95-4117-b715-5bc8569cea01">
        <updating/>
        <source>initialize(_oid 			: String;
		   _updateAction	: Character;
		   _updateType      : String;
		   _myObject        : Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars

begin
	self.oid				:= _oid;
	self.updateAction  		:= _updateAction;
	self.updateTimeStamp    := app.actualTimeServer();
	self.updateType         := _updateType;
	
	if _myObject.isKindOf(CM_Object) then
		self.myTerminal := _myObject.CM_Object.getMyTerminal();
	endif;
	
	if _updateAction  &lt;&gt; BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.myObject       := _myObject.Object;
	endif;
	
epilog

end;</source>
        <Parameter name="_oid" type="String"/>
        <Parameter name="_updateAction" type="Character"/>
        <Parameter name="_updateType" type="String"/>
        <Parameter name="_myObject" type="Any"/>
    </JadeMethod>
</Class>
