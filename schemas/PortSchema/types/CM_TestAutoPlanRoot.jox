    <JadeMethod name="doTestAutoPlan" id="b50db2d2-3d5c-40aa-a44d-babb7f400165">
        <source>doTestAutoPlan( _tblSelected : Table input;
				_alternateSelection : ObjectArray input;
				_terminal : CM_Terminal;
				_terminalArea : CM_TerminalArea;
				_clearResults : Boolean
				);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	ti : CM_TrackedItem;
	tiArray : ObjectArray;
	startRow : Integer;
	endRow : Integer;
	row : Integer;
	msg : String;
	size : String;
	success : Integer;
	failed : Integer;
	result : CM_TestAutoPlanResult;

begin

	if not self.allTestAutoPlanResults.isEmpty and _clearResults then
		// clear out all existing data.
		self.allTestAutoPlanResults.purge();
	endif;

	//find the cargo that is in the table.
	create tiArray transient;
	if _tblSelected = null and _alternateSelection &lt;&gt; null then
		// for unit test...
		_alternateSelection.copy( tiArray );
	else
		startRow := _tblSelected.fixedRows + 1;
		endRow := _tblSelected.rows;
		if endRow &lt; startRow then
			return;
		endif;
		foreach row in startRow to endRow do
			ti := _tblSelected.accessRow(row).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then
		//14 July 2014	NDL	Par 34559 - removed the code to exclude children.
		//		if ti.isChild then	//18 Jul 2013	NDL	Par 31899
		//			continue;
		//		else
				if ti.myPrimaryPlannedLocation = null then
					tiArray.addExclusive( ti );
				endif;
			endif;
		endforeach;
		if tiArray.isEmpty then
			return;
		endif;
	endif;
	
	//19 Jul 2013	NDL	Par 31899
	msg := "Start test auto plan for " &amp; tiArray.size.String &amp; " items";
	app.writeLog(msg, LogINFO);
	if app.myLoggingForm &lt;&gt; null then
		app.doFormLogging( method, msg, null );
	endif;
	
	self.processAutoPlanNoTrx( tiArray, _terminal, _terminalArea );
	
	//19 Jul 2013	NDL	Par 31899
	foreach result in self.allTestAutoPlanResults do
		if result.isFailed then
			failed := failed + 1;
		else
			success := success + 1;
		endif;
	endforeach;
	msg := "Result of test auto plan - " &amp; success.String &amp; " would plan, " &amp; failed.String &amp; " would not.";
	app.writeLog(msg, LogINFO);
	if app.myLoggingForm &lt;&gt; null or app.isDevelopmentSystem then
		app.doFormLogging( method, msg, null );
	endif;
	
epilog

	delete tiArray;

end;</source>
        <Parameter name="_tblSelected" type="Table" usage="input"/>
        <Parameter name="_alternateSelection" type="ObjectArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_clearResults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getResultFor" id="81e5ddae-c6c8-4de3-9a7d-ed3e2e5377dc">
        <source>getResultFor( ti : CM_TrackedItem ) : CM_TestAutoPlanResult;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	result : CM_TestAutoPlanResult;

begin

	foreach result in self.allTestAutoPlanResults do
		if result.myTrackedItem = ti then
			return result;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_TestAutoPlanResult"/>
    </JadeMethod>
    <JadeMethod name="processAutoPlanNoTrx" id="6837571f-715d-4b0c-ba02-9ecb68b03059">
        <source>processAutoPlanNoTrx(	_tiArray : ObjectArray;
						_terminal : CM_Terminal;
						_terminalArea : CM_TerminalArea
						) protected;
/*

Purpose:			

Parameters:		This version does NOT go into transaction state so is more LOCK friendly
				but does take longer than the one that goes into trans state.

Return Value:		

Date		Who		Reason
17 Jul 2013	cnwndl1	Initial creation	Par 32049
28 Jan 2014	cnwer1	PAR 30823 changes to also do scenario planning
29 Jan 2014 cnwer1	PAR 33386 fror interterminal test autoplan need to clone the ti. This is really because the cloning sets the voyage to the object in the 
					inter-terminal etc.
16 Jun 2016	NDL		try to handle bulk to split locations TFS 2172
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

	agent				: CM_YAAutoplanAgent;
	location			: CM_LocationsController;
	obj					: Object;
	ti, cloneTI			: CM_TrackedItem;
	passport			: CM_Passport;
	str					: String;
	primeYardAllocation : CM_YardAllocation;
	usedYardAllocation	: CM_YardAllocation;
	log					: StringArray512;
	cmifYAPlanScenario  : CMIF_YAAutoPlanSenario;
	splitLocations		: String;
begin

	// Check licensing and create agent if necessary.
	if not app.checkYardAllocationLicensing(_terminal) then
	 	return;
	endif;
	
	agent := app.myYAAgent;
	passport := app.myPassport;
	passport.setMyTerminal(_terminal);
	
	on Exception do agent.testPlanLockException(exception);	// catch Locks and Deadlocks
	
	agent.resetTestLocations();
	
	foreach obj in _tiArray do
		
		// Auto plan the ti
		// Tell the agent we are only testing.
		agent.setIsSenarioTesting(true, false);
		agent.initialiseForTrxStart();
		agent.clearForMulti();
		cmifYAPlanScenario:=null;
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			
			if ti.myTerminal &lt;&gt; _terminal then
				//epr par 33386 29/1/14
				cloneTI :=ti.cloneForInterTerminalPreNote(_terminal,true);
				agent.autoPlanTiYA(_terminal, _terminalArea, null, null, cloneTI, null);
			else
				agent.autoPlanTiYA(_terminal, _terminalArea, null, null, ti, null);
			endif;
		elseif obj.isKindOf(CMIF_YAAutoPlanSenario) then
			agent.autoPlanTiVerbose(_terminal, _terminalArea, obj.CMIF_YAAutoPlanSenario);
			ti:=obj.CMIF_YAAutoPlanSenario.getMyTrackedItem;
			cmifYAPlanScenario:=obj.CMIF_YAAutoPlanSenario;
			
		endif;
		
		splitLocations := null;
		location := agent.getFoundLocation();
		if location = null then
			splitLocations := agent.getSplitLocsString();
		endif;
		usedYardAllocation := agent.getYardAllocationUsed();
		
		if  obj.isKindOf(CMIF_YAAutoPlanSenario) and  location &lt;&gt; null  then
			primeYardAllocation:=	usedYardAllocation;
		else
			primeYardAllocation := agent.getPrimeYardAllocation;
		endif;
		log := agent.getLoggingArray(true);
		
		if  obj.isKindOf(CMIF_YAAutoPlanSenario) then
			agent.setYAAutoPlanToNull();
			agent.setCurrentYAAutoPlanToNull();
		endif;
		
		if location &lt;&gt; null or splitLocations &lt;&gt; null then
			
			self.addPlannedResult(	location,	//_plannedLoc : CM_LocationsController;
									usedYardAllocation,	//_myAllocationUsed : CM_YardAllocation;
									ti,	//_myTrackedItem : CM_TrackedItem;
									cmifYAPlanScenario,
									primeYardAllocation,	//_myPrimeYardAllocation : CM_YardAllocation;
									log,	//_log : StringArray512;
									splitLocations	//_splitLocations : String
									);
									
			if location &lt;&gt; null then
				agent.addYATestLocation( location, ti ); //jlier1 TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
 
			endif;
			
		else
			
			self.addFailedResult(	ti,	//_myTrackedItem : CM_TrackedItem;
									cmifYAPlanScenario,
									primeYardAllocation,	//_myPrimeYardAllocation : CM_YardAllocation;
									log	//_log : StringArray512
									);
			
		endif;
		
		if cloneTI &lt;&gt; null then
			delete cloneTI;
		endif;
	endforeach;
	
	return;
	
epilog
	if cloneTI &lt;&gt; null then
		delete cloneTI;
	endif;
	if agent &lt;&gt; null then
		agent.resetTestLocations();	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_tiArray" type="ObjectArray"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
</Class>
