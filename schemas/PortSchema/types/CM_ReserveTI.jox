    <JadeMethod name="getWeightLoaded" id="d0cc1bfd-32f7-4bcd-bfeb-c3c04deeed76">
        <source>getWeightLoaded(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2017	cnwndl1	Initial creation	TFS 3477

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	stagedWeight : Decimal[16,4];

begin
	
	ti := self.getTI;
	
	if ti &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; null then
		if not ti.isOnSite then
			return null;
		endif;
		if ti.isChild then
			return null;
		endif;
		lc := ti.myPrimaryActualLocation;
		if lc.isVehicle or lc.isTILCController then
			return ti.totalWeight;
		endif;
	endif;
		
	return null;

epilog
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightStaged" id="404d341d-fe14-49a2-9658-03ec528b564b">
        <source>getWeightStaged():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2016	cnwndl1	Initial creation	TFS 3037 / 2369

*/
vars
	ti : CM_TrackedItem;
	ta : CM_TerminalArea;
	stagedWeight : Decimal[16,4];
begin
	
	ti := self.getTI;
	
	if ti &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; null then
		if not ti.isOnSite then
			return stagedWeight;
		endif;
		if ti.isChild then
			return stagedWeight;
		endif;
		ta := ti.myPrimaryActualLocation.myTerminalArea;
		if ta &lt;&gt; null then
			if ta.type = TA_TYPE_YARD_INTERCHANGE then
				// Its actually already staged
				stagedWeight := ti.totalWeight;
			endif;
		endif;
	endif;
	return stagedWeight;

epilog
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
