    <JadeMethod name="getNumTEU" id="f4b3978d-1580-4007-a26b-20d0828ed90e">
        <source>getNumTEU() : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
28 July 2022	navsrk20	ChangeRequest 53917: MTN - Cargo Types TEUs for GC

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,4];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0;
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBreakBulk);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		if self.totalQuantity &lt;&gt; 0 then
			teu := self.totalQuantity/teu;
		endif;
	elseif ct.teuMultiplier = TEUMultiplierIndexW then
		if self.totalWeight &lt;&gt; 0 then
			teu := self.totalWeight/teu;
		endif;
	endif;
	
	return teu;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNumTEUDeci" id="4607a66a-0635-4522-9734-2472d79ce255">
        <source>getNumTEUDeci(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navsrk20	Bug 54611: MTN - getNumTEUDeci not returning value as expected

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,2];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0; 
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBreakBulk);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		if self.totalQuantity &lt;&gt; 0 then
			teu := self.totalQuantity/teu;
		endif;
	elseif ct.teuMultiplier = TEUMultiplierIndexW then
		if self.totalWeight &lt;&gt; 0 then
			teu := self.totalWeight/teu;
		endif;
	endif;
	
	return teu;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumTEUOfQty" id="275b5796-e77e-45c9-bc90-97316409df41">
        <source>getNumTEUOfQty(_qty:Real) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
10 Aug 	2022	navra1		TFS 53105

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,4];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0;
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBreakBulk);
	
	if _qty &lt;&gt; null then
		return _qty/teu;
	endif;
	
	//navra1 - 12th Aug 2022 - TFS 53105
	//If sent _qty is null, understand it as 0
	//return teu;	
	return 0;	
	
end;</source>
        <Parameter name="_qty" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="4ffa351b-414a-4d91-b523-0f6a6de54368">
