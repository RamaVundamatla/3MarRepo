    <JadeMethod name="getBOLTerminal" id="bc71f2aa-3611-4c6f-8425-563715b47ae6">
        <updating/>
        <source>getBOLTerminal(_terminal : CM_Terminal; _createIfNull : Boolean) : CM_BOLTerminal updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpBOLTerminal	: CM_BOLTerminal;

begin

	if _terminal = null then
		return tmpBOLTerminal;
	endif;
	
	tmpBOLTerminal := self.allBOLTerminals[_terminal];
	if tmpBOLTerminal = null and _createIfNull and (not self.isTransient) then
		create tmpBOLTerminal persistent;
		tmpBOLTerminal.setForCreate(_terminal);
		
		self.allBOLTerminals.add(tmpBOLTerminal);
		if _terminal = self.myTerminal then
			self.myOrigBOLTerminal := tmpBOLTerminal;
		endif;
	endif;
	
	return tmpBOLTerminal;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_createIfNull" type="Boolean"/>
        <ReturnType type="CM_BOLTerminal"/>
    </JadeMethod>
    <JadeMethod name="getBolTfrTransAndTis" id="517765e1-8f7c-45cd-97ae-511db95b5a17">
        <source>getBolTfrTransAndTis(	_allTrx : CM_BOLTrnsactByTypeDateDict input;
						_allTIs : CM_TIArray input
						);
/*

Purpose:			

Parameters:			Starting from this BOL get the related tfr transactions and Tis
					I.e All Tis that are on this Bol or have passed thru it, which BOLs
					they came from and which Bols they went too.

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation

*/

vars

	otherBOL : CM_BOLIn;	
	trx : CM_BOLTransaction;
	ti : CM_TrackedItem;

begin

	//gets the transactions going up the tree.
	foreach ti in self.allTrackedItems do
		_allTIs.addExclusive( ti );
		self.getTfrFromTrnsFor( _allTrx, ti );
	endforeach;
	
	//gets the bol transactions (and tis) going down the tree.
	foreach trx in self.allBOLTransactions discreteLock do
		if trx.type = TRANS_TYPE_BOL_TRANSFER then
			if trx.CM_BOLTransferTransaction.isTransferOut or trx.CM_BOLTransferTransaction.isUnassignTrn then
				ti := trx.CM_BOLTransferTransaction.myTrackedItem;
				if not _allTIs.includes(ti ) then
					_allTIs.addExclusive( ti );
					if ti.myReceivalBOL &lt;&gt; null then
						ti.myReceivalBOL.getTfrFromTrnsFor( _allTrx, ti );
					else
						_allTrx.addNoDuplicates( trx, false );
					endif;
				endif;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_allTrx" type="CM_BOLTrnsactByTypeDateDict" usage="input"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="4af519c9-0127-4c9f-bab4-53538d39f754">
        <source>getConsignee() : CM_ConsigneeConsignor;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	detail : CM_BOLDtl;
begin
	if self.myConsignee &lt;&gt; null then
		return self.myConsignee;
	endif;
	
	foreach detail in self.allBOLDtls discreteLock do
		if detail.consigneeCode &lt;&gt; null then
			return app.myRoot.allConsigneeConsignors[detail.consigneeCode];
		
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
