    <JadeMethod name="myCurrentWagon" id="ace8420f-a00f-4932-a043-9586b2132922">
        <methodInvocation>mapping</methodInvocation>
        <source>myCurrentWagon(set : Boolean; _value : CM_Wagon io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars

begin
	if set then
		if self.myCurrentWagon &lt;&gt; null then
			self.endNotification(self.myCurrentWagon, Wagon_Update_Cargo_Event);
		endif;
		if _value &lt;&gt; null then
			self.beginNotification(_value, Wagon_Update_Cargo_Event, Response_Continuous, 0);
		endif;
	endif;
epilog

end;</source>
