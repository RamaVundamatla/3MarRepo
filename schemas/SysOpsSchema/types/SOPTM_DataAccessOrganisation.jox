<Class name="SOPTM_DataAccessOrganisation" id="1b9c91c4-707d-4ebb-b520-5359114dd037">
    <superclass name="SOPTM_DataAccess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="e6957421-0e6d-4146-80fa-9e0e4927bb57">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_DataAccessOrganisations;
	self.permissionView	 := PmCmpDAOrgTableView;
	self.permissionMaint := PmCmpDAOrgTableMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="31ba78f8-352a-4117-97e0-fedca0276b98">
        <source>getMultiGroupHeading(): String;

// Created by cnwdvb1 on 26 July 2007

vars

begin
	return 'Organisations';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="159055e2-803f-4066-92c8-f9a547798746">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	
	theForm.setupForDataAccessController('Organisations', SOP_TableMaintForm::displayEntryOrganisation.name, CM_Organisation);
	theForm.mulSelect1.setAvailable(app.myRoot.allOrganisations, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="215002a3-0b0a-4caf-b98c-003f82935686">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
    theForm.chkIncludeNotSet.visible := true; // AKB2004SEP
  	theForm.myDataAccessClass := CM_Organisation;
	theForm.shtMultiSelect1.caption := "Organisation";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;

	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
    theForm.mulSelect1.setSelected(pDataAccess.allObjects);
    self.disableMulSelect1Contents();
	
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="5883bd3d-c053-4b6d-9232-b15bc7059e55">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if obj.CM_DataAccessController.classContainedName = CM_Organisation.name then //7.3.09 cnwgb1 PAR 19041
		return inheritMethod(table, obj);
	else
		return null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
