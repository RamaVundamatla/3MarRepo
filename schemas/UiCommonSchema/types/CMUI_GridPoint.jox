    <JadeMethod name="drawTI" id="fb7dd37e-78f0-4103-9246-edc06e23c1bd">
        <updating/>
        <source>drawTI(_theFrame: CMUI_GridAreaFrame input; _theTI : CM_TrackedItem;
		_theGridAttributes : CMUI_GridAttributes input;
	  	_x1, _y1, _x2, _y2 : Real) protected, updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lOuterColourUpper, 
	lOuterColourLower,
	lTIColour,
	lWeight,
	theTextWidth,
	theWeightWidth, 
	theCharacterWidth : Integer;
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	lDisplayMode,idx,lViewMode, selOffSet, halfOffset, theFontSize, theWidth, offset, offsetX,iconTot : Integer;
	lFactor : Real;
	theAttibuteString, theString : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theHoleWidth : Integer;
	theGridArea : CMUI_GridArea;
	theFrame: CMUI_GridAreaFrame;
	theSDF : CMUI_ScrollableDrawingFrame;
	drawNoMore : Boolean;
	endX : Real;
	isFortyFooter : Boolean;
begin

	theFrame 	:= _theFrame;
	theGridArea := self.myGridArea;
	theSDF 		:= theGridArea.mySDF;
	lFactor 	:= theGridArea.scaleXFactor;
	lDisplayMode := theSDF.displayMode;
	lViewMode 	:= theSDF.viewMode;
	theFrame.drawFontName := "Arial";
	theFontSize := (self.FontSize * lFactor).Integer;
	theWidth := _theGridAttributes.width;
	lWeight := _theGridAttributes.weight.Integer;
	
//	self.drawTIAddViewModeLegend(_theGridAttributes);	
	tm_y1 := _y1;
	tm_x1 := _x1;
	
	idx := theWidth;
	isFortyFooter := false;
	if idx &gt; 1 then
		// This TI spans more than one controller so have to
		// find subsequent controllers and alter x2
		isFortyFooter := true;
		if theGridArea.flipHorizontal then
			tm_x1 := _x2 - (idx * (_x2 - _x1)) - 2;
			tm_x2 := _x2;
		else
			tm_x2 := tm_x1 + (idx * (_x2 - tm_x1)) + 2;
		endif;
	else
		tm_x2 := _x2;
	endif;
	tm_x2 := tm_x2 - 1;
	tm_y2 := _y2 - 1;

	if _theTI.isKindOf(CM_Tower) then
		lTIColour := 33023; // ORANGE
	else
		lTIColour := _theGridAttributes.allDisplayColors[lViewMode];
	endif;

	if lTIColour = NullColour then
		lTIColour := White;
	endif;
	// if they have used the selector this will not be empty. If this TI is not in the selector collection then show in White
	if (not theSDF.allSelectorTIs.isEmpty) then
		if (not theSDF.allSelectorTIs.includes(_theTI)) then	
			lTIColour := White;
		endif;
	endif;

	if theGridArea.allSelectedTrackedItems.includes(_theTI) then
		theFrame.drawFillColor := White;
		theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  White); 
		if lFactor = 1 then
			selOffSet := 2;
		elseif lFactor = 4 then
			selOffSet := 4;
		else
			selOffSet := 3;
		endif;
		tm_x1 := tm_x1 + selOffSet;
		tm_y1 := tm_y1 + selOffSet;
		tm_x2 := tm_x2 - selOffSet;
		tm_y2 := tm_y2 - selOffSet;
		
		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawWidth := 1;
		theFrame.drawStyle := Frame.DrawStyle_Solid; //DrawStyle_Dash;

	else
		lOuterColourUpper := White;
		lOuterColourLower := DarkGray;
		theFrame.drawWidth := 1;
		theFrame.drawStyle := Frame.DrawStyle_Solid;
	endif;

	theFrame.drawFillColor := lTIColour;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  lTIColour); 
	theFrame.drawLine(tm_x1, tm_y1, tm_x2 + 1, tm_y1 ,  lOuterColourUpper);
	theFrame.drawLine(tm_x1, tm_y1, tm_x1, tm_y2,  lOuterColourUpper);
	theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
	theFrame.drawLine(tm_x1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	endX := tm_x2 - 3;

	theFrame.drawWidth := 1;

	// work out the width of the rectangle and split up, to get the even width for the attribute characters
	if theWidth &lt; 1 then
		theWidth := 1;
	endif;

	theCharacterWidth := ((tm_x2 - tm_x1) / (3 * theWidth)).Integer;

	tm_x1 := tm_x1 + (theCharacterWidth / 2).Integer;
	if _theGridAttributes.height = Ti_Half_Height then
		if lFactor = 2 then
			theFontSize := theFontSize - 2;
			halfOffset := 2;
		elseif lFactor = 3 then
			theFontSize := theFontSize - 5;
			halfOffset := 0;
		elseif lFactor = 4 then
			theFontSize := theFontSize - 5;
			halfOffset := 5;
		elseif lFactor = 1.5 then
			halfOffset := 5;
		elseif lFactor = 1 then
			halfOffset := 1;
		endif;

		tm_y1 := _y2 + halfOffset;
	else
		tm_y1 := _y2;
	endif;


	drawNoMore := false;
	if lFactor &gt;= 1.0 then
		if lFactor = 1 then
			theFontSize := 8;
		endif;
		iconTot := 0;
		foreach theAttibuteString in _theGridAttributes.allDisplayIcons do
			if theAttibuteString[1:12] = PicTIPlanned then
				if lDisplayMode = DISPLAY_MODE_PLAN then
					if theAttibuteString.length &gt; 12 then
						if theAttibuteString[13:end].Integer = 1 then
							continue;
						endif;
					else
						continue;
					endif;
				endif;
				theString := PicTIPlanned;
			else
				theString := theAttibuteString;
			endif;


			theDrawingAttribute := theSDF.allDrawingAttributes[theString];
			if theDrawingAttribute &lt;&gt; null then
				// normally in plan mode we do not show a P cos that is what we are looking at, but for DLR we do show a P
				// we have added the number of planned moves that this TI has onto the end. If more than 1 then display a 'P'
				if theDrawingAttribute.code = PicTIQueued and
				   lDisplayMode = DISPLAY_MODE_QUEUE then
					continue;
				endif;
				iconTot := iconTot + 1;
				theTextWidth := self.drawTITextLeft(theFrame, theDrawingAttribute.fontName, theFontSize,
													theDrawingAttribute.fontCharacter.Character,
													theDrawingAttribute.colour,
													tm_x1.Integer, _y1.Integer, tm_y1.Integer);
	
				if iconTot = 1 and lFactor = 1 then // only show 1 icon in the smallest scale - this is so that they can see the 'P' planned icon.
					break;
				endif;

				tm_x1 := tm_x1 + theCharacterWidth;
				
				// Only 2 icons on a 20' and 5 on a 40'
				if (isFortyFooter and iconTot &gt;= 5)
				or (not isFortyFooter and iconTot &gt;= 2) then
					break;
				endif;
			endif;
		endforeach;
	endif;
	// always draw the weight
	if lFactor = 1 then
		theFrame.drawFontSize :=8;
		offset := 0;
	elseif lFactor = 1.5 then
		theFrame.drawFontSize :=10;
		offset := 1;
	elseif lFactor = 2 then
		theFrame.drawFontSize :=10;
		offset := 3;
	elseif lFactor = 3 then
		theFrame.drawFontSize := 16;
		offset := 6;
	elseif lFactor = 4 then
		theFrame.drawFontSize := 20;
		offset := 8;
	endif;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
	theFrame.drawFontName := "Ariel";
	theFrame.drawTextAt(lWeight.String, endX , _y1 + offset,_theFrame.drawFillColor.getInverseColour);
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTIAddViewModeLegend" id="4b2374a9-2388-4ffc-b267-a700560b8abb">
        <source>drawTIAddViewModeLegend(_theGridAttributes : CMIF_GridAttributes);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theCode : String;
	theViewMode : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
	theColour : Integer;
begin
	theSDF := self.myGridArea.mySDF;
	theViewMode := theSDF.viewMode;
	theCode := _theGridAttributes.allDisplayCodes[theViewMode];
	theColour := _theGridAttributes.allDisplayColors[theViewMode];

	if (not theSDF.myViewModeAttribute.allDisplayIcons.includes(theCode)) then
		theSDF.myViewModeAttribute.allDisplayIcons.add(theCode);
		theSDF.myViewModeAttribute.allDisplayColors.add(theColour);
	endif;

end;</source>
        <Parameter name="_theGridAttributes" type="CMIF_GridAttributes"/>
    </JadeMethod>
    <JadeMethod name="drawTITextLeft" id="4a35b192-0bf8-4d6a-ba96-6213ea1f772b">
        <source>drawTITextLeft(_theFrame : CMUI_GridAreaFrame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _leftX, _topY, _bottomY : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	textTopY : Integer;
	theTextWidth, theTextHeight : Integer;

begin
	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	// must set the fontSize as it is used to calculate the text height and width
	_theFrame.fontSize := _theFontSize;
	
	theTextWidth := _theFrame.getTextExtent(_theCharacter);
	theTextHeight := _theFrame.getTextHeight(_theCharacter);
	
	textTopY := (((_bottomY - _topY) - theTextHeight) div 2) + _topY;

	_theFrame.drawTextAt(_theCharacter, _leftX, textTopY, _theFrame.drawFillColor.getInverseColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_leftX" type="Integer"/>
        <Parameter name="_topY" type="Integer"/>
        <Parameter name="_bottomY" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTITextLeftNew" id="2488efa3-a700-4fad-a20e-f5bbed233e72">
        <source>drawTITextLeftNew(_theFrame : CMUI_GridAreaFrame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _theX, _theY1, _theY2 : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTextWidth, theX, theY,theTextHeight : Integer;
	zoomScale : Real;
begin

	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;
	_theFrame.fontSize := _theFontSize;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	
//	zoomScale := _theFontSize / self.FontSize; // self.myGridArea.scaleXFactor; 
//	theTextWidth := (_theFrame.getTextExtent(_theCharacter) * zoomScale).Integer;
	theTextHeight := _theFrame.getTextHeight(_theCharacter);
	theX := _theX; // - theTextWidth - 2;

/*	if self.myGridArea.scaleXFactor = 1 then
		theTextHeight := theTextHeight - 5;
	elseif self.myGridArea.scaleXFactor = 1.5 then
		theTextHeight := theTextHeight - 4;
	elseif self.myGridArea.scaleXFactor = 2 then
		theTextHeight := theTextHeight - 6;
	else
		theTextHeight := theTextHeight - 10;
	endif;
*/
//	theY := _theY - theTextHeight;
//	theY := (((_theY - topY) - theTextHeight) div 2) + topY;
	theY := (((_theY2 - _theY1) - theTextHeight) / 2).Integer + _theY1;
/*
	if self.myGridArea.scaleXFactor &gt; 1 then
		_theFrame.drawTextAt(_theCharacter, theX + 1,theY - 1,White); // RIGHT &amp; UP
		_theFrame.drawTextAt(_theCharacter, theX - 1,theY + 1,White); // LEFT &amp; DOWN
		_theFrame.drawTextAt(_theCharacter, theX + 1,theY + 1,White); // RIGHT &amp; DOWN
		_theFrame.drawTextAt(_theCharacter, theX - 1,theY - 1,White); // LEFT &amp; UP
	endif;
*/
//	_theFrame.drawTextAt(_theCharacter, theX,theY,_theColour);
	_theFrame.drawTextAt(_theCharacter, theX,theY,_theFrame.drawFillColor.getInverseColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY1" type="Integer"/>
        <Parameter name="_theY2" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTITextRight" id="54e5e55f-c9c2-44ad-9d87-56bd953b6b9f">
        <source>drawTITextRight(_theFrame : CMUI_GridAreaFrame input; _theFontName : String; _theFontSize : Integer; _theCharacter : String;
						_theColour : Integer; _theX, _theY : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the width
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTextWidth, theX, theY,theTextHeight : Integer;
	zoomScale : Real;
begin

	_theFrame.drawFontName := _theFontName;
	_theFrame.drawFontSize := _theFontSize;

	zoomScale :=  (_theFontSize / 8);
	theTextWidth := (_theFrame.getTextExtent(_theCharacter) * zoomScale).Integer;
	theTextHeight := (_theFrame.getTextHeightForWidth(_theCharacter,theTextWidth) * zoomScale).Integer;

	theX := _theX - theTextWidth - 2;
	if zoomScale = 1 then
		theY := _theY - theTextHeight + 2;
	elseif zoomScale = 1.5 then
		theY := _theY - theTextHeight + 3;
	elseif zoomScale = 2 then
		theY := _theY - theTextHeight + 3;
	else
		theY := _theY - theTextHeight + 5;
	endif;
	_theFrame.drawTextAt(_theCharacter, theX + 1,theY + 1,White);
	_theFrame.drawTextAt(_theCharacter, theX - 1,theY - 1,White);
	_theFrame.drawTextAt(_theCharacter, theX,theY,_theColour);

	return theTextWidth;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontSize" type="Integer"/>
        <Parameter name="_theCharacter" type="String"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAutoMaskTIs" id="6c64a9a0-0296-4664-bba1-d43af0923bcf">
        <updating/>
        <source>getAutoMaskTIs(_dict : Collection input; _mode : Integer; _dischargePort, _commodityGroup, _voyageCode : String) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ti, theDummy	: CM_TrackedItem;
	tmpArray2 : CM_TIArray;
	needRedraw	: Boolean;
begin
	if _dict = null or _mode = null then 
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Null Dict/mode passed to method. Contact Developer', null, null);
		return;
	endif;

	if _dischargePort = null and 
		_commodityGroup = null and 
		_voyageCode = null then
		return;
	endif;
	
	if _mode = DISPLAY_MODE_ACTUAL then
		tmpArray2 := self.allTrackedItems;
	elseif _mode = DISPLAY_MODE_QUEUE then
		tmpArray2 := self.allQueuedTrackedItems;
	elseif _mode = DISPLAY_MODE_PLAN then
		tmpArray2 := self.allPlannedTrackedItems;
	endif;

	if tmpArray2.isEmpty then
		return;
	endif;
	
	foreach ti in tmpArray2 do
		if ti.id = "DUMMY" then
			continue;
		endif;
		// must match discharge port
		// must match voyage
		// must match commodity
		if ti.dischargePort &lt;&gt; _dischargePort or
		   ti.voyageCode &lt;&gt; _voyageCode or
		   ti.commodityGroup &lt;&gt; _commodityGroup then
			needRedraw := true;
			continue;
		endif;
		// we have a match, make sure it's not already in dict as 40' ti span two controllers
		if (not _dict.includes(ti)) then
			_dict.add(ti);
		endif;
	endforeach;

	if needRedraw then
		self.drawSelf(self.myGridArea.myGridAreaFrame);
	endif;
	
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_commodityGroup" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="cc98fffa-7ef6-4e0c-bb13-02635c95fcdd">
        <source>getExtraInfoForPoint(x, y : Real; _dataContainer : CM_DataContainer) : Object;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------

begin
	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoObject" id="b267fae3-8930-40c7-a85f-a56938ef1106">
        <source>getExtraInfoObject() : Object;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getIdxfromYPos" id="f2cfa29d-ff8f-4fc3-8113-a14caf703060">
        <source>getIdxfromYPos(_y2 : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, lCellPos : Integer;
begin
	lCellPos := (_y2 - self.y1).Integer;
	
	idx := lCellPos div self.cellHeight;
//	if self.myLocationsController.myTerminalArea.id = "W" then
//		write "ID: W " &amp; self.myLocationsController.CM_StackController.getID &amp; " CH: " &amp; self.cellHeight.String &amp; " y1: " &amp; y1.String &amp; " y2: " &amp; y2.String
//			&amp; " _y2: " &amp; _y2.String &amp; " idx: " &amp; idx.String;
//	endif;
	return idx;

end;</source>
        <Parameter name="_y2" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
