    <JadeMethod name="isProduct_Match" id="700fa37c-5547-4f82-bc8d-181dbd0044df">
        <source>isProduct_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria

