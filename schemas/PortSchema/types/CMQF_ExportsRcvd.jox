<Class name="CMQF_ExportsRcvd" id="c1406d87-5895-4d32-aab2-d0413dba0975">
    <superclass name="CMQF_Export"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="512544d5-bd4d-4685-9fa8-3ee8fc31c550">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	21 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/

vars
	ti					: CM_TrackedItem;
	tran				: CM_TITransaction;
	col					: CM_TITransactionByDateTypeDict;
	terminal			: CM_Terminal;
	endDateTime			: TimeStamp;
	breakOut			: Boolean;
	tiArray				: CM_TIArray;
	ta					: CM_TerminalArea;
	rail				: CM_Rail;
	railLine			: CM_RailLine;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);


	create col transient;
	//search for receivals
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAll(TRANS_TYPE_RECEIVE, self.startDate.TimeStamp, endDateTime, null , self ,col );
	endforeach;
	
	
	foreach tran in col do
		ti := tran.myTrackedItem;
		if ti &lt;&gt; null then		
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017				
				endif;
			endif;
		endif;
//		if breakOut then
//			return;
//		endif;
	
	endforeach;

	//must also check the rail for confirmed TIs
	
	create tiArray transient;
	foreach terminal in self.allTerminals do
		foreach ta in terminal.allTerminalAreasByTypeId discreteLock where ta.type = TA_TYPE_RAILWAY_TRACK do
			
			tiArray.clear;		
			if CM_Rail.hasInstance(ta) then
				rail := ta.CM_Rail;
				foreach railLine in rail.allRailLines discreteLock do
					railLine.getAllTrackedItems(tiArray);
					if breakOut then
						return;
					endif;
				endforeach;
			endif;
			
			//wont be thousands - can take this hit
			foreach ti in tiArray do
				if self.includeFromRail(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017					
					endif;
				endif;
				if breakOut then
					return;
				endif;
			endforeach;
			
		endforeach;
	endforeach;	


epilog
	delete tiArray;
	delete col;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includeFromRail" id="01a1cf69-8b22-49ee-a071-7eeac34527c9">
        <updating/>
        <source>includeFromRail(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _ti.receivedDT.date &gt; self.endDate or
	_ti.receivedDT.date &lt; self.startDate then
		return false;
	endif;
	
	return self.checkStatusIncludesObject(_ti, _passport, _breakOut);
//	if self.includesObject(_ti, _passport, _breakOut) then
//		return true;
//	endif;
	
	return false;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
